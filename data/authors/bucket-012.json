{"严抑":{"slug":"严抑","name":"严抑","dynasty":"宋","style":"","life":"","origin":"","seal":"严","bio":[],"works":[{"id":"c78-335","title":"洞仙歌·云车鹤盖","kind":"词"}]},"云端和尚":{"slug":"云端和尚","name":"云端和尚","dynasty":"唐","style":"","life":"","origin":"","seal":"云","bio":["云端和尚，与泰钦、郁山主同时。诗一首。（《全唐诗》无云端和尚诗）"],"works":[{"id":"t55-984","title":"郁山主赞","kind":"诗"}]},"元友直":{"slug":"元友直","name":"元友直","dynasty":"唐","style":"","life":"","origin":"","seal":"元","bio":["元友直，结之子，大历进士。诗一首。"],"works":[{"id":"t15-550","title":"小苑春望宫池柳色","kind":"诗"}]},"大同济禅师":{"slug":"大同济禅师","name":"大同济禅师","dynasty":"唐","style":"","life":"","origin":"","seal":"大","bio":["大同济禅师，嗣希迁。在澧州。曾访庞蕴。","诗一首。（《全唐诗》无大同济禅师诗）"],"works":[{"id":"t53-111","title":"颂","kind":"诗"}]},"崔邠":{"slug":"崔邠","name":"崔邠","dynasty":"唐","style":"字处仁","life":"","origin":"","seal":"崔","bio":["崔邠，字处仁，贝州武城人。第进士，官补阙，疏论裴延龄奸。由中书舍人迁吏部侍郎，久乃为太常卿，知吏部尚书铨。","为人沈密清俭，兄弟以孝敬闻。诗二首。"],"works":[{"id":"t0-752","title":"郊庙歌辞 享文敬太子庙乐章 亚献终献","kind":"诗"},{"id":"t17-543","title":"礼部权侍郎阁老史馆张秘监阁老有离合酬赠之什宿直吟玩聊继此章","kind":"诗"},{"id":"t17-544","title":"享文恭太子庙乐章","kind":"诗"}]},"徐光溥":{"slug":"徐光溥","name":"徐光溥","dynasty":"唐","style":"","life":"","origin":"","seal":"徐","bio":["徐光溥，蜀人。事孟知祥，为观察判官，知祥称尊号，进翰林学士。后主昶时，拜中书侍郎同平章事。","诗二首。"],"works":[{"id":"t42-529","title":"题黄居采秋山图","kind":"诗"},{"id":"t42-530","title":"同刘侍郎咏笋","kind":"诗"},{"id":"t56-259","title":"秋山图歌","kind":"诗"}]},"徐知仁":{"slug":"徐知仁","name":"徐知仁","dynasty":"唐","style":"","life":"","origin":"","seal":"徐","bio":["徐知仁，开元时人。诗一首。"],"works":[{"id":"t5-454","title":"奉和圣制送张说巡边","kind":"诗"}]},"徐知证":{"slug":"徐知证","name":"徐知证","dynasty":"唐","style":"","life":"","origin":"","seal":"徐","bio":["知证，徐温第五子也。在吴，历州刺史至节度使。李氏受禅，封江王，改魏王。","至元宗之世，尤见优礼。年四十三卒。（《全唐诗续补遗》卷十五录徐知证诗，无事迹。","今据马氏《南唐书》卷八、《十国春秋》卷二十补传）"],"works":[{"id":"t51-639","title":"东林寺天祚二年联句","kind":"诗"},{"id":"t55-351","title":"无题","kind":"诗"},{"id":"t55-352","title":"题东林寺联句","kind":"诗"}]},"敬相":{"slug":"敬相","name":"敬相","dynasty":"唐","style":"","life":"","origin":"","seal":"敬","bio":[],"works":[{"id":"t51-460","title":"赠妓（相牧庐州，有朝客留意饮妓，祖送短亭，妓车后至，相赠之曰：）","kind":"诗"}]},"李宗闵":{"slug":"李宗闵","name":"李宗闵","dynasty":"唐","style":"字损之","life":"","origin":"","seal":"李","bio":["李宗闵，字损之，擢进士，补洛阳尉。累官驾部郎中、知制诰。穆宗即位，拜中书舍人。","宝历初，进兵部侍郎。太和中，同中书门下平章事，迁中书侍郎，出为山南西道节度使，寻复秉政，后贬死。诗一首。"],"works":[{"id":"t25-273","title":"赠毛仙翁","kind":"诗"}]},"杜俨":{"slug":"杜俨","name":"杜俨","dynasty":"唐","style":"","life":"","origin":"","seal":"杜","bio":["杜俨，新安丞。诗一首。"],"works":[{"id":"t10-6","title":"客中作","kind":"诗"}]},"林横舟":{"slug":"林横舟","name":"林横舟","dynasty":"宋","style":"","life":"","origin":"","seal":"林","bio":[],"works":[{"id":"c76-54","title":"大江词・念奴娇·一蓂呈秀","kind":"词"}]},"潘孟阳":{"slug":"潘孟阳","name":"潘孟阳","dynasty":"唐","style":"","life":"","origin":"","seal":"潘","bio":["潘孟阳，侍郎炎之子，以荫进，登博学宏辞。母，刘晏女也。公卿多父友及外祖宾从，故得荐用。","累至兵部郎中，权知户部侍郎，年未四十。宪宗初，巡省江淮，宪宗尝诫江淮宣慰使郑敬曰：“朕宫中用度，一匹已上，皆有簿领，惟赠恤贫民，无所计算。卿宜体吾怀，勿学潘孟阳奉使，但务酣饮，游山寺也。","”诗三首。"],"works":[{"id":"t17-554","title":"和权载之离合诗","kind":"诗"},{"id":"t17-555","title":"春日雪以回文绝句呈张荐权德舆","kind":"诗"},{"id":"t17-556","title":"元日和布泽","kind":"诗"}]},"石麟":{"slug":"石麟","name":"石麟","dynasty":"宋","style":"","life":"","origin":"","seal":"石","bio":[],"works":[{"id":"c76-421","title":"贺新凉・贺新郎·一骑飞来速","kind":"词"},{"id":"c76-422","title":"金缕词・贺新郎·欲上南楼寿","kind":"词"},{"id":"c76-423","title":"水调歌头·九叶仙茅秀","kind":"词"},{"id":"c76-424","title":"鹧鸪天·欲寿中山不老仙","kind":"词"},{"id":"c76-425","title":"水调歌头·日暖唐宫绣","kind":"词"}]},"裴璀":{"slug":"裴璀","name":"裴璀","dynasty":"唐","style":"","life":"","origin":"","seal":"裴","bio":[],"works":[{"id":"t0-599","title":"郊庙歌辞 享龙池乐章 第十章","kind":"诗"}]},"谢勮":{"slug":"谢勮","name":"谢勮","dynasty":"唐","style":"","life":"","origin":"","seal":"谢","bio":["谢勮，不知何许人。诗四首。"],"works":[{"id":"t16-786","title":"游烂柯山 一","kind":"诗"},{"id":"t16-787","title":"游烂柯山 二","kind":"诗"},{"id":"t16-788","title":"游烂柯山 三","kind":"诗"},{"id":"t16-789","title":"游烂柯山 四","kind":"诗"}]},"赵子崧":{"slug":"赵子崧","name":"赵子崧","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"