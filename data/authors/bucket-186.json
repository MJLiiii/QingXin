{"刘思真":{"slug":"刘思真","name":"刘思真","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"t57-348","title":"丑妇赋","kind":"诗"}]},"应次蘧":{"slug":"应次蘧","name":"应次蘧","dynasty":"宋","style":"","life":"","origin":"","seal":"应","bio":[],"works":[{"id":"c73-970","title":"点绛唇·雪意娇春","kind":"词"}]},"张嗣初":{"slug":"张嗣初","name":"张嗣初","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"t17-148","title":"赋得白云起封中","kind":"诗"},{"id":"t17-149","title":"春色满皇州","kind":"诗"},{"id":"c76-621","title":"水调歌头·名节本来重","kind":"词"}]},"张翚":{"slug":"张翚","name":"张翚","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张翚，曲阿人。开元二十三年进士，为萧颖士同年生，官校书郎。诗二首。"],"works":[{"id":"t5-531","title":"游栖霞寺","kind":"诗"},{"id":"t5-532","title":"绝句","kind":"诗"}]},"张诚":{"slug":"张诚","name":"张诚","dynasty":"唐","style":"字老莱","life":"","origin":"","seal":"张","bio":["诚，字老莱，吴郡人。年十八，以通经中第，授苏州长洲尉。后服丧退归，复选授左武卫骑曹参军。","肃宗时授密县主簿，迁砀山县令。岭南节度使李勉奏授试大理评事，充岭南观察推官。未赴而卒，时为大历三年十一月，卒年五十五。","（《全唐诗》无张诚诗）"],"works":[{"id":"t52-940","title":"无题","kind":"诗"},{"id":"t52-941","title":"咏怀","kind":"诗"}]},"徐仁友":{"slug":"徐仁友","name":"徐仁友","dynasty":"唐","style":"","life":"","origin":"","seal":"徐","bio":["徐仁友，开元时人。诗一首。"],"works":[{"id":"t5-488","title":"古意赠孙翃","kind":"诗"}]},"李寿朋":{"slug":"李寿朋","name":"李寿朋","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t51-453","title":"送群玉归别业（句）","kind":"诗"}]},"杨道居":{"slug":"杨道居","name":"杨道居","dynasty":"宋","style":"","life":"","origin":"","seal":"杨","bio":[],"works":[{"id":"c78-633","title":"蝶恋花·气禀五行天与秀","kind":"词"}]},"王迥":{"slug":"王迥","name":"王迥","dynasty":"唐","style":"号白云先生","life":"","origin":"","seal":"王","bio":["王迥，家鹿门，号白云先生，与孟浩然善。诗一首。"],"works":[{"id":"t10-572","title":"同孟浩然宴赋","kind":"诗"}]},"窦庠":{"slug":"窦庠","name":"窦庠","dynasty":"唐","style":"字胄卿","life":"","origin":"","seal":"窦","bio":["窦庠，字胄卿，释褐，授国子主簿。韩臯镇武昌，辟为推官。臯移镇京中，用为度支副使，改殿中侍御史，历登、泽、信、婺四州刺史。","庠天授倜傥，气在物表，一言而合，期于岁寒。为五字诗，颇得其妙。诗二十一首。"],"works":[{"id":"t14-300","title":"留守府酬皇甫曙侍御弹琴之什","kind":"诗"},{"id":"t14-301","title":"金山行","kind":"诗"},{"id":"t14-302","title":"于阗钟歌送灵彻上人归越","kind":"诗"},{"id":"t14-303","title":"太原送穆质南游","kind":"诗"},{"id":"t14-304","title":"四皓驿听琴送王师简归湖南使幕","kind":"诗"},{"id":"t14-305","title":"夜行古战场","kind":"诗"},{"id":"t14-306","title":"奉和王侍郎春日喜李侍郎崔给谏张舍人韦谏议见访因命觞观乐之什","kind":"诗"},{"id":"t14-307","title":"酬谢韦卿二十五兄俯赠輙敢书情","kind":"诗"},{"id":"t14-308","title":"奉酬侍御家兄东洛闲居夜晴观雪之什","kind":"诗"},{"id":"t14-309","title":"勅目至家兄蒙淮南仆射杜公奏授秘校兼节度参谋同书寄上","kind":"诗"},{"id":"t14-310","title":"酬韩愈侍郎登岳阳楼见赠","kind":"诗"},{"id":"t14-311","title":"东都嘉量亭献留守韩仆射","kind":"诗"},{"id":"t14-312","title":"段都尉别业","kind":"诗"},{"id":"t14-313","title":"灵台镇赠丘岑中丞","kind":"诗"},{"id":"t14-314","title":"赠道芬上人","kind":"诗"},{"id":"t14-315","title":"金山寺","kind":"诗"},{"id":"t14-316","title":"冬夜寓怀寄王翰林","kind":"诗"},{"id":"t14-317","title":"醉中赠符载","kind":"诗"},{"id":"t14-318","title":"龙门看花","kind":"诗"},{"id":"t14-319","title":"陪留守韩仆射巡内至上阳宫感兴二首 一","kind":"诗"},{"id":"t14-320","title":"陪留守韩仆射巡内至上阳宫感兴二首 二","kind":"诗"}]},"赵汝恂":{"slug":"赵汝恂","name":"赵汝恂","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"c76-420","title":"念奴娇·金塘瑞溢","kind":"词"}]},"赵龙图":{"slug":"赵龙图","name":"赵龙图","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"c76-451","title":"念奴娇·吾今老矣","kind":"词"}]},"郭震":{"slug":"郭震","name":"郭震","dynasty":"唐","style":"字元振","life":"","origin":"","seal":"郭","bio":["郭震，字元振，魏州贵乡人。以字显，少有大志，十八举进士，为通泉尉。任侠使气，拨去小节，尝盗铸及掠卖部中口千余，以饷遗宾客。","武后召欲诘，既与语，奇之。索所为文章，上《宝劒篇》，后览嘉叹。授右武衞铠曹参军，进奉宸监丞。","久之，拜凉州都督。中宗神龙中，迁左骁衞将军、安西大都护。睿宗立，召为太仆卿。","景云二年，进同中书门下三品。先天元年，为朔方军大总管。明年，以兵部尚书复同中书门下三品，封代国公。","明皇讲武骊山，以军容不整，流新州。开元元年，起为饶州司马，道病卒。集二十卷，今编诗一卷。"],"works":[{"id":"t3-854","title":"古劒篇","kind":"诗"},{"id":"t3-855","title":"塞上","kind":"诗"},{"id":"t3-856","title":"寄刘校书","kind":"诗"},{"id":"t3-857","title":"同徐员外除太子舍人寓直之作","kind":"诗"},{"id":"t3-858","title":"春江曲","kind":"诗"},{"id":"t3-859","title":"王昭君三首 一","kind":"诗"},{"id":"t3-860","title":"王昭君三首 二","kind":"诗"},{"id":"t3-861","title":"王昭君三首 三","kind":"诗"},{"id":"t3-862","title":"子夜四时歌六首 春歌 一","kind":"诗"},{"id":"t3-863","title":"子夜四时歌六首 春歌 二","kind":"诗"},{"id":"t3-864","title":"子夜四时歌六首 秋歌 一","kind":"诗"},{"id":"t3-865","title":"子夜四时歌六首 秋歌 二","kind":"诗"},{"id":"t3-866","title":"子夜四时歌六首 冬歌 一","kind":"诗"},{"id":"t3-867","title":"子夜四时歌六首 冬歌 二","kind":"诗"},{"id":"t3-868","title":"二月乐游诗","kind":"诗"},{"id":"t3-869","title":"十月乐游诗","kind":"诗"},{"id":"t3-870","title":"萤","kind":"诗"},{"id":"t3-871","title":"蛩","kind":"诗"},{"id":"t3-872","title":"云","kind":"诗"},{"id":"t3-873","title":"野井","kind":"诗"},{"id":"t3-874","title":"米囊花","kind":"诗"},{"id":"t3-875","title":"惜花","kind":"诗"},{"id":"t3-876","title":"莲花","kind":"诗"},{"id":"t52-594","title":"发馆陶","kind":"诗"}]},"钱弘偡":{"slug":"钱弘偡","name":"钱弘偡","dynasty":"唐","style":"字惠达","life":"","origin":"","seal":"钱","bio":["弘偡，字惠达，元瓘第八子。明吏术，能为诗。官湖州刺史（《湖州府志》九，开运三年任吴兴太守），有妖巫登大树，恣为鬼神语，州人惊畏。","弘偡严治之，州人咸服。累授同中书门下平章事，封吴兴郡王。卒谥恭义。"],"works":[{"id":"t51-672","title":"飞英寺（句）","kind":"诗"}]},"青幕子妇":{"slug":"青幕子妇","name":"青幕子妇","dynasty":"宋","style":"","life":"","origin":"","seal":"青","bio":[],"works":[{"id":"c61-955","title":"减字木兰花·清词丽句","kind":"词"}]},"魏謩":{"slug":"魏謩","name":"魏謩","dynasty":"唐","style":"字申之","life":"","origin":"","seal":"魏","bio":["魏謩，字申之，郑公征五世孙。登进士第。文宗时，为右拾遗，擢谏议大夫。","武宗立，贬信法长史。宣宗嗣位，召授给事中，迁御史中丞，兼户部侍郎，俄进同中书门下平章事。大中十年，领劒南西川节度使，上疾求代，拜吏部尚书，寻授检校尚书右仆射。","集十卷，今存诗一首。"],"works":[{"id":"t31-329","title":"和重阳锡宴御制诗","kind":"诗"}]},"黄人杰":{"slug":"黄人杰","name":"黄人杰","dynasty":"宋","style":"","life":"","origin":"","seal":"黄","bio":[],"works":[{"id":"c69-473","title":"祝英台・祝英台近·异乡中","kind":"词"},{"id":"c69-474","title":"酹江月・念奴娇·年时今日","kind":"词"},{"id":"c69-475","title":"感皇恩·秋色满西湖","kind":"词"},{"id":"c69-476","title":"念奴娇·西湖胜绝","kind":"词"},{"id":"c69-477","title":"浣溪沙·的皪江梅共蜡梅","kind":"词"},{"id":"c69-478","title":"生查子·烟雨不多时","kind":"词"},{"id":"c69-479","title":"柳梢青·恰则年时","kind":"词"},{"id":"c69-480","title":"蓦山溪·翠环惊报","kind":"词"},{"id":"c69-481"