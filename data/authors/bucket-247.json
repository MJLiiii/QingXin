{"丁默":{"slug":"丁默","name":"丁默","dynasty":"宋","style":"","life":"","origin":"","seal":"丁","bio":[],"works":[{"id":"c74-806","title":"齐天乐·两株烟柳荒城外","kind":"词"},{"id":"c74-807","title":"华胥引·论交眉语","kind":"词"},{"id":"c74-808","title":"齐天乐·倦云休雨风还作","kind":"词"}]},"云表":{"slug":"云表","name":"云表","dynasty":"唐","style":"","life":"","origin":"","seal":"云","bio":["云表，唐末于豫章讲法华慈恩大疏，法席称盛。诗一首。"],"works":[{"id":"t45-521","title":"寒食日","kind":"诗"}]},"何景山":{"slug":"何景山","name":"何景山","dynasty":"唐","style":"","life":"","origin":"","seal":"何","bio":["景山，故唐进士，少有文名。入湖南，为王逵掌书记。周行逢据有潭州，署益阳县令，俄因事投之江。","（《全唐诗》无何景山诗，传据《十国春秋》卷七十五）"],"works":[{"id":"t55-957","title":"望早日","kind":"诗"}]},"刘氏":{"slug":"刘氏","name":"刘氏","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c76-24","title":"沁园春·我生不辰","kind":"词"}]},"唐备":{"slug":"唐备","name":"唐备","dynasty":"唐","style":"","life":"","origin":"","seal":"唐","bio":["备，龙纪元年进士。工古诗，多极讽刺，颇干教化，非浮艳轻斐之作。"],"works":[{"id":"t43-146","title":"失题二首 一","kind":"诗"},{"id":"t43-147","title":"失题二首 二","kind":"诗"},{"id":"t43-148","title":"道傍木","kind":"诗"},{"id":"t51-539","title":"别家（句）","kind":"诗"}]},"宗亮":{"slug":"宗亮","name":"宗亮","dynasty":"唐","style":"号月山","life":"","origin":"","seal":"宗","bio":["宗亮，一作元亮，俗姓冯，奉化人。家傍月山而居，因号月山，又称月僧。开成中出家。","会昌间退居家山。大中时住持明州国宁寺。与李频、方干善，又与贯霜、栖梧、不吟等人迭为文会。","晚年专事禅寂，不出寺门。年八十终于本寺。有诗集三百许首传世。","今存四首。（《全唐诗》无宗亮诗，传据《宋高僧传》卷二七《唐明州国宁寺宗亮传》及下引诸书）"],"works":[{"id":"t54-107","title":"它山歌","kind":"诗"},{"id":"t54-108","title":"它山堰","kind":"诗"},{"id":"t54-109","title":"礼舍利塔","kind":"诗"},{"id":"t54-110","title":"灵鳗井","kind":"诗"}]},"崔日用":{"slug":"崔日用","name":"崔日用","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":["崔日用，滑州灵昌人。进士举大足元年，为宗楚客称荐，擢新丰尉。神龙中，附楚客、三思，骤迁兵部侍郎，兼修文馆学士，复预讨韦庶人谋，授黄门侍郎，参知机务。","开元中，拜吏部尚书，终并州大都督长史。诗九首。"],"works":[{"id":"t0-595","title":"郊庙歌辞 享龙池乐章 第六章","kind":"诗"},{"id":"t2-938","title":"奉和九月九日登慈恩寺浮图应制","kind":"诗"},{"id":"t2-939","title":"奉和圣制送张说巡边","kind":"诗"},{"id":"t2-940","title":"奉和立春游苑迎春应制","kind":"诗"},{"id":"t2-941","title":"奉和圣制春日幸望春宫应制","kind":"诗"},{"id":"t2-942","title":"奉和人日重宴大明宫恩赐彩缕人胜应制","kind":"诗"},{"id":"t2-943","title":"奉和圣制龙池篇","kind":"诗"},{"id":"t2-944","title":"夜宴安乐公主宅","kind":"诗"},{"id":"t2-945","title":"饯唐永昌","kind":"诗"},{"id":"t2-946","title":"奉和送金城公主适西蕃","kind":"诗"},{"id":"t2-947","title":"句","kind":"诗"},{"id":"t48-226","title":"乞金鱼词","kind":"诗"},{"id":"t48-227","title":"又赐宴自歌","kind":"诗"},{"id":"t52-630","title":"赠崔沔（题拟）","kind":"诗"},{"id":"t52-631","title":"赠崔沔","kind":"诗"}]},"李夷简":{"slug":"李夷简","name":"李夷简","dynasty":"唐","style":"字易之","life":"","origin":"","seal":"李","bio":["李夷简，字易之。贞元初登进士第，累迁殿中侍御史。元和时，拜御史中丞。","历山南节度，寻拜御史大夫，进门下侍郎同平章事。诗一首。"],"works":[{"id":"t16-663","title":"西亭暇日书怀十二韵献上相公","kind":"诗"}]},"杨损":{"slug":"杨损","name":"杨损","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":[],"works":[{"id":"t47-887","title":"临刑赋","kind":"诗"}]},"梅远":{"slug":"梅远","name":"梅远","dynasty":"唐","style":"字维明","life":"","origin":"","seal":"梅","bio":["梅远，字维明。南唐时任宣城掾。著有《迁居草》，已佚。","诗二首。（《全唐诗》无梅远诗，事迹详附考）"],"works":[{"id":"t55-432","title":"无题","kind":"诗"},{"id":"t55-433","title":"筑居","kind":"诗"},{"id":"t55-434","title":"迁居","kind":"诗"}]},"欧阳董":{"slug":"欧阳董","name":"欧阳董","dynasty":"唐","style":"","life":"","origin":"","seal":"欧","bio":["董，清江人。昭宗时隐居山中。丞相孙偓以谪宦至，见之，叹为神仙中人。","诗一首。（《全唐诗》无欧阳董诗。传据《江西诗征》卷三）"],"works":[{"id":"t54-348","title":"读书台","kind":"诗"}]},"罗衮":{"slug":"罗衮","name":"罗衮","dynasty":"唐","style":"字子制","life":"","origin":"","seal":"罗","bio":["罗衮，字子制，临邛人。大顺中，历左拾遗、起居郎。仕梁为礼部员外郎。","集二卷，今存诗三首。"],"works":[{"id":"t41-198","title":"清明登奉先城楼","kind":"诗"},{"id":"t41-199","title":"清明赤水寺居","kind":"诗"},{"id":"t41-200","title":"赠罗隐","kind":"诗"},{"id":"t55-176","title":"鸣山","kind":"诗"},{"id":"t55-177","title":"句","kind":"诗"}]},"苏广文":{"slug":"苏广文","name":"苏广文","dynasty":"唐","style":"","life":"","origin":"","seal":"苏","bio":[],"works":[{"id":"t43-348","title":"自商山宿隐居","kind":"诗"},{"id":"t43-349","title":"夜归华川因寄幕府","kind":"诗"},{"id":"t43-350","title":"春日过田明府遇焦山人","kind":"诗"}]},"陈政":{"slug":"陈政","name":"陈政","dynasty":"唐","style":"","life":"","origin":"","seal":"陈","bio":[],"works":[{"id":"t42-995","title":"赠窦蔡二记室入蜀","kind":"诗"}]},"顾况":{"slug":"顾况","name":"顾况","dynasty":"唐","style":"字逋翁","life":"","origin":"","seal":"顾","bio":["顾况，字逋翁，海盐人。肃宗至德进士，长于歌诗，性好诙谐。尝为韩滉节度判官，与柳浑、李泌善。","浑辅政，以校书徴。泌为相，稍迁著作郎。悒悒不乐，求归，坐诗语调谑，贬饶州司户参军。","后隐茅山，以寿终。集二十卷，今编诗四卷。顾况，字逋翁，海盐人。","肃宗至德进士，长于歌诗，性好诙谐，尝为韩滉节度判官，与柳浑、李泌善。浑辅政，以校书徴，泌为相，稍迁著作郎。悒悒不乐，求归，坐诗语调谑，贬饶州司户参军，后隐茅山，以寿终。","集二十卷，今编诗四卷。"],"works":[{"id":"t1-3","title":"横吹曲辞 长安道","kind":"诗"},{"id":"t1-117","title":"相和歌辞 短歌行六首 一","kind":"诗"},{"id":"t1-118","title":"相和歌辞 短歌行六首 二","kind":"诗"},{"id":"t1-119","title":"相和歌辞 短歌行六首 三","kind":"诗"},{"id":"t1-120","title":"相和歌辞 短歌行六首 四","kind":"诗"},{"id":"t1-121","title":"相和歌辞 短歌行六首 五","kind":"诗"},{"id":"t1-122","title":"相和歌辞 短歌行六首 六","kind":"诗"},{"id":"t1-406","title":"相和歌辞 乌夜啼二首 一","kind":"诗"},{"id":"t1-407","title":"相和歌辞 乌夜啼二首 二","kind":"诗"},{"id":"t1-558","title":"琴曲歌辞  幽居弄","kind":"诗"},{"id":"t1-602","title":"琴曲歌辞 龙宫操","kind":"诗"},{"id":"t1-607","title":"琴曲歌辞 琴歌","kind":"诗"},{"id":"t1-730","title":"杂曲歌辞 游子吟","kind":"诗"},{"id":"t1-783","title":"杂曲歌辞 行路难三首 一","kind":"诗"},{"id":"t1-784","title":"杂曲歌辞 行路难三首 二","kind":"诗"},{"id":"t1-785","title":"杂曲歌辞 行路难三首 三","kind":"诗"},{"id":"t1-828","title":"杂曲歌辞 古离别","kind":"诗"},{"id":"t1-920","title":"杂曲歌辞 桃花曲","kind":"诗"},{"id":"t1-932","title":"杂曲歌辞 乐府","kind":"诗"},{"id":"t2-91","title":"杂曲歌辞 竹枝","kind":"诗"},{"id":"t2-375","title":"杂歌谣辞 步虚词","kind":"诗"},{"id":"t13-682","title":"琴歌","kind":"诗"},{"id":"t13-683","title":"上古之什补亡训传十三章","kind":"诗"},{"id":"t13-684","title":"上古之什补亡训传十三章  一","kind":"诗"},{"id":"t13-685","title":"上古之什补亡训传十三章  二","kind":"诗"},{"id":"t13-686","title":"上古之什补亡训传十三章  一","kind":"诗"},{"id":"t13-687","title":"上古之什补亡训传十三章  二","kind":"诗"},{"id":"t13-688","title":"上古之什补亡训传十三章","kind":"诗"},{"id":"t13-689","title":"上古之什补亡训传十三章","kind":"诗"},{"id":"t13-690","title":"上古之什补亡训传十三章","kind":"诗"},{"id":"t13-691","title":"上古之什补亡训传十三章","kind":"诗"},