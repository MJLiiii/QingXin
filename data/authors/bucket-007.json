{"丁注":{"slug":"丁注","name":"丁注","dynasty":"宋","style":"","life":"","origin":"","seal":"丁","bio":[],"works":[{"id":"c61-328","title":"无闷·风急还收","kind":"词"}]},"冯少吉":{"slug":"冯少吉","name":"冯少吉","dynasty":"唐","style":"","life":"","origin":"","seal":"冯","bio":[],"works":[{"id":"t42-987","title":"山寺见杨少卿书壁因题其尾","kind":"诗"}]},"刘学箕":{"slug":"刘学箕","name":"刘学箕","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c71-488","title":"哨遍·木叶尽凋","kind":"词"},{"id":"c71-489","title":"蝶恋花·灯火已收正月半","kind":"词"},{"id":"c71-490","title":"贺新郎·午睡莺惊起","kind":"词"},{"id":"c71-491","title":"忆王孙·淑景韶光晴昼","kind":"词"},{"id":"c71-492","title":"恋绣衾·柳絮风翻高下飞","kind":"词"},{"id":"c71-493","title":"惜分飞·池上楼台堤上路","kind":"词"},{"id":"c71-494","title":"浣溪沙·天上仙人萼绿华","kind":"词"},{"id":"c71-495","title":"贺新郎·往事何堪说","kind":"词"},{"id":"c71-496","title":"贺新郎·东阁凭诗说","kind":"词"},{"id":"c71-497","title":"贺新郎·晓听儿曹说","kind":"词"},{"id":"c71-498","title":"满江红·午转槐阴","kind":"词"},{"id":"c71-499","title":"满江红·一柄双花","kind":"词"},{"id":"c71-500","title":"沁园春·浮利虚名","kind":"词"},{"id":"c71-501","title":"念奴娇·水轩沙岸","kind":"词"},{"id":"c71-502","title":"念奴娇·断虹开霁","kind":"词"},{"id":"c71-503","title":"菩萨蛮·暮涛掀浪溪流急","kind":"词"},{"id":"c71-504","title":"菩萨蛮·鸦儿学画犹嫌丑","kind":"词"},{"id":"c71-505","title":"鹧鸪天·楼外银屏入望赊","kind":"词"},{"id":"c71-506","title":"西江月·世事从来无据","kind":"词"},{"id":"c71-507","title":"水调歌头·三载役京口","kind":"词"},{"id":"c71-508","title":"醉落魄・一斛珠·江头离席","kind":"词"},{"id":"c71-509","title":"长相思·湖山横","kind":"词"},{"id":"c71-510","title":"鹧鸪天·芳草萋萋入眼浓","kind":"词"},{"id":"c71-511","title":"鹧鸪天·梦绕天涯去意浓","kind":"词"},{"id":"c71-512","title":"鹧鸪天·山色都如归兴浓","kind":"词"},{"id":"c71-513","title":"菩萨蛮·昨日杏花春满树","kind":"词"},{"id":"c71-514","title":"浣溪沙·来日江头柳带香","kind":"词"},{"id":"c71-515","title":"眼儿媚·十年不见柳腰肢","kind":"词"},{"id":"c71-516","title":"桃源忆故人·暮霞散绮西溪浦","kind":"词"},{"id":"c71-517","title":"糖多令・唐多令·何处浣离忧","kind":"词"},{"id":"c71-518","title":"小重山·春水东流一苇杭","kind":"词"},{"id":"c71-519","title":"行香子·雪白肥鰜","kind":"词"},{"id":"c71-520","title":"临江仙·人在空江烟浪里","kind":"词"},{"id":"c71-521","title":"渔家傲·汉水悠悠还漾漾","kind":"词"},{"id":"c71-522","title":"菩萨蛮·烟汀一抹蒹葭渚","kind":"词"},{"id":"c71-523","title":"乌夜啼·长亭急管生愁","kind":"词"},{"id":"c71-524","title":"虞美人·寒来暑往何时了","kind":"词"},{"id":"c71-525","title":"贺新郎·莫向愁人说","kind":"词"}]},"刘真":{"slug":"刘真","name":"刘真","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":["刘真，广平人，磁州刺史。诗一首。"],"works":[{"id":"t24-788","title":"七老会诗","kind":"诗"}]},"刘舟":{"slug":"刘舟","name":"刘舟","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":["刘舟，天宝中登进士第。诗一首。"],"works":[{"id":"t10-259","title":"送萧颖士赴东府得适字","kind":"诗"}]},"去奢":{"slug":"去奢","name":"去奢","dynasty":"唐","style":"","life":"","origin":"","seal":"去","bio":[],"works":[{"id":"t50-83","title":"句","kind":"诗"}]},"封孟绅":{"slug":"封孟绅","name":"封孟绅","dynasty":"唐","style":"","life":"","origin":"","seal":"封","bio":["封孟绅，贞元十五年进士第一人，官终太常卿。诗一首。"],"works":[{"id":"t24-817","title":"赋得行不由径","kind":"诗"}]},"崔安潜":{"slug":"崔安潜","name":"崔安潜","dynasty":"唐","style":"字进之","life":"","origin":"","seal":"崔","bio":["崔安潜，字进之，齐州人。大中三年进士登第，咸通中，累擢忠武节度使，拒王仙芝有功，代高骈镇西川，终太子太傅，谥贞孝。诗一首。"],"works":[{"id":"t33-205","title":"报何泽","kind":"诗"}]},"李季萼":{"slug":"李季萼","name":"李季萼","dynasty":"宋","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"c61-112","title":"木兰花・玉楼春·东风忽起黄昏雨","kind":"词"}]},"李康成":{"slug":"李康成","name":"李康成","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李康成，天宝中，与李、杜同时。其赴使江东，刘长卿有诗送之。尝撰《玉台后集》，自陈后主、隋炀帝、江总、庾信、沈、宋、王、杨、卢、骆而下二百九人，诗六百七十首，汇为十卷，自载其诗八篇，今存四首。"],"works":[{"id":"t1-757","title":"杂曲歌辞 自君之出矣","kind":"诗"},{"id":"t10-48","title":"江南行","kind":"诗"},{"id":"t10-49","title":"采莲曲","kind":"诗"},{"id":"t10-50","title":"玉华仙子歌","kind":"诗"},{"id":"t10-51","title":"自君之出矣","kind":"诗"},{"id":"t10-52","title":"句","kind":"诗"},{"id":"t52-839","title":"河阳店家女（仅存六句）","kind":"诗"}]},"李憕":{"slug":"李憕","name":"李憕","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李憕，太原文水人。举明经，开元初，为咸阳尉。张说为并州长史太平军大使时，引憕常在幕下。","后为宇文融判官，括田课最，迁监察御史。历给事中，河南少尹。天宝初，出为清河太守，改尚书右丞、京兆尹。","转光禄卿、东都留守，迁礼部尚书。安禄山陷长安，遇害。赠司徒，谥忠烈。","诗三首。"],"works":[{"id":"t5-556","title":"和户部杨员外伯成寓直","kind":"诗"},{"id":"t5-557","title":"同望幸新亭赐钱公宴","kind":"诗"},{"id":"t5-558","title":"奉和圣制从蓬莱向兴庆阁道中留春雨中春望之作应制","kind":"诗"}]},"李邕":{"slug":"李邕","name":"李邕","dynasty":"唐","style":"字泰和","life":"","origin":"","seal":"李","bio":["李邕，字泰和，广陵江都人，兰台郎善之子。长安中，李峤、张廷珪荐其词高行直，拜左拾遗。宋璟劾奏二张，邕于天后前抗言助之。","开元初，历殿中侍御史，执政忌其才，频被眨斥。后为北海太守，李林甫傅以罪，杖杀之。邕早擅才名，尤长碑颂，虽贬职在外，中朝衣冠及天下寺观，多赍金帛往求其文，馈遗至钜万，自古鬻文获财，未有其比。","尝撰《六公咏》，杜甫《八哀诗》所谓“朗咏六公篇，忧来发蒙蔽”是也，今不传。存诗四首。"],"works":[{"id":"t5-559","title":"铜雀妓","kind":"诗"},{"id":"t5-560","title":"咏云","kind":"诗"},{"id":"t5-561","title":"登历下古城员外孙新亭","kind":"诗"},{"id":"t5-562","title":"奉和初春幸太平公主南庄应制","kind":"诗"},{"id":"t50-172","title":"度巴硖（伯三六一九[一]）","kind":"诗"},{"id":"t50-173","title":"□□（伯三八八五[一]三六一九） 一","kind":"诗"},{"id":"t50-174","title":"□□（伯三八八五[一]三六一九） 二","kind":"诗"},{"id":"t52-809","title":"游法华寺","kind":"诗"},{"id":"t52-810","title":"日赋附歌","kind":"诗"},{"id":"t52-811","title":"题滑州公府大厅梁上（题拟）","kind":"诗"},{"id":"t52-812","title":"秋夜泊江[渚]（诸） 一","kind":"诗"},{"id":"t52-813","title":"秋夜泊江[渚]（诸） 二","kind":"诗"}]},"杨景":{"slug":"杨景","name":"杨景","dynasty":"宋","style":"","life":"","origin":"","seal":"杨","bio":[],"works":[{"id":"c64-226","title":"婆罗门引·帐云暮卷","kind":"词"}]},"沈刚孙":{"slug":"沈刚孙","name":"沈刚孙","dynasty":"宋","style":"","life":"","origin":"","seal":"沈","bio":[],"works":[{"id":"c72-772","title":"酹江月・念奴娇·我来访古","kind":"词"}]},"王以宁":{"slug":"王以宁","name":"王以宁","dynasty":"宋","style":"字周土","life":"","origin":"湘潭（今属湖南）","seal":"王","bio":["--生卒年不详。字周土，湘潭 (今属湖南) 人。宣和三年 (1121)，以成忠郎换文资为从事郎。","建炎初，以枢密院编修官出守鼎州。二年 (1128)，京西制置使，升直显谟阁，寻落职降三官，责监台州酒税。绍兴二年 (1132)，责永州别驾，潮州安置。","五年 (1135)，特许自便。十年 (1140)，复右朝奉郎、知全州。有《王周士词》一卷。"],"works":[{"id":"c63-667","title":"水调歌头·岁晚橘洲上","kind":"词"},{"id":"c63-668","title":"水调歌头·大别我知友","kind":"词"},{"id":"c63-669","title":"满庭芳·山耸方壶","kind":"词"},{"id":"c63-670","title":"满庭芳·千古南阳","kind":"词"},{"id":"c63-671","title":"满庭芳·五十七年","kind":"词"},{"id":"c63-672","title":"满庭芳·千古黄州","kind":"词"},{"id":"c63-673","title":"蓦山溪·平山堂上","kind":"词"},{"id":"c63-674","title":"蓦山溪·雕弓绣帽","kind":"词"},{"id":"c63-675","title":"念奴娇·天工何意","kind":"词"},{"id":"c63-676","title":"念奴娇·云收天碧","kind":"词"},{"id":"c63-677","title":"念奴娇·晚烟凝碧","kind":"词"},{"id":"c63-678","title":"鹧鸪天·昔有书生荐寿杯","kind":"词"},{"id":"c63-679","title":"鹧鸪天·帝乙何年骑玉龙","kind":"词"},{"id":"c63-680","title":"鹧鸪天·桃李纷纷春事催","kind":"词"},{"id":"c63-681","title":"临江仙·眼看西园红与紫","kind":"词"},{"id":"c63-682","title":"临江仙·此理循环如引锯","kind":"词"},{"id":"c63-683","title":"临江仙·闻道洛阳花正好","kind":"词"},{"id":"c63-684","title":"浣溪沙·起看船头蜀锦张","kind":"词"},{"id":"c64-803","title":"浣溪沙·艾胜迎薰寿缕长","kind":"词"},{"id":"c64-804","title":"浣溪沙·招福宫中第几真","kind":"词"},{"id":"c64-805","title":"踏莎行·梦褥光宗","kind":"词"},{"id":"c64-806","title":"踏莎行·我自山中","kind":"词"},{"id":"c64-807","title":"踏莎行·位正三槐","kind":"词"},{"id":"c64-808","title":"感皇恩·千古洞庭湖","kind":"词"},{"id":"c64-809","title":"庆双椿・浣溪沙·问政山头景气嘉","kind":"词"},{"id":"c64-810","title":"渔家傲·往事闲思人共怕","kind":"词"},{"id":"c64-811","title":"好事近·诗客少微家","kind":"词"},{"id":"c64-812","title":"好事近·白石读书房","kind":"词"},{"id":"c64-813","title":"虞美人·归来峰下霜如水","kind":"词"},{"id":"c64-814","title":"浣溪沙·快雨疏风六月凉","kind":"词"},{"id":"c64-815","title":"南歌子·未折江南柳","kind":"词"},{"id":"c64-816","title":"鹧鸪天·瑞雪当空舞素英","kind":"词"}]},"盛小丛":{"slug":"盛小丛","name":"盛小丛","dynasty":"唐","style":"","life":"","origin":"","seal":"盛","bio":["盛小丛，越妓。李讷为浙东廉使，夜登城楼，闻歌声激切，召至，乃小丛也。时崔侍御元范[在]至府幕，赴阙，李饯之，命小丛歌饯，在座各赋诗赠之，小丛有诗一首。"],"works":[{"id":"t44-131","title":"突厥三台","kind":"诗"}]},"苑咸":{"slug":"苑咸","name":"苑咸","dynasty":"唐","style":"","life":"","origin":"","seal":"苑","bio":["苑咸，成都人，举进士登第。为李林甫书记，开元末上书，拜司经校书、中书舍人。尝为孙逖草除庶子诏，议者以为知言。","王维尝谓舍人能书梵字，兼达梵音，曲尽其妙。诗二首。"],"works":[{"id":"t6-247","title":"送大理正摄御史判凉州别驾","kind":"诗"},{"id":"t6-248","title":"酬王维","kind":"诗"}]},"萧华":{"slug":"萧华","name":"萧华","dynasty":"唐","style":"","life":"","origin":"","seal":"萧","bio":["萧华，徐国公嵩之子。天宝末，历官兵部侍郎。上元初，以中书侍郎同平章事，忤李辅国，矫诏罢为礼部侍郎，寻贬峡州司马卒。","诗一首。"],"works":[{"id":"t13-495","title":"扈从回銮应制","kind":"诗"}]},"蒋防":{"slug":"蒋防","name":"蒋防","dynasty":"唐","style":"","life":"","origin":"","seal":"蒋","bio":["蒋防，义兴人，官右拾遗。元和中，李绅荐为司封郎中、知制诰，进翰林学士。李逢吉逐绅，因出防为汀州刺史。","集一卷，今存诗十二首。"],"works":[{"id":"t27-286","title":"题杜宾客新丰里幽居","kind":"诗"},{"id":"t27-287","title":"望禁苑祥光","kind":"诗"},{"id":"t27-288","title":"冬至日祥风应候","kind":"诗"},{"id":"t27-289","title":"春风扇微和","kind":"诗"},{"id":"t27-290","title":"日暖万年枝","kind":"诗"},{"id":"t27-291","title":"秋月悬清辉","kind":"诗"},{"id":"t27-292","title":"八风从律","kind":"诗"},{"id":"t27-293","title":"藩臣恋魏阙","kind":"诗"},{"id":"t27-294","title":"[秋]稼如云","kind":"诗"},{"id":"t27-295","title":"玉巵无当","kind":"诗"},{"id":"t27-296","title":"至人无梦","kind":"诗"},{"id":"t27-297","title":"玄都楼桃","kind":"诗"},{"id":"t51-355","title":"灵岩洞","kind":"诗"},{"id":"t53-474","title":"临蒸诸葛亮宅（题拟）","kind":"诗"}]},"褚遂良":{"slug":"褚遂良","name":"褚遂良","dynasty":"唐","style":"字登善","life":"","origin":"","seal":"褚","bio":["褚遂良，字登善，亮之子。博涉文史，尤工隶书。贞观中起居郎，召令侍书，迁谏议大夫。","累官黄门侍郎，参综朝政，谏奏多所采纳，晋中书令。永徽初，出为同州刺史，征拜吏部尚书，进尚书右仆射，以谏立武昭仪贬，卒。集二十卷，今存诗一首。","褚遂良字登善，亮之子。以谏立武昭仪而贬，显广四年卒，年六十三。补诗四首。"],"works":[{"id":"t2-502","title":"安德山池宴集","kind":"诗"},{"id":"t50-377","title":"辽东侍宴山夜临秋同赋临韵应诏","kind":"诗"},{"id":"t50-378","title":"春日侍宴望海应诏","kind":"诗"},{"id":"t50-379","title":"奉和行经破薛举战地应诏","kind":"诗"},{"id":"t50-380","title":"湘潭偶题诗","kind":"诗"}]},"豆卢荣":{"slug":"豆卢荣","name":"豆卢荣","dynasty":"唐","style":"","life":"","origin":"","seal":"豆","bio":["豆卢荣，贞元进士。诗一首。"],"works":[{"id":"t18-399","title":"赋得春风扇微和","kind":"诗"}]},"赵才卿":{"slug":"赵才卿","name":"赵才卿","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"c64-774","title":"燕归梁·细柳营中有亚夫","kind":"词"}]},"魏扶":{"slug":"魏扶","name":"魏扶","dynasty":"唐","style":"","life":"","origin":"","seal":"魏","bio":["魏扶，太和四年进士第，大中三年兵部侍郎同平章事。诗三首。"],"works":[{"id":"t28-44","title":"和白敏中圣德和平致兹休运岁终功就合咏盛明呈上","kind":"诗"},{"id":"t28-45","title":"贡院题","kind":"诗"},{"id":"t28-46","title":"赋愁","kind":"诗"}]},"黄庭佐":{"slug":"黄庭佐","name":"黄庭佐","dynasty":"宋","style":"","life":"","origin":"","seal":"黄","bio":[],"works":[{"id":"c78-653","title":"水调歌头·露着桂枝晓","kind":"词"}]},"齐安和尚":{"slug":"齐安和尚","name":"齐安和尚","dynasty":"唐","style":"","life":"","origin":"","seal":"齐","bio":["齐安和尚，嗣华岩智藏禅师。住黄州。诗一首。","（《全唐诗》无齐安禅师诗）"],"works":[{"id":"t53-681","title":"偈","kind":"诗"}]}}