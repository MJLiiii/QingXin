le":"郊庙歌辞 让皇帝庙乐章 酌献","kind":"诗"},{"id":"t0-724","title":"郊庙歌辞 让皇帝庙乐章 亚献终献","kind":"诗"},{"id":"t0-725","title":"郊庙歌辞 让皇帝庙乐章 送神","kind":"诗"}]},"李褒":{"slug":"李褒","name":"李褒","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["褒，京兆人。开成元年为起居舍人，五年为翰林学士，会昌元年拜中书舍人，加承旨。二年，出守本官。","大中三年以礼部侍郎知贡举，出为浙东观察使，终于黔南观察使。诗一首。（《全唐诗》无李褒诗，兹据《郎官石柱题名考》卷十、《旧五代史》卷九二拟传）"],"works":[{"id":"t53-907","title":"无题","kind":"诗"},{"id":"t53-908","title":"宿云门香阁院","kind":"诗"}]},"杨旬":{"slug":"杨旬","name":"杨旬","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":["杨旬，大历中夔州推司。诗二首。（《全唐诗》无杨旬诗）"],"works":[{"id":"t53-22","title":"呈史君（名岩） 一","kind":"诗"},{"id":"t53-23","title":"呈史君（名岩） 二","kind":"诗"}]},"杨濬":{"slug":"杨濬","name":"杨濬","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":["杨濬，贞观时人。诗一首。"],"works":[{"id":"t2-518","title":"送刘散员赋得陈思王诗明月照高楼","kind":"诗"}]},"牛仙客":{"slug":"牛仙客","name":"牛仙客","dynasty":"唐","style":"","life":"","origin":"","seal":"牛","bio":["仙客，鹑觚人。初为县小吏，迁洮州司马，清勤不懈。以萧嵩荐，迁太仆少卿。","开元末为朔方总管，啬事省用，仓库积实。迁工部尚书、同中书门下三中品。谨身无它，与时沉浮，累封豳国公，加左相。","卒谥贞简。"],"works":[{"id":"t51-293","title":"宁国院（在新城县）","kind":"诗"}]},"王涯":{"slug":"王涯","name":"王涯","dynasty":"唐","style":"字广津","life":"","origin":"","seal":"王","bio":["王涯，字广津，太原人。博学，工属文。贞元中，擢进士，又举宏辞，调蓝田尉，以左拾遗为翰林学士，进起居舍人。","宪宗元和初，贬虢州司马，徙袁州刺史，以兵部员外郎召知制诰。再为翰林学士，累迁工部侍郎。涯文有雅思，永贞、元和间，训诰温丽，多所槀定。","拜中书侍郎、同中书门下平章事。寻罢，再迁吏部侍郎。穆宗立，出为劒南、东川节度使。","长庆三年，入为御史大夫，迁户部尚书、盐铁转运使。敬宗宝历时，复出领山南西道节度使。文宗嗣位，召拜太常卿，以吏部尚书总盐铁，岁中，进尚书右仆射、代郡公。","久之，以本官同中书门下平章事，俄检校司空、兼门下侍郎。李训败，乃及祸。集十卷，今编诗一卷。"],"works":[{"id":"t0-759","title":"郊庙歌辞 享惠昭太子庙乐章 送神","kind":"诗"},{"id":"t1-203","title":"相和歌辞 从军行三首 一","kind":"诗"},{"id":"t1-204","title":"相和歌辞 从军行三首 二","kind":"诗"},{"id":"t1-205","title":"相和歌辞 从军行三首 三","kind":"诗"},{"id":"t1-549","title":"琴曲歌辞 蔡氏五弄 游春曲二首 一","kind":"诗"},{"id":"t1-550","title":"琴曲歌辞 蔡氏五弄 游春曲二首 二","kind":"诗"},{"id":"t1-551","title":"琴曲歌辞  游春辞二首 一","kind":"诗"},{"id":"t1-552","title":"琴曲歌辞  游春辞二首 二","kind":"诗"},{"id":"t1-565","title":"琴曲歌辞  秋思二首 一","kind":"诗"},{"id":"t1-566","title":"琴曲歌辞  秋思二首 二","kind":"诗"},{"id":"t1-908","title":"杂曲歌辞 秋夜曲","kind":"诗"},{"id":"t1-916","title":"杂曲歌辞 春江曲","kind":"诗"},{"id":"t2-217","title":"杂曲歌辞 太平乐","kind":"诗"},{"id":"t18-318","title":"享惠昭太子庙乐章","kind":"诗"},{"id":"t18-319","title":"望禁门松雪","kind":"诗"},{"id":"t18-320","title":"广宣上人以诗贺放榜和谢","kind":"诗"},{"id":"t18-321","title":"九月九日勤政楼下观百僚献寿","kind":"诗"},{"id":"t18-322","title":"春游曲二首 一","kind":"诗"},{"id":"t18-323","title":"春游曲二首 二","kind":"诗"},{"id":"t18-324","title":"太平词","kind":"诗"},{"id":"t18-325","title":"送春词","kind":"诗"},{"id":"t18-326","title":"塞上曲二首 一","kind":"诗"},{"id":"t18-327","title":"塞上曲二首 二","kind":"诗"},{"id":"t18-328","title":"陇上行","kind":"诗"},{"id":"t18-329","title":"思君恩","kind":"诗"},{"id":"t18-330","title":"春闺思","kind":"诗"},{"id":"t18-331","title":"春江曲","kind":"诗"},{"id":"t18-332","title":"闺人赠远五首 一","kind":"诗"},{"id":"t18-333","title":"闺人赠远五首 二","kind":"诗"},{"id":"t18-334","title":"闺人赠远五首 三","kind":"诗"},{"id":"t18-335","title":"闺人赠远五首 四","kind":"诗"},{"id":"t18-336","title":"闺人赠远五首 五","kind":"诗"},{"id":"t18-337","title":"从军词三首 一","kind":"诗"},{"id":"t18-338","title":"从军词三首 二","kind":"诗"},{"id":"t18-339","title":"从军词三首 三","kind":"诗"},{"id":"t18-340","title":"塞下曲二首 一","kind":"诗"},{"id":"t18-341","title":"塞下曲二首 二","kind":"诗"},{"id":"t18-342","title":"平戎辞","kind":"诗"},{"id":"t18-343","title":"游春词二首 一","kind":"诗"},{"id":"t18-344","title":"游春词二首 二","kind":"诗"},{"id":"t18-345","title":"秋思二首 一","kind":"诗"},{"id":"t18-346","title":"秋思二首 二","kind":"诗"},{"id":"t18-347","title":"汉苑行","kind":"诗"},{"id":"t18-348","title":"秋夜曲","kind":"诗"},{"id":"t18-349","title":"献寿辞","kind":"诗"},{"id":"t18-350","title":"秋思赠远二首 一","kind":"诗"},{"id":"t18-351","title":"秋思赠远二首 二","kind":"诗"},{"id":"t18-352","title":"春闺思","kind":"诗"},{"id":"t18-353","title":"宫词三十首 一","kind":"诗"},{"id":"t18-354","title":"宫词三十首 二","kind":"诗"}]},"皇甫澈":{"slug":"皇甫澈","name":"皇甫澈","dynasty":"唐","style":"","life":"","origin":"","seal":"皇","bio":["皇甫澈，贞元中蜀州刺史。诗四首。"],"works":[{"id":"t16-801","title":"赋四相诗 中书令汉阳王张柬之","kind":"诗"},{"id":"t16-802","title":"赋四相诗 中书令钟绍京","kind":"诗"},{"id":"t16-803","title":"赋四相诗 礼部尚书门下侍郎平章事李岘","kind":"诗"},{"id":"t16-804","title":"赋四相诗 门下侍郎平章事王缙","kind":"诗"}]},"程紫霄":{"slug":"程紫霄","name":"程紫霄","dynasty":"唐","style":"","life":"","origin":"","seal":"程","bio":["程紫霄，唐末道士，后唐同光初，尝勅令入内殿讲论。诗一首。程紫霄，唐末道士，后唐同光初，尝勅令入内殿讲论。","诗一首。"],"works":[{"id":"t47-433","title":"示守庚申众","kind":"诗"},{"id":"t48-352","title":"与释惠江互谑","kind":"诗"}]},"虞刚简":{"slug":"虞刚简","name":"虞刚简","dynasty":"宋","style":"","life":"","origin":"","seal":"虞","bio":[],"works":[{"id":"c70-813","title":"南乡子·儿有掌中杯","kind":"词"}]},"许昼":{"slug":"许昼","name":"许昼","dynasty":"唐","style":"","life":"","origin":"","seal":"许","bio":["许昼，睢阳人，天复四年及第。诗二首。"],"works":[{"id":"t40-355","title":"江南行","kind":"诗"},{"id":"t40-356","title":"中秋月","kind":"诗"}]},"郭虚己":{"slug":"郭虚己","name":"郭虚己","dynasty":"唐","style":"","life":"","origin":"","seal":"郭","bio":["虚己，京兆人，一作太原人。历任侍御史、朔方节度行军司马、关内道采访处置使、工部侍郎、户部侍郎、剑南节度使、工部尚书，天宝九载卒。诗一首。","（《全唐诗》无郭虚己诗。兹据《元和姓纂》卷七、岑仲勉《元和姓纂四校记》卷七、《唐方镇年表》卷六、同书《考证》卷下录其事迹）"],"works":[{"id":"t52-823","title":"送贺秘监归会稽诗","kind":"诗"}]},"陈希烈":{"slug":"陈希烈","name":"陈希烈","dynasty":"唐","style":"","life":"","origin":"","seal":"陈","bio":["陈希烈，宋州人，长于名理。开元中，于禁中讲老、易，累迁至秘书少监，代张九龄专判集贤院事，明皇凡有撰述，必经其手。李林甫知上睠待，乃引为宰相，宠遇侔于林甫。","后为杨国忠所嫉，罢知政事。禄山之乱，受伪命为中书令。论陷贼罪当死，肃宗以旧恩特原之，长流合浦郡。","诗三首。"],"works":[{"id":"t5-749","title":"赋得云生栋梁间","kind":"诗"},{"id":"t5-750","title":"奉和圣制三月三日","kind":"诗"},{"id":"t5-751","title":"省试白云起封中","kind":"诗"}]},"陶彝之":{"slug":"陶彝之","name":"陶彝之","dynasty":"唐","style":"","life":"","origin":"","seal":"陶","bio":["陶彝之，陶谷之犹子。十二岁能诗。（《全唐诗》无陶彝之诗）"],"works":[{"id":"t55-334","title":"效胡峤饮茶诗","kind":"诗"}]}}