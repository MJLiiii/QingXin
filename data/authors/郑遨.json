{"slug":"郑遨","name":"郑遨","dynasty":"唐","style":"字云叟 · 号逍遥先生","life":"","origin":"","seal":"郑","bio":["郑遨，字云叟，滑州白马人。昭宗时，举进士，不第，入少室山为道士。徙居华阴，种田自给，与道士李道殷、罗隐之友善，世目为三高士。","唐明宗以左拾遗，晋高祖以谏议大夫召，皆不起，赐号逍遥先生，天福中卒。诗十七首。"],"works":[{"id":"t43-648","title":"与罗隐之联句","kind":"诗"},{"id":"t47-415","title":"山居 一","kind":"诗"},{"id":"t47-416","title":"山居 二","kind":"诗"},{"id":"t47-417","title":"山居 三","kind":"诗"},{"id":"t47-418","title":"茶诗","kind":"诗"},{"id":"t47-419","title":"哭张道古","kind":"诗"},{"id":"t47-420","title":"富贵曲","kind":"诗"},{"id":"t47-421","title":"伤农","kind":"诗"},{"id":"t47-422","title":"咏西施","kind":"诗"},{"id":"t47-423","title":"思山咏","kind":"诗"},{"id":"t47-424","title":"招友人游春","kind":"诗"},{"id":"t47-425","title":"宿洞庭","kind":"诗"},{"id":"t47-426","title":"题病僧寮","kind":"诗"},{"id":"t47-427","title":"题霍山秦尊师","kind":"诗"},{"id":"t47-428","title":"偶题 一","kind":"诗"},{"id":"t47-429","title":"偶题 二","kind":"诗"},{"id":"t47-430","title":"景福中作","kind":"诗"},{"id":"t47-431","title":"题中条静观","kind":"诗"}]}