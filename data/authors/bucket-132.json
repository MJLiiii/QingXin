{"万齐融":{"slug":"万齐融","name":"万齐融","dynasty":"唐","style":"字属上文","life":"","origin":"","seal":"万","bio":["万齐融，越州人，官昆山令。诗四首。按《旧唐书·文苑传》云：“神龙中，贺知章与贺朝万、齐融、张若虚、邢巨、包融，俱以吴越之士，文辞俊秀，名扬于上京，人间往往传其文。","朝万止山阴尉，齐融昆山令，盖以万字属上文，作贺朝万。及考唐人所选《国秀》、《搜玉》二集，俱作万齐融、贺朝，今仍之。”"],"works":[{"id":"t5-613","title":"三日绿潭篇","kind":"诗"},{"id":"t5-614","title":"仗劒行","kind":"诗"},{"id":"t5-615","title":"赠别江头","kind":"诗"},{"id":"t5-616","title":"送陈七还广陵","kind":"诗"}]},"任生":{"slug":"任生","name":"任生","dynasty":"唐","style":"","life":"","origin":"","seal":"任","bio":[],"works":[{"id":"t43-351","title":"题升山","kind":"诗"},{"id":"t43-352","title":"投曹文姬诗","kind":"诗"}]},"冯道":{"slug":"冯道","name":"冯道","dynasty":"唐","style":"字可道 · 号长乐老","life":"","origin":"","seal":"冯","bio":["冯道，字可道，景城人。初为刘守光参军，后历唐、晋、汉、周，事四姓十君，并在政府，自号长乐老，卒谥文懿，追封瀛王。诗集十卷，今存五首。"],"works":[{"id":"t41-354","title":"天道","kind":"诗"},{"id":"t41-355","title":"偶作","kind":"诗"},{"id":"t41-356","title":"北使还京作","kind":"诗"},{"id":"t41-357","title":"赠窦十","kind":"诗"},{"id":"t41-358","title":"放鱼书所钥户","kind":"诗"},{"id":"t41-359","title":"句","kind":"诗"},{"id":"t51-580","title":"舌","kind":"诗"},{"id":"t55-256","title":"平日自咏（题拟）","kind":"诗"},{"id":"t55-257","title":"使虏诗","kind":"诗"}]},"刘氏媛":{"slug":"刘氏媛","name":"刘氏媛","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"t1-323","title":"相和歌辞 长门怨二首 一","kind":"诗"},{"id":"t1-324","title":"相和歌辞 长门怨二首 二","kind":"诗"}]},"刘澜":{"slug":"刘澜","name":"刘澜","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c73-800","title":"庆宫春・高阳台·春翦绿波","kind":"词"},{"id":"c73-801","title":"瑞鹤仙·向阳看未足","kind":"词"},{"id":"c73-802","title":"齐天乐·玉钗分向金华后","kind":"词"},{"id":"c73-803","title":"买陂塘・摸鱼儿·御风来","kind":"词"}]},"卢元辅":{"slug":"卢元辅","name":"卢元辅","dynasty":"唐","style":"","life":"","origin":"","seal":"卢","bio":["史，召授吏部郎中，为华州刺史卒。诗一首。（《全唐诗》无卢元辅诗。","）"],"works":[{"id":"t50-652","title":"无题","kind":"诗"},{"id":"t50-653","title":"游天竺寺","kind":"诗"},{"id":"t53-529","title":"灵隐寺","kind":"诗"}]},"孟球":{"slug":"孟球","name":"孟球","dynasty":"唐","style":"字廷玉","life":"","origin":"","seal":"孟","bio":["孟球，字廷玉，会昌三年进士第。咸通中，捡校工部尚书、徐州刺史。诗一首。"],"works":[{"id":"t30-585","title":"和主司王起","kind":"诗"}]},"张枢密":{"slug":"张枢密","name":"张枢密","dynasty":"宋","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"c61-58","title":"声声慢·星冠懒带","kind":"词"}]},"明瓒":{"slug":"明瓒","name":"明瓒","dynasty":"唐","style":"","life":"","origin":"","seal":"明","bio":["明瓒，嗣普寂。住南岳。世称懒瓒和尚、懒残和尚。","天宝间为执役僧。李泌在南岳，尝与游。诗三首。","（《全唐诗》无明瓒诗。传据《祖堂集》卷三、《宋高僧传》卷十九、《林间录》、《南岳总胜集》。《丽廔丛书》影元刻《三教论衡搜神大全》卷六载其事独详，然迹近小说，今不取。","）"],"works":[{"id":"t52-962","title":"题像","kind":"诗"},{"id":"t52-963","title":"辞名","kind":"诗"},{"id":"t52-964","title":"乐道歌","kind":"诗"}]},"朱希真":{"slug":"朱希真","name":"朱希真","dynasty":"宋","style":"","life":"","origin":"","seal":"朱","bio":[],"works":[{"id":"c61-71","title":"失调名·苦汝临期话别","kind":"词"},{"id":"c61-72","title":"采桑子·王孙去后无芳草","kind":"词"}]},"朱庆余":{"slug":"朱庆余","name":"朱庆余","dynasty":"唐","style":"字行","life":"","origin":"","seal":"朱","bio":["朱庆余，名可久，以字行，越州人。受知于张籍，登宝历进士第。诗二卷。"],"works":[{"id":"t27-859","title":"泛溪","kind":"诗"},{"id":"t27-860","title":"宿陈处士书斋","kind":"诗"},{"id":"t27-861","title":"上宣州沈大夫","kind":"诗"},{"id":"t27-862","title":"杭州送萧宝校书","kind":"诗"},{"id":"t27-863","title":"送盛长史","kind":"诗"},{"id":"t27-864","title":"宿道士观","kind":"诗"},{"id":"t27-865","title":"湖州韩使君置宴","kind":"诗"},{"id":"t27-866","title":"题僊游寺","kind":"诗"},{"id":"t27-867","title":"宫词","kind":"诗"},{"id":"t27-868","title":"公子行","kind":"诗"},{"id":"t27-869","title":"送陈摽","kind":"诗"},{"id":"t27-870","title":"寻古观","kind":"诗"},{"id":"t27-871","title":"南岭路","kind":"诗"},{"id":"t27-872","title":"陪江州李使君重阳宴百花亭","kind":"诗"},{"id":"t27-873","title":"上张水部","kind":"诗"},{"id":"t27-874","title":"凤翔西池与贾岛纳凉","kind":"诗"},{"id":"t27-875","title":"上汴州令狐相公","kind":"诗"},{"id":"t27-876","title":"送于中丞入蕃册立","kind":"诗"},{"id":"t27-877","title":"送淮阴丁明府","kind":"诗"},{"id":"t27-878","title":"送韦校书佐灵州幕","kind":"诗"},{"id":"t27-879","title":"上江州李史君","kind":"诗"},{"id":"t