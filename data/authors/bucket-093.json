-799","title":"羽山","kind":"诗"},{"id":"t48-800","title":"游马耳山","kind":"诗"},{"id":"t48-801","title":"□□□赵载同游焦湖夜归作","kind":"诗"}]},"蒋贻恭":{"slug":"蒋贻恭","name":"蒋贻恭","dynasty":"唐","style":"","life":"","origin":"","seal":"蒋","bio":["蒋贻恭，江淮人，唐末入蜀。孟氏时，官大井县令。诗二首。"],"works":[{"id":"t42-522","title":"题张道隐太山祠画龙","kind":"诗"},{"id":"t42-523","title":"咏蚕","kind":"诗"},{"id":"t48-310","title":"咏王给事","kind":"诗"},{"id":"t48-311","title":"咏金刚","kind":"诗"},{"id":"t48-312","title":"咏伛背子","kind":"诗"},{"id":"t48-313","title":"咏安仁宰捣蒜","kind":"诗"},{"id":"t48-314","title":"五门街望有题","kind":"诗"},{"id":"t48-315","title":"谢郎中惠茶","kind":"诗"},{"id":"t48-316","title":"咏虾蟆","kind":"诗"},{"id":"t48-317","title":"住名山日陈情上府主高太保","kind":"诗"}]},"薛存诚":{"slug":"薛存诚","name":"薛存诚","dynasty":"唐","style":"字资明","life":"","origin":"","seal":"薛","bio":["薛存诚，字资明，河东人。登贞元进士第，元和末，官至御史中丞。诗十二首。"],"works":[{"id":"t24-902","title":"暮春自南台丞再除给事中","kind":"诗"},{"id":"t24-903","title":"御制段太尉碑","kind":"诗"},{"id":"t24-904","title":"御题国子监门","kind":"诗"},{"id":"t24-905","title":"御箭连中双兔","kind":"诗"},{"id":"t24-906","title":"太学创置石经","kind":"诗"},{"id":"t24-907","title":"观南郊回仗","kind":"诗"},{"id":"t24-908","title":"闻击壤","kind":"诗"},{"id":"t24-909","title":"膏泽多丰年","kind":"诗"},{"id":"t24-910","title":"东都父老望幸","kind":"诗"},{"id":"t24-911","title":"嵩山望幸","kind":"诗"},{"id":"t24-912","title":"华清宫望幸","kind":"诗"},{"id":"t24-913","title":"谒见日将至双阙","kind":"诗"}]},"袁正真":{"slug":"袁正真","name":"袁正真","dynasty":"宋","style":"","life":"","origin":"","seal":"袁","bio":["--宋旧宫人。存词一首。"],"works":[{"id":"c75-650","title":"长相思·南高峰","kind":"词"}]},"裴淑":{"slug":"裴淑","name":"裴淑","dynasty":"唐","style":"字柔之","life":"","origin":"","seal":"裴","bio":["裴淑，字柔之，元稹继室。诗一首。"],"works":[{"id":"t43-938","title":"荅微之","kind":"诗"}]},"赵防":{"slug":"赵防","name":"赵防","dynasty":"唐","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"t43-138","title":"秋日寄弟","kind":"诗"}]},"郑明":{"slug":"郑明","name":"郑明","dynasty":"唐","style":"","life":"","origin":"","seal":"郑","bio":[],"works":[{"id":"t50-60","title":"句","kind":"诗"}]},"韩琦":{"slug":"韩琦","name":"韩琦","dynasty":"宋","style":"字稚圭","life":"","origin":"安阳（今属河南）","seal":"韩","bio":["--(1008－1075) 字稚圭，安阳 (今属河南) 人。天圣五年 (1027) 进士。官至同中书门下平章事、昭文馆大学士，累封魏国公。","著有《安阳集》。《全宋词》录其词五首。"],"works":[{"id":"c58-464","title":"点绛唇·病起恹恹","kind":"词"},{"id":"c58-465","title":"维扬好·二十四桥千步柳","kind":"词"},{"id":"c58-466","title":"安阳好・忆江南·安阳好","kind":"词"},{"id":"c58-467","title":"安阳好・忆江南·安阳好","kind":"词"},{"id":"c58-468","title":"望江南・忆江南·维杨好","kind":"词"}]}}