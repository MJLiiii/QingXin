{"刘均国":{"slug":"刘均国","name":"刘均国","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c64-474","title":"梅花引·千里月","kind":"词"}]},"刘鼎臣妻":{"slug":"刘鼎臣妻","name":"刘鼎臣妻","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c76-412","title":"鹧鸪天·金屋无人夜剪缯","kind":"词"}]},"吕颐浩":{"slug":"吕颐浩","name":"吕颐浩","dynasty":"宋","style":"","life":"","origin":"","seal":"吕","bio":[],"works":[{"id":"c62-627","title":"水调歌头·一片苍崖璞","kind":"词"}]},"吴兢":{"slug":"吴兢","name":"吴兢","dynasty":"唐","style":"号《吴氏西斋书目》","life":"","origin":"","seal":"吴","bio":["吴兢，汴州浚仪人。博通经史，魏元忠、朱敬则深器之，荐其有史才，因令直史馆。神龙中，迁石补阙，与韦承庆、崔融等撰《则天实录》。","开元中，历修文馆学士，居史职殆三十年，序事简要，人皆称之。出为荆州司马，以史稿自随。萧嵩监修国史，奏取兢所撰，得六十五卷。","累迁台、洪、饶、蕲四州刺史。天宝初，为邺郡太守，入为恒王傅。尝以梁、陈、齐、周、隋五代史繁杂，乃别撰各史，又伤疎略。","卒年八十余。卒后，其子进兢所撰《唐史》八十余卷，事多纰缪，不逮壮年。兢家多藏书，尝录其卷第，号《吴氏西斋书目》。","诗二首。"],"works":[{"id":"t5-243","title":"永泰公主挽歌二首 一","kind":"诗"},{"id":"t5-244","title":"永泰公主挽歌二首 二","kind":"诗"},{"id":"t52-821","title":"拟采桑曲","kind":"诗"}]},"崔恂":{"slug":"崔恂","name":"崔恂","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":["崔恂，郑州人。为赵州长史。诗一首。","（《乾道临安志》卷三录《元和姓纂》逸文：「崔恂，水部郎中，杭州刺史，郑州人。」）（《全唐诗》无崔恂诗）"],"works":[{"id":"t50-587","title":"石桥咏","kind":"诗"}]},"崔道融":{"slug":"崔道融","name":"崔道融","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":["崔道融，荆州人。以徴辟为永嘉令，累官右补阙，避地入闽。《申唐诗》三卷，《东浮集》九卷，今编诗一卷。"],"works":[{"id":"t40-238","title":"梅花","kind":"诗"},{"id":"t40-239","title":"铜雀妓二首 一","kind":"诗"},{"id":"t40-240","title":"铜雀妓二首 二","kind":"诗"},{"id":"t40-241","title":"春闺二首 一","kind":"诗"},{"id":"t40-242","title":"春闺二首 二","kind":"诗"},{"id":"t40-243","title":"访僧不遇","kind":"诗"},{"id":"t40-244","title":"田上","kind":"诗"},{"id":"t40-245","title":"月夕","kind":"诗"},{"id":"t40-246","title":"槿花","kind":"诗"},{"id":"t40-247","title":"西施滩","kind":"诗"},{"id":"t40-248","title":"江上逢故人","kind":"诗"},{"id":"t40-249","title":"牧竖","kind":"诗"},{"id":"t40-250","title":"过农家","kind":"诗"},{"id":"t40-251","title":"江夕","kind":"诗"},{"id":"t40-252","title":"