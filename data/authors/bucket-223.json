2","title":"渔歌・渔父·掌握千差都照破","kind":"词"},{"id":"c78-203","title":"渔歌・渔父·孤硬云峰无计较","kind":"词"},{"id":"c78-204","title":"渔歌・渔父·万古黄龙真夭矫","kind":"词"},{"id":"c78-205","title":"渔歌・渔父·宝觉禅河波浩浩","kind":"词"},{"id":"c78-206","title":"渔歌・渔父·贬剥诸方真净老","kind":"词"},{"id":"c78-207","title":"渔歌・渔父·积翠十年丹风穴","kind":"词"},{"id":"c78-208","title":"渔歌・渔父·骂佛骂人新孟八","kind":"词"},{"id":"c78-209","title":"渔歌・渔父·绝唱灵源求和寡","kind":"词"},{"id":"c78-210","title":"渔歌・渔父·选佛堂中川藞苴","kind":"词"}]},"李潭":{"slug":"李潭","name":"李潭","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t50-59","title":"句","kind":"诗"}]},"杜周士":{"slug":"杜周士","name":"杜周士","dynasty":"唐","style":"","life":"","origin":"","seal":"杜","bio":[],"works":[{"id":"t43-271","title":"闰月定四时","kind":"诗"}]},"杨均":{"slug":"杨均","name":"杨均","dynasty":"宋","style":"","life":"","origin":"","seal":"杨","bio":[],"works":[{"id":"c75-997","title":"霜天晓角·丹楹转月","kind":"词"},{"id":"c75-998","title":"霜天晓角·当年宋壁","kind":"词"},{"id":"c75-999","title":"霜天晓角·忠忱谊愊","kind":"词"}]},"武少仪":{"slug":"武少仪","name":"武少仪","dynasty":"唐","style":"","life":"","origin":"","seal":"武","bio":["武少仪，元和中尝为大理卿。诗二首。"],"works":[{"id":"t17-557","title":"和权载之离合诗","kind":"诗"},{"id":"t17-558","title":"诸葛丞相庙","kind":"诗"}]},"沙碛女子":{"slug":"沙碛女子","name":"沙碛女子","dynasty":"唐","style":"","life":"","origin":"","seal":"沙","bio":[],"works":[{"id":"t48-43","title":"五原夜吟","kind":"诗"}]},"葛氏女":{"slug":"葛氏女","name":"葛氏女","dynasty":"唐","style":"","life":"","origin":"","seal":"葛","bio":[],"works":[{"id":"t44-81","title":"和潘雍","kind":"诗"}]},"薛业":{"slug":"薛业","name":"薛业","dynasty":"唐","style":"","life":"","origin":"","seal":"薛","bio":["薛业，天宝间处士。西游庐山，赵补阙骅、王侍御定、张评事有略，各以文为赠，独孤及尝称其敦于诗。困于学，敏于行，口弗言禄，禄亦不及。","识其真者，以为永叹。诗二首。"],"works":[{"id":"t5-621","title":"洪州客舍寄柳博士芳","kind":"诗"},{"id":"t5-622","title":"晚秋赠张折冲","kind":"诗"}]},"虞世南":{"slug":"虞世南","name":"虞世南","dynasty":"唐","style":"字伯施","life":"","origin":"","seal":"虞","bio":["虞世南，字伯施，余姚人。沉静寡欲，精思读书，至累旬不盥栉，文章婉缛，见称于仆射徐陵，由是有名。在隋，官秘书郎，十年不徙。","入唐，为秦府记室参军，迁太子中舍人。太宗践祚，历弘文馆学士、秘书监，卒谥文懿。太宗称其德行、忠直、博学、文词、书翰为五绝。","手诏魏王泰曰：“世南当代名臣，人伦准的，今其云亡，石渠、东观中无复人矣。”集三十卷，今编诗一卷。"],"works":[{"id":"t1-165","title":"相和歌辞 从军行二首 一","kind":"诗"},{"id":"t1-166","title":"相和歌辞 从军行二首 二","kind":"诗"},{"id":"t1-230","title":"相和歌辞 中妇织流黄","kind":"诗"},{"id":"t1-244","title":"相和歌辞 饮马长城窟行","kind":"诗"},{"id":"t1-260","title":"相和歌辞 飞来双白鹤","kind":"诗"},{"id":"t1-261","title":"相和歌辞 门有车马客行","kind":"诗"},{"id":"t1-296","title":"相和歌辞 怨歌行","kind":"诗"},{"id":"t1-663","title":"杂曲歌辞 结客少年场行","kind":"诗"},{"id":"t2-575","title":"从军行二首 一","kind":"诗"},{"id":"t2-576","title":"从军行二首 二","kind":"诗"},{"id":"t2-577","title":"拟饮马长城窟","kind":"诗"},{"id":"t2-578","title":"出塞","kind":"诗"},{"id":"t2-579","title":"结客少年场行","kind":"诗"},{"id":"t2-580","title":"怨歌行","kind":"诗"},{"id":"t2-581","title":"中妇织流黄","kind":"诗"},{"id":"t2-582","title":"门有车马客","kind":"诗"},{"id":"t2-583","title":"飞来双白鹤","kind":"诗"},{"id":"t2-584","title":"奉和幽山雨后应令","kind":"诗"},{"id":"t2-585","title":"赋得吴都","kind":"诗"},{"id":"t2-586","title":"赋得慎罚","kind":"诗"},{"id":"t2-587","title":"奉和咏日午","kind":"诗"},{"id":"t2-588","title":"发营逢雨应诏","kind":"诗"},{"id":"t2-589","title":"赋得临池竹应制","kind":"诗"},{"id":"t2-590","title":"侍宴应诏赋韵得前字","kind":"诗"},{"id":"t2-591","title":"侍宴归鴈堂","kind":"诗"},{"id":"t2-592","title":"凌晨早朝","kind":"诗"},{"id":"t2-593","title":"奉和咏风应魏王教","kind":"诗"},{"id":"t2-594","title":"初晴应教","kind":"诗"},{"id":"t2-595","title":"春夜","kind":"诗"},{"id":"t2-596","title":"咏舞","kind":"诗"},{"id":"t2-597","title":"咏萤","kind":"诗"},{"id":"t2-598","title":"蝉","kind":"诗"},{"id":"t2-599","title":"秋鴈","kind":"诗"},{"id":"t2-600","title":"奉和月夜观星应令","kind":"诗"},{"id":"t2-601","title":"和銮舆顿戏下","kind":"诗"},{"id":"t2-602","title":"奉和至寿春应令","kind":"诗"},{"id":"t2-603","title":"奉和幸江都应诏","kind":"诗"},{"id":"t2-604","title":"奉和献岁䜩宫臣","kind":"诗"},{"id":"t2-605","title":"奉和出颍至淮应令","kind":"诗"},{"id":"t2-606","title":"应诏嘲司花女","kind":"诗"}]},"释明解":{"slug":"释明解","name":"释明解","dynasty":"唐","style":"","life":"","origin":"","seal":"释","bio":[],"works":[{"id":