      "def": "天刚亮。"
    },
    {
      "term": "野性",
      "def": "粗野的性情。"
    },
    {
      "term": "人寰",
      "def": "人间；人世。"
    },
    {
      "term": "祥风",
      "def": "和暖的风。"
    },
    {
      "term": "汗漫",
