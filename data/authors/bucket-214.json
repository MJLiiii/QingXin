{"万俟绍之":{"slug":"万俟绍之","name":"万俟绍之","dynasty":"宋","style":"","life":"","origin":"","seal":"万","bio":[],"works":[{"id":"c73-781","title":"蝶恋花·啼鴂一声云榭晚","kind":"词"},{"id":"c73-782","title":"风入松·一春心事与谁同","kind":"词"},{"id":"c73-783","title":"贺新郎·决眦入飞鸟","kind":"词"},{"id":"c73-784","title":"江神子・江城子·十年心事上眉端","kind":"词"}]},"于季友":{"slug":"于季友","name":"于季友","dynasty":"唐","style":"","life":"","origin":"","seal":"于","bio":["于季友，河南人，为司空于𬱖第三子。曾为绛、宋、明等州刺史。尚宪宗永昌公主，拜驸马都尉。","（《季友传》附见于《新唐书》卷一七二《于𬱖传》，亦见卷七十二下《宰相世系表》。《旧唐书》卷一五六《于𬱖传》亦附及之）。诗一首。","（《全唐诗》无于季友诗）"],"works":[{"id":"t50-650","title":"范处士在育王寺书碑因以寄赠","kind":"诗"}]},"伊璠":{"slug":"伊璠","name":"伊璠","dynasty":"唐","style":"","life":"","origin":"","seal":"伊","bio":["伊璠，咸通四年，登进士第，为泾阳令。诗一首。"],"works":[{"id":"t33-335","title":"及第后寄梁烛处士","kind":"诗"}]},"史弥巩":{"slug":"史弥巩","name":"史弥巩","dynasty":"宋","style":"","life":"","origin":"","seal":"史","bio":[],"works":[{"id":"c70-943","title":"失调名·羊左合人我","kind":"词"}]},"孙叔向":{"slug":"孙叔向","name":"孙叔向","dynasty":"唐","style":"","life":"","origin":"","seal":"孙","bio":["孙叔向，德宗时人。诗三首。"],"works":[{"id":"t25-221","title":"将赴东都上李相国","kind":"诗"},{"id":"t25-222","title":"题昭应温泉","kind":"诗"},{"id":"t25-223","title":"送咸安公主","kind":"诗"}]},"孙氏":{"slug":"孙氏","name":"孙氏","dynasty":"唐","style":"","life":"","origin":"","seal":"孙","bio":["孙氏，乐昌一作安人，进士孟昌期妻也，善诗，每代夫作。一日忽曰：“才思非妇人事。”遂焚其事。","诗三首。"],"works":[{"id":"t43-953","title":"闻琴","kind":"诗"},{"id":"t43-954","title":"白蜡烛诗","kind":"诗"},{"id":"t43-955","title":"谢人送酒","kind":"诗"}]},"岑文本":{"slug":"岑文本","name":"岑文本","dynasty":"唐","style":"字景仁","life":"","origin":"","seal":"岑","bio":["岑文本，字景仁，邓州人。沈敏有姿仪，博综经史，美谈论，善属文。贞观初，除秘书郎，上《籍田》、《三元》二颂，辞甚工，擢中书舍人。","所草诏诰或繁凑，即命书僮六七人，随口并写，须臾悉成。时中书侍郎颜师古以谴罢，太宗曰：“朕自举一人。”乃以授文本，先与令狐德棻撰《周史》，史论多出文本，及史成，封江陵县子，后拜中书令。","集六十卷，今存诗四首。"],"works":[{"id":"t2-497","title":"奉和正日临朝","kind":"诗"},{"id":"t2-498","title":"奉述飞白书势","kind":"诗"},{"id":"t2-499","title":"冬日宴于庶子宅各赋一字得平","kind":"诗"},{"id":"t2-500","title":"安德山池宴集","kind":"诗"},{"id":"t52-70","title":"五言春日侍宴望海应诏","k