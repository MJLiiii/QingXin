d":"t3-883","title":"和宋之问下山歌","kind":"诗"},{"id":"t3-884","title":"孝和皇帝挽歌","kind":"诗"},{"id":"t3-885","title":"奉和春日出苑瞩目应令","kind":"诗"},{"id":"t3-886","title":"有所思","kind":"诗"},{"id":"t3-887","title":"祭汾阴乐章","kind":"诗"}]},"邹象先":{"slug":"邹象先","name":"邹象先","dynasty":"唐","style":"","life":"","origin":"","seal":"邹","bio":["邹象先，开元二十三年进士，与萧颕士为同年生，仕临涣尉。诗一首。"],"works":[{"id":"t13-472","title":"寄萧颕士补正字","kind":"诗"}]},"钱弘倧":{"slug":"钱弘倧","name":"钱弘倧","dynasty":"唐","style":"字隆道","life":"","origin":"","seal":"钱","bio":["弘倧，字隆道，元瓘第七子。兄弘佐卒，弘倧以次立。卑侮宿将胡进思，进思不能平。","岁除，刦幽衣锦军，传位于弟弘俶。徙居东府，即卧龙山置园亭。二十年卒，年四十四。","谥忠逊。著有《越中吟》二十卷。"],"works":[{"id":"t51-668","title":"登卧龙山偶成","kind":"诗"},{"id":"t51-669","title":"禹庙","kind":"诗"},{"id":"t51-670","title":"登蓬莱阁怀武肃王","kind":"诗"},{"id":"t51-671","title":"再游圣母阁（《舆地纪胜》十《绍兴府》诗摘第二联题《游天衣寺》）","kind":"诗"}]},"马友鹿":{"slug":"马友鹿","name":"马友鹿","dynasty":"唐","style":"","life":"","origin":"","seal":"马","bio":["马友鹿，武后时博城县令。（复出一首）"],"works":[{"id":"t50-524","title":"无题","kind":"诗"},{"id":"t50-525","title":"早春陪敕麻先生（慈力）祭岳（久视二年。见《山左金石志》卷十二，亦见《金石萃编》卷五十三。此诗《全唐诗》卷八百八十七补遗卷载之，作者马令，注曰」失名「。今按《山左金石志》署作者曰「行博城县令马友鹿」，则其名固未失也。诗同，不重出，校其异文如下：第三句「鞭挞造神鬼」，「造」《全唐诗》作「走」。五句「忽下元洲使」，「元洲」，《全唐诗》作「袁州」。六句「来赴紫洞前」，「赴」，《全唐诗》作「游」。八句「白鹤怪时还」，「怪」，《全唐诗》阙；「还」，作「年」。十一句「岩风半山水」，「岩」，《全唐诗》阙。十二句","kind":"诗"}]},"高湘":{"slug":"高湘","name":"高湘","dynasty":"唐","style":"字濬之","life":"","origin":"","seal":"高","bio":["高湘，字濬之，铢从子也。擢进士第，咸通中，历谏议大夫，僖宗朝，终江西观察使。诗一首。"],"works":[{"id":"t33-203","title":"和李尚书命妓饯崔侍御","kind":"诗"},{"id":"t33-204","title":"句","kind":"诗"}]}}