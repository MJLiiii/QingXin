[{"id":"c67-800","title":"减字木兰花·凌波不止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["凌波不止。","少小拍浮荷女喜。","出没由风。","安得灵犀与暗通。","龙池醉酒。","应是太真羞见寿。","不晓谁何。","却是浑身一半多。"]},{"id":"c67-801","title":"减字木兰花·渴心先止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["渴心先止。","惟有杨家梅可喜。","争笑梅风。","空怨楼头角数通。","甜浆酿酒。","紫气结成千日寿。","不奈人何。","化作飞星处处多。"]},{"id":"c67-802","title":"减字木兰花·必恭敬止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["必恭敬止。","老子甚为桑梓喜。","骏马争风。","诗卷人人数百通。","斗杓挹酒。","齐祝乡人箕翼寿。","天若言何。","更乞文星下照多。"]},{"id":"c67-803","title":"减字木兰花·锦囊送止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["锦囊送止。","拆看篇篇珠玉喜。","大胜鱼风。","韶沪宫商角徵通。","醉而强酒。","有愧多闻张子寿。","其哂由何。","刻画无盐已甚多。"]},{"id":"c67-804","title":"减字木兰花·竹斋陋止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["竹斋陋止。","坐客无毡为客喜。","壁不遮风。","八达门窗更四通。","邻家觅酒。","赤脚扶翁翁老寿。","子曰其何。","除却渠侬没事多。"]},{"id":"c67-805","title":"减字木兰花·荷公临止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["荷公临止。","宾客惯看儿亦喜。","歌雅歌风。","通鉴通书又史通。","欲相酹酒。","瓦缶田家羞出寿。","甚欲舟何。","愧没瑶觞玉斝多。"]},{"id":"c67-806","title":"减字木兰花·棋枰响止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["棋枰响止。","胜负岂能全两喜。","不竞南风。","忽尔三生六劫通。","客方对酒。","一片捷音来自寿。","甚快人何。","大胜呼庐百万多。"]},{"id":"c67-807","title":"减字木兰花·酒巡未止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["酒巡未止。","先说一些儿事喜。","别调吹风。","佛曲由来自普通。","长鲸吸酒。","面对沈香山刻寿。","吸尽如何。","吸了西江说甚多。"]},{"id":"c67-808","title":"减字木兰花·酒巡未止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["酒巡未止。","听说二疏归可喜。","随意乘风。","拄杖深村狭巷通。","渊明漉酒。","更与庞公庞媪寿。","切莫讥何。","唤取同来作队多。"]},{"id":"c67-809","title":"减字木兰花·酒巡未止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["酒巡未止。","更号三般杨氏喜。","上苑春风。","宝带灵犀点点通。","听歌侑酒。","富贵两全添个寿。","人少兼何。","彭祖人言只寿多。"]},{"id":"c67-810","title":"减字木兰花·酒巡未止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["酒巡未止。","说著四并须著喜。","好月兼风。","好个情怀命又通。","明朝醒酒。","起看佳人妆学寿。","定问人何。","昨夜何人饮最多。"]},{"id":"c67-811","title":"减字木兰花·酒巡未止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["酒巡未止。","更说五行人听喜。","康节淳风。","说道诸公运数通。","乞浆得酒。","更检戊申前定寿。","亥子推何。","甲子生年四百多。"]},{"id":"c67-812","title":"减字木兰花·酒巡未止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["酒巡未止。","鼓吹六经为公喜。","也没回风。","只有村中鼓数通。","长须把酒。","自当长头杯捧寿。","问得穷何。","一坐靴皮笑面多。"]},{"id":"c67-813","title":"减字木兰花·酒巡未止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["酒巡未止。","且听七言馀韵喜。","弹到悲风。","醒酒风吹路必通。","休休避酒。","末后茶仙来献寿。","七碗休何。","不独茶多酒亦多。"]},{"id":"c67-814","title":"减字木兰花·八巡将止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["八巡将止。","八节四时人贺喜。","汉俗成风。","薛老之言贵尚通。","妻儿设酒。","更得比邻相庆寿。","虚度时何。","只恐妻儿怪汝多。"]},{"id":"c67-815","title":"减字木兰花·九巡将止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["九巡将止。","留读九歌章句喜。","尽溘埃风。","发轫苍梧万里通。","楚歌发酒。","读到人生何所寿。","试问原何。","尔独惺然枉了多。"]},{"id":"c67-816","title":"减字木兰花·十巡今止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["十巡今止。","乐事要须防极喜。","烛影摇风。","月落参横影子通。","粗茶淡酒。","五十狂歌供宴寿。","敬谢来何。","再得寻盟后日多。"]},{"id":"c67-817","title":"减字木兰花·陋人居止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["陋人居止。","旬一集真终日喜。","先自薰风。","客目轮流次第通。","昔贤置酒。","十老半千年纪寿。","知彼由何。","真处闲中日月多。"]},{"id":"c67-818","title":"减字木兰花·鸡鸣弗止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["鸡鸣弗止。","弗到天明心弗喜。","投辖成风。","壑谷吾公宜弗通。","齐盟歃酒。","扬觯先听方饮寿。","盟载言何。","卜昼三杯不用多。"]},{"id":"c67-819","title":"减字木兰花·适然萃止","rhythmic":"减字木兰花","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["适然萃止。","不待灯花先报喜。","不速真风。","且免毛生不为通。","诗歌棋酒。","真正清欢真正寿。","事事真何。","更得真真真更多。"]},{"id":"c67-820","title":"野庵曲·野叟最昏迷","rhythmic":"野庵曲","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["野叟最昏迷。","叹世间、光阴奔走如驰。","逢这闲时。","忽寻忖、一生里事都非。","从头到尾。","都改了、重立根基。","枕上披衣。","浑无寐。","时时摩挲行气。","才睡起。","避户扉。","爇一炷清香，烟气霏霏。","膜拜更归依。","冥心坐、看经念佛行持。","消除秽恶，光洒洒、禅律威仪。","佛力慈悲。","愿今世。","永没冤债相随。","食将惭愧。","才饭了、一枕茶香美。","迟迟日长，觅伴相对围棋。","安排势子。","相望相窥。","闭心机。","输赢成败，却似人居世。","跳脱去、唤方帽杖黎。","为伴侣、小桥那边一奄儿。","登高望远输情思。","叹物荣物枯，节换时移。","春到园中，见寒梅同春雪乱飞。","冷艳冰肌。","须臾李杏开遍，一日芳菲。","和风骀荡，两岸细柳拈金丝。","清明时候，景物尤韶媚。","春事退。","叹万红狼籍飞满堤。","水平池。","风到卷涟漪。","荷花一望如霞绮。","对好些景物，敌去炎威。","秋景凄凄。","长空明月正扬辉。","蒹葭岸、浮云侧畔坐钓矾。","正桂花香喷鼻。","黄花满眼，风劲霜坠。","做寒来天气。","秋光老、草木一齐似洗。","独修篁径，青松路，残岁方知。","日将斜，园里缓行归。","听流水。","明窗净几。","调数徽。","到妙处、古曲幽闲韵渐稀。","徐徐弹了融心意。","忽然惊起。","外时闻车履。","故人来相对。","瓮浮蚁。","草草杯盘灯正辉。","漏声迟。","浮斝飞觞，言渐嘻嘻。","轩渠一笑，高歌野奄新唱、劝些儿。","人听村歌，一霎时、好娱戏。","休笑颠狂，也是大奇。","能赶气闷忧悲。","自然沈醉。","客都去后，睡齁齁地。","一枕华胥惊又起。","晓鸡啼。","重起着衣。","心火烧脐。","龙行虎驰。","依前囉囉喱喱。","从头到尾今如此。","若唱此曲没休时。","保取长年到期颐。"]},{"id":"c67-821","title":"醉乡曲·说与贤瞒","rhythmic":"醉乡曲","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["说与贤瞒，这躯壳、安能久仗凭。","幸尊中有酒浇磊块，先交神气平。","醉乡道路无他径。","任陶陶、现出真如性。","没闲恼、没闲争。","也能使情怀长似春。","也能使飘然逸气如云。","饶君万劫修功行。","又争如、一盏乐天真。","这些儿，休放过、且重斟。"]},{"id":"c67-822","title":"驻马听·人都道四者难并","rhythmic":"驻马听","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["人都道四者难并。","也由在人心。","烦恼欢喜元无定。","奸峭底自能称停。","你待前面怎那，且随任咱分。","自家有后自未奔。","枉劳人方寸。","眼前推辞怎。","那知他人也心闷。"]},{"id":"c67-823","title":"风入松·金榜初登","rhythmic":"风入松","author":"沈瀛","authorSlug":"沈瀛","dynasty":"宋","kind":"ci","paragraphs":["金榜初登。","绮楼朱楼对娉婷。","软红尘、有人相等。","归来寝立功名。","油盖拥著一书生。","开宴处、笙歌频奏声。","眼前光景。","人生如意享欢荣。","得酒娱情。","没事汉、清闲人。","任自由、毁誉利害不上心。","恣闲吟。","登山玩水且闲行。","来主他、风华雪月盟。","相逢道友，握手闲语百事真。","得酒忘情。"]},{"id":"c67-824","title":"归去来兮引・归去来兮·侬家贫甚诉长饥","rhythmic":"归去来兮引・归去来兮","author":"杨万里","authorSlug":"杨万里","dynasty":"宋","kind":"ci","paragraphs":["侬家贫甚诉长饥。","幼稚满庭闱。","正坐瓶无储粟，漫求为吏东西。","偶然彭泽近邻圻。","公秫滑流匙。","葛巾劝我求为酒，黄菊怨、冷落东篱。","五斗折腰，谁能许事，归去来兮。","老圃半榛茨。","山田欲蒺藜。","念心为形役又奚悲。","独惆怅前迷。","不谏后方追。","觉今来是了，觉昨来非。","扁舟轻扬破朝霏。","风细漫吹衣。","试问征夫前路，晨光小，恨熹微。","乃瞻衡宇载奔弛。","迎候满荆扉。","已荒三径存松菊，喜诸幼、入室相携。","有酒盈尊，引觞自酌，庭树遣颜怡。","容膝易安栖。","南窗寄傲睨。","更小园日涉趣尤奇。","尽虽设柴门，长是闭斜晖。","纵遐观矫首，短策扶持。","浮云出岫岂心思。","鸟倦亦归飞。","翳翳流光将入，孤松抚处凄其。","息交绝友堑山溪。","世与我相违。","驾言复出何求者，旷千载、今欲从谁。","亲戚笑谈，琴书觞咏，莫遣俗人知。","邂逅又春熙。","农人欲载菑。","告西畴有事要耘耔。","容老子舟车，取意任委蛇。","历崎岖窈窕，丘壑随宜。","欣欣花木向荣滋。","泉水始流澌。","万物得时如许，此生休笑吾衰。","寓形宇内几何时。","岂问去留为。","委心任运无多虑，顾皇皇、将欲何之。","大化中间，乘流归尽，喜惧莫随伊。","富贵本危机。","云乡不可期。","趁良辰、孤往恣游嬉。","独临水登山，舒啸更哦诗。","除乐天知命，了复奚疑。"]},{"id":"c67-825","title":"念奴娇·老夫归去","rhythmic":"念奴娇","author":"杨万里","authorSlug":"杨万里","dynasty":"宋","kind":"ci","paragraphs":["老夫归去，有三径、足可长拖衫袖。","一道官衔清彻骨，别有监临主守。","主守清风，监临明月，兼管栽花柳。","登山临水，作诗三首两首。","休说白日升天，莫夸金印，斗大悬双肘。","且说庐陵传盛事，三个闲人眉寿。","拣罢军员，归农押录，致政诚斋叟。","只愁醉杀，螺江门外私酒。"]},{"id":"c67-826","title":"好事近·月未到诚斋","rhythmic":"好事近","author":"杨万里","authorSlug":"杨万里","dynasty":"宋","kind":"ci","paragraphs":["月未到诚斋，先到万花川谷。","不是诚斋无月，隔一林修竹。","如今才是十三夜，月色已如玉。","未是秋光奇绝，看十五十六。"]},{"id":"c67-827","title":"昭君怨·偶听松梢扑鹿","rhythmic":"昭君怨","author":"杨万里","authorSlug":"杨万里","dynasty":"宋","kind":"ci","paragraphs":["偶听松梢扑鹿。","知是沙鸥来宿。","稚子莫喧哗。","恐惊他。","俄顷忽然飞去。","飞去不知何处。","我已乞归休。","报沙鸥。"]},{"id":"c67-828","title":"昭君怨·午梦扁舟花底","rhythmic":"昭君怨","author":"杨万里","authorSlug":"杨万里","dynasty":"宋","kind":"ci","paragraphs":["午梦扁舟花底。","香满西湖烟水。","急雨打篷声。","梦初惊。","却是池荷跳雨。","散了真珠还聚。","聚作水银窝。","泻清波。"]},{"id":"c67-829","title":"武陵春·长铗归乎逾十暑","rhythmic":"武陵春","author":"杨万里","authorSlug":"杨万里","dynasty":"宋","kind":"ci","paragraphs":["长铗归乎逾十暑，不著鵕鸃冠。","道是今年胜去年。","特地减清欢。","旧赐龙团新作祟，频啜得中寒。","瘦骨如柴痛又酸。","儿信问平安。"]},{"id":"c67-830","title":"水调歌头·玉树映阶秀","rhythmic":"水调歌头","author":"杨万里","authorSlug":"杨万里","dynasty":"宋","kind":"ci","paragraphs":["玉树映阶秀，玉节逐年新。","年年九月，好为阿母作生辰。","涧底蒲芽九节，海底银涛万顷，酿作一杯春。","泛以东篱菊，寿以漆园椿。","对西风，吹鬓雪，炷香云。","郎君入奏，又迎珠幰入修门。","看即金花紫诰，并举莆常两国，册命太夫人。","三点台星上，一点老人星。"]},{"id":"c67-831","title":"忆秦娥·新春早","rhythmic":"忆秦娥","author":"杨万里","authorSlug":"杨万里","dynasty":"宋","kind":"ci","paragraphs":["新春早。","春前十日春归了。","春归了。","落梅如雪，野桃红小。","老夫不管春催老。","只图烂醉花前倒。","花前倒。","儿扶归去，醒来窗晓。"]},{"id":"c67-832","title":"眼儿媚·鬓边一点似飞鸦","rhythmic":"眼儿媚","author":"某教授","authorSlug":"某教授","dynasty":"宋","kind":"ci","paragraphs":["鬓边一点似飞鸦。","莫把翠钿遮。","三年两载，千撋百就，今日天涯。","杨花又逐东风去，随分落谁家。","若还忘得，除非睡起，不照菱花。"]},{"id":"c67-833","title":"水调歌头·重过钓台路","rhythmic":"水调歌头","author":"陈居仁","authorSlug":"陈居仁","dynasty":"宋","kind":"ci","paragraphs":["重过钓台路，风物故依然。","羊裘轩上，俯临清泚面孱颜。","仰见先生风节，更有两公名德，冰雪照人寒。","龙野方驰逐，鸿翼自孤骞。","酹壶觞，追往昔，笑华颠。","别来三纪，推排曾戴侍臣冠。","惭愧君恩难答，聊复守符重绾，敢叹客途艰。","少报期年政，行泛五湖船。"]},{"id":"c67-834","title":"满庭芳·香满千岩","rhythmic":"满庭芳","author":"李洪","authorSlug":"李洪","dynasty":"宋","kind":"ci","paragraphs":["香满千岩，芳传丛桂，小山曾咏幽菲。","仙姿冷淡，不奈此香奇。","翠葆层层障日，深爱惜、早被风吹。","秋英嫩，夜来露浥，月底半离披。","谁知。","清品贵，带装金粟，韵透文犀。","与降真为侣，罗袖相宜。","宝鸭休薰百濯，清芬在、常惹人衣。","姮娥约，广寒宫殿，留折最高枝。"]},{"id":"c67-835","title":"满江红·梅雨成霖","rhythmic":"满江红","author":"李洪","authorSlug":"李洪","dynasty":"宋","kind":"ci","paragraphs":["梅雨成霖，倦永昼、暑行岩曲。","爱云梢翠樾，枕溪蓬屋。","轻木凌波冲卷雪，飞泉奔壑呜哀玉。","羡渔翁、终岁老烟波，披蓑绿。","嗟客宦，荒松菊。","颓壮志，青编竹。","更长年谙尽，是非荣辱。","钟鼎无心时节异，山林有味簟瓢足。","感故人、於此赋归欤，思之熟。"]},{"id":"c67-836","title":"南乡子·挂席泛安流","rhythmic":"南乡子","author":"李洪","authorSlug":"李洪","dynasty":"宋","kind":"ci","paragraphs":["挂席泛安流。","细雨斜风到渡头。","万叠云鬟真似画，云州。","自古诗人几个游。","旌旆去悠悠。","别驾无功愧食浮。","却忆五湖烟浪里，扁舟。","第四桥南云水秋。"]},{"id":"c67-837","title":"鹧鸪天·十月南闽未有霜","rhythmic":"鹧鸪天","author":"李洪","authorSlug":"李洪","dynasty":"宋","kind":"ci","paragraphs":["十月南闽未有霜。","蕉林蔗圃郁相望。","压枝橄榄浑如画，透甲香橙半弄黄。","斟绿醑，泛沧浪。","白沙翠竹近温汤。","分明水墨山阴道，只欠冰溪雪月光。"]},{"id":"c67-838","title":"西江月·渺渺长汀远壑","rhythmic":"西江月","author":"李洪","authorSlug":"李洪","dynasty":"宋","kind":"ci","paragraphs":["渺渺长汀远壑，萧萧雨叶风枝。","几回临水送将归。","客里暗添憔悴。","门枕数峰滴翠，舟横几度涟漪。","绿秧深处鹭于飞。","愈觉田园有味。"]},{"id":"c67-839","title":"菩萨蛮·寒山横抹修眉绿","rhythmic":"菩萨蛮","author":"李洪","authorSlug":"李洪","dynasty":"宋","kind":"ci","paragraphs":["寒山横抹修眉绿。","楼前溪瀑锵鸣玉。","车马各西东。","行人如转蓬。","阑干成独倚。","海阔天无际。","云淡隔壶山。","鸿飞杳霭间。"]},{"id":"c67-840","title":"浣溪沙·夭矫翔鸾溪上峰","rhythmic":"浣溪沙","author":"李洪","authorSlug":"李洪","dynasty":"宋","kind":"ci","paragraphs":["夭矫翔鸾溪上峰。","飘萧雪霰打船篷。","天花凌乱水晶宫。","飞透纸窗斜取势，吹回溪面舞因风。","身游水墨画图中。"]},{"id":"c67-841","title":"浣溪沙·碧涧苍崖玉四围","rhythmic":"浣溪沙","author":"李洪","authorSlug":"李洪","dynasty":"宋","kind":"ci","paragraphs":["碧涧苍崖玉四围。","东君翦水散明玑。","半开桃杏不胜威。","疑是群仙游阆苑，歌云舞蝶斗高飞。","珠幢玉节送人归。"]},{"id":"c67-842","title":"浣溪沙·扫地烧香绝点尘","rhythmic":"浣溪沙","author":"李洪","authorSlug":"李洪","dynasty":"宋","kind":"ci","paragraphs":["扫地烧香绝点尘。","绿阶绿草又残春。","略无闲事挠天真。","时落燕泥沾几席，乱粘飞絮上衣巾。","西湖回柁少年人。"]},{"id":"c67-843","title":"念奴娇·丽谯吹角","rhythmic":"念奴娇","author":"李洪","authorSlug":"李洪","dynasty":"宋","kind":"ci","paragraphs":["丽谯吹角，渐疏星明澹，帘筛残月。","袅袅霜飙欺翠袖，飞下一庭香雪。","半面妆新，回风舞困，此况真奇绝。","桄榔林里，苏仙偏感华发。","休怨时暂飘零，玉堂清梦，不惹闲蜂蝶。","好似王家从竹畔，乘兴山阴时节。","剪水无情，阆风归去，忍使芳心歇。","和羹有待，恁时身到天阕。"]},{"id":"c67-844","title":"卜算子·南国小春时","rhythmic":"卜算子","author":"李洪","authorSlug":"李洪","dynasty":"宋","kind":"ci","paragraphs":["南国小春时，常是寒威浅。","玉缀香苞已有梅，疏影无人见。","愁忆故园芳，梦断扬州远。","不御铅华自出尘，赛过徐妃面。"]},{"id":"c67-845","title":"鹊桥仙·迢迢郎意","rhythmic":"鹊桥仙","author":"李漳","authorSlug":"李漳","dynasty":"宋","kind":"ci","paragraphs":["迢迢郎意，盈盈妾恨，今夕鹊桥欲度。","世间儿女一何痴，斗乞巧、纷纷无数。","遥知此际，有人孤坐，心切天街云路。","好因缘是恶因缘，梦魂远、阳台雨暮。"]},{"id":"c67-846","title":"桃源忆故人·小楼帘卷栏干外","rhythmic":"桃源忆故人","author":"李漳","authorSlug":"李漳","dynasty":"宋","kind":"ci","paragraphs":["小楼帘卷栏干外。","花下朱门半启。","中有倾城佳丽。","一笑西风里。","盈盈临水情难致。","尽日相看如醉。","乾鹊不知人意。","只管声声喜。"]},{"id":"c67-847","title":"满江红·雨歇前林","rhythmic":"满江红","author":"李漳","authorSlug":"李漳","dynasty":"宋","kind":"ci","paragraphs":["雨歇前林，薰风度、琴声清淑。","绮窗迥、张眉初扫，弄弦鸣玉。","三叠瑶池仙侣宴，九江鹤唳清江曲。","政伯鸾、此日梦维熊，祥烟馥。","金徽外，音时续。","雕筵上，听难足。","且相将一醉，满倾醽醁。","共祝遐龄何所似，水流不尽高山矗。","算未应、归去抱琴书，云间宿。"]},{"id":"c67-848","title":"鹧鸪天·淑德由来孟母名","rhythmic":"鹧鸪天","author":"李漳","authorSlug":"李漳","dynasty":"宋","kind":"ci","paragraphs":["淑德由来孟母名。","方瞳鹤发莹精神。","天教遐算灵椿比，亲见贤郎擢桂荣。","逢诞日，庆孙曾。","金花纶诰又重新。","愿君学得司空母，管取年高寿太平。"]},{"id":"c67-849","title":"生查子·家承阀阅高","rhythmic":"生查子","author":"李漳","authorSlug":"李漳","dynasty":"宋","kind":"ci","paragraphs":["家承阀阅高，人擅闺房秀。","嫁得伯鸾夫，直是齐眉偶。","榴花著子时，萱草宜男候。","一笑捧觥船，共祝人常寿。"]},{"id":"c67-850","title":"南歌子·小子何时见","rhythmic":"南歌子","author":"李漳","authorSlug":"李漳","dynasty":"宋","kind":"ci","paragraphs":["小子何时见，高秋此日生。","阶兰岩桂正欣荣。","家比杜陵犹有、彩衣轻。","应诏须三载，传家有一经。","齐禽刷羽早蜚鸣。","莫效老夫头白、好归耕。"]},{"id":"c67-851","title":"水调歌头·危楼云雨上","rhythmic":"水调歌头","author":"李泳","authorSlug":"李泳","dynasty":"宋","kind":"ci","paragraphs":["危楼云雨上，其下水扶天。","群山四合，飞动寒翠落檐前。","尽是秋清栏槛，一笑波翻涛怒，雪阵卷苍烟。","炎暑去无迹，清驶久翩翩。","夜将阑，人欲静，月初圆。","素娥弄影，光射空际绿婵娟。","不用濯缨垂钓，唤取龙宫仙驾，耕此万琼田。","横笛望中起，吾意已超然。"]},{"id":"c67-852","title":"贺新郎·门掩长安道","rhythmic":"贺新郎","author":"李泳","authorSlug":"李泳","dynasty":"宋","kind":"ci","paragraphs":["门掩长安道。","卷重帘、垂杨散暑，嫩凉生早。","午梦惊回庭阴翠，蝶舞莺吟未了。","政露冷、芙蓉池沼。","金雁尘昏么弦断，理馀音、尚想腰支袅。","欢渐远，思还绕。","临皋望极苍江渺。","晚潮平、湘烟万顷，断虹残照。","彩舫凌波分飞后，别浦菱花自老。","问锦鲤、何时重到。","楼迥层城看不见，对潇潇、暮雨怜芳草。","幽恨阔、楚天杳。"]},{"id":"c67-853","title":"定风波·点点行人趁落晖","rhythmic":"定风波","author":"李泳","authorSlug":"李泳","dynasty":"宋","kind":"ci","paragraphs":["点点行人趁落晖。","摇摇烟艇出渔扉。","一路水香流不断。","零乱。","春潮绿浸野蔷薇。","南去北来愁几许，登临怀古欲沾衣。","试问越王歌舞地。","佳丽。","只今惟有鹧鸪啼。"]},{"id":"c67-854","title":"满庭芳·麦秀连云","rhythmic":"满庭芳","author":"李洤","authorSlug":"李洤","dynasty":"宋","kind":"ci","paragraphs":["麦秀连云，桑枝重绿，史君佳政流传。","凤衔丹诏，来自九重天。","千里欢腾祖帐，棠阴外、多少攀辕。","津亭路，紞如五鼓，难驻邓侯船。","光华，家世事，门中列戟，圯上遗编。","况建炎勋业，图画凌烟。","此去朝端济美，看平步、两两台躔。","须知道，中兴盛治，主圣赖臣贤。"]},{"id":"c67-855","title":"西江月·可是江梅开晚","rhythmic":"西江月","author":"李洤","authorSlug":"李洤","dynasty":"宋","kind":"ci","paragraphs":["可是江梅开晚，从教蜡雪来迟。","此花清绝胜南枝。","搀过春风第一。","蘸蜡女工斗巧，涂黄汉额偏宜。","□腮相倚并开时。","认取东君深意。"]},{"id":"c67-856","title":"踏莎行·红药香残","rhythmic":"踏莎行","author":"李淛","authorSlug":"李淛","dynasty":"宋","kind":"ci","paragraphs":["红药香残，绿筠粉嫩。","春归何处寻春信。","绣鞍初上马啼轻，举头便觉长安近。","别酒无情，啼妆有恨。","山城向晚斜阳褪。","清江极目带寒烟，锦鳞去后凭谁问。"]},{"id":"c67-857","title":"满庭芳·油幕新开","rhythmic":"满庭芳","author":"李淛","authorSlug":"李淛","dynasty":"宋","kind":"ci","paragraphs":["油幕新开，騂旄前导，暂归梓里舂容。","致身槐府，功在鼎彛中。","慨想东山故侣，烟霞外，久阔仙踪。","今何幸，相逢吐握，谈笑一尊同。","德星，占瑞处，旌髦五马，衮绣三公。","对渭川遗老，绛县仙翁。","厚意杯传绀玉，那堪更，篚实囊红。","拼沈醉，今宵盛事，复见古人风。"]},{"id":"c67-858","title":"千秋岁·鄮峰凝瑞","rhythmic":"千秋岁","author":"李淛","authorSlug":"李淛","dynasty":"宋","kind":"ci","paragraphs":["鄮峰凝瑞，鄞水浮佳气。","晴景转，花光媚。","碧幢森大纛，红旆纷千骑。","相遇处，满城鹤发群仙萃。","绮席张高会。","鼍鼓笙箫沸。","金兽袅，檀烟翠。","玉山环回座，休惜今朝醉。","觞再举，清歌共引千秋岁。"]},{"id":"c67-859","title":"浣溪沙·压架年来雪作堆","rhythmic":"浣溪沙","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["压架年来雪作堆。","珍丛也是近移栽。","肯令容易放春回。","却恐阴晴无定度，从教红白一时开。","多情蜂蝶早飞来。"]},{"id":"c67-860","title":"菩萨蛮·晚红飞尽春寒浅","rhythmic":"菩萨蛮","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["晚红飞尽春寒浅。","浅寒春尽飞红晚。","尊酒绿阴繁。","繁阴绿酒尊。","老仙诗句好。","好句诗仙老。","长恨送年芳。","芳年送恨长。"]},{"id":"c67-861","title":"菩萨蛮·暮江寒碧萦长路","rhythmic":"菩萨蛮","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["暮江寒碧萦长路。","路长萦碧寒江暮。","花坞夕阳斜。","斜阳夕坞花。","客愁无胜集。","集胜无愁客。","醒似醉多情。","情多醉似醒。"]},{"id":"c67-862","title":"好事近·春色欲来时","rhythmic":"好事近","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["春色欲来时，先散满天风雪。","坐使七闽松竹，变珠幢玉节。","中原佳气郁葱葱，河山壮宫阕。","丞相功成千载，映黄流清彻。"]},{"id":"c67-863","title":"西江月·睡处林风瑟瑟","rhythmic":"西江月","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["睡处林风瑟瑟，觉来山月团团。","身心无累久轻安。","况有清池凉馆。","句稳翻嫌白俗，情高却笑郊寒。","兰膏元自少陵残。","好处金章不换。"]},{"id":"c67-864","title":"西江月·堂下水浮新绿","rhythmic":"西江月","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["堂下水浮新绿，门前树长交枝。","晚凉快写一篇诗。","不说人间忧喜。","身老心闲益壮，形癯道胜还肥。","软轮加璧未应迟。","莫道前非今是。"]},{"id":"c67-865","title":"鹧鸪天·暮雨朝云不自怜","rhythmic":"鹧鸪天","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["暮雨朝云不自怜。","放教春涨绿浮天。","祗令画阁临无地，宿昔新诗满系船。","青鸟外，白鸥前。","几生香火旧因缘。","酒阑山月移雕槛，歌罢江风拂玳筵。"]},{"id":"c67-866","title":"鹧鸪天·已分江湖寄此生","rhythmic":"鹧鸪天","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["已分江湖寄此生。","长蓑短笠任阴晴。","鸣桡细雨沧洲远，系舸斜阳画阁明。","奇绝处，未忘情。","几时还得去寻盟。","江妃定许捐双佩，渔父何劳笑独醒。"]},{"id":"c67-867","title":"鹧鸪天·脱却儒冠著羽衣","rhythmic":"鹧鸪天","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["脱却儒冠著羽衣。","青山绿水浩然归。","看成鼎内真龙虎，管甚人间闲与非。","生羽翼，上烟霏。","回头祗见冢累累。","未寻跨凤吹箫侣，且伴孤云独鹤飞。"]},{"id":"c67-868","title":"南乡子·落日照楼船","rhythmic":"南乡子","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["落日照楼船。","稳过澄江一片天。","珍重使君留客意，依然。","风月从今别一川。","离绪悄危弦。","永夜清霜透幕毡。","明日回头江树远，怀贤。","目断晴空雁字连。"]},{"id":"c67-869","title":"满江红·秀野诗翁","rhythmic":"满江红","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["秀野诗翁，念故山、十年乖隔。","聊命驾、朱门旧隐，绿槐新陌。","好雨初晴仍半暖，金釭玉斝开瑶席。","更流传、丽藻借江天，留春色。","过里社、将儿侄。","谈往事，悲陈迹。","喜尊前现在，镜中如昔。","两鬓全期烟树绿，方瞳好映寒潭碧。","但一年、一度一归来，欢何极。"]},{"id":"c67-870","title":"水调歌头·富贵有馀乐","rhythmic":"水调歌头","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["富贵有馀乐，贫贱不堪忧。","谁知天路幽险，倚伏互相酬。","请看东门黄犬，更听华亭清唳，千古恨难收。","何似鸱夷子，散发弄扁舟。","鸱夷子，成霸业，有馀谋。","致身千乘卿相，归把钓渔钩。","春画五湖烟浪，秋夜一天云月，此外尽悠悠。","永弃人间事，吾道付沧洲。"]},{"id":"c67-871","title":"水调歌头·长记与君别","rhythmic":"水调歌头","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["长记与君别，丹凤九重城。","归来故里，愁思怅望渺难平。","今夕不知何夕，得共寒潭烟艇，一笑俯空明。","有酒径须醉，无事莫关情。","寻梅去，疏竹外，一枝横。","与君吟弄风月，端不负平生。","何处车尘不到，有个江天如许，争肯换浮名。","只恐买山隐，却要炼丹成。"]},{"id":"c67-872","title":"水调歌头·江水浸云影","rhythmic":"水调歌头","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["江水浸云影，鸿雁欲南飞。","携壶结客，何处空翠渺烟霏。","尘世难逢一笑，况有紫萸黄菊，堪插满头归。","风景今朝是，身世昔人非。","酬佳节，须酩酊，莫相违。","人生如寄，何事辛苦怨斜晖。","无尽今来古往，多少春花秋月，那更有危机。","与问牛山客，何必独沾衣。"]},{"id":"c67-873","title":"念奴娇·临风一笑","rhythmic":"念奴娇","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["临风一笑，问群芳谁是，真香纯白。","独立无朋，算只有、姑射山头仙客。","绝艳谁怜，真心自保，邈与尘缘隔。","天然殊胜，不关风露冰雪。","应笑俗李粗桃，无言翻引得，狂蜂轻蝶。","争似黄昏闲弄影，清浅一溪霜月。","画角吹残，瑶台梦断，直下成休歇。","绿阴青子，莫教容易波折。"]},{"id":"c67-874","title":"水调歌头·雪月两相映","rhythmic":"水调歌头","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["雪月两相映，水石互悲鸣。","不知岩上枯木，今夜若为情。","应见尘中胶扰。","便道山间空旷，与麽了平生。","与麽平生了，□水不流行。","起披衣，瞻碧汉，露华清。","寥寥千载，此事本分明。","若向乾坤识易，便信行藏无间，处处总圆成。","记取渊冰语，莫错定盘星。"]},{"id":"c67-875","title":"忆秦娥·云垂幕","rhythmic":"忆秦娥","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["云垂幕。","阴风惨淡天花落。","天花落。","千林琼玖，一空鸾鹤。","征车渺渺穿华薄。","路迷迷路增离索。","增离索。","剡溪山水，碧湘楼阁。"]},{"id":"c67-876","title":"忆秦娥·梅花发","rhythmic":"忆秦娥","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["梅花发。","寒梢挂著瑶台月。","瑶台月。","和羹心事，履霜时节。","野桥流水声呜咽。","行人立马空愁绝。","空愁绝。","为谁凝伫，为谁攀折。"]},{"id":"c67-877","title":"水调歌头·不见严夫子","rhythmic":"水调歌头","author":"朱熹","authorSlug":"朱熹","dynasty":"宋","kind":"ci","paragraphs":["不见严夫子，寂莫富春山。","空馀千丈危石，高插暮云端。","想象羊裘披了，一笑两忘身世，来把钓鱼竿。","不似林间翮，飞倦始知还。","中兴主，功业就，鬓毛斑。","驰驱一世豪杰，相与济时艰。","独委狂奴心事，不羡痴儿鼎足，放去任疏顽。","爽气动心斗，千古照林峦。"]},{"id":"c67-878","title":"江神子・江城子·秋风袅袅夕阳红","rhythmic":"江神子・江城子","author":"黄铢","authorSlug":"黄铢","dynasty":"宋","kind":"ci","paragraphs":["秋风袅袅夕阳红。","晚烟浓。","暮云重。","万叠青山，山外叫孤鸿。","独上高楼三百尺，凭玉楯，睇层空。","人间日月去匆匆。","碧梧桐。","又西风。","北去南来，销尽几英雄。","掷下玉尊天外去，多少事，不言中。"]},{"id":"c67-879","title":"菩萨蛮·海山翠叠青螺浅","rhythmic":"菩萨蛮","author":"黄铢","authorSlug":"黄铢","dynasty":"宋","kind":"ci","paragraphs":["海山翠叠青螺浅。","暮云散尽天容远。","匹马度江皋。","北风生怒号。","解鞍栖倦翮。","皓月空庭白。","何处小阑干。","玉箫吹夜寒。"]},{"id":"c67-880","title":"渔家傲·永日离忧千万绪","rhythmic":"渔家傲","author":"黄铢","authorSlug":"黄铢","dynasty":"宋","kind":"ci","paragraphs":["永日离忧千万绪。","雪舟远泛清漳浦。","珍重故人寒夜语。","挥玉麈。","沈沈画阁凝香雾。","风砌落花留不住。","红蜂翠蝶闲飞舞。","明日柳营江上路。","云起处。","苍山万叠人归去。"]},{"id":"c67-881","title":"卜算子·去又如何去","rhythmic":"卜算子","author":"高宣教","authorSlug":"高宣教","dynasty":"宋","kind":"ci","paragraphs":["去又如何去。","住又如何住。","但得山花插满头。","休问奴归处。"]},{"id":"c67-882","title":"卜算子·不是爱风尘","rhythmic":"卜算子","author":"严蕊","authorSlug":"严蕊","dynasty":"宋","kind":"ci","paragraphs":["不是爱风尘，似被前身误。","花落花开自有时，总是东君主。","去也终须去。","住也如何住。","若得山花插满头，莫问奴归处。"]},{"id":"c67-883","title":"如梦令·道是梨花不是","rhythmic":"如梦令","author":"严蕊","authorSlug":"严蕊","dynasty":"宋","kind":"ci","paragraphs":["道是梨花不是。","道是杏花不是。","白白与红红，别是东风情味。","曾记。","曾记。","人在武陵微醉。"]},{"id":"c67-884","title":"鹊桥仙·碧梧初出","rhythmic":"鹊桥仙","author":"严蕊","authorSlug":"严蕊","dynasty":"宋","kind":"ci","paragraphs":["碧梧初出，桂花才吐，池上水花微谢。","穿针人在合欢楼，正月露、玉盘高泻。","蛛忙鹊懒，耕慵织倦，空做古今佳话。","人间刚道隔年期，指天上、方才隔夜。"]},{"id":"c67-885","title":"满江红·胶扰劳生","rhythmic":"满江红","author":"晦庵","authorSlug":"晦庵","dynasty":"宋","kind":"ci","paragraphs":["胶扰劳生，待足后、何时是足。","据见定、随家丰俭，便堪龟缩。","得意浓时休进步，须知世事多翻覆。","漫教人、白了少年头，徒碌碌。","谁不爱，黄金屋。","谁不羡，千锺禄。","奈五行不是，这般题目。","枉费心神空计较，儿孙自有儿孙福。","也不须、采药访神仙，惟寡欲。"]},{"id":"c67-886","title":"清平乐·风韶雨秀","rhythmic":"清平乐","author":"徐逸","authorSlug":"徐逸","dynasty":"宋","kind":"ci","paragraphs":["风韶雨秀。","春已平分后。","陡顿故人疏把酒。","闲恁画阑搔首。","争须携手踏青。","人生几度清明。","待得燕慵莺懒，杨花点点浮萍。"]},{"id":"c67-887","title":"五福降中天·月胧烟澹霜蹊滑","rhythmic":"五福降中天","author":"沈端节","authorSlug":"沈端节","dynasty":"宋","kind":"ci","paragraphs":["月胧烟澹霜蹊滑，孤宿暮林荒驿。","绕树微吟，巡檐索笑，自分平生相得。","冰池半释。","正节物惊心，泪痕沾臆。","流水溅溅，照影古寺满春色。","沈叹今年未识。","暗香微动处，人□初寂。","酷爱芳姿，最怜幽韵，来款禅房深密。","他时恨□。","怅却月凌风，信音难的。","雪底幽期，为谁还露立。"]},{"id":"c67-888","title":"卜算子·愁极强登临","rhythmic":"卜算子","author":"沈端节","authorSlug":"沈端节","dynasty":"宋","kind":"ci","paragraphs":["愁极强登临，毕竟愁难避。","千里江山黯淡中，总是悲秋意。","谁插菊花枝，谁带茱萸佩。","独倚阑干醉不成，日暮西风起。"]},{"id":"c67-889","title":"卜算子·冷蕊伴疏枝","rhythmic":"卜算子","author":"沈端节","authorSlug":"沈端节","dynasty":"宋","kind":"ci","paragraphs":["冷蕊伴疏枝，一笑何时共。","江北江南两处愁，忍看花影动。","旅泊怕逢春，卜睡都无梦。","岁暮何郎未得归，手拈频呵冻。"]},{"id":"c67-890","title":"卜算子·踏雪探孤芳","rhythmic":"卜算子","author":"沈端节","authorSlug":"沈端节","dynasty":"宋","kind":"ci","paragraphs":["踏雪探孤芳，只有诗人共。","守定南枝待得开，不觉冰轮动。","却月与凌风，谩说扬州梦。","想见雕阑曲沼边，残雪和烟冻。"]},{"id":"c67-891","title":"卜算子·客里见梅花","rhythmic":"卜算子","author":"沈端节","authorSlug":"沈端节","dynasty":"宋","kind":"ci","paragraphs":["客里见梅花，独赏无人共。","风度精神总是伊，又是归心动。","把酒破忧端，熏被寻佳梦。","梦觉香残一味寒，有泪都成冻。"]},{"id":"c67-892","title":"卜算子·烘手熨笙簧","rhythmic":"卜算子","author":"沈端节","authorSlug":"沈端节","dynasty":"宋","kind":"ci","paragraphs":["烘手熨笙簧，呵冻匀酥面。","闲向梅花树下行，拜月遥相见。","何处托春心，乐府流深怨。","却拈寒窗傍绮疏，恨极东风远。"]},{"id":"c67-893","title":"忆秦娥·凭阑独","rhythmic":"忆秦娥","author":"沈端节","authorSlug":"沈端节","dynasty":"宋","kind":"ci","paragraphs":["凭阑独。","南山影蘸杯心绿。","杯心绿。","悠然忽见，卧披横轴。","西风暗度钗梁玉。","手香记得人簪菊。","人簪菊。","无穷幽韵，细看不足。"]},{"id":"c67-894","title":"惜分飞·喜入眉心黄点莹","rhythmic":"惜分飞","author":"沈端节","authorSlug":"沈端节","dynasty":"宋","kind":"ci","paragraphs":["喜入眉心黄点莹。","珠佩玲珑透影。","风露萧萧冷。","梦回月窟香成阵。","秋后情怀君莫问。","拼了因他瘦损。","不似寻常韵。","细看没处安排闷。"]},{"id":"c67-895","title":"南歌子·远树昏鸦闹","rhythmic":"南歌子","author":"沈端节","authorSlug":"沈端节","dynasty":"宋","kind":"ci","paragraphs":["远树昏鸦闹，衰芦睡鸭双。","雪篷烟棹炯寒光。","疑是风林纤月、到船窗。","时序惊心破，江山引梦长。","思量也待不思量。","泪染罗巾犹带、旧时香。"]},{"id":"c67-896","title":"鹊桥仙·怀人意思","rhythmic":"鹊桥仙","author":"沈端节","authorSlug":"沈端节","dynasty":"宋","kind":"ci","paragraphs":["怀人意思，悲秋情绪，长是文园病后。","蛛丝轻袅玉钗风，想花貌、参差依旧。","无穷往事，一襟新恨，老泪淋浪卮酒。","天涯相对话平生，怅南北、还如箕斗。"]},{"id":"c67-897","title":"醉落魄・一斛珠·红娇翠弱","rhythmic":"醉落魄・一斛珠","author":"沈端节","authorSlug":"沈端节","dynasty":"宋","kind":"ci","paragraphs":["红娇翠弱。","春寒睡起慵匀掠。","些儿心事谁能学。","深院无人，时有燕穿幕。","漏声滴尽莲花萼。","静看月转西阑角。","世情一任浮云薄。","花与东君，却解慰流落。"]},{"id":"c67-898","title":"太常引·三三五五短长亭","rhythmic":"太常引","author":"沈端节","authorSlug":"沈端节","dynasty":"宋","kind":"ci","paragraphs":["三三五五短长亭。","都只解、送人行。","天远树冥冥。","怅好梦、才成又惊。","夜堂歌罢，小楼钟断，归路已闻莺。","应是困瞢腾。","问心绪、而今怎生。"]},{"id":"c67-899","title":"谒金门·真个忆","rhythmic":"谒金门","author":"沈端节","authorSlug":"沈端节","dynasty":"宋","kind":"ci","paragraphs":["真个忆。","花下雨声初息。","猛记乌衣曾旧识。","丁宁教去觅。","春半峭寒犹力。","泪滴两襟成迹。","独倚危阑清昼寂。","草长流翠碧。"]}]