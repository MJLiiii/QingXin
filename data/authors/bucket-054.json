{"刘济":{"slug":"刘济","name":"刘济","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"t0-955","title":"横吹曲辞 出塞曲","kind":"诗"}]},"吴氏1":{"slug":"吴氏1","name":"吴氏1","dynasty":"宋","style":"","life":"","origin":"","seal":"吴","bio":[],"works":[{"id":"c58-667","title":"定风波·待得明年重把酒","kind":"词"}]},"国学生":{"slug":"国学生","name":"国学生","dynasty":"宋","style":"","life":"","origin":"","seal":"国","bio":[],"works":[{"id":"c73-424","title":"沁园春·三学上书","kind":"词"}]},"崔郊":{"slug":"崔郊","name":"崔郊","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":["崔郊，元和间秀才。诗一首。"],"works":[{"id":"t27-205","title":"赠去婢","kind":"诗"}]},"常衮":{"slug":"常衮","name":"常衮","dynasty":"唐","style":"","life":"","origin":"","seal":"常","bio":["常衮，京兆人。天宝末，举进士，历太子正字。宝应二年，为翰林学士、考功员外郎中、知制诰。","文章俊拔，当时推重。永泰元年，迁中书舍人，累上章陈西北利害，代宗甚顾遇之，加集贤院学士。大历初，拜门下侍郎，同平章事，与杨绾并掌机务，后出为福建观察使。","集十卷，今存诗九首。"],"works":[{"id":"t13-424","title":"奉和圣制麟德殿燕百僚应制","kind":"诗"},{"id":"t13-425","title":"晚秋集贤院即事寄徐薛二侍郎","kind":"诗"},{"id":"t13-426","title":"早秋望华清宫树因以成咏","kind":"诗"},{"id":"t13-427","title":"和考功员外杪秋忆终南旧宅之作","kind":"诗"},{"id":"t13-428","title":"题金吾郭将军石洑茅堂","kind":"诗"},{"id":"t13-429","title":"登栖霞寺","kind":"诗"},{"id":"t13-430","title":"逢南中使寄岭外故人","kind":"诗"},{"id":"t13-431","title":"代员将军罢战后归故里","kind":"诗"},{"id":"t13-432","title":"咏冬瑰花","kind":"诗"},{"id":"t13-433","title":"句","kind":"诗"},{"id":"t50-608","title":"送薛县丞还家","kind":"诗"},{"id":"t50-609","title":"赴京旅次感怀","kind":"诗"},{"id":"t53-28","title":"浮萍赋附歌","kind":"诗"}]},"德宗皇帝":{"slug":"德宗皇帝","name":"德宗皇帝","dynasty":"唐","style":"","life":"","origin":"","seal":"德","bio":["帝讳适，代宗长子，初封奉节郡王。乾元元年，进封鲁王。八月，徙封雍王。","广德二年，立为皇太子。善属文，尤长于篇什。每与学士言诗于浴堂殿，夜分不寐。","三令节，御制诗敕群臣赓和，品第优劣，四方贡艺者，帝多亲试。或有乖谬，浓点笔抹之。称旨，即翘足朗吟。","诧宰相，此朕门生，无不服帝之藻鉴焉。在位二十五年，谥曰孝文。集不传，今存诗十五首。"],"works":[{"id":"t0-185","title":"中和节日宴百僚赐诗","kind":"诗"},{"id":"t0-186","title":"中和节赐百官燕集因示所怀","kind":"诗"},{"id":"t0-187","title":"重阳日赐宴曲江亭赋六韵诗用清字","kind":"诗"},{"id":"t0-188","title":"九月十八赐百僚追赏因书所怀","kind":"诗"},{"id":"t0-189","titl