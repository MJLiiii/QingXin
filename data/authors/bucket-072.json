{"丁求安":{"slug":"丁求安","name":"丁求安","dynasty":"宋","style":"","life":"","origin":"","seal":"丁","bio":[],"works":[{"id":"c78-403","title":"踏莎行·风卷霜浓","kind":"词"},{"id":"c78-404","title":"踏莎行·紫府延龄","kind":"词"}]},"乔舜":{"slug":"乔舜","name":"乔舜","dynasty":"唐","style":"字亚元","life":"","origin":"","seal":"乔","bio":["乔舜，字亚元，高邮人。初为秘书省正字，保大中，历中书舍人，终刑部侍郎。诗一首。"],"works":[{"id":"t42-446","title":"送德林郎中学士赴东府","kind":"诗"},{"id":"t51-636","title":"小梅（句）（徐铉《和亚元长歌》中有句云：「开缄试读相思字，乃是多情乔亚元。短韵三篇皆丽绝，小梅寄意情偏切。」自注：「亚元诗云云。此语尤嘉。」）","kind":"诗"}]},"于逖":{"slug":"于逖","name":"于逖","dynasty":"唐","style":"","life":"","origin":"","seal":"于","bio":["于逖，开元时人，李白、独孤及皆有诗赠之，亦与元结友善。诗二首。"],"works":[{"id":"t13-531","title":"野外行","kind":"诗"},{"id":"t13-532","title":"忆舍弟","kind":"诗"}]},"云容":{"slug":"云容","name":"云容","dynasty":"唐","style":"","life":"","origin":"","seal":"云","bio":[],"works":[{"id":"t47-242","title":"逸句","kind":"诗"}]},"尉迟汾":{"slug":"尉迟汾","name":"尉迟汾","dynasty":"唐","style":"","life":"","origin":"","seal":"尉","bio":[],"works":[{"id":"t49-49","title":"府尹王侍郎准制拜岳因状嵩高灵胜寄呈三十韵","kind":"诗"}]},"崔远":{"slug":"崔远","name":"崔远","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":["远，博陵安平人，吏部侍郎澹子。龙纪元年登进士第。大顺初，以员外郎知制诰，召充翰林学士，正拜中书舍人。","干宁三年，转户部侍郎、兵部侍郎承旨，寻以本官同平章事，迁中书侍郎兼吏部尚书。天祐初，从昭宗东迁洛阳，罢相，守右仆射。二年，为柳璨希朱全忠意，累贬白州长史，旋被害。","远文才清丽，风神峻整，为时所重。诗一首。（《全唐诗》无崔远诗，事迹据《旧唐书》卷一七七《崔珙传》附本传）"],"works":[{"id":"t54-366","title":"送广利大师归江东","kind":"诗"}]},"慧藏":{"slug":"慧藏","name":"慧藏","dynasty":"唐","style":"","life":"","origin":"","seal":"慧","bio":["慧藏，抚州人。嗣汉州什邡僧道一，列大鉴之四世。世称石巩和尚。","诗一首。（《全唐诗》无慧藏诗，传录《景德传灯录》卷六）"],"works":[{"id":"t53-434","title":"弄珠吟","kind":"诗"}]},"戴公怀":{"slug":"戴公怀","name":"戴公怀","dynasty":"唐","style":"","life":"","origin":"","seal":"戴","bio":[],"works":[{"id":"t49-42","title":"奉和郎中游仙山四瀑泉兼寄李吏部包秘监赵婺州齐处州","kind":"诗"}]},"戴翼":{"slug":"戴翼","name":"戴翼","dynasty":"宋","style":"","life":"","origin":"","seal":"戴","bio":[],"works":[{"id":"c72-757","title":"水调歌头·嵩岳周王佐","kind":"词"},{"id":"c72-758","title":"水调歌头·渤海卖刀剑","kind":"词"}]},"朱孙