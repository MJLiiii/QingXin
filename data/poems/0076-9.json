[{"id":"c76-900","title":"醉落魄・一斛珠·梅花似雪","rhythmic":"醉落魄・一斛珠","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["梅花似雪。","赏花记得同欢悦。","更阑犹自贪攀折。","不怯春寒，须要待明月。","如今月上花争发。","疏枝冷蕊对离缺。","人心只道花争别。","不道人心，不似旧时节。"]},{"id":"c76-901","title":"更漏子·宝香瓶","rhythmic":"更漏子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["宝香瓶，桐叶卷。","荡水痕微还远。","思乡信，觉春迟。","野梅初见时。","上潮风，临晚渡。","人欲过西江去。","吹寒管，陇云低。","江南花未知。"]},{"id":"c76-902","title":"更漏子·绛纱笼","rhythmic":"更漏子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["绛纱笼，金叶盖。","向晓灯花犹在。","冰未结，小琉璃。","陇梅香满枝。","雪无香，花有意。","不是江南新寄。","霜月尽，碧天寒。","玉楼人倚阑。"]},{"id":"c76-903","title":"落梅风・落梅·宫烟如水湿芳晨","rhythmic":"落梅风・落梅","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["宫烟如水湿芳晨。","寒梅似雪相亲。","玉楼侧畔数枝春。","惹香尘。","寿阳娇面偏怜惜，妆成一面花新。","镜中重把玉纤匀。","酒初醺。"]},{"id":"c76-904","title":"古记・如梦令·一枕厌厌春困","rhythmic":"古记・如梦令","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["一枕厌厌春困。","记得小梅风韵。","何处最关情，嫩蕊初传芳信。","堪恨。","堪恨。","谁傍横斜疏影。"]},{"id":"c76-905","title":"古记・如梦令·腊半雪梅初绽","rhythmic":"古记・如梦令","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["腊半雪梅初绽。","玉屑琼英碎翦。","素艳与清香，别有风流堪羡。","苞嫩。","蕊嫩。","羞破寿阳人面。"]},{"id":"c76-906","title":"古记・如梦令·疑是水晶宫殿","rhythmic":"古记・如梦令","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["疑是水晶宫殿。","云女天仙宝宴。","吟赏欲黄昏，风送一声羌管。","烟淡。","霜淡。","月在画楼西畔。"]},{"id":"c76-907","title":"生查子·朔风吹冻云","rhythmic":"生查子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["朔风吹冻云，云破天容碧。","新月过溪来，隐见横云色。","天与水争妍，花与月争白。","一倩管城君，寄此春消息。"]},{"id":"c76-908","title":"蓦山溪·青春三月","rhythmic":"蓦山溪","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["青春三月。"]},{"id":"c76-909","title":"失调名·夜寒斗觉罗衣薄","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["夜寒斗觉罗衣薄。"]},{"id":"c76-910","title":"失调名·深诚杳隔无疑","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["深诚杳隔无疑。"]},{"id":"c76-911","title":"调笑・调笑令·千里","rhythmic":"调笑・调笑令","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["千里。","楚江水。","明月楼高愁独倚。","井梧宫殿生秋意。","望断巫山十二。","雪肌花貌参差是。","朱阁五云仙子。"]},{"id":"c76-912","title":"调笑・调笑令·相误","rhythmic":"调笑・调笑令","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["相误。","桃源路。","万里苍苍烟水暮。","留君不住君须去。","秋月春风闲度。","桃花零乱如红雨。","人面不知何处。"]},{"id":"c76-913","title":"调笑・调笑令·非雾","rhythmic":"调笑・调笑令","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["非雾。","花无语。","远似朝云何处去。","凌波不过横塘路。","燕燕莺莺飞舞。","风吹仙袂飘飘举。","拟倩游丝惹住。"]},{"id":"c76-914","title":"调笑・调笑令·相忆","rhythmic":"调笑・调笑令","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["相忆。","无消息。","目断遥天云自白。","寒山一带伤心碧。","风土萧疏胡国。","长安不见浮云隔。","纵使君来争得。"]},{"id":"c76-915","title":"调笑・调笑令·来见","rhythmic":"调笑・调笑令","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["来见。","蕊宫殿。","记得随班迎凤辇。","馀花落尽苍苔院。","斜掩金铺一片。","千金买笑无方便。","和泪盈盈娇眼。"]},{"id":"c76-916","title":"调笑・调笑令·君去","rhythmic":"调笑・调笑令","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["君去。","逐鸳侣。","斜倚绿窗鸳鉴女。","琴弹秋思明心素。","一寸还成千缕。","锦城春色知何许。","那似远山眉妩。"]},{"id":"c76-917","title":"调笑・调笑令·无处","rhythmic":"调笑・调笑令","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["无处。","难轻诉。","锦瑟华年谁与度。","黄昏更下潇潇雨。","况是青春将暮。","花虽无语莺能语。","来道曾逢郎否。"]},{"id":"c76-918","title":"调笑・调笑令·衫湿","rhythmic":"调笑・调笑令","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["衫湿。","情何极。","上下花间声转急。","满船明月芦花白。","秋水长天一色。","芳年未老时难得。","目断远空凝碧。"]},{"id":"c76-919","title":"九张机·一张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["一张机。","织梭光景去如飞。","兰房夜永愁无寐。","呕呕轧轧，织成春恨，留著待郎归。"]},{"id":"c76-920","title":"九张机·两张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["两张机。","月明人静漏声稀。","千丝万缕相萦系。","织成一段，回纹锦字。","将去寄呈伊。"]},{"id":"c76-921","title":"九张机·三张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["三张机。","中心有朵耍花儿。","娇红嫩绿春明媚。","君须早折，一枝浓艳，莫待过芳菲。"]},{"id":"c76-922","title":"九张机·四张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["四张机。","鸳鸯织就欲双飞。","可怜未老头先白，春波碧草，晓寒深处，相对浴红衣。"]},{"id":"c76-923","title":"九张机·五张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["五张机。","芳心密与巧心期。","合欢树上枝连理。","双头花下，两同心处，一对化生儿。"]},{"id":"c76-924","title":"九张机·六张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["六张机。","雕花铺锦半离披。","兰房别有留春计。","炉添小篆，日长一线，相对绣工迟。"]},{"id":"c76-925","title":"九张机·七张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["七张机。","春蚕吐尽一生丝。","莫教容易裁罗绮。","无端翦破，仙鸾彩凤，分作两般衣。"]},{"id":"c76-926","title":"九张机·八张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["八张机。","纤纤玉手住无时。","蜀江濯尽春波媚。","香遗囊麝，花房绣被。","归去意迟迟。"]},{"id":"c76-927","title":"九张机·九张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["九张机。","一心长在百花枝。","百花共作红堆被。","都将春色，藏头里面，不怕睡多时。"]},{"id":"c76-928","title":"九张机·轻丝","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["轻丝。","象床玉手出新奇。","千花万草光凝碧。","裁缝衣著，春天歌舞，飞蝶语黄鹂。"]},{"id":"c76-929","title":"九张机·春衣","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["春衣。","素丝染就已堪悲。","尘世昏污无颜色。","应同秋扇，从兹永弃。","无复奉君时。"]},{"id":"c76-930","title":"九张机·一张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["一张机。","采桑陌上试春衣。","风晴日暖慵无力。","桃花枝上，啼莺言语，不肯放人归。"]},{"id":"c76-931","title":"九张机·两张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["两张机。","行人立马意迟迟。","深心未忍轻分付，回头一笑，花间归去，只恐被花知。"]},{"id":"c76-932","title":"九张机·三张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["三张机。","吴蚕已老燕雏飞。","东风宴罢长洲苑，轻绡催趁，馆娃宫女，要换舞时衣。"]},{"id":"c76-933","title":"九张机·四张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["四张机。","咿哑声里暗颦眉。","回梭织朵垂莲子。","盘花易绾，愁心难整，脉脉乱如丝。"]},{"id":"c76-934","title":"九张机·五张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["五张机。","横纹织就沈郎诗。","中心一句无人会。","不言愁恨，不言憔悴。","只恁寄相思。"]},{"id":"c76-935","title":"九张机·六张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["六张机。","行行都是耍花儿。","花间更有双蝴蝶，停梭一晌，闲窗影里。","独自看多时。"]},{"id":"c76-936","title":"九张机·七张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["七张机。","鸳鸯织就又迟疑。","只恐被人轻裁剪，分飞两处，一场离恨，何计再相随。"]},{"id":"c76-937","title":"九张机·八张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["八张机。","回纹知是阿谁诗。","织成一片凄凉意。","行行读遍，厌厌无语，不忍更寻思。"]},{"id":"c76-938","title":"九张机·九张机","rhythmic":"九张机","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["九张机。","双花双叶又双枝。","薄情自古多离别。","从头到底。","将心萦系。","穿过一条丝。"]},{"id":"c76-939","title":"南歌子·席近浑如远","rhythmic":"南歌子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["席近浑如远，帘高故放低。","偏它能画斗头眉。","戴顶烧香铺翠、小冠儿。","酒伴残妆在，花随秀鬓垂。","薄罗小扇写新诗。","解下双双罗带、要重题。"]},{"id":"c76-940","title":"南歌子·象戏红牙局","rhythmic":"南歌子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["象戏红牙局，琵琶绿锦绦。","小窗方簟困香醪。","帘外拂檐宫柳、翠阴交。","烟媚莺莺近，风微燕燕高。","更将乳酪伴樱桃。","要共那人一递、一匙抄。"]},{"id":"c76-941","title":"南歌子·小小生金屋","rhythmic":"南歌子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["小小生金屋，盈盈向凤帏。","斜枝石竹绣罗衣。","为怕春来风日、卷帘稀。","金殿承恩久，兰堂得梦回。","薰炉空惹御香归。","今夜花前还是、日平西。"]},{"id":"c76-942","title":"南歌子·阁儿虽不大","rhythmic":"南歌子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["阁儿虽不大，都无半点俗。","窗儿根底数竿竹。","画展江南山景、两三幅。","彝鼎烧异香，胆瓶插嫩菊。","け然无事净心目。","共那人人相对、弈棋局。"]},{"id":"c76-943","title":"南歌子·风动槐龙舞","rhythmic":"南歌子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["风动槐龙舞，花深禁漏传。","一竿红日照花砖。","走马晨晖门里、快行宣。","百五开新火，清明尚禁烟。","鱼符不请便朝天。","醉里归来疑是、梦游仙。"]},{"id":"c76-944","title":"感皇恩·暖律破寒威","rhythmic":"感皇恩","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["暖律破寒威，春回宫柳。","晴景初曦上元候。","禁城烟火，移下一天星斗。","素娥凝碧汉，明如昼。","绣毂电转，锦鞯飞骤。","九踏笙歌按新奏。","胜游方凝，忽听晓钟银漏。","两两归去也，应回首。"]},{"id":"c76-945","title":"鱼游春水·秦楼东风里","rhythmic":"鱼游春水","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["秦楼东风里。","燕子还来寻旧垒。","馀寒微透，红日薄侵罗绮。","嫩笋才抽碧玉簪，细柳轻窣黄金蕊。","莺啭上林，鱼游春水。","屈曲阑干遍倚。","又是一番新桃李。","佳人应念归期，梅妆淡洗。","凤箫声杳沈孤雁，目断澄波无双鲤。","云山万重，寸心千里。"]},{"id":"c76-946","title":"五彩结同心·珠帘垂户","rhythmic":"五彩结同心","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["珠帘垂户。","金索悬窗，家接浣沙溪路。","相见桐阴下，一钩月、恰在凤凰栖处。","素琼拈就宫腰小。","花枝袅、盈盈娇步。","新妆浅，满腮红雪，绰约片云欲度。","尘寰岂能留住。","唯只愁、化作彩云飞去。","蝉翼衫儿，薄冰肌莹，轻罩一团香雾。","彩笺巧缀相思苦。","脉脉动、怜才心绪。","好作个、秦楼活计，吹箫伴侣。"]},{"id":"c76-947","title":"侍香金童·宝台蒙绣","rhythmic":"侍香金童","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["宝台蒙绣，瑞兽高三尺。","玉殿无风烟自直。","迤逦传杯盈绮席。","苒苒菲菲，断处凝碧。","是龙涎凤髓，恼人情意极。","想韩寿、风流应暗识。","去似彩云无处觅。","惟有多情，袖中留得。"]},{"id":"c76-948","title":"洞仙歌·溶溶泄泄","rhythmic":"洞仙歌","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["溶溶泄泄，似飘扬愁绪。","不是因风等闲度。","道无心用甚，却又情多，行未驻，还作高阳暮雨。","襄王情尚浅，会少离多，空自朝朝又暮暮。","肠断晓光中，一缕归时，销散后、不知何处。","试密锁、琼楼洞房深，与遮断江皋，楚台归路。"]},{"id":"c76-949","title":"永遇乐·功名闲事","rhythmic":"永遇乐","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["功名闲事，利禄休问，莫系心上。","幸有衣食，随缘过得，著甚乾劳攘。","风前月下，三杯两盏，撞著即莫与放。","且与个、山庄道友，退闲故人来往。","新来做得，一个宽袖布衫，著来也畅。","出户迎宾，入城干事，恰似王保长。","我咱忺后，神歌鬼舞，任尔万般毁谤。","死来后，一家一个，那底怎向。"]},{"id":"c76-950","title":"西江月·灯火楼台欲下","rhythmic":"西江月","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["灯火楼台欲下，笙歌院落将归。","冰瓷金缕胜琉璃。","春笋捧来纤细。","饮罢高阳人散，曲终巫峡云飞。","千万修合斗新奇。","须带别离滋味。"]},{"id":"c76-951","title":"水调歌头·帆落松陵浦","rhythmic":"水调歌头","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["帆落松陵浦，枯柳缆琼艘。","杖策无人独步，浪厌百花桥。","我挂风裳水佩，一笑波寒月白，馀韵触惊涛。","绝景有谁赏，雾暮闭三高。","不须臾，千古事，一萧条。","鲈鱼纵有，泽荒甫里失溪桥。","更吾名高业茂，终归荒田野草，且稳一枝巢。","举酒酹空阔，烟远路迢迢。"]},{"id":"c76-952","title":"菩萨蛮·江城烽火连三月","rhythmic":"菩萨蛮","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["江城烽火连三月。","不堪对酒江亭别。","休作断肠声。","老来无泪倾。","风高帆影疾。","目送舟痕碧。","锦字几时来。","薰风无雁回。"]},{"id":"c76-953","title":"减字木兰花·啬薇叶暗","rhythmic":"减字木兰花","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["啬薇叶暗。","满架浓阴风不乱。","午酒才醒。","历历黄鹂枕上听。","此情难遣。","不比红蕉心易展。","要识离愁。","只似杨花不自由。"]},{"id":"c76-954","title":"浣溪沙·梦入瑶台千步芳","rhythmic":"浣溪沙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["梦入瑶台千步芳。","万妃相向玉为装。","同心鞶带翠罗长。","浓艳只宜供枕席，醉魂长是傍壶觞。","绀纱囊薄为谁香。"]},{"id":"c76-955","title":"浣溪沙·白玉楼中白雪歌","rhythmic":"浣溪沙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["白玉楼中白雪歌。","更将白纻衬春罗。","软红香里最么麽。","桃叶桃根随处有，江南江北见来多。","风前月底奈愁何。"]},{"id":"c76-956","title":"临江仙·竹里行厨草草","rhythmic":"临江仙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["竹里行厨草草，花边系马匆匆。","使君移传意何穷。","儿童随骑火，猿鹤避歌钟。","梅雪自欺舞态，烛花先放春红。","酒醒人散夜堂空。","殷勤松上月，独照老仙翁。"]},{"id":"c76-957","title":"阮郎归·山池芳草绿初匀","rhythmic":"阮郎归","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["山池芳草绿初匀。","柳寒眉尚颦。","东风吹雨细如尘。","一庭花脸皴。","莺共蝶，怨还嗔。","眼前无好春。","这番天气杀愁人。","人愁旋旋新。"]},{"id":"c76-958","title":"浣溪沙·春院无人花自香","rhythmic":"浣溪沙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["春院无人花自香。","飞来蜂蝶意何狂。","玉钩帘卷日偏长。","笑又不成愁未是，曲屏闲倚绣鸳鸯。","归时应供□□妆。"]},{"id":"c76-959","title":"南乡子·李郭共仙舟","rhythmic":"南乡子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["李郭共仙舟。","准拟苏台烂熳游。","风雪为谁留住也，沧洲。","一尺银沙未肯收。","无语只关愁。","强殢金卮不计筹。","想得人人梳洗懒，妆楼。","只窣帘儿不上钩。"]},{"id":"c76-960","title":"凤栖梧・蝶恋花·姑射仙人游汗漫","rhythmic":"凤栖梧・蝶恋花","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["姑射仙人游汗漫。","白凤翩翩，银海光凌乱。","龟手儿童贪戏玩。","风檐更折梅梢看。","漠漠银沙平晚岸。","笑拥寒蓑，聊作渔翁伴。","横玉愁云吹不断。","归舟又载苹花满。"]},{"id":"c76-961","title":"归自谣·愁冉冉","rhythmic":"归自谣","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["愁冉冉。","目送书空鸿数点。","落霞风剪江分染。","胜处屏云犹未掩。","羞娥敛。","红潮怕上春风脸。"]},{"id":"c76-962","title":"卜算子·曾约再来时","rhythmic":"卜算子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["曾约再来时，花暗春风树。","今日人来花未开，春未知人处。","坐客有疏狂，彩笔题新语。","浑为玉人颓玉山，忘了阳关路。"]},{"id":"c76-963","title":"卜算子·烟髻绾层巅","rhythmic":"卜算子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["烟髻绾层巅，云叶生寒树。","斜日行人窈窕村，愁阵纵横处。","细细写蛮笺，道寄相思语。","会倩春风展柳眉，回马章台路。"]},{"id":"c76-964","title":"好事近·潇洒小楼东","rhythmic":"好事近","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["潇洒小楼东，斜亚一枝梅雪。","若在玉溪仙馆，更风流奇绝。","花神应为护芳心，付与何人折。","行客几回搔首，认暗香浮月。"]},{"id":"c76-965","title":"谒金门·江上路","rhythmic":"谒金门","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["江上路。","依约数家烟树。","一枕归心村店暮。","更乱山深处。","梦过江南芳草渡。","晓色又催人去。","愁似游丝千万缕。","倩东风约住。"]},{"id":"c76-966","title":"杜韦娘·华堂深院","rhythmic":"杜韦娘","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["华堂深院，霜笼月采生寒晕。","度翠幄、风触梅香喷。","渐岁晚、春光将近。","惹离恨万种，多情易感，欢难聚少愁成阵。","拥红炉，凤枕慵敧，银灯挑尽。","当此际，争忍前期后约，度岁无凭准。","对好景、空积相思恨。","但自觉、恹恹方寸。","拟蛮笺象管，丹青好手，写出寄与伊教信。","尽千工万巧，唯有心期难问。"]},{"id":"c76-967","title":"摸鱼儿·被谁家","rhythmic":"摸鱼儿","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["被谁家、数声弦管，惊回好梦难省。","起来无语疏雨过，芳草嫩苔侵径。","春昼永。","迟日暮，碧沼浪浸红楼影。","卷帘人静。","被风触，一叶两叶，杏花零乱对残景。","依前是，撩拨春心堪恨。","檀郎言约无定。","不知何处贪欢笑，恣纵酒迷歌逞。","珠泪迸。","自别后，每忆翠黛凭谁整。","芳年相称。","又到得今来，却成病了，羞懒对鸾镜。"]},{"id":"c76-968","title":"满庭芳·五斗相逢","rhythmic":"满庭芳","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["五斗相逢，千锺一饮，古今乐事无过。","香生银瓮，浮蚁浴春波。","潋滟光凝盏面，轻风皱、浅碧宫罗。","乘欢处，倾罍痛饮，珠贯引清歌。","云何。","君不饮，良辰美景，聚少离多。","忍怎放春风，容易蹉跎。","但愿一樽常共，花阴下、急景如梭。","须乘醉，雕鞍归去，争看醉颜酡。"]},{"id":"c76-969","title":"潇湘静・湘江静·画帘微卷香风逗","rhythmic":"潇湘静・湘江静","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["画帘微卷香风逗。","正明月、乍圆时候。","金盘露冷，玉炉篆消，渐红鳞生酒。","娇唱倚繁弦，琼枝碎、轻回云袖。","风台歌短、铜壶漏永，人欲醉、夜如昼。","因念流年迅景，被浮名、暗辜欢偶。","人生大抵，离多会少，更相将白首。","何似猛寻芳，都莫问、积金过斗。","歌阑宴阕，云窗凤枕，钗横麝透。"]},{"id":"c76-970","title":"十月桃·东篱菊尽","rhythmic":"十月桃","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["东篱菊尽，遍园林败叶，满地寒荄。","露井平明，破香笼粉初开。","佳人共喜芳意，呵手剪、密插鸾钗。","无言有艳，不避繁霜，变作春媒。","问武陵溪上谁栽。","分付与南园，舞榭歌台。","恰似凝酥衬玉，点缀装裁。","东君自是为主，先暖信、律管飞灰。","从今雪里，第一番花，休话江梅。"]},{"id":"c76-971","title":"汉宫春·江月初圆","rhythmic":"汉宫春","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["江月初圆，正新春夜永，灯市行乐。","芙蕖万朵，向晚为谁开却。","层楼画阁。","尽卷上、东风帘幕。","罗绮拥，欢声和气，惊破柳梢梅萼。","绰约。","暗尘浮动，正鱼龙曼衍，戏车交作。","高牙影里，缓控玉羁金络。","铅华间错。","更一部、笙歌围著。","香散处，厌厌醉听，南楼画角。"]},{"id":"c76-972","title":"汉宫春·玉减香销","rhythmic":"汉宫春","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["玉减香销，被婵娟误我，临镜妆慵。","无聊强开强解，蹙破眉峰。","凭高望远，但断肠、残月初钟。","须信道，承恩在貌，如何教妾为容。","风暖鸟声和碎，更日高院静，花影重重。","愁来待只殢酒，酒困愁浓。","长门怨感，恨无金、卖赋临邛。","翻动念，年年女伴，越溪共采芙蓉。"]},{"id":"c76-973","title":"风流子·淑景皇州满","rhythmic":"风流子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["淑景皇州满，和风渐、催促柳花飞。","过清明骤雨，五候台榭，青烟散入，新火开时。","绣帘外、傍人飞燕子，映叶语黄鹂。","秋千昼永，绮罗人散，花阴笑隔，红粉墙低。","青门多行乐，寻芳处、何计强逐轻肥。","空对旧游满目，谁共开眉。","遇有时系马，垂杨影下，风前伫立，惆怅佳期。","回望故园桃李，应待人归。"]},{"id":"c76-974","title":"夏日宴黉堂・夏日燕黉堂·日初长","rhythmic":"夏日宴黉堂・夏日燕黉堂","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["日初长。","正园林换叶，瓜李飘香。","帘外雨过，送一霎微凉。","萍芜迳，曲凝珠颗，衬汀沙、细簇蜂房。","被晚风轻飐，圆荷翻水，泼觉鸳鸯。","此景最难忘。","趁芳樽泛蚁，筠簟铺湘。","兰舟棹稳，倚何处垂杨。","岂能文字成狂饮，更红裙、闲也何妨。","任醉归明月，虾须帘筛，几线馀霜。"]},{"id":"c76-975","title":"渔家傲·轻拍红牙留客住","rhythmic":"渔家傲","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["轻拍红牙留客住。","韩家石鼎联新句。","珍重龙团并凤髓。","君王与。","春风吹破黄金缕。","往事不须凭陆羽。","且看盏面浓如乳。","若是蓬莱鳌稳负。","知何处。","玉川一枕清风去。"]},{"id":"c76-976","title":"醉春风·陌上清明近","rhythmic":"醉春风","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["陌上清明近。","行人难借问。","风流何处不来归，闷闷闷。","回雁峰前，戏鱼波上，试寻芳信。","夜久兰膏烬。","春睡何曾稳。","枕边珠泪几时乾，恨恨恨。","惟有窗前，过来明月，照人方寸。"]},{"id":"c76-977","title":"卓牌儿・卓牌子·当年早梅芳","rhythmic":"卓牌儿・卓牌子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["当年早梅芳，曾邂逅、飞琼侣。","肌云莹玉，颜开嫩桃，腰支轻袅，未胜金缕。","佯羞整云环，频向人、娇波寄语。","湘佩笑解，韩香暗传，幽欢后期难诉。","梦魂顿阻。","似一枕、高唐云雨。","蕙心兰态，知何计重遇。","试问春蚕丝多少，未抵离愁半缕。","凝伫。","望凤楼何处。"]},{"id":"c76-978","title":"南乡子·晓日压重檐","rhythmic":"南乡子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["晓日压重檐。","斗帐犹寒起未忺。","天气困人梳洗倦，眉尖。","淡画春山不喜添。","闲把绣丝撏。","紝得金针又怕拈。","陌上行人归也未，恹恹。","满院杨花不卷帘。"]},{"id":"c76-979","title":"南乡子·深结花工知","rhythmic":"南乡子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["深结花工知。","赐与衣裳尽是绯。","曾向玉盘深处见，隈随。","两个心肠一片儿。","从小便相依。","酒伴歌筵不暂离。","只恐被人分擘破，东西。","怎得团圆似旧时。"]},{"id":"c76-980","title":"望远行·当时云雨梦","rhythmic":"望远行","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["当时云雨梦，不负楚王期。","翠峰中、高楼十二掩瑶扉。","尽人间欢会，只有两心自知。","渐玉困花柔香汗挥。","歌声翻别怨，云驭欲回时。","这无情红日，何似且休西。","但涓涓珠泪，滴湿仙郎羽衣。","怎忍见、双鸳相背飞。"]},{"id":"c76-981","title":"归田乐·水绕溪桥绿","rhythmic":"归田乐","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["水绕溪桥绿。","泛苹汀、步迷花曲。","衣巾散馀馥。","种竹更洗竹。","咏竹题竹。","日暮无人伴幽独。","光阴双转毂。","可惜许、等闲愁万斛。","世间种种，只是荣和辱。","念足又愿足。","意足心足。","忘了眉头怎生蹙。"]},{"id":"c76-982","title":"临江仙·促坐重燃绛蜡","rhythmic":"临江仙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["促坐重燃绛蜡，香泉细泻银瓶。","一瓯月露照人明。","清真无俗韵，久淡似交清。","正味能销酒力，馀甘解助茶清。","琼浆一饮觉身轻。","蓝桥知不远，归卧对云英。"]},{"id":"c76-983","title":"行香子·天与秋光","rhythmic":"行香子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["天与秋光。","转转情伤，探金英、知近重阳。","薄衣初减，绿蚁初尝。","渐一番风，一番雨，一番凉。","黄昏院落，恓恓惶惶。","酒醒时、往事愁肠。","那堪永夜，明月空床。","问砧声捣，蛩声细，漏声长。"]},{"id":"c76-984","title":"诉衷情·碧天明月晃金波","rhythmic":"诉衷情","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["碧天明月晃金波。","清浅滞星河。","深深院宇人静，独自问姮娥。","圆夜少，缺时多。","事因何。","嫦娥莫是，也有别离，一似人麽。"]},{"id":"c76-985","title":"绕池游·渐春工巧","rhythmic":"绕池游","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["渐春工巧，玉漏花深寒浅。","韶景变、融晴蕙风暖。","都门十二，三五银蟾光满。","瑞烟葱茜，禁城阆苑。","棚山雉扇。","绛蜡交辉星汉。","神仙籍、梨园奏弦管。","都人游玩。","万井山呼欢抃。","岁岁天仗，愿瞻凤辇。"]},{"id":"c76-986","title":"好事近·小院看酴醿","rhythmic":"好事近","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["小院看酴醿，正是盛开时节。","莫惜大家沈醉，有春醅初泼。","花前月下细看来，无物比清绝。","若问此花何似，似一堆香雪。"]},{"id":"c76-987","title":"阮郎归·春风吹雨绕残枝","rhythmic":"阮郎归","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["春风吹雨绕残枝。","落花无可飞。","小池寒渌欲生漪。","雨晴还日西。","帘半卷，燕双归。","讳愁无奈眉。","翻身整顿著残棋。","沈吟应劫迟。"]},{"id":"c76-988","title":"点绛唇·公子归来","rhythmic":"点绛唇","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["公子归来，画堂深院丛罗绮。","绿杯浮蚁。","风皱红鳞起。","信马斜阳，误入桃源里。","珠帘底。","淡妆斜倚。","一寸秋江水。"]},{"id":"c76-989","title":"海棠春·晓莺窗外春啼晓","rhythmic":"海棠春","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["晓莺窗外春啼晓。","睡未足、把人惊觉。","翠被晓寒轻，宝篆沈烟袅。","宿酲未解，双娥报道。","别院笙歌宴早。","试问海棠花，昨夜开多少。"]},{"id":"c76-990","title":"宴桃源・如梦令·落日霞消一缕","rhythmic":"宴桃源・如梦令","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["落日霞消一缕。","素月棱棱微吐。","何处夜归人，呕嗄几声柔橹。","归去。","归去。","家在烟波深处。"]},{"id":"c76-991","title":"祝英台・祝英台近·海棠开","rhythmic":"祝英台・祝英台近","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["海棠开，花影下，忆得共游戏。","恰似双鸾，同步彩云里。","梦回雨收云散，匆匆归去，一枕乍、惊回浓睡。","甚情味。","人去花亦凋零，秾芳伴憔悴。","点点飞红，知是去时泪。","可堪冷落黄昏，潇潇微雨，断魂处。","朱阑独倚。"]},{"id":"c76-992","title":"夜游宫·是处追寻侣","rhythmic":"夜游宫","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["是处追寻侣。","灯光散、九衢红雾。","人在星河繁闹处。","暗相逢，惹天香，飘满路。","游困先归去。","奈怨别、相思情绪。","闲傍小桃□独步。","月明寒，拈宜男，无一语。"]},{"id":"c76-993","title":"杨柳枝·簌簌花飞一雨残","rhythmic":"杨柳枝","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["簌簌花飞一雨残。","乍衣单。","屏风数幅画江山。","水云闲。","别易会难无计那，泪潸潸。","夕阳楼上凭栏干。","望长安。"]},{"id":"c76-994","title":"摊破浣溪沙・山花子·相恨相思一个人","rhythmic":"摊破浣溪沙・山花子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["相恨相思一个人。","柳眉桃脸自然春。","别离情思，寂寞向谁论。","映地残霞红照水，断魂芳草碧连云。","水边楼上，回首倚黄昏。"]},{"id":"c76-995","title":"一翦梅·恨入椒觞暖未拈","rhythmic":"一翦梅","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["恨入椒觞暖未拈。","春葱微蘸，谁是纤纤。","别来愁夜不胜长，明日从教一线添。","夜久寒深睡未忺。","旧愁新恨，占断眉尖。","一钩斜月却知人。","直到天明，不下疏帘。"]},{"id":"c76-996","title":"卜算子·垂螺近额时","rhythmic":"卜算子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["垂螺近额时，只怕莺声老。","尽日贪花斗草忙，不信有闲烦恼。","凤鬓已胜钗，恨别王孙早。","若把芳心说与伊，道绿遍、池塘草。"]},{"id":"c76-997","title":"忆王孙·杨柳风前旗鼓闹","rhythmic":"忆王孙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["杨柳风前旗鼓闹。","正陌上、闲花芳草。","忍将愁眼覰芳菲，人未老。","春先老。","长安比日知多少。","日易见、长安难到。","无情苕水不西流，渐迤逦、仙舟小。"]},{"id":"c76-998","title":"南歌子·夕露沾芳草","rhythmic":"南歌子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["夕露沾芳草，斜阳带远村。","几声残角起谯门。","撩乱栖鸦飞舞、闹黄昏。","天共高城远，香馀绣被温。","客程常是可销魂。","乍向心头横著、个人人。"]},{"id":"c76-999","title":"南歌子·楼迥迷云日","rhythmic":"南歌子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["楼迥迷云日，溪深涨晓沙。","年来悴憔费铅华。","楼上一天春思、浩无涯。","罗带宽腰素，真珠溜脸霞。","海棠开尽柳飞花。","薄幸只知游荡、不思家。"]}]