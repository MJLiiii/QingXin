[{"id":"c58-700","title":"菩萨蛮·楼头上有三冬鼓","rhythmic":"菩萨蛮","author":"孙洙","authorSlug":"孙洙","dynasty":"宋","kind":"ci","paragraphs":["楼头上有三冬鼓。","何须抵死催人去。","上马苦匆匆。","琵琶曲未终。","回头肠断处。","却更廉纤雨。","漫道玉为堂。","玉堂今夜长。"]},{"id":"c58-701","title":"河满子·怅望浮生急景","rhythmic":"河满子","author":"孙洙","authorSlug":"孙洙","dynasty":"宋","kind":"ci","paragraphs":["怅望浮生急景，凄凉宝瑟馀音。","楚客多情偏怨别，碧山远水登临。","目送连天衰草，夜阑几处疏砧。","黄叶无风自落，秋云不雨长阴。","天若有情天亦老，摇摇幽恨难禁。","惆怅旧欢如梦，觉来无处追寻。"]},{"id":"c58-702","title":"失调名·杨花落","rhythmic":"失调名","author":"李清臣","authorSlug":"李清臣","dynasty":"宋","kind":"ci","paragraphs":["杨花落。","燕子穿朱阁。","苦恨春醪如水薄。","闲愁无处著。","去年今日王陵舍，鼓角秋风。","千岁辽东。","回首人间万事空。"]},{"id":"c58-703","title":"减字木兰花·人生可意","rhythmic":"减字木兰花","author":"韦骧","authorSlug":"韦骧","dynasty":"宋","kind":"ci","paragraphs":["人生可意。","祗说功名贪富贵。","遇景开怀。","且尽生前有限杯。","韶华几许。","鹈鴂声残无觅处。","莫自因循。","一片花飞减却春。"]},{"id":"c58-704","title":"减字木兰花·金貂贳酒","rhythmic":"减字木兰花","author":"韦骧","authorSlug":"韦骧","dynasty":"宋","kind":"ci","paragraphs":["金貂贳酒。","乐事可为须趁手。","且醉青春。","白发何曾饶贵人。","凤笙鼍鼓。","况是桃花落红雨。","莫诉觥筹。","炊熟黄粱一梦休。"]},{"id":"c58-705","title":"减字木兰花·鸾坡凤沼","rhythmic":"减字木兰花","author":"韦骧","authorSlug":"韦骧","dynasty":"宋","kind":"ci","paragraphs":["鸾坡凤沼。","轩冕傥来何足道。","存养天真。","安用浮名绊此身。","劳生逸老。","摆脱纷华须是早。","解绶眠云。","林下何曾见一人。"]},{"id":"c58-706","title":"减字木兰花·危楼引望","rhythmic":"减字木兰花","author":"韦骧","authorSlug":"韦骧","dynasty":"宋","kind":"ci","paragraphs":["危楼引望。","天气犹寒花未放。","远思悠悠。","芳草何年恨即休。","仙踪何处。","此去蓬山多少路。","春霭腾腾。","更在瑶台十二层。"]},{"id":"c58-707","title":"减字木兰花·帝城春媚","rhythmic":"减字木兰花","author":"韦骧","authorSlug":"韦骧","dynasty":"宋","kind":"ci","paragraphs":["帝城春媚。","绿柳参天花照地。","共乐升平。","处处楼台歌板声。","香轮玉镫。","驰骤芳郊争选胜。","妙舞轻讴。","扰乱春风卒未休。"]},{"id":"c58-708","title":"菩萨蛮·琼杯且尽清歌送","rhythmic":"菩萨蛮","author":"韦骧","authorSlug":"韦骧","dynasty":"宋","kind":"ci","paragraphs":["琼杯且尽清歌送。","人生离合真如梦。","瞬息又春归。","回头光景非。","香喷金兽暖。","欢意愁更短。","白发不须量。","从教千丈长。"]},{"id":"c58-709","title":"鹊桥仙·岁华将暮","rhythmic":"鹊桥仙","author":"韦骧","authorSlug":"韦骧","dynasty":"宋","kind":"ci","paragraphs":["岁华将暮，寒林萧索，极目冻云垂地。","官梅忽见一枝芳，便顿觉、新春情味。","小筵开处，歌喉清婉，舞态蹁跹争媚。","沈腰潘鬓两休论，共举白、何须惜醉。"]},{"id":"c58-710","title":"减字木兰花·雕阑香砌","rhythmic":"减字木兰花","author":"韦骧","authorSlug":"韦骧","dynasty":"宋","kind":"ci","paragraphs":["雕阑香砌。","红紫妖韶何足计。","争似幽芳。","几朵先春蘸碧塘。","玉盘金盏。","谁谓花神情有限。","绰约仙姿。","仿佛江皋解佩时。"]},{"id":"c58-711","title":"洛阳春・一落萦·冷艳幽香奇绝","rhythmic":"洛阳春・一落萦","author":"韦骧","authorSlug":"韦骧","dynasty":"宋","kind":"ci","paragraphs":["冷艳幽香奇绝。","粉金裁雪。","无端又欲恨春风，恨不解、千千结。","曲槛小池清切。","倚烟笼月。","佳人纤手傍柔条，似不忍、轻攀折。"]},{"id":"c58-712","title":"醉蓬莱·漏新春消耗","rhythmic":"醉蓬莱","author":"韦骧","authorSlug":"韦骧","dynasty":"宋","kind":"ci","paragraphs":["漏新春消耗，柳眼微青，素梅犹小。","帘幕轻寒，引炉烟袅袅。","凤管雍容，雁筝清切，对绮筵呈妙。","此际欢虞，门庭自有，辉光荣耀。","庆事难逢，世间须信，八十遐龄，古来稀少。","况偶佳辰，是桑弧曾表。","满奉金觥，暂停牙板，听雅歌精祷。","惟愿增高，龟年鹤算，鸿恩紫诏。"]},{"id":"c58-713","title":"沁园春·林叶阴浓","rhythmic":"沁园春","author":"韦骧","authorSlug":"韦骧","dynasty":"宋","kind":"ci","paragraphs":["林叶阴浓，海云峰耸，夏景渐分。","称画堂开宴，雍雍笑语，高年耆德，初弄君恩。","汉相家声，一经传训，赏典今朝归庆门。","清和昼，见香飘百和，乐按长春。","休论。","万事纷纭。","算寿考、乡闾能几人。","况凤书才降，龟龄正永，莫辞金盏，一醉醺醺。","萱草忘忧，榴花含笑，庭院风光如再新。","成欢颂，愿齐坚桧柏，频奉丝纶。"]},{"id":"c58-714","title":"渔家傲·本是潇湘一钓客","rhythmic":"渔家傲","author":"圆禅师","authorSlug":"圆禅师","dynasty":"宋","kind":"ci","paragraphs":["本是潇湘一钓客。","自东自西自南北。","只把孤舟为屋宅。","无宽窄。","幕天席地人难测。","顷闻四海停戈革。","金门懒去投书册。","时向滩头歌月白。","真高格。","浮名浮利谁拘得。"]},{"id":"c58-715","title":"满庭芳·咄这牛儿","rhythmic":"满庭芳","author":"则禅师","authorSlug":"则禅师","dynasty":"宋","kind":"ci","paragraphs":["咄这牛儿，身强力健，几人能解牵骑。","为贪原上，嫩草绿离离。","只管寻芳逐翠，奔驰后、不顾倾危。","争知道，山遥水远，回首到家迟。","牧童，今有智，长绳牢把，短杖高提。","入泥入水，终是不生疲。","直待心调步稳，青松下、孤笛横吹。","当归去，人牛不见，正是月明时。"]},{"id":"c58-716","title":"八声甘州·芰荷风","rhythmic":"八声甘州","author":"陈偕","authorSlug":"陈偕","dynasty":"宋","kind":"ci","paragraphs":["芰荷风、涤面恰麦秋，应倒著春衣。","渡晓溪云湿，日流尘脚，露滉蛛丝。","调翼受风雏燕，弱不解争泥。","衬琅玕锦院，竹外蔷薇。","立久阑干凭暖，看行鱼吹沫，波晕平池。","藓痕斑础石，渐雨熟梅时。","傍短篱、成团粉蝶，掠野花、相逐□高低。","忘言处，徽弦乍拂，流水先知。"]},{"id":"c58-717","title":"满庭芳·岚影浮春","rhythmic":"满庭芳","author":"陈偕","authorSlug":"陈偕","dynasty":"宋","kind":"ci","paragraphs":["岚影浮春，云容阁雨，澄泓碧展玻璃。","高低楼观，窗户舞涟漪。","别有轻盈水面，清讴起、舟叶如飞。","沙堤上，垂鞭信马，柳重绿交枝。","渐残红倒影，金波潋滟，弦管催归。","看飘香陈粉，满路扶携。","不尽湖边风月，孤山下、猿鸟须知。","东风里、年年此水，贮尽是和非。"]},{"id":"c58-718","title":"满庭芳·榆荚抛钱","rhythmic":"满庭芳","author":"陈偕","authorSlug":"陈偕","dynasty":"宋","kind":"ci","paragraphs":["榆荚抛钱，桃英胎子，杨花已送春归。","未成萍叶，水面绿纹肥。","沙暖溪禽行哺，忘机处、雏母相随。","重帘静，铜壶昼歇，声度竹间棋。","人生如意少，乐随春减，恨为情离。","怕牵愁勾怨，渐近金徽。","浮世更相代谢，江头明月，渡口斜晖。","关情处，摩挲钓石，莫遣上苔衣。"]},{"id":"c58-719","title":"临江仙·斗草阶前初见","rhythmic":"临江仙","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["斗草阶前初见，穿针楼上曾逢。","罗裙香露玉钗风。","靓妆眉沁绿，羞脸粉生红。","流水便随春远，行云终与谁同。","酒醒长恨锦屏空。","相寻梦里路，飞雨落花中。"]},{"id":"c58-720","title":"临江仙·身外闲愁空满","rhythmic":"临江仙","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["身外闲愁空满，眼中欢事常稀。","明年应赋送君诗。","细从今夜数，相会几多时。","浅酒欲邀谁劝，深情惟有君知。","东溪春近好同归。","柳垂江上影，梅谢雪中枝。"]},{"id":"c58-721","title":"临江仙·淡水三年欢意","rhythmic":"临江仙","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["淡水三年欢意，危弦几夜离情。","晓霜红叶舞归程。","客情今古道，秋梦短长亭。","渌酒尊前清泪，阳关叠里离声。","少陵诗思旧才名。","云鸿相约处，烟雾九重城。"]},{"id":"c58-722","title":"临江仙·浅浅馀寒春半","rhythmic":"临江仙","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["浅浅馀寒春半，雪消蕙草初长。","烟迷柳岸旧池塘。","风吹梅蕊闹，雨细杏花香。","月堕枝头欢意，从前虚梦高唐，觉来何处放思量。","如今不是梦，真个到伊行。"]},{"id":"c58-723","title":"临江仙·长爱碧阑干影","rhythmic":"临江仙","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["长爱碧阑干影，芙蓉秋水开时。","脸红凝露学娇啼。","霞觞熏冷艳，云髻袅纤枝。","烟雨依前时候，霜丛如旧芳菲。","与谁同醉采香归。","去年花下客，今似蝶分飞。"]},{"id":"c58-724","title":"临江仙·旖旎仙花解语","rhythmic":"临江仙","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["旖旎仙花解语，轻盈春柳能眠。","玉楼深处绮窗前。","梦回芳草夜，歌罢落梅天。","沈水浓熏绣被，流霞浅酌金船。","绿娇红小正堪怜。","莫如云易散，须似月频圆。"]},{"id":"c58-725","title":"临江仙·梦后楼台高锁","rhythmic":"临江仙","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["梦后楼台高锁，酒醒帘幕低垂。","去年春恨却来时。","落花人独立，微雨燕双飞。","记得小苹初见，两重心字罗衣。","琵琶弦上说相思。","当时明月在，曾照彩云归。"]},{"id":"c58-726","title":"临江仙·东野亡来无丽句","rhythmic":"临江仙","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["东野亡来无丽句，于君去后少交亲。","追思往事好沾巾。","白头王建在，犹见咏诗人。","学道深山空自老，留名千载不干身。","酒筵歌席莫辞频。","争如南陌上，占取一年春。"]},{"id":"c58-727","title":"蝶恋花·卷絮风头寒欲尽","rhythmic":"蝶恋花","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["卷絮风头寒欲尽。","坠粉飘红，日日香成阵。","新酒又添残酒困。","今春不减前春恨。","蝶去莺飞无处问。","隔水高楼，望断双鱼信。","恼乱层波横一寸。","斜阳只与黄昏近。"]},{"id":"c58-728","title":"蝶恋花·初拈霜纨生怅望","rhythmic":"蝶恋花","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["初拈霜纨生怅望。","隔叶莺声，似学秦娥唱。","午睡醒来慵一饷。","双纹翠簟铺寒浪。","雨罢苹风吹碧涨。","脉脉荷花，泪脸红相向。","斜贴绿云新月上。","弯环正是愁眉样。"]},{"id":"c58-729","title":"蝶恋花·庭院碧苔红叶遍","rhythmic":"蝶恋花","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["庭院碧苔红叶遍。","金菊开时，已近重阳宴。","日日露荷凋绿扇。","粉塘烟水澄如练。","试倚凉风醒酒面。","雁字来时，恰向层楼见。","几点护霜云影转。","谁家芦管吹秋怨。"]},{"id":"c58-730","title":"蝶恋花·喜鹊桥成催凤驾","rhythmic":"蝶恋花","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["喜鹊桥成催凤驾。","天为欢迟，乞与初凉夜。","乞巧双蛾加意画。","玉钩斜傍西南挂。","分钿擘钗凉叶下。","香袖凭肩，谁记当时话。","路隔银河犹可借。","世间离恨何年罢。"]},{"id":"c58-731","title":"蝶恋花·碧草池塘春又晚","rhythmic":"蝶恋花","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["碧草池塘春又晚。","小叶风娇，尚学娥妆浅。","双燕来时还念远。","珠帘绣户杨花满。","绿柱频移弦易断。","细看秦筝，正似人情短。","一曲啼乌心绪乱。","红颜暗与流年换。"]},{"id":"c58-732","title":"蝶恋花·碾玉钗头双凤小","rhythmic":"蝶恋花","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["碾玉钗头双凤小。","倒晕工夫，画得宫眉巧。","嫩曲罗裙胜碧草。","鸳鸯绣字春衫好。","三月露桃芳意早。","细看花枝，人面争多少。","水调声长歌未了。","掌中杯尽东池晓。"]},{"id":"c58-733","title":"蝶恋花·醉别西楼醒不记","rhythmic":"蝶恋花","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["醉别西楼醒不记。","春梦秋云，聚散真容易。","斜月半窗还少睡。","画屏闲展吴山翠。","衣上酒痕诗里字。","点点行行，总是凄凉意。","红烛自怜无好计。","夜寒空替人垂泪。"]},{"id":"c58-734","title":"蝶恋花·欲减罗衣寒未去","rhythmic":"蝶恋花","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["欲减罗衣寒未去。","不卷珠帘，人在深深处。","残杏枝头花几许。","啼红正恨清明雨。","尽日沈香烟一缕。","宿酒醒迟，恼破春情绪。","远信还因归燕误。","小屏风上西江路。"]},{"id":"c58-735","title":"蝶恋花·千叶早梅夸百媚","rhythmic":"蝶恋花","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["千叶早梅夸百媚。","笑面凌寒，内样妆先试。","月脸冰肌香细腻。","风流新称东君意。","一捻年光春有味。","江北江南，更有谁相比。","横玉声中吹满地。","好枝长恨无人寄。"]},{"id":"c58-736","title":"蝶恋花·金翦刀头芳意动","rhythmic":"蝶恋花","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["金翦刀头芳意动。","彩蕊开时，不怕朝寒重。","晴雪半消花䰒䰄。","晓妆呵尽香酥冻。","十二楼中双翠凤。","缥缈歌声，记得江南弄。","醉舞春风谁可共。","秦云已有鸳屏梦。"]},{"id":"c58-737","title":"蝶恋花·笑艳秋莲生绿浦","rhythmic":"蝶恋花","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["笑艳秋莲生绿浦。","红脸青腰，旧识凌波女。","照影弄妆娇欲语。","西风岂是繁华主。","可恨良辰天不与。","才过斜阳，又是黄昏雨。","朝落暮开空自许。","竟无人解知心苦。"]},{"id":"c58-738","title":"蝶恋花·碧落秋风吹玉树","rhythmic":"蝶恋花","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["碧落秋风吹玉树。","翠节红旌，晚过银河路。","休笑星机停弄杼。","凤帏已在云深处。","楼上金针穿绣缕。","谁管天边，隔岁分飞苦。","试等夜阑寻别绪。","泪痕千点罗衣露。"]},{"id":"c58-739","title":"蝶恋花·碧玉高楼临水住","rhythmic":"蝶恋花","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["碧玉高楼临水住。","红杏开时，花底曾相遇。","一曲阳春春已暮。","晓莺声断朝云去。","远水来从楼下路。","过尽流波，未得鱼中素。","月细风尖垂柳渡。","梦魂长在分襟处。"]},{"id":"c58-740","title":"蝶恋花·梦入江南烟水路","rhythmic":"蝶恋花","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["梦入江南烟水路。","行尽江南，不与离人遇。","睡里消魂无说处。","觉来惆怅消魂误。","欲尽此情书尺素。","浮雁沈鱼，终了无凭据。","却倚缓弦歌别绪。","断肠移破秦筝柱。"]},{"id":"c58-741","title":"蝶恋花·黄菊开时伤聚散","rhythmic":"蝶恋花","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["黄菊开时伤聚散。","曾记花前，共说深深愿。","重见金英人未见。","相思一夜天涯远。","罗带同心闲结遍。","带易成双，人恨成双晚。","欲写彩笺书别怨。","泪痕早已先书满。"]},{"id":"c58-742","title":"鹧鸪天·彩袖殷勤捧玉锺","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["彩袖殷勤捧玉锺。","当年拼却醉颜红。","舞低杨柳楼心月，歌尽桃花扇影风。","从别后，忆相逢。","几回魂梦与君同。","今宵剩把银釭照，犹恐相逢是梦中。"]},{"id":"c58-743","title":"鹧鸪天·一醉醒来春又残","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["一醉醒来春又残。","野棠梨雨泪阑干。","玉笙声里鸾空怨。","罗幕香中燕未还。","终易散，且长闲。","莫教离恨损朱颜。","谁堪共展鸳鸯锦，同过西楼此夜寒。"]},{"id":"c58-744","title":"鹧鸪天·梅蕊新妆桂叶眉","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["梅蕊新妆桂叶眉。","小莲风韵出瑶池。","云随绿水歌声转，雪绕红绡舞袖垂。","伤别易，恨欢迟。","惜无红锦为裁诗。","行人莫便消魂去，汉渚星桥尚有期。"]},{"id":"c58-745","title":"鹧鸪天·守得莲开结伴游","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["守得莲开结伴游。","约开萍叶上兰舟。","来时浦口云随棹，采罢江边月满楼。","花不语，水空流。","年年拼得为花愁。","明朝万一西风动，争向朱颜不耐秋。"]},{"id":"c58-746","title":"鹧鸪天·斗鸭池南夜不归","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["斗鸭池南夜不归。","酒阑纨扇有新诗。","云随碧玉歌声转，雪绕红琼舞袖回。","今感旧，欲沾衣。","可怜人似水东西。","回头满眼凄凉事，秋月春风岂得知。"]},{"id":"c58-747","title":"鹧鸪天·当日佳期鹊误传","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["当日佳期鹊误传。","至今犹作断肠仙。","桥成汉渚星波外，人在鸾歌凤舞前。","欢尽夜，别经年。","别多欢少奈何天。","情知此会无长计。","咫尺凉蟾亦未圆。"]},{"id":"c58-748","title":"鹧鸪天·题破香笺小砑红","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["题破香笺小砑红。","诗篇多寄旧相逢。","西楼酒面垂垂雪，南苑春衫细细风。","花不尽，柳无穷。","别来欢事少人同。","凭谁问取归云信，今在巫山第几峰。"]},{"id":"c58-749","title":"鹧鸪天·清颍尊前酒满衣","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["清颍尊前酒满衣。","十年风月旧相知。","凭谁细话当时事，肠断山长水远诗。","金凤阙，玉龙墀。","看君来换锦袍时。","姮娥已有殷勤约，留著蟾宫第一枝。"]},{"id":"c58-750","title":"鹧鸪天·醉拍春衫惜旧香","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["醉拍春衫惜旧香。","天将离恨恼疏狂。","年年陌上生秋草，日日楼中到夕阳。","云渺渺，水茫茫。","征人归路许多长。","相思本是无凭语，莫向花笺费泪行。"]},{"id":"c58-751","title":"鹧鸪天·小令尊前见玉箫","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["小令尊前见玉箫。","银灯一曲太妖娆。","歌中醉倒谁能恨，唱罢归来酒未消。","春悄悄，夜迢迢。","碧云天共楚宫遥。","梦魂惯得无拘检，又踏杨花过谢桥。"]},{"id":"c58-752","title":"鹧鸪天·楚女腰肢越女腮","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["楚女腰肢越女腮。","粉圆双蕊髻中开。","朱弦曲怨愁春尽，渌酒杯寒记夜来。","新掷果，旧分钗。","冶游音信隔章台。","花间锦字空频寄，月底金鞍竟未回。"]},{"id":"c58-753","title":"鹧鸪天·十里楼台倚翠微","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["十里楼台倚翠微。","百花深处杜娟啼。","殷勤自与行人语，不似流莺取次飞。","惊梦觉，弄晴时。","声声只道不如归。","天涯岂是无归意，争奈归期未可期。"]},{"id":"c58-754","title":"鹧鸪天·陌上濛濛残絮飞","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["陌上濛濛残絮飞。","杜娟花里杜娟啼。","年年底事不归去，怨月愁烟长为谁。","梅雨细，晓风微。","倚楼人听欲沾衣。","故园三度群花谢，曼倩天涯犹未归。"]},{"id":"c58-755","title":"鹧鸪天·晓日迎长岁岁同","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["晓日迎长岁岁同。","太平箫鼓间歌钟。","云高未有前村雪，梅小初开昨夜风。","罗幕翠，锦筵红。","钗头罗胜写宜冬。","从今屈指春期近，莫使金尊对月空。"]},{"id":"c58-756","title":"鹧鸪天·小玉楼中月上时","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["小玉楼中月上时。","夜来惟许月华知。","重帘有意藏私语，双烛无端恼暗期。","伤别易，恨欢迟。","归来何处验相思。","沈郎春雪愁消臂，谢女香膏懒画眉。"]},{"id":"c58-757","title":"鹧鸪天·手拈香笺忆小莲","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["手拈香笺忆小莲。","欲将遗恨倩谁传。","归来独卧逍遥夜，梦里相逢酩酊天。","花易落，月难圆。","只应花月似欢缘。","秦筝算有心情在，试写离声入旧弦。"]},{"id":"c58-758","title":"鹧鸪天·九日悲秋不到心","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["九日悲秋不到心。","凤城歌管有新音。","风凋碧柳愁眉淡，露染黄花笑靥深。","初见雁，已闻砧。","绮罗丛里胜登临。","须教月户纤纤玉，细捧霞觞滟滟金。"]},{"id":"c58-759","title":"鹧鸪天·碧藕花开水殿凉","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["碧藕花开水殿凉。","万年枝外转红阳。","升平歌管随天仗，祥瑞封章满御床。","金掌露，玉炉香。","岁华方共圣恩长。","皇州又奏圜扉静，十样宫眉捧寿觞。"]},{"id":"c58-760","title":"鹧鸪天·绿橘梢头几点春","rhythmic":"鹧鸪天","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["绿橘梢头几点春。","似留香蕊送行人。","明朝紫凤朝天路，十二重城五碧云。","歌渐咽，酒初醺。","尽将红泪湿湘裙。","赣江西畔从今日，明月清风忆使君。"]},{"id":"c58-761","title":"生查子·金鞭美少年","rhythmic":"生查子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["金鞭美少年，去跃青骢马。","牵系玉楼人，绣被春寒夜。","消息未归来，寒食梨花谢。","无处说相思，背面秋千下。"]},{"id":"c58-762","title":"生查子·轻匀两脸花","rhythmic":"生查子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["轻匀两脸花，淡扫双眉柳。","会写锦笺时，学弄朱弦后。","今春玉钏宽，昨夜罗裙皱。","无计奈情何，且醉金杯酒。"]},{"id":"c58-763","title":"生查子·关山魂梦长","rhythmic":"生查子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["关山魂梦长，鱼雁音尘少。","两鬓可怜青，只为相思老。","归梦碧纱窗，说与人人道。","真个别离难，不似相逢好。"]},{"id":"c58-764","title":"生查子·坠雨已辞云","rhythmic":"生查子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["坠雨已辞云，流水难归浦。","遗恨几时休，心抵秋莲苦。","忍泪不能歌，试托哀弦语。","弦语愿相逢，知有相逢否。"]},{"id":"c58-765","title":"生查子·一分残酒霞","rhythmic":"生查子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["一分残酒霞，两点愁蛾晕。","罗幕夜犹寒，玉枕春先困。","心情翦彩慵，时节烧灯近。","见少别离多，还有人堪恨。"]},{"id":"c58-766","title":"生查子·轻轻制舞衣","rhythmic":"生查子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["轻轻制舞衣，小小裁歌扇。","三月柳浓时，又向津亭见。","垂泪送行人，湿破红妆面。","玉指袖中弹，一曲清商怨。"]},{"id":"c58-767","title":"生查子·红尘陌上游","rhythmic":"生查子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["红尘陌上游，碧柳堤边住。","才趁彩云来，又逐飞花去。","深深美酒家，曲曲幽香路。","风月有情时，总是相思处。"]},{"id":"c58-768","title":"生查子·长恨涉江遥","rhythmic":"生查子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["长恨涉江遥，移近溪头住。","闲荡木兰舟，误入双鸳浦。","无端轻薄云，暗作廉纤雨。","翠袖不胜寒，欲向荷花语。"]},{"id":"c58-769","title":"生查子·远山眉黛长","rhythmic":"生查子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["远山眉黛长，细柳腰肢袅。","妆罢立春风，一笑千金少。","归去凤城时，说与青楼道。","遍看颍川花，不似师师好。"]},{"id":"c58-770","title":"生查子·落梅庭榭香","rhythmic":"生查子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["落梅庭榭香，芳草池塘绿。","春恨最关情，日过阑干曲。","几时花里闲，看得花枝足。","醉后莫思家，借取师师宿。"]},{"id":"c58-771","title":"生查子·狂花顷刻香","rhythmic":"生查子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["狂花顷刻香，晚蝶缠绵意。","天与短因缘，聚散常容易。","传唱入离声，恼乱双蛾翠。","游子不堪闻，正是衷肠事。"]},{"id":"c58-772","title":"生查子·官身几日闲","rhythmic":"生查子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["官身几日闲，世事何时足。","君貌不长红，我鬓无重绿。","榴花满盏香，金缕多情曲。","且尽眼中欢，莫叹时光促。"]},{"id":"c58-773","title":"生查子·春从何处归","rhythmic":"生查子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["春从何处归，试向溪边问。","岸柳弄娇黄，陇麦回青润。","多情美少年，屈指芳菲近。","谁寄岭头梅，来报江南信。"]},{"id":"c58-774","title":"南乡子·渌水带青潮","rhythmic":"南乡子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["渌水带青潮。","水上朱阑小渡桥。","桥上女儿双笑靥，妖娆。","倚著阑干弄柳条。","月夜落花朝。","减字偷声按玉箫。","柳外行人回首处，迢迢。","若比银河路更遥。"]},{"id":"c58-775","title":"南乡子·小蕊受春风","rhythmic":"南乡子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["小蕊受春风。","日日宫花花树中。","恰向柳绵撩乱处，相逢。","笑靥旁边心字浓。","归路草茸茸。","家在秦楼更近东。","醒去醉来无限事，谁同。","说著西池满面红。"]},{"id":"c58-776","title":"南乡子·花落未须悲","rhythmic":"南乡子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["花落未须悲。","红蕊明年又满枝。","惟有花间人别后，无期。","水阔山长雁字迟。","今日最相思。","记得攀条话别离。","共说春来春去事，多时。","一点愁心入翠眉。"]},{"id":"c58-777","title":"南乡子·何处别时难","rhythmic":"南乡子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["何处别时难。","玉指偷将粉泪弹。","记得来时楼上烛，初残。","待得清霜满画阑。","不惯独眠寒。","自解罗衣衬枕檀。","百媚也应愁不睡，更阑。","恼乱心情半被闲。"]},{"id":"c58-778","title":"南乡子·画鸭懒熏香","rhythmic":"南乡子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["画鸭懒熏香。","绣茵犹展旧鸳鸯。","不似同衾愁易晓，空床。","细剔银灯怨漏长。","几夜月波凉。","梦魂随月到兰房。","残睡觉来人又远，难忘。","便是无情也断肠。"]},{"id":"c58-779","title":"南乡子·眼约也应虚","rhythmic":"南乡子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["眼约也应虚。","昨夜归来凤枕孤。","且据如今情分里，相於。","只恐多时不似初。","深意托双鱼。","小翦蛮笺细字书。","更把此情重问得，何如。","共结因缘久远无。"]},{"id":"c58-780","title":"南乡子·新月又如眉","rhythmic":"南乡子","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["新月又如眉。","长笛谁教月下吹。","楼倚暮云初见雁，南飞。","漫道行人雁后归。","意欲梦佳期。","梦里关山路不知。","却待短书来破恨，应迟。","还是凉生玉枕时。"]},{"id":"c58-781","title":"清平乐·留人不住","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["留人不住。","醉解兰舟去。","一棹碧涛春水路。","过尽晓莺啼处。","渡头杨柳青青。","枝枝叶叶离情。","此后锦书休寄，画楼云雨无凭。"]},{"id":"c58-782","title":"清平乐·千花百草","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["千花百草。","送得春归了。","拾蕊人稀红渐少。","叶底杏青梅小。","小琼闲抱琵琶。","雪香微透轻纱。","正好一枝娇艳，当筵独占韶华。"]},{"id":"c58-783","title":"清平乐·烟轻雨小","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["烟轻雨小。","紫陌香尘少。","谢客池塘生绿草。","一夜红梅先老。","旋题罗带新诗。","重寻杨柳佳期。","强半春寒去后，几番花信来时。"]},{"id":"c58-784","title":"清平乐·可怜娇小","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["可怜娇小。","掌上承恩早。","把镜不知人易老。","欲占朱颜长好。","画堂秋月佳期。","藏钩赌酒归迟。","红烛泪前低语，绿笺花里新词。"]},{"id":"c58-785","title":"清平乐·红英落尽","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["红英落尽。","未有相逢信。","可恨流年凋绿鬓。","睡得春酲欲醒。","钿筝曾醉西楼。","朱弦玉指梁州。","曲罢翠帘高卷，几回新月如钩。"]},{"id":"c58-786","title":"清平乐·春云绿处","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["春云绿处。","又见归鸿去。","侧帽风前花满路。","冶叶倡条情绪。","红楼桂酒新开。","曾携翠袖同来。","醉弄影娥池水，短箫吹落残梅。"]},{"id":"c58-787","title":"清平乐·波纹碧皱","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["波纹碧皱。","曲水清明后。","折得疏梅香满袖。","暗喜春红依旧。","归来紫陌东头。","金钗换酒消愁。","柳影深深细路，花梢小小层楼。"]},{"id":"c58-788","title":"清平乐·西池烟草","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["西池烟草。","恨不寻芳早。","满路落花红不扫。","春色渐随人老。","远山眉黛娇长。","清歌细逐霞觞。","正在十洲残梦，水心宫殿斜阳。"]},{"id":"c58-789","title":"清平乐·蕙心堪怨","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["蕙心堪怨。","也逐春风转。","丹杏墙东当日见。","幽会绿窗题遍。","眼中前事分明。","可怜如梦难凭。","都把旧时薄幸，只消今日无情。"]},{"id":"c58-790","title":"清平乐·幺弦写意","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["幺弦写意。","意密弦声碎。","书得凤笺无限事。","犹恨春心难寄。","卧听疏雨梧桐。","雨馀淡月朦胧。","一夜梦魂何处，那回杨叶楼中。"]},{"id":"c58-791","title":"清平乐·笙歌宛转","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["笙歌宛转。","台上吴王宴。","宫女如花倚春殿。","舞绽缕金衣线。","酒阑画烛低迷。","彩鸳惊起双栖。","月底三千绣户，云间十二琼梯。"]},{"id":"c58-792","title":"清平乐·暂来还去","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["暂来还去。","轻似风头絮。","纵得相逢留不住。","何况相逢无处。","去时约略黄昏。","月华却到朱门。","别后几番明月，素娥应是消魂。"]},{"id":"c58-793","title":"清平乐·双纹彩袖","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["双纹彩袖。","笑捧金船酒。","娇妙如花轻似柳。","劝客千春长寿。","艳歌更倚疏弦。","有情须醉尊前。","恰是可怜时候，玉娇今夜初圆。"]},{"id":"c58-794","title":"清平乐·寒催酒醒","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["寒催酒醒。","晓陌飞霜定。","背照画帘残烛影。","斜月光中人静。","锦衣才子西征。","万重云水初程。","翠黛倚门相送，鸾肠断处离声。"]},{"id":"c58-795","title":"清平乐·莲开欲遍","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["莲开欲遍。","一夜秋声转。","残绿断红香片片。","长是西风堪怨。","莫愁家住溪边。","采莲心事年年。","谁管水流花谢，月明昨夜兰船。"]},{"id":"c58-796","title":"清平乐·沈思暗记","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["沈思暗记。","几许无凭事。","菊靥开残秋少味。","闲却画阑风意。","梦云归处难寻。","微凉暗入香襟。","犹恨那回庭院，依前月浅灯深。"]},{"id":"c58-797","title":"清平乐·莺来燕去","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["莺来燕去。","宋玉墙东路。","草草幽欢能几度。","便有系人心处。","碧天秋月无端。","别来长照关山。","一点恹恹谁会，依前凭暖阑干。"]},{"id":"c58-798","title":"清平乐·心期休问","rhythmic":"清平乐","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["心期休问。","只有尊前分。","勾引行人添别恨。","因是语低香近。","劝人满酌金锺。","清歌唱彻还重。","莫道后期无定，梦魂犹有相逢。"]},{"id":"c58-799","title":"木兰花・玉楼春·秋千院落重帘暮","rhythmic":"木兰花・玉楼春","author":"晏几道","authorSlug":"晏几道","dynasty":"宋","kind":"ci","paragraphs":["秋千院落重帘暮。","彩笔闲来题绣户。","墙头丹杏雨馀花，门外绿杨风后絮。","朝云信断知何处。","应作襄王春梦去。","紫骝认得旧游踪，嘶过画桥东畔路。"]}]