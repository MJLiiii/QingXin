io":["朱少端，元和初越州乡贡进士。诗一首。（《全唐诗》无朱少端诗）"],"works":[{"id":"t53-389","title":"送空海上人朝谒后归日本","kind":"诗"}]},"朱晞颜":{"slug":"朱晞颜","name":"朱晞颜","dynasty":"宋","style":"","life":"","origin":"","seal":"朱","bio":[],"works":[{"id":"c68-163","title":"南歌子·影落三秋月","kind":"词"}]},"李白":{"slug":"李白","name":"李白","dynasty":"唐","style":"字太白","life":"","origin":"或曰山东","seal":"李","bio":["李白，字太白，陇西成纪人，凉武昭王暠九世孙。或曰山东人，或曰蜀人。白少有逸才，志气宏放，飘然有超世之心。","初隐岷山，益州长史苏颋见而异之曰：“是子天才英特，可比相如。”天宝初，至长安，往见贺知章。知章见其文，叹曰：“子谪仙人也。","”言于明皇，召见金銮殿，奏颂一篇。帝赐食，亲为调羹。有诏供奉翰林，白犹与酒徒饮于巿。","帝坐沉香亭子，意有所感，欲得白为乐章，召入，而白已醉。左右以水颒面，稍解，援笔成文，婉丽精切。帝爱其才，数宴见。","白常侍帝，醉，使高力士脱鞾。力士素贵，耻之，摘其诗以激杨贵妃。帝欲官白，妃輙沮止。","白自知不为亲近所容，恳求还山。帝赐金放还，乃浪迹江湖，终日沈饮。永王璘都督江陵，辟为僚佐。","璘谋乱，兵败，白坐长流夜郎，会赦得还。族人阳冰为当涂令，白往依之。代宗立，以左拾遗召，而白已卒。","文宗时，诏以白歌诗、裴旻劒舞、张旭草书为三绝云。集三十卷，今编诗二十五卷。"],"works":[{"id":"t0-854","title":"鼓吹曲辞 上之回","kind":"诗"},{"id":"t0-857","title":"鼓吹曲辞 战城南","kind":"诗"},{"id":"t0-874","title":"鼓吹曲辞 将进酒","kind":"诗"},{"id":"t0-877","title":"鼓吹曲辞 君马黄","kind":"诗"},{"id":"t0-885","title":"鼓吹曲辞 有所思","kind":"诗"},{"id":"t0-890","title":"鼓吹曲辞 雉子班","kind":"诗"},{"id":"t0-978","title":"横吹曲辞 折杨柳","kind":"诗"},{"id":"t0-987","title":"横吹曲辞 关山月","kind":"诗"},{"id":"t1-0","title":"横吹曲辞 洛阳陌","kind":"诗"},{"id":"t1-14","title":"横吹曲辞 紫骝马","kind":"诗"},{"id":"t1-24","title":"横吹曲辞 幽州胡马客歌","kind":"诗"},{"id":"t1-25","title":"横吹曲辞 白鼻䯄","kind":"诗"},{"id":"t1-28","title":"相和歌辞 公无渡河","kind":"诗"},{"id":"t1-60","title":"相和歌辞 登高丘而望远","kind":"诗"},{"id":"t1-68","title":"相和歌辞 对酒二首 一","kind":"诗"},{"id":"t1-69","title":"相和歌辞 对酒二首 二","kind":"诗"},{"id":"t1-70","title":"相和歌辞 陌上桑","kind":"诗"},{"id":"t1-77","title":"相和歌辞 日出行","kind":"诗"},{"id":"t1-95","title":"相和歌辞 王昭君二首 一","kind":"诗"},{"id":"t1-96","title":"相和歌辞 王昭君二首 二","kind":"诗"},{"id":"t1-113","title":"相和歌辞 长歌行","kind":"诗"},{"id":"t1-116","title":"相和歌辞 短歌行","kind":"诗"},{"id":"t1-156","title":"相和歌辞 猛虎行","kind":"诗"},{"id":"t1-176","title":"相和歌辞 从军行二首 一","kind":"诗"},{"id":"t1-177","title":"相和歌辞 从军行二首 二","kind":"诗"},{"id":"t1-213","title":"相和歌辞 鞠歌行","kind":"诗"},{"id":"t1-221","title":"相和歌辞  北上行","kind":"诗"},{"id":"t1-222","title":"相和歌辞  豫章行","kind":"诗"},{"id":"t1-226","title":"相和歌辞 相逢行二首 一","kind":"诗"},{"id":"t1-227","title":"相和歌辞 相逢行二首 二","kind":"诗"},{"id":"t1-237","title":"相和歌辞 来日大难","kind":"诗"},{"id":"t1-249","title":"相和歌辞 上留田","kind":"诗"},{"id":"t1-253","title":"相和歌辞 野田黄雀行","kind":"诗"},{"id":"t1-262","title":"相和歌辞 门有车马客行","kind":"诗"},{"id":"t1-264","title":"相和歌辞 蜀道难","kind":"诗"},{"id":"t1-269","title":"相和歌辞 胡无人行","kind":"诗"},{"id":"t1-272","title":"相和歌辞 白头吟二首 一","kind":"诗"},{"id":"t1-273","title":"相和歌辞 白头吟二首 二","kind":"诗"},{"id":"t1-279","title":"相和歌辞 梁甫吟","kind":"诗"},{"id":"t1-280","title":"相和歌辞 东武吟","kind":"诗"},{"id":"t1-297","title":"相和歌辞 怨歌行","kind":"诗"},{"id":"t1-308","title":"相和歌辞 长门怨二首 一","kind":"诗"},{"id":"t1-309","title":"相和歌辞 长门怨二首 二","kind":"诗"},{"id":"t1-343","title":"相和歌辞 长信怨","kind":"诗"},{"id":"t1-345","title":"相和歌辞 玉阶怨","kind":"诗"},{"id":"t1-366","title":"相和歌辞 子夜四时歌四首 春歌","kind":"诗"},{"id":"t1-367","title":"相和歌辞 子夜四时歌四首 夏歌","kind":"诗"},{"id":"t1-368","title":"相和歌辞 子夜四时歌四首 秋歌","kind":"诗"},{"id":"t1-369","title":"相和歌辞 子夜四时歌四首 冬歌","kind":"诗"},{"id":"t1-378","title":"相和歌辞 丁督护歌","kind":"诗"}]},"杜之松":{"slug":"杜之松","name":"杜之松","dynasty":"唐","style":"","life":"","origin":"","seal":"杜","bio":["杜之松，博陵曲阿人，隋起居舍人。贞观中，为河中刺史，尝荅王绩书云：“康成道重，不许太守称官；老莱家居，羞与诸侯为伍。仆岂不能正平公之坐，敬养亥唐，屈文侯之膝，恭师子夏，其雅尚可知矣。","”诗一首。"],"works":[{"id":"t2-684","title":"和卫尉寺柳","kind":"诗"}]},"杨敬述进":{"slug":"杨敬述进","name":"杨敬述进","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":[],"works":[{"id":"t2-45","title":"杂曲歌辞 婆罗门","kind":"诗"}]},"王万之":{"slug":"王万之","name":"王万之","dynasty":"宋","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"c74-821","title":"踏莎行·柳外寒轻","kind":"词"}]},"王琚":{"slug":"王琚","name":"王琚","dynasty":"唐","style":"号内宰相","life":"","origin":"","seal":"王","bio":["王琚，怀州河内人。神龙初，为驸马王同皎所器，预谋刺武三思。后太平公主谋逆，琚劝明皇先事诛之，荐张说、刘幽求、郭元振等与决议。","事平，进户部尚书，眷委特异，参豫大政，时号内宰相。后以谗见疏，历典外郡。卒为李林甫所搆，贬死。","诗四首。"],"works":[{"id":"t5-168","title":"奉荅燕公","kind":"诗"},{"id":"t5-169","title":"美女篇","kind":"诗"},{"id":"t5-170","title":"自荆湖入朝至岳阳奉别张燕公","kind":"诗"},{"id":"t5-171","title":"游㴩湖上寺","kind":"诗"},{"id":"t52-816","title":"奉答燕公 一","kind":"诗"},{"id":"t52-817","title":"奉答燕公 二","kind":"诗"}]},"田中行":{"slug":"田中行","name":"田中行","dynasty":"宋","style":"","life":"","origin":"","seal":"田","bio":[],"works":[{"id":"c63-99","title":"失调名·为谁和泪倚阑干","kind":"词"},{"id":"c63-100","title":"风入松·一宵风雨送春归","kind":"词"}]},"窦裕":{"slug":"窦裕","name":"窦裕","dynasty":"唐","style":"","life":"","origin":"","seal":"窦","bio":[],"works":[{"id":"t47-952","title":"洋州馆夜吟","kind":"诗"}]},"苏小小":{"slug":"苏小小","name":"苏小小","dynasty":"宋","style":"","life":"","origin":"","seal":"苏","bio":[],"works":[{"id":"c76-624","title":"减字木兰花·别离情绪","kind":"词"}]},"若水":{"slug":"若水","name":"若水","dynasty":"唐","style":"","life":"","origin":"","seal":"若","bio":[],"works":[{"id":"t47-220","title":"题慧山泉","kind":"诗"}]},"赵冬曦":{"slug":"赵冬曦","name":"赵冬曦","dynasty":"唐","style":"","life":"","origin":"","seal":"赵","bio":["赵冬曦，定州人。进士擢第，历左拾遗。开元初，迁监察御史，坐事流岳州。","时与刺史张说数赋诗相倡和，后召还复官，累迁中书舍人，内供奉，终国子祭酒。冬曦兄冬日、弟和璧等六人，韦述弟亦六人，并词学登科。张说称之曰：“韦赵昆季，人之杞梓。","”诗十九首。"],"works":[{"id":"t5-145","title":"陪张燕公登南楼","kind":"诗"},{"id":"t5-146","title":"酬燕公出湖见寄","kind":"诗"},{"id":"t5-147","title":"奉和张燕公早霁南楼","kind":"诗"},{"id":"t5-148","title":"㴩湖作","kind":"诗"},{"id":"t5-149","title":"和燕公岳州山城","kind":"诗"},{"id":"t5-150","title":"和尹懋秋夜游㴩湖二首 一","kind":"诗"},{"id":"t5-151","title":"和尹懋秋夜游㴩湖二首 二","kind":"诗"},{"id":"t5-152","title":"陪燕公游㴩湖","kind":"诗"},{"id":"t5-153","title":"荅张燕公翻著葛巾见呈之作","kind":"诗"},{"id":"t5-154","title":"奉荅燕公","kind":"诗"},{"id":"t5-155","title":"奉和圣制同二相已下群官乐游园宴","kind":"诗"},{"id":"t5-156","title":"奉和圣制荅张说扈从南出雀鼠谷","kind":"诗"},{"id":"t5-157","title":"奉和圣制送张说上集贤学士赐宴赋得莲字","kind":"诗"},{"id":"t5-158","title":"奉荅燕公","kind":"诗"},{"id":"t5-159","title":"陪张燕公行郡竹篱","kind":"诗"},{"id":"t5-160","title":"和燕公别㴩湖","kind":"诗"},{"id":"t5-161","title":"奉酬燕公见归田赋垂赠之作","kind":"诗"},{"id":"t5-162","title":"和张燕公耗磨日饮 一","kind":"诗"},{"id":"t5-16