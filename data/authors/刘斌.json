{"slug":"刘斌","name":"刘斌","dynasty":"唐","style":"字太初","life":"","origin":"","seal":"刘","bio":["刘辟，字太初。擢进士第，佐韦臯西川幕。后代为节度使，以叛诛。","诗二首。"],"works":[{"id":"t41-186","title":"和谒孔子庙","kind":"诗"},{"id":"t41-187","title":"和许给事伤牛尚书","kind":"诗"},{"id":"t41-188","title":"送刘散员同赋陈思王诗得好鸟鸣高枝","kind":"诗"},{"id":"t41-189","title":"咏山","kind":"诗"},{"id":"t41-190","title":"登楼望月二首 一","kind":"诗"},{"id":"t41-191","title":"登楼望月二首 二","kind":"诗"}]}