{"史松":{"slug":"史松","name":"史松","dynasty":"唐","style":"","life":"","origin":"","seal":"史","bio":["史松，又名史邕，郑滑人。试礼部不第，往游荆州。天成二年至武陵。","诗二首。（《全唐诗》无史松诗）"],"works":[{"id":"t55-231","title":"梦中献南楚国王夜宴诗（题拟）","kind":"诗"},{"id":"t55-232","title":"翛公上人草书歌（题从《书苑菁华》）","kind":"诗"}]},"叶适":{"slug":"叶适","name":"叶适","dynasty":"宋","style":"","life":"","origin":"","seal":"叶","bio":[],"works":[{"id":"c63-911","title":"西江月·识贯事中枢纽","kind":"词"}]},"吴编修":{"slug":"吴编修","name":"吴编修","dynasty":"宋","style":"","life":"","origin":"","seal":"吴","bio":[],"works":[{"id":"c76-448","title":"贺新凉・贺新郎·出处男儿事","kind":"词"},{"id":"c76-449","title":"八声甘州·系酒船","kind":"词"},{"id":"c76-450","title":"摸鱼儿·予何人","kind":"词"}]},"周朴":{"slug":"周朴","name":"周朴","dynasty":"唐","style":"字太朴","life":"","origin":"","seal":"周","bio":["周朴，字太朴，吴兴人。避地福州，寄食乌石山僧寺。黄巢寇闽，欲降之，朴不从，遂见害。","诗一卷。周朴字太朴，吴兴人。补诗一首并诗句二。"],"works":[{"id":"t37-476","title":"题甘露寺","kind":"诗"},{"id":"t37-477","title":"题玄公院","kind":"诗"},{"id":"t37-478","title":"福州东禅寺","kind":"诗"},{"id":"t37-479","title":"赠大沩和尚","kind":"诗"},{"id":"t37-480","title":"秋夜不寐寄崔温进士","kind":"诗"},{"id":"t37-481","title":"春中途中寄南巴崔使君","kind":"诗"},{"id":"t37-482","title":"寄处士方干","kind":"诗"},{"id":"t37-483","title":"寄塞北张符","kind":"诗"},{"id":"t37-484","title":"次梧州却寄永州使君","kind":"诗"},{"id":"t37-485","title":"赠念经僧","kind":"诗"},{"id":"t37-486","title":"董岭水","kind":"诗"},{"id":"t37-487","title":"早春","kind":"诗"},{"id":"t37-488","title":"秋深","kind":"诗"},{"id":"t37-489","title":"赠双峰山和尚","kind":"诗"},{"id":"t37-490","title":"赠无了禅师","kind":"诗"},{"id":"t37-491","title":"王霸坛","kind":"诗"},{"id":"t37-492","title":"送梁道士","kind":"诗"},{"id":"t37-493","title":"边思","kind":"诗"},{"id":"t37-494","title":"哭陈庾","kind":"诗"},{"id":"t37-495","title":"宿玉泉寺","kind":"诗"},{"id":"t37-496","title":"题赤城中岩寺","kind":"诗"},{"id":"t37-497","title":"塞上行","kind":"诗"},{"id":"t37-498","title":"玉泉寺","kind":"诗"},{"id":"t37-499","title":"春宫怨","kind":"诗"},{"id":"t37-500","title":"宿刘温书斋","kind":"诗"},{"id":"t37-501","title":"登福州南涧寺","kind":"诗"},{"id":