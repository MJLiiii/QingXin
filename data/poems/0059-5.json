[{"id":"c59-500","title":"雨中花令·休把身心撋就","rhythmic":"雨中花令","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["休把身心撋就。","著便醉人如酒。","富贵功名虽有味，毕竟因谁守。","看取刀头切藕。","厚薄都随他手。","趁取日中归去好，□莫待、黄昏后。"]},{"id":"c59-501","title":"雨中花令·点缀叶间如绣","rhythmic":"雨中花令","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["点缀叶间如绣。","开傍小春时候。","莫把幽兰容易比，都占尽、人间秀。","信是眼前稀有。","消得千锺美酒。","只有些儿堪恨处，管不似、人长久。"]},{"id":"c59-502","title":"留春令·梦断难寻","rhythmic":"留春令","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["梦断难寻，酒醒犹困，那堪春暮。","香阁深沈，红窗翠暗，莫羡颠狂絮。","绿满当时携手路，懒见同欢处。","何时却得，低帏昵枕，尽诉情千缕。"]},{"id":"c59-503","title":"踏莎行·紫燕衔泥","rhythmic":"踏莎行","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["紫燕衔泥，黄莺唤友。","可人春色暄晴昼。","王孙一去杳无音，断肠最是黄昏后。","宝髻慵梳，玉钗斜溜。","凭阑目断空回首。","薄情何事不归来，谩教折尽庭前柳。"]},{"id":"c59-504","title":"踏莎行·一别芳容","rhythmic":"踏莎行","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["一别芳容，五经寒暑。","回文欲寄无鳞羽。","多情犹自梦中来，向人粉泪流如雨。","梦破南窗，愁肠万缕。","那听角动城头鼓。","人生弹指事成空，断魂惆怅无寻处。"]},{"id":"c59-505","title":"南乡子·夜雨滴空阶","rhythmic":"南乡子","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["夜雨滴空阶。","想见尊前赋咏才。","更觉鸣蛙如鼓吹，安排。","惆怅流光去不回。","万事已成灰。","只这些儿尚满怀。","刚被北风吹晓角，相催。","不许时间入梦来。"]},{"id":"c59-506","title":"万年欢·暖律才中","rhythmic":"万年欢","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["暖律才中，正莺喉竞巧，燕语新成。","万绿阴浓，全无一点芳尘。","门巷朝来报喜，庆佳期、此日光荣。","开华宴、交酌琼酥，共祝鹤算椿龄。","须知最难得处，双双凤翼，一对和鸣。","造化无私，谁教特地多情。","惟愿疏封大国，彩笺上、频易佳名。","从此去、贤子才孙，岁岁长捧瑶觥。"]},{"id":"c59-507","title":"朝中措·新开湖水浸遥天","rhythmic":"朝中措","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["新开湖水浸遥天。","风叶响珊珊。","记得昔游情味，浩歌不怕朝寒。","故人一去，高名万古，长对孱颜。","惟有落霞孤骛，晚年依旧争还。"]},{"id":"c59-508","title":"朝中措·败荷枯苇夕阳天","rhythmic":"朝中措","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["败荷枯苇夕阳天。","时节渐阑珊。","独泛扁舟归去，老来不耐霜寒。","平生志气，消磨尽也，留得苍颜。","寄语山中糜鹿，断云相次东还。"]},{"id":"c59-509","title":"临江仙·初破晓寒无限思","rhythmic":"临江仙","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["初破晓寒无限思，融融腊意全迷。","春工从此被人知。","不随蜂蝶，长伴玉蟾低。","缥缈云间应好在，盈盈泪湿征衣。","背人偷拗向东枝。","清香满袖，犹记画堂西。"]},{"id":"c59-510","title":"临江仙·病里不知春早晚","rhythmic":"临江仙","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["病里不知春早晚，惊心绿暗红稀。","起来初拭薄罗衣。","多情海燕，还傍旧梁飞。","瘦损休文谁记得，空将销臂频围。","眼前都是去年时。","不堪追想，魂断画楼西。"]},{"id":"c59-511","title":"蝶恋花·帘外飞花湖上语","rhythmic":"蝶恋花","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["帘外飞花湖上语。","不恨花飞，只恨人难住。","多谢雨来留得住。","看看却恐晴催去。","寸寸离肠须会取。","今日宁宁，明日从谁诉。","怎得此身如去路。","迢迢长在君行处。"]},{"id":"c59-512","title":"失调名·骊山宫中看乞巧","rhythmic":"失调名","author":"蔡确","authorSlug":"蔡确","dynasty":"宋","kind":"ci","paragraphs":["骊山宫中看乞巧，太液池边收曝衣。"]},{"id":"c59-513","title":"惜黄花·雁声晚断","rhythmic":"惜黄花","author":"许将","authorSlug":"许将","dynasty":"宋","kind":"ci","paragraphs":["雁声晚断。","寒宵云卷。","正一枝开，风前看，月下见。","花占千花上，香笑千香浅。","化工与、最先裁翦。","谁把瑶林，闲抛江岸。","恁素英浓，芳心细，意何限。","不恨宫妆色，不怨吹羌管。","恨天远、恨春来晚。"]},{"id":"c59-514","title":"临江仙·圣主临轩亲策试","rhythmic":"临江仙","author":"许将","authorSlug":"许将","dynasty":"宋","kind":"ci","paragraphs":["圣主临轩亲策试，集英佳气葱葱。","鸣鞘声震未央宫。","卷帘龙影动，挥翰御烟浓。","上第归来何事好，迎人花面争红。","蓝袍香散六街风。","一鞭春色里，骄损玉花骢。"]},{"id":"c59-515","title":"临江仙·不比寻常三五夜","rhythmic":"临江仙","author":"郑无党","authorSlug":"郑无党","dynasty":"宋","kind":"ci","paragraphs":["不比寻常三五夜，万家齐望清辉。","烂银盘透碧琉璃。","莫辞终夕看，动是隔年期。","试问嫦娥还记否，玉人曾折高枝。","明年此夜再圆时。","合开东府宴，身在凤凰池。"]},{"id":"c59-516","title":"无愁可解·光景百年","rhythmic":"无愁可解","author":"陈","authorSlug":"陈","dynasty":"宋","kind":"ci","paragraphs":["光景百年，看便一世。","生来不识愁味。","问愁何处来，更开解个甚底。","万事从来风过耳。","何用不著心里。","你唤做、展却眉头，便是达者，也则恐未。","此理。","本不通言，何曾道、欢游胜如名利。","道即浑是错，不道如何即是。","这里元无我与你。","甚唤做、物情之外。","若须待醉了、方开解时，问无酒、怎生醉。"]},{"id":"c59-517","title":"调啸・调笑令·渔父","rhythmic":"调啸・调笑令","author":"苏辙","authorSlug":"苏辙","dynasty":"宋","kind":"ci","paragraphs":["渔父。","渔父。","水上微风细雨。","青蓑黄箬裳衣。","红酒白鱼暮归。","暮归、暮归、归暮。","长笛一声何处。"]},{"id":"c59-518","title":"调啸・调笑令·归雁","rhythmic":"调啸・调笑令","author":"苏辙","authorSlug":"苏辙","dynasty":"宋","kind":"ci","paragraphs":["归雁。","归雁。","饮啄江南南岸。","将飞却下盘桓。","塞北春来苦寒。","苦寒。","苦寒。","寒苦。","藻荇欲生且住。"]},{"id":"c59-519","title":"水调歌头·离别一何久","rhythmic":"水调歌头","author":"苏辙","authorSlug":"苏辙","dynasty":"宋","kind":"ci","paragraphs":["离别一何久，七度过中秋。","去年东武今夕，明月不胜愁。","岂意彭城山下，同泛清河古汴，船上载凉州。","鼓吹助清赏，鸿雁起汀洲。","坐中客，翠羽帔，紫绮裘。","素娥无赖，西去曾不为人留。","今夜清尊对客，明夜孤帆水驿，依旧照离忧。","但恐同王粲，相对永登楼。"]},{"id":"c59-520","title":"渔家傲·七十馀年真一梦","rhythmic":"渔家傲","author":"苏辙","authorSlug":"苏辙","dynasty":"宋","kind":"ci","paragraphs":["七十馀年真一梦。","朝来寿斝儿孙奉。","忧患已空无复痛。","心不动。","此间自有千钧重。","早岁文章供世用。","中年禅味疑天纵。","石塔成时无一缝。","谁与共。","人间天上随他送。"]},{"id":"c59-521","title":"沁园春·小雪初晴","rhythmic":"沁园春","author":"陈睦","authorSlug":"陈睦","dynasty":"宋","kind":"ci","paragraphs":["小雪初晴，画舫明月，强饮未眠。","念翠鬟双耸，舞衣半卷，琵琶催拍，促管危弦。","密意虽具，欢期难偶，遣我离情愁绪牵。","追思处，奈溪桥道窄，无计留连。","天天。","莫是前缘。","自别后、深诚谁为传。","想玉篦偷付，珠囊暗解，两心长在，须合金钿。","浅淡精神，温柔情性，记我疏狂应痛怜。","空肠断，奈衾寒漏永，终夜如年。"]},{"id":"c59-522","title":"清平乐·鬓云斜坠","rhythmic":"清平乐","author":"陈睦","authorSlug":"陈睦","dynasty":"宋","kind":"ci","paragraphs":["鬓云斜坠。","莲步弯弯细。","笑脸双蛾生多媚。","百步兰麝香喷。","从前万种愁烦。","枕边未可明言。","好是蓝桥再渡，玉篦还胜金钿。"]},{"id":"c59-523","title":"玉楼春·来时吴会犹残暑","rhythmic":"玉楼春","author":"马成","authorSlug":"马成","dynasty":"宋","kind":"ci","paragraphs":["来时吴会犹残暑。","去日武林春已暮。","欲知遗爱感人深，洒泪多於江上雨。","欢情未举眉先聚。","别酒多斟君莫诉。","从今宁忍看西湖，抬眼尽成肠断处。"]},{"id":"c59-524","title":"满江红·荆楚风烟","rhythmic":"满江红","author":"李婴","authorSlug":"李婴","dynasty":"宋","kind":"ci","paragraphs":["荆楚风烟，寂寞近、中秋时候。","露下冷、兰英将谢，苇花初秀。","归燕殷勤辞巷陌，鸣蛩凄楚来窗牖。","又谁念、江边有神仙，飘零久。","横琴膝，携筇手。","旷望眼，闲吟口。","任纷纷万事，到头何有。","君不见、凌烟冠剑客，何人气貌长依旧。","归去来、一曲为君吟，为君寿。"]},{"id":"c59-525","title":"菩萨蛮·玉肌香衬冰丝縠","rhythmic":"菩萨蛮","author":"王齐愈","authorSlug":"王齐愈","dynasty":"宋","kind":"ci","paragraphs":["玉肌香衬冰丝縠。","縠丝冰衬香肌玉。","纤指拂眉尖。","尖眉拂指纤。","巧裁罗袜小。","小袜罗裁巧。","移步看尘飞。","飞尘看步移。"]},{"id":"c59-526","title":"菩萨蛮·吼雷催雨飞沙走","rhythmic":"菩萨蛮","author":"王齐愈","authorSlug":"王齐愈","dynasty":"宋","kind":"ci","paragraphs":["吼雷催雨飞沙走。","走沙飞雨催雷吼。","波涨泻倾河。","河倾泻涨波。","幌纱凉气爽。","爽气凉纱幌。","幽梦觉仙游。","游仙觉梦幽。"]},{"id":"c59-527","title":"菩萨蛮·兽喷香缕飞长昼","rhythmic":"菩萨蛮","author":"王齐愈","authorSlug":"王齐愈","dynasty":"宋","kind":"ci","paragraphs":["兽喷香缕飞长昼。","昼长飞缕香喷兽。","迎日喜葵倾。","倾葵喜日迎。","卷帘双舞燕。","燕舞双帘卷。","清簟枕钗横。","横钗枕簟清。"]},{"id":"c59-528","title":"菩萨蛮·远香风递莲湖满","rhythmic":"菩萨蛮","author":"王齐愈","authorSlug":"王齐愈","dynasty":"宋","kind":"ci","paragraphs":["远香风递莲湖满。","满湖莲递风香远。","光鉴试新妆。","妆新试鉴光。","棹穿花处好。","好处花穿棹。","明月咏歌清。","清歌咏月明。"]},{"id":"c59-529","title":"菩萨蛮·酒中愁说人留久","rhythmic":"菩萨蛮","author":"王齐愈","authorSlug":"王齐愈","dynasty":"宋","kind":"ci","paragraphs":["酒中愁说人留久。","久留人说愁中酒。","归梦要迟迟。","迟迟要梦归。","旧衣香染袖。","袖染香衣旧。","封短托飞鸿。","鸿飞托短封。"]},{"id":"c59-530","title":"菩萨蛮·老人愁叹惊年早","rhythmic":"菩萨蛮","author":"王齐愈","authorSlug":"王齐愈","dynasty":"宋","kind":"ci","paragraphs":["老人愁叹惊年早。","早年惊叹愁人老。","霜点鬓苍苍。","苍苍鬓点霜。","酒杯停欲久。","久欲停杯酒。","杯酒唤眉开。","开眉唤酒杯。"]},{"id":"c59-531","title":"菩萨蛮·暑烦人困初时午","rhythmic":"菩萨蛮","author":"王齐愈","authorSlug":"王齐愈","dynasty":"宋","kind":"ci","paragraphs":["暑烦人困初时午。","午时初困人烦暑。","新诗得酒因。","因酒得诗新。","缕金歌眉举。","举眉歌金缕。","人妒月圆频。","频圆月妒人。"]},{"id":"c59-532","title":"虞美人·黄金柳嫩摇丝软","rhythmic":"虞美人","author":"王齐愈","authorSlug":"王齐愈","dynasty":"宋","kind":"ci","paragraphs":["黄金柳嫩摇丝软。","永日堂堂掩。","卷帘飞燕未归来。","客去醉眠敧枕、殢残杯。","眉山浅拂青螺黛。","整整垂双带。","水沈香熨窄衫轻。","莹玉碧溪春溜、眼波横。"]},{"id":"c59-533","title":"望江南・忆江南·居下位","rhythmic":"望江南・忆江南","author":"王齐叟","authorSlug":"王齐叟","dynasty":"宋","kind":"ci","paragraphs":["居下位，常恐被人谗。","只是曾填青玉案，何曾敢作望江南。","请问马都监。"]},{"id":"c59-534","title":"失调名·蹙绣圈金","rhythmic":"失调名","author":"王齐叟","authorSlug":"王齐叟","dynasty":"宋","kind":"ci","paragraphs":["蹙绣圈金，槃囊密约，未赴意先警。","欲罢还休，临行又怯，倚定画栏痴等。","帘风渐冷。","先自虑、春宵不永。","更那堪、斗转星移，尚在有无之境。","绿云满压蝤蛴领。","惭愧也、满怀香拥。","此际有谁知证。","但楼前明月，窗间花影。"]},{"id":"c59-535","title":"点绛唇·独自临池","rhythmic":"点绛唇","author":"舒氏","authorSlug":"舒氏","dynasty":"宋","kind":"ci","paragraphs":["独自临池，闷来强把阑干凭。","旧愁新恨。","耗却年时兴。","鹭散鱼潜，烟敛风初定。","波心静。","照人如镜。","少个年时影。"]},{"id":"c59-536","title":"满庭芳·山抹微云","rhythmic":"满庭芳","author":"琴操","authorSlug":"琴操","dynasty":"宋","kind":"ci","paragraphs":["山抹微云，天连衰草，画角声断斜阳。","暂停征辔，聊共饮离觞。","多少蓬莱旧侣，频回首、烟霭茫茫。","孤村里，寒鸦万点，流水绕红墙。","魂伤。","当此际，轻分罗带，暗解香囊。","谩赢得，青楼薄幸名狂。","此去何时见也，襟袖上、空有馀香。","伤心处，高城望断，灯火已昏黄。"]},{"id":"c59-537","title":"卜算子·欲整别离情","rhythmic":"卜算子","author":"琴操","authorSlug":"琴操","dynasty":"宋","kind":"ci","paragraphs":["欲整别离情，怯对尊中酒。","野梵幽幽石上飘，搴落楼头柳。","不系黄金绶。","粉黛愁成垢。","春风三月有时阑，遮不尽、梨花丑。"]},{"id":"c59-538","title":"临江仙·折柳门前鹦鹉绿","rhythmic":"临江仙","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["折柳门前鹦鹉绿，河梁小驻归船。","不堪华发对离筵。","孤村啼鴂日，深院落花天。","文采弟兄真叠玉，赤宵去路谁先。","明朝便恐各风烟。","江山如有恨，桃李自无言。"]},{"id":"c59-539","title":"点绛唇·紫雾香浓","rhythmic":"点绛唇","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["紫雾香浓，岁华风转花随辇。","洞天云暖。","一片笙歌远。","水殿龙舟，忆侍瑶池宴。","闲庭院。","梦回春半。","雪鬓无人见。"]},{"id":"c59-540","title":"散天花·云断长空叶落秋","rhythmic":"散天花","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["云断长空叶落秋。","寒江烟浪静，月随舟。","西风偏解送离愁。","声声南去雁，下汀洲。","无奈多情去复留。","骊歌齐唱罢，泪争流。","悠悠别恨几时休。","不堪残酒醒，凭危楼。"]},{"id":"c59-541","title":"醉花阴·露芽初破云腴细","rhythmic":"醉花阴","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["露芽初破云腴细。","玉纤纤亲试。","香雪透金瓶，无限仙风，月下人微醉。","相如消渴无佳思。","了知君此意。","不信老卢郎，花底春寒，赢得空无睡。"]},{"id":"c59-542","title":"醉花阴·月幌风帘香一阵","rhythmic":"醉花阴","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["月幌风帘香一阵。","正千山雪尽。","冷对酒尊傍，无语含情，别是江南信。","寿阳妆罢人微困。","更玉钗斜衬。","拟插一枝归，只恐风流，羞上潘郎鬓。"]},{"id":"c59-543","title":"虞美人·芙蓉落尽天涵水","rhythmic":"虞美人","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["芙蓉落尽天涵水。","日暮沧波起。","背飞双燕帖云寒。","独向小楼东畔、倚阑看。","浮生只合尊前老。","雪满长安道。","故人早晚上高台。","赠我江南春色、一枝梅。"]},{"id":"c59-544","title":"虞美人·酒边陡觉罗衣暖","rhythmic":"虞美人","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["酒边陡觉罗衣暖。","独倚黄昏看。","寒鸦两两下楼东。","著处暗云垂地、一重重。","红炉欢坐谁能醉。","多少看花意。","谢娘也拟殢春风。","便道无端柳絮、逼帘栊。"]},{"id":"c59-545","title":"虞美人·重帘小阁香云暖","rhythmic":"虞美人","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["重帘小阁香云暖。","黛拂梳妆浅。","玉箫一曲杜韦娘。","谁是苏州刺史、断人肠。","醉归旋拨红炉火。","却倚屏山坐。","银缸明灭月横斜。","还是画楼角送、小梅花。"]},{"id":"c59-546","title":"丑奴儿・采桑子·一池秋水疏星动","rhythmic":"丑奴儿・采桑子","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["一池秋水疏星动，寒影横斜。","满坐风花。","红烛纷纷透绛纱。","江湖散诞扁舟里，到处如家。","且尽流霞。","莫管年来两鬓华。"]},{"id":"c59-547","title":"一落索·正是看花天气","rhythmic":"一落索","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["正是看花天气。","为春一醉。","醉来却不带花归，诮不解、看花意。","试问此花明媚。","将花谁比。","只应花好似年年，花不似、人憔悴。"]},{"id":"c59-548","title":"一落索·叶底枝头红小","rhythmic":"一落索","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["叶底枝头红小。","天然窈窕。","后园桃李谩成蹊，问占得、春多少。","不管雪消霜晓。","朱颜长好。","年年若许醉花间，待拼了、花间老。"]},{"id":"c59-549","title":"满庭芳·寒日穿帘","rhythmic":"满庭芳","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["寒日穿帘，澄江凭槛，练光浮动馀霞。","蓼汀芦岸，黄叶衬孤花。","天外征帆隐隐，残云共、流水无涯。","登临处，琼枝潋滟，风帽醉敧斜。","丰年，时节好，玉香田舍，酒满渔家。","算浮世劳生，事事输他。","便恁从今酩酊，休更问、白雪笼纱。","还须仗，神仙妙手，传向画图夸。"]},{"id":"c59-550","title":"满庭芳·红叶飘零","rhythmic":"满庭芳","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["红叶飘零，寒烟疏淡，楼台半在云间。","望中风景，图画也应难。","又是重阳过了，东篱下、黄菊阑珊。","陶潜病，风流载酒，秋意与人闲。","霞冠。","敧倒处，瑶台唱罢，如梦中还。","但醉里赢得，满眼青山。","华发看看满也，留不住、当日朱颜。","平生事，从头话了，独自却凭栏。"]},{"id":"c59-551","title":"满庭芳·阊阖天门","rhythmic":"满庭芳","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["阊阖天门，芙蓉春殿，几年目断鸡翘。","短蓬秋鬓，端幸倚琼瑶。","南圃花边小院，西湖畔、云低双桥。","归时节，红香露冷，月影上芭蕉。","明朝。","那可望，旗亭烟草，柳渡寒潮。","但万户千门，恨客歌樵。","戏彩光浮衮绣，听鸣珂、响逼云宵。","应回首，绮裘醉客，还是独吹箫。"]},{"id":"c59-552","title":"卜算子·池台小雨乾","rhythmic":"卜算子","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["池台小雨乾，门巷香轮少。","谁把青钱衬落红，满地无人扫。","何时斗草归，几度寻花了。","留得佳人莲步痕，宫样鞋儿小。"]},{"id":"c59-553","title":"菩萨蛮·三年江上风吹泪","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["三年江上风吹泪。","夭桃艳杏无春意。","今日欲开眉。","那堪更别离。","莫折长亭柳。","折尽愁依旧。","只有醉如狂。","人生空断肠。"]},{"id":"c59-554","title":"菩萨蛮·柳桥花坞南城陌","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["柳桥花坞南城陌。","朱颜绿发长安路。","雨后小池台。","寻常载酒来。","马头今日路。","却望城西去。","斜日下汀洲。","断云和泪流。"]},{"id":"c59-555","title":"菩萨蛮·画船槌鼓催君去","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["画船槌鼓催君去。","高楼把酒留君住。","去住若为情。","西江潮欲平。","江潮容易得。","只是人南北。","今日此尊空。","知君何日同。"]},{"id":"c59-556","title":"菩萨蛮·画檐细雨偏红烛","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["画檐细雨偏红烛。","疏星冷落排寒玉。","赌得碧云篇。","金波更涉船。","樽前当日客。","行色垂杨陌。","天阔水悠悠。","含情独倚楼。"]},{"id":"c59-557","title":"菩萨蛮·杜鹃啼破江南月","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["杜鹃啼破江南月。","香风扑面吹红雪。","赋就缕金笺。","黄昏醉上船。","年华爽短鬓。","事往情何尽。","明日各天涯。","来春空好花。"]},{"id":"c59-558","title":"菩萨蛮·朱帘乍卷层烟起","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["朱帘乍卷层烟起。","露华深浅初疑洗。","困倚玉阑风。","绮罗知几重。","向人如有意。","不醉何时醉。","便得一枝红。","犹胜两鬓空。"]},{"id":"c59-559","title":"菩萨蛮·小池山额垂螺碧","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["小池山额垂螺碧。","绿红香里眠鸂鶒。","波面翠云开。","仙槎天上来。","吹将红日落。","懊恼严城角。","风月此时情。","知君华发生。"]},{"id":"c59-560","title":"菩萨蛮·一回别后一回老","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["一回别后一回老。","别离易得相逢少。","莫问故园花。","长安君是家。","短亭秋日晚。","草色随人远。","欲醉又还醒。","江楼暮角声。"]},{"id":"c59-561","title":"菩萨蛮·樽前休话人生事","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["樽前休话人生事。","人生只合樽前醉。","金盏大如船。","江城风雪天。","绮窗灯自语。","一夜芭蕉雨。","玉漏为谁长。","枕衾残酒香。"]},{"id":"c59-562","title":"菩萨蛮·楼前流水西江道","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["楼前流水西江道。","江头水落芙蓉老。","画鼓叠凉波。","凭栏颦翠娥。","当年金马客。","青鬓芦花色。","把酒感秋蓬。","骊歌半醉中。"]},{"id":"c59-563","title":"菩萨蛮·绮栊深闭桃园曲","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["绮栊深闭桃园曲。","刘郎老向花间宿。","笑脸抹流霞。","心知是小琶。","纤纤垂素玉。","掠鬓春云绿。","弹了醉思仙。","小窗红日偏。"]},{"id":"c59-564","title":"菩萨蛮·真珠酒滴琵琶送","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["真珠酒滴琵琶送。","行云旧识巫山梦。","空得醉中归。","老来心事非。","江梅含日暖。","照水花枝短。","密叶似商量。","向人春意长。"]},{"id":"c59-565","title":"菩萨蛮·小亭露厌风枝动","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["小亭露厌风枝动。","鹊炉火冷金瓶冻。","悄悄对西窗。","瘦知罗带长。","欲眠思殢酒。","坐听寒更久。","无赖是青灯。","开花故故明。"]},{"id":"c59-566","title":"菩萨蛮·流年又见风沙送","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["流年又见风沙送。","钧天回首清都梦。","塞雁几时归。","镜中双鬓非。","绿袍同冷暖。","谁道交情短。","愁斛若为量。","还随一线长。"]},{"id":"c59-567","title":"菩萨蛮·白苹洲渚垂杨岸","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["白苹洲渚垂杨岸。","藕花未放青蒲短。","斜日画船归。","背人双鹭飞。","醉眠金马客。","不道风尘隔。","红影上窗纱。","小庭空落花。"]},{"id":"c59-568","title":"菩萨蛮·金船满引人微醉","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["金船满引人微醉。","红绡笼烛崔归骑。","香泛雪盈杯。","云龙疑梦回。","不辞风满腋。","旧是仙家客。","坐得夜无眠。","南窗衾枕寒。"]},{"id":"c59-569","title":"菩萨蛮·江梅未放枝头结","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["江梅未放枝头结。","江楼已见山头雪。","待得此花开。","知君来不来。","风帆双画鹢。","小雨随行色。","空得郁金裙。","酒痕和泪痕。"]},{"id":"c59-570","title":"菩萨蛮·香波绿暖浮鹦鹉","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["香波绿暖浮鹦鹉。","黄金捍拨么弦语。","小雨落梧桐。","帘栊残烛红。","人生闲亦好。","双鬓催人老。","莫惜醉中归。","醒来思醉时。"]},{"id":"c59-571","title":"菩萨蛮·绿窗酒醒春如梦","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["绿窗酒醒春如梦。","小池犹见红云动。","露湿井干桐。","翠阴生细风。","雨过芳塘净。","清昼闲中永。","门外立双旌。","隔花闻笑声。"]},{"id":"c59-572","title":"菩萨蛮·忆曾把酒赏红翠","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["忆曾把酒赏红翠。","舞腰柳弱歌声细。","纵马杏园西。","归来香满衣。","宝车空犊驻。","事逐孤鸿去。","搔首立江干。","春萝挂暮山。"]},{"id":"c59-573","title":"蝶恋花·雪后江城红日晚","rhythmic":"蝶恋花","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["雪后江城红日晚。","暖入香梢，渐觉玲珑满。","仿佛临风妆半面。","冰帘斜卷谁庭院。","折向樽前君细看。","便是江南，寄我人还远。","手把此枝多少怨。","小楼横笛吹肠断。"]},{"id":"c59-574","title":"蝶恋花·深炷熏炉扃小院","rhythmic":"蝶恋花","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["深炷熏炉扃小院。","手拈黄花，尚觉金犹浅。","回首画堂双语燕。","无情渐渐看人远。","相见争如初不见。","短鬓潘郎，斗觉年华换。","最是西风吹不断。","心头往事歌中怨。"]},{"id":"c59-575","title":"减字木兰花·眉山敛额","rhythmic":"减字木兰花","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["眉山敛额。","往事追思空手拍。","雁字频飞。","生怕人来说著伊。","闲抛绣履。","愁殢香衾浑不起。","莫似扬州。","只作寻常薄幸休。"]},{"id":"c59-576","title":"减字木兰花·碎红如绣","rhythmic":"减字木兰花","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["碎红如绣。","摇曳东风垂彩绶。","拟倩柔条。","约住佳人细柳腰。","蜀江春绿。","争似枝头能结束。","纤手攀时。","欲绾同心寄与谁。"]},{"id":"c59-577","title":"木兰花·十二阑干褰画箔","rhythmic":"木兰花","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["十二阑干褰画箔。","取次穿花成小酌。","彩鸾舞罢凤孤飞，回首东风空院落。","杳杳桃源仙路邈。","晴日晓窗红薄薄。","伤春还是懒梳妆，想见绿云垂鬓脚。"]},{"id":"c59-578","title":"木兰花·金丝络马青钱路","rhythmic":"木兰花","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["金丝络马青钱路。","笑指玉皇香案去。","点衣柳陌堕残红，拂面风桥吹细雨。","晓钗压鬓头慵举。","恨里歌声兼别苦。","西湖一顷白菱花，惆怅行云无觅处。"]},{"id":"c59-579","title":"木兰花·琉璃一片春湖面","rhythmic":"木兰花","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["琉璃一片春湖面。","画舫游人帘外见。","水边风嫩柳低眠，花底雨乾莺细啭。","秋千寂寂垂杨岸。","芳草绿随人渐远。","一番乐事又将离。","金盏莫辞红袖劝。"]},{"id":"c59-580","title":"浣溪沙·燕外青楼已禁烟","rhythmic":"浣溪沙","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["燕外青楼已禁烟。","小寒犹自薄胜绵。","画桥红日下秋千。","惟有樽前芳意在，应须沈醉倒花前。","绿窗还是五更天。"]},{"id":"c59-581","title":"浣溪沙·金缕歌残红烛稀","rhythmic":"浣溪沙","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["金缕歌残红烛稀。","梁州舞罢小鬟垂。","酒醒还是独归时。","画栋日高来语燕，绮窗风暖度游丝。","几多落叶上青枝。"]},{"id":"c59-582","title":"浣溪沙·黑白纷纷小战争","rhythmic":"浣溪沙","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["黑白纷纷小战争。","几人心手斗纵横。","谁知胜处本无情。","谢傅老来思别墅，杜郎闲去忆鏖兵。","何妨谈笑下辽城。"]},{"id":"c59-583","title":"浣溪沙·雨洗秋空斜日红","rhythmic":"浣溪沙","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["雨洗秋空斜日红。","青葱瑶辔玉玲珑。","好风吹起□江东。","且尽红裙歌一曲，莫辞白酒饮千锺。","人生半在别离中。"]},{"id":"c59-584","title":"浣溪沙·白鹭飞飞点碧塘","rhythmic":"浣溪沙","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["白鹭飞飞点碧塘。","雨荷风卷绿罗裳。","管弦竟奏杂鱼榔。","游女谩能歌白纻，使君不学野鸳鸯。","桃花空解误刘郎。"]},{"id":"c59-585","title":"鹊桥仙·教来歌舞","rhythmic":"鹊桥仙","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["教来歌舞，接成桃李。","尽是使君指似。","如今装就满城春，忍便拥、双旌归去。","莺心巧啭，花心争吐。","无计可留君住。","两堤芳草一江云，早晚是、西楼望处。"]},{"id":"c59-586","title":"菩萨蛮·疏英乍蕾馀寒浅","rhythmic":"菩萨蛮","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["疏英乍蕾馀寒浅。","蹋枝小鹊娇犹颤。","谩炷水沈香。","帘波不是湘。","清愁支酒力。","畏听江城笛。","恁忍说华年。","垂垂欲暮天。"]},{"id":"c59-587","title":"好事近·箫鼓却微寒","rhythmic":"好事近","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["箫鼓却微寒，犹是芳菲时节。","分付塞鸿归后，剩一钩寒月。","双垂锦幄谢残枝，馀香恋衣结。","又被鸟声呼醒，似征鞍催发。"]},{"id":"c59-588","title":"失调名·十年马上春如梦","rhythmic":"失调名","author":"舒亶","authorSlug":"舒亶","dynasty":"宋","kind":"ci","paragraphs":["十年马上春如梦。"]},{"id":"c59-589","title":"导引·思齐文母","rhythmic":"导引","author":"范祖禹","authorSlug":"范祖禹","dynasty":"宋","kind":"ci","paragraphs":["思齐文母，盛烈对皇天。","演宝祚千年。","卿云复旦治功全。","厌人世登仙。","龙舆忽掩三川。","彩仗属车旋。","维清象舞告英宣。","入诗颂歌弦。"]},{"id":"c59-590","title":"六州·太平功","rhythmic":"六州","author":"范祖禹","authorSlug":"范祖禹","dynasty":"宋","kind":"ci","paragraphs":["太平功。","拥佑帝尧聪。","歌九德，偃五戎。","寰海被祥风。","车书万里文轨同。","自南北西东。","耕田凿井，戏垂髫华发，跻仁寿域变时雍。","大明方天中。","弃养东朝苦匆匆。","玉座如存，永隔慈容。","恨难穷。","崇庆空。","飙轮仙驭无踪。","超宇宙，驾云龙。","褘翟掩轩宫。","柏城王气长郁葱。","温洛照寒崧。","光灵在上，徽音流千古，昭如日月丽层穹。","太任家邦隆。","彤史青编永垂鸿。","清庙笙镛。","奏假钦崇。"]},{"id":"c59-591","title":"十二时・忆少年·转招摇","rhythmic":"十二时・忆少年","author":"范祖禹","authorSlug":"范祖禹","dynasty":"宋","kind":"ci","paragraphs":["转招摇。","厚陵回望，双阙起岧嶢。","晓日丽谯。","金爵上干霄。","风雨阕，夜宫闭，不重朝。","奉鸾镳渐遥。","玉京知何处，飞英衔恤，乱絮缠悲，春路迢迢。","缥缈哀音，发龙笳凤箫。","光景同，惨淡度岩邑，指河桥。","马萧萧。","络绎星轺。","拂天容卫，江海上寒潮。","万国魂销。","追昔御东朝。","开钿扇，垂珠箔，侍珰貂。","宝香烧。","散飘。","开仁寿域，神孙高拱，昆仑渤澥，玉烛方调。","一旦宫车晚，旋归泬寥。","九载初，如梦次，功得琼瑶。"]},{"id":"c59-592","title":"虞神歌·驾玉龙","rhythmic":"虞神歌","author":"范祖禹","authorSlug":"范祖禹","dynasty":"宋","kind":"ci","paragraphs":["驾玉龙。","设初虞祭终。","前旌举，天回洛水，路转崧峰。","瞻寥廓，烟霏冲融。","窅无踪。","震地鼓吹悲雄。","谁何羽卫重。","拂云旗帜眩青红。","来渐东。","清尘洒道，修职百神恭。","回首苍茫醅雾雨吹风。","掩泉宫。","□□□□□□□□□寰畿入，山川改容。","鼓钟临近次，千官望拜，涕泪衡从。","人如堵，晨光葱茏。","阙穹隆。","驰道禁水相通。","当年游幸空。","皇仪事毕泣重瞳。","哀未穷。","巍巍馀烈，辉映简编中。","亿万斯年，覆载同功。"]},{"id":"c59-593","title":"导引·延和幄座","rhythmic":"导引","author":"范祖禹","authorSlug":"范祖禹","dynasty":"宋","kind":"ci","paragraphs":["延和幄座，临御九年中。","往事已成空。","皇基固覆盂四海，本自太任功。","九虞初毕下西宫。","庙祏与天崇。","周家盛，卜年卜世，万祀永无穷。"]},{"id":"c59-594","title":"千秋岁·春风湖外","rhythmic":"千秋岁","author":"孔平仲","authorSlug":"孔平仲","dynasty":"宋","kind":"ci","paragraphs":["春风湖外。","红杏花初退。","孤馆静，愁肠碎。","泪馀痕在枕，别久香销带。","新睡起。","小园戏蝶飞成对。","惆怅人谁会。","随处聊倾盖。","情暂遣，心何在。","锦书消息断，玉漏花阴改。","迟日暮，仙山杳杳空云海。"]},{"id":"c59-595","title":"满庭芳·鳞甲何多","rhythmic":"满庭芳","author":"了元","authorSlug":"了元","dynasty":"宋","kind":"ci","paragraphs":["鳞甲何多，羽毛无数，悟来佛性皆同。","世人何事，刚爱口头浓。","痛把群生割剖，刀头转、鲜血飞红。","□□□，零炮碎炙，不忍见渠侬。","喉咙。","才咽罢，龙肝凤髓，毕竟无踪。","谩赢得、生前夭寿多凶。","奉劝世人省悟，休恣意、激恼阎翁。","轮回转，本来面目，改换片时中。"]},{"id":"c59-596","title":"极相思令・极相思·柳烟霁色方春","rhythmic":"极相思令・极相思","author":"太尉夫人","authorSlug":"太尉夫人","dynasty":"宋","kind":"ci","paragraphs":["柳烟霁色方春。","花露逼金茎。","秋千院落，海棠渐老，才过清明。","嫩玉腕托香脂脸，相傅粉、更与谁情。","秋波绽处，相思泪迸，天阻深诚。"]},{"id":"c59-597","title":"醉翁操·冷冷潺潺","rhythmic":"醉翁操","author":"郭祥正","authorSlug":"郭祥正","dynasty":"宋","kind":"ci","paragraphs":["冷冷潺潺。","寒泉。","泻云间。","如弹。","醉翁洗心逃区寰。","自期猿鹤俱闲。","情未阑。","日暮造深原。","异芳谁与搴。","忘还。","琼楼玉阙，归去何年。","遗风馀思，犹有猿吟鹤怨。","花落溪边。","萧然。","莺语林中清圆。","空山。","春又残。","客怀文章仙。","度曲响涓涓。","清商回徵星斗寒。"]},{"id":"c59-598","title":"望江南・忆江南·缥缈烟中渔父桨","rhythmic":"望江南・忆江南","author":"董","authorSlug":"董","dynasty":"宋","kind":"ci","paragraphs":["缥缈烟中渔父桨，坡陀山上使君衙。"]},{"id":"c59-599","title":"望江南・忆江南·六月凉窗凉衽袖","rhythmic":"望江南・忆江南","author":"董","authorSlug":"董","dynasty":"宋","kind":"ci","paragraphs":["六月凉窗凉衽袖，二苏辞翰照青冥。"]}]