{"代宗":{"slug":"代宗","name":"代宗","dynasty":"唐","style":"","life":"","origin":"","seal":"代","bio":[],"works":[{"id":"t48-162","title":"梦黄衣童子歌","kind":"诗"}]},"刘夷道":{"slug":"刘夷道","name":"刘夷道","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"t42-938","title":"伤死奴","kind":"诗"}]},"刘戬":{"slug":"刘戬","name":"刘戬","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"t42-936","title":"夏弹琴","kind":"诗"}]},"客户里女子":{"slug":"客户里女子","name":"客户里女子","dynasty":"唐","style":"","life":"","origin":"","seal":"客","bio":[],"works":[{"id":"t48-32","title":"赠段何","kind":"诗"}]},"张众甫":{"slug":"张众甫","name":"张众甫","dynasty":"唐","style":"字子初","life":"","origin":"","seal":"张","bio":["张众甫，字子初，清河人。河南寿安县尉，罢秩，侨居云阳，后拜监察御史，为淮宁军从事。诗三首。"],"works":[{"id":"t14-714","title":"寄兴国池鹤上刘相公","kind":"诗"},{"id":"t14-715","title":"送李司直使吴","kind":"诗"},{"id":"t14-716","title":"送李观之宣州谒袁中丞赋得三州渡","kind":"诗"}]},"张光朝":{"slug":"张光朝","name":"张光朝","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张光朝，元和时人。诗二首。"],"works":[{"id":"t27-214","title":"荻塘西庄赠房元垂","kind":"诗"},{"id":"t27-215","title":"天门街西观荣王聘妃","kind":"诗"}]},"张敬忠":{"slug":"张敬忠","name":"张敬忠","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张敬忠，官监察御史，以文吏著称，张仁亶在朔方，奏判军事。开元中，为平卢节应使。诗二首。"],"works":[{"id":"t4-122","title":"边词","kind":"诗"},{"id":"t4-123","title":"戏咏","kind":"诗"},{"id":"t48-238","title":"咏王主敬","kind":"诗"}]},"本净":{"slug":"本净","name":"本净","dynasty":"唐","style":"","life":"","origin":"","seal":"本","bio":["本净，俗姓张，绛州人。幼入曹溪，后住司空山无相寺。天宝三年，玄宗遣中使入山礼问，召赴京，与两街名僧共论佛理。","上元三年卒，年九十五。诗七首。（《全唐诗》无本净诗）"],"works":[{"id":"t52-893","title":"四大无主偈","kind":"诗"},{"id":"t52-894","title":"见闻觉知偈","kind":"诗"},{"id":"t52-895","title":"无修偈","kind":"诗"},{"id":"t52-896","title":"背道逐教偈","kind":"诗"},{"id":"t52-897","title":"真妄偈","kind":"诗"},{"id":"t52-898","title":"善恶二根不实偈","kind":"诗"},{"id":"t52-899","title":"来往如梦偈","kind":"诗"}]},"朱用之":{"slug":"朱用之","name":"朱用之","dynasty":"宋","style":"","life":"","origin":"","seal":"朱","bio":[],"works":[{"id":"c70-859","title":"意难忘·宫额涂黄","kind":"词"}]},"林滋":{"slug":"林滋","name":"林滋","dynasty":"唐","style":"字后象","life":"","origin":"","seal":"林","bio":["林滋，字后象，闽人。会昌三年进士第，与同年詹雄、郑𫍯齐名，时称雄诗、𫍯文、滋赋为闽中三绝。官终金部郎中。","诗六首。"],"works":[{"id":"t30-592","title":"望九华山","kind":"诗"},{"id":"t30-593","title":"春望","kind":"诗"},{"id":"t30-594","title":"蠡泽旅怀","kind":"诗"},{"id":"t30-595","title":"宴韦侍御新亭","kind":"诗"},{"id":"t30-596","title":"人日","kind":"诗"},{"id":"t30-597","title":"和主司王起","kind":"诗"}]},"沈颜":{"slug":"沈颜","name":"沈颜","dynasty":"唐","style":"字可铸","life":"","origin":"","seal":"沈","bio":["沈颜，字可铸，吴郡人。天复初，登进士第，授校书郎。入吴，仕至翰林学士、知制诰。","《陵阳集》五卷，今存诗二首。"],"works":[{"id":"t40-343","title":"题县令范传真化洽亭","kind":"诗"},{"id":"t40-344","title":"书怀寄友人","kind":"诗"}]},"王承旨":{"slug":"王承旨","name":"王承旨","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"t51-766","title":"咏后主出降（《后山诗话》以为花蕊夫人作，但前二句多异文）","kind":"诗"}]},"芮挺章":{"slug":"芮挺章","name":"芮挺章","dynasty":"唐","style":"","life":"","origin":"","seal":"芮","bio":["芮挺章，国子进士。天宝三年编《国秀集》，集中并载挺章诗二首。"],"works":[{"id":"t10-41","title":"江南弄","kind":"诗"},{"id":"t10-42","title":"少年行","kind":"诗"}]},"薛晏":{"slug":"薛晏","name":"薛晏","dynasty":"唐","style":"","life":"","origin":"","seal":"薛","bio":["晏，蒲州汾阴人。父江童，天宝间为陈留太守。晏仕至岭南推官。","诗三首。（《全唐诗》无薛晏诗，兹据《新唐书》卷七十三《宰相世系表》三下、劳格《郎官石柱题名考》卷六录其事迹。郑辕为大历九年进士，与晏时代正相合。","）"],"works":[{"id":"t52-973","title":"与郑辕崔全素游枋口同赋三韵诗（题拟） 蒙泉","kind":"诗"},{"id":"t52-974","title":"与郑辕崔全素游枋口同赋三韵诗（题拟） 薜荔壁","kind":"诗"},{"id":"t52-975","title":"与郑辕崔全素游枋口同赋三韵诗（题拟） 石笋高","kind":"诗"}]},"裴澈":{"slug":"裴澈","name":"裴澈","dynasty":"唐","style":"","life":"","origin":"","seal":"裴","bio":["裴澈，登咸通进士第。僖宗朝，拜相，以拥立伪煴诛。诗一首。"],"works":[{"id":"t33-350","title":"吊孟昌图","kind":"诗"}]},"郑仅":{"slug":"郑仅","name":"郑仅","dynasty":"宋","style":"","life":"","origin":"","seal":"郑","bio":[],"works":[{"id":"c61-299","title":"调笑转踏・调笑令·归去","kind":"词"},{"id":"c61-300","title":"调笑转踏・调笑令·双桨","kind":"词"},{"id":"c61-301","title":"调笑转踏・调笑令·草草","k