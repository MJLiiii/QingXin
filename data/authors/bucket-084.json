36","title":"霜天晓角·冰清霜洁","kind":"词"},{"id":"c57-637","title":"瑞鹧鸪·众芳摇落独鲜妍","kind":"词"}]},"潘纬":{"slug":"潘纬","name":"潘纬","dynasty":"唐","style":"","life":"","origin":"","seal":"潘","bio":["潘纬，湘南人，登咸通进士第。诗二首。"],"works":[{"id":"t33-360","title":"中秋月","kind":"诗"},{"id":"t33-361","title":"琴","kind":"诗"},{"id":"t33-362","title":"句","kind":"诗"}]},"玄奘":{"slug":"玄奘","name":"玄奘","dynasty":"唐","style":"","life":"","origin":"","seal":"玄","bio":["玄奘，俗姓陈，名祎，洛州缑氏人。十三岁出家，历住成都、荆州、赵州、长安等地。贞观三年西行求法，历游天竺各地，历十七年始还。","后住长安译出经籍一千三百余卷。麟德元年二月病逝，年六十五。诗五首。","（《全唐诗》无玄奘诗，事迹据《大慈恩寺三藏法师传》，参《中国佛教》第二册游侠文。）"],"works":[{"id":"t52-137","title":"题西天舍眼塔（在西天）","kind":"诗"},{"id":"t52-138","title":"题尼莲河七言","kind":"诗"},{"id":"t52-139","title":"题半偈舍身山（在西天）","kind":"诗"},{"id":"t52-140","title":"题童子寺五言（在太原□□北京）","kind":"诗"},{"id":"t52-141","title":"题中岳山七言（在京南）","kind":"诗"}]},"田澄":{"slug":"田澄","name":"田澄","dynasty":"唐","style":"","life":"","origin":"","seal":"田","bio":["田澄，天宝时官献纳使、起居舍人，杜甫尝有诗赠之。诗一首。"],"works":[{"id":"t13-444","title":"成都为客作","kind":"诗"}]},"程正同":{"slug":"程正同","name":"程正同","dynasty":"宋","style":"","life":"","origin":"","seal":"程","bio":[],"works":[{"id":"c72-457","title":"贺新郎·久矣无循吏","kind":"词"},{"id":"c72-458","title":"沁园春·富敌陶猗","kind":"词"},{"id":"c72-459","title":"满庭芳·五柳先生","kind":"词"},{"id":"c72-460","title":"思越人・朝天子·曾把隋珠抵鹊来","kind":"词"},{"id":"c72-461","title":"朝中措·少年不入利名场","kind":"词"}]},"詹敦仁":{"slug":"詹敦仁","name":"詹敦仁","dynasty":"唐","style":"字君泽","life":"","origin":"","seal":"詹","bio":["詹敦仁，字君泽，固始人。初隐仙游，后为清溪令。诗六首。","詹敦仁字君泽，固始人。补诗四首。"],"works":[{"id":"t42-540","title":"复留侯从効问南汉刘岩改名䶮字音义","kind":"诗"},{"id":"t42-541","title":"柳堤诗","kind":"诗"},{"id":"t42-542","title":"劝王氏入贡宠予以官作辞命篇","kind":"诗"},{"id":"t42-543","title":"余迁泉山城留侯招游郡圃作此","kind":"诗"},{"id":"t42-544","title":"留侯受南唐节度使知郡事辟予为属以诗谢之","kind":"诗"},{"id":"t42-545","title":"遣子访刘乙","kind":"诗"},{"id":"t50-999","title":"寄刘乙处士","kind":"诗"},{"id":"t51-0","title":"琲访刘君乙时已殁故将归王令留之不可以书来嘱作此篇示","kind":"诗"},{"id":"t51-1","title":"入局吟","kind":"诗"},{"id":"t51-2",