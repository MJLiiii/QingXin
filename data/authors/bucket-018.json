{"张氲":{"slug":"张氲","name":"张氲","dynasty":"唐","style":"字藏真 · 号洪崖子","life":"","origin":"","seal":"张","bio":["张氲，一名蕴，字藏真，晋州人。神情秀逸翛闲，学道不娶，尝寓李峤家十余年，栖息洪崖古坛，自号洪崖子，天后及明皇朝屡召不赴。诗三首。"],"works":[{"id":"t47-248","title":"醉吟三首 一","kind":"诗"},{"id":"t47-249","title":"醉吟三首 二","kind":"诗"},{"id":"t47-250","title":"醉吟三首 三","kind":"诗"}]},"张生1":{"slug":"张生1","name":"张生1","dynasty":"宋","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"c62-956","title":"雨中花慢·事往人离","kind":"词"}]},"张贲":{"slug":"张贲","name":"张贲","dynasty":"唐","style":"字润卿","life":"","origin":"","seal":"张","bio":["张贲，字润卿，南阳人，登大中进士第。唐末为广文博士，尝隐于茅山，后寓吴中，与皮陆游，诗十六首。"],"works":[{"id":"t34-742","title":"旅泊吴门","kind":"诗"},{"id":"t34-743","title":"贲中间有吴门旅泊之什蒙鲁望垂和更作一章以伸詶谢","kind":"诗"},{"id":"t34-744","title":"酬袭美先见寄倒来韵","kind":"诗"},{"id":"t34-745","title":"奉和袭美醉中即席见赠次韵","kind":"诗"},{"id":"t34-746","title":"奉和袭美题褚家林亭","kind":"诗"},{"id":"t34-747","title":"奉和袭美伤开元观顾道士","kind":"诗"},{"id":"t34-748","title":"和鲁望白菊","kind":"诗"},{"id":"t34-749","title":"奉和袭美先辈悼鹤","kind":"诗"},{"id":"t34-750","title":"偶约道流终乖文会荅皮陆","kind":"诗"},{"id":"t34-751","title":"和袭美寒夜见访","kind":"诗"},{"id":"t34-752","title":"和袭美醉中先起次韵","kind":"诗"},{"id":"t34-753","title":"和皮陆酒病偶作","kind":"诗"},{"id":"t34-754","title":"送浙东德师侍御罢府西归","kind":"诗"},{"id":"t34-755","title":"以青䭀饭分送袭美鲁望因成一绝","kind":"诗"},{"id":"t34-756","title":"玩金㶉鶒和陆鲁望","kind":"诗"},{"id":"t34-757","title":"悼鹤和袭美","kind":"诗"},{"id":"t54-163","title":"题招提院静照堂","kind":"诗"},{"id":"t54-164","title":"清弋江田舍","kind":"诗"}]},"景审":{"slug":"景审","name":"景审","dynasty":"唐","style":"","life":"","origin":"","seal":"景","bio":["景审，南阳人，长庆中有善书名。诗一首。"],"works":[{"id":"t27-361","title":"题所书黄庭经后","kind":"诗"},{"id":"t27-362","title":"句","kind":"诗"}]},"李冠":{"slug":"李冠","name":"李冠","dynasty":"宋","style":"字世英","life":"","origin":"历城（今山东济南）","seal":"李","bio":["--字世英，历城 (今山东济南) 人。以文学著称，与王樵、贾同齐名。官乾宁主簿。","有《东皋集》，不传。存词五首。"],"works":[{"id":"c58-181","title":"蝶恋花·遥夜亭皋闲信步","kind":"词"},{"id":"c58-182","title":"六州歌头·凄凉绣岭","kind":"词"},{"id":"c58-183","title":"六州歌头·秦亡草昧","kind":"词"},{"id":"c58-184","title":"蝶恋花·贴鬓香云双绾绿","kind":"词"},{"id":"c58-185","title":"千秋万岁・千秋岁引·杏花好","kind":"词"}]},"李暠":{"slug":"李暠","name":"李暠","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李暠，清河王孝节孙。开元初汝州刺史，入为太常少卿，三迁黄门侍郎，兼太原尹，仍充诸军节度使，俄拜工部尚书，东都留守。持节使吐蕃，既还，金城公主请定汉蕃界，树碑赤岭，以奉使称职，转兵部尚书，终太子少傅。","诗一首。"],"works":[{"id":"t5-377","title":"奉和圣制送张说上集贤学士赐宴","kind":"诗"}]},"欧阳瑾":{"slug":"欧阳瑾","name":"欧阳瑾","dynasty":"唐","style":"","life":"","origin":"","seal":"欧","bio":[],"works":[{"id":"t0-974","title":"横吹曲辞 折杨柳","kind":"诗"},{"id":"t43-173","title":"折杨柳","kind":"诗"}]},"江文蔚":{"slug":"江文蔚","name":"江文蔚","dynasty":"唐","style":"字君章","life":"","origin":"","seal":"江","bio":["文蔚，字君章，建安人。长兴二年进士。南奔仕吴，累迁比部员外郎、知制诰。","南唐初，改主客郎中、中书舍人。中主立，判太常卿事。保大初，迁御史中丞。","因事贬外，复入为翰林学士知贡举事。保大十年卒，年五十二。（《全唐诗》无江文蔚诗。","事迹据《十国春秋》卷二十五本传）"],"works":[{"id":"t55-358","title":"无题","kind":"诗"},{"id":"t55-359","title":"句","kind":"诗"}]},"萧静":{"slug":"萧静","name":"萧静","dynasty":"唐","style":"","life":"","origin":"","seal":"萧","bio":[],"works":[{"id":"t43-115","title":"三湘有怀","kind":"诗"}]},"詹景全":{"slug":"詹景全","name":"詹景全","dynasty":"唐","style":"","life":"","origin":"","seal":"詹","bio":["詹景全，时称詹四郎，商人。咸通、中和间，多次赴日，与日僧圆珍交厚，有诗唱和。中和四年，随日僧圆载赴日，船遇风倾覆而死。","诗二首。（《全唐诗》无詹景全诗）"],"works":[{"id":"t54-155","title":"次韵二首 一","kind":"诗"},{"id":"t54-156","title":"次韵二首 二","kind":"诗"}]},"许天正":{"slug":"许天正","name":"许天正","dynasty":"唐","style":"","life":"","origin":"","seal":"许","bio":["许天正，汝南人。为陈元光副使，博学能文，历宣威将军。诗一首。"],"works":[{"id":"t2-919","title":"和陈元光平潮寇诗","kind":"诗"}]},"谢太虚":{"slug":"谢太虚","name":"谢太虚","dynasty":"唐","style":"","life":"","origin":"","seal":"谢","bio":[],"works":[{"id":"t43-63","title":"杪秋洞庭怀王道士","kind":"诗"}]},"谢直":{"slug":"谢直","name":"谢直","dynasty":"宋","style":"","life":"","origin":"","seal":"谢","bio":[],"works":[{"id":"c70-741","title":"卜算子·双桨浪花平","kind":"词"}]},"赵崇霄":{"slug":"赵崇霄","name":"赵崇霄","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"c73-411","title":"东风第一枝·妒雪梅苏","kind":"词"}]},"郑师冉":{"slug":"郑师冉","name":"郑师冉","dynasty":"唐","style":"","life":"","origin":"","seal":"郑","bio":[],"works":[{"id":"t50-64","title":"句","kind":"诗"}]},"陆亘":{"slug":"陆亘","name":"陆亘","dynasty":"唐","style":"字景山","life":"","origin":"","seal":"陆","bio":["亘，字景山，苏州人。元和三年，策制科中第，补万年丞，再迁太常博士。自虞部员外郎出为邓州刺史，复入为户部郎中、秘书少监、太常少卿，历刺衮蔡虢苏四州，迁浙东观察使，徙宣歙观察使，大和八年九月卒，年七十一。","诗一首。（《全唐诗》无陆亘诗，传据《旧唐书》卷一六二、《新唐书》卷一五九本传）"],"works":[{"id":"t53-615","title":"无题","kind":"诗"},{"id":"t53-616","title":"游天衣寺","kind":"诗"}]},"韩绛":{"slug":"韩绛","name":"韩绛","dynasty":"宋","style":"","life":"","origin":"","seal":"韩","bio":[],"works":[{"id":"c58-607","title":"踏莎行·嵩峤云高","kind":"词"}]},"魏征":{"slug":"魏征","name":"魏征","dynasty":"唐","style":"字玄成","life":"","origin":"","seal":"魏","bio":["魏征，字玄成，魏州曲城人。少孤，落魄有大志，初为太子洗马。太宗即位，拜谏议大夫、秘书监，寻晋检校侍中，封郑国公，以疾辞职，拜特进，仍知门下省事。","征性谅直，知无不言，太宗或引至卧内，访天下事，尝以古名臣称之。校辑秘省群书，及撰齐、梁、陈、周、隋诸史，序论多出其手，卒谥文贞。集二十卷，今编诗一卷。"],"works":[{"id":"t0-449","title":"郊庙歌辞 五郊乐章 黄帝宫音","kind":"诗"},{"id":"t0-450","title":"郊庙歌辞 五郊乐章 黄帝宫音 肃和","kind":"诗"},{"id":"t0-451","title":"郊庙歌辞 五郊乐章 黄帝宫音 雍和","kind":"诗"},{"id":"t0-452","title":"郊庙歌辞 五郊乐章 黄帝宫音 舒和","kind":"诗"},{"id":"t0-453","title":"郊庙歌辞 五郊乐章 青帝角音","kind":"诗"},{"id":"t0-454","title":"郊庙歌辞 五郊乐章 青帝角音 肃和","kind":"诗"},{"id":"t0-455","title":"郊庙歌辞 五郊乐章 青帝角音 雍和","kind":"诗"},{"id":"t0-456","title":"郊庙歌辞 五郊乐章 青帝角音 舒和","kind":"诗"},{"id":"t0-457","title":"郊庙歌辞 五郊乐章 赤帝徵音","kind":"诗"},{"id":"t0-458","title":"郊庙歌辞 五郊乐章 赤帝徵音 肃和","kind":"诗"},{"id":"t0-459","title":"郊庙歌辞 五郊乐章 赤帝徵音 雍和","kind":"诗"},{"id":"t0-460","title":"郊庙歌辞 五郊乐章 赤帝徵音 舒和","kind":"诗"},{"id":"t0-461","title":"郊庙歌辞 五郊乐章 白帝商音","kind":"诗"},{"id":"t0-462","title":"郊庙歌辞 五郊乐章 白帝商音 肃和","kind":"诗"},{"id":"t0-463","title":"郊庙歌辞 五郊乐章 白帝商音 雍和","kind":"诗"},{"id":"t0-464","title":"郊庙歌辞 五郊乐章 白帝商音 舒和","kind":"诗"},{"id":"t0-465","title":"郊庙歌辞 五郊乐章 黑帝羽音","kind":"诗"},{"id":"t0-466","title":"郊庙歌辞 五郊乐章 黑帝羽音 肃和","kind":"诗"},{"id":"t0-467","title":"郊庙歌辞 五郊乐章 黑帝羽音 雍和","kind":"诗"},{"id":"t0-468","title":