  "notes": [
    {
      "term": "骄",
      "def": "指马高大健壮。"
    },
    {
      "term": "直",
      "def": "特地，故意。"
    },
    {
      "term": "拂",
      "def": "掠过。"
    },
    {
      "term": "五云车",
      "def": "传说中神仙的座驾。这里指代华美的车驾。"
    },
    {
      "term": "褰",
      "def": "提起，撩起。"
    },
    {
      "term": "遥指",
      "def": "有邀至其家之意。"
    },
    {
      "term": "红楼",
      "def": "一作青楼。"
    }
  ],
  "translation": [
    "我骑着高大健壮的良马踏步行走在落花上，手中的马鞭故意掠过华美的车驾。",
    "车中美人笑着撩起珠帘，遥遥指向前方红楼说那是我的家。"
  ],
