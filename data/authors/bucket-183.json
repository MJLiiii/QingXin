诗"},{"id":"t47-429","title":"偶题 二","kind":"诗"},{"id":"t47-430","title":"景福中作","kind":"诗"},{"id":"t47-431","title":"题中条静观","kind":"诗"}]},"陆贽":{"slug":"陆贽","name":"陆贽","dynasty":"唐","style":"字敬舆","life":"","origin":"","seal":"陆","bio":["陆贽，字敬舆，嘉兴人。登进士第，中博学宏词，调郑尉，罢归。复以书判拔萃补渭南尉。","德宗立，由监察御史召为翰林学士。贞元八年，拜中书侍郎同平章事。裴延龄搆之，贬忠州别驾。","顺宗立，召还，诏未至卒。赠兵部尚书，谥曰宣。集二十七卷，今存三首。"],"works":[{"id":"t15-538","title":"晓过南宫闻太常清乐","kind":"诗"},{"id":"t15-539","title":"禁中春松","kind":"诗"},{"id":"t15-540","title":"赋得御园芳草","kind":"诗"},{"id":"t15-541","title":"句","kind":"诗"},{"id":"t51-320","title":"句","kind":"诗"}]},"陆长源":{"slug":"陆长源","name":"陆长源","dynasty":"唐","style":"字泳之","life":"","origin":"","seal":"陆","bio":["陆长源，字泳之，海之孙也，历汝州刺史。贞元中，为宣武节度司马，总留后事，军乱，遇害。诗三首。"],"works":[{"id":"t1-937","title":"杂曲歌辞 乐府","kind":"诗"},{"id":"t14-710","title":"乐府荅孟东野戏赠","kind":"诗"},{"id":"t14-711","title":"詶孟十二新居见寄","kind":"诗"},{"id":"t14-712","title":"荅东野夷门雪","kind":"诗"},{"id":"t14-713","title":"句","kind":"诗"}]},"陈三聘":{"slug":"陈三聘","name":"陈三聘","dynasty":"宋","style":"","life":"","origin":"","seal":"陈","bio":[],"works":[{"id":"c69-490","title":"满江红·薄日轻云","kind":"词"},{"id":"c69-491","title":"满江红·天岂无情","kind":"词"},{"id":"c69-492","title":"满江红·绀縠浮空","kind":"词"},{"id":"c69-493","title":"满江红·斜日熔金","kind":"词"},{"id":"c69-494","title":"千秋岁·当年渔隐","kind":"词"},{"id":"c69-495","title":"浣溪沙·酒力先从脸晕生","kind":"词"},{"id":"c69-496","title":"浣溪沙·翠幕遮笼锦一丛","kind":"词"},{"id":"c69-497","title":"浣溪沙·不怕春寒更出游","kind":"词"},{"id":"c69-498","title":"浣溪沙·越浦潮来信息通","kind":"词"},{"id":"c69-499","title":"浣溪沙·点检尊前花柳丛","kind":"词"},{"id":"c69-500","title":"浣溪沙·不跃银鞍与绣鞯","kind":"词"},{"id":"c69-501","title":"浣溪沙·帘押低垂月影疏","kind":"词"},{"id":"c69-502","title":"朝中措·朝来和气满西山","kind":"词"},{"id":"c69-503","title":"朝中措·求田何处是生涯","kind":"词"},{"id":"c69-504","title":"朝中措·去年曾醉杏花坊","kind":"词"},{"id":"c69-505","title":"朝中措·草堂春过一分馀","kind":"词"},{"id":"c69-506","title":"朝中措·秋山横截半湖光","kind":"词"},{"id":"c69-507","title":"蝶恋花·阊阖城西山四面","kind":"词"},{"id":"c69-508","title":"南柯子・南歌子·