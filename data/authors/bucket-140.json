{"严向":{"slug":"严向","name":"严向","dynasty":"唐","style":"","life":"","origin":"","seal":"严","bio":["向，同州朝邑人。乾元中为凤翔尹，宝应中授太常员外卿。广德二年卒，年八十五。","诗一首。（《全唐诗》无严向诗，传录《旧唐书》卷一九一《严善思传》附传）"],"works":[{"id":"t52-930","title":"送贺秘监归会稽诗","kind":"诗"}]},"刘袤":{"slug":"刘袤","name":"刘袤","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c65-273","title":"临江仙·樱桃结子春归尽","kind":"词"}]},"南巨川":{"slug":"南巨川","name":"南巨川","dynasty":"唐","style":"","life":"","origin":"","seal":"南","bio":[],"works":[{"id":"t43-285","title":"美玉","kind":"诗"}]},"吕直夫":{"slug":"吕直夫","name":"吕直夫","dynasty":"宋","style":"","life":"","origin":"","seal":"吕","bio":[],"works":[{"id":"c64-225","title":"洞仙歌·征鞍带月","kind":"词"}]},"和岘":{"slug":"和岘","name":"和岘","dynasty":"宋","style":"","life":"","origin":"","seal":"和","bio":[],"works":[{"id":"c57-607","title":"导引·气和玉烛","kind":"词"},{"id":"c57-608","title":"六州·严夜警","kind":"词"},{"id":"c57-609","title":"十二时・忆少年·承宝运","kind":"词"}]},"姚伦":{"slug":"姚伦","name":"姚伦","dynasty":"唐","style":"","life":"","origin":"","seal":"姚","bio":["姚伦，扬州大都督府参军。诗二首。"],"works":[{"id":"t14-369","title":"感秋","kind":"诗"},{"id":"t14-370","title":"过章秀才洛阳客舍","kind":"诗"}]},"孟浩然":{"slug":"孟浩然","name":"孟浩然","dynasty":"唐","style":"字浩然","life":"","origin":"","seal":"孟","bio":["孟浩然，字浩然，襄阳人。少隐鹿门山，年四十，乃游京师。常于太学赋诗，一坐嗟伏，与张九龄、王维为忘形交。","维私邀入内署，适明皇至，浩然匿床下，维以实对。帝喜曰：“朕闻其人而未见也。”诏浩然出，诵所为诗。","至“不才明主弃”，帝曰：“卿不求仕，朕未[尝]常弃卿，奈何诬我？”因放还。采访使韩朝宗约浩然偕至京师，欲荐诸朝。会与故人剧饮懽甚，不赴。","朝宗怒，辞行，浩然亦不悔也。张九龄镇荆州，署为从事。开元末，疽发背卒。","浩然为诗，伫兴而作，造意极苦，篇什既成，洗削凡近，超然独妙，虽气象清远，而采秀内映，藻思所不及。当明皇时，章句之风大得建安体，论者推李杜为尤，介其间能不媿者，浩然也。集三卷，今编诗二卷。","孟浩然，襄阳人。开元二十八年卒，年五十二。（复出一首）"],"works":[{"id":"t1-435","title":"相和歌辞 大堤行","kind":"诗"},{"id":"t7-671","title":"从张丞相游南纪城猎戏赠裴迪张参军","kind":"诗"},{"id":"t7-672","title":"登江中孤屿赠白云先生王迥","kind":"诗"},{"id":"t7-673","title":"晚春卧病寄张八","kind":"诗"},{"id":"t7-674","title":"秋登兰山寄张五","kind":"诗"},{"id":"t7-675","title":"入峡寄弟","kind":"诗"},{"id":"t7-676","title":"湖中旅泊寄阎九司户防","kind":"诗"},{"id":"t7-677","title":"大堤行寄万七","kind":"诗"},{"id":"t7-678","title":"仲夏归汉南园寄京邑耆旧","kind":"诗"},{"id":"t7-679","title":"题云门山寄越府包户曹徐起居","kind":"诗"},{"id":"t7-680","title":"宿扬子津寄润州长山刘隐士","kind":"诗"},{"id":"t7-681","title":"书怀贻京邑同好","kind":"诗"},{"id":"t7-682","title":"还山贻湛法师","kind":"诗"},{"id":"t7-683","title":"夏日南亭怀辛大","kind":"诗"},{"id":"t7-684","title":"秋宵月下有怀","kind":"诗"},{"id":"t7-685","title":"将适天台留别临安李主簿","kind":"诗"},{"id":"t7-686","title":"送丁大凤进士赴举呈张九龄","kind":"诗"},{"id":"t7-687","title":"送吴悦游韶阳","kind":"诗"},{"id":"t7-688","title":"适越留别谯县张主簿申屠少府","kind":"诗"},{"id":"t7-689","title":"送陈七赴西军","kind":"诗"},{"id":"t7-690","title":"送从弟邕下第后寻会稽","kind":"诗"},{"id":"t7-691","title":"送辛大之鄂渚不及","kind":"诗"},{"id":"t7-692","title":"江上别流人","kind":"诗"},{"id":"t7-693","title":"宴包二融宅","kind":"诗"},{"id":"t7-694","title":"与王昌龄宴王道士房","kind":"诗"},{"id":"t7-695","title":"襄阳公宅饮","kind":"诗"},{"id":"t7-696","title":"寻香山湛上人","kind":"诗"},{"id":"t7-697","title":"云门寺西六七里闻符公兰若最幽与薛八同往","kind":"诗"},{"id":"t7-698","title":"宿天台桐柏观","kind":"诗"},{"id":"t7-699","title":"岘潭作","kind":"诗"},{"id":"t7-700","title":"题终南翠微寺空上人房","kind":"诗"},{"id":"t7-701","title":"初春汉中漾舟","kind":"诗"},{"id":"t7-702","title":"宿业师山房期丁大不至","kind":"诗"},{"id":"t7-703","title":"耶溪泛舟","kind":"诗"},{"id":"t7-704","title":"彭蠡湖中望庐山","kind":"诗"},{"id":"t7-705","title":"登鹿门山","kind":"诗"},{"id":"t7-706","title":"游明禅师西山兰若","kind":"诗"},{"id":"t7-707","title":"登望楚山最高顶","kind":"诗"},{"id":"t7-708","title":"疾愈过龙泉寺精舍呈易业二公","kind":"诗"},{"id":"t7-709","title":"万山潭作","kind":"诗"},{"id":"t7-710","title":"与黄侍御北津泛舟","kind":"诗"},{"id":"t7-711","title":"洗然弟竹亭","kind":"诗"},{"id":"t7-712","title":"山中逢道士云公","kind":"诗"},{"id":"t7-713","title":"越中逢天台太乙子","kind":"诗"},{"id":"t7-714","title":"家园卧疾毕太祝曜见寻","kind":"诗"},{"id":"t7-715","title":"白云先生王迥见访","kind":"诗"},{"id":"t7-716","title":"田园作","kind":"诗"},{"id":"t7-717","title":"采樵作","kind":"诗"},{"id":"t7-718","title":"自浔阳泛舟经明海","kind":"诗"},{"id":"t7-719","title":"早发渔浦潭","kind":"诗"}]},"张芬":{"slug":"张芬","name":"张芬","dynasty":"唐","style":"字茂宗","life":"","origin":"","seal":"张","bio":["芬，字茂宗，江东人。工正书，大历二年书徐浩《郭英杰碑》。曾任大理评事，与李端有过往。","贞元中以兵部郎中入韦臯幕府。诗一首。（《全唐诗》无张芬诗，传据《金石录》、《书史会要》及苻载《剑南西川幕府诸公写真赞》）"],"works":[{"id":"t53-112","title":"无题","kind":"诗"},{"id":"t53-113","title":"酬李端山中见期不至（题拟）","kind":"诗"}]},"李愚":{"slug":"李愚","name":"李愚","dynasty":"唐","style":"字子晦","life":"","origin":"","seal":"李","bio":["愚，字子晦，渤海无棣人。天祐三年，登进士第，又登宏词科，授河南府参军。梁初避地河朔，末帝召为左拾遗，累迁司勋员外郎。","庄宗时，为翰林学士。长兴初，拜中书侍郎平章事。修成《创业功臣传》三十卷。","清泰二年卒。著有《白沙集》十卷、《五书》一卷，已佚。诗一首。","（《全唐诗》无李愚诗，传据《旧五代史》卷六七本传及《宋史·艺文志》）"],"works":[{"id":"t55-235","title":"无题","kind":"诗"},{"id":"t55-236","title":"述怀","kind":"诗"}]},"李挚":{"slug":"李挚","name":"李挚","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t43-664","title":"句","kind":"诗"}]},"李瀚":{"slug":"李瀚","name":"李瀚","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李瀚，后唐天成中，擢进士第。仕晋，为翰林学士。《丁年集》若干卷，今存诗一首。","李瀚，后唐天成中，擢进士第，仕晋，为翰林学士。丁年集若干卷，今存诗一首。"],"works":[{"id":"t41-383","title":"留题座主和凝旧阁","kind":"诗"},{"id":"t48-778","title":"蒙求","kind":"诗"}]},"李蔚":{"slug":"李蔚","name":"李蔚","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t43-680","title":"句","kind":"诗"}]},"直言":{"slug":"直言","name":"直言","dynasty":"唐","style":"","life":"","origin":"","seal":"直","bio":["直言，元稹同时之僧人。（详附按）"],"works":[{"id":"t53-533","title":"观元相公花饮（一作「宴」）","kind":"诗"}]},"织女":{"slug":"织女","name":"织女","dynasty":"唐","style":"","life":"","origin":"","seal":"织","bio":[],"works":[{"id":"t47-871","title":"赠郭翰二首 一","kind":"诗"},{"id":"t47-872","title":"赠郭翰二首 二","kind":"诗"},{"id":"t47-873","title":"郭翰酬织女 一","kind":"诗"},{"id":"t47-874","title":"郭翰酬织女 二","kind":"诗"}]},"萧结":{"slug":"萧结","name":"萧结","dynasty":"唐","style":"","life":"","origin":"","seal":"萧","bio":[],"works":[{"id":"t48-398","title":"批州符","kind":"诗"}]},"贺兰求":{"slug":"贺兰求","name":"贺兰求","dynasty":"唐","style":"","life":"","origin":"","seal":"贺","bio":[],"works":[{"id":"t56-529","title":"还丹歌","kind":"诗"}]},"贺兰遂":{"slug":"贺兰遂","name":"贺兰遂","dynasty":"唐","style":"","life":"","ori