{"slug":"马怀素","name":"马怀素","dynasty":"唐","style":"字惟白","life":"","origin":"","seal":"马","bio":["马怀素，字惟白，润州丹徒人，擢进士第。长安中，为监察御史，守正不阿。开元初，拜户部侍郎，昭文馆学士，卒，谥曰文。","诗十二首。"],"works":[{"id":"t4-951","title":"九日幸临渭亭登高应制得酒字","kind":"诗"},{"id":"t4-952","title":"奉和九月九日登慈恩寺浮图应制","kind":"诗"},{"id":"t4-953","title":"奉和送金城公主适西蕃应制","kind":"诗"},{"id":"t4-954","title":"饯许州宋司马赴任","kind":"诗"},{"id":"t4-955","title":"饯唐州高使君赴任","kind":"诗"},{"id":"t4-956","title":"奉和立春游苑迎春应制","kind":"诗"},{"id":"t4-957","title":"奉和圣制春日幸望春宫应制","kind":"诗"},{"id":"t4-958","title":"奉和人日䜩大明宫恩赐彩缕人胜应制","kind":"诗"},{"id":"t4-959","title":"奉和幸安乐公主山庄应制","kind":"诗"},{"id":"t4-960","title":"兴庆池侍宴应制","kind":"诗"},{"id":"t4-961","title":"夜宴安乐公主宅","kind":"诗"},{"id":"t4-962","title":"饯唐永昌","kind":"诗"}]}