{"侯蒙":{"slug":"侯蒙","name":"侯蒙","dynasty":"宋","style":"","life":"","origin":"","seal":"侯","bio":[],"works":[{"id":"c61-965","title":"临江仙·未遇行藏谁肯信","kind":"词"}]},"史达祖":{"slug":"史达祖","name":"史达祖","dynasty":"宋","style":"字邦卿 · 号梅溪","life":"","origin":"","seal":"史","bio":["字邦卿，号梅溪，汴 (今河南开封) 人。尝为韩胄堂吏，韩败，坐受黥刑。其词多抒写闲情逸致，用笔尖巧，追求细腻工致，以咏物真著称，亦有少数感慨国事的篇什，有《梅溪词》传世。"],"works":[{"id":"c70-994","title":"绮罗香·做冷欺花","kind":"词"},{"id":"c70-995","title":"双双燕·过春社了","kind":"词"},{"id":"c70-996","title":"阳春曲・阳春·杏花烟","kind":"词"},{"id":"c70-997","title":"海棠春令・海棠春·似红如白含芳意","kind":"词"},{"id":"c70-998","title":"夜行船·不翦春衫愁意态","kind":"词"},{"id":"c70-999","title":"东风第一枝·巧沁兰心","kind":"词"},{"id":"c71-0","title":"东风第一枝·草脚愁苏","kind":"词"},{"id":"c71-1","title":"东风第一枝·酒馆歌云","kind":"词"},{"id":"c71-2","title":"玉楼春·游人等得春晴也","kind":"词"},{"id":"c71-3","title":"玉楼春·玉容寂寞谁为主","kind":"词"},{"id":"c71-4","title":"喜迁莺·月波疑滴","kind":"词"},{"id":"c71-5","title":"万年欢·两袖梅风","kind":"词"},{"id":"c71-6","title":"阮郎归·龙香吹袖白藤鞭","kind":"词"},{"id":"c71-7","title":"阮郎归·旧时明月旧时身","kind":"词"},{"id":"c71-8","title":"眼儿媚·潘郎心老不成春","kind":"词"},{"id":"c71-9","title":"眼儿媚·儿家七十二鸳鸯","kind":"词"},{"id":"c71-10","title":"忆瑶姬·娇月笼烟","kind":"词"},{"id":"c71-11","title":"南歌子·采绿随双桨","kind":"词"},{"id":"c71-12","title":"风流子·红楼横落日","kind":"词"},{"id":"c71-13","title":"风流子·飞琼神仙客","kind":"词"},{"id":"c71-14","title":"金盏子·奖绿催红","kind":"词"},{"id":"c71-15","title":"杏花天·软波拖碧蒲芽短","kind":"词"},{"id":"c71-16","title":"杏花天·古城官道花如霰","kind":"词"},{"id":"c71-17","title":"杏花天·细风微月垂杨院","kind":"词"},{"id":"c71-18","title":"杏花天·扇香曾靠腮边粉","kind":"词"},{"id":"c71-19","title":"三姝媚·烟光摇缥瓦","kind":"词"},{"id":"c71-20","title":"寿楼春·裁春衫寻芳","kind":"词"},{"id":"c71-21","title":"于飞乐·绮翼□□","kind":"词"},{"id":"c71-22","title":"南浦·玉树晓飞香","kind":"词"},{"id":"c71-23","title":"探芳信·谢池晓","kind":"词"},{"id":"c71-24","title":"祝英台近·柳枝愁","kind":"词"},{"id":"c71-25","title":"祝英台近·绾流苏","kind":"词"},{"id":"c71-26","title":"祝英台近·落花深","kind":"词"},{"id":"c71-27","title":"钗头凤・撷芳词·春愁远","kind":"词"},{"id":"c71-28","title":"西江月·西月澹窥楼角","kind":"词"},{"id":"c71-29","title":"西江月·三十六宫月冷","kind":"词"},{"id":"c71-30","title":"西江月·一片秋香世界","kind":"词"},{"id":"c71-31","title":"西江月·裙摺绿罗芳草","kind":"词"},{"id":"c71-32","title":"庆清朝·坠絮孳萍","kind":"词"},{"id":"c71-33","title":"桃源忆故人·双鸳蹙月天津近","kind":"词"},{"id":"c71-34","title":"桃源忆故人·明霞烘透春机杼","kind":"词"},{"id":"c71-35","title":"花心动·风约帘波","kind":"词"},{"id":"c71-36","title":"解佩令·人行花坞","kind":"词"},{"id":"c71-37","title":"菩萨蛮·梨花不碍东城月","kind":"词"},{"id":"c71-38","title":"菩萨蛮·唐昌观里东风软","kind":"词"},{"id":"c71-39","title":"菩萨蛮·广寒夜捣玄霜细","kind":"词"},{"id":"c71-40","title":"贺新郎·花落台池静","kind":"词"},{"id":"c71-41","title":"贺新郎·绿障南城树","kind":"词"},{"id":"c71-42","title":"贺新郎·鹊翅西风浅","kind":"词"},{"id":"c71-43","title":"贺新郎·同住西山下","kind":"词"}]},"吕南公":{"slug":"吕南公","name":"吕南公","dynasty":"宋","style":"","life":"","origin":"","seal":"吕","bio":[],"works":[{"id":"c61-322","title":"调笑令·行客","kind":"词"},{"id":"c61-323","title":"调笑令·华草","kind":"词"}]},"孟光":{"slug":"孟光","name":"孟光","dynasty":"唐","style":"","life":"","origin":"","seal":"孟","bio":["孟光，贞元二十一年任台州录事参军。诗一首。（《全唐诗》无孟光诗）"],"works":[{"id":"t53-165","title":"送最澄上人还日本国","kind":"诗"}]},"宣宗皇帝":{"slug":"宣宗皇帝","name":"宣宗皇帝","dynasty":"唐","style":"","life":"","origin":"","seal":"宣","bio":["帝讳忱，宪宗第十三子，初名怡，封光王。会昌六年，立为皇太叔，恭俭好善，虚襟听纳，大中之政，有贞观风。每曲宴，与学士倡和，公卿出镇，多赋诗饯行。","重科第，留心贡举。常微行，采舆论，察知选士之得失。其对朝臣，必问及第与所试诗赋题，主司姓氏，苟有科名对者，必大喜。","或佳人物偶不中第，必叹息移时。常于内自题乡贡进士李道龙云。在位十三年，谥曰献文，诗六首。"],"works":[{"id":"t0-207","title":"百丈山","kind":"诗"},{"id":"t0-208","title":"吊白居易","kind":"诗"},{"id":"t0-209","title":"幸华严寺","kind":"诗"},{"id":"t0-210","title":"重阳锡宴群臣","kind":"诗"},{"id":"t0-211","title":"题泾县水西寺","kind":"诗"},{"id":"t0-212","title":"瀑布联句","kind":"诗"},{"id":"t0-213","title":"句","kind":"诗"}]},"徐坚":{"slug":"徐坚","name":"徐坚","dynasty":"唐","style":"字元固","life":"","origin":"","seal":"徐","bio":["徐坚，字元固，湖州人，举进士。圣历中为东都留守判官，专主表奏。王方庆称为掌纶诰之选，杨再思亦曰：“此凤阁舍人样。","”与徐彦伯、刘知几、张说同修《三教珠英》，搆意撰录，具为条流。书成，迁司封员外郎。中宗时，为给事中。","睿宗朝，自刑部侍郎拜散骑常侍。开元中，改丽正书院为集贤院，以坚为学士，副张说知院事。坚多识典故，前后修撰格式、氏族及国史等，凡七入书府。","又讨集前代文词故实，为《初学记》，坚与父齐耼俱以词学著闻。长姑为太宗充容，次姑为高宗倢伃，并有文藻，议者方之汉世班氏。集三十卷，今存诗九首。"],"works":[{"id":"t0-704","title":"郊庙歌辞 仪坤庙乐章 寿和","kind":"诗"},{"id":"t1-266","title":"相和歌辞 櫂歌行","kind":"诗"},{"id":"t5-356","title":"奉和圣制送张说赴集贤院学士赐宴赋得虚字","kind":"诗"},{"id":"t5-357","title":"奉和圣制送张说巡边","kind":"诗"},{"id":"t5-358","title":"奉和送金城公主适西蕃应制","kind":"诗"},{"id":"t5-359","title":"饯许州宋司马赴任","kind":"诗"},{"id":"t5-360","title":"饯唐永昌","kind":"诗"},{"id":"t5-361","title":"送考功武员外学士使嵩山置舍利塔歌","kind":"诗"},{"id":"t5-362","title":"櫂歌行","kind":"诗"},{"id":"t5-363","title":"送武进郑明府","kind":"诗"},{"id":"t5-364","title":"仪坤庙乐章","kind":"诗"}]},"慧救":{"slug":"慧救","name":"慧救","dynasty":"唐","style":"","life":"","origin":"","seal":"慧","bio":["慧救，泉州莆田人。出家于龟洋山，后嗣师备。世称中塔和尚。","闽王钦敬，奏赐紫衣。诗二首。（《全唐诗》无慧救诗）"],"works":[{"id":"t55-800","title":"无题","kind":"诗"},{"id":"t55-801","title":"曜日颂","kind":"诗"},{"id":"t55-802","title":"送灵云和尚颂（题拟）","kind":"诗"}]},"朱绛":{"slug":"朱绛","name":"朱绛","dynasty":"唐","style":"","life":"","origin":"","seal":"朱","bio":[],"works":[{"id":"t42-963","title":"春女怨","kind":"诗"}]},"李嵘":{"slug":"李嵘","name":"李嵘","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李嵘，咸通时人，诗一首。"],"works":[{"id":"t33-222","title":"献淮南师","kind":"诗"}]},"杨贲":{"slug":"杨贲","name":"杨贲","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":["杨贲，天宝三年登第。诗一首。"],"works":[{"id":"t10-53","title":"时兴","kind":"诗"}]},"江汉":{"slug":"江汉","name":"江汉","dynasty":"宋","style":"","life":"","origin":"","seal":"江","bio":[],"works":[{"id":"c63-98","title":"喜迁莺·升平无际","kind":"词"}]},"熊可量":{"slug":"熊可量","name":"熊可量","dynasty":"宋","style":"","life":"","origin":"","seal":"熊","bio":[],"works":[{"id":"c69-740","title":"鹧鸪天·清晓南窗笑语喧","kind":"词"}]},"赵抟":{"slug":"赵抟","name":"赵抟","dynasty":"唐","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"t43-27","title":"琴歌","kind":"诗"},{"id":"t43-28","title":"废长行","kind":"诗"}]},"赵鼎臣":{"slug":"赵鼎臣","name":"赵鼎臣","dynasty":"宋","style":"字元镇 · 号得全居士","life":"1085 — 1147","origin":"解州闻喜（今属山西）","seal":"赵","bio":["--(1085-1147) 字元镇，解州闻喜 (今属山西) 人。自号得全居士。中兴名臣之一。","崇宁五年 (1160) 进士。累官开封市曹。高宗擢右司谏，历官至尚书左仆射、同中书门下平章事。","为秦桧所忌，出为奉国军节度使，徙知泉州，安置潮州，移吉阳军，不食而卒。著有《忠正德文集》、《得全居士词》。"],"works":[{"id":"c62-564","title":"念奴娇·旧游何处","kind":"词"},{"id":"c78-277","title":"念奴娇·嫦娥伴侣","kind":"词"}]},"郑子玉":{"slug":"郑子玉","name":"郑子玉","dynasty":"宋","style":"","life":"","origin":"","seal":"郑","bio":[],"works":[{"id":"c74-119","title":"八声甘州·渐莺声近也","kind":"词"}]},"陆子":{"slug":"陆子","name":"陆子","dynasty":"唐","style":"","life":"","origin":"","seal":"陆","bio":[],"works":[{"id":"t48-223","title":"嘲父","kind":"诗"}]},"韦述":{"slug":"韦述","name":"韦述","dynasty":"唐","style":"","life":"","origin":"","seal":"韦","bio":["韦述，京兆人。家有书二千卷，儿时记览皆徧，缀文，操牍便就。举进士时甚少，仪形渺小，考功郎宋之问曰：“韦学士童年有何事业？”对曰：“性好著书。","”之问曰：“本求异才，果得迁固。”开元中，诏马怀素编次图书，乃奏用元行冲、齐澣、王珣、吴兢并述等二十六人，同于秘阁详录四部书，五年而成。述好谱学，又于《柳冲姓族系录》外，撰《开元谱》二十卷。","张说引为集贤院直学士，累迁尚书工部侍郎。在书府四十年，居史职二十年，勒成国史，事简记详，萧颖士以为谯周、陈寿之流。后陷贼，流渝州卒。","诗四首。"],"works":[{"id":"t5-378","title":"奉和圣制送张说上集贤学士赐宴","kind":"诗"},{"id":"t5-379","title":"晚渡伊水","kind":"诗"},{"id":"t5-380","title":"春日山庄","kind":"诗"},{"id":"t5-381","title":"广陵送别宋员外佐越郑舍人还京","kind":"诗"},{"id":"t52-863","title":"送贺秘监归会稽诗","kind":"诗"}]},"高元裕":{"slug":"高元裕","name":"高元裕","dynasty":"唐","style":"字景圭","life":"","origin":"","seal":"高","bio":["字景圭，渤海人，开成中翰林学士，终吏部尚书。"],"works":[{"id":"t43-672","title":"句","kind":"诗"},{"id":"t53-919","title":"简知举陈商（题拟）","kind":"诗"}]},"黎瓘":{"slug":"黎瓘","name":"黎瓘","dynasty":"唐","style":"","life":"","origin":"","seal":"黎","bio":[],"works":[{"id":"t48-297","title":"赠漳州崔使君乡饮飜韵诗","kind":"诗"}]}}