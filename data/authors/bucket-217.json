{"元德昭":{"slug":"元德昭","name":"元德昭","dynasty":"唐","style":"","life":"","origin":"","seal":"元","bio":[],"works":[{"id":"t43-712","title":"句","kind":"诗"}]},"全豁":{"slug":"全豁","name":"全豁","dynasty":"唐","style":"","life":"","origin":"","seal":"全","bio":["全豁，俗姓柯，泉州南安人。嗣德山，后住持鄂州唐宁寺，世称岩头和尚。中和五年卒，年六十。","诗一首。（《全唐诗》无全豁诗。事迹见《宋高僧传》卷二三。","《五灯会元》卷七谓光启三年卒）"],"works":[{"id":"t54-190","title":"曜日颂","kind":"诗"}]},"吴融":{"slug":"吴融","name":"吴融","dynasty":"唐","style":"字子华","life":"","origin":"","seal":"吴","bio":["吴融，字子华，越州山阴人。龙纪初，及进士第，韦昭度讨蜀，表掌书记，累迁侍御史。去官依荆南成汭。","久之，召为左补阙，拜中书舍人。昭宗反正，造次草诏，无不称旨，进户部侍郎。凤翔劫迁，融不克从，去客阌乡，俄召还翰林，迁承旨卒。","有《唐英集》三卷，今编诗四卷。"],"works":[{"id":"t1-820","title":"杂曲歌辞 古别离","kind":"诗"},{"id":"t1-979","title":"杂曲歌辞 水调","kind":"诗"},{"id":"t38-314","title":"奉和御制","kind":"诗"},{"id":"t38-315","title":"和集贤相公西溪侍宴观竞渡","kind":"诗"},{"id":"t38-316","title":"山居即事四首 一","kind":"诗"},{"id":"t38-317","title":"山居即事四首 二","kind":"诗"},{"id":"t38-318","title":"山居即事四首 三","kind":"诗"},{"id":"t38-319","title":"山居即事四首 四","kind":"诗"},{"id":"t38-320","title":"红白牡丹","kind":"诗"},{"id":"t38-321","title":"中秋陪熙用学士禁中玩月","kind":"诗"},{"id":"t38-322","title":"题豪家故池","kind":"诗"},{"id":"t38-323","title":"偶题","kind":"诗"},{"id":"t38-324","title":"渚宫立春书怀","kind":"诗"},{"id":"t38-325","title":"闻李翰林游池上有寄","kind":"诗"},{"id":"t38-326","title":"谷口寓居偶题","kind":"诗"},{"id":"t38-327","title":"无题","kind":"诗"},{"id":"t38-328","title":"赋雪","kind":"诗"},{"id":"t38-329","title":"寄僧","kind":"诗"},{"id":"t38-330","title":"酬僧","kind":"诗"},{"id":"t38-331","title":"题延寿坊东南角古池","kind":"诗"},{"id":"t38-332","title":"登鹳雀楼","kind":"诗"},{"id":"t38-333","title":"和峡州冯使君题所居","kind":"诗"},{"id":"t38-334","title":"秋日感事","kind":"诗"},{"id":"t38-335","title":"莺","kind":"诗"},{"id":"t38-336","title":"次韵和王员外杂游四韵","kind":"诗"},{"id":"t38-337","title":"秋事","kind":"诗"},{"id":"t38-338","title":"和陆拾遗题谏院松","kind":"诗"},{"id":"t38-339","title":"题杨子津亭","kind":"诗"},{"id":"t38-340","title":"闲望","kind":"诗"},{"id":"t38-341","title":"雪后过昭应","kind":"诗"},{"id":"t38-342","title":"商人","kind":"诗"},{"id":"t38-343","title":"岐下闻杜鹃","kind":"诗"},{"id":"t38-344","title":"雨后闻思归乐二首 一","kind":"诗"},{"id":"t38-345","title":"雨后闻思归乐二首 二","kind":"诗"},{"id":"t38-346","title":"中夜闻啼禽","kind":"诗"},{"id":"t38-347","title":"灵池县见早梅","kind":"诗"},{"id":"t38-348","title":"野庙","kind":"诗"},{"id":"t38-349","title":"闲书","kind":"诗"},{"id":"t38-350","title":"寄贯休上人","kind":"诗"},{"id":"t38-351","title":"书怀","kind":"诗"},{"id":"t38-352","title":"重阳日荆州作","kind":"诗"},{"id":"t38-353","title":"寄贯休","kind":"诗"},{"id":"t38-354","title":"秋日渚宫即事","kind":"诗"},{"id":"t38-355","title":"荆州寓居书怀","kind":"诗"},{"id":"t38-356","title":"和严谏议萧山庙十韵","kind":"诗"},{"id":"t38-357","title":"松江晚泊","kind":"诗"},{"id":"t38-358","title":"湖州溪楼书献郑员外","kind":"诗"},{"id":"t38-359","title":"秋兴","kind":"诗"},{"id":"t38-360","title":"端居","kind":"诗"},{"id":"t38-361","title":"途中","kind":"诗"}]},"崔恭":{"slug":"崔恭","name":"崔恭","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":["崔恭，官历太原节度副使、检校右散骑常侍、汾州刺史。诗一首。"],"works":[{"id":"t19-534","title":"和张相公太原山亭怀古诗","kind":"诗"}]},"徐浩":{"slug":"徐浩","name":"徐浩","dynasty":"唐","style":"字季海","life":"","origin":"","seal":"徐","bio":["徐浩，字季海，越州人。少举明经，工草隶，以张说荐，为丽正殿校理。三迁右拾遗，张守珪表佐幽州幕，改监察御史，历宪部郎中。","肃宗即位，拜中书舍人。时天下事殷，诏令俱出其手，文词赡给。加尚书右丞，除国子祭酒，寻贬卢州长史。","代宗征还，仍拜中书舍人，迁工部侍郎、岭南节度观察使，又为吏部侍郎、集贤殿学士。为李栖筠所弹，贬明州别驾，终彭王傅，卒赠太子少师。世称其书法如怒猊抉石，渴骥奔泉。","诗二首。"],"works":[{"id":"t10-562","title":"宝林寺作","kind":"诗"},{"id":"t10-563","title":"谒禹庙","kind":"诗"},{"id":"t51-250","title":"题雷威琴","kind":"诗"},{"id":"t51-251","title":"送东林廉上人还庐（山）","kind":"诗"},{"id":"t53-116","title":"诗","kind":"诗"}]},"护国":{"slug":"护国","name":"护国","dynasty":"唐","style":"","life":"","origin":"","seal":"护","bio":["护国，江南人。工词翰，有声大历间。诗十二首。"],"works":[{"id":"t44-782","title":"归山作","kind":"诗"},{"id":"t44-783","title":"题醴陵玉仙观歌","kind":"诗"},{"id":"t44-784","title":"访云母山僧","kind":"诗"},{"id":"t44-785","title":"题王班水亭","kind":"诗"},{"id":"t44-786","title":"山中寄王员外","kind":"诗"},{"id":"t44-787","title":"许州郑使君孩子","kind":"诗"},{"id":"t44-788","title":"怆故人旧居","kind":"诗"},{"id":"t44-789","title":"逢灵道士","kind":"诗"},{"id":"t44-790","title":"别盛安","kind":"诗"},{"id":"t44-791","title":"伤蔡处士","kind":"诗"},{"id":"t44-792","title":"临川道中","kind":"诗"},{"id":"t44-793","title":"赠张驸马斑竹柱杖","kind":"诗"}]},"方干":{"slug":"方干","name":"方干","dynasty":"唐","style":"字雄飞","life":"","origin":"","seal":"方","bio":["方干，字雄飞，新定人。徐凝一见器之，授以诗律，始举进士。谒钱塘太守姚合，合视其貌陋，甚卑之。","坐定览卷，乃骇目变容。馆之数日，登山临水，无不与焉。咸通中，一举不得志，遂遯会稽，渔于鉴湖，太守王龟以其亢直，宜在谏署，欲荐之，不果。","干自咸通得名，迄文德，江之南无有及者。殁后十余年，宰臣张文蔚奏名儒不第者五人，请赐一官，以慰其魂，干其一也。后进私谥曰玄英先生，门人杨弇与释子居远收得诗三百七十余篇，集十卷。","今编诗六卷。"],"works":[{"id":"t36-55","title":"采莲","kind":"诗"},{"id":"t36-56","title":"寄李频","kind":"诗"},{"id":"t36-57","title":"东溪别业寄吉州段郎中","kind":"诗"},{"id":"t36-58","title":"怀州客舍","kind":"诗"},{"id":"t36-59","title":"中路寄喻凫先辈","kind":"诗"},{"id":"t36-60","title":"送赵明府还北","kind":"诗"},{"id":"t36-61","title":"过朱协律故山","kind":"诗"},{"id":"t36-62","title":"途中寄刘沆","kind":"诗"},{"id":"t36-63","title":"送班主簿入谒荆南韦常侍","kind":"诗"},{"id":"t36-64","title":"夏日登灵隐寺后峰","kind":"诗"},{"id":"t36-65","title":"听新蝉寄张昼","kind":"诗"},{"id":"t36-66","title":"送喻坦之下第还江东","kind":"诗"},{"id":"t36-67","title":"送姚舒下第游蜀","kind":"诗"},{"id":"t36-68","title":"旅次钱塘","kind":"诗"},{"id":"t36-69","title":"别喻凫","kind":"诗"},{"id":"t36-70","title":"送相里烛","kind":"诗"},{"id":"t36-71","title":"君不来","kind":"诗"},{"id":"t36-72","title":"将谒商州吕郎中道出楚州留献章中丞","kind":"诗"},{"id":"t36-73","title":"金州客舍","kind":"诗"},{"id":"t36-74","title":"途中逢孙辂因得李频消息","kind":"诗"},{"id":"t36-75","title":"送从兄郜","kind":"诗"},{"id":"t36-76","title":"送许温","kind":"诗"},{"id":"t36-77","title":"镜中别业二首 一","kind":"诗"},{"id":"t36-78","title":"镜中别业二首 二","kind":"诗"},{"id":"t36-79","title":"经周处士故居","kind":"诗"},{"id":"t36-80","title":"赠喻凫","kind":"诗"},{"id":"t36-81","title":"早发洞庭","kind":"诗"},{"id":"t36-82","title":"贻钱塘县路明府","kind":"诗"},{"id":"t36-83","title":"湖上言事寄长城喻明府","kind":"诗"},{"id":"t36-84","title":"涵碧亭","kind":"诗"},{"id":"t36-85","title":"除夜","kind":"诗"},{"id":"t36-86","title":"赠许牍山人","kind":"诗"},{"id":"t36-87","title":"赠功成