[{"id":"t48-500","title":"南唐升元殿基下石记","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["莫问江南事，江南事可凭。","抱鸡升宝位，跨犬出金陵。","子建司南位，安仁秉夜灯。","东邻娇小女，骑虎渡河冰。"]},{"id":"t48-501","title":"马殷浚城石碣篆","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["龙举头，猳掉尾。","羊为兄，猴作弟。","羊归穴，猴离次。"]},{"id":"t48-502","title":"王霸仙坛甎刻","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["树枯不用伐，坛坏不须结。","未满一千岁，自有系孙列。","后来是三皇，潮水荡祸殃。","岩逢二乍间，未免有消亡。","子孙依吾道，代代封闽疆。"]},{"id":"t48-503","title":"刘䶮石谶","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["人人有一，山山值牛。","兔丝吞骨，盖海承刘。"]},{"id":"t48-504","title":"南汉罗浮古劒篆文","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["丁与水同宫，王将耳口同。","尹来居口上，山岫获重重。"]},{"id":"t48-505","title":"司马承祯含象鉴文 一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["天地含象，日月贞明。","写规万物，洞鉴百灵。"]},{"id":"t48-506","title":"司马承祯含象鉴文 二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["龟自卜，镜自照。","吉可募，光不曜。"]},{"id":"t48-507","title":"司马承祯含象鉴文 三","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["青盖作镜大吉昌，巧工刊之成文章。","左龙右虎辟不祥，朱鸟玄武顺于旁，子孙富贵居中央。"]},{"id":"t48-508","title":"景震劒文 一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["㧑雷电，运玄星。","摧凶恶，亨利贞。"]},{"id":"t48-509","title":"景震劒文 二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["干降精，坤应灵。","日月象，岳渎形。"]},{"id":"t48-510","title":"高丽镜文","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["三水中，四维下，上帝降子于辰马。","先操鸡，后搏鸭。","己年中，二龙见。","一则藏身青木中，一则见形黑金东。"]},{"id":"t48-511","title":"京西市放生池墓铭","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["龟言市，蓍言水。"]},{"id":"t48-512","title":"古墓卜地词","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["尔后一千岁，此地化为泉。","赖逢邬侍御，移我向高原。"]},{"id":"t48-513","title":"卫先生墓铭","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["姜师度，更移向南三五步。"]},{"id":"t48-514","title":"隐者瘗男铭","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["神真链形年未足，化为我子功相续。","丞相瘗之刻玄玉，仙路何长死何促。"]},{"id":"t48-515","title":"乌氏葬碑","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["牛领冈头，红箫笼下。","葬用两日，手板相亚。"]},{"id":"t48-516","title":"岩腹棺铭","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["欲堕不堕逢王果，五百年中重收我。"]},{"id":"t48-517","title":"古棺石铭","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["欲陷不陷被藤缚，欲落不落被沙阁，五百年后遇熊博。"]},{"id":"t48-518","title":"涟水古冢缾文","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["一双青乌子，飞来五两头。","借问船轻重，寄信到扬州。"]},{"id":"t48-519","title":"沈彬圹篆","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["佳城今已开，虽开不葬埋。","漆灯犹未灭，留待沈彬来。"]},{"id":"t48-520","title":"广陵古冢石刻","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["日为箭兮月为弓，四时躬人兮无穷。","但得天将明月死，不觉人随流水空。","山川秀兮碧穹窿，崇夫人墓兮直其中。","猨啼鸟啸烟蒙蒙，千年万年松柏风。"]},{"id":"t48-521","title":"王承检掘得墓铭","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["车道之北，邽山之阳。","深深葬玉，郁郁埋香。","刻斯贞石，焕乎遗芳。","地变陵谷，崄列城隍。","干德丙年，坏者合郎。"]},{"id":"t48-522","title":"马希振葬地碣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["乱石之壤，绝世之冈。","谷变庚戌，马氏无王。"]},{"id":"t48-523","title":"二贺诗","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["学行可师贺德基，文质彬彬贺德仁。"]},{"id":"t48-524","title":"四王语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["宁向儋崖振白，不事江滕蒋虢。"]},{"id":"t48-525","title":"时人为屈突语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["宁食三斗艾，不见屈突盖。","宁服三斗葱，不逢屈突通。"]},{"id":"t48-526","title":"杨刺史语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["宁食三斗蒜，不逢杨德干。"]},{"id":"t48-527","title":"万年人语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["宁食三斗尘，无逢权怀恩。"]},{"id":"t48-528","title":"赞皇人语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["太冲无兄，孝端无弟。"]},{"id":"t48-529","title":"高宗时语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["左相宣威沙漠，右相驰誉丹青。","三馆学生放散，五台令史经明。"]},{"id":"t48-530","title":"时人为李义甫语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["今日巨唐年，还诛四凶族。"]},{"id":"t48-531","title":"洛州语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["洛州有前贾后张，可敌京兆三王。"]},{"id":"t48-532","title":"江淮间语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["贵如许郝，富若田彭。"]},{"id":"t48-533","title":"河北语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["唯此两何，杀人最多。"]},{"id":"t48-534","title":"李昭德为王弘义语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["昔闻苍鹰狱吏，今见白兔御史。"]},{"id":"t48-535","title":"京洛语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["衣裳好，仪貌恶。","不姓许，即姓郝。"]},{"id":"t48-536","title":"台中语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["侯知一不伏致仕，张悰自请起复。","高筠不肯作孝，张栖贞情愿遭忧。"]},{"id":"t48-537","title":"吏人语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["不畏侯卿杖，惟畏尹卿笔。"]},{"id":"t48-538","title":"选人语 一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["有钱石上好，无钱刘下好，士大夫张下好。"]},{"id":"t48-539","title":"选人语 二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["硕学师刘子，儒生用与言。"]},{"id":"t48-540","title":"选人语 三","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["今年柿子并遭霜，为语石榴须早摘。"]},{"id":"t48-541","title":"韦氏语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["大郎罢相，小郎拜相。"]},{"id":"t48-542","title":"益州人吏语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["录事意，与天通，益州司马折威风。"]},{"id":"t48-543","title":"天授中语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["遇徐杜者必生，遇来侯者必死。"]},{"id":"t48-544","title":"时人为邹昉语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["萧佺驸马子，邹昉骆驼儿。","非关道德合，只为钱相知。"]},{"id":"t48-545","title":"题张昌仪门语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["一两丝能得几时络。"]},{"id":"t48-546","title":"时人号李知远语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["李下无蹊。"]},{"id":"t48-547","title":"又号李乂语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["李下无蹊径。"]},{"id":"t48-548","title":"窦仆射语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["窦仆射，前为韦氏国㸙，后作公主邑丞。"]},{"id":"t48-549","title":"时人为崔无诐语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["皇后嫁女，天子娶妇。"]},{"id":"t48-550","title":"神龙中语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["崔冉郑，乱时政。"]},{"id":"t48-551","title":"斜封官语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["姚宋为相，邪不如正。","太平用事，正不如邪。"]},{"id":"t48-552","title":"李处郁语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["飧若入咽，百无一全。"]},{"id":"t48-553","title":"景云初语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["前有裴马，后有卢李。"]},{"id":"t48-554","title":"先天时京中语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["姜师度一心看地，傅孝忠两眼相天。"]},{"id":"t48-555","title":"时人号王丘崔沔语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["丘山岌岌连天峻，沔水澄澄彻底清。"]},{"id":"t48-556","title":"吏部过官语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["麟之口，光庭手。"]},{"id":"t48-557","title":"郇公厨语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["人欲不饭筋骨舒，夤缘须入郇公厨。"]},{"id":"t48-558","title":"四俊语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["令君四俊，苗吕崔员。"]},{"id":"t48-559","title":"八友语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["殷颜柳陆，李萧邵赵。"]},{"id":"t48-560","title":"罗吉口号","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["罗钳吉网。"]},{"id":"t48-561","title":"里闾诅语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["若违教，值三豹。"]},{"id":"t48-562","title":"陕州语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["不须赛神明，不必求巫祝。","尔莫犯卢公，立便有祸福。"]},{"id":"t48-563","title":"真源邑语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["南金口，明府手。"]},{"id":"t48-564","title":"称二王语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["朝廷左相笔，天下右丞诗。"]},{"id":"t48-565","title":"代宗朝京师语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["常无分别元好钱，贤者愚，愚者贤。"]},{"id":"t48-566","title":"戏谏司语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["韩谏议虽分左右，归拾遗莫辨存亡。"]},{"id":"t48-567","title":"裴度语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["鸡猪鱼蒜，逢著则吃。","生老病死，时至则行。"]},{"id":"t48-568","title":"魏博语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["长安天子，魏府牙军。"]},{"id":"t48-569","title":"宝历宫中语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["宝帐香重重，一双红芙蓉。"]},{"id":"t48-570","title":"京师人号牛杨语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["太牢笔，少牢口，东西南北何处走。"]},{"id":"t48-571","title":"又号牛李","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["门生故吏，不牛则李。"]},{"id":"t48-572","title":"荆南语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["旱不苦，祷而雨。","雨不愁，公出游。"]},{"id":"t48-573","title":"郑仁表自语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["天瑞有五色云，人瑞有郑仁表。"]},{"id":"t48-574","title":"湖苏二郡语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["湖接两头，苏联三尾。"]},{"id":"t48-575","title":"广明初都人语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["黄贼打黑贼。"]},{"id":"t48-576","title":"吏部旧语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["长名以前，选人属侍郎。","长名以后，侍郎属选人。"]},{"id":"t48-577","title":"省中语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["后行祠屯，不博中行都门。","中行礼部，不博前行驾库。"]},{"id":"t48-578","title":"郎吏语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["司门水部，入省不数。"]},{"id":"t48-579","title":"谏院台省语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["遗补相惜，御史相憎，郎官相轻。"]},{"id":"t48-580","title":"御史台语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["事长如事端。"]},{"id":"t48-581","title":"京兆府语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["不立两县令，不坐两少尹。"]},{"id":"t48-582","title":"翰林谏议语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["饶道斗上坡去，亦须却下坡来。"]},{"id":"t48-583","title":"举子语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["槐花黄，举子忙。"]},{"id":"t48-584","title":"明经进士语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["三十老明经，五十少进士。"]},{"id":"t48-585","title":"杂帖语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["常杂鲍帖。"]},{"id":"t48-586","title":"闽人语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["欧阳独步，藻蕴横行。"]},{"id":"t48-587","title":"举场语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["欲入举场，先问苏张。","苏张犹可，三杨杀我。"]},{"id":"t48-588","title":"大中后进士语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["欲得命通，问瑝嵎都雍。"]},{"id":"t48-589","title":"大中时语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["郑杨段薛，炙手可热。","欲得命通，鲁绍瓌蒙。"]},{"id":"t48-590","title":"选举人语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["王凝裴瓒，舍弟安潜。","朝中无呼字，知闻厅里，绝脱鞾宾客。"]},{"id":"t48-591","title":"科目举人语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["未见王窦，徒劳漫走。"]},{"id":"t48-592","title":"戏杜审权语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["座主审权，门生处权。"]},{"id":"t48-593","title":"崔沆放牓时人语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["座主门生，沆瀣一家。"]},{"id":"t48-594","title":"唐末五代人语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["及第不必读书，作官何须事业。"]},{"id":"t48-595","title":"号沈宋语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["苏李居前，沈宋比肩。"]},{"id":"t48-596","title":"号钱郎语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["前有沈宋，后有钱郎。"]},{"id":"t48-597","title":"潘何诗赋语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["潘纬十年吟古镜，何涓一夜赋潇湘。"]},{"id":"t48-598","title":"魏薛草书语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["前有虞褚，后有薛魏。"]},{"id":"t48-599","title":"薛稷书语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["买褚得薛不落节。"]}]