{"任华":{"slug":"任华","name":"任华","dynasty":"唐","style":"","life":"","origin":"","seal":"任","bio":["任华，李、杜同时人。初为桂州刺史参佐，尝与贾京尹、杜中丞，严大夫牋多所致责。又《与庾中丞书》云：“华本野人，常思渔钓，寻当杖策，归乎旧山，非有机心，致斯扣击，其亦狂狷之流欤。","”诗三首。"],"works":[{"id":"t13-584","title":"寄李白","kind":"诗"},{"id":"t13-585","title":"寄杜拾遗","kind":"诗"},{"id":"t13-586","title":"怀素上人草书歌","kind":"诗"}]},"刘知几":{"slug":"刘知几","name":"刘知几","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":["刘知几，后名子玄，以词学知名。弱冠举进士，授获嘉主簿。证圣中，诏九品以上各言时政，知几上陈四事，词甚切直。","累迁左史，擢凤阁舍人。景龙初，转太子中允，仍修国史。时监修者多，知几奏记萧至忠言五不可，以为汗青无日，头白可期。","又著《史通》二十卷，备论史策之体。徐坚重其书，谓居史职者宜置座右。景云中，迁太子左庶子，兼崇文馆学土。","开元初，为左散骑常侍。在史职二十年，尝对郑惟忠曰：“史才须有三长，才也、学也、识也。”时人以为知言。","诗一首。"],"works":[{"id":"t4-982","title":"仪坤庙乐章","kind":"诗"},{"id":"t50-155","title":"次河神庙虞参军船先发余阻风不进寒夜旅泊（斯二七一七下同）","kind":"诗"},{"id":"t50-156","title":"读《汉书》作","kind":"诗"},{"id":"t50-157","title":"咏史","kind":"诗"}]},"卓英英":{"slug":"卓英英","name":"卓英英","dynasty":"唐","style":"","life":"","origin":"","seal":"卓","bio":["卓英英，成都女郎《万首绝句》采入宫闺，以与眉娘、玄士倡和，故载于此。"],"works":[{"id":"t47-839","title":"锦城春望","kind":"诗"},{"id":"t47-840","title":"理笙","kind":"诗"},{"id":"t47-841","title":"游福感寺荅少年","kind":"诗"},{"id":"t47-842","title":"荅玄士","kind":"诗"}]},"姜个翁":{"slug":"姜个翁","name":"姜个翁","dynasty":"宋","style":"","life":"","origin":"","seal":"姜","bio":[],"works":[{"id":"c76-459","title":"霓裳中序第一·园林罢组织","kind":"词"}]},"安锜":{"slug":"安锜","name":"安锜","dynasty":"唐","style":"","life":"","origin":"","seal":"安","bio":["安锜，普州从事。诗一首。"],"works":[{"id":"t42-911","title":"题贾岛墓","kind":"诗"}]},"寿涯禅师":{"slug":"寿涯禅师","name":"寿涯禅师","dynasty":"宋","style":"","life":"","origin":"","seal":"寿","bio":[],"works":[{"id":"c58-682","title":"渔家傲·深愿弘慈无缝罅","kind":"词"}]},"庞德公":{"slug":"庞德公","name":"庞德公","dynasty":"唐","style":"","life":"","origin":"","seal":"庞","bio":[],"works":[{"id":"t47-997","title":"同鹿门少年马绍隆冥游诗 一","kind":"诗"},{"id":"t47-998","title":"同鹿门少年马绍隆冥游诗 二","kind":"诗"}]},"庾抱":{"slug":"庾抱","name":"庾抱","dynasty":"唐","style":"","life":"","origin":"","seal":"庾","bio":["庾抱，润州江宁人，有学术，隋元德太子学士。高祖初起，隐太子引为陇西公府记室，文檄皆出其手，转太子舍人。集十卷，今存诗五首。"],"works":[{"id":"t2-705","title":"骢马","kind":"诗"},{"id":"t2-706","title":"别蔡参军","kind":"诗"},{"id":"t2-707","title":"赋得胥台露","kind":"诗"},{"id":"t2-708","title":"卧疴喜霁开扉望月简宫内知友","kind":"诗"},{"id":"t2-709","title":"和乐记室忆江水","kind":"诗"},{"id":"t51-987","title":"咏史得韩非","kind":"诗"}]},"惟劲":{"slug":"惟劲","name":"惟劲","dynasty":"唐","style":"号宝文大师","life":"","origin":"","seal":"惟","bio":["惟劲，福州永泰人。嗣灵峰，光化中入南岳，住报慈东藏，迁般舟道场。开平中撰《续宝林传》四卷及《南岳高僧传》。","马殷迎入府中，赐号宝文大师。诗四首。（《全唐诗》无惟劲诗，传据《祖堂集》卷十一、《宋高僧传》卷十七、《景德传灯录》卷十九。","）"],"works":[{"id":"t55-945","title":"赞镜灯颂","kind":"诗"},{"id":"t55-946","title":"述象骨偈","kind":"诗"},{"id":"t55-947","title":"学道颂","kind":"诗"},{"id":"t55-948","title":"觉地颂","kind":"诗"}]},"李祁":{"slug":"李祁","name":"李祁","dynasty":"宋","style":"字萧远","life":"","origin":"雍丘（今河南县）","seal":"李","bio":["--字萧远，雍丘 (今河南县) 人。登进士，官至尚书郎。宣和间，责监汉阳酒税。","词存《乐府雅词》中。"],"works":[{"id":"c64-207","title":"减字木兰花·梨花院宇","kind":"词"},{"id":"c64-208","title":"点绛唇·楼下清歌","kind":"词"},{"id":"c64-209","title":"青玉案·绿琐窗纱明月透","kind":"词"},{"id":"c64-210","title":"鹊桥仙·春阴淡淡","kind":"词"},{"id":"c64-211","title":"阮郎归·校书学士小蓬山","kind":"词"},{"id":"c64-212","title":"南歌子·袅袅秋风起","kind":"词"},{"id":"c64-213","title":"醉桃源・阮郎归·春风碧水满郎湖","kind":"词"},{"id":"c64-214","title":"朝中措·郎官湖上探春回","kind":"词"},{"id":"c64-215","title":"西江月·拾翠亭前水满","kind":"词"},{"id":"c64-216","title":"西江月·云观三山清露","kind":"词"},{"id":"c64-217","title":"如梦令·春水湖塘深处","kind":"词"},{"id":"c64-218","title":"如梦令·不见玉人清晓","kind":"词"},{"id":"c64-219","title":"水龙吟·碧山横绕清湖","kind":"词"},{"id":"c64-220","title":"浪淘沙·拍手趁西风","kind":"词"}]},"杨奇鲲":{"slug":"杨奇鲲","name":"杨奇鲲","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":["杨奇鲲，南诏宰相，有词藻。僖宗幸蜀时，来朝行在。诗一首。"],"works":[{"id":"t41-157","title":"途中诗","kind":"诗"},{"id":"t54-176","title":"岩嵌绿玉","kind":"诗"}]},"杨师道":{"slug":"杨师道","name":"杨师道","dynasty":"唐","style":"字景猷","life":"","origin":"","seal":"杨","bio":["杨师道，字景猷，华阴人，隋宗室也，清警有才思。入唐，尚桂阳公主，封安德郡公。贞观中，拜侍中，参豫朝政，迁中书令，罢为吏部尚书，师道善草隶，工诗，每与有名士燕集，歌咏自适，帝每见其诗，必吟讽嗟赏。","后赐宴，帝曰：“闻公每酣赏，捉笔赋诗，如宿搆者，试为朕为之。”师道再拜，少选辄成，无所窜定，一座嗟伏，卒谥曰懿。集十卷，今编诗一卷。"],"works":[{"id":"t0-917","title":"横吹曲辞 陇头水","kind":"诗"},{"id":"t2-519","title":"陇头水","kind":"诗"},{"id":"t2-520","title":"中书寓直咏雨简褚起居上官学士","kind":"诗"},{"id":"t2-521","title":"阙题","kind":"诗"},{"id":"t2-522","title":"初秋夜坐应诏","kind":"诗"},{"id":"t2-523","title":"赋终南山用风字韵应诏","kind":"诗"},{"id":"t2-524","title":"咏饮马应诏","kind":"诗"},{"id":"t2-525","title":"初宵看婚","kind":"诗"},{"id":"t2-526","title":"侍宴赋得起坐弹鸣琴二首 一","kind":"诗"},{"id":"t2-527","title":"侍宴赋得起坐弹鸣琴二首 二","kind":"诗"},{"id":"t2-528","title":"咏琴","kind":"诗"},{"id":"t2-529","title":"咏笙","kind":"诗"},{"id":"t2-530","title":"应诏咏巢乌","kind":"诗"},{"id":"t2-531","title":"奉和夏日晚景应诏","kind":"诗"},{"id":"t2-532","title":"奉和圣制春日望海","kind":"诗"},{"id":"t2-533","title":"春朝闲步","kind":"诗"},{"id":"t2-534","title":"还山宅","kind":"诗"},{"id":"t2-535","title":"咏马","kind":"诗"},{"id":"t2-536","title":"奉和咏弓","kind":"诗"},{"id":"t2-537","title":"咏砚","kind":"诗"},{"id":"t2-538","title":"奉和正日临朝应诏","kind":"诗"},{"id":"t2-539","title":"咏舞","kind":"诗"},{"id":"t49-945","title":"采莲","kind":"诗"},{"id":"t52-80","title":"五言早秋[仪鸾殿]侍宴应诏","kind":"诗"},{"id":"t52-81","title":"五言奉和行经破薛举战地应诏","kind":"诗"}]},"灵澈":{"slug":"灵澈","name":"灵澈","dynasty":"唐","style":"字源澄","life":"","origin":"","seal":"灵","bio":["灵澈，字源澄，姓汤氏，会稽人，云门寺律僧也。少从严维学为诗，后至吴兴，与僧皎然游。贞元中，皎然荐之包佶，又荐之李纾，名振辇下。","缁流嫉之，造飞语激中贵人，贬徙汀州，会赦归乡。诗一卷，今存十六首。灵澈，字源澄，姓汤氏，会稽人，云门寺律僧也。","少从严维学为诗，后至吴兴，与僧皎然游。贞元中，皎然荐之包佶，又荐之李纾。名振辇下，缁流嫉之，造飞语激中贵人，贬徙汀州，会赦归乡。","诗一卷，今存十六首。"],"works":[{"id":"t44-751","title":"听莺歌","kind":"诗"},{"id":"t44-752","title":"归湖南作","kind":"诗"},{"id":"t44-753","title":"初到汀州","kind":"诗"},{"id":"t44-754","title":"九日和于使君思上京亲故","kind":"诗"},{"id":"t44-755","title":"送道虔上人游方","kind":"诗"},{"id":"t44-756","title":"送鉴供奉归蜀宁亲","kind":"诗"},{"id":"t44-757","title":"天姥岑望天台山","kind":"诗"},{"id":"t44-758","title":"远公墓","kind":"诗"},{"id":"t44-759","title":"宿东林寺","kind":"诗"},{"id":"t44-760","title":"简寂观","kind":"诗"},{"id":"t44-761","title":"元日观郭