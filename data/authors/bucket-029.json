{"乐仲卿":{"slug":"乐仲卿","name":"乐仲卿","dynasty":"唐","style":"","life":"","origin":"","seal":"乐","bio":[],"works":[{"id":"t50-214","title":"咏萤","kind":"诗"}]},"刘之翰":{"slug":"刘之翰","name":"刘之翰","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c66-995","title":"水调歌头·凉露洗金井","kind":"词"}]},"刘仲讷":{"slug":"刘仲讷","name":"刘仲讷","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c78-581","title":"水调歌头·昨夜乘秋兴","kind":"词"}]},"姚康":{"slug":"姚康","name":"姚康","dynasty":"唐","style":"字汝谐","life":"","origin":"","seal":"姚","bio":["姚康，字汝谐，下邽人。登元和十五年进士第，试右武卫曹参军、剑南观察推官。大中时，终太子詹事。","诗四首。"],"works":[{"id":"t17-569","title":"奉陪段相公晚夏登张仪楼","kind":"诗"},{"id":"t17-570","title":"和段相公登武担寺西台","kind":"诗"},{"id":"t17-571","title":"礼部试早春残雪","kind":"诗"},{"id":"t17-572","title":"赋得巨鱼纵大壑","kind":"诗"}]},"尚宫宋氏若昭":{"slug":"尚宫宋氏若昭","name":"尚宫宋氏若昭","dynasty":"唐","style":"","life":"","origin":"","seal":"尚","bio":["穆宗拜若昭尚宫，嗣若华秩，历穆敬文三朝，皆呼先生，进封梁国夫人。诗一首。"],"works":[{"id":"t0-309","title":"奉和御制麟德殿宴百僚应制","kind":"诗"}]},"左偃":{"slug":"左偃","name":"左偃","dynasty":"唐","style":"","life":"","origin":"","seal":"左","bio":["左偃，南唐人，不仕，居金陵。能诗，有《钟山集》一卷，今存诗十首。"],"works":[{"id":"t41-523","title":"寄庐山白上人","kind":"诗"},{"id":"t41-524","title":"寄韩侍郎","kind":"诗"},{"id":"t41-525","title":"汉宫词","kind":"诗"},{"id":"t41-526","title":"送君去","kind":"诗"},{"id":"t41-527","title":"秋晚野望","kind":"诗"},{"id":"t41-528","title":"郊原晚望怀李秘书","kind":"诗"},{"id":"t41-529","title":"言怀别同志","kind":"诗"},{"id":"t41-530","title":"江上晚泊","kind":"诗"},{"id":"t41-531","title":"寄鉴上人","kind":"诗"},{"id":"t41-532","title":"送人","kind":"诗"},{"id":"t41-533","title":"句","kind":"诗"},{"id":"t55-425","title":"怀海上故人","kind":"诗"},{"id":"t55-426","title":"落花","kind":"诗"}]},"张正一":{"slug":"张正一","name":"张正一","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张正一，德宗末左补阙，以上书召见，王叔文之党疑其言己阴事，令韦执谊谮之，坐贬。诗一首。"],"works":[{"id":"t17-94","title":"和武相公中秋锦楼玩月得苍字","kind":"诗"}]},"徐元杰":{"slug":"徐元杰","name":"徐元杰","dynasty":"宋","style":"","life":"","origin":"","seal":"徐","bio":[],"works":[{"id":"c73-423","title":"满江红·似玉仙人","kind":"词"}]},"杜淹":{"slug":"杜淹","name":"杜淹","dynasty":"唐","style":"字执礼","life":"","origin":"","seal":"杜","bio":["杜淹，字执礼，隋时隐太山。文帝恶之，谪戍江表，秦王引为天策府曹参军，文学馆学士，侍宴，赋诗尤工，赐金钟，坐事流嶲州。太宗召拜御史大夫，检校吏部尚书，参预朝政。","诗三首。"],"works":[{"id":"t2-421","title":"召拜御史大夫赠袁天纲","kind":"诗"},{"id":"t2-422","title":"咏寒食鬬鸡应秦王教","kind":"诗"},{"id":"t2-423","title":"寄赠齐公","kind":"诗"}]},"杨容华":{"slug":"杨容华","name":"杨容华","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":["杨容华，华阴人，炯之绖女。诗一首。"],"works":[{"id":"t43-919","title":"新妆诗","kind":"诗"}]},"殷尧恭":{"slug":"殷尧恭","name":"殷尧恭","dynasty":"唐","style":"","life":"","origin":"","seal":"殷","bio":["殷尧恭，元和间人。诗一首。"],"works":[{"id":"t25-232","title":"府试中元观道流步虚","kind":"诗"}]},"贾岛":{"slug":"贾岛","name":"贾岛","dynasty":"唐","style":"字浪一作阆仙","life":"","origin":"","seal":"贾","bio":["贾岛，字浪一作阆仙，范阳人。初为浮屠，名无本。来东都时，洛阳令禁僧午后不得出，岛为诗自伤，韩愈怜之，因教其为文，遂去浮屠，举进士。","诗思入僻，当其苦吟，虽逢公卿贵人，不之觉也。累举不中第，文宗时，坐飞谤，贬长江主簿。会昌初，以普州司仓参军迁司户，未受命卒。","有《长江集》十卷，小集三卷，今编诗四卷。贾岛，字浪一作阆仙，范阳人。初为浮屠，名无本。","来东都时，洛阳令禁僧午后不得出，岛为诗自伤，韩愈怜之，因教其为文。遂去浮屠，举进士。诗思入僻，当其苦吟，虽逢公卿贵人，不之觉也。","累举不中第。文宗时，坐飞谤，贬长江主簿。会昌初，以普州司仓参军迁司户，未受命卒。","有长江集十卷，小集三卷，今编诗四卷。贾岛字浪仙，范阳人。初为僧，法名无本。","韩愈重其才，劝之还俗。文宗时为长江（属剑南道遂州）主簿，后改普州（亦属剑南道）司仓参军。武宗会昌三年七月卒，年六十四（据苏绛撰《唐故司仓参军贾公墓志铭》）。","补诗一首。"],"works":[{"id":"t1-732","title":"杂曲歌辞 壮士吟","kind":"诗"},{"id":"t31-710","title":"古意","kind":"诗"},{"id":"t31-711","title":"望山","kind":"诗"},{"id":"t31-712","title":"北岳庙","kind":"诗"},{"id":"t31-713","title":"朝饥","kind":"诗"},{"id":"t31-714","title":"哭卢仝","kind":"诗"},{"id":"t31-715","title":"剑客","kind":"诗"},{"id":"t31-716","title":"口号","kind":"诗"},{"id":"t31-717","title":"寄远","kind":"诗"},{"id":"t31-718","title":"斋中","kind":"诗"},{"id":"t31-719","title":"感秋","kind":"诗"},{"id":"t31-720","title":"玩月","kind":"诗"},{"id":"t31-721","title":"辞二知己","kind":"诗"},{"id":"t31-722","title":"义雀行和朱评事","kind":"诗"},{"id":"t31-723","title":"宿悬泉驿","kind":"诗"},{"id":"t31-724","title":"辩士","kind":"诗"},{"id":"t31-725