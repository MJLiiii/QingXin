{"slug":"蒋防","name":"蒋防","dynasty":"唐","style":"","life":"","origin":"","seal":"蒋","bio":["蒋防，义兴人，官右拾遗。元和中，李绅荐为司封郎中、知制诰，进翰林学士。李逢吉逐绅，因出防为汀州刺史。","集一卷，今存诗十二首。"],"works":[{"id":"t27-286","title":"题杜宾客新丰里幽居","kind":"诗"},{"id":"t27-287","title":"望禁苑祥光","kind":"诗"},{"id":"t27-288","title":"冬至日祥风应候","kind":"诗"},{"id":"t27-289","title":"春风扇微和","kind":"诗"},{"id":"t27-290","title":"日暖万年枝","kind":"诗"},{"id":"t27-291","title":"秋月悬清辉","kind":"诗"},{"id":"t27-292","title":"八风从律","kind":"诗"},{"id":"t27-293","title":"藩臣恋魏阙","kind":"诗"},{"id":"t27-294","title":"[秋]稼如云","kind":"诗"},{"id":"t27-295","title":"玉巵无当","kind":"诗"},{"id":"t27-296","title":"至人无梦","kind":"诗"},{"id":"t27-297","title":"玄都楼桃","kind":"诗"},{"id":"t51-355","title":"灵岩洞","kind":"诗"},{"id":"t53-474","title":"临蒸诸葛亮宅（题拟）","kind":"诗"}]}