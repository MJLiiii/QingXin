今编诗一卷。"],"works":[{"id":"t0-0","title":"帝京篇十首 一","kind":"诗"},{"id":"t0-1","title":"帝京篇十首 二","kind":"诗"},{"id":"t0-2","title":"帝京篇十首 三","kind":"诗"},{"id":"t0-3","title":"帝京篇十首 四","kind":"诗"},{"id":"t0-4","title":"帝京篇十首 五","kind":"诗"},{"id":"t0-5","title":"帝京篇十首 六","kind":"诗"},{"id":"t0-6","title":"帝京篇十首 七","kind":"诗"},{"id":"t0-7","title":"帝京篇十首 八","kind":"诗"},{"id":"t0-8","title":"帝京篇十首 九","kind":"诗"},{"id":"t0-9","title":"帝京篇十首 十","kind":"诗"},{"id":"t0-10","title":"饮马长城窟行","kind":"诗"},{"id":"t0-11","title":"执契静三边","kind":"诗"},{"id":"t0-12","title":"正日临朝","kind":"诗"},{"id":"t0-13","title":"幸武功庆善宫","kind":"诗"},{"id":"t0-14","title":"重幸武功","kind":"诗"},{"id":"t0-15","title":"经破薛举战地","kind":"诗"},{"id":"t0-16","title":"过旧宅二首 一","kind":"诗"},{"id":"t0-17","title":"过旧宅二首 二","kind":"诗"},{"id":"t0-18","title":"还陕述怀","kind":"诗"},{"id":"t0-19","title":"入潼关","kind":"诗"},{"id":"t0-20","title":"于北平作","kind":"诗"},{"id":"t0-21","title":"辽城望月","kind":"诗"},{"id":"t0-22","title":"春日登陕州城楼俯眺原野回丹碧缀烟霞密翠斑红芳菲花柳即目川岫聊以命篇","kind":"诗"},{"id":"t0-23","title":"春日玄武门宴群臣","kind":"诗"},{"id":"t0-24","title":"登三台言志","kind":"诗"},{"id":"t0-25","title":"出猎","kind":"诗"},{"id":"t0-26","title":"冬狩","kind":"诗"},{"id":"t0-27","title":"春日望海","kind":"诗"},{"id":"t0-28","title":"临洛水","kind":"诗"},{"id":"t0-29","title":"望终南山","kind":"诗"},{"id":"t0-30","title":"元日","kind":"诗"},{"id":"t0-31","title":"初春登楼即目观作述怀","kind":"诗"},{"id":"t0-32","title":"首春","kind":"诗"},{"id":"t0-33","title":"初晴落景","kind":"诗"},{"id":"t0-34","title":"初夏","kind":"诗"},{"id":"t0-35","title":"度秋","kind":"诗"},{"id":"t0-36","title":"仪鸾殿早秋","kind":"诗"},{"id":"t0-37","title":"秋日即目","kind":"诗"},{"id":"t0-38","title":"山阁晚秋","kind":"诗"},{"id":"t0-39","title":"秋暮言志","kind":"诗"},{"id":"t0-40","title":"喜雪","kind":"诗"},{"id":"t0-41","title":"秋日斅庾信体","kind":"诗"},{"id":"t0-42","title":"赋尚书","kind":"诗"},{"id":"t0-43","title":"咏司马彪续汉志","kind":"诗"},{"id":"t0-44","title":"咏风","kind":"诗"},{"id":"t0-45","title":"咏雨","kind":"诗"},{"id":"t0-46","title":"咏雪","kind":"诗"}