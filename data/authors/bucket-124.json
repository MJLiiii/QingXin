,"origin":"","seal":"柳","bio":["柳氏，李生姬也。天宝中，韩翃馆于李，柳曰：“韩夫子岂长贫贱者。”李即以赠翃，翃为淄青侯希逸所辟。","柳留都下，遭乱，寄决灵寺为尼。为番将沙咤利所劫，虞候许俊以计取之，复归于翃。诗一首。"],"works":[{"id":"t43-976","title":"荅韩翃","kind":"诗"},{"id":"t49-899","title":"杨柳枝","kind":"诗"}]},"梅坡":{"slug":"梅坡","name":"梅坡","dynasty":"宋","style":"","life":"","origin":"","seal":"梅","bio":[],"works":[{"id":"c76-387","title":"鹊桥仙·华桐日永","kind":"词"},{"id":"c76-388","title":"满江红·天佑生贤","kind":"词"},{"id":"c76-389","title":"水调歌头·五月进农黍","kind":"词"},{"id":"c76-390","title":"千秋岁引·两叶蓂开","kind":"词"}]},"楼":{"slug":"楼","name":"楼","dynasty":"宋","style":"","life":"","origin":"","seal":"楼","bio":[],"works":[{"id":"c73-389","title":"霜天晓角·月淡风轻","kind":"词"},{"id":"c73-390","title":"霜天晓角·翦雪裁冰","kind":"词"}]},"水心寺僧":{"slug":"水心寺僧","name":"水心寺僧","dynasty":"唐","style":"","life":"","origin":"","seal":"水","bio":[],"works":[{"id":"t47-223","title":"赠贾松先辈","kind":"诗"}]},"沈与求":{"slug":"沈与求","name":"沈与求","dynasty":"宋","style":"","life":"","origin":"","seal":"沈","bio":[],"works":[{"id":"c64-426","title":"浣溪沙·云幕垂垂不掩关","kind":"词"},{"id":"c64-427","title":"浣溪沙·花信催春入帝关","kind":"词"},{"id":"c64-428","title":"江城子·华灯高宴水精宫","kind":"词"},{"id":"c64-429","title":"江城子·鱼龙戏舞近幽宫","kind":"词"}]},"程弥纶":{"slug":"程弥纶","name":"程弥纶","dynasty":"唐","style":"","life":"","origin":"","seal":"程","bio":["程弥纶，开宝间进士。诗一首。"],"works":[{"id":"t10-26","title":"怀鲁","kind":"诗"}]},"英才":{"slug":"英才","name":"英才","dynasty":"唐","style":"","life":"","origin":"","seal":"英","bio":[],"works":[{"id":"t51-444","title":"明月湖醉后蔷薇花歌（《文苑英华》三三七《歌行》。《全唐诗》七八五无名氏第一首）（〖1〗《文苑英华》录诗皆署作者姓名，不署字，此说恐未允。）","kind":"诗"}]},"萧颖士":{"slug":"萧颖士","name":"萧颖士","dynasty":"唐","style":"字茂挺 · 号萧夫子","life":"","origin":"","seal":"萧","bio":["萧颖士，字茂挺。开元中，对策第一，补秘书正字。奉使括遗书赵卫间，淹久不报，为有司劾免，留客濮阳教授，时号萧夫子。","召为集贤校理，宰相李林甫怒其不下己，调广陵参军事。史官韦述荐颖士自代，召诣史馆待制。林甫愈见疾，遂免官。","寻调河南府参军事，山南节度使源洧辟掌书记。洧卒，崔圆署为扬州功曹参军，至官信宿去。后客死汝南逆旅，门人私谥曰文元先生。","颖士乐闻人善，以推引后进为己任，所奖目皆为名士。集十卷，今编诗一卷。"],"works":[{"id":"t7-562","title":"江有枫一篇十章 一","kind":"诗"},{"id":"t7-563","title":"江有枫一篇十章 二","kind":"诗"},{"id":"t7-564","title":"江有枫一篇十章 三","kind":"诗"},{"id":"t7-565","title":"江有枫一篇十章 四","kind":"诗"},{"id":"t7-566","title":"江有枫一篇十章 五","kind":"诗"},{"id":"t7-567","title":"江有枫一篇十章 六","kind":"诗"},{"id":"t7-568","title":"江有枫一篇十章 七","kind":"诗"},{"id":"t7-569","title":"江有枫一篇十章 八","kind":"诗"},{"id":"t7-570","title":"江有枫一篇十章 九","kind":"诗"},{"id":"t7-571","title":"江有枫一篇十章 十","kind":"诗"},{"id":"t7-572","title":"菊荣一篇五章 一","kind":"诗"},{"id":"t7-573","title":"菊荣一篇五章 二","kind":"诗"},{"id":"t7-574","title":"菊荣一篇五章 三","kind":"诗"},{"id":"t7-575","title":"菊荣一篇五章 四","kind":"诗"},{"id":"t7-576","title":"菊荣一篇五章 五","kind":"诗"},{"id":"t7-577","title":"凉雨一章","kind":"诗"},{"id":"t7-578","title":"有竹一篇七章","kind":"诗"},{"id":"t7-579","title":"有竹一篇七章 一","kind":"诗"},{"id":"t7-580","title":"有竹一篇七章 二","kind":"诗"},{"id":"t7-581","title":"有竹一篇七章 三","kind":"诗"},{"id":"t7-582","title":"有竹一篇七章 四","kind":"诗"},{"id":"t7-583","title":"有竹一篇七章 五","kind":"诗"},{"id":"t7-584","title":"有竹一篇七章 六","kind":"诗"},{"id":"t7-585","title":"有竹一篇七章 七","kind":"诗"},{"id":"t7-586","title":"江有归舟三章 一","kind":"诗"},{"id":"t7-587","title":"江有归舟三章 二","kind":"诗"},{"id":"t7-588","title":"江有归舟三章 三","kind":"诗"},{"id":"t7-589","title":"过河滨和文学张志尹","kind":"诗"},{"id":"t7-590","title":"舟中遇陆棣兄西归数日得广陵二三子书知迟晚次沙垫西岸作","kind":"诗"},{"id":"t7-591","title":"重阳日陪元鲁山德秀登北城瞩对新霁因以赠别","kind":"诗"},{"id":"t7-592","title":"留别二三子得韵字","kind":"诗"},{"id":"t7-593","title":"仰荅韦司业垂访五首 一","kind":"诗"},{"id":"t7-594","title":"仰荅韦司业垂访五首 二","kind":"诗"},{"id":"t7-595","title":"仰荅韦司业垂访五首 三","kind":"诗"},{"id":"t7-596","title":"仰荅韦司业垂访五首 四","kind":"诗"},{"id":"t7-597","title":"仰荅韦司业垂访五首 五","kind":"诗"},{"id":"t7-598","title":"答邹象先","kind":"诗"},{"id":"t7-599","title":"蒙山作","kind":"诗"},{"id":"t7-600","title":"早春过七岭寄题硖石裴丞厅壁","kind":"诗"},{"id":"t7-601","title":"送张翚下第归江东","kind":"诗"},{"id":"t7-602","title":"越江秋曙","kind":"诗"},{"id":"t7-603","title":"山庄月夜作","kind":"诗"}]},"蒋钧":{"slug":"蒋钧","name":"蒋钧","dynasty":"唐","style":"","life":"","origin":"","seal":"蒋","bio":[],"works":[{"id":"t43-692","title":"句","kind":"诗"},{"id":"t55-962","title":"孤雁","kind":"诗"}]},"韦处厚":{"slug":"韦处厚","name":"韦处厚","dynasty":"唐","style":"字德成","life":"","origin":"","seal":"韦","bio":["韦处厚，字德成，京兆人。元和初登第，又擢贤良方正异等，授秘书郎，兼史职，改咸阳尉，迁右拾遗，转考功员外，出为开州刺史，入拜户部郎中、知制诰。穆宗召入翰林为侍讲学士，改中书舍人。","文宗即位，拜兵部侍郎，寻以中书侍郎同平章事。集七十卷，今存诗十二首。"],"works":[{"id":"t25-710","title":"盛山十二诗 隐月岫","kind":"诗"},{"id":"t25-711","title":"盛山十二诗 流桮渠","kind":"诗"},{"id":"t25-712","title":"盛山十二诗 竹岩","kind":"诗"},{"id":"t25-713","title":"盛山十二诗 绣衣石榻","kind":"诗"},{"id":"t25-714","title":"盛山十二诗 宿云亭","kind":"诗"},{"id":"t25-715","title":"盛山十二诗 梅溪","kind":"诗"},{"id":"t25-716","title":"盛山十二诗 桃坞","kind":"诗"},{"id":"t25-717","title":"盛山十二诗 胡卢沼","kind":"诗"},{"id":"t25-718","title":"盛山十二诗 茶岭","kind":"诗"},{"id":"t25-719","title":"盛山十二诗 盘石磴","kind":"诗"},{"id":"t25-720","title":"盛山十二诗 琵琶台","kind":"诗"},{"id":"t25-721","title":"盛山十二诗 上士缾泉","kind":"诗"},{"id":"t53-511","title":"秪（疑当作「抵」）剡","kind":"诗"},{"id":"t53-512","title":"又","kind":"诗"},{"id":"t53-513","title":"句","kind":"诗"}]},"马周":{"slug":"马周","name":"马周","dynasty":"唐","style":"字宾王","life":"","origin":"何武","seal":"马","bio":["马周，字宾王，清河茌平人。孤贫好学，尤精诗传。初入关，舍中郎将常何家。","贞观中，代为草疏。何武人，上怪其能，对以臣家客马周为之，召见大悦，授监察御史，数言事，无不嘉纳，累迁中书令。太宗尝赐以飞白书曰：“鸾凤凌云，必资羽翼，股肱之寄，诚在忠良。","”集十卷，今存诗一首。"],"works":[{"id":"t2-710","title":"凌朝浮江旅思","kind":"诗"},{"id":"t2-711","title":"句","kind":"诗"}]}}