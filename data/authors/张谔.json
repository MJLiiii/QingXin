{"slug":"张谔","name":"张谔","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张谔，景龙中登进士第，仕为陈王掾。岐王范雅好儒士，谔与阎朝隐、刘庭琦、郑繇等皆从之游，赋诗饮酒，后坐贬山茌丞。诗十二首。"],"works":[{"id":"t5-406","title":"百子池","kind":"诗"},{"id":"t5-407","title":"东封山下宴群臣","kind":"诗"},{"id":"t5-408","title":"三日岐王宅","kind":"诗"},{"id":"t5-409","title":"满月","kind":"诗"},{"id":"t5-410","title":"岐王山亭","kind":"诗"},{"id":"t5-411","title":"岐王席上咏美人","kind":"诗"},{"id":"t5-412","title":"还京","kind":"诗"},{"id":"t5-413","title":"赠吏部孙员外济","kind":"诗"},{"id":"t5-414","title":"送李著作倅杭州","kind":"诗"},{"id":"t5-415","title":"九日","kind":"诗"},{"id":"t5-416","title":"延平门高斋亭子应岐王教","kind":"诗"},{"id":"t5-417","title":"九日宴","kind":"诗"},{"id":"t49-947","title":"句","kind":"诗"}]}