{"slug":"卞震","name":"卞震","dynasty":"唐","style":"","life":"","origin":"","seal":"卞","bio":["卞震，成都人。蜀进士，为渝州判。蜀平，入宋，仍旧职。","补句二。"],"works":[{"id":"t43-730","title":"句","kind":"诗"},{"id":"t50-991","title":"句（《吟窗杂录》卷三一《历代吟谱》引此二句，题作《秋夕诗》。）","kind":"诗"},{"id":"t56-285","title":"忆鹳诗","kind":"诗"},{"id":"t56-286","title":"途中诗","kind":"诗"},{"id":"t56-287","title":"寄陈抟诗","kind":"诗"},{"id":"t56-288","title":"东郊诗","kind":"诗"}]}