-967","title":"贺新郎·鹄立通明殿","kind":"词"},{"id":"c70-968","title":"鱼游春水·湖南三千里","kind":"词"},{"id":"c70-969","title":"水调歌头·万里碧鸡使","kind":"词"},{"id":"c70-970","title":"酹江月・念奴娇·汉庭用老","kind":"词"},{"id":"c70-971","title":"满庭芳·郑履声传","kind":"词"},{"id":"c70-972","title":"生查子·湘江贯地维","kind":"词"},{"id":"c70-973","title":"浣溪沙·濯锦江边玉树明","kind":"词"},{"id":"c70-974","title":"朝中措·我生辰在斗牛中","kind":"词"},{"id":"c70-975","title":"水调歌头·端正九秋月","kind":"词"},{"id":"c70-976","title":"鹧鸪天·恰则重阳信宿前","kind":"词"},{"id":"c70-977","title":"生查子·万里彩衣远","kind":"词"}]},"李崇嗣":{"slug":"李崇嗣","name":"李崇嗣","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李崇嗣，则天时奉宸府主簿。圣历中，曾奉敕预东观修书，见沈佺期《黄口赞序》。诗三首。"],"works":[{"id":"t5-213","title":"寒食","kind":"诗"},{"id":"t5-214","title":"览镜","kind":"诗"},{"id":"t5-215","title":"独愁","kind":"诗"}]},"李甘":{"slug":"李甘","name":"李甘","dynasty":"唐","style":"字和鼎","life":"","origin":"","seal":"李","bio":["李甘，字和鼎，长庆末进士擢第。太和中，官侍御史，贬封州司马。集一卷，今存诗一首。"],"works":[{"id":"t27-357","title":"九成宫","kind":"诗"}]},"来鹏":{"slug":"来鹏","name":"来鹏","dynasty":"唐","style":"","life":"","origin":"","seal":"来","bio":["来鹏，豫章人。家徐孺子亭边，林园自乐，师韩柳为文。咸通间，举进士不第。","广明中，避地荆襄，中和间客死于维扬逆旅，主人收葬之。补诗一首。"],"works":[{"id":"t50-885","title":"牡丹","kind":"诗"},{"id":"t54-183","title":"水仙花（题拟） 一","kind":"诗"},{"id":"t54-184","title":"水仙花（题拟） 二","kind":"诗"}]},"柳公权":{"slug":"柳公权","name":"柳公权","dynasty":"唐","style":"字诚悬","life":"","origin":"","seal":"柳","bio":["柳公权，字诚悬，公绰之弟，精于书学。元和初，擢进士第。穆宗时，拜右拾遗、侍书学士，改弘文馆学士。","文宗复召侍书，寻以谏议为学士、知制诰，转工部侍郎。咸通初，改太子少师。诗五首。"],"works":[{"id":"t25-703","title":"应制贺边军支春衣 一","kind":"诗"},{"id":"t25-704","title":"应制贺边军支春衣 二","kind":"诗"},{"id":"t25-705","title":"应制为宫嫔咏","kind":"诗"},{"id":"t25-706","title":"题朱审寺壁山水画","kind":"诗"},{"id":"t25-707","title":"阊门即事","kind":"诗"},{"id":"t51-377","title":"砥柱","kind":"诗"}]},"王邵":{"slug":"王邵","name":"王邵","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"t43-0","title":"冬晚对雪忆胡处士","kind":"诗"}]},"甄后":{"slug":"甄后","name":"甄后","dynasty":"唐","style":"","life":"","origin":"","seal":"甄","bio":[],"works":[{"id":"t48-40","title":"与萧旷冥会诗 一","kind":"诗"},{"id":"t48-41","title":"与萧旷冥会诗 二","kind":"诗"},{"id":"t48-42","title":"与萧旷冥会诗 三","kind":"诗"}]},"纥干著":{"slug":"纥干著","name":"纥干著","dynasty":"唐","style":"","life":"","origin":"","seal":"纥","bio":[],"works":[{"id":"t42-957","title":"赏残花","kind":"诗"},{"id":"t42-958","title":"古仙词","kind":"诗"},{"id":"t42-959","title":"感春词","kind":"诗"},{"id":"t42-960","title":"灞上","kind":"诗"}]},"羊滔":{"slug":"羊滔","name":"羊滔","dynasty":"唐","style":"","life":"","origin":"","seal":"羊","bio":["羊滔，泰山人，大历中宏词及第。诗四首。"],"works":[{"id":"t16-778","title":"游烂柯山 一","kind":"诗"},{"id":"t16-779","title":"游烂柯山 二","kind":"诗"},{"id":"t16-780","title":"游烂柯山 三","kind":"诗"},{"id":"t16-781","title":"游烂柯山 四","kind":"诗"}]},"范仲淹":{"slug":"范仲淹","name":"范仲淹","dynasty":"宋","style":"字希文","life":"","origin":"其先（今陕西县）","seal":"范","bio":["(989－1052) 字希文。其先 (今陕西县) 人，后徙苏州吴县 (今属江苏)。大中祥符八年 (1015) 进士。","官至枢密副使，参加政事，又曾出任陕西四路宣抚使，知州。守边多年，西夏称他“胸中自有数万甲兵”。卒谥文正。","著有《范文正公集》。词存五首，风格、题材均不拘一格，如《渔家傲》写边塞生活，苍劲明健，《苏幕遮》、《御街行》写离别相思，缠绵深致，均脍炙人口。有今辑本《范文正公诗馀》。"],"works":[{"id":"c57-648","title":"苏幕遮·碧云天","kind":"词"},{"id":"c57-649","title":"渔家傲·塞下秋来风景异","kind":"词"},{"id":"c57-650","title":"御街行·纷纷堕叶飘香砌","kind":"词"},{"id":"c57-651","title":"剔银灯·昨夜因看蜀志","kind":"词"},{"id":"c57-652","title":"定风波·罗绮满城春欲暮","kind":"词"}]},"赵晟":{"slug":"赵晟","name":"赵晟","dynasty":"唐","style":"","life":"","origin":"","seal":"赵","bio":["赵晟，孟宾于同时人。诗一首。（《全唐诗》无赵晟诗）"],"works":[{"id":"t55-464","title":"赠孟宾于（题拟）","kind":"诗"}]},"郭受":{"slug":"郭受","name":"郭受","dynasty":"唐","style":"","life":"","origin":"","seal":"郭","bio":["郭受，大历间人。杜甫有《酬郭十五判官》诗，盖受曾为衡阳判官。诗一首。"],"works":[{"id":"t13-598","title":"寄杜员外","kind":"诗"}]},"韦冰":{"slug":"韦冰","name":"韦冰","dynasty":"唐","style":"","life":"","origin":"","seal":"韦","bio":["韦冰，唐末邺令。诗一首。"],"works":[{"id":"t40-838","title":"和三乡诗","kind":"诗"}]},"韩偓":{"slug":"韩偓","name":"韩偓","dynasty":"唐","style":"字致光一作尧","life":"","origin":"","seal":"韩","bio":["韩偓，字致光一作尧，京兆万年人。龙纪元年，擢进士第，佐河中幕府，召拜左拾遗，累迁谏议大夫，历翰林学士、中书舍人、兵部侍郎。以不附朱全忠，贬濮州司马，再贬荣懿尉，徙邓州司马。","天祐二年，复原官，偓不赴召，南依王审知而卒。《翰林集》一卷，《香籢集》三卷，今合编四卷。韩偓，字致光一作尧，京兆万年人。","龙纪元年，擢进士第，佐河中幕府，召拜左拾遗，累迁谏议大夫，历翰林学士，中书舍人、兵部侍郎，以不附朱全忠，贬濮州司马，再贬荣懿尉，徙邓州司马。天祐二年，复原官，偓不赴召，南依王审知而卒。翰林集一卷，香籢集三卷，今合编四卷。"],"works":[{"id":"t37-971","title":"雨后月中玉堂闲坐","kind":"诗"},{"id":"t37-972","title":"六月十七日召对自辰及申方归本院","kind":"诗"},{"id":"t37-973","title":"与吴子华侍郎同年玉堂同直怀恩叙恳因成长句四韵兼呈诸同年","kind":"诗"},{"id":"t37-974","title":"和吴子华侍郎令狐昭化舍人叹白菊衰谢之绝次山本韵","kind":"诗"},{"id":"t37-975","title":"中秋禁直","kind":"诗"},{"id":"t37-976","title":"侍宴","kind":"诗"},{"id":"t37-977","title":"锡宴日作","kind":"诗"},{"id":"t37-978","title":"宫柳","kind":"诗"},{"id":"t37-979","title":"苑中","kind":"诗"},{"id":"t37-980","title":"从猎三首 一","kind":"诗"},{"id":"t37-981","title":"从猎三首 二","kind":"诗"},{"id":"t37-982","title":"从猎三首 三","kind":"诗"},{"id":"t37-983","title":"辛酉岁冬十一月随驾幸岐下作","kind":"诗"},{"id":"t37-984","title":"冬至夜作","kind":"诗"},{"id":"t37-985","title":"秋霖夜忆家","kind":"诗"},{"id":"t37-986","title":"恩赐樱桃分寄朝士","kind":"诗"},{"id":"t37-987","title":"出官经硖石县","kind":"诗"},{"id":"t37-988","title":"访同年虞部李郎中","kind":"诗"},{"id":"t37-989","title":"赠渔者","kind":"诗"},{"id":"t37-990","title":"春阴独酌寄同年虞部李郎中","kind":"诗"},{"id":"t37-991","title":"奉和峡州孙舍人肇荆南重围中寄诸朝士二篇时李常侍洵严谏议龟李起居殷衡李郎中冉皆有继和余久有是债今至湖南方暇牵课 一","kind":"诗"},{"id":"t37-992","title":"奉和峡州孙舍人肇荆南重围中寄诸朝士二篇时李常侍洵严谏议龟李起居殷衡李郎中冉皆有继和余久有是债今至湖南方暇牵课 二","kind":"诗"},{"id":"t37-993","title":"雪中过重湖信笔偶题","kind":"诗"},{"id":"t37-994","title":"寄湖南从事","kind":"诗"},{"id":"t37-995","title":"玩水禽","kind":"诗"},{"id":"t37-996","title":"早玩雪梅有怀亲属","kind":"诗"},{"id":"t37-997","title":"欲明","kind":"诗"},{"id":"t37-998","title":"梅花","kind":"诗"},{"id":"t37-999","title":"小隐","kind":"诗"},{"id":"t38-0","title":"曛黑","kind":"诗"},{"id":"t38-1","title":"晓日","kind":"诗"},{"id":"t38-2","title":"醉著","kind":"诗"},{"id":"t38-3","title":"柳","kind":"诗"},{"id":"t38-4","title":"病中初闻复官二首 一","kind":"诗"},{"id":"t38-5","title":"病中初闻复官二首 二","kind":"诗"},{"id":"t38-6","title":"早起五言三韵","kind":"诗"},{"id":"t38-7","title":"家书后批二十八字","kind":"诗"},{"id":"t38-8","title":"湖南梅花一冬再发偶题于花援","kind":"诗"},{"id":"t38-9","title":"即目二首 一","kind":"诗"},{"id":"t38-10","title":"即目二首 二","kind":"诗"},{"id":"t38-11","title":"净兴寺杜鹃一枝繁艳无比","kind":"诗"},{"id":"t38-12","title":"花时与钱尊师同醉因成二十字","kind":"诗"},{"id":"t38-13","title":"避地","kind":"诗"},{"id":"t38-14","title":"息兵","kind":"诗"},{"id":"t38-15","title":"翠碧鸟","kind":"诗"},{"id":"t38-16","title":"赠孙仁本尊师","kind":"诗"},{"id":"t38-17","title":"乙丑岁九月在萧滩镇驻泊两月忽得商马杨迢员外书贺余复除戎曹依旧承旨还缄后因书四十字","kind":"诗"},{"id":"t38-18","title":"丙寅二月二十二日抚州如归馆雨中有怀诸朝客","kind":"诗"},{"id":"t38-19","title":"三月二十七日自抚州往南城县舟行见拂水蔷薇因有是作","kind":"诗"},{"id":"t38-20","title":"茘枝三首 一","kind":"诗"}]},"高衢":{"slug":"高衢","name":"高衢","dynasty":"唐","style":"","life":"","origin":"","seal":"高","bio":["高衢，唐末人。诗一首。"],"works":[{"id":"t40-843","title":"和三乡诗","kind":"诗"}]},"魏了翁":{"slug":"魏了翁","name":"魏了翁","dynasty":"宋","style":"字华甫","life":"1178 — 1237","origin":"蒲江（今属四川）","seal":"魏","bio":["--(1178-1237) 字华甫，蒲江 (今属四川) 人。庆元五年 (1199) 进士。开禧初，以武学博士对策，谏开边事，被劾狂妄。","改秘书省正字，迁校书郎。奉亲还里，辞朝迁召命，筑室白鹤山下，授徒进学。嘉定末，除起居郎，历任州郡。","入朝权工部侍郎，不久，贬靖州。理宗亲政，召还，命直学士院，累擢端明殿学士，同签书枢密院事，督视江淮军马。以资政殿学士致仕。","有《鹤山先生大全文集》、《鹤山词》。"],"works":[{"id":"c64-30","title":"蝶恋花·又见王正班玉瑞","kind":"词"},{"id":"c64-31","title":"水调歌头·江水自石纽","kind":"词"},{"id":"c64-32","title":"水调歌头·轻露沦残暑","kind":"词"},{"id":"c64-33","title":"水调歌头·风露浸秋色","kind":"词"},{"id":"c64-34","title":"水调歌头·万里蜀山险","kind":"词"},{"id":"c64-35","title":"念奴娇·万人遮道","kind":"词"},{"id":"c64-36","title":"临江仙·九十秋光三十八","kind":"词"},{"id":"c64-37","title":"临江仙·细雨斜风驱晓瘴","kind":"词"},{"id":"c64-38","title":"感皇恩·三峡打头风","kind":"词"},{"id":"c64-39","title":"水龙吟·阑风长雨连霄","kind":"词"},{"id":"c64-40","title":"满江红·玉质金相","kind":"词"},{"id":"c64-41","title":"水调歌头·世界要扶助","kind":"词"},{"id":"c64-42","title":"南乡子·万里载浮名","kind":"词"},{"id":"c64-43","title":"水调歌头·冬至子之半","kind":"词"},{"id":"c64-44","title":"临江仙·尚忆去年称寿日","kind":"词"},{"id":"c64-45","title":"水调歌头·曾向君王说","kind":"词"},{"id":"c64-46","title":"临江仙·腰著万钉犀玉夸","kind":"词"},{"