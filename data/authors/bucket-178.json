458","title":"沁园春·粉破梅梢","kind":"词"}]},"陈叔达":{"slug":"陈叔达","name":"陈叔达","dynasty":"唐","style":"字子聪","life":"","origin":"","seal":"陈","bio":["陈叔达，字子聪，陈宣帝第十六子也。善容止，有才学，在陈封义阳王。十余岁侍宴，赋诗十韵，援笔便就，仆射徐陵甚奇之。","入隋，为绛郡通守，归款于唐，授丞相府主簿，与记室温大雅同掌机密，军书敕令及禅代文诰，多叔达所为。进黄门侍郎，兼纳言侍中，封江国公。贞观中，拜礼部尚书。","集十五卷，今存诗九首。陈叔达，字子聪，陈宣帝第十六子也。善容止，有才学，在陈封义阳王。","十余岁侍宴，赋诗十韵，援笔便就，仆射徐陵甚奇之。入隋，为绛郡通守，归款于唐，授丞相府主簿，与记室温大雅同掌机密，军书敕令及禅代文诰，多叔达所为。进黄门侍郎，兼纳言侍中，封江国公。","贞观中，拜礼部尚书。集十五卷，今存诗九首。"],"works":[{"id":"t2-402","title":"早春桂林殿应诏","kind":"诗"},{"id":"t2-403","title":"后渚置酒","kind":"诗"},{"id":"t2-404","title":"听邻人琵琶","kind":"诗"},{"id":"t2-405","title":"州城西园入斋祠社","kind":"诗"},{"id":"t2-406","title":"春首","kind":"诗"},{"id":"t2-407","title":"初年","kind":"诗"},{"id":"t2-408","title":"咏菊","kind":"诗"},{"id":"t2-410","title":"自君之出矣  一","kind":"诗"},{"id":"t2-411","title":"自君之出矣  二","kind":"诗"},{"id":"t48-780","title":"太庙祼地歌辞","kind":"诗"},{"id":"t51-989","title":"入阙咏空镜台诗","kind":"诗"}]},"隐求":{"slug":"隐求","name":"隐求","dynasty":"唐","style":"","life":"","origin":"","seal":"隐","bio":[],"works":[{"id":"t47-195","title":"石桥琪树","kind":"诗"}]},"韦瓘":{"slug":"韦瓘","name":"韦瓘","dynasty":"唐","style":"字茂弘","life":"","origin":"","seal":"韦","bio":["韦瓘，字茂弘，京兆万年人。登进士第，累擢中书舍人，贬明州刺史。会昌末，累迁楚州刺史，终桂管观察使。","诗一首。"],"works":[{"id":"t27-315","title":"留题桂州碧浔亭","kind":"诗"},{"id":"t53-856","title":"句","kind":"诗"}]},"高越":{"slug":"高越","name":"高越","dynasty":"唐","style":"字仲远","life":"","origin":"","seal":"高","bio":["高越，字仲远，幽州人。仕吴，授秘书郎，累迁中书舍人，终勤政学士、户部侍郎。诗一首。"],"works":[{"id":"t41-546","title":"咏鹰","kind":"诗"}]},"鱼玄机":{"slug":"鱼玄机","name":"鱼玄机","dynasty":"唐","style":"字幼微一字蕙兰","life":"","origin":"","seal":"鱼","bio":["鱼玄机，字幼微一字蕙兰。长安里家女，喜读书，有才思，补阙李亿纳为妾。爱衰，遂从冠帔于咸宜观，后以笞杀女童绿翘事，为京兆温璋所戮。","今编诗一卷。"],"works":[{"id":"t44-232","title":"赋得江边柳","kind":"诗"},{"id":"t44-233","title":"赠邻女","kind":"诗"},{"id":"t44-234","title":"寄国香","kind":"诗"},{"id":"t44-235","title":"寄题炼师","kind":"诗"},{"id":"t44-236","title":"寄刘尚书","kind":"诗"},{"id":"t44-237","title":"浣纱庙","kind":"诗"},{"id":"t44-238","title"