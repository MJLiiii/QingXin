{"于结":{"slug":"于结","name":"于结","dynasty":"唐","style":"","life":"","origin":"","seal":"于","bio":["于结，大历间人。崔宁尝欲荐为御史，为杨炎所沮。诗一首。"],"works":[{"id":"t14-371","title":"赋得生刍一束","kind":"诗"}]},"任玠":{"slug":"任玠","name":"任玠","dynasty":"唐","style":"","life":"","origin":"","seal":"任","bio":[],"works":[{"id":"t48-194","title":"梦中和句","kind":"诗"}]},"伏牛小师":{"slug":"伏牛小师","name":"伏牛小师","dynasty":"唐","style":"","life":"","origin":"","seal":"伏","bio":["伏牛小师，法名待考，师伏牛和尚自在。诗一首。（《全唐诗》无伏牛小师诗）"],"works":[{"id":"t53-461","title":"答伏牛和尚（题拟）","kind":"诗"}]},"冯时行":{"slug":"冯时行","name":"冯时行","dynasty":"宋","style":"","life":"","origin":"","seal":"冯","bio":[],"works":[{"id":"c65-237","title":"青玉案·年时江上垂杨路","kind":"词"},{"id":"c65-238","title":"虞美人·东君已了韶华媚","kind":"词"},{"id":"c65-239","title":"虞美人·芳菲不是浑无据","kind":"词"},{"id":"c65-240","title":"虞美人·去年同醉黄花下","kind":"词"},{"id":"c65-241","title":"渔家傲·云复衡茅霜雪后","kind":"词"},{"id":"c65-242","title":"天仙子·风幸多情开得好","kind":"词"},{"id":"c65-243","title":"点绛唇·十日春风","kind":"词"},{"id":"c65-244","title":"玉楼春·杏花微露春犹浅","kind":"词"},{"id":"c65-245","title":"点绛唇·江上新晴","kind":"词"},{"id":"c65-246","title":"点绛唇·眉黛低颦","kind":"词"},{"id":"c65-247","title":"梦兰堂·小雨清尘淡烟晚","kind":"词"},{"id":"c65-248","title":"蓦山溪·艰难时世","kind":"词"},{"id":"c65-249","title":"醉落魄・一斛珠·点酥点蜡","kind":"词"}]},"同谷子":{"slug":"同谷子","name":"同谷子","dynasty":"唐","style":"","life":"","origin":"","seal":"同","bio":[],"works":[{"id":"t43-373","title":"五子之歌 一","kind":"诗"},{"id":"t43-374","title":"五子之歌 二","kind":"诗"},{"id":"t43-375","title":"五子之歌 三","kind":"诗"},{"id":"t43-376","title":"五子之歌 四","kind":"诗"},{"id":"t43-377","title":"五子之歌 五","kind":"诗"}]},"尹元凯":{"slug":"尹元凯","name":"尹元凯","dynasty":"唐","style":"字戫","life":"","origin":"","seal":"尹","bio":["尹元凯字戫，河间人。初为磁州司仓，坐事免，乃栖迟山林，不求仕进垂三十年。与张说、卢藏用善。","征魏王右补阙。开元十五年卒于并州司马任。诗一首。","（《全唐诗》无尹元凯诗。尹元凯，《旧唐书·文苑传》有传附《阎朝隐传》，《新唐书》入《文艺传》）"],"works":[{"id":"t50-511","title":"无题","kind":"诗"},{"id":"t50-512","title":"五言同韦子斿神泉诗（并序）","kind":"诗"}]},"师复":{"slug":"师复","name":"师复","dynasty":"唐","style":"","life":"","origin":"","seal":"师","bio":["师复，咸通间福州双峰寺僧。（《全唐诗》无师复诗）"],"works":[{"id":"t53-982","title":"句","kind":"诗"}]},"归处讷":{"slug":"归处讷","name":"归处讷","dynasty":"唐","style":"","life":"","origin":"","seal":"归","bio":["处讷，吴人，侍郎融之曾孙。多游秦陇，言足是非，在事者无不以金帛酒食弥缝之，畏其咏也。"],"works":[{"id":"t51-553","title":"见人衣鲜华作诗","kind":"诗"},{"id":"t51-554","title":"咏虺汉（黄巢犯京后，守亮、守信等悉为杨军容复恭义儿，势夺诸侯，亦一时之威也。归有不平之色咏虺汉以刺之曰：）","kind":"诗"},{"id":"t51-555","title":"咏奸汉","kind":"诗"},{"id":"t51-556","title":"代村妇咏边将","kind":"诗"},{"id":"t51-557","title":"咏石校书（钦若）（石校书，本东川人。文章四六，与王超齐名。天复初应举，值大驾东迁，蜀路不心目，干戈继起，遂客寄天水，荏苒一纪有余。后知父亡，方乃举恸，广于寺院追荐忏罪而已。归与石遽因小隟，荼毒咏之。石氏声名，因兹减价。诗曰：）","kind":"诗"}]},"文炬":{"slug":"文炬","name":"文炬","dynasty":"唐","style":"号慧日禅师","life":"","origin":"","seal":"文","bio":["泉州创崇福院以居之。号慧日禅师。光化元年卒。","一云干宁中卒。诗二首。（《全唐诗》无文炬诗）"],"works":[{"id":"t54-228","title":"无题","kind":"诗"},{"id":"t54-229","title":"偈","kind":"诗"},{"id":"t54-230","title":"过尤溪青印石留偈（题拟）","kind":"诗"}]},"方君遇":{"slug":"方君遇","name":"方君遇","dynasty":"宋","style":"","life":"","origin":"","seal":"方","bio":[],"works":[{"id":"c73-30","title":"风流子·春被雨禁持","kind":"词"}]},"止禅师":{"slug":"止禅师","name":"止禅师","dynasty":"宋","style":"","life":"","origin":"","seal":"止","bio":[],"works":[{"id":"c76-67","title":"卜算子·书是玉关来","kind":"词"}]},"段倚":{"slug":"段倚","name":"段倚","dynasty":"宋","style":"","life":"","origin":"","seal":"段","bio":[],"works":[{"id":"c78-602","title":"醉蓬莱·正星杓首舍","kind":"词"}]},"王智兴":{"slug":"王智兴","name":"王智兴","dynasty":"唐","style":"字匡谏","life":"","origin":"","seal":"王","bio":["王智兴，字匡谏，怀州人。起牙将，自贞元至太和，历战功，进位侍中，封雁门郡王。诗一首。"],"works":[{"id":"t16-850","title":"徐州使院赋","kind":"诗"}]},"蒋琰":{"slug":"蒋琰","name":"蒋琰","dynasty":"唐","style":"字公器","life":"","origin":"","seal":"蒋","bio":["琰，字公器，高池人，一作仙居人。干符间明经，累官谏垣。诗二首。","（《全唐诗》无蒋琰诗）"],"works":[{"id":"t54-127","title":"隐居即事","kind":"诗"},{"id":"t54-128","title":"日泊","kind":"诗"}]},"蔡昆":{"slug":"蔡昆","name":"蔡昆","dynasty":"唐","style":"","life":"","origin":"","seal":"蔡","bio":[],"works":[{"id":"t43-230","title":"善卷先生