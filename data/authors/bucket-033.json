":"诗"},{"id":"t0-774","title":"郊庙歌辞 梁郊祀乐章 庆和 三","kind":"诗"},{"id":"t0-775","title":"郊庙歌辞 梁郊祀乐章 庆和 四","kind":"诗"},{"id":"t0-776","title":"郊庙歌辞 梁郊祀乐章 庆和 五","kind":"诗"},{"id":"t0-777","title":"郊庙歌辞 梁郊祀乐章 庆和 六","kind":"诗"},{"id":"t0-778","title":"郊庙歌辞 梁郊祀乐章 庆顺","kind":"诗"},{"id":"t0-779","title":"郊庙歌辞 梁郊祀乐章 庆平","kind":"诗"},{"id":"t0-780","title":"郊庙歌辞 梁郊祀乐章 庆肃","kind":"诗"},{"id":"t0-781","title":"郊庙歌辞 梁郊祀乐章 庆熙","kind":"诗"},{"id":"t0-782","title":"郊庙歌辞 梁郊祀乐章 庆隆","kind":"诗"},{"id":"t0-783","title":"郊庙歌辞 梁郊祀乐章 庆融","kind":"诗"},{"id":"t0-784","title":"郊庙歌辞 梁郊祀乐章 庆休","kind":"诗"},{"id":"t0-785","title":"郊庙歌辞 梁郊祀乐章 庆和","kind":"诗"}]},"韩仪":{"slug":"韩仪","name":"韩仪","dynasty":"唐","style":"字羽光","life":"","origin":"","seal":"韩","bio":["韩仪，字羽光，京兆万年人，偓之兄也。以翰林学士为御史中丞，朱全忠贬为棣州司马。诗一首。"],"works":[{"id":"t37-183","title":"记知闻近过关试","kind":"诗"}]},"马植":{"slug":"马植","name":"马植","dynasty":"唐","style":"字存之","life":"","origin":"","seal":"马","bio":["马植，字存之，扶风人。元和中进士擢第，历安南招讨、黔中观察使。宣宗朝，以户部侍郎同中书门下平章事，寻罢为太子宾客，分司东都，起忠武节度使，徙宣武卒。","诗一首。"],"works":[{"id":"t25-745","title":"奉和白敏中圣道和平致兹休运岁终功就合咏盛明呈上","kind":"诗"}]}}