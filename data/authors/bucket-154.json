{"丽天和尚":{"slug":"丽天和尚","name":"丽天和尚","dynasty":"唐","style":"","life":"","origin":"","seal":"丽","bio":["丽天和尚，灵照同时人。诗一首。（《全唐诗》无丽天和尚诗）"],"works":[{"id":"t55-581","title":"无题","kind":"诗"},{"id":"t55-582","title":"无著对文殊话颂","kind":"诗"}]},"元载":{"slug":"元载","name":"元载","dynasty":"唐","style":"字公辅","life":"","origin":"","seal":"元","bio":["元载，字公辅，岐山人。嗜学好属文，以明庄、老、文、列四子之学，策入高科。初授新平尉，历度支郎中。","肃宗嘉其奏对，委以国计，充使江淮，都岭漕挽。俄迁户部侍郎度支使，并诸道转运使。以附李辅国，迁中书侍郎同平章事。","排去忠良，引用贪猥。大历中，以贿败，伏诛。集十卷，今存诗一首。"],"works":[{"id":"t5-748","title":"别妻王韫秀","kind":"诗"}]},"孙光宪":{"slug":"孙光宪","name":"孙光宪","dynasty":"唐","style":"字孟文 · 号葆光子","life":"","origin":"陵州贵平（今四川仁寿东北）","seal":"孙","bio":["--(约 895－968) 字孟文，自号葆光子，陵州贵平 (今四川仁寿东北) 人。唐时为陵州判官。天成初 (926 前后) 避地江陵，后事南平三世。","累官检校秘书少监兼御史中丞。归宋后，授黄州刺史。《花间集》称孙少监。","性嗜经籍，聚书凡数千卷，校勘抄写，老而不辍。著有笔记《北梦琐言》。词存八十四首，风格与“花间”的浮艳、绮靡有所不同。","刘毓辑入《唐五代宋辽金元名家词集六十种》中。又有王国维辑《孙中丞词》一卷。"],"works":[{"id":"t2-111","title":"杂曲歌辞 竹枝 一","kind":"诗"},{"id":"t2-112","title":"杂曲歌辞 竹枝 二","kind":"诗"},{"id":"t2-188","title":"杂曲歌辞 杨柳枝 一","kind":"诗"},{"id":"t2-189","title":"杂曲歌辞 杨柳枝 二","kind":"诗"},{"id":"t2-190","title":"杂曲歌辞 杨柳枝 三","kind":"诗"},{"id":"t2-191","title":"杂曲歌辞 杨柳枝 四","kind":"诗"},{"id":"t42-600","title":"竹枝词二首 一","kind":"诗"},{"id":"t42-601","title":"竹枝词二首 二","kind":"诗"},{"id":"t42-602","title":"杨柳枝词四首 一","kind":"诗"},{"id":"t42-603","title":"杨柳枝词四首 二","kind":"诗"},{"id":"t42-604","title":"杨柳枝词四首 三","kind":"诗"},{"id":"t42-605","title":"杨柳枝词四首 四","kind":"诗"},{"id":"t42-606","title":"采莲","kind":"诗"},{"id":"t42-607","title":"八拍蛮","kind":"诗"},{"id":"t42-608","title":"句","kind":"诗"},{"id":"t48-346","title":"引自落便宜句","kind":"诗"},{"id":"t49-692","title":"竹枝 一","kind":"诗"},{"id":"t49-693","title":"竹枝 二","kind":"诗"},{"id":"t49-694","title":"浣溪沙 一","kind":"诗"},{"id":"t49-695","title":"浣溪沙 二","kind":"诗"},{"id":"t49-696","title":"浣溪沙 三","kind":"诗"},{"id":"t49-697","title":"浣溪沙 四","kind":"诗"},{"id":"t49-698","title":"浣溪沙 五","kind":"诗"},{"id":"t49-699","title":"浣溪沙 六","kind":"诗"},{"id":"t49-700","title":"浣溪沙 七","kind":"诗"},{"id":"t49-701","title":"浣溪沙 八","kind":"诗"},{"id":"t49-702","title":"浣溪沙 九","kind":"诗"},{"id":"t49-703","title":"浣溪沙 十","kind":"诗"},{"id":"t49-704","title":"浣溪沙 十一","kind":"诗"},{"id":"t49-705","title":"浣溪沙 十二","kind":"诗"},{"id":"t49-706","title":"浣溪沙 十三","kind":"诗"},{"id":"t49-707","title":"浣溪沙 十四","kind":"诗"},{"id":"t49-708","title":"浣溪沙 十五","kind":"诗"},{"id":"t49-709","title":"浣溪沙 十六","kind":"诗"},{"id":"t49-710","title":"浣溪沙 十七","kind":"诗"},{"id":"t49-711","title":"浣溪沙 十八","kind":"诗"},{"id":"t49-712","title":"浣溪沙 十九","kind":"诗"},{"id":"t49-713","title":"河传 一","kind":"诗"},{"id":"t49-714","title":"河传 二","kind":"诗"},{"id":"t49-715","title":"河传 三","kind":"诗"},{"id":"t49-716","title":"河传 四","kind":"诗"},{"id":"t49-717","title":"菩萨鬘 一","kind":"诗"},{"id":"t49-718","title":"菩萨鬘 二","kind":"诗"},{"id":"t49-719","title":"菩萨鬘 三","kind":"诗"},{"id":"t49-720","title":"菩萨鬘 四","kind":"诗"},{"id":"t49-721","title":"菩萨鬘 五","kind":"诗"},{"id":"t49-722","title":"河渎神 一","kind":"诗"},{"id":"t49-723","title":"河渎神 二","kind":"诗"},{"id":"t49-724","title":"虞美人 一","kind":"诗"},{"id":"t49-725","title":"虞美人 二","kind":"诗"}]},"封彦卿":{"slug":"封彦卿","name":"封彦卿","dynasty":"唐","style":"号之初","life":"","origin":"","seal":"封","bio":["会昌季年，武宗大翦释氏，巾其徒且数万人，民隶其居，容貌于土木者沈诸水，言词于纸素者烈诸火，分命御史乘驲走天下，察敢隐匿者罪之。由是天下名祠珍宇，毁撤如扫。天子建号之初，雪释氏之不可废也，诏徐复之，而自湖已南，远人畏法，不能酌朝廷之体，前时焚撤书像，殆无遗者，故虽明命复许创立，莫能得其书。","道林寺，湘川之胜游也，有释疏言，警辨有谋，独曰：“太原府国家旧都，多释祠，我闻其帅司空范阳公，天下仁人，我第往求释氏遗文，以惠湘川之人，宜其听我而助成之矣。”即杖而北游，既上谒军门，范阳公果诺之，因四求散逸不成蕴帙者，至释祠而不见焚而副剩者，又命讲丐以补缮缺漏者。未几，凡得释经五千四十八卷，以大中九年秋八月，辇自河东而归于湘焉。","喜释氏之助世，既言之矣。向非我君洞察理源，其何能复立之，即既立之，且亡其书，非有疏言识远而诚坚，孰克洪之耶？吾嘉疏言，奉君之令，演释之宗，不惮寒暑之勤，德及远人，为叙其事，且赠以诗。"],"works":[{"id":"t31-410","title":"和李尚书命妓饯崔侍御","kind":"诗"},{"id":"t31-411","title":"一","kind":"诗"},{"id":"t31-412","title":"二","kind":"诗"},{"id":"t31-413","title":"三","kind":"诗"}]},"尚宫宋氏若宪":{"slug":"尚宫宋氏若宪","name":"尚宫宋氏若宪","dynasty":"唐","style":"","life":"","origin":"","seal":"尚","bio":["宝历初，若昭卒，若宪复代司宫籍。诗一首。"],"works":[{"id":"t0-310","title":"奉和御制麟德殿宴百官","kind":"诗"}]},"崔琮":{"slug":"崔琮","name":"崔琮","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":["崔琮，登大历二年进士第。诗一首。"],"works":[{"id":"t15-61","title":"长至日上公献寿","kind":"诗"}]},"曹豳":{"slug":"曹豳","name":"曹豳","dynasty":"宋","style":"字西士 · 号东亩","life":"","origin":"瑞安（今属浙江）","seal":"曹","bio":["--字西士，号东亩，一作东猷，瑞安 (今属浙江) 人。嘉泰二年 (1202) 进士，历官至浙东提点刑狱，召为左司谏，以宝章阁待制致仕。存词二首。"],"works":[{"id":"c71-652","title":"西河·今日事","kind":"词"},{"id":"c71-653","title":"红窗迥·春闱期近也","kind":"词"}]},"李损之":{"slug":"李损之","name":"李损之","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李损之，文宗朝进士。诗一首。"],"works":[{"id":"t29-914","title":"都堂试贡士日庆春雪","kind":"诗"}]},"李质":{"slug":"李质","name":"李质","dynasty":"唐","style":"字公干","life":"","origin":"","seal":"李","bio":["李质，字公干，襄阳人。擢进士第，大中时，官至江西观察使。诗一首。"],"works":[{"id":"t31-340","title":"宿日观东房诗","kind":"诗"}]},"梁藻":{"slug":"梁藻","name":"梁藻","dynasty":"唐","style":"字仲华","life":"","origin":"","seal":"梁","bio":["梁藻，字仲华，长汀人，南唐总殿前步军晖之子。性乐萧散，应袭父任，不就。《处士集》若干卷，今存诗一首。"],"works":[{"id":"t42-417","title":"南山池","kind":"诗"}]},"法藏":{"slug":"法藏","name":"法藏","dynasty":"唐","style":"","life":"","origin":"","seal":"法","bio":["法藏，姓周，南康人。幼研史籍，明于医方。中年投本郡宝积院纳戒。","又师马祖。后北下庐山，卜居五老峰，世称高城和尚。宝历中卒，年八十二。","诗一首。（《全唐诗》无法藏诗，传据《祖堂集》卷十四、《宋高僧传》卷二十）"],"works":[{"id":"t53-489","title":"歌行一首","kind":"诗"}]},"王武陵":{"slug":"王武陵","name":"王武陵","dynasty":"唐","style":"字晦伯","life":"","origin":"","seal":"王","bio":["王武陵，字晦伯，太原人，官尚书郎。诗二首。"],"works":[{"id":"t14-717","title":"宿慧山寺","kind":"诗"},{"id":"t14-718","title":"秋暮登北楼","kind":"诗"}]},"窦冀":{"slug":"窦冀","name":"窦冀","dynasty":"唐","style":"","life":"","origin":"","seal":"窦","bio":["窦冀，官御史。诗一首。"],"works":[{"id":"t10-62","title":"怀素上人草书歌","kind":"诗"}]},"赋梅":{"slug":"赋梅","name":"赋梅","dynasty":"宋","style":"","life":"","origin":"","seal":"赋","bio":[],"works":[{"id":"c76-600","title":"齐天乐·雕阑曲曲芙蓉水","kind":"词"}]},"赵祯":{"slug":"赵祯","name":"赵祯","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"c58-604","title":"合宫歌·缵重明","kind":"词"}]},"路岩":{"slug":"路岩","name":"路岩","dynasty":"唐","style":"","life":"","origin":"","seal":"路","bio":[],"works":[{"id":"t51-532","title":"赠妓行云等感恩多词（句）（路侍中具有，风貌之美，为世所闻。镇成都日，委执政于孔目吏边咸，以官妓行云等十人侍宴。移镇渚宫日，于合江亭离筵，赠行云等《口恩多》词。有「离魂」云云。至今播于倡楼也。）","kind":"诗"}]},"郑畋":{"slug":"郑畋","name":"郑畋","dynasty":"唐","style":"字台文","life":"","origin":"","seal":"郑","bio":["郑畋，字台文，荥阳人。会昌进士第。刘瞻镇北门，辟为从事，瞻作相，荐为翰林学士，迁中书舍人。","干符中，以兵部侍郎同平章事，寻出为凤翔节度使，拒巢贼有功，授检校尚书左仆射。诗一卷，今存十六首。郑畋字台文，荥阳人。","补诗一首。"],"works":[{"id":"t30-951","title":"中秋月直禁苑","kind":"诗"},{"id":"t30-952","title":"麦穗两岐","kind":"诗"},{"id":"t30-953","title":"五月一日紫宸候对时属禁直穿内而行因书六韵","kind":"诗"},{"id":"t30-954","title":"题缑山王子晋庙","kind":"诗"},{"id":"t30-955","title":"初秋寓直三首 一","kind":"诗"},{"id":"t30-956","title":"初秋寓直三首 二","kind":"诗"},{"id":"t30-957","title":"初秋寓直三首 三","kind":"诗"},{"id":"t30-958","title":"夜景又作","kind":"诗"},{"id":"t30-959","title":"杪秋夜直","kind":"诗"},{"id":"t30-960","title":"禁直寄崔员外","kind":"诗"},{"id":"t30-961","title":"闻号","kind":"诗"},{"id":"t30-962","title":"禁直和人饮酒","kind":"诗"},{"id":"t30-963","title":"下直早出","kind":"诗"},{"id":"t30-964","title":"金銮坡上南望","kind":"诗"},{"id":"t30-965","title":"酬隐珪舍人寄红烛","kind":"诗"},{"id":"t30-966","title":"马嵬坡","kind":"诗"},{"id":"t30-967","title":"句","kind":"诗"},{"id":"t50-847","title":"白鹤观水阁题诗（题拟）","kind":"诗"},{"id":"t54-177","title":"酬通义刘相瞻","kind":"诗"},{"id":"t54-178","title":"二十八宿诗","kind":"诗"}]},"郭郧":{"slug":"郭郧","name":"郭郧","dynasty":"唐","style":"","life":"","origin":"","seal":"郭","bio":["郭郧，毘陵人，大历、贞元间诗人。诗一首。"],"works":[{"id":"t16-661","title":"寒食寄李补阙","kind":"诗"}]},"陈允平":{"slug":"陈允平","name":"陈允平","dynasty":"宋","style":"字君衡 · 号西麓","life":"","origin":"四明（今浙江宁波）","seal":"陈","bio":["--字君衡，一字衡仲，号西麓，自称莆澹室后人，四明 (今浙江宁波) 人。德时，授沿海制置司参议官。宋亡后，曾征至大都。","著有《西麓诗稿》。词学周邦彦，有《西麓继周集》、《日湖渔唱》。"],"works":[{"id":"c74-445","title":"摸鱼儿·倚东风","kind":"词"},{"id":"c74-446","title":"木兰花慢·杜鹃声渐老","kind":"词"},{"id":"c74-447","title":"绛都春·秋千倦倚","kind":"词"},{"id":"c74-448","title":"酹江月・念奴娇·汉江露冷","kind":"词"},{"id":"c74-449","title":"倦寻芳·杏檐转午","kind":"词"},{