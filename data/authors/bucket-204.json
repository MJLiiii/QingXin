in":"","seal":"张","bio":["事、判度支。寻贬连州刺史，至蓝田不行，留华州依韩建。昭宗干宁二年复为兵部尚书，领天下租庸使。","三年，罢使务，守尚书右仆射。上书评乞致仕，乃还洛阳，居长水县别墅。天复三年为人所杀，（《旧唐书》卷一七九，《新唐书》卷一八五均有传）。","诗一首。（《全唐诗》无张濬诗）"],"works":[{"id":"t50-848","title":"无题","kind":"诗"},{"id":"t50-849","title":"山居洞前得杜鹃花走笔偶成以□（八琼室本作「简」）桂帅仆射兼寄呈广州仆射刘公","kind":"诗"},{"id":"t54-294","title":"咏红叶题诗事（题拟）","kind":"诗"}]},"张野人":{"slug":"张野人","name":"张野人","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"t50-43","title":"句","kind":"诗"}]},"志懃":{"slug":"志懃","name":"志懃","dynasty":"唐","style":"号灵云和尚","life":"","origin":"","seal":"志","bio":["志懃，福州人。嗣沩山。在福州，号灵云和尚。","诗一首。（《全唐诗》无志懃诗）"],"works":[{"id":"t55-726","title":"偶覩春时花蘂繁发忽然发悟喜不自胜乃作一偈","kind":"诗"}]},"择禅师":{"slug":"择禅师","name":"择禅师","dynasty":"唐","style":"","life":"","origin":"","seal":"择","bio":["择禅师，休静、善会同时僧。诗二首。（《全唐诗》无择禅师诗）"],"works":[{"id":"t54-158","title":"因道吾指夹山寻师颂","kind":"诗"},{"id":"t54-159","title":"夹山顿遇以华亭颂","kind":"诗"}]},"曹稆孙":{"slug":"曹稆孙","name":"曹稆孙","dynasty":"宋","style":"","life":"","origin":"","seal":"曹","bio":[],"works":[{"id":"c76-53","title":"贺新郎·极目天如画","kind":"词"}]},"李归唐":{"slug":"李归唐","name":"李归唐","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t43-216","title":"失鹭鹚","kind":"诗"}]},"李德裕":{"slug":"李德裕","name":"李德裕","dynasty":"唐","style":"字文饶","life":"","origin":"","seal":"李","bio":["李德裕，字文饶，赵郡人，宰相吉甫子也。以荫补校书郎，拜监察御史。穆宗即位，擢翰林学士，再进中书舍人。","未几，授御史中丞。牛僧孺、李宗闵追怨吉甫，出德裕为浙江观察使。太和三年，召拜兵部侍郎，宗闵秉政，复出为郑滑节度使。","逾年，徙劒南西川，以兵部尚书召。俄拜中书门下平章事，封赞皇县伯。宗闵罢，代为中书侍郎、集贤殿大学士。","郑注、李训怨之，乃召宗闵，拜德裕为兴元节度使。入见帝，自陈愿留阙下，复拜兵部尚书。为王璠、李汉所谮，贬太子宾客，分司东都，再贬袁州刺史，未几徙滁州。","开成初，起为浙西观察使，迁淮南节度使。武宗立，召为门下侍郎，同中书门下平章事，拜太尉，封卫国公。当国凡六年，威名独重于时。","宣宗即位，罢为荆南节度使，白敏中、令狐绹使党人搆之，贬崖州司户参军卒。德裕少力学，善为文，虽在大位，手不去书。《会昌一品集》二十卷，别集十卷，外集四卷，今编诗一卷。"],"works":[{"id":"t25-377","title":"奉和圣制南郊礼毕诗","kind":"诗"},{"id":"t25-378","title":"郊坛回舆中书二相公蒙圣慈召至御马前仰感恩遇辄书是诗兼呈二相公","kind":"诗"},{"id":"t25-379","title":"寒食日三殿侍宴奉进诗一首","kind":"诗"},{"id":"t25-380","title":"雨中自秘书省访王三侍御知早入朝便入集贤侍御任集贤校书及升柏台又与秘阁相对同院张学士亦余特厚故以诗赠之","kind":"诗"},{"id":"t25-381","title":"奉和太原张尚书山亭书怀","kind":"诗"},{"id":"t25-382","title":"奉和韦侍御陪相公游开义五言六韵","kind":"诗"},{"id":"t25-383","title":"赠圆明上人","kind":"诗"},{"id":"t25-384","title":"赠奉律上人","kind":"诗"},{"id":"t25-385","title":"戏赠慎微寺主道安上座三僧正","kind":"诗"},{"id":"t25-386","title":"长安秋夜","kind":"诗"},{"id":"t25-387","title":"清冷池怀古","kind":"诗"},{"id":"t25-388","title":"述梦诗四十韵","kind":"诗"},{"id":"t25-389","title":"招隐山观玉蘂树戏书即事奉寄江西沈大夫阁老","kind":"诗"},{"id":"t25-390","title":"寄题惠林李侍郎旧馆","kind":"诗"},{"id":"t25-391","title":"寄茅山孙炼师","kind":"诗"},{"id":"t25-392","title":"又二绝 一","kind":"诗"},{"id":"t25-393","title":"又二绝 二","kind":"诗"},{"id":"t25-394","title":"题奇石","kind":"诗"},{"id":"t25-395","title":"送张中丞入台从事","kind":"诗"},{"id":"t25-396","title":"怀京国","kind":"诗"},{"id":"t25-397","title":"追和太师颜公同清远道士游虎丘寺","kind":"诗"},{"id":"t25-398","title":"东郡怀古二首 王京兆","kind":"诗"},{"id":"t25-399","title":"东郡怀古二首 阳给事","kind":"诗"},{"id":"t25-400","title":"秋日登郡楼望赞皇山感而成咏","kind":"诗"},{"id":"t25-401","title":"雨后净望河西连山怆然成咏","kind":"诗"},{"id":"t25-402","title":"秋日美晴郡楼闲眺寄荆南张书记","kind":"诗"},{"id":"t25-403","title":"故人寄茶","kind":"诗"},{"id":"t25-404","title":"奉送相公十八丈镇杨州","kind":"诗"},{"id":"t25-405","title":"题劒门","kind":"诗"},{"id":"t25-406","title":"汉州月夕游房太尉西湖","kind":"诗"},{"id":"t25-407","title":"重题","kind":"诗"},{"id":"t25-408","title":"房公旧竹亭闻琴缅慕风流神期如在因重题此作","kind":"诗"},{"id":"t25-409","title":"忆金门旧游奉寄江西沈大夫","kind":"诗"},{"id":"t25-410","title":"早入中书行公主册礼事毕登集贤阁成咏","kind":"诗"},{"id":"t25-411","title":"题罗浮石","kind":"诗"},{"id":"t25-412","title":"重过列子庙追感顷年自淮服与居守王仆射同题名于庙壁仆射已为御史余尚布衣自后俱列紫垣继游内署两为夏官之代复联左揆之荣荷宠多同感涕何极因书四韵奉寄","kind":"诗"},{"id":"t25-413","title":"遥伤茅山县孙尊师三首 一","kind":"诗"},{"id":"t25-414","title":"遥伤茅山县孙尊师三首 二","kind":"诗"},{"id":"t25-415","title":"遥伤茅山县孙尊师三首 三","kind":"诗"},{"id":"t25-416","title":"尊师是桃源黄先生传法弟子常见尊师称先师灵迹今重赋此诗兼寄题黄先生旧馆","kind":"诗"},{"id":"t25-417","title":"仆射相公偶话于故集贤张学士厅写得德裕与仆射旧唱和诗其时和者五人惟仆射与德裕皆列高位凄然怀旧辄献此诗","kind":"诗"},{"id":"t25-418","title":"惠泉","kind":"诗"},{"id":"t25-419","title":"无题","kind":"诗"},{"id":"t25-420","title":"题冠盖里","kind":"诗"},{"id":"t25-421","title":"离平泉马上作","kind":"诗"},{"id":"t25-422","title":"谪岭南道中作","kind":"诗"},{"id":"t25-423","title":"到恶溪夜泊芦岛","kind":"诗"},{"id":"t25-424","title":"登崖州城作","kind":"诗"},{"id":"t25-425","title":"鸳鸯篇","kind":"诗"},{"id":"t25-426","title":"南梁行","kind":"诗"}]},"李正封":{"slug":"李正封","name":"李正封","dynasty":"唐","style":"字中护","life":"","origin":"","seal":"李","bio":["李正封，官监察御史。诗五首。正封，字中护，陇西人。","元和二年举进士及第，同年贤良方正能直言极谏科及第。历任监察御史、司勋员外郎、彰义军判官、司勋郎中。（《全唐诗》卷三四七小传过略，今据《郎官石柱题名考》卷七补传）"],"works":[{"id":"t18-382","title":"洛阳清明日雨霁","kind":"诗"},{"id":"t18-383","title":"咏露","kind":"诗"},{"id":"t18-384","title":"夏游招隐寺暴雨晚晴","kind":"诗"},{"id":"t18-385","title":"禅门寺暮钟","kind":"诗"},{"id":"t18-386","title":"贡院楼北新栽小松","kind":"诗"},{"id":"t51-345","title":"赏牡丹（句）","kind":"诗"},{"id":"t51-346","title":"岘山（句）","kind":"诗"},{"id":"t53-446","title":"月桂","kind":"诗"},{"id":"t53-447","title":"句","kind":"诗"}]},"范灯":{"slug":"范灯","name":"范灯","dynasty":"唐","style":"","life":"","origin":"","seal":"范","bio":["范灯，贞元时人。诗二首。"],"works":[{"id":"t16-642","title":"忆长安 九月","kind":"诗"},{"id":"t16-643","title":"状江南 季夏","kind":"诗"}]},"赵□":{"slug":"赵□","name":"赵□","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"c78-654","title":"失调名·寸心千里","kind":"词"}]},"通真道人":{"slug":"通真道人","name":"通真道人","dynasty":"唐","style":"","life":"","origin":"","seal":"通","bio":["通真道人，唐末以前人。诗一首。（《全唐诗续补遗》卷十七收杜光庭《题天坛》诗，《天坛王屋山圣迹记》原作通真道人诗）"],"works":[{"id":"t54-451","title":"七言三十韵","kind":"诗"}]},"邓洵美":{"slug":"邓洵美","name":"邓洵美","dynasty":"唐","style":"","life":"","origin":"","seal":"邓","bio":["邓洵美，连州人，或曰郴郡人。晋天福中登第，后还乡，上牋周行逢，署馆驿巡官，已而行逢疑之，贬为易俗场官，使盗杀之。诗一首。"],"works":[{"id":"t41-203","title":"荅同年李昉见赠次韵","kind":"诗"}]},"陈九流":{"slug":"陈九流","name":"陈九流","dynasty":"唐","style":"","life":"","origin":"","seal":"陈","bio":["陈九流，贞元中进士。诗一首。"],"works":[{"id":"t18-402","title":"赋得春风扇微和","kind":"诗"}]},"马咸":{"slug":"马咸","name":"马咸","dynasty":"宋","style":"","life":"","origin":"","seal":"马","b