  "id": "t30-890",
  "notes": [
    {
      "term": "金带",
      "def": "大刀柄上系的红绸子。连环：一种刀。束：捆。"
    },
    {
      "term": "临洮（táo）",
      "def": "古县名，在今甘肃省岷县，以临洮水得名，在临河沿岸。"
    },
    {
      "term": "卷（juǎn）旗",
      "def": "指急行军，军旗高高飘扬。"
    },
    {
      "term": "劫",
      "def": "劫持，冲杀。"
    },
    {
      "term": "斫",
      "def": "读zhuó，砍。缺：破损。"
    }
  ],
  "translation": [
    "扎紧战袍，系上红缨大刀，打马前行，雪夜度过洮水河。",
    "旗子高扬，连夜冲入单于帐内，砍杀胡兵，宝刀都残缺破损了。"
  ],
