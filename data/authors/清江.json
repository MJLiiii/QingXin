{"slug":"清江","name":"清江","dynasty":"唐","style":"","life":"","origin":"","seal":"清","bio":["清江，会稽人，善篇章。大历、贞元间，与清昼齐名，称为会稽二清。诗一卷。"],"works":[{"id":"t44-811","title":"早发陕州途中赠严秘书","kind":"诗"},{"id":"t44-812","title":"早春书情寄河南崔少府","kind":"诗"},{"id":"t44-813","title":"春游司直城西鸬鹚溪别业","kind":"诗"},{"id":"t44-814","title":"夕次襄邑","kind":"诗"},{"id":"t44-815","title":"宿严维宅简章八元","kind":"诗"},{"id":"t44-816","title":"赠淮西贾兵马使","kind":"诗"},{"id":"t44-817","title":"送坚上人归杭州天竺寺","kind":"诗"},{"id":"t44-818","title":"送赞律师归嵩山","kind":"诗"},{"id":"t44-819","title":"上都酬章十八兄","kind":"诗"},{"id":"t44-820","title":"登楼望月寄凤翔李少尹","kind":"诗"},{"id":"t44-821","title":"湘川怀古","kind":"诗"},{"id":"t44-822","title":"七夕","kind":"诗"},{"id":"t44-823","title":"长安卧病","kind":"诗"},{"id":"t44-824","title":"送婆罗门","kind":"诗"},{"id":"t44-825","title":"喜皇甫大夫同宿大梁驿","kind":"诗"},{"id":"t44-826","title":"酬姚补阙南仲云溪馆中戏题随书见寄","kind":"诗"},{"id":"t44-827","title":"喜严侍御蜀还赠严秘书","kind":"诗"},{"id":"t44-828","title":"送韦参军江陵","kind":"诗"},{"id":"t44-829","title":"月夜有怀黄端公兼简朱孙二判官","kind":"诗"},{"id":"t44-830","title":"精舍遇雨","kind":"诗"},{"id":"t44-831","title":"小雪","kind":"诗"},{"id":"t44-832","title":"句","kind":"诗"}]}