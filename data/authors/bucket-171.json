"dynasty":"唐","style":"字元辅","life":"","origin":"","seal":"苗","bio":["苗晋卿，字元辅，潞州壶关人。擢进士第，累迁吏部郎中，知选事，久之，进侍郎。天宝二载，较书判，以御史中丞张倚之子奭为第一，议者不平。","帝御花萼楼覆实，奭持纸终日，笔不下，人谓之曳白。坐贬安康太守，俄充河北采访使。肃宗召赴行在，拜左相。","广德中，以太保致仕。永泰初卒，谥懿献。诗一首。"],"works":[{"id":"t13-492","title":"奉和圣制早登太行山中言志","kind":"诗"},{"id":"t52-932","title":"奉和圣制雨中春望诗","kind":"诗"},{"id":"t52-933","title":"奉和行幸诗","kind":"诗"}]},"莫":{"slug":"莫","name":"莫","dynasty":"宋","style":"","life":"","origin":"","seal":"莫","bio":[],"works":[{"id":"c75-792","title":"水龙吟·镜寒香歇江城路","kind":"词"},{"id":"c75-793","title":"玉楼春·绿杨芳径莺声小","kind":"词"},{"id":"c75-794","title":"生查子·三两信凉风","kind":"词"},{"id":"c75-795","title":"卜算子·红底过丝明","kind":"词"},{"id":"c75-796","title":"摸鱼儿·听春教","kind":"词"}]},"萧仲":{"slug":"萧仲","name":"萧仲","dynasty":"宋","style":"","life":"","origin":"","seal":"萧","bio":[],"works":[{"id":"c76-429","title":"沁园春·笑问鸥盟","kind":"词"}]},"蔡京":{"slug":"蔡京","name":"蔡京","dynasty":"唐","style":"","life":"","origin":"","seal":"蔡","bio":[],"works":[{"id":"t25-242","title":"责商山四皓","kind":"诗"},{"id":"t25-243","title":"假节邕交道由吴溪","kind":"诗"},{"id":"t25-244","title":"咏子规","kind":"诗"},{"id":"c61-311","title":"西江月·八十一年住世","kind":"词"}]},"裴谟":{"slug":"裴谟","name":"裴谟","dynasty":"唐","style":"","life":"","origin":"","seal":"裴","bio":["谟，坦兄。大中间任秘书监、台州刺史等职。诗一首。","（《全唐诗》无裴谟诗，事迹据《新唐书·宰相世系表》、《庐山记》及《嘉定赤城志》卷八，并参岑仲勉考证）"],"works":[{"id":"t54-97","title":"和舍弟寄题东林寺","kind":"诗"},{"id":"t54-98","title":"送陈谠授本府长史（题拟）","kind":"诗"}]},"贾謩":{"slug":"贾謩","name":"贾謩","dynasty":"唐","style":"","life":"","origin":"","seal":"贾","bio":["贾謩，元和进士。诗一首。"],"works":[{"id":"t26-119","title":"赋得芙蓉出水","kind":"诗"}]},"陈去疾":{"slug":"陈去疾","name":"陈去疾","dynasty":"唐","style":"字文医","life":"","origin":"","seal":"陈","bio":["陈去疾，字文医，侯官人。元和十四年及第，历官邕管副使。诗十三首。"],"works":[{"id":"t26-144","title":"送林刺史简言之漳州","kind":"诗"},{"id":"t26-145","title":"忆山中","kind":"诗"},{"id":"t26-146","title":"元夕京城和欧阳衮","kind":"诗"},{"id":"t26-147","title":"送韩将军之鴈门","kind":"诗"},{"id":"t26-148","title":"赋得骐骥长鸣","kind":"诗"},{"id":"t26-149