},{"id":"t38-685","title":"惆怅诗十二首 四","kind":"诗"},{"id":"t38-686","title":"惆怅诗十二首 五","kind":"诗"},{"id":"t38-687","title":"惆怅诗十二首 六","kind":"诗"},{"id":"t38-688","title":"惆怅诗十二首 七","kind":"诗"},{"id":"t38-689","title":"惆怅诗十二首 八","kind":"诗"},{"id":"t38-690","title":"惆怅诗十二首 九","kind":"诗"},{"id":"t38-691","title":"惆怅诗十二首 十","kind":"诗"},{"id":"t38-692","title":"惆怅诗十二首 十一","kind":"诗"},{"id":"t38-693","title":"惆怅诗十二首 十二","kind":"诗"},{"id":"c78-421","title":"念奴娇·水沉香霭","kind":"词"}]},"花仲胤妻":{"slug":"花仲胤妻","name":"花仲胤妻","dynasty":"宋","style":"","life":"","origin":"","seal":"花","bio":[],"works":[{"id":"c64-760","title":"伊川令・伊州令·西风昨夜穿帘幕","kind":"词"},{"id":"c64-761","title":"失调名·奴启情人勿见罪","kind":"词"}]},"蒋涣":{"slug":"蒋涣","name":"蒋涣","dynasty":"唐","style":"","life":"","origin":"","seal":"蒋","bio":["蒋涣，冽之弟，擢进士。天宝末，为给事中。永泰初，历鸿胪卿，日本使尝遗金帛，不受，惟取牋一番，为书以贻其副。","终礼部尚书。诗五首。"],"works":[{"id":"t13-506","title":"途次维扬望京口寄白下诸公","kind":"诗"},{"id":"t13-507","title":"登栖霞寺塔","kind":"诗"},{"id":"t13-508","title":"和徐侍郎书丛筿韵","kind":"诗"},{"id":"t13-509","title":"故太常卿赠礼部尚书李公及夫人挽歌二首 一","kind":"诗"},{"id":"t13-510","title":"故太常卿赠礼部尚书李公及夫人挽歌二首 二","kind":"诗"}]},"裴光庭":{"slug":"裴光庭","name":"裴光庭","dynasty":"唐","style":"字连城","life":"","origin":"绛州闻喜","seal":"裴","bio":["裴光庭，字连城。绛州闻喜人，行俭之子。母库狄氏，则天时召入宫，甚见亲待。","光庭由是累迁太常丞，以武三思壻坐贬郢州司马。开元中，擢兵部郎中，从东封还，拜中书侍郎，同平章事。从谒诸陵，拜侍中，兼吏部尚书，加弘文馆学士，撰《瑶山往则》、《维城前规》二篇献之，手制褒美。","其为吏部，因行俭长名牓，为循资格，并促选限，任门下省主事阎麟之专主选官。每麟之裁定，光庭随而下笔，时人语曰：“麟之[口]手，光庭[手]口。”博士孙琬以其用循资格非奖劝之道，谥为克。","诗一首。"],"works":[{"id":"t5-386","title":"奉和御制左丞相说右丞相璟太子少傅乾曜同日上官命都堂赐诗","kind":"诗"}]},"郭世模":{"slug":"郭世模","name":"郭世模","dynasty":"宋","style":"","life":"","origin":"","seal":"郭","bio":[],"works":[{"id":"c59-998","title":"瑞鹧鸪·倾城一笑得留人","kind":"词"},{"id":"c59-999","title":"瑞鹤仙·云阶连月地","kind":"词"},{"id":"c60-0","title":"朝中措·青灯听雨夜荒凉","kind":"词"},{"id":"c60-1","title":"南歌子·玉盏浮琼蚁","kind":"词"},{"id":"c60-2","title":"念奴娇·光风转蕙","kind":"词"},{"id":"c60-3","title":"浣溪沙·几点胭脂印指红","kind":"词"}]},"陆蟾":{"slug":"陆蟾","name":"陆蟾","dynasty":"唐","style":"","life":"","origin":"","seal":"陆","bio":["蟾，寓居潭州攸县司空山。好神仙事，多辟谷累月。雍熙中服药卒。"],"works":[{"id":"t51-809","title":"题庐山瀑布","kind":"诗"},{"id":"t51-810","title":"春暮经石头城","kind":"诗"},{"id":"t51-811","title":"司空山闻子规","kind":"诗"}]},"颜师古":{"slug":"颜师古","name":"颜师古","dynasty":"唐","style":"字籀《旧唐书》云：“颜籀","life":"","origin":"累迁中书舍","seal":"颜","bio":["颜师古，字籀《旧唐书》云：“颜籀，字师古。”，雍州万年人，齐黄门侍郎之推之孙。博览群书，尤精训诂。","隋末为安养尉，高祖入关，谒见长春宫，授朝散大夫。累迁中书舍人，专掌机密。太宗初，擢中书侍郎，考定五经，多所厘正，颁其书令天下学习。","所注班固《汉书》、《急就章》，大行于世。终秘书监、弘文馆学士。集六十卷，今存诗一首。"],"works":[{"id":"t2-420","title":"奉和正日临朝","kind":"诗"}]}}