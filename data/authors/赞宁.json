{"slug":"赞宁","name":"赞宁","dynasty":"唐","style":"号明义","life":"","origin":"","seal":"赞","bio":["赞宁，德清高氏子。出家杭州龙兴寺，吴越武肃王署为两浙僧统，赐号明义。入宋，至道二年示寂。","诗二首。（《全唐诗》无赞宁诗）"],"works":[{"id":"t51-32","title":"无题","kind":"诗"},{"id":"t51-33","title":"寄题水月禅院（在洞庭山缥缈峰下，梁大同四年建，山有无碍泉。）","kind":"诗"},{"id":"t51-34","title":"居天柱山","kind":"诗"},{"id":"t55-691","title":"寄题明月禅院（之二）","kind":"诗"},{"id":"t55-692","title":"悟空塔","kind":"诗"},{"id":"t55-693","title":"夜吟","kind":"诗"},{"id":"t55-694","title":"秋日寄人","kind":"诗"},{"id":"t55-695","title":"钱唐潮信诗","kind":"诗"},{"id":"t55-696","title":"句 一","kind":"诗"},{"id":"t55-697","title":"句 二","kind":"诗"},{"id":"t55-698","title":"句 三","kind":"诗"},{"id":"t55-699","title":"句 四","kind":"诗"},{"id":"t55-700","title":"句 五","kind":"诗"}]}