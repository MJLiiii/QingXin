{"slug":"詹敦仁","name":"詹敦仁","dynasty":"唐","style":"字君泽","life":"","origin":"","seal":"詹","bio":["詹敦仁，字君泽，固始人。初隐仙游，后为清溪令。诗六首。","詹敦仁字君泽，固始人。补诗四首。"],"works":[{"id":"t42-540","title":"复留侯从効问南汉刘岩改名䶮字音义","kind":"诗"},{"id":"t42-541","title":"柳堤诗","kind":"诗"},{"id":"t42-542","title":"劝王氏入贡宠予以官作辞命篇","kind":"诗"},{"id":"t42-543","title":"余迁泉山城留侯招游郡圃作此","kind":"诗"},{"id":"t42-544","title":"留侯受南唐节度使知郡事辟予为属以诗谢之","kind":"诗"},{"id":"t42-545","title":"遣子访刘乙","kind":"诗"},{"id":"t50-999","title":"寄刘乙处士","kind":"诗"},{"id":"t51-0","title":"琲访刘君乙时已殁故将归王令留之不可以书来嘱作此篇示","kind":"诗"},{"id":"t51-1","title":"入局吟","kind":"诗"},{"id":"t51-2","title":"又一首（用前韵）","kind":"诗"},{"id":"t51-767","title":"题九仙山","kind":"诗"},{"id":"t51-768","title":"题二石将军","kind":"诗"},{"id":"t51-769","title":"题佛耳山","kind":"诗"},{"id":"t51-770","title":"介庵赠古墨梅酬以一篇","kind":"诗"},{"id":"t51-771","title":"清隐堂","kind":"诗"},{"id":"t51-772","title":"题舫斋（原作詹时泽诗，敦仁字君泽，疑即一人）","kind":"诗"},{"id":"t55-820","title":"行至双溪口午炊主人开瓮求诗作","kind":"诗"},{"id":"t55-821","title":"欧阳长官见迓约余买邻作此奉呈","kind":"诗"},{"id":"t55-822","title":"父子联韵诗","kind":"诗"}]}