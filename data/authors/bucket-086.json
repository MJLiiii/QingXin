-347","title":"长相思·要相忘","kind":"词"},{"id":"c64-348","title":"减字木兰花·去年今夜","kind":"词"},{"id":"c64-349","title":"菩萨蛮·客愁不到西池路","kind":"词"},{"id":"c64-350","title":"菩萨蛮·高楼只在斜阳里","kind":"词"},{"id":"c64-351","title":"菩萨蛮·登楼一望南山雪","kind":"词"},{"id":"c64-352","title":"踏莎行·雪似梅花","kind":"词"},{"id":"c64-353","title":"清平乐·故人何处","kind":"词"},{"id":"c64-354","title":"渔家傲·小院悠悠春未远","kind":"词"},{"id":"c64-355","title":"生查子·残春雾雨馀","kind":"词"},{"id":"c64-356","title":"满江红·东里先生","kind":"词"},{"id":"c64-357","title":"浪淘沙·柳色过疏篱","kind":"词"},{"id":"c64-358","title":"浪淘沙·柳塘新涨","kind":"词"},{"id":"c64-359","title":"生查子·双双小凤斜","kind":"词"},{"id":"c64-360","title":"生查子·人分南浦春","kind":"词"},{"id":"c64-361","title":"蝶恋花·巧语娇莺春未暮","kind":"词"}]},"吴渊":{"slug":"吴渊","name":"吴渊","dynasty":"宋","style":"字道夫 · 号退庵","life":"","origin":"宣州宁国（今属安徽）","seal":"吴","bio":["--(1190－1257) 字道夫，号退庵，宣州宁国 (今属安徽) 人，一说德清 (今属浙江) 人。嘉定七年 (1214) 进士。累官兵部尚书，进端明殿学士，江东安抚使、拜资政殿大学士，封金陵公，徙知福州、福建安抚使，予祠。","起拜参知政事。有《退庵集》、《退庵词》。"],"works":[{"id":"c72-646","title":"念奴娇·我来牛渚","kind":"词"},{"id":"c72-647","title":"水调歌头·太白已仙去","kind":"词"},{"id":"c72-648","title":"沁园春·喜我新归","kind":"词"},{"id":"c72-649","title":"沁园春·十月江南","kind":"词"},{"id":"c72-650","title":"满江红·秋后锺山","kind":"词"},{"id":"c72-651","title":"满江红·投老未归","kind":"词"}]},"崔珪":{"slug":"崔珪","name":"崔珪","dynasty":"唐","style":"号三戟崔家","life":"","origin":"","seal":"崔","bio":["崔珪，贝丘人。开元中，官太子詹事，与兄中书舍人琳，弟光禄卿瑶，俱列棨戟，世号三戟崔家。诗一首。"],"works":[{"id":"t5-728","title":"孤寝怨","kind":"诗"}]},"张彦胜":{"slug":"张彦胜","name":"张彦胜","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"t56-381","title":"露赋附歌","kind":"诗"}]},"张顶":{"slug":"张顶","name":"张顶","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张顶，抚州人。诗一首。"],"works":[{"id":"t25-245","title":"献蔡京","kind":"诗"}]},"李令":{"slug":"李令","name":"李令","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t48-325","title":"寄女","kind":"诗"}]},"李峤":{"slug":"李峤","name":"李峤","dynasty":"唐","style":"字巨山","life":"","origin":"","seal":"李","bio":["李峤，字巨山，赵州赞皇人。儿时梦人遗双笔，由是有文辞。弱冠擢进士第，始调安定尉，举制策甲科。","武后时，官凤阁舍人，每有大手笔，皆特命峤为之，累迁鸾台侍郎，知政事，封赵国公。景龙中，以特进守兵部尚书同中书门下三品。睿宗立，出刺怀州，明皇贬为滁州别驾，改庐州。","峤富于才思，初与王、杨接踵，中与崔、苏齐名，晚诸人没，独为文章宿老，一时学者取法焉。集五十卷，今编诗五卷。"],"works":[{"id":"t1-742","title":"杂曲歌辞 东飞伯劳歌","kind":"诗"},{"id":"t2-298","title":"杂曲歌辞 桃花行 一","kind":"诗"},{"id":"t2-299","title":"杂曲歌辞 桃花行 二","kind":"诗"},{"id":"t2-300","title":"杂曲歌辞 桃花行 三","kind":"诗"},{"id":"t2-301","title":"杂曲歌辞 桃花行 四","kind":"诗"},{"id":"t2-302","title":"杂曲歌辞 桃花行 五","kind":"诗"},{"id":"t3-547","title":"奉教追赴九成宫途中口号","kind":"诗"},{"id":"t3-548","title":"秋山望月酬李骑曹","kind":"诗"},{"id":"t3-549","title":"和同府李祭酒休沐田居","kind":"诗"},{"id":"t3-550","title":"扈从还洛呈侍从群官","kind":"诗"},{"id":"t3-551","title":"奉使筑朔方六州城率尔而作","kind":"诗"},{"id":"t3-552","title":"早发苦竹馆","kind":"诗"},{"id":"t3-553","title":"安辑岭表事平罢归","kind":"诗"},{"id":"t3-554","title":"鹧鸪","kind":"诗"},{"id":"t3-555","title":"清明日龙门游泛","kind":"诗"},{"id":"t3-556","title":"云","kind":"诗"},{"id":"t3-557","title":"拟古东飞伯劳西飞燕","kind":"诗"},{"id":"t3-558","title":"宝劒篇","kind":"诗"},{"id":"t3-559","title":"汾阴行","kind":"诗"},{"id":"t3-560","title":"中宗降诞日长宁公主满月侍宴应制","kind":"诗"},{"id":"t3-561","title":"奉和送金城公主适西蕃应制","kind":"诗"},{"id":"t3-562","title":"侍宴长宁公主东庄应制","kind":"诗"},{"id":"t3-563","title":"立春日侍宴内殿出剪彩花应制","kind":"诗"},{"id":"t3-564","title":"奉和人日清晖阁宴群臣遇雪应制","kind":"诗"},{"id":"t3-565","title":"奉和春日游苑喜雨应制","kind":"诗"},{"id":"t3-566","title":"春日侍宴幸芙蓉园应制","kind":"诗"},{"id":"t3-567","title":"甘露殿侍宴应制","kind":"诗"},{"id":"t3-568","title":"奉和七夕两仪殿会宴应制","kind":"诗"},{"id":"t3-569","title":"奉和九月九日登慈恩寺浮图应制","kind":"诗"},{"id":"t3-570","title":"闰九月九日幸总持寺登浮图应制","kind":"诗"},{"id":"t3-571","title":"奉和骊山高顶寓目应制","kind":"诗"},{"id":"t3-572","title":"游禁苑陪幸临渭亭遇雪应制","kind":"诗"},{"id":"t3-573","title":"幸白鹿观应制","kind":"诗"},{"id":"t3-574","title":"送沙门弘景道俊玄奘还荆州应制","kind":"诗"},{"id":"t3-575","title":"酬杜五弟晴朝独坐见赠","kind":"诗"},{"id":"t3-576","title":"同赋山居七夕","kind":"诗"},{"id":"t3-577","title":"送崔主簿赴沧州","kind":"诗"},{"id":"t3-578","titl