{"slug":"白元鉴","name":"白元鉴","dynasty":"唐","style":"","life":"","origin":"","seal":"白","bio":["白元鉴，西川成都府人。明皇奔蜀时为威仪道士，住上皇观。后周览山川，寄居余杭之天柱观。","元和十二年八月卒。诗十首。（《全唐诗》无白元鉴诗）"],"works":[{"id":"t51-44","title":"大涤洞","kind":"诗"},{"id":"t51-45","title":"天坛","kind":"诗"},{"id":"t51-46","title":"驯虎岩","kind":"诗"},{"id":"t51-47","title":"石门","kind":"诗"},{"id":"t51-48","title":"药圃","kind":"诗"},{"id":"t51-49","title":"抚掌泉","kind":"诗"},{"id":"t51-50","title":"讲堂","kind":"诗"},{"id":"t51-51","title":"书楼","kind":"诗"},{"id":"t51-52","title":"瀑布","kind":"诗"},{"id":"t51-53","title":"新池","kind":"诗"},{"id":"t53-414","title":"大涤山（题拟）","kind":"诗"},{"id":"t53-415","title":"法堂","kind":"诗"},{"id":"t53-416","title":"新池","kind":"诗"},{"id":"t53-417","title":"瀑布","kind":"诗"}]}