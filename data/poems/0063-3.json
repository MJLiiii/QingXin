[{"id":"c63-300","title":"杏花天·残春庭院东风晓","rhythmic":"杏花天","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["残春庭院东风晓。","细雨打、鸳鸯寒峭。","花尖望见秋千了。","无路踏青斗草。","人别后、碧云信杳。","对好景、愁多欢少。","等他燕子传音耗。","红杏开也未到。"]},{"id":"c63-301","title":"恋绣衾·木落江南感未平","rhythmic":"恋绣衾","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["木落江南感未平。","雨萧萧、衰鬓到今。","甚处是长安路，水连空、山锁暮云。","老人对酒今如此，一番新、残梦暗惊。","又是洒黄花泪，问明年、此会怎生。"]},{"id":"c63-302","title":"青玉案·芝房并蒂空称瑞","rhythmic":"青玉案","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["芝房并蒂空称瑞。","几曾见、香旎旎。","也不论兰休比蕙。","王孙高韵，说得的当，不减唐诸李。","今朝影落琼杯里。","共才子佳人斗高致。","莫道衰翁都无意。","为他丰韵，为他情味，销得真个醉。"]},{"id":"c63-303","title":"南歌子·住近沈香浦","rhythmic":"南歌子","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["住近沈香浦，门前蕙草春。","鸳鸯飞下柘枝新。","见弄青梅初著、翠罗裙。","怕唤拈歌扇，嫌催上舞茵。","几时微步不生尘。","来作维摩方丈、散花人。"]},{"id":"c63-304","title":"苏幕遮·瘦仙人","rhythmic":"苏幕遮","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["瘦仙人，穷活计。","不养丹砂，不肯参同契。","两顿家餐三觉睡。","闭著门儿，不管人闲事。","又经年，知几岁。","老屋穿空，幸有天遮蔽。","不饮香醪常似醉。","白鹤飞来，笑我颠颠地。"]},{"id":"c63-305","title":"苏幕遮·酒壶空","rhythmic":"苏幕遮","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["酒壶空，歌扇去。","独倚危楼，无限伤心处。","芳草连天云薄暮。","故国山河，一阵黄梅雨。","有奇才，无用处。","壮节飘零，受尽人间苦。","欲指虚无问征路。","回首风云，未忍辞明主。"]},{"id":"c63-306","title":"浪淘沙·圆月又中秋","rhythmic":"浪淘沙","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["圆月又中秋。","南海西头。","蛮云瘴雨晚难收。","北客相逢弹泪坐，合恨分愁。","无酒可销忧。","但说皇州。","天家宫阙酒家楼。","今夜只应清汴水，呜咽东流。"]},{"id":"c63-307","title":"浪淘沙·风约雨横江","rhythmic":"浪淘沙","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["风约雨横江。","秋满篷窗。","个中物色尽凄凉。","更是行人行未得，独系归艎。","拥被换残香。","黄卷堆床。","开愁展恨翦思量。","伊是浮云侬是梦，休问家乡。"]},{"id":"c63-308","title":"浪淘沙·白菊好开迟","rhythmic":"浪淘沙","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["白菊好开迟。","冷蝶空迷。","沾风惹露也随时。","何事深藏偏在后，天性难移。","陶令最怜伊。","同病相医。","寒枝瘦叶更栽培。","直待群芳零落后，独殿东篱。"]},{"id":"c63-309","title":"千秋岁·占秋呈瑞","rhythmic":"千秋岁","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["占秋呈瑞。","四海杨公子。","蹋拖尚带蓬壶体。","清新春草句，潇洒兰亭字。","宦情少，眠云弄月知心事。","此去应无滞。","稳步烟宵地。","鹏万里，鹤千岁。","他年黄阁老，访我清溪醉。","青凤舞，贻君万斛瑶花蕊。"]},{"id":"c63-310","title":"定风波·红药花前欲送春","rhythmic":"定风波","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["红药花前欲送春。","金鞭柘弹趁芳尘。","故傍绣帘挼柳线。","恰见。","澹梳妆映瘦腰身。","闲倚金铺书闷字。","尤殢。","为谁憔悴减心情。","放下彩毫匀粉泪。","弹指。","你不知人是不知人。"]},{"id":"c63-311","title":"踏莎行·梅倚江娥","rhythmic":"踏莎行","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["梅倚江娥，日舒宫线。","老人星唤群仙宴。","泛杯玉友暖飞浮，堆盘金橘光零乱。","听命宽心，随缘适愿。","痴狂赢取身长健。","醉中等看碧桃春，尊前莫问蓬莱浅。"]},{"id":"c63-312","title":"踏莎行·花涨藤江","rhythmic":"踏莎行","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["花涨藤江，草熏鸭步。","锦帆兰棹分春去。","二翁元是一溪云，暂为山北山南雨。","绿酒多斟，白须休觑。","飞丹约定烟霞侣。","与君先占赤城春，回桡早趁桃源路。"]},{"id":"c63-313","title":"梦玉人引·浪萍风梗","rhythmic":"梦玉人引","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["浪萍风梗，寄人间，倦为客。","梦里瀛洲，姓名误题仙籍。","敛翅归来，爱小园、蜕箨篔筜碧。","新种幽花，戒儿童休摘。","放怀随分，各逍遥，飞鷃等鹏翼。","舍此萧闲，问君携杖安适。","诸彦群英，诗酒皆勍敌。","太平时，向花前，不醉如何休得。"]},{"id":"c63-314","title":"一落索·一夜雨声连晓","rhythmic":"一落索","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["一夜雨声连晓。","青灯相照。","旧时情绪此时心，花不见、人空老。","可惜春光闲了。","阴多晴少。","江南江北水连云，问何处、寻芳草。"]},{"id":"c63-315","title":"一落索·惯被好花留住","rhythmic":"一落索","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["惯被好花留住。","蝶飞莺语。","少年场上醉乡中，容易放、春归去。","今日江南春暮。","朱颜何处。","莫将愁绪比飞花，花有数、愁无数。"]},{"id":"c63-316","title":"渔家傲·谁转琵琶弹侧调","rhythmic":"渔家傲","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["谁转琵琶弹侧调。","征尘万里伤怀抱。","客散黄昏庭院悄。","灯相照。","春寒燕子归来早。","可惜韶光虚过了。","多情人已非年少。","只恐莺啼春又老。","知音少。","人间何处寻芳草。"]},{"id":"c63-317","title":"渔家傲·鉴水稽山尘不染","rhythmic":"渔家傲","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["鉴水稽山尘不染。","归来贺老身强健。","有客跨鲸游汗漫。","留羽扇。","玉船取酒青鸾劝。","莫恨飞花容易散。","仙家风味何曾减。","春色一壶丹九转。","堪为伴。","雕粱幸有轻盈燕。"]},{"id":"c63-318","title":"渔家傲·畏暑闲寻湖上径","rhythmic":"渔家傲","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["畏暑闲寻湖上径。","雨丝断送凉成阵。","风里芙蓉斜不整。","沈红影。","约回萍叶波心静。","催唤吴姬迎小艇。","妆花烛焰明相映。","饮到夜阑人却醒。","风雨定。","欲归更把阑干凭。"]},{"id":"c63-319","title":"望江南・忆江南·炎昼永","rhythmic":"望江南・忆江南","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["炎昼永，初夜月侵床。","露卧一丛莲叶畔，芙蓉香细水风凉。","枕上是仙乡。","浮世事，能有几多长。","白日明朝依旧在，黄花非晚是重阳。","不用苦思量。"]},{"id":"c63-320","title":"十二时・忆少年·连云衰草","rhythmic":"十二时・忆少年","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["连云衰草，连天晚照，连山红叶。","西风正摇落，更前溪呜咽。","燕去鸿归音信绝。","问黄花、又共谁折。","征人最愁处，送寒衣时节。"]},{"id":"c63-321","title":"南乡子·宫样细腰身","rhythmic":"南乡子","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["宫样细腰身。","玉带罗衫稳试新。","小底走来宣对御，催频。","曲殿西厢小苑门。","歌舞斗轻盈。","不许杨花上锦茵。","劝得君王真个醉，承恩。","金凤红袍印粉痕。"]},{"id":"c63-322","title":"南乡子·风雪打黄昏","rhythmic":"南乡子","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["风雪打黄昏。","别殿无人早闭门。","拜了天香罗袖冷，低颦。","催灭银灯解绣裙。","金鸭卧残薰。","看破屏风数泪痕。","回首昭阳天样远，销魂。","又过梅花一番春。"]},{"id":"c63-323","title":"行香子·宝篆香沈","rhythmic":"行香子","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["宝篆香沈。","锦瑟尘侵。","日长时、懒把金针。","裙腰暗减，眉黛长颦。","看梅花过，梨花谢，柳花新。","春寒院落，灯火黄昏。","悄无言、独自销魂。","空弹粉泪，难托清尘。","但楼前望，心中想，梦中寻。"]},{"id":"c63-324","title":"忆帝京·元来老子曾垂教","rhythmic":"忆帝京","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["元来老子曾垂教。","挫锐和光为妙。","因甚不听他，强要争工巧。","只为忒惺惺，惹尽闲烦恼。","你但莫、多愁早老。","你但且、不分不晓。","第一随风便倒拖，第二君言亦大好。","管取没人嫌，便总道、先生俏。"]},{"id":"c63-325","title":"桃源忆故人·飘萧我是孤飞雁","rhythmic":"桃源忆故人","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["飘萧我是孤飞雁。","不共红尘结怨。","几度蓬莱清浅。","侧翅曾傍看。","有时飞入西真院。","许趁风光流转。","玉芯绿花开遍。","可惜无人见。"]},{"id":"c63-326","title":"桃源忆故人·小园雨霁秋光转","rhythmic":"桃源忆故人","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["小园雨霁秋光转。","天气微寒犹暖。","黄菊红蕉庭院。","翠径苔痕软。","眼前明快眉间展。","细酌霞觞不浅。","一曲广陵弹遍。","目送飞鸿远。"]},{"id":"c63-327","title":"桃源忆故人·雨斜风横香成阵","rhythmic":"桃源忆故人","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["雨斜风横香成阵。","春去空留春恨。","欢少愁多因甚。","燕子浑难问。","碧尖蹙损眉慵晕。","泪湿燕支红沁。","可惜海棠吹尽。","又是黄昏近。"]},{"id":"c63-328","title":"桃源忆故人·西楼几日无人到","rhythmic":"桃源忆故人","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["西楼几日无人到。","依旧红围绿绕。","楼下落花谁扫。","不见长安道。","碧云望断无音耗。","倚遍阑干残照。","试问泪弹多少。","湿遍楼前草。"]},{"id":"c63-329","title":"桃源忆故人·谁能留得朱颜住","rhythmic":"桃源忆故人","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["谁能留得朱颜住。","枉了百般辛苦。","争似萧然无虑。","任运随缘去。","人人放著逍遥路。","只怕君心不悟。","弹指百年今古。","有甚成亏处。"]},{"id":"c63-330","title":"桃源忆故人·玉笙吹彻清商后","rhythmic":"桃源忆故人","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["玉笙吹彻清商后。","寂寞弓弯舞袖。","巧画远山不就。","只为眉长皱。","灵犀望断星难透。","立到凄凉时候。","今夜月明如昼。","人共梅花瘦。"]},{"id":"c63-331","title":"好事近·春雨细如尘","rhythmic":"好事近","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["春雨细如尘，楼外柳丝黄湿。","风约绣帘斜去，透窗纱寒碧。","美人慵翦上元灯，弹泪倚瑶瑟。","却上紫姑香火，问辽东消息。"]},{"id":"c63-332","title":"好事近·春雨挠元宵","rhythmic":"好事近","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["春雨挠元宵，花绽柳眠无力。","风峭画堂帘幕，卷金泥红湿。","王孙开宴聚娇饶，越山洗愁碧。","休说凤凰城里，少年时踪迹。"]},{"id":"c63-333","title":"好事近·惊见老仙来","rhythmic":"好事近","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["惊见老仙来，触目琳琅奇绝。","打酒道人林下，奏醉翁三叠。","接䍦倾倒海云飞，物色又催别。","回棹晚江春雨，胜剡溪风雪。"]},{"id":"c63-334","title":"好事近·春去尚堪寻","rhythmic":"好事近","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["春去尚堪寻，莫恨老来难却。","且趁禁烟百七，醉残英馀萼。","坐间玉润赋妍辞，情语见真乐。","引满瘿杯竹盏，胜黄金凿落。"]},{"id":"c63-335","title":"好事近·摇首出红尘","rhythmic":"好事近","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["摇首出红尘，醒醉更无时节。","活计绿蓑青笠，惯披霜冲雪。","晚来风定钓丝闲，上下是新月。","千里水天一色，看孤鸿明灭。"]},{"id":"c63-336","title":"好事近·眼里数闲人","rhythmic":"好事近","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["眼里数闲人，只有钓翁潇洒。","已佩水仙宫印，恶风波不怕。","此心那许世人知，名姓是虚假。","一棹五湖三岛，任船儿尖耍。"]},{"id":"c63-337","title":"好事近·渔父长身来","rhythmic":"好事近","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["渔父长身来，只共钓竿相识。","随意转船回棹，似飞空无迹。","芦花开落任浮生，长醉是良策。","昨夜一江风雨，都不曾听得。"]},{"id":"c63-338","title":"好事近·拨转钓鱼船","rhythmic":"好事近","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["拨转钓鱼船，江海尽为吾宅。","恰向洞庭沽酒，却钱塘横笛。","醉颜禁冷更添红，潮落下前碛。","经过子陵滩畔，得梅花消息。"]},{"id":"c63-339","title":"好事近·短棹钓船轻","rhythmic":"好事近","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["短棹钓船轻，江上晚烟笼碧。","塞雁海鸥分路，占江天秋色。","锦鳞拨刺满蓝鱼，取酒价相敌。","风顺片帆归去，有何人留得。"]},{"id":"c63-340","title":"好事近·猛向这边来","rhythmic":"好事近","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["猛向这边来，得个信音端的。","天与一轮钓线，领烟波千亿。","红尘今古转船头，鸥鹭已陈迹。","不受世间拘束，任东西南北。"]},{"id":"c63-341","title":"好事近·绿泛一瓯云","rhythmic":"好事近","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["绿泛一瓯云，留住欲飞胡蝶。","相对夜深花下，洗萧萧风月。","从容言笑醉还醒，争忍便轻别。","只愿主人留客，更重斟金叶。"]},{"id":"c63-342","title":"好事近·失却故山云","rhythmic":"好事近","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["失却故山云，索手指空为客。","莼菜鲈鱼留我，住鸳鸯湖侧。","偶然添酒旧壶卢，小醉度朝夕。","吹笛月波楼下，有何人相识。"]},{"id":"c63-343","title":"好事近·深住小溪春","rhythmic":"好事近","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["深住小溪春，好在柳枝桃叶。","风澹水轩人静，数双飞胡蝶。","日长时有一莺啼，兰佩为谁结。","销散旧愁新恨，泛琴心三叠。"]},{"id":"c63-344","title":"好事近·我不是神仙","rhythmic":"好事近","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["我不是神仙，不会炼丹烧药。","只是爱闲耽酒，畏浮名拘缚。","种成桃李一园花，真处怕人觉。","受用现前活计，且行歌行乐。"]},{"id":"c63-345","title":"长相思·昨日晴","rhythmic":"长相思","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["昨日晴。","今日阴。","楼下飞花楼上云。","阑干双泪痕。","江南人。","江北人。","一样春风两样情。","晚寒潮未平。"]},{"id":"c63-346","title":"长相思·海云黄","rhythmic":"长相思","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["海云黄。","橘洲霜。","如箭滩流石似羊。","溪船十丈长。","人难量。","水难量。","过险方知著甚忙。","归休老醉乡。"]},{"id":"c63-347","title":"乌夜啼·翦胜迎春后","rhythmic":"乌夜啼","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["翦胜迎春后，和风入律频催。","前回下叶飞霜处，红绽一枝梅。","正遇时调玉烛，须添酒满金杯。","寻芳伴侣休闲过，排日有花开。"]},{"id":"c63-348","title":"沙塞子·万里飘零南越","rhythmic":"沙塞子","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["万里飘零南越，山引泪、酒添愁。","不见凤楼龙阙、又惊秋。","九日江亭闲望，蛮树绕，瘴云浮。","肠断红蕉花晚、水西流。"]},{"id":"c63-349","title":"沙塞子·蛮径寻春春早","rhythmic":"沙塞子","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["蛮径寻春春早，千点雪，已飞梅。","席地插花传酒、日西催。","莫作楚囚相泣，倾银汉，洗瑶池。","看尽人间桃李、拂衣归。"]},{"id":"c63-350","title":"西江月·澹澹薰风庭院","rhythmic":"西江月","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["澹澹薰风庭院，青青过雨园林。","铜驼陌上旧莺声。","今日江边重听。","落帽酒中有趣，题桥琴里无心。","香残沈水缕烟轻。","花影阑干人静。"]},{"id":"c63-351","title":"西江月·琴上金星正照","rhythmic":"西江月","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["琴上金星正照，砚中鸖眼相青。","闲来自觉有精神。","心海风恬浪静。","且喜面前花好，更听林外莺新。","瓮头清辣洞庭春。","醉里徐行路稳。"]},{"id":"c63-352","title":"西江月·元是西都散汉","rhythmic":"西江月","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["元是西都散汉，江南今日衰翁。","从来颠怪更心风。","做尽百般无用。","屈指八旬将到，回头万事皆空。","云间鸿雁草间虫。","共我一般做梦。"]},{"id":"c63-353","title":"西江月·穷后常如囚系","rhythmic":"西江月","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["穷后常如囚系，老来半似心风。","饥蚊饿蚤不相容。","一夜何曾做梦。","被我不扇不捉，廓然总是虚空。","寺钟官角任西东。","别弄些儿骨董。"]},{"id":"c63-354","title":"西江月·世事短如春梦","rhythmic":"西江月","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["世事短如春梦，人情薄似秋云。","不须计较苦劳心。","万事原来有命。","幸遇三杯酒好，况逢一朵花新。","片时欢笑且相亲。","明日阴晴未定。"]},{"id":"c63-355","title":"西江月·日日深杯酒满","rhythmic":"西江月","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["日日深杯酒满，朝朝小圃花开。","自歌自舞自开怀。","且喜无拘无碍。","青史几番春梦，黄泉多少奇才。","不须计较与安排。","领取而今现在。"]},{"id":"c63-356","title":"西江月·正月天饶阴雨","rhythmic":"西江月","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["正月天饶阴雨，江南寒在晨朝。","娇莺声袅杏花梢。","暗澹绿窗春晓。","好梦空留被在，新愁不共香销。","小楼帘卷路迢迢。","望断天涯芳草。"]},{"id":"c63-357","title":"西江月·织素休寻往恨","rhythmic":"西江月","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["织素休寻往恨，攀条幸有前缘。","隔河彼此事经年。","且说蓬莱清浅。","障面重新团扇，倾鬟再整花钿。","歌云舞雪画堂前。","长共阿郎相见。"]},{"id":"c63-358","title":"减字木兰花·挼花弄扇","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["挼花弄扇。","碧斗遥山眉黛晚。","白玉阑干。","倚遍春风翠袖寒。","难寻可见。","何似一双青翅燕。","人瘦春残。","芳草连云日下山。"]},{"id":"c63-359","title":"减字木兰花·寻花携李","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["寻花携李。","红漾轻舟汀柳外。","小簇春山。","溪雨岩云不饱帆。","相逢心醉。","容易堆盘银烛泪。","痛饮何言。","犀箸敲残玉酒船。"]},{"id":"c63-360","title":"减字木兰花·东风桃李","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["东风桃李。","春水绿波花影外。","载酒胥山。","祓禊相期落锦帆。","吾曹一醉。","却笑新亭人有泪。","相对清言。","不觉黄昏雨打船。"]},{"id":"c63-361","title":"减字木兰花·闲人行李","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["闲人行李。","羽扇芒鞋尘世外。","一叠溪山。","也解分风送客帆。","时平易醉。","无复惊心并溅泪。","长揖忘言。","回棹桃花插满船。"]},{"id":"c63-362","title":"减字木兰花·刘郎已老","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["刘郎已老。","不管桃花依旧笑。","要听琵琶。","重院莺啼觅谢家。","曲终人醉。","多似浔阳江上泪。","万里东风。","国破山河落照红。"]},{"id":"c63-363","title":"减字木兰花·慵歌怕酒","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["慵歌怕酒。","今日春衫惊著瘦。","双燕帘栊。","金鸭香沈客泪中。","琵琶重听。","谁信人间多少恨。","落日东风。","吹得桃花满院红。"]},{"id":"c63-364","title":"减字木兰花·古人误我","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["古人误我。","独舞西风双泪堕。","鹤去无踪。","木落西陵返照红。","人间难住。","掷下酒杯何处去。","楼锁钟残。","山北山南两点烟。"]},{"id":"c63-365","title":"减字木兰花·无知老子","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["无知老子。","元住渔舟樵舍里。","暂借权监。","持节纡朱我甚惭。","不能者止。","免苦龟肠忧虎尾。","身退心闲。","剩向人间活几年。"]},{"id":"c63-366","title":"减字木兰花·斫鱼作鮓","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["斫鱼作鮓。","酒面打开香可醡。","相唤同来。","草草杯盘饮几杯。","人生虚假。","昨日梅花今日谢。","不醉何为。","从古英雄总是痴。"]},{"id":"c63-367","title":"减字木兰花·今年梅晚","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["今年梅晚。","懒趁寿阳钗上燕。","月唤霜催。","不肯人间取次开。","低鬟掩袂。","愁寄玉阑金井外。","粉瘦香寒。","独抱深心一点酸。"]},{"id":"c63-368","title":"减字木兰花·无人惜我","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["无人惜我。","我自殷勤怜这个。","恧峭惺惺。","不肯随人独自行。","乾坤许大。","只在棘针尖上坐。","依旧多情。","搂著虚空睡到明。"]},{"id":"c63-369","title":"减字木兰花·年衰人老","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["年衰人老。","矍铄支离君莫笑。","白日青天。","我自心情胜少年。","超凡入妙。","游戏神通随意到。","酒圣诗仙。","舞棹虚空驾铁船。"]},{"id":"c63-370","title":"减字木兰花·虚空无碍","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["虚空无碍。","你自痴迷不自在。","撒手游行。","到处笙歌拥路迎。","天然美满。","不用些儿心计算。","莫听先生。","引入深山百丈坑。"]},{"id":"c63-371","title":"减字木兰花·无人请我","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["无人请我。","我自铺毡松下坐。","酌酒栽诗。","调弄梅花作侍儿。","心欢易醉。","明月飞来花下睡。","醉舞谁知。","花满纱巾月满怀。"]},{"id":"c63-372","title":"减字木兰花·花随人去","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["花随人去。","今夜钱塘江上雨。","宿酒残更。","潮过西窗不肯明。","小罗金缕。","结尽同心留不住。","何处长亭。","绣被春寒掩翠屏。"]},{"id":"c63-373","title":"减字木兰花·有何不可","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["有何不可。","依旧一枚闲底我。","饭饱茶香。","瞌睡之时便上床。","百般经过。","且喜青鞋踏不破。","小院低窗。","桃李花开春昼长。"]},{"id":"c63-374","title":"减字木兰花·江南春水","rhythmic":"减字木兰花","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["江南春水。","罗幕黄昏寒未退。","好个相知。","唱到姮娥敛黛眉。","夜阑人醉。","风露无情花有泪。","画角残时。","一片参旗红杏西。"]},{"id":"c63-375","title":"点绛唇·淮海秋风","rhythmic":"点绛唇","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["淮海秋风，冶城飞下扬州叶。","画船催发。","倾酒留君别。","卧倒金壶，相对天涯客。","阳关彻。","大江横绝。","泪湿杯中月。"]},{"id":"c63-376","title":"点绛唇·客梦初回","rhythmic":"点绛唇","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["客梦初回，卧听吴语开帆索。","护霜云薄。","澹澹芙蓉落。","画舫无情，人去天涯角。","思量著。","翠蝉金雀。","别后新梳掠。"]},{"id":"c63-377","title":"点绛唇·至日春云","rhythmic":"点绛唇","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["至日春云，万般祥瑞朝来奏。","太平时候。","乐事家家有。","玉指呵寒，酥点梅花瘦。","金杯酒。","与君为寿。","只愿人长久。"]},{"id":"c63-378","title":"点绛唇·春雨春风","rhythmic":"点绛唇","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["春雨春风，问谁染就江南草。","燕娇莺巧。","只是参军老。","今古红尘，愁了人多少。","尊前好。","缓歌低笑。","醉向花间倒。"]},{"id":"c63-379","title":"点绛唇·缘径朱阑","rhythmic":"点绛唇","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["缘径朱阑，暖烟晴日春来早。","自家亭沼。","不问人寻讨。","携酒提篮，儿女相随到。","风光好。","醉敧纱帽。","索共梅花笑。"]},{"id":"c63-380","title":"柳梢青·狂踪怪迹","rhythmic":"柳梢青","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["狂踪怪迹。","谁料年老，天涯为客。","帆展霜风，船随江月，山寒波碧。","如今著处添愁，怎忍看、参西雁北。","洛浦莺花，伊川云水，何时归得。"]},{"id":"c63-381","title":"柳梢青·松江胜集","rhythmic":"柳梢青","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["松江胜集。","中秋载酒，幽人闲客。","云将迟疑，桂娥羞涩，一欢难得。","天怜我辈凄凉，借万里、晴空湛碧。","浩浩烟波，堂堂风月，今夕何夕。"]},{"id":"c63-382","title":"柳梢青·红分翠别","rhythmic":"柳梢青","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["红分翠别。","宿酒半醒，征鞍将发。","楼外残钟，帐前残烛，窗边残月。","想伊绣枕无眠，记行客、如今去也。","心下难拚，眼前难觅，口头难说。"]},{"id":"c63-383","title":"柳梢青·梅蒸乍热","rhythmic":"柳梢青","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["梅蒸乍热。","无处散策，芳菲初歇。","席展凉莞，帐垂黄草，天然奇绝。","披襟永昼清风，更荐枕、良宵皓月。","一梦游仙，软云推倒，广寒宫阙。"]},{"id":"c63-384","title":"柳梢青·秋光正洁","rhythmic":"柳梢青","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["秋光正洁。","仙家瑞草，黄花初发。","物外高情，天然雅致，清标偏别。","仙翁笑酌金杯，庆儿女、团圆喜悦。","嫁与萧郎，凤凰台上，长生风月。"]},{"id":"c63-385","title":"柳梢青·水云晚照","rhythmic":"柳梢青","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["水云晚照。","浮生了了，霜风衰草。","日月金梭，江山春梦，天多人少。","赤松认得虚空，便一向、飞腾缥缈。","直上蓬瀛，回看沧海，凄然长啸。"]},{"id":"c63-386","title":"采桑子·扁舟去作江南客","rhythmic":"采桑子","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["扁舟去作江南客，旅雁孤云。","万里烟尘。","回首中原泪满巾。","碧山对晚汀洲冷，枫叶芦根。","日落波平。","愁损辞乡去国人。"]},{"id":"c63-387","title":"采桑子·天高风劲尘寰静","rhythmic":"采桑子","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["天高风劲尘寰静，佳节重阳。","叶下潇湘。","碧海晴空一陈霜。","安排弦管倾芳酝，报答秋光。","昼短歌长。","红烛黄花夜未央。"]},{"id":"c63-388","title":"采桑子·一番海角凄凉梦","rhythmic":"采桑子","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["一番海角凄凉梦，却到长安。","翠帐犀帘。","依旧屏斜十二山。","玉人为我调琴瑟，颦黛低鬟。","云散香残。","风雨蛮溪半夜寒。"]},{"id":"c63-389","title":"忆秦娥·西江碧","rhythmic":"忆秦娥","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["西江碧。","江亭夜燕天涯客。","天涯客。","一杯相属，此夕何夕。","烛残花冷歌声急。","秦关汉苑无消息。","无消息。","戍楼吹角，故人难得。"]},{"id":"c63-390","title":"忆秦娥·霜风急","rhythmic":"忆秦娥","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["霜风急。","江南路上梅花白。","梅花白。","寒溪残月，冷村深雪。","洛阳醉里曾同摘。","水西竹外常相忆。","常相忆。","宝钗双凤，鬓边春色。"]},{"id":"c63-391","title":"忆秦娥·吴船窄","rhythmic":"忆秦娥","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["吴船窄。","吴江岸下长安客。","长安客。","惊尘心绪，转蓬踪迹。","征鸿也是关河隔。","孤飞万里谁相识。","谁相识。","三更月落，斗横西北。"]},{"id":"c63-392","title":"忆秦娥·歌锺列","rhythmic":"忆秦娥","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["歌锺列。","公堂盛会酬佳节。","酬佳节。","皇恩宣布，早梅争发。","舞场椎鼓催回雪。","金壶镟酒琼酥热。","琼酥热。","今朝不饮，几时欢悦。"]},{"id":"c63-393","title":"卜算子·江上见新年","rhythmic":"卜算子","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["江上见新年，年夜听春雨。","有个人人领略春，粉澹红轻注。","深劝玉东西，低唱黄金缕。","拈底梅花总是愁，酒尽人归去。"]},{"id":"c63-394","title":"卜算子·陌上雪销初","rhythmic":"卜算子","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["陌上雪销初，才得江梅信。","翦彩盘金院落香，便觉烧灯近。","乐事眼前多，春酒今年胜。","好趁迎梅接柳时，满引金杯饮。"]},{"id":"c63-395","title":"卜算子·碧瓦小红楼","rhythmic":"卜算子","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["碧瓦小红楼，芳草江南岸。","雨后纱窗几阵寒，零落梨花晚。","看到水如云，送尽鸦成点。","南北东西处处愁，独倚阑干遍。"]},{"id":"c63-396","title":"卜算子·古涧一枝梅","rhythmic":"卜算子","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["古涧一枝梅，免被园林锁。","路远山深不怕寒，似共春相趓。","幽思有谁知，托契都难可。","独自风流独自香，明月来寻我。"]},{"id":"c63-397","title":"卜算子·灼灼一枝桃","rhythmic":"卜算子","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["灼灼一枝桃，粉艳天然好。","只被春风摆撼多，颜色凋零早。","结子未为迟，悔恨随芳草。","不下山来不出溪，待守刘郎老。"]},{"id":"c63-398","title":"卜算子·旅雁向南飞","rhythmic":"卜算子","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["旅雁向南飞，风雨群初失。","饥渴辛勤两翅垂，独下寒汀立。","鸥鹭苦难亲，矰缴忧相逼。","云海茫茫无处归，谁听哀鸣急。"]},{"id":"c63-399","title":"卜算子·山晓鹧鸪啼","rhythmic":"卜算子","author":"朱敦儒","authorSlug":"朱敦儒","dynasty":"宋","kind":"ci","paragraphs":["山晓鹧鸪啼，云暗泷州路。","榕叶阴浓荔子青，百尺桄榔树。","尽日不逢人，猛地风吹雨。","惨黯蛮溪鬼峒寒，隐隐闻铜鼓。"]}]