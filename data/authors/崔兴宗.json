{"slug":"崔兴宗","name":"崔兴宗","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":["崔兴宗，与王维、裴迪俱居终南，后官右补阙。诗五首。"],"works":[{"id":"t6-242","title":"同王右丞送瑗公南归","kind":"诗"},{"id":"t6-243","title":"青雀歌","kind":"诗"},{"id":"t6-244","title":"和王维敕赐百官樱桃","kind":"诗"},{"id":"t6-245","title":"留别王维","kind":"诗"},{"id":"t6-246","title":"酬王维卢象见过林亭","kind":"诗"}]}