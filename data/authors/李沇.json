{"slug":"李沇","name":"李沇","dynasty":"唐","style":"字东济","life":"","origin":"","seal":"李","bio":["李沇，字东济，江夏人，宰相磎之子也。与磎同为王行瑜所杀，行瑜败，赠礼部员外郎。诗六首。"],"works":[{"id":"t38-628","title":"闲宵望月","kind":"诗"},{"id":"t38-629","title":"醮词","kind":"诗"},{"id":"t38-630","title":"巫山高","kind":"诗"},{"id":"t38-631","title":"梦仙谣","kind":"诗"},{"id":"t38-632","title":"秋霖歌","kind":"诗"},{"id":"t38-633","title":"方响歌","kind":"诗"}]}