{"slug":"宋光嗣","name":"宋光嗣","dynasty":"唐","style":"","life":"","origin":"","seal":"宋","bio":["六军诸卫事。凡断国章，多同儿戏。前蜀亡，为王宗弼所杀。","诗七首。（《全唐诗》无宋光嗣诗，传据《十国春秋》卷四十六本传）"],"works":[{"id":"t56-240","title":"无题","kind":"诗"},{"id":"t56-241","title":"判行营将士申请裹粮","kind":"诗"},{"id":"t56-242","title":"判内庭求事人","kind":"诗"},{"id":"t56-243","title":"判导江县申状封皮上著状门府衙","kind":"诗"},{"id":"t56-244","title":"判小朝官郭延钧进识字女子","kind":"诗"},{"id":"t56-245","title":"判神奇军背军官健李绍妻阿邓乞改嫁","kind":"诗"},{"id":"t56-246","title":"判简州刺史安太尉申院状希酒场云系州收搉","kind":"诗"},{"id":"t56-247","title":"判内门捉得御厨杂使衙官偷肉","kind":"诗"}]}