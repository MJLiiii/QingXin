[{"id":"c59-400","title":"菩萨蛮·湿云不动溪桥冷","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["湿云不动溪桥冷。","嫩寒初透东风影。","桥下水声长。","一枝和月香。","人怜花似旧。","花比人应瘦。","莫凭小栏干。","夜深花正寒。"]},{"id":"c59-401","title":"踏青游·□火初晴","rhythmic":"踏青游","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["□火初晴，绿遍禁池芳草。","斗锦绣、火城驰道。","踏青游，拾翠惜，袜罗弓小。","莲步袅。","腰支佩兰轻妙。","行过上林春好。","今困天涯，何限旧情相恼。","念摇落、玉京寒早。","任刘郎、目断蓬山难到。","仙梦杳。","良宵又过了。","楼台万家清晓。"]},{"id":"c59-402","title":"阮郎归·歌停檀板舞停鸾","rhythmic":"阮郎归","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["歌停檀板舞停鸾。","高阳饮兴阑。","兽烟喷尽玉壶乾。","香分小凤团。","雪浪浅，露珠圆。","捧瓯春笋寒。","绛纱笼下跃金鞍。","归时人倚栏。"]},{"id":"c59-403","title":"西江月·马趁香微路远","rhythmic":"西江月","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["马趁香微路远，沙笼月淡烟斜。","渡波清彻映妍华。","倒绿枝寒凤挂。","挂凤寒枝绿倒，华妍映彻清波。","渡斜烟淡月笼沙。","远路微香趁马。"]},{"id":"c59-404","title":"失调名·拼沈醉","rhythmic":"失调名","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["拼沈醉、金荷须满。","怕年年此际，催归禁篽，侍黄柑宴。"]},{"id":"c59-405","title":"踏莎行·山秀芙蓉","rhythmic":"踏莎行","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["山秀芙蓉，溪明罨画。","真游洞穴沧波下。","临风慨想斩蛟灵，长桥千载犹横跨。","解佩投簪，求田问舍。","黄鸡白酒渔樵社。","元龙非复少时豪，耳根洗尽功名话。"]},{"id":"c59-406","title":"踏莎行·这个秃奴","rhythmic":"踏莎行","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["这个秃奴，修行忒煞。","云山顶上空持戒。","一从迷恋玉楼人，鹑衣百结浑无奈。","毒手伤人，花容粉碎。","空空色色今何在。","臂间刺道苦相思，这回还了相思债。"]},{"id":"c59-407","title":"失调名·寂寂珠帘蛛网满","rhythmic":"失调名","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["寂寂珠帘蛛网满。"]},{"id":"c59-408","title":"定风波·闲卧藤床观社柳","rhythmic":"定风波","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["闲卧藤床观社柳。"]},{"id":"c59-409","title":"定风波·子瞻书困点新茶","rhythmic":"定风波","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["子瞻书困点新茶。"]},{"id":"c59-410","title":"失调名·唤起离情","rhythmic":"失调名","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["唤起离情，慵推孤枕。"]},{"id":"c59-411","title":"失调名·山头望","rhythmic":"失调名","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["山头望，波光泼眼。"]},{"id":"c59-412","title":"水调歌・水调·我歌月徘徊","rhythmic":"水调歌・水调","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["我歌月徘徊，我舞影凌乱。"]},{"id":"c59-413","title":"失调名·揭起裙儿","rhythmic":"失调名","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["揭起裙儿，一阵油盐酱醋香。"]},{"id":"c59-414","title":"鹧鸪天·罗带双垂画不成","rhythmic":"鹧鸪天","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["罗带双垂画不成。","殢人娇态最轻盈。","酥胸斜抱天边月，玉手轻弹水面冰。","无限事，许多情。","四弦丝竹苦丁宁。","饶君拨尽相思调，待听梧桐叶落声。"]},{"id":"c59-415","title":"西江月·碧雾轻笼两凤","rhythmic":"西江月","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["碧雾轻笼两凤，寒烟淡拂双鸦。","为谁流睇不归家。","错认门前过马。","有意偷回笑眼，无言强整衣纱。","刘郎一见武陵花。","从此春心荡也。"]},{"id":"c59-416","title":"夜行船·今夜阴云初霁","rhythmic":"夜行船","author":"赵","authorSlug":"赵","dynasty":"宋","kind":"ci","paragraphs":["今夜阴云初霁。","画帘外、月华如水。","露霭晴空，风吹高树，满院中秋意。","皎皎蟾光当此际。","怎奈何、不成况味。","莫近檐间，休来窗上，且放离人睡。"]},{"id":"c59-417","title":"河传·大官无闷","rhythmic":"河传","author":"郭讵","authorSlug":"郭讵","dynasty":"宋","kind":"ci","paragraphs":["大官无闷。","刚被傍人、竟来相问。","又难为□□敷臣。","且只将、甘草论。","朴消大戟并银粉。","疏风紧。","甘草闲相混。","及至下来，转杀他人。","尔甘草、有一分。"]},{"id":"c59-418","title":"水龙吟·晚来轻拂","rhythmic":"水龙吟","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["晚来轻拂，游云尽卷，霁色寒相射。","银潢半掩，秋毫欲数，分明不夜。","玉琯传声，羽衣催舞，此欢难借。","凛清辉，但觉圆光照影，冰壶莹、真无价。","闻道水晶宫殿，蕙炉薰、珠帘高挂。","琼枝半倚，瑶觞更劝，莺娇燕姹。","目断魂飞，翠萦红绕，空吟小砑。","想归来醉里，鸾篦凤朵，倩何人卸。"]},{"id":"c59-419","title":"蓦山溪·神仙院宇","rhythmic":"蓦山溪","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["神仙院宇，记得春归后。","蜂蝶不胜闲，惹残香、萦纡深透。","玉徽指稳，别是一般情，方永昼。","因谁瘦。","都为天然秀。","桐阴未减，独自携芳酎。","再弄想前欢，拊金樽、何时似旧。","凭谁说与，潘鬓转添霜，飞陇首。","云将皱。","应念相思久。"]},{"id":"c59-420","title":"蓦山溪·金柔火老","rhythmic":"蓦山溪","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["金柔火老，欲避几无地。","谁借一檐风，锁幽香、愔愔清邃。","瑶阶珠砌，如膜遇金篦，流水外，落花前，岂是人能致。","擘鳞泛玉，笑语皆真类。","惆怅月边人，驾云軿、何方适意。","么弦咽处，空感旧时声，兰易歇，恨偏长，魂断成何事。"]},{"id":"c59-421","title":"蓦山溪·蛾眉亭上","rhythmic":"蓦山溪","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["蛾眉亭上，今日交冬至。","已报一阳生，更佳雪、因时呈瑞。","匀飞密舞，都是散天花，山不见，水如山，浑在冰壶里。","平生选胜，到此非容易。","弄月与燃犀，漫劳神、徒能惊世。","争如此际，天意巧相符，须痛饮，庆难逢，莫诉厌厌醉。"]},{"id":"c59-422","title":"蓦山溪·晚来寒甚","rhythmic":"蓦山溪","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["晚来寒甚，密雪穿庭户。","如在广寒宫，惊满目、瑶林琼树。","佳人乘兴，应是得欢多，泛新声，催金盏，别有留心处。","争知这里，没个人言语。","拨尽火边灰，搅愁肠、飞花舞絮。","凭谁子细，说与此时情，欢暂歇，酒微醺，还解相思否。"]},{"id":"c59-423","title":"满庭芳·一到江南","rhythmic":"满庭芳","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["一到江南，三逢此夜，举头羞见婵娟。","黯然怀抱，特地遣谁宽。","分外清光泼眼，迷滉漾、无计拘拦。","天如洗，星河尽掩，全胜异时看。","佳人，还忆否，年时此际，相见方难。","谩红绫偷寄，孤被添寒。","何事佳期再睹，翻怅望、重叠关山。","归来呵，休教独自，肠断对团圆。"]},{"id":"c59-424","title":"满庭芳·花陌千条","rhythmic":"满庭芳","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["花陌千条，珠帘十里，梦中还是扬州。","月斜河汉，曾记醉歌楼。","谁赋红绫小砑，因飞絮、天与风流。","春常在，仙源路隔，空自泛渔舟。","新秋。","初雨过，龙团细碾，雪乳浮瓯。","问殷勤何处，特地相留。","应念长门赋罢，消渴甚、无物堪酬。","情无尽，金扉玉榜，何日许重游。"]},{"id":"c59-425","title":"玉蝴蝶·坐久灯花开尽","rhythmic":"玉蝴蝶","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["坐久灯花开尽，暗惊风叶，初报霜寒。","冉冉年华催暮，颜色非丹。","搅回肠、蛩吟似织，留恨意、月彩如摊。","惨无欢。","篆烟萦素，空转雕盘。","何难。","别来几日，信沈鱼鸟，情满关山。","耳边依约，常记巧语绵蛮。","聚愁窠、蜂房未密，倾泪眼、海水犹悭。","奄更阑。","渐移银汉，低泛帘颜。"]},{"id":"c59-426","title":"早梅芳・喜迁莺·雪初销","rhythmic":"早梅芳・喜迁莺","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["雪初销，斗觉寒将变。","已报梅梢暖。","日边霜外，迤逦枝条自柔软。","嫩苞匀点缀，绿萼轻裁剪。","隐深心，未许清香散。","渐融和，开欲遍。","密处疑无间。","天然标韵，不与群花斗深浅。","夕阳波似动，曲水风犹懒。","最销魂，弄影无人见。"]},{"id":"c59-427","title":"谢池春·残寒销尽","rhythmic":"谢池春","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["残寒销尽，疏雨过、清明后。","花径敛馀红，风沼萦新皱。","乳燕穿庭户，飞絮沾襟袖。","正佳时，仍晚昼。","著人滋味，真个浓如酒。","频移带眼，空只恁、厌厌瘦。","不见又思量，见了还依旧。","为问频相见，何似长相守。","天不老，人未偶。","且将此恨，分付庭前柳。"]},{"id":"c59-428","title":"怨三三·清溪一派泻揉蓝","rhythmic":"怨三三","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["清溪一派泻揉蓝。","岸草毵毵。","记得黄鹂语画檐。","唤狂里、醉重三。","春风不动垂帘。","似三五、初圆素蟾。","镇泪眼廉纤。","何时歌舞，再和池南。"]},{"id":"c59-429","title":"春光好·霜压晓","rhythmic":"春光好","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["霜压晓，月收阴。","斗寒深。","看尽烛花金鸭冷，卷残衾。","卯酒从谁细酌，馀香无计重寻。","空把夜来相见梦，写文琴。"]},{"id":"c59-430","title":"千秋岁·深帘静昼","rhythmic":"千秋岁","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["深帘静昼。","绰约闺房秀。","叩衣楚制飞文绣。","凝脂肤理腻，削玉腰围瘦。","闲舞袖。","回身昵语凭肩久。","眉压横波皱。","歌断青青柳。","钗遽擘，壶频叩。","鬓凄清镜雪，泪涨芳樽酒。","难再偶。","沈沈梦峡雪归后。"]},{"id":"c59-431","title":"千秋岁·柔肠寸折","rhythmic":"千秋岁","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["柔肠寸折。","解袂留清血。","蓝桥动是经年别。","掩门春絮乱，敧枕秋蛩咽。","檀篆灭。","鸳衾半拥空床月。","妆镜分来缺。","尘污菱花洁。","嘶骑远，鸣机歇。","密封书锦字，巧绾香囊结。","芳信绝。","东风半落梅梢雪。"]},{"id":"c59-432","title":"千秋岁·万红暄昼","rhythmic":"千秋岁","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["万红暄昼。","占尽人间秀。","怎生图画如何绣。","宜推萧史伴，消得东阳瘦。","垂窄袖。","花前镇忆相携久。","泪裛回纹皱。","好在章台柳。","洞户隔，凭谁叩。","寄声虽有雁，会面难同酒。","无计偶。","萧萧暮雨黄昏后。"]},{"id":"c59-433","title":"千秋岁·休嗟磨折","rhythmic":"千秋岁","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["休嗟磨折。","看取罗巾血。","殷勤且话经年别。","庭花番怅望，檐雨同呜咽。","明半灭。","灯光夜夜多如月。","无复伤离缺。","共保冰霜洁。","不断梦，从今歇。","收回书上絮，解尽眉头结。","犹未绝。","金徽泛处应能雪。"]},{"id":"c59-434","title":"千秋岁·中秋才过","rhythmic":"千秋岁","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["中秋才过，又是重阳到。","露乍冷，寒将报。","绿香摧渚芰，黄密攒庭草。","人未老。","蓝桥漫促霜砧捣。","照影兰缸晕，破户银蟾小。","樽在眼，从谁倒。","强铺同处被，愁却欢时帽。","须信道。","狂心未歇情难老。"]},{"id":"c59-435","title":"千秋岁·深秋庭院","rhythmic":"千秋岁","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["深秋庭院，残暑全消退。","天幕迥，云容碎。","地偏人罕到，风惨寒微带。","初睡起，翩翩戏蝶飞成对。","叹息谁能会。","犹记逢倾盖。","情暂遣，心常在。","沈沈音信断，冉冉光阴改。","红日晚，仙山路隔空云海。"]},{"id":"c59-436","title":"临江仙·知有阆风花解语","rhythmic":"临江仙","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["知有阆风花解语，从来只许传闻。","光明休咏汉宫新。","拥身疑有月，衬步恨无云。","莫把金樽容易劝，坐来几度销魂。","不知仙骨在何人。","好将千岁日，占断四时春。"]},{"id":"c59-437","title":"临江仙·九十日春都过了","rhythmic":"临江仙","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["九十日春都过了，寻常偶到江皋。","水容山态两相饶。","草平天一色，风暖燕双高。","酒病厌厌何计那，飞红更送无聊。","莺声又似耳边娇。","难回巫峡梦，空恨武陵桃。"]},{"id":"c59-438","title":"江神子・江城子·恼人天气雪消时","rhythmic":"江神子・江城子","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["恼人天气雪消时。","落梅飞。","日初迟。","小阁幽窗，时节听黄鹂。","新洗头来娇困甚，才试著，夹罗衣。","木梨花拂淡燕脂。","翠云敧。","敛双眉。","月浅星深，天淡玉绳低。","不道有人肠断也，浑不语，醉如痴。"]},{"id":"c59-439","title":"江神子・江城子·今宵莫惜醉颜红","rhythmic":"江神子・江城子","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["今宵莫惜醉颜红。","十分中。","且从容。","须信欢情，回首似旋风。","流落天涯头白也，难得是，再相逢。","十年南北感征鸿。","恨应同。","苦重重。","休把愁怀，容易便书空。","只有琴樽堪寄老，除此外，尽蒿蓬。"]},{"id":"c59-440","title":"江神子・江城子·阑干掐遍等新红","rhythmic":"江神子・江城子","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["阑干掐遍等新红。","酒频中。","恨匆匆。","投得花开，还报夜来风。","惆怅春光留不住，又何似，莫相逢。","月窗何处想归鸿。","与谁同。","意千重。","婉思柔情，一旦总成空。","仿佛么弦犹在耳，应为我，首如蓬。"]},{"id":"c59-441","title":"清平乐·西江霜后","rhythmic":"清平乐","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["西江霜后，万点暄晴昼。","璀璨寄来光欲溜。","正值文君病酒。","画屏斜倚窗纱。","睡痕犹带朝霞。","为问清香绝韵，何如解语梅花。"]},{"id":"c59-442","title":"清平乐·萧萧风叶","rhythmic":"清平乐","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["萧萧风叶。","似与更声接。","欲寄明珰非为怯。","梦断兰舟桂楫。","学书只写鸳鸯。","却应无奈愁肠。","安得一双飞去，春风芳草池塘。"]},{"id":"c59-443","title":"清平乐·殷勤仙友","rhythmic":"清平乐","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["殷勤仙友。","劝我千年酒。","一曲履霜谁与奏。","邂逅麻姑妙手。","坐来休叹尘劳。","相逢难似今朝。","不待亲移玉指，自然痒处都消。"]},{"id":"c59-444","title":"清平乐·当时命友","rhythmic":"清平乐","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["当时命友。","曾借邻家酒。","旧曲不知何处奏。","梦断空思纤手。","却应去路非遥。","今朝还有明朝。","谩道人能化石，须知石被人消。"]},{"id":"c59-445","title":"清平乐·仙家庭院","rhythmic":"清平乐","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["仙家庭院。","红日看看晚。","一朵梅花挨枕畔。","玉指几回拈看。","拥衾不比寻常。","天涯无限思量。","看了又还重嗅，分明不为清香。"]},{"id":"c59-446","title":"浪淘沙·霞卷与云舒","rhythmic":"浪淘沙","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["霞卷与云舒。","月淡星疏。","摩徽转轸不曾虚。","弹到当时留意处，谁是相如。","魂断酒家垆。","路隔云衢。","舞鸾镜里早妆初。","拟学画眉张内史，略借功夫。"]},{"id":"c59-447","title":"卜算子·我住长江头","rhythmic":"卜算子","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["我住长江头，君住长江尾。","日日思君不见君，共饮长江水。","此水几时休，此恨何时已。","只愿君心似我心，定不负相思意。"]},{"id":"c59-448","title":"忆秦娥·清溪咽","rhythmic":"忆秦娥","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["清溪咽。","霜风洗出山头月。","山头月。","迎得云归，还送云别。","不知今是何时节。","凌歊望断音尘绝。","音尘绝。","帆来帆去，天际双阙。"]},{"id":"c59-449","title":"蝶恋花·天淡云闲晴昼永","rhythmic":"蝶恋花","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["天淡云闲晴昼永。","庭户深沈，满地梧桐影。","骨冷魂清如梦醒。","梦回犹是前时景。","取次杯盘催酩酊。","醉帽频敧，又被风吹正。","踏月归来人已静。","恍疑身在蓬莱顶。"]},{"id":"c59-450","title":"蝶恋花·玉骨冰肌天所赋","rhythmic":"蝶恋花","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["玉骨冰肌天所赋。","似与神仙，来作烟霞侣。","枕畔拈来亲手付。","书窗终日常相顾。","几度离披留不住。","依旧清香，只欠能言语。","再送神仙须爱护。","他时却待亲来取。"]},{"id":"c59-451","title":"蝶恋花·万事都归一梦了","rhythmic":"蝶恋花","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["万事都归一梦了。","曾向邯郸，枕上教知道。","百岁年光谁得到。","其间忧患知多少。","无事且频开口笑。","纵酒狂歌，销遣闲烦恼。","金谷繁华春正好。","玉山一任樽前倒。"]},{"id":"c59-452","title":"蝶恋花·为爱梅花如粉面","rhythmic":"蝶恋花","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["为爱梅花如粉面。","天与功夫，不似人间见。","几度拈来亲比看。","功夫却是花枝浅。","觅得归来临几砚。","尽日相看，默默情无限。","更不嗅时须百遍。","分明销得人肠断。"]},{"id":"c59-453","title":"浣溪沙·剪水开头碧玉条","rhythmic":"浣溪沙","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["剪水开头碧玉条。","能令江汉客魂销。","只应香信是春潮。","戴了又羞缘我老，折来同嗅许谁招。","凭将此意问妖娆。"]},{"id":"c59-454","title":"浣溪沙·玉室金堂不动尘","rhythmic":"浣溪沙","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["玉室金堂不动尘。","林梢绿遍已无春。","清和佳思一番新。","道骨仙风云外侣，烟鬟雾鬓月边人。","何妨沈醉到黄昏。"]},{"id":"c59-455","title":"浣溪沙·依旧琅玕不染尘","rhythmic":"浣溪沙","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["依旧琅玕不染尘。","霜风吹断笑时春。","一簪华发为谁新。","白雪幽兰犹有韵，鹊桥星渚可无人。","金莲移处任尘昏。"]},{"id":"c59-456","title":"浣溪沙·昨日霜风入绛帷","rhythmic":"浣溪沙","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["昨日霜风入绛帷。","曲房深院绣帘垂。","屏风几曲画生枝。","酒韵渐浓欢渐密，罗衣初试漏初迟。","已凉天气未寒时。"]},{"id":"c59-457","title":"西江月·昨夜十分霜重","rhythmic":"西江月","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["昨夜十分霜重，晓来千里书传。","吴山秀处洞庭边。","不夜星垂初遍。","好事寄来禅侣，多情将送琴仙。","为怜佳果称婵娟。","一笑聊回媚眼。"]},{"id":"c59-458","title":"西江月·醉透香浓斗帐","rhythmic":"西江月","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["醉透香浓斗帐，灯深月浅回廊。","当时背面两伥伥。","何况临风怀想。","舞柳经春祗瘦，游丝到地能长。","鸳鸯半调已无肠。","忍把么弦再上。"]},{"id":"c59-459","title":"西江月·念念欲归未得","rhythmic":"西江月","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["念念欲归未得，迢迢此去何求。","都缘一点在心头。","忘了霜朝雪后。","要见有时有梦，相思无处无愁。","小窗若得再绸缪。","应记如今时候。"]},{"id":"c59-460","title":"鹊桥仙·风清月莹","rhythmic":"鹊桥仙","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["风清月莹，天然标韵，自是闺房之秀。","情多无那不能禁，常是为、而今时候。","绿云低拢，红潮微上，画幕梅寒初透。","一般偏更恼人深，时更把、眉儿轻皱。"]},{"id":"c59-461","title":"西江月·宿云收尽","rhythmic":"西江月","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["宿云收尽，纤尘不警，万里银河低挂。","清冥风露不胜寒，无计学、双鸾并驾。","玉徽声断，宝钗香远，空赋红绫小砑。","庾郎知有几多愁，怎奈向、月明今夜。"]},{"id":"c59-462","title":"踏莎行·绿遍东山","rhythmic":"踏莎行","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["绿遍东山，寒归西渡。","分明认得春来处。","风轻雨细更愁人，高唐何在空朝暮。","离恨相寻，酒狂无素。","柳条又折年时数。","一番情味有谁知，断魂还送征帆去。"]},{"id":"c59-463","title":"踏莎行·还是归来","rhythmic":"踏莎行","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["还是归来，依前问渡。","好风引到经行处。","几声啼鸟又催耕，草长柳暗春将暮。","潦倒无成，疏慵有素。","且陪野老酬天数。","多情惟有面前山，不随潮水来还去。"]},{"id":"c59-464","title":"鹧鸪天·节是重阳却斗寒","rhythmic":"鹧鸪天","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["节是重阳却斗寒。","可堪风雨累寻欢。","虽辜早菊同高柳，聊楫残蕉共小栏。","浮蚁嫩，炷烟盘。","恨无莺唱舞催鸾。","空惊绝韵天边落，不许韶颜梦里看。"]},{"id":"c59-465","title":"鹧鸪天·浓丽妖妍不是妆","rhythmic":"鹧鸪天","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["浓丽妖妍不是妆。","十分风艳夺韶光。","牡丹开就应难比，繁富犹疑过海棠。","须仔细，更端相。","烂霞梳晕带朝阳。","千金未足酬真赏，一度相看一断肠。"]},{"id":"c59-466","title":"鹧鸪天·避暑佳人不著妆","rhythmic":"鹧鸪天","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["避暑佳人不著妆。","水晶冠子薄罗裳。","摩绵扑粉飞琼屑，滤蜜调冰结绛霜。","随定我，小兰堂。","金盆盛水绕牙床。","时时浸手心头熨，受尽无人知处凉。"]},{"id":"c59-467","title":"鹧鸪天·收尽微风不见江","rhythmic":"鹧鸪天","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["收尽微风不见江。","分明天水共澄光。","由来好处输闲地，堪叹人生有底忙。","心既远，味偏长。","须知粗布胜无裳。","从今认得归田乐，何必桃源是故乡。"]},{"id":"c59-468","title":"朝中措·腊穷天际傍危栏","rhythmic":"朝中措","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["腊穷天际傍危栏。","密雪舞初残。","表里江山如画，分明不似人间。","功名何在，文章漫与，空叹流年。","独恨归来已晚，半生孤负渔竿。"]},{"id":"c59-469","title":"朝中措·暮山环翠绕层栏","rhythmic":"朝中措","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["暮山环翠绕层栏。","时节岁将残。","远雁不传家信，空能嘹唳人间。","客程无尽，归心易感，谁与忘年。","早晚临流凝望，饥帆催卸风竿。"]},{"id":"c59-470","title":"朝中措·翰林豪放绝勾栏","rhythmic":"朝中措","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["翰林豪放绝勾栏。","风月敢雕残。","一旦荆溪仙子，笔头唤聚时间。","锦袍如在，云山顿改，宛似当年。","应笑溧阳衰尉，鲇鱼依旧悬竿。"]},{"id":"c59-471","title":"阮郎归·朱唇玉羽下蓬莱","rhythmic":"阮郎归","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["朱唇玉羽下蓬莱。","佳时近早梅。","惜花情味久安排。","枝头开未开。","魂欲断，恨难裁。","香心休见猜。","果知何逊是仙才。","何妨入梦来。"]},{"id":"c59-472","title":"采桑子·相逢未几还相别","rhythmic":"采桑子","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["相逢未几还相别，此恨难同。","细雨濛濛。","一片离愁醉眼中。","明朝去路云宵外，欲见无从。","满袂仙风。","空托双凫作信鸿。"]},{"id":"c59-473","title":"如梦令·回首芜城旧苑","rhythmic":"如梦令","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["回首芜城旧苑。","还是翠深红浅。","春意已无多，斜日满帘飞燕。","不见。","不见。","门掩落花庭院。"]},{"id":"c59-474","title":"临江仙·偶向凌歊台上望","rhythmic":"临江仙","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["偶向凌歊台上望，春光已过三分。","江山重叠倍销魂。","风花飞有态，烟絮醉无痕。","已是年来伤感甚，那堪旧恨仍存。","清愁满眼共谁论。","却应台下草，不解忆王孙。"]},{"id":"c59-475","title":"临江仙·难得今朝风日好","rhythmic":"临江仙","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["难得今朝风日好，春光佳思平分。","虽然公子暗招魂。","其如抬眼看，都是旧时痕。","酒到强寻欢日路，坐来谁为温存。","落花流水不堪论。","何时弦上意，重为拂桐孙。"]},{"id":"c59-476","title":"丑奴儿・采桑子·春风似有灯前约","rhythmic":"丑奴儿・采桑子","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["春风似有灯前约，先报佳期。","点缀相宜。","天气犹寒蝶未知。","嫩黄染就蜂鬓巧，香压团枝。","淡注仙衣。","方士临门未起时。"]},{"id":"c59-477","title":"青玉案·小篷又泛曾行路","rhythmic":"青玉案","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["小篷又泛曾行路。","这身世、如何去。","去了还来知几度。","多情山色，有情江水，笑我归无处。","夕阳杳杳还催暮。","练净空吟谢郎句。","拭祷波神应见许。","帆开风转，事谐心遂，直到明年雨。"]},{"id":"c59-478","title":"更漏子·暑方烦","rhythmic":"更漏子","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["暑方烦，人似愠。","怅望林泉幽峻。","情会处，景偏长。","心清闻妙香。","宝幢低，金锁碎。","竹影桐印窗外。","新事旧，旧愁新。","空嗟不见人。"]},{"id":"c59-479","title":"渔家傲·洗尽秋容天似莹","rhythmic":"渔家傲","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["洗尽秋容天似莹。","星稀月淡人初静。","策杖萦纡寻远径。","披昏暝。","堤边犊母闲相并。","遥想去舟魂欲凝。","一番佳思从谁咏。","憔悴归来如独醒。","知何境。","沈沈但觉烟村迥。"]},{"id":"c59-480","title":"南乡子·春后雨馀天","rhythmic":"南乡子","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["春后雨馀天。","娅姹黄鹂胜品弦。","榴叶千灯初报暑，阶前。","只有茶瓯味最便。","身世几蹁跹。","自觉年来更可怜。","欲问此情何所似，缘延。","看取窗间坠柳绵。"]},{"id":"c59-481","title":"南乡子·绿水满池塘","rhythmic":"南乡子","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["绿水满池塘。","点水蜻蜓避燕忙。","杏子压枝黄半熟，邻墙。","风送荷花几阵香。","角簟衬牙床。","汗透鲛绡昼影长。","点滴芭蕉疏雨过，微凉。","画角悠悠送夕阳。"]},{"id":"c59-482","title":"南乡子·睡起绕回塘","rhythmic":"南乡子","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["睡起绕回塘。","不见衔泥燕子忙。","前日花梢都绿遍，西墙。","犹有轻风递暗香。","步懒恰寻床。","卧看游丝到地长。","自恨无聊常病酒，凄凉。","岂有才情似沈阳。"]},{"id":"c59-483","title":"南乡子·小雨湿黄昏","rhythmic":"南乡子","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["小雨湿黄昏。","重午佳辰独掩门。","巢燕引雏浑去尽，销魂。","空向梁间觅宿痕。","客舍宛如村。","好事无人载一樽。","唯有莺声知此恨，殷勤。","恰似当时枕上闻。"]},{"id":"c59-484","title":"南乡子·泪眼转天昏","rhythmic":"南乡子","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["泪眼转天昏。","去路迢迢隔九门。","角黍满盘无意举，凝魂。","不为当时泽畔痕。","肠断武陵村。","骨冷难同月下樽。","强泛菖蒲酬令节，空勤。","风叶萧萧不忍闻。"]},{"id":"c59-485","title":"蓦山溪·青楼薄幸","rhythmic":"蓦山溪","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["青楼薄幸，已分终难偶。","寻遍绮罗间，悄无个、眼中翘秀。","江南春晓，花发乱莺飞，情渐透。","休辞瘦。","果有人相候。","醉乡路稳，常是身偏后。","谁谓正欢时，把相思、番成红豆。","千言万语，毕竟总成虚，章台柳。","青青否。","魂梦空搔首。"]},{"id":"c59-486","title":"减字木兰花·乱魂无据","rhythmic":"减字木兰花","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["乱魂无据。","黯黯只寻来处路。","灯尽花残。","不觉长更又向阑。","几回枕上。","那件不曾留梦想。","变尽星星。","一滴秋霖是一茎。"]},{"id":"c59-487","title":"减字木兰花·堤长春晚","rhythmic":"减字木兰花","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["堤长春晚。","冉冉浑如云外见。","欲语无门。","略许莺声隔岸闻。","锦屏绣幌。","犹待归来留一饷。","何事迟迟。","直恐游丝惹住伊。"]},{"id":"c59-488","title":"减字木兰花·触涂是碍","rhythmic":"减字木兰花","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["触涂是碍。","一任浮沈何必改。","有个人人。","自说居尘不染尘。","谩夸千手。","千物执持都是有。","气候融怡。","还取青天白日时。"]},{"id":"c59-489","title":"减字木兰花·莫非魔境","rhythmic":"减字木兰花","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["莫非魔境。","强向中间谈独醒。","一叶才飞。","便觉年华太半归。","醉云可矣。","认著依前还不是。","虚过今春。","有愧斜川得意人。"]},{"id":"c59-490","title":"减字木兰花·揉花催柳","rhythmic":"减字木兰花","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["揉花催柳。","一夜阴风几破牖。","平晓无云。","依旧光明一片春。","掀衣起走。","欲助喜欢须是酒。","惆怅空樽。","拟就王孙借十分。"]},{"id":"c59-491","title":"天门谣·天堑休论险","rhythmic":"天门谣","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["天堑休论险。","尽远目、与天俱占。","山水敛。","称霜晴披览。","正风静云闲、平潋滟。","想见高吟名不滥。","频扣槛。","杳杳落、沙鸥数点。"]},{"id":"c59-492","title":"好事近·相见两无言","rhythmic":"好事近","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["相见两无言，愁恨又还千叠。","别有恼人深处，在懵腾双睫。","七弦虽妙不须弹，惟愿醉香颊。","只恐近来情绪，似风前秋叶。"]},{"id":"c59-493","title":"减字木兰花·春到雨初晴","rhythmic":"减字木兰花","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["春到雨初晴，正是小楼时节。","柳眼向人微笑，傍阑干堪折。","暮山浓淡锁烟霏，梅杏半明灭。","玉斝莫辞沈醉，待归时斜月。"]},{"id":"c59-494","title":"减字木兰花·上尽玉梯云","rhythmic":"减字木兰花","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["上尽玉梯云，还见一番佳节。","惆怅旧时行处，把青青轻折。","倚阑人醉欲黄昏，飞鸟望中灭。","天面碧琉璃上，印弯弯新月。"]},{"id":"c59-495","title":"浣溪沙·龟坼沟塍草压堤","rhythmic":"浣溪沙","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["龟坼沟塍草压堤。","三农终日望云霓。","一番甘雨报佳时。","闻道醉乡新占断，更开诗社互排巇。","此时空恨隔云泥。"]},{"id":"c59-496","title":"浣溪沙·雨暗轩窗昼易昏","rhythmic":"浣溪沙","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["雨暗轩窗昼易昏。","强敧纤手浴金盆。","却因凉思谢飞蚊。","酒量羡君如鹄举，寒乡怜我似鸱蹲。","由来同是一乾坤。"]},{"id":"c59-497","title":"浣溪沙·声名自昔犹时鸟","rhythmic":"浣溪沙","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["声名自昔犹时鸟，日月何尝避覆盆。","是非都付鬓边蚊。","邂逅风雷终有用，低回囊槛要深蹲。","酒中聊复比乾坤。"]},{"id":"c59-498","title":"菩萨蛮·五云深处蓬山杳","rhythmic":"菩萨蛮","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["五云深处蓬山杳。","寒轻雾重银蟾小。","枕上挹馀香。","春风归路长。","雁来书不到。","人静重门悄。","一阵落花风。","云山千万重。"]},{"id":"c59-499","title":"菩萨蛮·青梅又是花时节","rhythmic":"菩萨蛮","author":"李之仪","authorSlug":"李之仪","dynasty":"宋","kind":"ci","paragraphs":["青梅又是花时节。","粉墙闲把青梅折。","玉镫偶逢君。","春情如乱云。","藕丝牵不断。","谁信朱颜换。","莫厌十分斟。","酒深情更深。"]}]