{"□嘉惠":{"slug":"□嘉惠","name":"□嘉惠","dynasty":"唐","style":"","life":"","origin":"","seal":"□","bio":[],"works":[{"id":"t50-222","title":"咏鹊","kind":"诗"}]},"叶景山":{"slug":"叶景山","name":"叶景山","dynasty":"宋","style":"","life":"","origin":"","seal":"叶","bio":[],"works":[{"id":"c78-307","title":"感皇恩·十月小春时","kind":"词"},{"id":"c78-308","title":"临江仙·清晓于门开寿宴","kind":"词"},{"id":"c78-309","title":"临江仙·杨柳池塘桃李径","kind":"词"},{"id":"c78-310","title":"感皇恩·春水满池塘","kind":"词"}]},"张轸":{"slug":"张轸","name":"张轸","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"t43-205","title":"舟行旦发","kind":"诗"}]},"朱敦复":{"slug":"朱敦复","name":"朱敦复","dynasty":"宋","style":"","life":"","origin":"","seal":"朱","bio":[],"works":[{"id":"c63-207","title":"双燕儿·尚志服事跛神仙","kind":"词"}]},"李善美":{"slug":"李善美","name":"李善美","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t56-317","title":"习家池大堤诗（题拟）","kind":"诗"}]},"李竦":{"slug":"李竦","name":"李竦","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["张惟俭，宣城当涂人。大历六年进士第，官和州刺史。诗一首。"],"works":[{"id":"t15-62","title":"长至日上公献寿","kind":"诗"},{"id":"t15-63","title":"赋得西戎献白玉环","kind":"诗"}]},"李舜弦":{"slug":"李舜弦","name":"李舜弦","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李舜弦，梓州人，珣之妹，蜀王衍纳为昭仪。诗三首。"],"works":[{"id":"t43-755","title":"随驾游青城","kind":"诗"},{"id":"t43-756","title":"蜀宫应制","kind":"诗"},{"id":"t43-757","title":"钓鱼不得","kind":"诗"}]},"林氏":{"slug":"林氏","name":"林氏","dynasty":"唐","style":"","life":"","origin":"","seal":"林","bio":["林氏，济南人，隰城丞薛元暧妻也。元暧早卒，林博涉五经，有母仪令德。训其子彦辅、彦国、彦伟、彦云及姪据、摠、播，并登进士第，衣冠荣之。","诗一首。"],"works":[{"id":"t43-923","title":"送男左贬诗","kind":"诗"}]},"王幼玉":{"slug":"王幼玉","name":"王幼玉","dynasty":"宋","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"c64-754","title":"失调名·粉面羞搽泪满腮","kind":"词"}]},"白履忠":{"slug":"白履忠","name":"白履忠","dynasty":"唐","style":"号为梁丘子","life":"","origin":"","seal":"白","bio":["白履忠，陈留浚仪人。博涉文史。隐居于古大梁城，时号为梁丘子。","景云中，征拜校书郎，寻弃官而归。开元十年，被荐入阁侍读。十七年，被征赴京师。","留数月，即以老病归。寻寿终。著有《三玄精辩论》一卷，文集十卷，又注《老子》及《黄庭内景经》。","诗一首。（《全唐诗》无白履忠立场，传据《旧唐书》本传）"],"works":[{"id":"t52-717","title":"还丹口诀","kind":"诗"}]},"皇甫湜":{"slug":"皇甫湜","name":"皇甫湜","dynasty":"唐","style":"字持正","life":"","origin":"","seal":"皇","bio":["皇甫湜，字持正，新安人。元和中擢进士第，为陆浑尉，仕至工部郎中。裴度辟为判官。","集三卷，今存诗三首。"],"works":[{"id":"t19-622","title":"题浯溪石","kind":"诗"},{"id":"t19-623","title":"石佛谷","kind":"诗"},{"id":"t19-624","title":"出世篇","kind":"诗"}]},"萧辟":{"slug":"萧辟","name":"萧辟","dynasty":"唐","style":"","life":"","origin":"","seal":"萧","bio":[],"works":[{"id":"t56-420","title":"留题曹娥庙","kind":"诗"}]},"郑仁表":{"slug":"郑仁表","name":"郑仁表","dynasty":"唐","style":"字休范","life":"","origin":"","seal":"郑","bio":["郑仁表，字休范，荥阳人。累擢起居郎，刘邺作相时，贬死岭外。诗二首。","郑仁表，字休范，荥阳人，累擢起居郎，刘邺作相时，贬死岭外。诗二首。"],"works":[{"id":"t33-712","title":"赠妓僊哥","kind":"诗"},{"id":"t33-713","title":"赠妓命洛真","kind":"诗"},{"id":"t33-714","title":"句","kind":"诗"},{"id":"t48-278","title":"题沧浪峡牓","kind":"诗"}]},"郑仁轨":{"slug":"郑仁轨","name":"郑仁轨","dynasty":"唐","style":"","life":"","origin":"","seal":"郑","bio":["仁轨，贞观间为龙宗卫率府长史弘文馆直学士。诗一首。（《全唐诗》无郑仁轨诗）"],"works":[{"id":"t52-74","title":"五言奉日侍宴望海应诏","kind":"诗"}]},"郑昉":{"slug":"郑昉","name":"郑昉","dynasty":"唐","style":"","life":"","origin":"","seal":"郑","bio":[],"works":[{"id":"t43-311","title":"人不易知","kind":"诗"}]},"陆淞":{"slug":"陆淞","name":"陆淞","dynasty":"宋","style":"字子逸 · 号云溪","life":"","origin":"山阴（今浙江绍兴）","seal":"陆","bio":["--字子逸，号云溪，山阴 (今浙江绍兴) 人。陆佃之孙，陆游长兄。曾知辰州。","晚以疾废，卜筑于秀野，放傲世间。存词二首。"],"works":[{"id":"c59-782","title":"念奴娇·黄橙紫蟹","kind":"词"},{"id":"c59-783","title":"瑞鹤仙·脸霞红印枕","kind":"词"}]},"陈璠":{"slug":"陈璠","name":"陈璠","dynasty":"唐","style":"","life":"","origin":"","seal":"陈","bio":["陈璠，沛中走卒，与徐帅时溥结好，表为宿州太守，后以贪汚斩之。诗一首。"],"works":[{"id":"t41-167","title":"临刑诗","kind":"诗"}]},"齐推":{"slug":"齐推","name":"齐推","dynasty":"唐","style":"","life":"","origin":"","seal":"齐","bio":["推，高阳人。德宗相齐抗之弟。工正书，元和五年书李德裕《唐圯上图赞》，七年作《灵飞散传信录》，九年预石伞峰之游。","诗一首。（《全唐诗》无齐推诗，传据《全唐文》卷七一六、《金石录》卷六、《旧唐书》卷一三六及陈谏序）"],"works":[{"id":"t53-401","title":"登石伞峰","kind":"诗"}]}}