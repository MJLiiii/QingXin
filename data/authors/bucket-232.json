"}]},"彭叔夏":{"slug":"彭叔夏","name":"彭叔夏","dynasty":"宋","style":"","life":"","origin":"","seal":"彭","bio":[],"works":[{"id":"c70-796","title":"水调歌头·铜章纡墨绶","kind":"词"}]},"李景让":{"slug":"李景让","name":"李景让","dynasty":"唐","style":"字后己","life":"","origin":"","seal":"李","bio":["李景让，字后己，憕之孙。大中中，历御史大夫、西川节度使，终太子少保分司东都，谥曰孝。诗一首。"],"works":[{"id":"t31-332","title":"寄华州周侍郎立秋日奉诏祭岳诗","kind":"诗"},{"id":"t31-333","title":"句","kind":"诗"}]},"柳登":{"slug":"柳登","name":"柳登","dynasty":"唐","style":"字成伯","life":"","origin":"","seal":"柳","bio":["柳登，字成伯，河东人。年六十余方从宦，累迁至膳部郎中。元和初为大理少卿，迁右庶子，授右散骑审侍致仕。","长庆二年卒，年九十余。（《全唐诗》无柳登诗，传据《旧唐书》卷一四九本传）"],"works":[{"id":"t53-464","title":"颜鲁公挽歌词","kind":"诗"}]},"程垓":{"slug":"程垓","name":"程垓","dynasty":"宋","style":"字正伯","life":"","origin":"眉山（今属四川）","seal":"程","bio":["--字正伯，眉山 (今属四川) 人。苏轼中表程正辅之孙。淳熙间尝游临安，光宗时尚未宦达。","工诗文，词风凄婉绵丽。有《书舟词》。"],"works":[{"id":"c69-305","title":"满江红·门掩垂杨","kind":"词"},{"id":"c69-306","title":"满江红·水远山明","kind":"词"},{"id":"c69-307","title":"最高楼·旧时心事","kind":"词"},{"id":"c69-308","title":"南浦·金鸭懒薰香","kind":"词"},{"id":"c69-309","title":"摊破江城子・江城梅花引·娟娟霜月又侵门","kind":"词"},{"id":"c69-310","title":"木兰花慢·倩娇莺姹燕","kind":"词"},{"id":"c69-311","title":"八声甘州·问东君","kind":"词"},{"id":"c69-312","title":"洞庭春色・沁园春·锦字亲裁","kind":"词"},{"id":"c69-313","title":"四代好・宴清都·翠幕东风早","kind":"词"},{"id":"c69-314","title":"水龙吟·夜来风雨匆匆","kind":"词"},{"id":"c69-315","title":"玉漏迟·一春浑不见","kind":"词"},{"id":"c69-316","title":"折红英・撷芳词·桃花暖","kind":"词"},{"id":"c69-317","title":"上平西・金人捧露盘·爱春归","kind":"词"},{"id":"c69-318","title":"瑶阶草·空山子规叫","kind":"词"},{"id":"c69-319","title":"碧牡丹·睡起情无著","kind":"词"},{"id":"c69-320","title":"满庭芳·南月惊乌","kind":"词"},{"id":"c69-321","title":"念奴娇·秋风秋雨","kind":"词"},{"id":"c69-322","title":"雪狮儿·断云低晚","kind":"词"},{"id":"c69-323","title":"摸鱼儿·掩凄凉","kind":"词"},{"id":"c69-324","title":"无闷·天与多才","kind":"词"},{"id":"c69-325","title":"孤雁儿・御街行·在家不觉穷冬好","kind":"词"},{"id":"c69-326","title":"孤雁儿・御街行·双鬓乍绾横波溜","kind":"词"},{"id":"c69-327","title":"意难忘·花拥鸳房","kind":"词"},{"id":"c69-328","title":"一丛花·伤春时候一凭阑","kind":"词"},{"id":"c69-329","title":"蓦山溪·老来风味","kind":"词"},{"id":"c69-330","title":"满江红·葺屋为舟","kind":"词"},{"id":"c69-331","title":"小桃红・连理枝·不恨残花妥","kind":"词"},{"id":"c69-332","title":"芭蕉雨·雨过凉生藕叶","kind":"词"},{"id":"c69-333","title":"红娘子・连理枝·小小闲窗底","kind":"词"},{"id":"c69-334","title":"醉落魄・一斛珠·夏围初结","kind":"词"},{"id":"c69-335","title":"一翦梅·旧日心期不易招","kind":"词"},{"id":"c69-336","title":"一翦梅·小会幽欢整及时","kind":"词"},{"id":"c69-337","title":"眼儿媚·一枝烟雨瘦东墙","kind":"词"},{"id":"c69-338","title":"浪淘沙·山尽两溪头","kind":"词"},{"id":"c69-339","title":"雨中花令·闻说海棠开尽了","kind":"词"},{"id":"c69-340","title":"雨中花令·旧日爱花心未了","kind":"词"},{"id":"c69-341","title":"雨中花令·卷地芳草都过了","kind":"词"},{"id":"c69-342","title":"凤栖梧・蝶恋花·九月江南烟雨里","kind":"词"},{"id":"c69-343","title":"凤栖梧・蝶恋花·有客钱塘江上住","kind":"词"},{"id":"c69-344","title":"凤栖梧・蝶恋花·门外飞花风约住","kind":"词"},{"id":"c69-345","title":"凤栖梧・蝶恋花·薄薄窗油清似镜","kind":"词"},{"id":"c69-346","title":"凤栖梧・蝶恋花·九月重湖寒意早","kind":"词"},{"id":"c69-347","title":"愁倚阑・春光好·山无数","kind":"词"},{"id":"c69-348","title":"渔家傲·野店无人霜似水","kind":"词"},{"id":"c69-349","title":"渔家傲·独木小舟烟雨湿","kind":"词"},{"id":"c69-350","title":"临江仙·送我南来舟一叶","kind":"词"},{"id":"c69-351","title":"临江仙·浓绿锁窗闲院静","kind":"词"},{"id":"c69-352","title":"朝中措·矮窗西畔翠荷香","kind":"词"},{"id":"c69-353","title":"朝中措·华筵饮散撤芳尊","kind":"词"},{"id":"c69-354","title":"朝中措·龙团分罢觉芳滋","kind":"词"}]},"章玄同":{"slug":"章玄同","name":"章玄同","dynasty":"唐","style":"","life":"","origin":"","seal":"章","bio":["章玄同，武后时人。久视中，张锡为相，请还庐陵王，坐流循州。玄同有流所赠诗，盖亦当时贬谪者。","诗一首。"],"works":[{"id":"t5-193","title":"流所赠张锡","kind":"诗"}]},"许宣平":{"slug":"许宣平","name":"许宣平","dynasty":"唐","style":"","life":"","origin":"","seal":"许","bio":["许宣平，新安歙人。景云中，隐城阳山南坞，结庵以居，时或负薪卖，担挂一花瓠及曲竹杖，每醉，拄之以归。尝于同华间题诗传舍，李白东游，览之，曰：“此仙诗也。","”及新安，累访之不得。后咸通七年，郡人许明奴家有妪入山采樵，见一人坐石上，食桃甚大，自称明奴之祖，即宣平也。与一桃食妪，妪后却食轻健，入山不归。"],"works":[{"id":"t47-697","title":"负薪行","kind":"诗"},{"id":"t47-698","title":"庵壁题诗","kind":"诗"},{"id":"t47-699","title":"见李白诗又吟","kind":"诗"}]},"赵光远":{"slug":"赵光远","name":"赵光远","dynasty":"唐","style":"","life":"","origin":"","seal":"赵","bio":["赵光远，华州刺史隲之子，不第而没。光化中，韦庄奏赠官。诗三首。"],"works":[{"id":"t40-846","title":"咏手二首 一","kind":"诗"},{"id":"t40-847","title":"咏手二首 二","kind":"诗"},{"id":"t40-848","title":"题妓莱儿壁","kind":"诗"}]},"韦鼎":{"slug":"韦鼎","name":"韦鼎","dynasty":"唐","style":"","life":"","origin":"","seal":"韦","bio":["韦鼎，湖南人，与廖匡图俱知名。诗一卷，今存一首。"],"works":[{"id":"t41-522","title":"赠廖凝","kind":"诗"}]},"魏兼恕":{"slug":"魏兼恕","name":"魏兼恕","dynasty":"唐","style":"","life":"","origin":"","seal":"魏","bio":[],"works":[{"id":"t43-168","title":"送张兵曹赴营田","kind":"诗"}]}}