{"slug":"薛稷","name":"薛稷","dynasty":"唐","style":"字嗣通","life":"","origin":"","seal":"薛","bio":["薛稷，字嗣通，汾阴人，道衡曾孙，魏征外甥也。擢进士第，景龙中，昭文馆学士。睿宗立，拜中书侍郎，参知机务。","历太子少保，以翊赞功封晋国公。工书画，诗十四首。"],"works":[{"id":"t0-702","title":"郊庙歌辞 仪坤庙乐章 昭升","kind":"诗"},{"id":"t4-937","title":"仪坤庙乐章二首 一","kind":"诗"},{"id":"t4-938","title":"仪坤庙乐章二首 二","kind":"诗"},{"id":"t4-939","title":"九日幸临渭亭登高应制得历字","kind":"诗"},{"id":"t4-940","title":"慈恩寺九日应制","kind":"诗"},{"id":"t4-941","title":"早春鱼亭山","kind":"诗"},{"id":"t4-942","title":"秋日还京陕西十里作","kind":"诗"},{"id":"t4-943","title":"奉和送金城公主适西蕃应制","kind":"诗"},{"id":"t4-944","title":"春日登楼野望","kind":"诗"},{"id":"t4-945","title":"饯许州宋司马赴任","kind":"诗"},{"id":"t4-946","title":"奉和圣制春日幸望春宫应制","kind":"诗"},{"id":"t4-947","title":"奉和幸安乐公主山庄应制","kind":"诗"},{"id":"t4-948","title":"秋朝览镜","kind":"诗"},{"id":"t4-949","title":"夜宴安乐公主新宅","kind":"诗"},{"id":"t4-950","title":"饯唐永昌","kind":"诗"}]}