e":"","origin":"","seal":"李","bio":["李阳冰，字仲温，赵郡人，李白之从叔。宝应元年，为当涂令，白往依之，曾为白序其诗集。官止将作少监，工篆书。","诗一首。"],"works":[{"id":"t13-616","title":"阮客旧居","kind":"诗"}]},"杨汉公":{"slug":"杨汉公","name":"杨汉公","dynasty":"唐","style":"字用乂","life":"","origin":"","seal":"杨","bio":["杨汉公，字用乂，虞卿之弟。太和八年擢进士第，累官司封郎中，坐虞卿，出刺舒州，徙湖、亳、苏三州，终桂林观察使。诗二首。"],"works":[{"id":"t28-47","title":"登郡中销暑楼寄东川汝士","kind":"诗"},{"id":"t28-48","title":"明月楼","kind":"诗"},{"id":"t53-852","title":"訾州宴游","kind":"诗"},{"id":"t53-853","title":"八月十五夜销楼玩月","kind":"诗"}]},"段怀然":{"slug":"段怀然","name":"段怀然","dynasty":"唐","style":"","life":"","origin":"","seal":"段","bio":["段怀然，台州刺史，天宝中人。诗一首。"],"works":[{"id":"t13-511","title":"挽涌泉寺僧怀玉","kind":"诗"}]},"王苏苏":{"slug":"王苏苏","name":"王苏苏","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王苏苏，南曲中妓。诗一首。"],"works":[{"id":"t44-114","title":"和李标","kind":"诗"}]},"白居易":{"slug":"白居易","name":"白居易","dynasty":"唐","style":"字乐天 · 号醉吟先生","life":"","origin":"","seal":"白","bio":["白居易，字乐天，下邽人。贞元中，擢进士第，补校书郎。元和初，对制策，入等，调盩厔尉、集贤校理，寻召为翰林学士、左拾遗，拜赞善大夫。","以言事贬江州司马，徙忠州刺史。穆宗初，征为主客郎中、知制诰，复乞外，历杭、苏二州刺史。文宗立，以秘书监召，迁刑部侍郎。","俄移病，除太子宾客分司东都，拜河南尹。开成初，起为同州刺史，不拜，改太子少傅。会昌初，以刑部尚书致仕。","卒赠尚书右仆射，谥曰文。自号醉吟先生，亦称香山居士。与同年元稹酬咏，号元白；与刘禹锡酬咏，号刘白。","《长庆集》诗二十卷，后集诗十七卷，别集补遗二卷，今编诗三十九卷。白居易，字乐天，下邽人。贞元中，擢进士第，补校书郎。","元和初，对制策，入等，调盩厔尉、集贤校理，寻召为翰林学士、左拾遗，拜赞善大夫。以言事贬江州司马，徙忠州刺史。穆宗初，征为主客郎中、知制诰，复乞外，历杭、苏二州刺史。","文宗立，以秘书监召，迁刑部侍郎。俄移病，除太子宾客分司东都，拜河南尹。开成初，起为同州刺史，不拜，改太子少傅。","会昌初，以刑部尚书致仕。卒赠尚书右仆射，谥曰文。自号醉吟先生，亦称香山居士。","与同年元稹酬咏，号元白；与刘禹锡酬咏，号刘白。《长庆集》诗二十卷，后集诗十七卷，别集补遗二卷，今编诗三十九卷。白居易，字乐天，下邽人。","贞元中，擢进士第，补校书郎。元和初，对制策，入等，调盩厔尉、集贤校理，寻召为翰林学士、左拾遗，拜赞善大夫。以言事贬江州司马，徙忠州刺史。","穆宗初，征为主客郎中、知制诰，复乞外，历杭、苏二州刺史。文宗立，以秘书监召，迁刑部侍郎。俄移病，除太子宾客分司东都，拜河南尹。","开成初，起为同州刺史，不拜，改太子少傅。会昌初，以刑部尚书致仕。卒赠尚书右仆射，谥曰文。","自号醉吟先生，亦称香山居士。与同年元稹酬咏，号元白；与刘禹锡酬咏，号刘白。《长庆集》诗二十卷，后集诗十七卷，别集补遗二卷，今编诗三十九卷。","白居易，字乐天，下邽人。贞元中，擢进士第，补校书郎。元和初，对制策，入等，调盩厔尉、集贤校理，寻召为翰林学士、左拾遗，拜赞善大夫。","以言事贬江州司马，徙忠州刺史。穆宗初，征为主客郎中、知制诰，复乞外，历杭、苏二州刺史。文宗立，以秘书监召，迁刑部侍郎。","俄移病，除太子宾客分司东都，拜河南尹。开成初，起为同州刺史，不拜，改太子少傅。会昌初，以刑部尚书致仕。","卒赠尚书右仆射，谥曰文。自号醉吟先生，亦称香山居士。与同年元稹酬咏，号元白；与刘禹锡酬咏，号刘白。","长庆集诗二十卷，后集诗十七卷，别集补遗二卷，今编诗三十九卷。白居易，字乐天，下邽人。贞元中，擢进士第，补校书郎。","元和初，对制策，入等，调盩厔尉、集贤校理，寻召为翰林学士、左拾遗，拜赞善大夫。以言事贬江州司马，徙忠州刺史。穆宗初，征为主客郎中、知制诰，复乞外，历杭、苏二州刺史。","文宗立，以秘书监召，迁刑部侍郎。俄移病，除太子宾客分司东都，拜河南尹。开成初，起为同州刺史，不拜，改太子少傅。","会昌初，以刑部尚书致仕。卒赠尚书右仆射，谥曰文。自号醉吟先生，亦称香山居士。","与同年元稹酬咏，号元白；与刘禹锡酬咏，号刘白。长庆集诗二十卷，后集诗十七卷，别集补遗二卷，今编诗三十九卷。白居易字乐天，其先太原人，后迁居下邽。","贞元十六年擢进士第，元和初又擢才识兼茂、明于礼用科。任左拾遗，出为江州司马，历刺杭、苏二州，以刑部尚书致仕。会昌六我卒，年七十五。","补诗二首。（复出一首）"],"works":[{"id":"t1-6","title":"横吹曲辞 长安道","kind":"诗"},{"id":"t1-66","title":"相和歌辞 挽歌","kind":"诗"},{"id":"t1-99","title":"相和歌辞 王昭君二首 一","kind":"诗"},{"id":"t1-100","title":"相和歌辞 王昭君二首 二","kind":"诗"},{"id":"t1-125","title":"相和歌辞 短歌行二首 一","kind":"诗"},{"id":"t1-126","title":"相和歌辞 短歌行二首 二","kind":"诗"},{"id":"t1-275","title":"相和歌辞 反白头吟","kind":"诗"},{"id":"t1-293","title":"相和歌辞 怨诗","kind":"诗"},{"id":"t1-410","title":"相和歌辞 乌夜啼","kind":"诗"},{"id":"t1-455","title":"相和歌辞 采莲曲","kind":"诗"},{"id":"t1-544","title":"琴曲歌辞 昭君怨","kind":"诗"},{"id":"t1-627","title":"杂曲歌辞 悲哉行","kind":"诗"},{"id":"t1-737","title":"杂曲歌辞 浩歌行","kind":"诗"},{"id":"t1-769","title":"杂曲歌辞 长相思","kind":"诗"},{"id":"t1-832","title":"杂曲歌辞 生别离","kind":"诗"},{"id":"t1-841","title":"杂曲歌辞 潜别离","kind":"诗"},{"id":"t2-59","title":"杂曲歌辞 离别难","kind":"诗"},{"id":"t2-65","title":"杂曲歌辞 乐世","kind":"诗"},{"id":"t2-66","title":"杂曲歌辞 急[乐世]","kind":"诗"},{"id":"t2-67","title":"杂曲歌辞 何满子","kind":"诗"},{"id":"t2-103","title":"杂曲歌辞 竹枝 一","kind":"诗"},{"id":"t2-104","title":"杂曲歌辞 竹枝 二","kind":"诗"},{"id":"t2-105","title":"杂曲歌辞 竹枝 三","kind":"诗"},{"id":"t2-106","title":"杂曲歌辞 竹枝 四","kind":"诗"},{"id":"t2-113","title":"杂曲歌辞 杨柳枝 一","kind":"诗"},{"id":"t2-114","title":"杂曲歌辞 杨柳枝 二","kind":"诗"},{"id":"t2-115","title":"杂曲歌辞 杨柳枝 一","kind":"诗"},{"id":"t2-116","title":"杂曲歌辞 杨柳枝 二","kind":"诗"},{"id":"t2-117","title":"杂曲歌辞 杨柳枝 三","kind":"诗"},{"id":"t2-118","title":"杂曲歌辞 杨柳枝 四","kind":"诗"},{"id":"t2-119","title":"杂曲歌辞 杨柳枝 五","kind":"诗"},{"id":"t2-120","title":"杂曲歌辞 杨柳枝 六","kind":"诗"},{"id":"t2-121","title":"杂曲歌辞 杨柳枝 七","kind":"诗"},{"id":"t2-122","title":"杂曲歌辞 杨柳枝 八","