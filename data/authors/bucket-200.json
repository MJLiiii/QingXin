章事。为御史劾奏，贬江州司马，安乐公主从中申护，改襄州刺史。","韦氏称制，复同中书门下三品。睿宗立，出为华州刺史，除太子詹事。景云中，太平公主引为中书令。","明皇立，流岭外，以[尝]常预逆谋，追及荆州，赐死。湜执政时，年三十八，常暮出端门，缓辔赋诗，张说见之，叹曰：“文与位固可致，其年不可及也。”诗三十八首。"],"works":[{"id":"t0-972","title":"横吹曲辞 折杨柳","kind":"诗"},{"id":"t1-331","title":"相和歌辞 倢伃怨","kind":"诗"},{"id":"t3-404","title":"塞垣行","kind":"诗"},{"id":"t3-405","title":"送梁卿王郎中使东蕃吊册","kind":"诗"},{"id":"t3-406","title":"饯唐州高使君赴任","kind":"诗"},{"id":"t3-407","title":"冀北春望","kind":"诗"},{"id":"t3-408","title":"景龙二年余自门下平章事削阶授江州员外司马寻拜襄州刺史春日赴襄阳途中言志","kind":"诗"},{"id":"t3-409","title":"大漠行","kind":"诗"},{"id":"t3-410","title":"奉和登骊山高顶寓目应制","kind":"诗"},{"id":"t3-411","title":"侍宴长宁公主东庄应制","kind":"诗"},{"id":"t3-412","title":"奉和送金城公主适西蕃应制","kind":"诗"},{"id":"t3-413","title":"幸白鹿观应制","kind":"诗"},{"id":"t3-414","title":"幸梨园亭观打毬应制","kind":"诗"},{"id":"t3-415","title":"慈恩寺九日应制","kind":"诗"},{"id":"t3-416","title":"折杨柳","kind":"诗"},{"id":"t3-417","title":"边愁","kind":"诗"},{"id":"t3-418","title":"婕妤怨","kind":"诗"},{"id":"t3-419","title":"酬杜麟台春思","kind":"诗"},{"id":"t3-420","title":"寄天台司马先生","kind":"诗"},{"id":"t3-421","title":"唐都尉山池","kind":"诗"},{"id":"t3-422","title":"江楼夕望","kind":"诗"},{"id":"t3-423","title":"襄城即事","kind":"诗"},{"id":"t3-424","title":"秦州薛都督挽词","kind":"诗"},{"id":"t3-425","title":"奉和春日幸望春宫","kind":"诗"},{"id":"t3-426","title":"奉和幸韦嗣立山庄侍宴应制","kind":"诗"},{"id":"t3-427","title":"同李员外春闺","kind":"诗"},{"id":"t3-428","title":"襄阳早秋寄岑侍郎","kind":"诗"},{"id":"t3-429","title":"赠苏少府赴任江南余时还京","kind":"诗"},{"id":"t3-430","title":"登总持寺阁","kind":"诗"},{"id":"t3-431","title":"早春边城怀归","kind":"诗"},{"id":"t3-432","title":"至桃林塞作","kind":"诗"},{"id":"t3-433","title":"襄阳作","kind":"诗"},{"id":"t3-434","title":"喜入长安","kind":"诗"},{"id":"t3-435","title":"奉和幸韦嗣立山庄应制","kind":"诗"},{"id":"t50-134","title":"无题","kind":"诗"},{"id":"t50-135","title":"责躬诗（斯二七一七下同）","kind":"诗"},{"id":"t50-136","title":"暮秋书怀","kind":"诗"},{"id":"t50-137","title":"杂诗","kind":"诗"},{"id":"t50-138","title":"九龙潭作","kind":"诗"}]},"张俨":{"slug":"张俨","name":"张俨","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张俨，贞元中人。诗三首。"],"works":[{"id":"t25-206","title":"贞元八年十二月谒先主庙绝句三首 一","kind":"诗"},{"id":"t25-207","title":"贞元八年十二月谒先主庙绝句三首 二","kind":"诗"},{"id":"t25-208","title":"贞元八年十二月谒先主庙绝句三首 三","kind":"诗"}]},"张孝祥":{"slug":"张孝祥","name":"张孝祥","dynasty":"宋","style":"字安国 · 号于湖居士","life":"","origin":"历阳乌江（今安徽和县乌江镇）","seal":"张","bio":["--(1132－1169) 字安国，号于湖居士，历阳乌江 (今安徽和县乌江镇) 人。绍兴二十四年 (1154) 进士第一。孝宗朝，累迁中书舍人，直学士院，领建康留守，因赞助张浚北伐罢职。","后知荆南府，兼荆湖北路安抚使，兴水利，筑金堤，有政绩。乾道五年 (1169)，因病退居芜湖，卒。善诗文，工词，词风豪放，颇有感怀时事之作，清旷飘逸处，酷似东坡。","著有《于湖居士文集》、《于湖词》。"],"works":[{"id":"c59-949","title":"南歌子·人物羲皇上","kind":"词"},{"id":"c59-950","title":"霜天晓角·柳丝无力","kind":"词"},{"id":"c59-951","title":"生查子·远山眉黛横","kind":"词"},{"id":"c59-952","title":"长相思·小楼重","kind":"词"},{"id":"c59-953","title":"忆秦娥·元宵节","kind":"词"},{"id":"c59-954","title":"苍梧谣・归字谣·归","kind":"词"},{"id":"c59-955","title":"苍梧谣・归字谣·归","kind":"词"},{"id":"c59-956","title":"苍梧谣・归字谣·归","kind":"词"},{"id":"c59-957","title":"水调歌头·天上掌纶手","kind":"词"},{"id":"c59-958","title":"水调歌头·客里送行客","kind":"词"},{"id":"c59-959","title":"木兰花・玉楼春·拥貔貅万骑","kind":"词"},{"id":"c59-960","title":"雨中花・夜行船·一舸凌风","kind":"词"},{"id":"c59-961","title":"鹧鸪天·可意黄花人不知","kind":"词"},{"id":"c59-962","title":"眼儿媚·晓来江上荻花秋","kind":"词"},{"id":"c59-963","title":"虞美人·清宫初入韶华管","kind":"词"},{"id":"c59-964","title":"菩萨蛮·史君家枕吴波碧","kind":"词"},{"id":"c59-965","title":"临江仙·罨画楼前初立马","kind":"词"},{"id":"c59-966","title":"浣溪沙·我是临川旧史君","kind":"词"},{"id":"c59-967","title":"浣溪沙·康乐亭前种此君","kind":"词"},{"id":"c59-968","title":"西江月·十里轻红自笑","kind":"词"},{"id":"c59-969","title":"忆秦娥·天一角","kind":"词"},{"id":"c59-970","title":"浣溪沙·湓浦从君已十年","kind":"词"},{"id":"c59-971","title":"柳梢青·碧云风月无多","kind":"词"},{"id":"c59-972","title":"卜算子·万里去担簦","kind":"词"},{"id":"c59-973","title":"柳梢青·草底蛩吟","kind":"词"},{"id":"c59-974","title":"瑞鹧鸪·香佩潜分紫绣囊","kind":"词"},{"id":"c59-975","title":"青玉案·相春堂上闻莺语","kind":"词"},{"id":"c59-976","title":"念奴娇·海云四敛","kind":"词"},{"id":"c59-977","title":"念奴娇·风帆更起","kind":"词"},{"id":"c59-978","title":"蓦山溪·雄风豪雨","kind":"词"},{"id":"c59-979","title":"拾翠羽·春入园林","kind":"词"},{"id":"c59-980","title":"蝶恋花·烂烂明霞红日暮","kind":"词"},{"id":"c59-981","title":"渔家傲·红白莲房生一处","kind":"词"},{"id":"c59-982","title":"夜游宫·听话危亭句景","kind":"词"},{"id":"c59-983","title":"鹧鸪天·桃换肌肤菊换妆","kind":"词"},{"id":"c59-984","title":"鹧鸪天·人物风流册府仙","kind":"词"},{"id":"c59-985","title":"菩萨蛮·落霞残照横西阁","kind":"词"},{"id":"c59-986","title":"菩萨蛮·渚莲红乱风翻雨","kind":"词"},{"id":"c59-987","title":"菩萨蛮·晚花残雨风帘卷","kind":"词"},{"id":"c59-988","title":"菩萨蛮·白头人笑花间客","kind":"词"},{"id":"c59-989","title":"南歌子·路尽湘江水","kind":"词"},{"id":"c59-990","title":"燕归梁·风柳摇丝花缠枝","kind":"词"},{"id":"c59-991","title":"卜算子·风生杜若洲","kind":"词"},{"id":"c59-992","title":"点绛唇·秩秩宾筵","kind":"词"},{"id":"c59-993","title":"水调歌头·湖海倦游客","kind":"词"},{"id":"c59-994","title":"锦园春·醉痕潮玉","kind":"词"},{"id":"c59-995","title":"天仙子·三月灞桥烟共雨","kind":"词"},{"id":"c59-996","title":"鹧鸪天·日日青楼醉梦中","kind":"词"},{"id":"c59-997","title":"风入松·玉妃孤艳照冰霜","kind":"词"},{"id":"c60-609","title":"浣溪沙·只倚精忠不要兵","kind":"词"}]},"慕幽":{"slug":"慕幽","name":"慕幽","dynasty":"唐","style":"","life":"","origin":"","seal":"慕","bio":[],"works":[{"id":"t47-208","title":"劒客","kind":"诗"},{"id":"t47-209","title":"酬和友人见寄","kind":"诗"},{"id":"t47-210","title":"冬日淮上别文上人","kind":"诗"},{"id":"t47-211","title":"柳","kind":"诗"},{"id":"t47-212","title":"三峡闻猨","kind":"诗"},{"id":"t47-213","title":"灯","kind":"诗"}]},"方衡":{"slug":"方衡","name":"方衡","dynasty":"宋","style":"","life":"","origin":"","seal":"方","bio":[],"works":[{"id":"c75-521","title":"齐天乐·皇天眷佑中兴烈","kind":"词"}]},"李太古":{"slug":"李太古","name":"李太古","dynasty":"宋","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"c76-474","title":"永遇乐·玉砌标鲜","kind":"词"},{"id":"c76-475","title":"恋绣衾·桔花风信满院香","kind":"词"},{"id":"c76-476","title":"南歌子·月下秦淮海","kind":"词"},{"id":"c76-477","title":"虞美人·西风海色秋无际","kind":"词"},{"id":"c76-478","title":"卜算子·尽道是伤春","kind":"词"}]},"李靖":{"slug":"李靖","name":"李靖","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["靖，本名药师，雍州三原人。少有文武材略。初仕隋，为长安县功曹、驾部员外郎、马邑郡丞。","唐高祖时，任行军总管，从李孝恭征萧铣，复度岭招抚岭南诸州，屡立军功。太宗时，历任刑部尚书、兵部尚书、尚书右仆射等职，先后击败东突厥、吐谷浑。初封代国公，改卫国公。","贞观二十三年卒，年七十九。诗一首。（《全唐诗》无李靖诗。","事迹据《旧唐书》卷六七本传。）"],"works":[{"id":"t52-94","title":"舞剑歌","kind":"诗"}]},"杨昭俭":{"slug":"杨昭俭","name":"杨昭俭","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":["杨昭俭，石晋时人，官尚书。诗一首。"],"works":[{"id":"t41-384","title":"题家园","kind":"诗"}]},"王丽真女郎":{"slug":"王丽真女郎","name":"王丽真女郎","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"t49-900","title":"字字双","kind":"诗"}]},"罗愿":{"slug":"罗愿","name":"罗愿","dynasty":"宋","style":"","life":"","origin":"","seal":"罗","bio":[],"works":[{"id":"c68-602","title":"水调歌头·秋宇净如水","kind":"词"},{"id":"c68-603","title":"失调名·九月江南秋色","kind":"词"}]},"罗椿":{"slug":"罗椿","name":"罗椿","dynasty":"宋","style":"","life":"","origin":"","seal":"罗","bio":[],"works":[{"id":"c69-746","title":"酹江月・念奴娇·郎星锦帐","kind":"词"}]},"萧意":{"slug":"萧意","name":"萧意","dynasty":"唐","style":"","life":"","origin":"","seal":"萧","bio":[],"works":[{"id":"t43-70","title":"长门失宠","kind":"诗"}]},"裴漼":{"slug":"裴漼","name":"裴漼","dynasty":"唐","style":"","life":"","origin":"","seal":"裴","bio":["裴漼，绛州闻喜人。应大礼举，累官监察御史，三迁中书舍人。开元中，拜吏部侍郎，典选数年，多所甄拔，再转黄门侍郎。","漼早与张说善，说为相，数荐之。漼长于敷奏，上亦自嘉重，由是擢为吏部尚书，太子宾客。诗四首。"],"works":[{"id":"t5-369","title":"奉和圣制送张说上集贤学士赐宴","kind":"诗"},{"id":"t5-370","title":"奉和御制旋师喜捷","kind":"诗"},{"id":"t5-371","title":"奉和御制平胡","kind":"诗"},{"id":"t5-372","title":"奉和圣制龙池篇","kind":"诗"}]}}