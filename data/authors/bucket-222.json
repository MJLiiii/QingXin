nd":"诗"}]},"徐宝之":{"slug":"徐宝之","name":"徐宝之","dynasty":"宋","style":"","life":"","origin":"","seal":"徐","bio":[],"works":[{"id":"c73-391","title":"桂枝香·人间秋至","kind":"词"},{"id":"c73-392","title":"沁园春·水榭春寒","kind":"词"},{"id":"c73-393","title":"莺啼序·荼䕷一番过雨","kind":"词"},{"id":"c73-394","title":"水调歌・水调·了却意中事","kind":"词"}]},"沈晦":{"slug":"沈晦","name":"沈晦","dynasty":"宋","style":"","life":"","origin":"","seal":"沈","bio":[],"works":[{"id":"c60-542","title":"小重山·湖上秋来莲荡空","kind":"词"}]},"洪迈":{"slug":"洪迈","name":"洪迈","dynasty":"宋","style":"字景卢 · 号野处","life":"","origin":"鄱阳（今江西波阳）","seal":"洪","bio":["--(1123－1202) 字景卢，别号野处，鄱阳 (今江西波阳) 人。洪皓季子。绍兴十五年 (1145)，中博学宏词科。","孝宗朝，累迁中书舍人、兼侍读、直学士院、拜翰林学士。进焕章阁学士、知绍兴府。以端明殿学士致仕。","有《野处类》、《容斋随笔》、《夷坚志》、《万首唐人绝句》行于世。词存六首。"],"works":[{"id":"c66-984","title":"满江红·雨涩风悭","kind":"词"},{"id":"c66-985","title":"临江仙·绮席流欢欢正洽","kind":"词"},{"id":"c66-986","title":"导引·寒日短","kind":"词"},{"id":"c66-987","title":"六州·尧传舜","kind":"词"},{"id":"c66-988","title":"十二时・忆少年·璧门双阙转苍龙","kind":"词"},{"id":"c66-989","title":"踏莎行·院落深沈","kind":"词"}]},"蒋吉":{"slug":"蒋吉","name":"蒋吉","dynasty":"唐","style":"","life":"","origin":"","seal":"蒋","bio":[],"works":[{"id":"t43-31","title":"石城","kind":"诗"},{"id":"t43-32","title":"汉东道中","kind":"诗"},{"id":"t43-33","title":"高溪有怀","kind":"诗"},{"id":"t43-34","title":"寄进士贾希","kind":"诗"},{"id":"t43-35","title":"出塞","kind":"诗"},{"id":"t43-36","title":"旅泊","kind":"诗"},{"id":"t43-37","title":"次青云驿","kind":"诗"},{"id":"t43-38","title":"大庾驿有怀","kind":"诗"},{"id":"t43-39","title":"题商山修路僧院","kind":"诗"},{"id":"t43-40","title":"题长安僧院","kind":"诗"},{"id":"t43-41","title":"次商于感旧寄卢中丞","kind":"诗"},{"id":"t43-42","title":"樵翁","kind":"诗"},{"id":"t43-43","title":"四老庙","kind":"诗"},{"id":"t43-44","title":"昭君冢","kind":"诗"},{"id":"t43-45","title":"闻歌竹枝","kind":"诗"}]},"郑余庆":{"slug":"郑余庆","name":"郑余庆","dynasty":"唐","style":"字居业 · 号为详衷","life":"","origin":"","seal":"郑","bio":["郑余庆，字居业。大历中举进士第，初为严震山南从事。贞元初，历库部郎中，为翰林学士，以工部侍郎知吏部选，后拜中书侍郎同平章事。","宪宗时，为尚书左仆射，详定典制，引韩愈、李程为副，崔郾、陈珮、杨嗣复、庾敬休为判官，损益仪规，号为详衷。终太子太师、检校司徒。集五十卷，今存诗二首。"],"works":[{"id":"t0-671","title":"郊庙歌辞 享太庙乐章 文明舞","kind":"诗"},{"id":"t17-88","title":"和黄门相公诏还题石门洞","kind":"诗"},{"id":"t17-89","title":"享太庙乐章","kind":"诗"}]},"高元矩":{"slug":"高元矩","name":"高元矩","dynasty":"唐","style":"","life":"","origin":"","seal":"高","bio":[],"works":[{"id":"t43-700","title":"句","kind":"诗"}]}}