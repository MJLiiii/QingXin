{"令狐绹":{"slug":"令狐绹","name":"令狐绹","dynasty":"唐","style":"字子直","life":"","origin":"","seal":"令","bio":["令狐绹，字子直，楚之子。举进士，擢累左补阙、右司郎中，出为湖州刺史。大中初，召为考功郎中、知制诰，入翰林为学士，进中书舍人，再迁兵部侍郎，俄拜同中书门下平章事。","懿宗嗣位，出为河中节度使，徙宣武、淮南。僖宗时，终凤翔节度使，封赵国公。诗一首。"],"works":[{"id":"t31-327","title":"登望京楼赋","kind":"诗"}]},"何昌龄":{"slug":"何昌龄","name":"何昌龄","dynasty":"唐","style":"","life":"","origin":"","seal":"何","bio":["何昌龄，南唐时庐陵宰。诗一首。"],"works":[{"id":"t42-415","title":"题杨克俭池馆","kind":"诗"}]},"冯□原":{"slug":"冯□原","name":"冯□原","dynasty":"唐","style":"","life":"","origin":"","seal":"冯","bio":["冯□原，开元十七年为黄土县令。"],"works":[{"id":"t52-650","title":"同[前]","kind":"诗"}]},"卢栯":{"slug":"卢栯","name":"卢栯","dynasty":"唐","style":"","life":"","origin":"","seal":"卢","bio":["卢栯，弘文馆学士，诗一首。"],"works":[{"id":"t31-376","title":"和于中丞登越王楼作","kind":"诗"}]},"寇埴":{"slug":"寇埴","name":"寇埴","dynasty":"唐","style":"","life":"","origin":"","seal":"寇","bio":[],"works":[{"id":"t43-240","title":"题莹上人院","kind":"诗"}]},"崔□":{"slug":"崔□","name":"崔□","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":["崔□，名不详，杜牧之内兄，官和州刺史。诗一首。"],"works":[{"id":"t53-886","title":"走笔送杜十三归京","kind":"诗"}]},"张昭":{"slug":"张昭","name":"张昭","dynasty":"唐","style":"字潜夫","life":"","origin":"","seal":"张","bio":["张昭，南汉时人。诗一首。张昭字潜夫，濮州苑县人。","历仕唐、晋、汉、周四朝，官至兵部尚书。宋初拜吏部尚书，进封郑国公。开宝五年卒，年七十九。","有《嘉善集》。补诗一首，"],"works":[{"id":"t0-813","title":"郊庙歌辞 汉宗庙乐舞辞 武德舞","kind":"诗"},{"id":"t0-814","title":"郊庙歌辞 汉宗庙乐舞辞 灵长舞","kind":"诗"},{"id":"t0-815","title":"郊庙歌辞 汉宗庙乐舞辞 积善舞","kind":"诗"},{"id":"t0-816","title":"郊庙歌辞 汉宗庙乐舞辞 显仁舞","kind":"诗"},{"id":"t0-817","title":"郊庙歌辞 汉宗庙乐舞辞 章庆舞","kind":"诗"},{"id":"t0-818","title":"郊庙歌辞 汉宗庙乐舞辞 观德舞","kind":"诗"},{"id":"t42-631","title":"汉宗庙乐舞辞","kind":"诗"},{"id":"t50-984","title":"夜吟窦巩集追思夷门题处已三稔矣凄然感兴书之","kind":"诗"}]},"无何有翁":{"slug":"无何有翁","name":"无何有翁","dynasty":"宋","style":"","life":"","origin":"","seal":"无","bio":[],"works":[{"id":"c76-592","title":"江城子·小年底死路槐忙","kind":"词"}]},"李延陵":{"slug":"李延陵","name":"李延陵","dynasty":"唐","style":"","life":"","origin":"","se