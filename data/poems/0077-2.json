[{"id":"c77-200","title":"踏莎行·宴罢琼林","rhythmic":"踏莎行","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["宴罢琼林，醉游花市，此时方显男儿志。"]},{"id":"c77-201","title":"祝英台近·客毡寒","rhythmic":"祝英台近","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["客毡寒，兰房悄，金炉爇红兽。","好个霜天，消遣正宜酒。","嫩橙初截鹅肪，肌肤香透。","又还记、吴姬纤手。","事难偶。","墨冻空染梨笺，新词谩题就。","酒薄愁浓，敧枕听寒漏。","可堪霜月亭亭，照人无寐，映窗外、一枝梅瘦。"]},{"id":"c77-202","title":"花心动·碧瓦朱甍","rhythmic":"花心动","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["碧瓦朱甍，销千门沈沈，丽日初旭。","画栋暗尘，锦瑟空弦，窈窕故窗红绿。","御柳宫花依然好，春不管、为谁妆束。","翠华远，风光尽属，野樵夷牧。","指似行人恸哭。","尚能道、先朝圣游不足。","凤辇路荒，龙沼波乾，犹有弃珠遗玉。","禁廊人静风琴响，只疑是、霓裳遗曲。","断魂晚，寒鸦又啼古木。"]},{"id":"c77-203","title":"西江月·梁上喃喃燕语","rhythmic":"西江月","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["梁上喃喃燕语，纸间戢戢蚕生。","满城风雨近清明。","不道有人新病。","春事一溪流水，杨花千点浮萍。","好风一霎为吹晴。","独步小园清影。"]},{"id":"c77-204","title":"梅花引·清阴陌","rhythmic":"梅花引","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["清阴陌。","狂踪迹。","朱门团扇香迎客。","牡丹风。","数苞红。","水香扑蕊，新妆谁为容。","蜡灯春酒风光夕。","锦浪龙须花六尺。","月波寒。","玉琅玕。","无情又是，华星送宝鞍。"]},{"id":"c77-205","title":"恋绣衾·元宵三五酒半醺","rhythmic":"恋绣衾","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["元宵三五酒半醺。","马蹄前、步步是春。","闹市里、看灯去，喜金吾、不禁夜深。","如今老大都休也，未黄昏、先闭上门。","待月到、窗儿上，对梅花、如对故人。"]},{"id":"c77-206","title":"青玉案·年年社日停针线","rhythmic":"青玉案","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["年年社日停针线。","怎忍见、双飞燕。","今日江城春已半。","一身犹在，乱山深处，寂寞溪桥畔。","春衫著破谁针线。","点点行行泪痕满。","落日解鞍芳草岸。","花无人戴，酒无人劝，醉也无人管。"]},{"id":"c77-207","title":"捣练子·偏□戏","rhythmic":"捣练子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["偏□戏，最风流。","斗帐金猊暖不收。","一阵蜜蜂狂絮里，酒酣眠折玉搔头。"]},{"id":"c77-208","title":"捣练子·初酒醒","rhythmic":"捣练子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["初酒醒，乍衣单。","褪著裙儿侧著冠。","门外小桥寒食夜，月明人去杏花残。"]},{"id":"c77-209","title":"楼心月·柳下争拿画浆摇","rhythmic":"楼心月","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["柳下争拿画浆摇。","水痕不觉透红绡。","月明相顾羞归去，都坐池头合凤箫。"]},{"id":"c77-210","title":"楼心月·手把新荷叶一枝","rhythmic":"楼心月","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["手把新荷叶一枝。","唤来池上只愁归。","流萤裹在红纱袖，忽到持杯个个飞。"]},{"id":"c77-211","title":"楼心月·新著生红小舞衣","rhythmic":"楼心月","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["新著生红小舞衣。","案前磨墨误淋漓。","含嗔逗晚不梳洗，背面牙床吃荔支。"]},{"id":"c77-212","title":"花心动·粉堞云齐","rhythmic":"花心动","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["粉堞云齐，度清笳、愁入暮烟林杪。","素艳透春，玉骨凄凉，勾带月痕生早。","江天苍莽黄昏后，依然是、粉寒香瘦。","动追感、西园嫩约，夜深人悄。","记得东风窈窕。","曾夜踏横斜，醉携娇小。","惆怅旧欢，回首俱非，忍看绿笺红豆。","香销纸帐人孤寝，相思恨、花还知否。","梦回处，霜飞翠楼已晓。"]},{"id":"c77-213","title":"踏莎行·殢酒情怀","rhythmic":"踏莎行","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["殢酒情怀，恨春时节。","柳丝巷陌黄昏月。","把君团扇卜君来，近墙扑得双蝴蝶。","笑不成言，喜还生怯。","颠狂绝似前春雪。","夜寒无处著相思，梨花一树人如削。"]},{"id":"c77-214","title":"鹧鸪天·题得相思字数行","rhythmic":"鹧鸪天","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["题得相思字数行。","起来桐叶满纱窗。","秋光欲雨棋声泻，粉帐不容花露香。","新寂寞，旧疏狂。","玉炉消息记钱塘。","小阑立遍红蕉树，一带残云趁月黄。"]},{"id":"c77-215","title":"阮郎归·薄罗生色画酴醿","rhythmic":"阮郎归","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["薄罗生色画酴醿。","酴醿满架时。","隔池贪看燕争泥。","坠双红荔支。","销金字，晚唐诗。","夹纱团扇儿。","自遮微雨傍花归。","个情天得知。"]},{"id":"c77-216","title":"青门怨·月痮烟景","rhythmic":"青门怨","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["月痮烟景。","远思孤影。","旧梦云飞，离魂冰冷。","脉脉恨满东风。","对孤鸿。","翠珠尘冷香如雾。","人何许。","心逐章台絮。","夜深酒醒烛暗，独倚危楼。","为谁愁。"]},{"id":"c77-217","title":"水调歌头·不能烦恼得","rhythmic":"水调歌头","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["不能烦恼得，掉臂便归休。","前度风樯，这回潦辙几悠悠。","幸得有云一谷，更自有书万卷，著甚麽来由。","月采混鱼目，霜口涴蝇头。","相山中，侯醉境，将诗流。","情知薄命，天样勋业也须收。","辟逻世间万事，推放那边一壁，百尺卧高楼。","日月草头露，天地水中沤。"]},{"id":"c77-218","title":"失调名·东南妩媚","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["东南妩媚，雌了男儿。"]},{"id":"c77-219","title":"霜天晓角·一声阿鹊","rhythmic":"霜天晓角","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["一声阿鹊。","人在云西角。","信有黄昏风雨，孤灯酒、不禁酌。","错错。","谁误著。","明知明做却。","颇寄香笺归去，教看了、细揉嚼。"]},{"id":"c77-220","title":"满庭芳·凤阁祥烟","rhythmic":"满庭芳","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["凤阁祥烟，龙城佳气，明禋恭谢时丰。","绮罗争看，帘幕卷南风。","十里仙仪宝仗，暖红翠、玉碾玲珑。","銮回也，箫韶缓奏，声在五云中。","千官，迎万乘，丝纶叠叠，锦绣重重。","听鸣矟辇路，宴罢鳌宫。","瞻仰天颜有喜，君恩霈、寰宇雍容。","生平愿，洪基巩固，圣寿永无穷。"]},{"id":"c77-221","title":"庆清朝·银漏花残","rhythmic":"庆清朝","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["银漏花残，红消烛泪。","九重鱼钥欢声沸。","奏万乘、祥曦门外。","盖圣君、恭谢灵休，谨访景明嘉礼。","天意好，祥风瑞月，时正当、小春天气。","禁街十里香中，御辇万红影里。","千官花底，控绣勒、宝鞭摇曳。","看万年，永庆吾皇，拈指又瞻三载。"]},{"id":"c77-222","title":"御街行·时康三载升平世","rhythmic":"御街行","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["时康三载升平世。","恭谢三朝礼。","群臣禁卫带花回，龊巷儿郎精锐。","战袍新样团雕拥，重隘围子队。","绣衣花帽挨排砌。","锦仗天街里。","有如仙队玉京来，妙乐钧天盈耳。","都民观望时，果是消灾灭罪。"]},{"id":"c77-223","title":"瑞鹤仙·是欢声盈万户","rhythmic":"瑞鹤仙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["是欢声盈万户。","庆景陵礼毕，銮舆游步。","西郊暖风布。","喜湖山深锁，非烟非雾。","传收绣羽。","骅骝驰骤绒缕。","望彤芳、稳稳金銮，衮鸾翔舞。","云驭。","近回天厩，锡宴琼津，洪恩均顾。","霞天向暮。","翠华动，舞韶举。","绛纱笼千点，星飞清禁，银烛交辉辇路。","瑞光中、渺祝无疆，太平圣主。"]},{"id":"c77-224","title":"真珠帘·病酒情怀犹困懒","rhythmic":"真珠帘","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["病酒情怀犹困懒。"]},{"id":"c77-225","title":"沁园春·国步多艰","rhythmic":"沁园春","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["国步多艰，民心靡定，诚吾隐忧。","叹浙民转徙，怨寒嗟暑，荆襄死守，阅岁经秋。","虏未易支，人将相食，识者深为社稷羞。","当今亟，出陈大谏，箸借留候。","□□迂阔为谋。","天下士如何可籍收。","况君能尧舜，臣皆稷契，世逢汤武，业比伊周。","政不必新，贯仍宜旧，莫与秀才做尽休。","吾元老，广四门贤路，一柱中流。"]},{"id":"c77-226","title":"小重山·鼓报黄昏禽影歇","rhythmic":"小重山","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["鼓报黄昏禽影歇。","单衣犹未试，觉寒怯。","尘生锦瑟可曾阅。","人去也，闲过好时节。","对景复愁绝。","东风吹不散，鬓边雪。","些儿心事对谁说。","眠不得，一枕杏花月。"]},{"id":"c77-227","title":"谒金门·休只坐","rhythmic":"谒金门","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["休只坐。","也去看花则个。","明日满庭红欲堕。","花还愁似我。","索性痴眠一和。","凭个梦儿好做。","杜宇不知春已过。","枝头声越大。"]},{"id":"c77-228","title":"失调名·惜花心性","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["惜花心性。"]},{"id":"c77-229","title":"行香子·浙右华亭","rhythmic":"行香子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["浙右华亭。","物价廉平。","一道会、卖个三升。","打开瓶后，滑辣光馨。","教君霎时饮，霎时醉，霎时醒。","听得渊明。","说与刘伶。","这一瓶、约迭三斤。","君还不信，把秤来秤。","有一斤酒，一斤水，一斤瓶。"]},{"id":"c77-230","title":"长相思·晴也行","rhythmic":"长相思","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["晴也行。","雨也行。","雨也行时不似晴。","天晴终快人。","名也成。","利也成。","利也成时不似名。","名成天下惊。"]},{"id":"c77-231","title":"摸鱼儿·过湘皋","rhythmic":"摸鱼儿","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["过湘皋、碧龙惊起，冰涎犹护髯影。","春洲未有菱歌伴，独占暮烟千顷。","呼短艇。","试翦取纤条，玉溜青丝莹。","尊前细认。","试水面新荷，波心半掩，点点翠钿净。","凄凉味，酪乳那堪比并。","吴盐一箸秋冷。","当时不为鲈鱼去，聊尔动渠归兴。","还记省。","是几度西风，几度吹愁醒。","鸥昏鹭瞑。","谩换得霜痕，萧萧两鬓，羞与共秋镜。"]},{"id":"c77-232","title":"失调名·东君去后花无主","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["东君去后花无主。"]},{"id":"c77-233","title":"多丽·日初长","rhythmic":"多丽","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["日初长，宝炉一缕沈烟。","绿阴新，垂杨亭榭，知谁巧擘香绵。","有时共、落红零乱，有时共、芳草留连。","只道无情，那知有意，几回飞过绮窗前。","人争讶，艳阳三月，乾雪舞晴天。","游丝外，不堪燕掠，无奈蜂黏。","那小鬟、忒�山苛樱�镇日地、倚阑干。","轻吹处、樱桃的的，闲拈处、笋指纤纤。","爱点猩罗，装成粉缬，嗔人不许放朱帘。","端相好、蓦然风起，特送上秋千。","明朝看，池塘雨过，萍翠应添。"]},{"id":"c77-234","title":"沁园春·我善观梅","rhythmic":"沁园春","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["我善观梅，识梅妙处，舍我其谁。","待裁冰翦雪，已无足道，凝酥弄粉，愈不为奇。","枉费心神，巡檐索笑，点检南枝并北枝。","梅应道，似这般题品，未是相知。","分明有个端倪。","遮莫把人间凡眼窥。","那精神全在，半含蕊处，风流全在，未有香时。","万木丛边，两三点白，此是生生化化机。","花开也，又怎生消得，个样词儿。"]},{"id":"c77-235","title":"壶中天・念奴娇·日长晴昼","rhythmic":"壶中天・念奴娇","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["日长晴昼。","厌厌地、懒向窗前絣绣。","因倚屏风无意绪，□把眉儿双皱。","似醉还醒，才眠又起，频拈梨花嗅。","看他儿女，闲寻百草来斗。","相思能几何时，料归期不到，清和时候。","生怕鸳鸯香被冷，旋爇沈檀薰透。","欲把单衣，鼎新裁翦，又怕供春瘦。","试看今夜，孤灯还有花否。"]},{"id":"c77-236","title":"满江红·一点阳和","rhythmic":"满江红","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["一点阳和，天不许、凡花先得。","这些儿深意，蜂蝶怎生窥测。","北陆正当风凛冽，南枝却漏春消息。","教琼仙、翦水缀成葩，天然白。","影横处，寒窗月。","香浮处，寒梢雪。","被东皇做就，这般标格。","虽是腊前年后景，终非竹外篱边物。","不安排、顿放玉堂中，真堪惜。"]},{"id":"c77-237","title":"买坡塘・摸鱼儿·喜西风","rhythmic":"买坡塘・摸鱼儿","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["喜西风、朝来如约，新凉一雨初霁。","家山望断知何处，渺渺长天秋水。","空眼底。","叹雁杳鱼沈，尺纸无人寄。","芸窗草砌。","渐影颤疏桐，声敲落叶，孤枕怎成睡。","逢场戏。","遮莫悲秋憔悴。","今朝有酒须醉。","尊前待唤佳人道，为雪藕丝轻脆。","闲省记。","便笑口频开，一岁知能几。","归期尚未。","且蜡屐兰桡，湖山深处，同赏月中桂。"]},{"id":"c77-238","title":"瑞鹤仙·赏残陶径菊","rhythmic":"瑞鹤仙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["赏残陶径菊。","正袅袅愁予，风凄露肃。","何人抱幽独。","更檐马锵金，廊鱼响木。","此情谁属。","向底处、骋怀游目。","小窗前，频览菱花，一笑鬓丝犹绿。","萧索。","故国云迷，佳人日暮，轻颦倚竹。","短钗敲玉。","算几夜，恁孤宿。","问旅情如许，怎生排遣，应费酒尊诗轴。","最无端、谁隔西楼，正调弦促。"]},{"id":"c77-239","title":"更漏子·画楼深","rhythmic":"更漏子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["画楼深，春昼永。","帘幕东风微冷。","莺啭罢，燕归来。","佳人午梦回。","鬓钗横，眉黛浅。","一捻楚腰纤软。","推绣户，倚雕阑。","无言看牡丹。"]},{"id":"c77-240","title":"更漏子·鬓慵梳","rhythmic":"更漏子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["鬓慵梳，眉懒画。","独自行来花下。","情脉脉，泪垂垂。","此情知为谁。","雨初晴，帘半卷。","两两衔泥新燕。","人比燕，不成双。","枉教人断肠。"]},{"id":"c77-241","title":"更漏子·粉墙低","rhythmic":"更漏子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["粉墙低，蓬户小。","一点尘运不到。","眠纱帐，坐蒲团。","道人随分安。","笋芽新，蔬甲嫩。","日日家常羹饭。","羹饭罢，怎消闲。","携筇出看山。"]},{"id":"c77-242","title":"愁倚阑令・春光好·东风恶","rhythmic":"愁倚阑令・春光好","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["东风恶，宿云凝。","忒无情。","合造梨花深院雨，断肠声。","枕上春梦初醒。","红窗外、何处啼莺。","已办春游双画舫，几时晴。"]},{"id":"c77-243","title":"红窗迥·河可挽","rhythmic":"红窗迥","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["河可挽。","石可转。","那一个愁字，却难驱遣。","眉向酒边暂展。","酒后依旧见。","枫叶满阶红万片。","待拾来、一一题写教遍。","却倩霜风吹卷。","直到沙岛远。"]},{"id":"c77-244","title":"一翦梅·漠漠春阴酒半酣","rhythmic":"一翦梅","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["漠漠春阴酒半酣。","风透春衫。","雨透春衫。","人家蚕事欲眠三。","桑满筐篮。","柘满筐篮。","先自离怀百不堪。","樯燕呢喃。","梁燕呢喃。","篝灯强把锦书看。","人在江南。","心在江南。"]},{"id":"c77-245","title":"长相思·不思量","rhythmic":"长相思","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["不思量。","又思量。","一点寒灯耿夜光。","鸳衾闲半床。","雨声长。","漏声长。","几阵斜风摇纸窗。","如何不断肠。"]},{"id":"c77-246","title":"长相思·云垂垂","rhythmic":"长相思","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["云垂垂。","雨霏霏。","只恐今年花事迟。","不然孤负伊。","燕飞飞。","柳依依。","有个人人倚翠扉。","深攒双黛眉。"]},{"id":"c77-247","title":"长相思·雨如丝","rhythmic":"长相思","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["雨如丝。","柳如丝。","织出春来一段奇。","莺梭来往飞。","酒如池。","醉如泥。","遮莫教人有醒时。","雨晴都不知。"]},{"id":"c77-248","title":"长相思·燕成双","rhythmic":"长相思","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["燕成双。","蝶成双。","飞去飞来杨柳旁。","问伊因底忙。","绿纱窗。","篆炉香。","午梦惊回书满床。","棋声春昼长。"]},{"id":"c77-249","title":"采桑子·年年才到花时候","rhythmic":"采桑子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["年年才到花时候，风雨成旬。","不肯开晴。","误却寻花陌上人。","今朝报道天晴也，花已成尘。","寄语花神。","何似当初莫做春。"]},{"id":"c77-250","title":"风光好·柳阴阴","rhythmic":"风光好","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["柳阴阴。","水深深。","风约双凫不自禁。","碧波心。","孤村桥断人迷路。","舟横渡。","旋买村醪浅浅斟。","更微吟。"]},{"id":"c77-251","title":"虞美人·□□□□□□□","rhythmic":"虞美人","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["□□□□□□□。","□□□□□。","□□□□□□□。","□□□□□□、□□□。","□□□□□□处。","归向桃源住。","桃源有路透渔溪。","自恨仙凡从此、隔云泥。"]},{"id":"c77-252","title":"虞美人·绮疏人把罗衣叠","rhythmic":"虞美人","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["绮疏人把罗衣叠。","岫幌铺残月。","宝烟细袅博山中。","梦惹暖红鸳锦、醉香风。","觉来犹记乘鸾处。","不是蓝桥住。","落花流水认前溪。","想见五云为路、静无泥。"]},{"id":"c77-253","title":"虞美人·悲商吹尽枝间绿","rhythmic":"虞美人","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["悲商吹尽枝间绿。","绛萼含冰玉。","为谁搀早冒寒开。","应念天涯憔悴、挽春回。","玉壶自酌清漪满。","又识东风面。","夜深斜月印窗纱。","好在数枝疏瘦、两三花。"]},{"id":"c77-254","title":"虞美人·萧萧风竹千蛟舞","rhythmic":"虞美人","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["萧萧风竹千蛟舞。","云阁催诗雨。","中秋时节变新凉。","又是一番红叶、下三湘。","君如膝上王文度。","早晚乡关去。","绣香佳处且留连。","正好橙黄橘绿、未寒天。"]},{"id":"c77-255","title":"虞美人·当年合德并飞燕","rhythmic":"虞美人","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["当年合德并飞燕。","涎涎无人见。","清魂沦入海棠枝。","料想天寒同著、翠罗衣。","同心佩带连环玉。","并髻云鬟绿。","谁教红萼自成双。","恰似新荷叶里、睡鸳鸯。"]},{"id":"c77-256","title":"木兰花・玉楼春·小桃枝上东风转","rhythmic":"木兰花・玉楼春","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["小桃枝上东风转。","□□草绿江南岸。","绿杨学舞小蛮腰，红药惜开菩萨面。","故乡何处天涯远。","黄梁梦断行云断。","登楼准拟故人书，殷勤试问西归雁。"]},{"id":"c77-257","title":"朝中措·严霜封草树凋红","rhythmic":"朝中措","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["严霜封草树凋红。","叶落小园空。","何事洛阳花面，却来冠冕秋风。","尊前羞损，篱边野菊，池上芙蓉。","莫放花归崑阆，且留客醉金锺。"]},{"id":"c77-258","title":"朝中措·红鸾飞下绿云中","rhythmic":"朝中措","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["红鸾飞下绿云中。","天淡日和融。","回首小园桃杏，怜伊独困霜风。","妖姿丽质，天然富贵，不假铅红。","梦作一双蝴蝶，翻翻绕遍芳丛。"]},{"id":"c77-259","title":"朝中措·洛阳常见画图中","rhythmic":"朝中措","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["洛阳常见画图中。","春去只心融。","国色辉开寒日，天香熏破霜风。","平生看了，姚黄魏紫，一捻深红。","莫是神仙韩令，裁成顷刻花丛。"]},{"id":"c77-260","title":"朝中措·从来黄菊占秋风","rhythmic":"朝中措","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["从来黄菊占秋风。","红只许芙蓉。","正是百花浓睡，如何唤起春工。","小桃破萼，胭脂淡伫，妆粉轻笼。","为报多情刘阮，武陵消息先通。"]},{"id":"c77-261","title":"朝中措·宦游只欲赋归休","rhythmic":"朝中措","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["宦游只欲赋归休。","花为解离愁。","看取星星潘鬓，花应羞上人头。","武陵流水，桃源路远，空误渔舟。","把住春光一醉，从教风叶悲秋。"]},{"id":"c77-262","title":"西江月·草市人归日落","rhythmic":"西江月","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["草市人归日落，荒城风急鸦翻。","独携尊酒上高寒。","缥缈云横楚观。","柳外半篙绿水，烟中数笔青山。","天涯流落岁将残。","望断故园心眼。"]},{"id":"c77-263","title":"西江月·扑扑云垂四野","rhythmic":"西江月","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["扑扑云垂四野。","冥冥雁下平芜。","萧萧风叶乱黄芦。","寒入一滩鸥鹭。","准拟云窗水榭。","装成玉树冰壶。","卷帘独坐拈髭须。","待看六花飞舞。"]},{"id":"c77-264","title":"西江月·风雨朝来恶甚","rhythmic":"西江月","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["风雨朝来恶甚，池塘春去无多。","绿杨阴里溜莺棱。","枝上老红犹堕。","酒满蚁浮金匜，烛残泪滴铜荷。","更阑孤枕奈情何。","只恐巫山梦破。"]},{"id":"c77-265","title":"西江月·花下春光正好","rhythmic":"西江月","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["花下春光正好，柳边春色才多。","雨声日夜长沧波。","暗地芳心滴破。","拍拍浪飞白雪，冥冥山点青螺。","汀兰岸芷有情麽。","还惜江城春过。"]},{"id":"c77-266","title":"西江月·膝下红金不暖","rhythmic":"西江月","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["膝下红金不暖，窗前绛蜡犹然。","夜深城麓走风烟。","的砾还飘雪霰。","海上正迷蝶梦，山阴未棹溪船。","愿骑白凤玉为鞭。","西赴瑶池芳宴。"]},{"id":"c77-267","title":"西江月·琼沼融成沆瀣","rhythmic":"西江月","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["琼沼融成沆瀣，冰檐滴尽真珠。","一园草木气方苏。","又学杨花飞舞。","何必乱飘密洒，却疑细糁轻铺。","谁将粉墨画成图。","玉做小亭高树。"]},{"id":"c77-268","title":"西江月·翦翦轻寒雨后","rhythmic":"西江月","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["翦翦轻寒雨后，瞳瞳晓日晴时。","春风先到绿杨枝。","金缕野桥山市。","鶗鴂巧调琴筑，海棠惜吐胭脂。","玉骢未解锦障泥。","且挂征鞭一醉。"]},{"id":"c77-269","title":"西江月·翠岭游仙梦破","rhythmic":"西江月","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["翠岭游仙梦破，暖香残酒醒时。","子规啼月下花枝。","日涌山光照市。","柳拂眉间黛色，桃匀脸上胭脂。","凄凄芳草路无泥。","脉脉归心似醉。"]},{"id":"c77-270","title":"西江月·风雨馀寒过了","rhythmic":"西江月","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["风雨馀寒过了，池塘春水生时。","迁莺飞上拂云枝。","春遍柳村花市。","酒面清空似水，玉杯温莹如脂。","莫教花谢涴尘泥。","把住东君索醉。"]},{"id":"c77-271","title":"点绛唇·晓翠初分","rhythmic":"点绛唇","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["晓翠初分，挂藤窈窕穿深静。","乌啼风径。","竹舞千蛟影。","又过重阳，感叹伤流景。","人多病。","酒杯慵问。","闲却金卮柄。"]},{"id":"c77-272","title":"好事近·篱落晓来霜","rhythmic":"好事近","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["篱落晓来霜，花嫩不禁寒力。","脉脉自摇疏影，印一奁空碧。","天生潇洒谢夫人，绝世有谁识。","何必嫣然一笑，已倾城倾国。"]},{"id":"c77-273","title":"秦楼月・忆秦娥·□□□","rhythmic":"秦楼月・忆秦娥","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["□□□。","□□□□□□□。","□□□。","□□□□，□□□□。","白鸥飞下屏山曲。","行人点破秋郊绿。","秋郊绿。","细看重咏，怎生得足。"]},{"id":"c77-274","title":"秦楼月・忆秦娥·秋漠漠","rhythmic":"秦楼月・忆秦娥","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["秋漠漠。","登临常羡东飞鹤。","东飞鹤。","一襟乡泪，为君双落。","明年不负黄花约。","故人须我归舟泊。","归舟泊。","荆溪亭下，晚秋寒薄。"]},{"id":"c77-275","title":"秦楼月・忆秦娥·风淅淅","rhythmic":"秦楼月・忆秦娥","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["风淅淅。","天容暗淡梅花白。","梅花白。","点酥凝粉，比君不得。","清歌飞下龙沙雪。","绮疏休印蟾宫月。","蟾宫月。","婵娟虽好，有时圆缺。"]},{"id":"c77-276","title":"西地锦·重过黄梁古驿","rhythmic":"西地锦","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["重过黄梁古驿。","著一鞭春色。","长亭细柳，青青尚浅，不禁攀折。","且醉章台风月。","莫归鞍催发。","紫泥诏下，朝天去了，如何来得。"]},{"id":"c77-277","title":"如梦令·试问春归何处","rhythmic":"如梦令","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["试问春归何处。","红入小桃花树。","同访古章台，把盏重听金缕。","休去。","休去。","应被好山留住。"]},{"id":"c77-278","title":"清平乐·风不定","rhythmic":"清平乐","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["风不定。","舞碎海棠红影。","数点雨声池上听。","湿尽一庭花冷。","倚阑多少心情。","轻寒未放春晴。","谁管天涯憔悴，楚乡又过清明。"]},{"id":"c77-279","title":"浣溪沙·遍地轻阴绿满枝","rhythmic":"浣溪沙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["遍地轻阴绿满枝。","乍晴初试袷罗衣。","东风院落日长时。","鸂鶒池边飞燕子，海棠花里闹蜂儿。","一春心事只春知。"]},{"id":"c77-280","title":"望江南・忆江南·清夜老","rhythmic":"望江南・忆江南","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["清夜老，流水淡疏星。","云母窗前生晓色，梧桐叶上得秋声。","村落一鸡鸣。","催唤起，带梦著冠缨。","老去悲秋如宋玉，病来止酒似渊明。","满院竹风清。"]},{"id":"c77-281","title":"醉蓬莱·见笋成新竹","rhythmic":"醉蓬莱","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["见笋成新竹，燕教雏飞，画堂清昼。","萱草榴花，遍小庭如绣。","角簟纱厨，葛巾葵扇，正麦秋时候。","玉尘生风，け然隐几，香蟠金兽。","又值生初，故乡何在，三楚云高，谩劳回首。","睡起情怀，况渊明止酒。","赖有宾朋，惠来相顾，尽一时英秀。","旋涤瑶觞，重歌金缕，与公同寿。"]},{"id":"c77-282","title":"满庭芳·梅子成阴","rhythmic":"满庭芳","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["梅子成阴，海棠初谢，小园才过清明。","百花扫地，红紫践为尘。","别有烟红露绿，嫣然笑、管领东君。","还知否，天香国色，独步殿馀春。","轻盈。","多态度，洛阳图画，韩令经营。","想谪仙风韵，洒面词成。","一捻深红尚透，谁信道、花亦通灵。","君休待、花归阆苑，莫惜醉山倾。"]},{"id":"c77-283","title":"汉宫春·争似我","rhythmic":"汉宫春","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["争似我，随时临风对月，畅饮更高歌。"]},{"id":"c77-284","title":"瑞鹤仙·恨佳人命薄","rhythmic":"瑞鹤仙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["恨佳人命薄。","似春云无定，杨花飘泊。"]},{"id":"c77-285","title":"失调名·须信道","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["须信道、颜色如花，命如秋叶。"]},{"id":"c77-286","title":"失调名·但入新年","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["但入新年，愿百事、皆如意。"]},{"id":"c77-287","title":"水龙吟·□□含娇眼","rhythmic":"水龙吟","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["□□含娇眼。"]},{"id":"c77-288","title":"失调名·雨后轻寒","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["雨后轻寒。"]},{"id":"c77-289","title":"失调名·柳丝柔无力","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["柳丝柔无力。"]},{"id":"c77-290","title":"失调名·伤怀长是蹙双眉","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["伤怀长是蹙双眉。","怎禁持。"]},{"id":"c77-291","title":"失调名·杨花飞絮","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["杨花飞絮。","搅乱少年情绪。"]},{"id":"c77-292","title":"失调名·天气阴阴","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["天气阴阴。"]},{"id":"c77-293","title":"失调名·倚遍阑干十二楼","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["倚遍阑干十二楼。"]},{"id":"c77-294","title":"满庭芳·柳眠花心","rhythmic":"满庭芳","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["柳眠花心，此夜欢会。"]},{"id":"c77-295","title":"失调名·蝶意蜂情","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["蝶意蜂情，恣还飘逸。"]},{"id":"c77-296","title":"失调名·金鸭香消","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["金鸭香消。"]},{"id":"c77-297","title":"念奴娇·脉脉此情难识","rhythmic":"念奴娇","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["脉脉此情难识。"]},{"id":"c77-298","title":"失调名·无计奈愁何","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["无计奈愁何。"]},{"id":"c77-299","title":"失调名·知他今夜","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["知他今夜，好好为谁梳洗。"]}]