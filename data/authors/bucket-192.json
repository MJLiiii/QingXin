{"匡仁":{"slug":"匡仁","name":"匡仁","dynasty":"唐","style":"","life":"","origin":"","seal":"匡","bio":["匡仁，新淦人。初嗣洞山，后历游瑞、潭、福州，得圆悟法。危全讽为抚州刺史，延请住持疎山白云禅院，世称疎山和尚。","著有《四大等颂略》、《华严长者论》。诗二首。（《全唐诗》无匡仁诗，传据《祖堂集》卷八、《宋高僧传》卷十三、《江西诗徴》卷八七）"],"works":[{"id":"t55-181","title":"偈","kind":"诗"},{"id":"t55-182","title":"临迁化时偈（《江西诗徴》题作《诗》）","kind":"诗"}]},"南山居士":{"slug":"南山居士","name":"南山居士","dynasty":"宋","style":"","life":"","origin":"","seal":"南","bio":[],"works":[{"id":"c64-480","title":"永遇乐·满眼寒姿","kind":"词"},{"id":"c64-481","title":"永遇乐·玉骨冰肌","kind":"词"}]},"卢郢":{"slug":"卢郢","name":"卢郢","dynasty":"唐","style":"","life":"","origin":"","seal":"卢","bio":["郢，金陵人。好学有才艺，膂力过人，善吹铁笛。南唐后主时，试赋擢第一。","尝代徐铉为文，铉以文进。后主曰：「语势似非卿所作。」铉以实对，郢由是知名。","后归宋，累官至南全守，有治绩。"],"works":[{"id":"t51-642","title":"黄鹤楼（《宋诗纪事》亦未收）","kind":"诗"},{"id":"t55-502","title":"残丝曲","kind":"诗"}]},"姚述尧1":{"slug":"姚述尧1","name":"姚述尧1","dynasty":"宋","style":"","life":"","origin":"","seal":"姚","bio":[],"works":[{"id":"c64-973","title":"青玉案·三年枕上吴中路","kind":"词"}]},"崔希逸":{"slug":"崔希逸","name":"崔希逸","dynasty":"唐","style":"字里不详","life":"","origin":"","seal":"崔","bio":["崔希逸，字里不详，开元九年任万年县尉，宇文融奏为劝农判官，迁监察御史。曾任吏部郎中。二十二年自郑州刺史改任江淮河南转运副使。","二十四年秋，以右散骑常侍知河西节度事。二十六年，改河南尹，不久即卒。封博陵县公，谥成。","诗二首。（《全唐诗》无崔希逸诗，传据《郎官石柱题名考》卷三、《唐刺史考》卷四九）"],"works":[{"id":"t52-758","title":"燕支行营 一","kind":"诗"},{"id":"t52-759","title":"燕支行营 二","kind":"诗"}]},"张伯端":{"slug":"张伯端","name":"张伯端","dynasty":"宋","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"c58-576","title":"西江月·内药还同外药","kind":"词"},{"id":"c58-577","title":"西江月·此道至神至圣","kind":"词"},{"id":"c58-578","title":"西江月·白虎首经至宝","kind":"词"},{"id":"c58-579","title":"西江月·若要真铅留汞","kind":"词"},{"id":"c58-580","title":"西江月·二八谁家姹女","kind":"词"},{"id":"c58-581","title":"西江月·七返朱砂反本","kind":"词"},{"id":"c58-582","title":"西江月·雄里内含雌质","kind":"词"},{"id":"c58-583","title":"西江月·天地才经否泰","kind":"词"},{"id":"c58-584","title":"西江月·冬至一阳来服","kind":"词"},{"id":"c58-585","title":"西江月·不辨五行四象","kind":"词"},{"id":"c58-586","title":"西江月·德行修逾八百","kind":"词"},{"id":"c58-587","title":"西江月·牛女情缘道合","kind":"词"},{"id":"c58-588","title":"西江月·丹是色身至宝","kind":"词"},{"id":"c58-589","title":"西江月·妄想不须强灭","kind":"词"},{"id":"c58-590","title":"西江月·本自无生无灭","kind":"词"},{"id":"c58-591","title":"西江月·我性入诸佛性","kind":"词"},{"id":"c58-592","title":"西江月·法法法元无法","kind":"词"},{"id":"c58-593","title":"西江月·善恶一时妄念","kind":"词"},{"id":"c58-594","title":"西江月·对镜不须强灭","kind":"词"},{"id":"c58-595","title":"西江月·人我众生寿者","kind":"词"},{"id":"c58-596","title":"西江月·住想修行布施","kind":"词"},{"id":"c58-597","title":"西江月·鱼兔若还入手","kind":"词"},{"id":"c58-598","title":"西江月·悟了莫求寂灭","kind":"词"},{"id":"c58-599","title":"西江月·我见时人说性","kind":"词"},{"id":"c58-600","title":"西江月·欲了无生妙道","kind":"词"},{"id":"c58-601","title":"满庭芳·真铁牛儿","kind":"词"},{"id":"c78-212","title":"解佩令·修行之士","kind":"词"}]},"张鲁封":{"slug":"张鲁封","name":"张鲁封","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"t48-332","title":"谑池亳二州宾佐兼寄宣武军掌书记李昼","kind":"诗"}]},"文彧":{"slug":"文彧","name":"文彧","dynasty":"唐","style":"","life":"","origin":"","seal":"文","bio":["文彧，五代闽僧。有《诗格》一卷，收入《吟窗杂录》。《宋史·艺文志》有「僧文彧诗一卷，今不存。","诗一首又二句。」（《全唐诗》无文彧诗）"],"works":[{"id":"t55-823","title":"赠陈文亮（题拟）","kind":"诗"},{"id":"t55-824","title":"引陈文亮（题拟）","kind":"诗"}]},"朱子真":{"slug":"朱子真","name":"朱子真","dynasty":"唐","style":"","life":"","origin":"","seal":"朱","bio":["朱子真，明皇时人，居南山下，别墅甚盛。出游，尝以绣衣女子数人自随。长安少年赵颍造之求饮，令侍女及木凤歌舞侑酒，子真自歌，仍取一丸丹赐颍。","銮舆幸蜀，忽失子真家，颍服丹，得二百余岁。"],"works":[{"id":"t43-2","title":"对赵颖歌","kind":"诗"},{"id":"t47-701","title":"对赵颍歌","kind":"诗"}]},"李华":{"slug":"李华","name":"李华","dynasty":"唐","style":"字遐叔","life":"","origin":"","seal":"李","bio":["李华，字遐叔，赞皇人。开元中，第进士，擢宏辞科。累官监察御史，右补阙。","以受安禄山伪署，贬杭州司户。上元中，召为左补阙，司封员外郎，华称疾不拜。李岘领选江南，表置幕府，擢检校吏部员外郎。","苦风痺，去官，客隐山阳，勒子弟力农，安于穷槁。大历初卒。集三十卷，今编诗一卷。"],"works":[{"id":"t1-310","title":"相和歌辞 长门怨","kind":"诗"},{"id":"t7-533","title":"杂诗六首 一","kind":"诗"},{"id":"t7-534","title":"杂诗六首 二","kind":"诗"},{"id":"t7-535","title":"杂诗六首 三","kind":"诗"},{"id":"t7-536","title":"杂诗六首 四","kind":"诗"},{"id":"t7-537","t