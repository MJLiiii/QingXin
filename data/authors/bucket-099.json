"origin":"","seal":"袁","bio":[],"works":[{"id":"t43-312","title":"早春送郎官出宰","kind":"诗"}]},"许敬宗":{"slug":"许敬宗","name":"许敬宗","dynasty":"唐","style":"字延族","life":"","origin":"","seal":"许","bio":["许敬宗，字延族，杭州新城人，善心子也。隋时官直谒者台奏通事舍人事。入唐，为著作郎，兼修国史。","寻贬洪州司马，累转给事中，复修史，迁太子右庶子。高宗即位，擢礼部尚书，历侍中、中书令、右相。卒谥曰缪。","集八十卷，今编诗二十七首。许敬宗，字延族，杭州新城人，善心子也。隋时官直谒者台奏通事舍人事。","入唐，为著作郎，兼修国史。寻贬洪州司马，累转给事中，复修史，迁太子右庶子。高宗即位，擢礼部尚书，历侍中、中书令、右相。","卒谥曰缪。集八十卷，今编诗二十七首。"],"works":[{"id":"t2-540","title":"奉和执契静三边应诏","kind":"诗"},{"id":"t2-541","title":"奉和行经破薛举战地应制","kind":"诗"},{"id":"t2-542","title":"奉和入潼关","kind":"诗"},{"id":"t2-543","title":"奉和春日望海","kind":"诗"},{"id":"t2-544","title":"奉和元日应制","kind":"诗"},{"id":"t2-545","title":"奉和初春登楼即目应诏","kind":"诗"},{"id":"t2-546","title":"奉和秋日即目应制","kind":"诗"},{"id":"t2-547","title":"奉和秋暮言志应制","kind":"诗"},{"id":"t2-548","title":"奉和喜雪应制","kind":"诗"},{"id":"t2-549","title":"奉和登陕州城楼应制","kind":"诗"},{"id":"t2-550","title":"游清都观寻沈道士得清字","kind":"诗"},{"id":"t2-551","title":"奉和七夕宴悬圃应制二首 一","kind":"诗"},{"id":"t2-552","title":"奉和七夕宴悬圃应制二首 二","kind":"诗"},{"id":"t2-553","title":"奉和仪鸾殿早秋应制","kind":"诗"},{"id":"t2-554","title":"奉和咏雨应诏","kind":"诗"},{"id":"t2-555","title":"奉和过慈恩寺应制","kind":"诗"},{"id":"t2-556","title":"冬日宴于庶子宅各赋一字得归","kind":"诗"},{"id":"t2-557","title":"送刘散员同赋得陈思王诗山树郁苍苍","kind":"诗"},{"id":"t2-558","title":"侍宴莎册宫应制得情字","kind":"诗"},{"id":"t2-559","title":"奉和过旧宅应制","kind":"诗"},{"id":"t2-560","title":"奉和宴中山应制","kind":"诗"},{"id":"t2-561","title":"奉和圣制登三台言志应制","kind":"诗"},{"id":"t2-562","title":"安德山池宴集","kind":"诗"},{"id":"t2-563","title":"奉和圣制送来济应制","kind":"诗"},{"id":"t2-564","title":"七夕赋咏成篇","kind":"诗"},{"id":"t2-565","title":"拟江令于长安归扬州九日赋","kind":"诗"},{"id":"t2-566","title":"拟江令于长安归扬州九日赋","kind":"诗"},{"id":"t48-783","title":"奉和九月九日应制","kind":"诗"},{"id":"t48-784","title":"奉和守岁应制","kind":"诗"},{"id":"t51-135","title":"无题","kind":"诗"},{"id":"t51-136","title":"辽左雪中登楼","kind":"诗"},{"id":"t52-145","title":"四言奉陪皇太子释奠诗一首应令 一","kind":"诗"},{"id":"t52-146","title":"四言奉陪皇太子释奠诗一首应令 二","kind":"诗"},{"id