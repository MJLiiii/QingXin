{"上官仪":{"slug":"上官仪","name":"上官仪","dynasty":"唐","style":"字游韶","life":"","origin":"","seal":"上","bio":["上官仪，字游韶，陕州陕人。贞观初，擢进士第，召授弘文馆直学士，迁秘书郎。太宗每属文，遣仪视藁，私宴未尝不预。","高宗即位，为秘书少监，进西台侍郎，同东西台三品，麟德元年，坐梁王忠事下狱死。仪工诗，其词绮错婉媚，人多效之，谓为上官体。集三十卷，今编诗一卷。"],"works":[{"id":"t1-85","title":"相和歌辞 王昭君","kind":"诗"},{"id":"t2-725","title":"奉和过旧宅应制","kind":"诗"},{"id":"t2-726","title":"早春桂林殿应诏","kind":"诗"},{"id":"t2-727","title":"安德山池宴集","kind":"诗"},{"id":"t2-728","title":"酬薛舍人万年宫晚景寓直怀友","kind":"诗"},{"id":"t2-729","title":"奉和颍川公秋夜","kind":"诗"},{"id":"t2-730","title":"谢都督挽歌","kind":"诗"},{"id":"t2-731","title":"八咏应制二首 一","kind":"诗"},{"id":"t2-732","title":"八咏应制二首 二","kind":"诗"},{"id":"t2-733","title":"和太尉戏赠高阳公","kind":"诗"},{"id":"t2-734","title":"王昭君","kind":"诗"},{"id":"t2-735","title":"咏雪应诏","kind":"诗"},{"id":"t2-736","title":"奉和山夜临秋","kind":"诗"},{"id":"t2-737","title":"江王太妃挽歌","kind":"诗"},{"id":"t2-738","title":"故北平公挽歌","kind":"诗"},{"id":"t2-739","title":"高密长公主挽歌","kind":"诗"},{"id":"t2-740","title":"咏画障","kind":"诗"},{"id":"t2-741","title":"奉和秋日即目应制","kind":"诗"},{"id":"t2-742","title":"入朝洛堤步行","kind":"诗"},{"id":"t2-743","title":"春日","kind":"诗"},{"id":"t2-744","title":"从驾闾山咏马","kind":"诗"},{"id":"t49-946","title":"句","kind":"诗"},{"id":"t52-124","title":"五言辽东侍宴山夜临秋同赋临韵应诏","kind":"诗"},{"id":"t52-125","title":"五言奉和咏棋应诏 一","kind":"诗"},{"id":"t52-126","title":"五言奉和咏棋应诏 二","kind":"诗"},{"id":"t52-127","title":"五言春日侍宴望海应诏","kind":"诗"},{"id":"t52-128","title":"五言奉和行经破薛举战地应诏","kind":"诗"},{"id":"t52-129","title":"五言侍宴延庆殿同赋别离得凌霜雁应诏","kind":"诗"},{"id":"t52-130","title":"假作屏风诗","kind":"诗"},{"id":"t52-131","title":"假作赠别诗","kind":"诗"},{"id":"t52-132","title":"假作幽兰诗","kind":"诗"},{"id":"t52-133","title":"假作赋得鲁司寇诗","kind":"诗"},{"id":"t52-134","title":"假作田家诗","kind":"诗"},{"id":"t52-135","title":"假作美人诗","kind":"诗"}]},"丘说":{"slug":"丘说","name":"丘说","dynasty":"唐","style":"","life":"","origin":"","seal":"丘","bio":[],"works":[{"id":"t0-699","title":"郊庙歌辞 仪坤庙乐章 太和","kind":"诗"}]},"南卓":{"slug":"南卓","name":"南卓","dynasty":"唐","style":"字昭嗣","life":"","origin":"","seal":"南","bio":["南卓，字昭嗣。初为拾遗，因谏出宰松滋。大中时，为黔南经略使。","诗一首。"],"works":[{"id":"t31-341","title":"赠副戎","kind":"诗"},{"id":"t53-920","title":"句","kind":"诗"}]},"夏侯孜":{"slug":"夏侯孜","name":"夏侯孜","dynasty":"唐","style":"字妤学","life":"","origin":"","seal":"夏","bio":["夏侯孜，字妤学，亳州谯人。累迁婺、绛等州刺史。宣宗时，自兵部侍郎为同中书门下平章事。","懿宗立，进司空，寻罢，以太子少保分司东都。诗一首。"],"works":[{"id":"t0-676","title":"郊庙歌辞 享太庙乐章 宣宗室舞","kind":"诗"},{"id":"t31-328","title":"享太庙乐章","kind":"诗"}]},"李聪":{"slug":"李聪","name":"李聪","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t43-158","title":"咏𣻕溪在历阳西一里","kind":"诗"},{"id":"t56-313","title":"咏历溪在历阳西一里","kind":"诗"}]},"梁洽":{"slug":"梁洽","name":"梁洽","dynasty":"唐","style":"","life":"","origin":"","seal":"梁","bio":["梁洽，开宝间进士。诗一首。"],"works":[{"id":"t10-32","title":"观汉水","kind":"诗"}]},"梁锽":{"slug":"梁锽","name":"梁锽","dynasty":"唐","style":"","life":"","origin":"","seal":"梁","bio":["梁锽，官执戟，天宝中人。诗十五首。"],"works":[{"id":"t9-990","title":"天长节","kind":"诗"},{"id":"t9-991","title":"长门怨","kind":"诗"},{"id":"t9-992","title":"美人春卧","kind":"诗"},{"id":"t9-993","title":"名姝咏","kind":"诗"},{"id":"t9-994","title":"艳女词","kind":"诗"},{"id":"t9-995","title":"狷氏子","kind":"诗"},{"id":"t9-996","title":"戏赠歌者","kind":"诗"},{"id":"t9-997","title":"七夕泛舟","kind":"诗"},{"id":"t9-998","title":"崔驸马宅咏画山水扇","kind":"诗"},{"id":"t9-999","title":"观王美人海图障子","kind":"诗"},{"id":"t10-0","title":"闻百舌鸟","kind":"诗"},{"id":"t10-1","title":"省试方士进恒春草","kind":"诗"},{"id":"t10-2","title":"代征人妻喜夫还","kind":"诗"},{"id":"t10-3","title":"赠李中华","kind":"诗"},{"id":"t10-4","title":"咏木老人","kind":"诗"},{"id":"t10-5","title":"句","kind":"诗"}]},"梅顺淑":{"slug":"梅顺淑","name":"梅顺淑","dynasty":"宋","style":"","life":"","origin":"","seal":"梅","bio":[],"works":[{"id":"c75-658","title":"望江南・忆江南·风渐软","kind":"词"}]},"清豁":{"slug":"清豁","name":"清豁","dynasty":"唐","style":"","life":"","origin":"","seal":"清","bio":[],"works":[{"id":"t49-62","title":"归山吟","kind":"诗"},{"id":"t51-781","title":"过三岭苎溪","kind":"诗"},{"id":"t55-835","title":"夜覩豺虎奔至契如庵前自然驯遶因有诗（题拟）","kind":"诗"}]},"窦参":{"slug":"窦参","name":"窦参","dynasty":"唐","style":"字时中","life":"","origin":"","seal":"窦","bio":["窦参，字时中，岐州人。以门荫累官中丞，德宗以为宰相。后贬郴州别驾，赐死。","诗三首。"],"works":[{"id":"t16-841","title":"湖上闲居","kind":"诗"},{"id":"t16-842","title":"迁谪江表久未归","kind":"诗"},{"id":"t16-843","title":"登潜山观","kind":"诗"}]},"苏易简":{"slug":"苏易简","name":"苏易简","dynasty":"宋","style":"","life":"","origin":"","seal":"苏","bio":[],"works":[{"id":"c57-611","title":"越江吟·神仙神仙瑶池宴","kind":"词"}]},"萧倣":{"slug":"萧倣","name":"萧倣","dynasty":"唐","style":"","life":"","origin":"","seal":"萧","bio":["萧倣，登太和进士第，历谏议大夫、给事中。咸通初，迁左散骑常侍。懿宗时，擢礼部侍郎，出为滑州刺史，充义成军节度，郑滑颍观察处置等使，入为兵部尚书判度支，转吏部尚书同平章事，出为岭南节度使。","诗二首。"],"works":[{"id":"t0-677","title":"郊庙歌辞  懿宗室舞","kind":"诗"},{"id":"t28-56","title":"享太庙乐章","kind":"诗"},{"id":"t28-57","title":"享太庙乐章","kind":"诗"}]},"萧泰来":{"slug":"萧泰来","name":"萧泰来","dynasty":"宋","style":"字则阳 · 号小山","life":"","origin":"临江（今四川忠县）","seal":"萧","bio":["--字则阳，一说字阳山，号小山，临江 (今四川忠县) 人。绍定二年 (1229) 进士。宝元年 (1253)，自起居郎出守隆兴府。","又曾为御史。著有《小山集》。存词二首。"],"works":[{"id":"c73-417","title":"霜天晓角·千霜万雪","kind":"词"},{"id":"c73-418","title":"满江红·七十人稀","kind":"词"}]},"贾逸祖":{"slug":"贾逸祖","name":"贾逸祖","dynasty":"宋","style":"","life":"","origin":"","seal":"贾","bio":[],"works":[{"id":"c67-558","title":"朝中措·青山隐隐水斜斜","kind":"词"}]},"赵孟谦":{"slug":"赵孟谦","name":"赵孟谦","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"c78-539","title":"减字木兰花·荣魁鹗荐","kind":"词"}]},"钟元章":{"slug":"钟元章","name":"钟元章","dynasty":"唐","style":"","life":"","origin":"","seal":"钟","bio":[],"works":[{"id":"t43-721","title":"句","kind":"诗"}]},"颜真卿":{"slug":"颜真卿","name":"颜真卿","dynasty":"唐","style":"字清臣","life":"","origin":"","seal":"颜","bio":["颜真卿，字清臣，京兆长安人。博学，工辞章，事亲孝。开元中举进士，又擢制科，调醴泉尉。","累迁殿中侍御史，忤宰相杨国忠，出为平原太守。安禄山反，河朔尽陷，独平原城守具备，使司兵参军李平驰奏，明皇大喜，即拜户部侍郎。肃宗即位灵武，真卿数遣使以蜡丸裹书陈事，拜工部尚书，兼御史大夫，为河北招讨采访处置使。","至德二年，朝于凤翔，授宪部尚书，迁御史大夫。军国之事，知无不言，为宰相所忌，出为冯翊太守，改蒲州刺史。御史唐旻诬劾，贬饶州刺史。","旋拜浙西节度使，召入为刑部侍郎，李辅国衔之，贬蓬州长史。代宗立，起为户部侍郎，除荆南节度使。未行，改尚书右丞，寻除检校刑部尚书，兼御史大夫，封鲁国公。","与元载不合，贬峡州别驾，改吉州司马，迁抚湖二州刺史。载诛，擢刑部尚书，进吏部。卢杞当国，益恶之，改太子太师。","李希烈陷汝州，杞奏遣真卿往谕，拘脋累岁，不屈而死。赠司徒，谥文忠。真卿立朝正色，刚而有礼，非公言直道，不萌于心，天下不以姓名称，而独曰鲁公。","善正草书，笔力遒婉，世宝传之。诗一卷。"],"works":[{"id":"t7-523","title":"题杼山癸亭得暮字","kind":"诗"},{"id":"t7-524","title":"谢陆处士杼山折青桂花见寄之什","kind":"诗"},{"id":"t7-525","title":"赠裴将军","kind":"诗"},{"id":"t7-526","title":"赠僧皎然","kind":"诗"},{"id":"t7-527","title":"咏陶渊明","kind":"诗"},{"id":"t7-528","title":"三言拟五杂组二首 一","kind":"诗"},{"id":"t7-529","title":"三言拟五杂组二首 二","kind":"诗"},{"id":"t7-530","title":"使过瑶台寺有怀圆寂上人","kind":"诗"},{"id":"t7-531","title":"登平望桥下作","kind":"诗"},{"id":"t7-532","title":"刻清远道士诗因而继作","kind":"诗"},{"id":"t43-517","title":"登岘山观李左相石尊联句","kind":"诗"},{"id":"t43-518","title":"水堂送诸文士戏赠潘丞联句","kind":"诗"},{"id":"t43-519","title":"与耿𣲗水亭咏风联句","kind":"诗"},{"id":"t43-520","title":"又溪馆听蝉联句","kind":"诗"},{"id":"t43-521","title":"送耿𣲗拾遗联句","kind":"诗"},{"id":"t43-522","title":"五言月夜啜茶联句","kind":"诗"},{"id":"t43-523","title":"五言夜宴咏灯联句","kind":"诗"},{"id":"t43-524","title":"三言喜皇甫侍御见过南楼玩月","kind":"诗"},{"id":"t43-525","title":"七言重联句","kind":"诗"},{"id":"t43-526","title":"五言送李侍御联句","kind":"诗"},{"id":"t43-527","title":"五言玩初月重游联句","kind":"诗"},{"id":"t43-528","title":"五言重送横飞联句","kind":"诗"},{"id":"t43-529","title":"五言夜集联句","kind":"诗"},{"id":"t43-530","title":"三言拟五杂组联句","kind":"诗"},{"id":"t43-531","title":"三言重拟五杂组联句","kind":"诗"},{"id":"t43-532","title":"七言大言联句","kind":"诗"},{"id":"t43-533","title":"七言小言联句","kind":"诗"},{"id":"t43-534","title":"七言乐语联句","kind":"诗"},{"id":"t43-535","title":"七言嚵语联句","kind":"诗"},{"id":"t43-536","title":"七言滑语联句","kind":"诗"},{"id":"t43-537","title":"七言醉语联句","kind":"诗"},{"id":"t51-253","title":"句（书《奉使帖》后）","kind":"诗"},{"id":"t53-117","title":"天台智者大师画赞","kind":"诗"}]}}