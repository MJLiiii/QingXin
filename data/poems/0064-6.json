[{"id":"c64-600","title":"清平乐·南窗月满","rhythmic":"清平乐","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["南窗月满。","绣被堆香暖。","苦恨春宵更漏短。","应讶郎归又晚。","征帆初落桥边。","迎门一笑嫣然。","今夜流霞共酌，何妨金盏垂莲。"]},{"id":"c64-601","title":"清平乐·明眸秀色","rhythmic":"清平乐","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["明眸秀色。","肌理凝香雪。","罗绮丛中标韵别。","捧酒歌声清越。","不辞醉脸潮红。","却愁归骑匆匆。","回首绿窗朱户，断肠明月清风。"]},{"id":"c64-602","title":"谒金门·溪声咽","rhythmic":"谒金门","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["溪声咽。","溪上有人离别。","别语叮咛和泪说。","罗巾沾泪血。","尽做刚肠如铁。","到此也应愁绝。","回首断山帆影灭。","画船空载月。"]},{"id":"c64-603","title":"谒金门·相思切","rhythmic":"谒金门","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["相思切。","触目只供愁绝。","好梦惊回清漏咽。","烛残香穗结。","长恨南楼明月。","只解照人离缺。","同倚朱栏飞大白。","今宵风月别。"]},{"id":"c64-604","title":"忆王孙·凉生冰簟怯衣单","rhythmic":"忆王孙","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["凉生冰簟怯衣单。","明月楼高空画栏。","满院啼螀人未眠。","掩重关。","乌鹊南飞风露寒。"]},{"id":"c64-605","title":"阮郎归·烟笼寒水暝禽栖","rhythmic":"阮郎归","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["烟笼寒水暝禽栖。","满庭红叶飞。","兰堂寂寂画帘垂。","霜浓更漏迟。","鸳被冷，麝香微。","强敧单枕时。","西窗看尽月痕移。","此情君怎知。"]},{"id":"c64-606","title":"柳梢青·数声鶗鴂","rhythmic":"柳梢青","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["数声鶗鴂。","可怜又是，春归时节。","满院东风，海棠铺绣，梨花飘雪。","丁香露泣残枝，算未比、愁肠寸结。","自是休文，多情多感，不干风月。"]},{"id":"c64-607","title":"柳梢青·子规啼月","rhythmic":"柳梢青","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["子规啼月。","幽衾梦断，销魂时节。","枕上斑斑，枝头点点，染成清血。","凄凉断雨残云，算此恨、文君更切。","老去情怀，春来况味，那禁离别。"]},{"id":"c64-608","title":"柳梢青·联璧寻春","rhythmic":"柳梢青","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["联璧寻春，踏青尚意，年时携手。","此际重来，可怜还是，年时时候。","阴阴柳下人家，人面桃花似旧。","但原年年，春风有信，人心长久。"]},{"id":"c64-609","title":"好事近·花露滴香红","rhythmic":"好事近","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["花露滴香红，花低漏声初歇。","人似一枝梅瘦，照冰壶清彻。","翠娥云鬓为谁容，虫丝宝奁结。","可惜一春憔悴，负满怀风月。"]},{"id":"c64-610","title":"好事近·十幅健帆风","rhythmic":"好事近","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["十幅健帆风，天意巧催行客。","极目五湖云浪，泛满空秋色。","玉人应怪误佳期，凝恨正脉脉。","锦鳞为传尺素，报兰舟消息。"]},{"id":"c64-611","title":"卜算子·风雨送春归","rhythmic":"卜算子","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["风雨送春归，寂寞花空委。","枝上红稀地上多，万点随流水。","翠黛敛春愁，照影临清泚。","应念韶华惜蕣颜，洒遍胭脂泪。"]},{"id":"c64-612","title":"卜算子·小阁枕清流","rhythmic":"卜算子","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["小阁枕清流，一霎莲塘雨。","风递幽香入槛来，枕簟全无暑。","遐想似花人，阅岁音尘阻。","物是人非空断肠，梦入芳洲路。"]},{"id":"c64-613","title":"卜算子·玉斧斫冰轮","rhythmic":"卜算子","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["玉斧斫冰轮，中有乘鸾女。","鬓乱钗横襟袖凉，只恐轻飞举。","青冥缥缈间，自有吹箫侣。","不向巫山十二峰，朝暮为云雨。"]},{"id":"c64-614","title":"卜算子·前度月圆时","rhythmic":"卜算子","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["前度月圆时，月下相携手。","今夜天边月又圆，夜色如清昼。","风月浑依旧。","水馆空回首。","明夜归来试问伊，曾解思量否。"]},{"id":"c64-615","title":"卜算子·重重雪外山","rhythmic":"卜算子","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["重重雪外山，渺渺烟中路。","路转山横无尽愁，正是分携处。","望极锦中书，肠断鱼中素。","锦素沈沈两未期，鱼雁空相误。"]},{"id":"c64-616","title":"卜算子·春事付莺花","rhythmic":"卜算子","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["春事付莺花，曾是莺花主。","醉拍春衫金缕衣，只向花间住。","密意君听取。","莫逐风来去。","若是真心待于飞，云里千条路。"]},{"id":"c64-617","title":"小重山·楼外江山展翠屏","rhythmic":"小重山","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["楼外江山展翠屏。","沈沈虹影畔，彩舟横。","一尊别酒为君倾。","留不住，风色太无情。","斜日半山明。","画栏重倚处，独销凝。","片帆回首在青冥。","人不见，千里暮云平。"]},{"id":"c64-618","title":"小重山·澹澹秋容烟水寒","rhythmic":"小重山","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["澹澹秋容烟水寒。","楼高清夜永，倚阑干。","玉人不见坐长叹。","箫声远，明月满空山。","遐想绿云鬟。","青冥风露冷，独乘鸾。","别时容易见时难。","凭孤枕，聊复梦蝉娟。"]},{"id":"c64-619","title":"小重山·流水桃花小洞天","rhythmic":"小重山","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["流水桃花小洞天。","壶中春不老，胜尘寰。","霞衣鹤氅并桃冠。","新装好，风韵愈飘然。","功行满三千。","婴儿并姹女，炼成丹。","刘郎曾约共升仙。","十个月，养个小金坛。"]},{"id":"c64-620","title":"小重山·楼上风高翠袖寒","rhythmic":"小重山","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["楼上风高翠袖寒。","碧云笼淡日，照阑干。","绿杨芳草恨绵绵。","长亭路，何处认征鞍。","晓镜懒重看。","鬓云堆凤髻，任阑珊。","鸾衾鸳枕小屏山。","人如玉，忍负一春闲。"]},{"id":"c64-621","title":"踏莎行·佩解江皋","rhythmic":"踏莎行","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["佩解江皋，魂消南浦。","人生惟有别离苦。","别时容易见时难，算来却是无情语。","百计留君，留君不住。","留君不住君须去。","望君频问梦中来，免教肠断巫山雨。"]},{"id":"c64-622","title":"踏莎行·如是我闻","rhythmic":"踏莎行","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["如是我闻，金仙出世。","一超直入如来地。","慈悲方便济群生，端严妙相谁能比。","四众归依，悉皆欢喜。","有情同赴龙华会。","无忧帐里结良缘，麽诃修哩修修哩。"]},{"id":"c64-623","title":"踏莎行·客里光阴","rhythmic":"踏莎行","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["客里光阴，伤离情味。","玉觞未举心先醉。","临岐莫怪苦留连，樯乌转处人千里。","恨写新声，云笺密寄。","短封难尽心中事。","凭君看取纸痕斑，分明总是离人泪。"]},{"id":"c64-624","title":"踏莎行·落日归云","rhythmic":"踏莎行","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["落日归云，寒空断雁。","吴波浅淡山平远。","丹青写出在霜缣，佳人特地栽团扇。","渔艇孤烟，酒旗幽院。","些儿景趣君休羡。","五湖归去共扁舟，何如早早酬深愿。"]},{"id":"c64-625","title":"踏莎行·水满青钱","rhythmic":"踏莎行","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["水满青钱，烟滋翠葆。","残英满地无人扫。","先来羁思乱如云，无端更被春酲恼。","叠叠遥山，绵绵远道。","凭阑满目唯芳草。","莫惊青鬓点秋霜，卢郎已分愁中老。"]},{"id":"c64-626","title":"踏莎行·玉质孤高","rhythmic":"踏莎行","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["玉质孤高，天姿明慧。","了无一点尘凡气。","白莲空殿锁幽芳，亭亭独占秋光里。","一切见闻，不可思议。","我今有分亲瞻礼。","愿垂方便济众生，他时同赴龙华会。"]},{"id":"c64-627","title":"定风波·一曲骊歌酒一锺","rhythmic":"定风波","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["一曲骊歌酒一锺。","可怜分袂太匆匆。","百计留君留不住。","□去。","满川烟暝满帆风。","目断魂销人不见。","但见。","青山隐隐水浮空。","拟把一襟相忆泪。","试□。","云笺密洒付飞鸿。"]},{"id":"c64-628","title":"定风波·老去情锺不自持","rhythmic":"定风波","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["老去情锺不自持。","篸花酌酒送春归。","玉貌冰姿人窈窕。","一笑。","清狂岂减少年时。","欲上香车俱脉脉，半帘花影月平西。","待得酒醒人已去。","凝伫。","断云残雨尽堪悲。"]},{"id":"c64-629","title":"点绛唇·水绕孤城","rhythmic":"点绛唇","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["水绕孤城，乱山深锁横江路。","帆归别浦。","苒苒兰皋暮。","人在天涯，雁背南云去。","空凝伫。","凤楼何处。","烟霭迷津渡。"]},{"id":"c64-630","title":"点绛唇·香雪飘零","rhythmic":"点绛唇","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["香雪飘零，暖风著柳笼丝雨。","恼人情绪。","春事还如许。","宝勒朱轮，共结寻芳侣。","东郊路。","乱红深处。","醉拍黄金缕。"]},{"id":"c64-631","title":"点绛唇·背壁灯残","rhythmic":"点绛唇","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["背壁灯残，卧听檐雨难成寐。","井梧飘坠。","历历蛩声细。","数尽更筹。","滴尽罗巾泪。","如何睡。","甫能得睡。","梦到相思地。"]},{"id":"c64-632","title":"点绛唇·月缺花残","rhythmic":"点绛唇","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["月缺花残，世间乐事难双美。","夜来相对。","把酒弹轻泪。","一点情锺，销尽英雄气。","樊笼外。","五湖烟水。","好作扁舟计。"]},{"id":"c64-633","title":"点绛唇·玉笋持杯","rhythmic":"点绛唇","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["玉笋持杯，敛红颦翠歌金缕。","彩鸳戢羽。","未免群鸡妒。","我为情多，愁听多情语。","君休诉。","两心坚固。","云里千条路。"]},{"id":"c64-634","title":"点绛唇·人面桃花","rhythmic":"点绛唇","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["人面桃花，去年今日津亭见。","瑶琴锦荐。","一弄清商怨。","金日重来，不见如花面。","空肠断。","乱红千片。","流水天涯远。"]},{"id":"c64-635","title":"点绛唇·梅雨初晴","rhythmic":"点绛唇","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["梅雨初晴，画栏开遍忘忧草。","兰堂清窈。","高柳新蝉噪。","枕上芙蓉，如梦还惊觉。","匀妆了。","背人微笑。","风入玲珑罩。"]},{"id":"c64-636","title":"点绛唇·帐外华灯","rhythmic":"点绛唇","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["帐外华灯，翠屏花影参差满。","锦衣香暖。","苦恨春宵短。","画角声中，云雨还轻散。","河桥畔。","月华如练。","回首成肠断。"]},{"id":"c64-637","title":"点绛唇·绿萼冰花","rhythmic":"点绛唇","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["绿萼冰花，数枝清影横疏牖。","玉肌清瘦。","夜久轻寒透。","忍使孤芳，攀折他人手。","人归后。","断肠回首。","只有香盈袖。"]},{"id":"c64-638","title":"点绛唇·解绂朝天","rhythmic":"点绛唇","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["解绂朝天，满城桃李繁阴市。","彩舟难驻。","忍听骊歌举。","协赞中兴，圣意方倾注。","从今去。","五云深处。","稳步沙堤路。"]},{"id":"c64-639","title":"点绛唇·云雨匆匆","rhythmic":"点绛唇","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["云雨匆匆，洞房当日曾相遇。","暂来还去。","无计留春住。","宝瑟重调，静听莺弦语。","休轻负。","绮窗朱户。","好做风光主。"]},{"id":"c64-640","title":"昭君怨·一曲云和松响","rhythmic":"昭君怨","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["一曲云和松响。","多少离愁心上。","寂寞掩屏帷。","泪沾衣。","最是销魂处。","夜夜绮窗风雨。","风雨伴愁眠。","夜如年。"]},{"id":"c64-641","title":"醉落魄・一斛珠·波纹如縠","rhythmic":"醉落魄・一斛珠","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["波纹如縠。","池塘雨后添新绿。","海棠初绽红生肉。","双燕归来，还认旧巢宿。","凝情凭暖阑干曲。","新愁无限伤心目。","谁人月下吹横玉。","惊起鸳鸯，飞去自相逐。"]},{"id":"c64-642","title":"醉落魄・一斛珠·霜华摇落","rhythmic":"醉落魄・一斛珠","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["霜华摇落。","亭亭皓月侵朱箔。","梦回敧枕听残角。","一片寒声，风送入寥廓。","眼前风月都如昨。","独眠无奈情怀恶。","凭肩携手于飞约。","料想人人，终是赋情薄。"]},{"id":"c64-643","title":"醉落魄・一斛珠·明眸秀色","rhythmic":"醉落魄・一斛珠","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["明眸秀色。","双蛾巧画春山碧。","盈盈标韵倾瑶席。","一见尊前，宛是旧相识。","深期密语虽端的。","良宵无奈成轻掷。","忍教只恁空相忆。","得入手来，无限好则剧。"]},{"id":"c64-644","title":"醉落魄・一斛珠·阳关声咽","rhythmic":"醉落魄・一斛珠","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["阳关声咽。","清歌响断云屏隔。","溪山依旧连空碧。","昨日主人，今日是行客。","绿窗朱户应如昔。","回头往事成陈迹。","后期总便无端的。","月下风前，应也解相忆。"]},{"id":"c64-645","title":"极相思·碧檐鸣玉玎珰","rhythmic":"极相思","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["碧檐鸣玉玎珰。","金锁小兰房。","楼高夜永，飞霜满院，璧月沈缸。","云雨不成巫峡梦，望仙乡、烟水茫茫。","风前月底，登高念远，无限凄凉。"]},{"id":"c64-646","title":"极相思·相思情味堪伤","rhythmic":"极相思","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["相思情味堪伤。","谁与话衷肠。","明朝见也，桃花人面，碧藓回廊。","别后相逢唯有梦，梦回时、展转思量。","不如早睡，今宵魂梦，先到伊行。"]},{"id":"c64-647","title":"玉楼春·碧桃溪上蓝桥路","rhythmic":"玉楼春","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["碧桃溪上蓝桥路。","寂寞朱门闲院宇。","粉墙疏竹弄清蟾，玉砌红蕉宜夜雨。","个中人是吹箫侣。","花底深盟曾共语。","人生乐在两知心，此意此生君记取。"]},{"id":"c64-648","title":"玉楼春·星河风露经年别","rhythmic":"玉楼春","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["星河风露经年别。","月照离亭花似雪。","宝钗鸾镜会重逢，花里同眠今夜月。","月华依旧当时节。","细把离肠和泪说。","人生只合镇长圆，休似月圆圆又缺。"]},{"id":"c64-649","title":"长相思·我心坚","rhythmic":"长相思","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["我心坚。","你心坚。","各自心坚石也穿。","谁言相见难。","小窗前。","月婵娟。","玉困花柔并枕眠。","今宵人月圆。"]},{"id":"c64-650","title":"长相思·锦衾香","rhythmic":"长相思","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["锦衾香。","玉枕双。","昨夜深深小洞房。","回头已断肠。","背兰缸。","梦仙乡。","风撼梧桐雨洒窗。","今宵好夜长。"]},{"id":"c64-651","title":"长相思·村姑儿","rhythmic":"长相思","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["村姑儿。","红袖衣。","初发黄梅插稻时。","双双女伴随。","长歌诗。","短歌诗。","歌里真情恨别离。","休言伊不知。"]},{"id":"c64-652","title":"西地锦·寂寞悲秋怀抱","rhythmic":"西地锦","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["寂寞悲秋怀抱。","掩重门悄悄。","清风皓月，朱阑画阁，双鸳池沼。","不忍今宵重到。","惹离愁多少。","蓬山路杳，蓝桥信阻，黄花空老。"]},{"id":"c64-653","title":"归田乐·风生苹末莲香细","rhythmic":"归田乐","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["风生苹末莲香细。","新浴晚凉天气。","犹自倚朱阑，波面双双彩鸳戏。","鸾钗委坠云堆髻。","谁会此时情意。","冰簟玉琴横，还是月明人千里。"]},{"id":"c64-654","title":"七娘子·天涯触目伤离绪","rhythmic":"七娘子","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["天涯触目伤离绪。","登临况值秋光暮。","手拈黄花，凭谁分付。","雍雍雁落蒹葭浦。","凭高目断桃溪路。","屏山楼外青无数。","绿水红桥，锁窗朱户。","如今总是销魂处。"]},{"id":"c64-655","title":"感皇恩·酒晕衬横波","rhythmic":"感皇恩","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["酒晕衬横波，玉肌香透。","轻袅腰肢妒垂柳。","臂宽金钏，且是不干春瘦。","拈金双合字，无心绣。","鬒云半堕，金钗欲溜。","罗袂残香忍重嗅。","渡江桃叶，肠断为谁招手。","倚阑凝望久，眉空斗。"]},{"id":"c64-656","title":"感皇恩·膏雨晓来晴","rhythmic":"感皇恩","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["膏雨晓来晴，海棠红透。","碧草池塘袅金柳。","王孙何在，不念玉容消瘦。","日长深院静，帘垂绣。","璨枕堕钗，粉痕轻溜。","玉鼎龙涎记同嗅。","钿筝重理，心事谩凭纤手。","素弦弹不尽，眉峰斗。"]},{"id":"c64-657","title":"减字木兰花·彤庭龙尾","rhythmic":"减字木兰花","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["彤庭龙尾。","礼备天颜知有喜。","九奏初传。","耳冷人间十七年。","盈成持守。","仁德如春渐九有。","三辅名州。","好整笙歌结胜游。"]},{"id":"c64-658","title":"减字木兰花·船回沙尾","rhythmic":"减字木兰花","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["船回沙尾。","几误红窗听鹊喜。","尺素空传。","转首相逢又隔年。","寒灯独守。","玉笋持杯宁复有。","秀水南州。","徒使幽人作梦游。"]},{"id":"c64-659","title":"减字木兰花·多情多病","rhythmic":"减字木兰花","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["多情多病。","玉貌疲来愁览镜。","门掩东风。","零落桃花满地红。","重帘不卷。","愁睹杏梁双语燕。","强拂瑶琴。","一曲幽兰泪满襟。"]},{"id":"c64-660","title":"减字木兰花·金风玉露","rhythmic":"减字木兰花","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["金风玉露。","喜鹊桥成牛女渡。","天宇沈沈。","一夕佳期两意深。","琼签报曙。","忍使飙轮容易去。","明日如今。","想见君心似我心。"]},{"id":"c64-661","title":"减字木兰花·锦屏人醉","rhythmic":"减字木兰花","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["锦屏人醉。","玉暖香融春有味。","今日兰舟。","魂梦还随绿水流。","高城望断。","无奈城中人不见。","斜倚妆楼。","恨入眉峰两点愁。"]},{"id":"c64-662","title":"渔家傲·烟锁池塘秋欲暮","rhythmic":"渔家傲","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["烟锁池塘秋欲暮。","细细前香，直到双栖处。","并枕东窗听夜雨。","偎金缕。","云深不见来时路。","晓色朦胧人去住。","香覆重帘，密密闻私语。","日断征帆归别浦。","空凝伫。","苔痕绿印金莲步。"]},{"id":"c64-663","title":"西楼子・相见欢·楼前流水悠悠","rhythmic":"西楼子・相见欢","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["楼前流水悠悠。","驻行舟。","满目寒云衰草、使人愁。","多少恨，多少泪，谩迟留。","何似蓦然拚舍、去来休。"]},{"id":"c64-664","title":"西楼子・相见欢·红靴玉带葳蕤","rhythmic":"西楼子・相见欢","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["红靴玉带葳蕤。","翠绡衣。","并辔垂鞭妆影、照清溪。","长亭路。","停骑处。","晚凉时。","空有许多明月、伴双栖。"]},{"id":"c64-665","title":"御街行·东君不锁寻芳路","rhythmic":"御街行","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["东君不锁寻芳路。","曾是莺花主。","有情风月可怜宵，犹记绿窗朱户。","十年空想，春风面杳，无计凭鳞羽。","凄凉怀抱今如许。","天与重相遇。","不应还向楚峰前，朝暮为云为雨。","算来各把，平生分付，也不是、恶著处。"]},{"id":"c64-666","title":"上阳春・蓦山溪·好在章台杨柳","rhythmic":"上阳春・蓦山溪","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["好在章台杨柳。","不禁春瘦。","淡烟微雨曲尘丝，锁一点、眉头皱。","忆自灞陵别后。","青青依旧。","万丝千缕太多情，忍攀折、行人手。"]},{"id":"c64-667","title":"临江仙·繁杏枝头蜂蝶乱","rhythmic":"临江仙","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["繁杏枝头蜂蝶乱，香风阖坐微闻。","靓妆浓艳任东君。","无情风雨，春事已平分。","珍重主人留客意，夜阑秉烛开尊。","何须歌韵遏行云。","羽觞交劝，挥麈细论文。"]},{"id":"c64-668","title":"临江仙·昨夜中秋今夕望","rhythmic":"临江仙","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["昨夜中秋今夕望，十分桂影团圆。","玉人相对绿尊前。","素娥有恨，应是妒蝉娟。","人静小庭风露冷，歌声特地清圆。","醉红醺脸髻鬟偏。","翠裙轻皱，端的为留仙。"]},{"id":"c64-669","title":"临江仙·帘幕深深清昼永","rhythmic":"临江仙","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["帘幕深深清昼永，玉人不耐春寒。","镂牙棋子缕金圆。","象盘雅戏，相对小窗前。","隔打直行尖曲路，教人费尽机关。","局中胜负定谁偏。","饶伊使幸，毕竟我赢先。"]},{"id":"c64-670","title":"临江仙·仙品不同桃李艳","rhythmic":"临江仙","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["仙品不同桃李艳，移来月窟云乡。","幽姿绰约道家妆。","绿云堆髻，娇额半涂黄。","可但乍凉风月下，饶伊独占秋光。","雨中别有恼人香。","错教萧史，肠断忆巫阳。"]},{"id":"c64-671","title":"临江仙·琪树鸾栖花露重","rhythmic":"临江仙","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["琪树鸾栖花露重，依稀兰洞风光。","玉人相对自生凉。","翠鬟琼佩，绰约蕊珠妆。","宝瑟声沈清梦觉，夜阑明月幽窗。","可堪襟袂惹馀香。","断云残雨，何处认高唐。"]},{"id":"c64-672","title":"临江仙·记得南楼三五夜","rhythmic":"临江仙","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["记得南楼三五夜，曾听凤管昭华。","曾前此际重兴嗟。","素娥端有恨，烟霭等闲遮。","珍重主人留客意，厌厌缓引流霞。","夜间银汉淡天涯。","亭亭丹桂现，耿耿玉绳斜。"]},{"id":"c64-673","title":"临江仙·青润奇峰名韫玉","rhythmic":"临江仙","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["青润奇峰名韫玉，温其质并琼瑶。","中分瀑布泻云涛。","双峦呈翠色，气象两相高。","珍重幽人诚好事，绿窗聊助风骚。","寄言俗客莫相嘲。","物轻人意重，千里赠鹅毛。"]},{"id":"c64-674","title":"鹧鸪天·脉脉柔情不自持","rhythmic":"鹧鸪天","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["脉脉柔情不自持。","浅颦轻笑百般宜。","尊前唱歇黄金缕，一点春愁入翠眉。","流蕙盼，捧瑶卮。","借君歌扇写新诗。","浮花谩说惊郎目，不似东风第一枝。"]},{"id":"c64-675","title":"惜奴娇·隔阔多时","rhythmic":"惜奴娇","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["隔阔多时，算彼此、难存济。","咫尺地、千山万水。","眼眼相看，要说话、都无计。","只是。","唱曲儿、词中认意。","雪意垂垂，更刮地、寒风起。","怎禁这几夜意。","未散痴心，便指望、长偎倚。","只替。","那火桶儿、与奴暖被。"]},{"id":"c64-676","title":"行香子·珠露初零","rhythmic":"行香子","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["珠露初零。","天宇澄明。","正闲阶、皎月亭亭。","更阑人静，烟敛风清。","更井边桐，一叶叶，做秋声。","斗帐鸾屏。","翠被华茵。","梦回时、酒力初醒。","绿云堆枕，红玉生春。","且打叠起，龙牙簟，竹夫人。"]},{"id":"c64-677","title":"一翦梅·堆枕乌云堕翠翘","rhythmic":"一翦梅","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["堆枕乌云堕翠翘。","午梦惊回，满眼春娇。","嬛嬛一袅楚宫腰。","那更春来，玉减香消。","柳下朱门傍小桥。","几度红窗，误认鸣镳。","断肠风月可怜宵。","忍使恹恹，两处无聊。"]},{"id":"c64-678","title":"一翦梅·高宴华堂夜向阑","rhythmic":"一翦梅","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["高宴华堂夜向阑。","急管飞霜，羯鼓声乾。","仙人掌上水晶盘。","回按凌波，舞袖弓弯。","曲罢凝娇整翠鬟。","玉笋持杯，巧笑嫣然。","为君一醉倒金船。","只恐醒来，人隔云山。"]},{"id":"c64-679","title":"一翦梅·夜永虚堂烛影寒","rhythmic":"一翦梅","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["夜永虚堂烛影寒。","斗转春来，又是明年。","异乡怀抱只凄然。","尊酒相逢且自宽。","天际孤云云外山。","梦绕觚稜，日下长安。","功名已觉负初心，羞对菱花，绿鬓成斑。"]},{"id":"c64-680","title":"六么令·梅英飘雪","rhythmic":"六么令","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["梅英飘雪，弱柳弄新绿。","泠泠画桥流水，风静波如縠。","长记扁舟共载，偶近旗亭宿。","渺云横玉。","鸳鸯枕上，听彻新翻数般曲。","此际魂清梦冷，绣被香芬馥。","因念多感情怀，触处伤心目。","自是今宵独寐，怎不添愁蹙。","如今心足。","风前月下，赖有斯人慰幽独。"]},{"id":"c64-681","title":"镇西・小镇西犯·秋风吹暗雨","rhythmic":"镇西・小镇西犯","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["秋风吹暗雨，重衾寒透。","伤心听、晓钟残漏。","凝情久。","记红窗夜雪，促膝围炉，交杯劝酒。","如今顿孤欢偶。","念别后。","菱花清镜里。","眉峰暗斗。","想标容、怎禁销瘦。","忍回首。","但云笺妙墨，鸳锦啼妆，依然似旧。","临风泪沾襟袖。"]},{"id":"c64-682","title":"看花回·夜久凉生","rhythmic":"看花回","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["夜久凉生，庭院漏声频促。","念昔胜游旧地，对画阁层峦，雨馀烟簇。","新诗暗藏小字，霜刀刊翠竹。","携素手、细绕回塘，芰荷香里彩鸳宿。","别后想、香销腻玉。","带围减、钏宽金粟。","虽有鳞鸿锦素，柰事与心违，佳期难卜。","拟解愁肠万结，唯凭尊酒绿。","望天涯断魂处，醉拍阑干曲。"]},{"id":"c64-683","title":"诉衷情·亭亭秋水玉芙蓉","rhythmic":"诉衷情","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["亭亭秋水玉芙蓉。","天际水浮空。","碧云望中空暮，人在广寒宫。","双缕枕，曲屏风。","小房栊。","可怜今夜，明月清风，无计君同。"]},{"id":"c64-684","title":"浪淘沙·楼下水潺湲","rhythmic":"浪淘沙","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["楼下水潺湲。","楼外屏山。","淡烟笼月晚凉天。","曾共玉人携素手，同倚阑干。","云散梦难圆。","幽恨绵绵。","旧游重到忍重看。","负你一生多少泪，月下花前。"]},{"id":"c64-685","title":"如梦令·人静重门深亚","rhythmic":"如梦令","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["人静重门深亚。","朱阁画帘高挂。","人与月俱圆，月色波光相射。","潇洒。","潇洒。","人月长长今夜。"]},{"id":"c64-686","title":"如梦令·今夜行云何处","rhythmic":"如梦令","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["今夜行云何处。","还是月华当午。","倚遍曲阑桥，望断锦屏归路。","空去。","空去。","梦到绿窗朱户。"]},{"id":"c64-687","title":"愁倚阑・春光好·伤春晚","rhythmic":"愁倚阑・春光好","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["伤春晚，送春归。","步云溪。","绿叶同心双小字，记曾题。","楼外红日平西。","长亭路、烟草萋萋。","云雨不成新梦后，倚阑时。"]},{"id":"c64-688","title":"愁倚阑・春光好·天如水","rhythmic":"愁倚阑・春光好","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["天如水，月如钩。","正新秋。","月影参差人窈窕，小红楼。","如今往事悠悠。","楼前水、肠断东流。","旧物忍看金约腕，玉搔头。"]},{"id":"c64-689","title":"愁倚阑・春光好·一番雨","rhythmic":"愁倚阑・春光好","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["一番雨，一番凉。","夜初长。","满院蛩吟人不寝，月侵廊。","木犀微绽幽芳。","西风透、窈窕红窗。","恰似个人鸳被里，玉肌香。"]},{"id":"c64-690","title":"望江南・忆江南·花落尽","rhythmic":"望江南・忆江南","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["花落尽，寂寞委残红。","蝶帐梦回空晓月，凤楼人去谩东风。","春事已成空。","闲伫立，□□水溶溶。","云锁乱山横惨淡，烟笼绿树晚溟濛。","却在泪痕中。"]},{"id":"c64-691","title":"春光好·鸾屏掩","rhythmic":"春光好","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["鸾屏掩，翠衾香。","小兰房。","回首当时云雨梦，两难忘。","如今水远山长。","凭鳞翼、难叙衷肠。","况是教人无可恨，一味思量。"]},{"id":"c64-692","title":"风流子·韶华惊晼晚","rhythmic":"风流子","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["韶华惊晼晚，青春老、倦客惜年芳。","庭樾荫浓，半藏莺语，畹兰花减，时有蜂忙。","粉墙低，嫩岚滋翠葆，零露湿残妆。","风暖昼长，柳绵吹尽，澹烟微雨，梅子初黄。","洛浦音容远，书空漫惆怅，往事悲凉。","无奈锦鳞杳杳，不渡横塘。","念蝴蝶梦回，子规声里，半窗斜月，一枕馀香。","拟待自宽，除非铁做心肠。"]},{"id":"c64-693","title":"朝中措·章台杨柳月依依","rhythmic":"朝中措","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["章台杨柳月依依。","飞絮送春归。","院宇日长人静，园林绿暗红稀。","庭前花谢了，行云散后，物是人非。","唯有一襟清泪，凭阑洒遍残枝。"]},{"id":"c64-694","title":"朝中措·雨馀清镜湛秋容","rhythmic":"朝中措","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["雨馀清镜湛秋容。","屏展九华峰。","万里闲云散尽，半规凉月当空。","楼高夜永，凭阑笑语，此际谁同。","端有妙人携手，け然归路凌风。"]},{"id":"c64-695","title":"侍香金童·宝马行春","rhythmic":"侍香金童","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["宝马行春，缓辔随油壁。","念一瞬、韶光堪重惜。","还是去年同醉日。","客里情怀，倍添凄恻。","记南城、锦径名园曾遍历。","更柳下、人家似织。","此际凭阑愁脉脉。","满目江山，暮云空碧。"]},{"id":"c64-696","title":"江城子·碧厨文簟小窗前","rhythmic":"江城子","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["碧厨文簟小窗前。","乍更阑。","□□□。","乌鹊南飞，秋意渐凄然。","满院蛩吟风露下，人窈窕，月蝉娟。","双星旧约又经年。","信谁传。","恨绵绵。","□隔明河，长作断肠仙。","争似秦楼萧史伴，瑶台路，共乘鸾。"]},{"id":"c64-697","title":"西江月·翡翠蒙金衫子","rhythmic":"西江月","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["翡翠蒙金衫子，缕尘如意冠儿。","持杯轻按遏云词。","别是出尘风味。","莫羡双星旧约，愿谐明月佳期。","凭肩密语两心知。","一棹五湖烟水。"]},{"id":"c64-698","title":"苍梧谣・归字谣·天","rhythmic":"苍梧谣・归字谣","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["天。","休使圆蟾照客眠。","人何在，桂影自婵娟。"]},{"id":"c64-699","title":"采桑子·奇花不比寻常艳","rhythmic":"采桑子","author":"蔡伸","authorSlug":"蔡伸","dynasty":"宋","kind":"ci","paragraphs":["奇花不比寻常艳，独步南州。","往事悠悠。","辽鹤重来忆梦游。","仙翁不改青青眼，一醉迟留。","妙墨银钩。","题作人间第一流。"]}]