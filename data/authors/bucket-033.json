{"丘丹":{"slug":"丘丹","name":"丘丹","dynasty":"唐","style":"","life":"","origin":"","seal":"丘","bio":["丘丹，苏州嘉兴人。诸暨令，历尚书郎。隐临平山，与韦应物、鲍防、吕渭诸牧守往还。","存诗十一首。丘丹，苏州嘉兴人，诸暨令，历尚书郎。隐临平山，与韦应物、鲍防、吕渭诸牧守往还，存诗十一首。"],"works":[{"id":"t16-608","title":"忆长安 四月","kind":"诗"},{"id":"t16-609","title":"状江南 季冬","kind":"诗"},{"id":"t16-610","title":"和韦使君秋夜见寄","kind":"诗"},{"id":"t16-611","title":"奉酬韦苏州使君","kind":"诗"},{"id":"t16-612","title":"和韦使君听江笛送陈侍御","kind":"诗"},{"id":"t16-613","title":"奉酬韦使君送归山之作","kind":"诗"},{"id":"t16-614","title":"奉酬重送归山","kind":"诗"},{"id":"t16-615","title":"经湛长史草堂","kind":"诗"},{"id":"t16-616","title":"萧山祗园寺","kind":"诗"},{"id":"t16-617","title":"奉使过石门观瀑","kind":"诗"},{"id":"t16-618","title":"秋夕宿石门馆","kind":"诗"},{"id":"t48-831","title":"奉使过石门瀑布","kind":"诗"},{"id":"t48-832","title":"秋夕宿石门馆","kind":"诗"}]},"令超":{"slug":"令超","name":"令超","dynasty":"唐","style":"","life":"","origin":"","seal":"令","bio":["令超，住筠州上蓝山，世称上蓝和尚。大顺庚戌岁卒。（《全唐诗》卷八七五收上蓝谶偈三则，云「失其名」，今据《景德传灯录》卷十六补传）"],"works":[{"id":"t54-264","title":"垂训诗","kind":"诗"}]},"利踪":{"slug":"利踪","name":"利踪","dynasty":"唐","style":"","life":"","origin":"","seal":"利","bio":["利踪，姓周，澶州人。嗣南泉，住衢州子湖山，世称神力子湖和尚。广明中卒，年八十一。","诗五首。（《全唐诗》无利踪诗）"],"works":[{"id":"t54-137","title":"颂 一","kind":"诗"},{"id":"t54-138","title":"颂 二","kind":"诗"},{"id":"t54-139","title":"临行颂三首 一","kind":"诗"},{"id":"t54-140","title":"临行颂三首 二","kind":"诗"},{"id":"t54-141","title":"临行颂三首 三","kind":"诗"}]},"后蜀嗣主孟昶":{"slug":"后蜀嗣主孟昶","name":"后蜀嗣主孟昶","dynasty":"唐","style":"字保元","life":"","origin":"","seal":"后","bio":["昶，字保元，蜀主知祥第三子，明德元年，立为太子，在位二十八年。国亡，降宋，封秦国公。卒，赠楚王，谥恭惠。","诗一篇。"],"works":[{"id":"t0-353","title":"避暑摩诃池上作","kind":"诗"}]},"周辉":{"slug":"周辉","name":"周辉","dynasty":"宋","style":"","life":"","origin":"","seal":"周","bio":[],"works":[{"id":"c67-597","title":"失调名·卷帘试约东君","kind":"词"},{"id":"c67-598","title":"失调名·生怕冻损蜂房","kind":"词"}]},"周颉":{"slug":"周颉","name":"周颉","dynasty":"宋","style":"","life":"","origin":"","seal":"周","bio":[],"works":[{"id":"c68-79","title":"朝中措·郧城清胜压湖湘","kind":"词"}]},