{"万俟造":{"slug":"万俟造","name":"万俟造","dynasty":"唐","style":"","life":"","origin":"","seal":"万","bio":[],"works":[{"id":"t43-320","title":"龙池春草","kind":"诗"}]},"严郭":{"slug":"严郭","name":"严郭","dynasty":"唐","style":"","life":"","origin":"","seal":"严","bio":[],"works":[{"id":"t43-3","title":"赋百舌鸟","kind":"诗"}]},"休静":{"slug":"休静","name":"休静","dynasty":"唐","style":"","life":"","origin":"","seal":"休","bio":["休静，嗣洞山。住洛京华岩寺。世称华岩和尚。","诗一首。（《全唐诗》无休静诗，传据《祖堂集》卷八）"],"works":[{"id":"t54-157","title":"颂","kind":"诗"}]},"光云":{"slug":"光云","name":"光云","dynasty":"唐","style":"","life":"","origin":"","seal":"光","bio":["光云，莆田人。嗣长庆慧棱。闽主请住福州报慈院，世称报慈和尚。","（《祖堂集》卷一二）"],"works":[{"id":"t55-775","title":"和晖和尚颂","kind":"诗"}]},"史愚":{"slug":"史愚","name":"史愚","dynasty":"宋","style":"","life":"","origin":"","seal":"史","bio":[],"works":[{"id":"c71-970","title":"谒金门·深院宇","kind":"词"}]},"周某":{"slug":"周某","name":"周某","dynasty":"宋","style":"","life":"","origin":"","seal":"周","bio":[],"works":[{"id":"c66-996","title":"失调名·瑶池仙伴","kind":"词"}]},"孙□":{"slug":"孙□","name":"孙□","dynasty":"唐","style":"","life":"","origin":"","seal":"孙","bio":["孙□，名不详，开元十七年任石泉县令。"],"works":[{"id":"t52-658","title":"同前","kind":"诗"}]},"张云容":{"slug":"张云容","name":"张云容","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张云容，杨贵妃侍儿也。申天师与绛雪丹服之，教其死后为大棺通穴，百年后，遇生人交精气，再生，可为地仙。后死，如法葬兰昌宫。","至元和末，有平陆尉金陵薛昭，以义气逸县囚，谪赴海东。至三乡，夜遁去，匿兰昌宫古殿傍，见三美女至，一则云容，其二则萧凤台、刘兰翘。向为九仙媛所毒杀，同藏云容穴侧者。","云容向昭备说生前事及申天师语，昭叹异。二女送酒合卺，各为歌献酬。懽洽数夕，云容倏自言，吾体已苏，昭为启榇，遂活，同归金陵。"],"works":[{"id":"t47-833","title":"与薛昭合婚诗 一","kind":"诗"},{"id":"t47-834","title":"与薛昭合婚诗 二","kind":"诗"},{"id":"t47-835","title":"与薛昭合婚诗 三","kind":"诗"},{"id":"t47-836","title":"与薛昭合婚诗 四","kind":"诗"}]},"房千里":{"slug":"房千里","name":"房千里","dynasty":"唐","style":"字鹄举","life":"","origin":"","seal":"房","bio":["房千里，字鹄举。登太和进士第，官国子博士，终高州刺史。诗一首。"],"works":[{"id":"t28-52","title":"寄妾赵氏","kind":"诗"}]},"李君何":{"slug":"李君何","name":"李君何","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李君何，贞元中进士第。诗一首。"],"works"