{"万楚":{"slug":"万楚","name":"万楚","dynasty":"唐","style":"","life":"","origin":"","seal":"万","bio":["万楚，登开元进士第。诗八首。"],"works":[{"id":"t1-864","title":"杂曲歌辞 茱萸女","kind":"诗"},{"id":"t6-975","title":"小山歌","kind":"诗"},{"id":"t6-976","title":"题江潮庄壁","kind":"诗"},{"id":"t6-977","title":"咏帘","kind":"诗"},{"id":"t6-978","title":"茱萸女","kind":"诗"},{"id":"t6-979","title":"五日观妓","kind":"诗"},{"id":"t6-980","title":"骢马","kind":"诗"},{"id":"t6-981","title":"题情人药栏","kind":"诗"},{"id":"t6-982","title":"河上逢落花","kind":"诗"}]},"乔备":{"slug":"乔备","name":"乔备","dynasty":"唐","style":"","life":"","origin":"","seal":"乔","bio":["乔备，亦知之弟。则天时，预修《三教珠英》，终襄阳令。集六卷，今存诗二首。","乔备，亦知之弟。则天时，预修三教珠英，终襄阳令，集六卷，今存诗二首。"],"works":[{"id":"t4-337","title":"出塞","kind":"诗"},{"id":"t4-338","title":"长门怨","kind":"诗"},{"id":"t48-795","title":"秋夜巫山","kind":"诗"},{"id":"t50-150","title":"杂诗（伯三七七一。下同）","kind":"诗"},{"id":"t50-151","title":"秋夜巫山","kind":"诗"}]},"关盼盼":{"slug":"关盼盼","name":"关盼盼","dynasty":"唐","style":"","life":"","origin":"","seal":"关","bio":["关盼盼，徐州妓也。张建封纳之，张殁，独居彭城故燕子楼，历十余年。白居易赠诗讽其死，盼盼得诗，泣曰：“妾非不能死，恐我公有从死之妾，玷清范耳。","”乃和白诗，旬日不食而卒。诗四首。"],"works":[{"id":"t44-91","title":"燕子楼三首 一","kind":"诗"},{"id":"t44-92","title":"燕子楼三首 二","kind":"诗"},{"id":"t44-93","title":"燕子楼三首 三","kind":"诗"},{"id":"t44-94","title":"和白公诗","kind":"诗"},{"id":"t44-95","title":"句","kind":"诗"}]},"刘畋":{"slug":"刘畋","name":"刘畋","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":["刘畋，唐末人。诗一首。"],"works":[{"id":"t40-542","title":"晚泊汉江渡","kind":"诗"},{"id":"t40-543","title":"句","kind":"诗"}]},"周颛":{"slug":"周颛","name":"周颛","dynasty":"唐","style":"","life":"","origin":"","seal":"周","bio":[],"works":[{"id":"t48-336","title":"和座客","kind":"诗"}]},"契此":{"slug":"契此","name":"契此","dynasty":"唐","style":"号长汀子布袋师","life":"","origin":"","seal":"契","bio":["契此，即布袋和尚，在明州奉化县。未详氏族，自称名契此。出语无定，寝卧随处，常以杖荷一布囊，凡供身之具，尽贮囊中。","入鄽肆聚落，见物则乞，时号长汀子布袋师。贞明三年三月卒。诗二十四首。","（《全唐诗》无契此诗。）"],"works":[{"id":"t55-526","title":"歌 一","kind":"诗"},{"id":"t55-527","title":"歌 二","kind":"诗"},{"id":"t55-528","title":"歌 三","kind":"诗"},{"id":"t55-529","title":"歌 四","kind":"诗"},{"id":"t55-530","title":"歌 五","kind":"诗"},{"id":"t55-531","title":"偈","kind":"诗"},{"id":"t55-532","title":"临灭偈（题拟）","kind":"诗"},{"id":"t55-533","title":"偈 一","kind":"诗"},{"id":"t55-534","title":"偈 二","kind":"诗"},{"id":"t55-535","title":"偈 三","kind":"诗"},{"id":"t55-536","title":"偈 四","kind":"诗"},{"id":"t55-537","title":"偈 五","kind":"诗"},{"id":"t55-538","title":"偈 六","kind":"诗"},{"id":"t55-539","title":"偈 七","kind":"诗"},{"id":"t55-540","title":"偈 八","kind":"诗"},{"id":"t55-541","title":"偈 九","kind":"诗"},{"id":"t55-542","title":"偈 十","kind":"诗"},{"id":"t55-543","title":"偈 十一","kind":"诗"},{"id":"t55-544","title":"偈 十二","kind":"诗"},{"id":"t55-545","title":"偈 十三","kind":"诗"},{"id":"t55-546","title":"偈 十四","kind":"诗"},{"id":"t55-547","title":"偈 十五","kind":"诗"},{"id":"t55-548","title":"偈 十六","kind":"诗"}]},"孔平仲":{"slug":"孔平仲","name":"孔平仲","dynasty":"宋","style":"","life":"","origin":"","seal":"孔","bio":[],"works":[{"id":"c59-594","title":"千秋岁·春风湖外","kind":"词"}]},"张𬸦":{"slug":"张𬸦","name":"张𬸦","dynasty":"唐","style":"字文成 · 号青钱学士","life":"","origin":"","seal":"张","bio":["张𬸦，字文成，深州深泽人。儿时梦紫色大鸟，五彩成文，降于家庭，其祖谓之曰：“五色赤文，凤也；紫文，𬸚𬸦也，为凤之佐，吾儿当以文章瑞于明廷。”因以为名字。","调露中，登进士第，八中制科，四参选判，员半千谓人曰：“张子之文，如青钱万简选中，未闻退时。”因号青钱学士。开元中，历司门员外郎，其文远播外夷，撰《朝野佥载》及《龙筋凤髓判百道》。","诗一首。张𬸦，字文成，深州深泽人。儿时梦紫色大鸟，五彩成文，降于家庭，其祖谓之曰：五色赤文，凤也；紫文，𬸚𬸦也，为凤之佐。","吾儿当以文章瑞于明廷，因以为名字。调露中，登进士第，八中制科，四参选判，员半千谓人曰：张子之文，如青钱万简选中，未闻退时，因号青钱学士。开元中，历司门员外郎，其文远播外夷，撰朝野佥载及龙筋凤髓判百道。","诗一首。张𬸦字文成，深州陆泽人。补诗一卷，计五十八首。","（按张𬸦《游仙窟》诗共七十余首，日本河世宁《全唐诗逸》曾选取十九首。今自《古佚小说丛刊》本《游仙窟》中将河世宁氏所未收者，悉数录出，而以彭泽汪辟疆先生《唐人小说》所载《游仙窟》诗校之）。"],"works":[{"id":"t2-923","title":"咏燕","kind":"诗"},{"id":"t48-337","title":"荅或人","kind":"诗"},{"id":"t50-526","title":"赠崔十娘","kind":"诗"},{"id":"t50-527","title":"诗一首","kind":"诗"},{"id":"t50-528","title":"又一首","kind":"诗"},{"id":"t50-529","title":"又一首","kind":"诗"},{"id":"t50-530","title":"又一首","kind":"诗"},{"id":"t50-531","title":"咏𡱈","kind":"诗"},{"id":"t50-532","title":"诗一首","kind":"诗"},{"id":"t