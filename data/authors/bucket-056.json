{"严羽":{"slug":"严羽","name":"严羽","dynasty":"宋","style":"字丹邱 · 号沧浪逋客","life":"","origin":"邵武（今属福建）","seal":"严","bio":["--字丹邱，一字仪卿，号沧浪逋客，邵武 (今属福建) 人。主要活动于理宗时。终生未仕，曾避地江楚，漫游吴越，与戴复古游，属江湖诗人。","论诗推崇盛唐，主“妙悟”，倡“兴趣”说。著有《沧浪诗话》。存词二首。"],"works":[{"id":"c71-889","title":"满江红·日近觚棱","kind":"词"},{"id":"c71-890","title":"沁园春·问讯溪庄","kind":"词"}]},"修睦":{"slug":"修睦","name":"修睦","dynasty":"唐","style":"","life":"","origin":"","seal":"修","bio":["修睦，光化中，为洪州僧正，与贯休、处默、栖隐为诗友。诗二十首。修睦，与贯休同时。","补诗一首。"],"works":[{"id":"t47-169","title":"秋日闲居","kind":"诗"},{"id":"t47-170","title":"宿岳阳开元寺","kind":"诗"},{"id":"t47-171","title":"送边将","kind":"诗"},{"id":"t47-172","title":"雪中送人北游","kind":"诗"},{"id":"t47-173","title":"落叶","kind":"诗"},{"id":"t47-174","title":"落花","kind":"诗"},{"id":"t47-175","title":"题田道者院","kind":"诗"},{"id":"t47-176","title":"东林寺","kind":"诗"},{"id":"t47-177","title":"寄贯休上人","kind":"诗"},{"id":"t47-178","title":"喜僧友到","kind":"诗"},{"id":"t47-179","title":"怀虚中上人","kind":"诗"},{"id":"t47-180","title":"简寂观","kind":"诗"},{"id":"t47-181","title":"睡起作","kind":"诗"},{"id":"t47-182","title":"卖松者","kind":"诗"},{"id":"t47-183","title":"思齐己上人","kind":"诗"},{"id":"t47-184","title":"送玄泰禅师","kind":"诗"},{"id":"t47-185","title":"三生石","kind":"诗"},{"id":"t47-186","title":"题僧梦微房","kind":"诗"},{"id":"t47-187","title":"秋台作","kind":"诗"},{"id":"t47-188","title":"怀故园","kind":"诗"},{"id":"t49-55","title":"僧院泉","kind":"诗"},{"id":"t49-56","title":"题僧院泉","kind":"诗"},{"id":"t49-57","title":"岳上作","kind":"诗"},{"id":"t49-58","title":"望西山","kind":"诗"},{"id":"t49-59","title":"题虎掊泉","kind":"诗"},{"id":"t49-60","title":"松","kind":"诗"},{"id":"t49-61","title":"岳阳对柳","kind":"诗"},{"id":"t51-28","title":"长安柳","kind":"诗"},{"id":"t55-339","title":"落星寺诗","kind":"诗"},{"id":"t55-340","title":"山北东林诗","kind":"诗"},{"id":"t55-341","title":"庐山（题拟）","kind":"诗"}]},"僧儿":{"slug":"僧儿","name":"僧儿","dynasty":"宋","style":"","life":"","origin":"","seal":"僧","bio":[],"works":[{"id":"c64-837","title":"满庭芳·团菊苞金","kind":"词"}]},"吴氏3":{"slug":"吴氏3","name":"吴氏3","dynasty":"宋","style":"","life":"","origin":"","seal":"吴","bio":[],"works":[{"id":"c78-655","title":"失调名·剪新幡儿","kind":"词"},{"id":"c78-656","title":"南乡子·楼台里","kind":"词"},{"id":"c78-657","title":"南乡子·乍卷珠帘新燕入","kind":"词"},{"id":"c78-658","title":"多丽·几声天外归鸿","kind":"词"},{"id":"c78-659","title":"渔家傲·鶗鴂一声初报晓","kind":"词"}]},"周庠":{"slug":"周庠","name":"周庠","dynasty":"唐","style":"","life":"","origin":"","seal":"周","bio":["周庠，唐龙州司仓，后事王建，累官御史中丞、中书侍郎同平章事。王衍嗣位，进司徒。诗一首。"],"works":[{"id":"t42-508","title":"寄禅月大师","kind":"诗"}]},"李密":{"slug":"李密","name":"李密","dynasty":"唐","style":"号魏公","life":"","origin":"","seal":"李","bio":["李密，京兆长安人。隋末，以父宽荫为左亲侍，宇文述劝令学，因谢病读书。尝乘一黄牛，被以蒲韀，挂汉书一帙于角上，一手捉靷，一手翻卷。","越公杨素见而异之，语其子玄感，倾心结纳。及玄感举兵，迎密为谋主，兵败亡命，集众据洛口，自号魏公，移檄州郡。后为王世充所败，归唐，拜光禄卿，封邢国公。","行至桃林，惧诛，将叛，史万宝遣副将盛彦师追斩之。诗一首。"],"works":[{"id":"t41-171","title":"淮阳感怀","kind":"诗"}]},"李揆":{"slug":"李揆","name":"李揆","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["子祭酒、礼部尚书。兴元元年卒，年七十四。（《全唐诗》无李揆诗）"],"works":[{"id":"t50-599","title":"无题","kind":"诗"},{"id":"t50-600","title":"句","kind":"诗"},{"id":"t50-601","title":"又句","kind":"诗"},{"id":"t50-602","title":"又句","kind":"诗"}]},"毛炳":{"slug":"毛炳","name":"毛炳","dynasty":"唐","style":"","life":"","origin":"","seal":"毛","bio":[],"works":[{"id":"t43-705","title":"句","kind":"诗"}]},"熊节":{"slug":"熊节","name":"熊节","dynasty":"宋","style":"","life":"","origin":"","seal":"熊","bio":[],"works":[{"id":"c71-447","title":"朝中措·麒麟早贵挂朝冠","kind":"词"}]},"王镣":{"slug":"王镣","name":"王镣","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王镣，登咸通进士第，累官汝州刺史。干符中，贬韶州司马，终太子宾客。诗一首。"],"works":[{"id":"t33-378","title":"感事","kind":"诗"}]},"章江书生":{"slug":"章江书生","name":"章江书生","dynasty":"唐","style":"","life":"","origin":"","seal":"章","bio":[],"works":[{"id":"t47-798","title":"吟","kind":"诗"}]},"罗炯":{"slug":"罗炯","name":"罗炯","dynasty":"唐","style":"","life":"","origin":"","seal":"罗","bio":[],"works":[{"id":"t42-989","title":"行县至浮查寺","kind":"诗"}]},"辨章":{"slug":"辨章","name":"辨章","dynasty":"唐","style":"","life":"","origin":"","seal":"辨","bio":["辨早，大中间长安千福寺僧，三教首座。诗一首。（《全唐诗》无辨章诗）"],"works":[{"id":"t53-942","title":"依韵奉酬悟真大德（题拟）","kind":"诗"}]},"郑云娘":{"slug":"郑云娘","name":"郑云娘","dynasty":"宋","style":"","life":"","origin":"","seal":"郑","bio":[],"works":[{"id":"c61-81","title":"西江月·一片冰轮皎洁","kind":"词"}]},"闽后陈氏":{"slug":"闽后陈氏","name":"闽后陈氏","dynasty":"唐","style":"","life":"","origin":"","seal":"闽","bio":[],"works":[{"id":"t49-897","title":"乐游曲 一","kind":"诗"},{"id":"t49-898","title":"乐游曲 二","kind":"诗"}]},"陈璀":{"slug":"陈璀","name":"陈璀","dynasty":"唐","style":"","life":"","origin":"","seal":"陈","bio":[],"works":[{"id":"t43-256","title":"风光草际浮","kind":"诗"}]},"静山":{"slug":"静山","name":"静山","dynasty":"宋","style":"","life":"","origin":"","seal":"静","bio":[],"works":[{"id":"c76-588","title":"摸鱼儿·晓峰高","kind":"词"},{"id":"c76-589","title":"水龙吟·片帆天际归舟","kind":"词"}]},"高崇文":{"slug":"高崇文","name":"高崇文","dynasty":"唐","style":"字崇文","life":"","origin":"","seal":"高","bio":["高崇文，字崇文。其先自渤海徙幽州，崇文少籍平卢军。贞元中，随韩全义镇长武城，累官金吾将军。","全义入觐，崇文掌行营节度留务。宪宗朝，拜东川节度使。西蜀平，封南平郡王，同中书门下平章事。","卒，谥曰威武。诗一首。"],"works":[{"id":"t16-798","title":"雪席口占","kind":"诗"},{"id":"t16-799","title":"雪席口占","kind":"诗"}]},"鱼又玄":{"slug":"鱼又玄","name":"鱼又玄","dynasty":"唐","style":"","life":"","origin":"","seal":"鱼","bio":["鱼又玄，道士。诗一首。"],"works":[{"id":"t47-438","title":"题柳公权书度人经后","kind":"诗"}]}}