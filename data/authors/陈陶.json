{"slug":"陈陶","name":"陈陶","dynasty":"唐","style":"字嵩伯","life":"","origin":"","seal":"陈","bio":["陈陶，字嵩伯，岭南一云鄱阳，一云剑浦人。大中时，游学长安，南唐升元中，隐洪州西山，后不知所终。诗十卷，今编为二卷。"],"works":[{"id":"t2-399","title":"杂歌谣辞 步虚引","kind":"诗"},{"id":"t41-617","title":"塞下曲 一","kind":"诗"},{"id":"t41-618","title":"塞下曲 二","kind":"诗"},{"id":"t41-619","title":"胡无人行","kind":"诗"},{"id":"t41-620","title":"悲哉行","kind":"诗"},{"id":"t41-621","title":"涂山怀古","kind":"诗"},{"id":"t41-622","title":"游子吟","kind":"诗"},{"id":"t41-623","title":"怀仙吟二首 一","kind":"诗"},{"id":"t41-624","title":"怀仙吟二首 二","kind":"诗"},{"id":"t41-625","title":"海昌望月","kind":"诗"},{"id":"t41-626","title":"蒲门戍观海作","kind":"诗"},{"id":"t41-627","title":"番禺道中作","kind":"诗"},{"id":"t41-628","title":"赠江西周大夫","kind":"诗"},{"id":"t41-629","title":"旅次铜山途中先寄温州韩使君","kind":"诗"},{"id":"t41-630","title":"种兰","kind":"诗"},{"id":"t41-631","title":"草木言","kind":"诗"},{"id":"t41-632","title":"题僧院紫竹","kind":"诗"},{"id":"t41-633","title":"早发始兴","kind":"诗"},{"id":"t41-634","title":"寄元孚道人","kind":"诗"},{"id":"t41-635","title":"和西江李助副使早登开元寺阁","kind":"诗"},{"id":"t41-636","title":"将归钟陵留赠南海李尚书","kind":"诗"},{"id":"t41-637","title":"宿岛径夷山舍","kind":"诗"},{"id":"t41-638","title":"避世翁","kind":"诗"},{"id":"t41-639","title":"冬夜吟","kind":"诗"},{"id":"t41-640","title":"西川座上听金五云唱歌","kind":"诗"},{"id":"t41-641","title":"飞龙引","kind":"诗"},{"id":"t41-642","title":"谪仙词","kind":"诗"},{"id":"t41-643","title":"步虚引","kind":"诗"},{"id":"t41-644","title":"独摇手","kind":"诗"},{"id":"t41-645","title":"空城雀","kind":"诗"},{"id":"t41-646","title":"鸡鸣曲","kind":"诗"},{"id":"t41-647","title":"小笛弄","kind":"诗"},{"id":"t41-648","title":"将进酒","kind":"诗"},{"id":"t41-649","title":"钱塘对酒曲","kind":"诗"},{"id":"t41-650","title":"巫山高","kind":"诗"},{"id":"t41-651","title":"赠别离","kind":"诗"},{"id":"t41-652","title":"关山月","kind":"诗"},{"id":"t41-653","title":"殿前生桂树","kind":"诗"},{"id":"t41-654","title":"古镜篇","kind":"诗"},{"id":"t41-655","title":"自归山","kind":"诗"},{"id":"t41-656","title":"渡浙江","kind":"诗"},{"id":"t41-657","title":"清源途中旅思","kind":"诗