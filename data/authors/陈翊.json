{"slug":"陈翊","name":"陈翊","dynasty":"唐","style":"字载物","life":"","origin":"","seal":"陈","bio":["陈翊，字载物，闽县人，大历中进士第。贞元中，官户部郎中、知制诰。诗十卷，今存七首。"],"works":[{"id":"t16-546","title":"登城楼作","kind":"诗"},{"id":"t16-547","title":"宴柏台","kind":"诗"},{"id":"t16-548","title":"过马侍中亭","kind":"诗"},{"id":"t16-549","title":"寄邵校书楚苌","kind":"诗"},{"id":"t16-550","title":"龙池春草","kind":"诗"},{"id":"t16-551","title":"郊行示友人","kind":"诗"},{"id":"t16-552","title":"送别萧二","kind":"诗"}]}