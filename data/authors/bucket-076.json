{"仁俭":{"slug":"仁俭","name":"仁俭","dynasty":"唐","style":"","life":"","origin":"","seal":"仁","bio":["仁俭，师禅宗五祖弘忍法嗣安国和尚，住洛阳奉先寺，时谓之腾腾和尚。天册万岁中，诏入殿前，进短歌十九首，令写歌辞传布天下。长寿元年卒。","今存诗一首。（《全唐诗》无仁俭诗，传据《景德传灯录》卷四、《释氏稽古略》卷三）"],"works":[{"id":"t52-503","title":"乐道歌（一作《了元歌》）","kind":"诗"}]},"刘子玄":{"slug":"刘子玄","name":"刘子玄","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"t0-706","title":"郊庙歌辞 仪坤庙乐章 安和","kind":"诗"}]},"刘彤":{"slug":"刘彤","name":"刘彤","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c64-836","title":"临江仙·千里长安名利客","kind":"词"}]},"吴大江":{"slug":"吴大江","name":"吴大江","dynasty":"唐","style":"","life":"","origin":"","seal":"吴","bio":[],"works":[{"id":"t43-113","title":"捣衣","kind":"诗"}]},"周伯阳":{"slug":"周伯阳","name":"周伯阳","dynasty":"宋","style":"","life":"","origin":"","seal":"周","bio":[],"works":[{"id":"c76-507","title":"摸鱼儿·又匆匆","kind":"词"},{"id":"c76-508","title":"春从天上来·浩荡青冥","kind":"词"}]},"师虔":{"slug":"师虔","name":"师虔","dynasty":"唐","style":"","life":"","origin":"","seal":"师","bio":["师虔，初师夹山，住随州土门小青林兰若，世称青林和尚。后师洞山良价，移住洞山，称后洞山禅师。诗一首。","（《全唐诗》无师虔诗）"],"works":[{"id":"t54-63","title":"栽松颂","kind":"诗"}]},"李清臣":{"slug":"李清臣","name":"李清臣","dynasty":"宋","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"c58-702","title":"失调名·杨花落","kind":"词"}]},"李贻孙":{"slug":"李贻孙","name":"李贻孙","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李贻孙，夔州刺史。（《全唐诗》无李贻孙诗） 贻孙，大和初为福建团练副使，会昌五年为夔州刺史，大中三年以左谏议大夫充弘文馆学士判馆事，大中五年为福建观察使。（《全唐诗诗补逸》卷十七据《入蜀记》录夔州刺史李贻诗一句，李贻为李贻孙之误。","今据《郎官石柱题名考》卷十六拟传。）"],"works":[{"id":"t50-843","title":"句","kind":"诗"},{"id":"t53-906","title":"同观察使张公仲方大和元年夏祷雨归至圣泉寺作（题拟）","kind":"诗"}]},"王大烈":{"slug":"王大烈","name":"王大烈","dynasty":"宋","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"c71-743","title":"鹊桥仙·银潢流派","kind":"词"},{"id":"c71-744","title":"蓦山溪·东风吹物","kind":"词"}]},"王起":{"slug":"王起","name":"王起","dynasty":"唐","style":"字举之","life":"","origin":"","seal":"王","bio":["王起，字举之，扬州人，宰相播之弟。贞元十四年进士第，又登制策直言极谏科，累官尚书左仆射，终山南西道节度使。起书无不读，一经目弗忘，三典贡举，皆得人。","集一百二十卷，今存诗六首。"],"works":[{"id":"t24-809","title":"和李校书雨中自秘省见访知早入朝便入集贤不遇诗","kind":"诗"},{"id":"t24-810","title":"贡举人谒先师闻雅乐","kind":"诗"},{"id":"t24-811","title":"浊水求珠","kind":"诗"},{"id":"t24-812","title":"和周侍郎见寄","kind":"诗"},{"id":"t24-813","title":"赠毛仙翁","kind":"诗"},{"id":"t24-814","title":"赋花","kind":"诗"},{"id":"t53-851","title":"答广宣上人","kind":"诗"}]},"程氏长文":{"slug":"程氏长文","name":"程氏长文","dynasty":"唐","style":"","life":"","origin":"","seal":"程","bio":[],"works":[{"id":"t1-151","title":"相和歌辞 雀台怨","kind":"诗"}]},"胡惠斋":{"slug":"胡惠斋","name":"胡惠斋","dynasty":"宋","style":"","life":"","origin":"","seal":"胡","bio":[],"works":[{"id":"c70-739","title":"百字令・念奴娇·小斋幽僻","kind":"词"},{"id":"c70-740","title":"满江红·暝霭黄昏","kind":"词"}]},"范尧佐":{"slug":"范尧佐","name":"范尧佐","dynasty":"唐","style":"","life":"","origin":"","seal":"范","bio":["范尧佐，长庆、元和中道士。诗一首。"],"works":[{"id":"t47-258","title":"一字至七字诗 书","kind":"诗"}]},"蒋捷":{"slug":"蒋捷","name":"蒋捷","dynasty":"宋","style":"字胜欲 · 号竹山","life":"","origin":"阳羡（今江苏宜兴）","seal":"蒋","bio":["字胜欲，号竹山，阳羡 (今江苏宜兴) 人。咸淳十年 (1274) 进士。宋亡不仕。","颇有追昔伤今之词，词语尖新动人。有《竹山词》。"],"works":[{"id":"c72-240","title":"玉漏迟·翠鸳双穗冷","kind":"词"},{"id":"c72-241","title":"高阳台·宛转怜香","kind":"词"},{"id":"c72-242","title":"探春令·玉窗蝇字记春寒","kind":"词"},{"id":"c72-243","title":"秋夜雨·黄云水驿秋笳噎","kind":"词"},{"id":"c72-244","title":"秋夜雨·金衣露湿莺喉噎","kind":"词"},{"id":"c72-245","title":"秋夜雨·髹车转急风如噎","kind":"词"},{"id":"c72-246","title":"秋夜雨·红麟不暖瓶笙噎","kind":"词"},{"id":"c72-247","title":"少年游·梨边风紧雪难晴","kind":"词"},{"id":"c72-248","title":"少年游·枫林红透晚烟青","kind":"词"},{"id":"c72-249","title":"柳梢青·学唱新腔","kind":"词"},{"id":"c72-250","title":"霜天晓角·人影窗纱","kind":"词"},{"id":"c76-68","title":"贺新郎·渺渺啼鸦了","kind":"词"},{"id":"c76-69","title":"贺新郎·雁屿晴岚薄","kind":"词"},{"id":"c76-70","title":"贺新郎·浪涌孤亭起","kind":"词"},{"id":"c76-71","title":"贺新郎·梦冷黄金屋","kind":"词"},{"id":"c76-72","title":"贺新郎·深阁帘垂绣","kind":"词"},{"id":"c76-73","title":"沁园春·老子平生","kind":"词"},{"id":"c76-74","title":"沁园春·结算平生","k