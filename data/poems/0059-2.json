[{"id":"c59-200","title":"行香子·三入承明","rhythmic":"行香子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["三入承明。","四至九卿。","问书生、何辱何荣。","金张七叶，纨绮貂缨。","无汗马事，不献赋，不明经。","成都卜肆，寂莫君平。","郑子真、岩谷躬耕。","寒灰炙手，人重人轻。","除竺乾学，得无念，得无名。"]},{"id":"c59-201","title":"行香子·清夜无尘","rhythmic":"行香子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["清夜无尘。","月色如银。","酒斟时、须满十分。","浮名浮利，虚苦劳神。","叹隙中驹，石中火，梦中身。","虽抱文章，开口谁亲。","且陶陶、乐尽天真。","几时归去，作个闲人。","对一张琴，一壶酒，一溪云。"]},{"id":"c59-202","title":"行香子·昨夜霜风","rhythmic":"行香子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["昨夜霜风。","先入梧桐。","浑无处、回避衰容。","问公何事，不语书空。","但一回醉，一回病，一回慵。","朝来庭下，光阴如箭，似无言、有意伤侬。","都将万事，付与千锺。","任酒花白，眼花乱，烛花红。"]},{"id":"c59-203","title":"行香子·携手江村","rhythmic":"行香子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["携手江村。","梅雪飘裙。","情何限、处处消魂。","故人不见，旧曲重闻。","向望湖楼，孤山寺，涌金门。","寻常行处，题诗千首，绣罗衫、与拂红尘。","别来相忆，知是何人。","有湖中月，江边柳，陇头云。"]},{"id":"c59-204","title":"行香子·一叶轻舟","rhythmic":"行香子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["一叶轻舟。","双桨鸿惊。","水天清、影湛波平。","鱼翻藻鉴，鹭点烟汀。","过沙溪急，霜溪冷，月溪明。","重重似画，曲曲如屏。","算当年、虚老岩陵。","君臣一梦，今古虚名。","但远山长，云山乱，晓山清。"]},{"id":"c59-205","title":"菩萨蛮·绣帘高卷倾城出","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["绣帘高卷倾城出。","灯前潋滟横波溢。","皓齿发清歌。","春愁入翠蛾。","凄音休怨乱。","我已先肠断。","遗响下清虚。","累累一串珠。"]},{"id":"c59-206","title":"菩萨蛮·碧纱微露纤纤玉","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["碧纱微露纤纤玉。","朱唇渐暖参差竹。","越调变新声。","龙吟彻骨清。","夜来残酒醒。","惟觉霜袍冷。","不见敛眉人。","胭脂觅旧痕。"]},{"id":"c59-207","title":"菩萨蛮·秋风湖上萧萧雨","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["秋风湖上萧萧雨。","使君欲去还留住。","今日漫留君。","明朝愁杀人。","佳人千点泪。","洒向长河水。","不用敛双蛾。","路人啼更多。"]},{"id":"c59-208","title":"菩萨蛮·玉童西迓浮丘伯","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["玉童西迓浮丘伯。","洞天冷落秋萧瑟。","不用许飞琼。","瑶台空月明。","清香凝夜宴。","借与韦郎看。","莫便向姑苏。","扁舟下五湖。"]},{"id":"c59-209","title":"菩萨蛮·天怜豪俊腰金晚","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["天怜豪俊腰金晚。","故教月向松江满。","清景为淹留。","从君都占秋。","身闲惟有酒。","拭问清游首。","帝梦已遥思。","匆匆归去时。"]},{"id":"c59-210","title":"菩萨蛮·娟娟缺月西南落","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["娟娟缺月西南落。","相思拨断琵琶索。","枕泪梦魂中。","觉来眉晕重。","华堂堆烛泪。","长笛吹《新水》。","醉客各西东。","应思陈孟公。"]},{"id":"c59-211","title":"菩萨蛮·玉笙不受朱唇暖","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["玉笙不受朱唇暖。","离声凄咽胸填满。","遗痕几千秋。","恩留人不留。","他年京国酒。","泫泪攀枯柳。","莫唱短因缘。","长安远似天。"]},{"id":"c59-212","title":"菩萨蛮·画檐初挂弯弯月","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["画檐初挂弯弯月。","孤光未满先忧缺。","遥认玉帘钩。","天孙梳洗楼。","佳人言语好。","不顾求新巧。","此恨固应知。","愿人无别离。"]},{"id":"c59-213","title":"菩萨蛮·风回仙驭云开扇","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["风回仙驭云开扇。","更阑月堕星河转。","枕上梦魂惊。","晓檐疏雨零。","相逢虽草草。","长共天难老。","终不羡人间。","人间日似年。"]},{"id":"c59-214","title":"菩萨蛮·城隅静女谁人见","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["城隅静女谁人见。","先生日夜歌彤管。","谁识蔡姬贤。","江南顾彦先。","先生那久困。","汤沐须名郡。","惟有谢夫人。","从来见拟伦。"]},{"id":"c59-215","title":"菩萨蛮·买田阳羡吾将老","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["买田阳羡吾将老。","从来只为溪山好。","来往一虚舟。","聊随物外游。","有书仍懒著。","水调歌归去。","筋力不辞诗。","要须风雨时。"]},{"id":"c59-216","title":"菩萨蛮·落花闲院春衫薄","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["落花闲院春衫薄。","薄衫春院闲花落。","迟日恨依依。","依依恨日迟。","梦回莺舌弄。","弄舌莺回梦。","邮便问人羞。","羞人问便邮。"]},{"id":"c59-217","title":"菩萨蛮·火云凝汗挥珠颗","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["火云凝汗挥珠颗。","颗珠挥汗凝云火。","琼暖碧纱轻。","轻纱碧暖琼。","晕腮嫌枕印。","印枕嫌腮晕。","闲照晚妆残。","残妆晚照闲。"]},{"id":"c59-218","title":"菩萨蛮·峤南江浅红梅小","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["峤南江浅红梅小。","小梅红浅江南峤。","窥我向疏篱。","篱疏向我窥。","老人行即到。","到即行人老。","离别惜残枝。","枝残惜别离。"]},{"id":"c59-219","title":"菩萨蛮·翠鬟斜幔云垂耳","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["翠鬟斜幔云垂耳。","耳垂云幔斜鬟翠。","春晚睡昏昏。","昏昏睡晚春。","细花梨雪坠。","坠雪梨花细。","颦浅念谁人。","人谁念浅颦。"]},{"id":"c59-220","title":"菩萨蛮·柳庭风静人眠昼","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["柳庭风静人眠昼。","昼眠人静风庭柳。","香汗薄衫凉。","凉衫薄汗香。","手红冰碗藕。","藕碗冰红手。","郎笑藕丝长。","长丝藕笑郎。"]},{"id":"c59-221","title":"菩萨蛮·井桐双照新妆冷","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["井桐双照新妆冷。","冷妆新照双桐井。","羞对井花愁。","愁花井对羞。","影孤怜夜永。","永夜怜孤影。","楼上不宜秋。","秋宜不上楼。"]},{"id":"c59-222","title":"菩萨蛮·雪花飞暖融香颊","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["雪花飞暖融香颊。","颊香融暖飞花雪。","欺雪任单衣。","衣单任雪欺。","别时梅子结。","结子梅时别。","归不恨开迟。","迟开恨不归。"]},{"id":"c59-223","title":"生查子·三度别君来","rhythmic":"生查子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["三度别君来，此别真迟暮。","白尽老髭须，明日淮南去。","酒罢月随人，泪湿花如雾。","后月逐君还，梦绕湖边路。"]},{"id":"c59-224","title":"翻香令·金炉犹暖麝煤残","rhythmic":"翻香令","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["金炉犹暖麝煤残。","惜香更把宝钗翻。","重闻处，馀薰在，这一番、气味胜从前。","背人偷盖小蓬山。","更将沈水暗同然。","且图得，氤氲久，为情深、嫌怕断头烟。"]},{"id":"c59-225","title":"乌夜啼·莫怪归心甚速","rhythmic":"乌夜啼","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["莫怪归心甚速，西湖自有蛾眉。","若见故人须细说，白发倍当时。","小郑非常强记，二南依旧能诗。","更有鲈鱼堪切脍，儿辈莫教知。"]},{"id":"c59-226","title":"虞美人·定场贺老今何在","rhythmic":"虞美人","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["定场贺老今何在。","几度新声改。","怨声坐使旧声阑。","俗耳只知繁手、不须弹。","断弦拭问谁能晓。","七岁文姬小。","拭教弹作辊雷声。","应有开元遗老、泪纵横。"]},{"id":"c59-227","title":"虞美人·归心正似三春草","rhythmic":"虞美人","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["归心正似三春草。","拭著莱衣小。","橘怀几日向翁开。","怀祖已瞋文度、不归来。","禅心已断人间爱。","只有平交在。","笑论瓜葛一枰同。","看取灵光新赋、有家风。"]},{"id":"c59-228","title":"虞美人·湖山信是东南美","rhythmic":"虞美人","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["湖山信是东南美。","一望弥千里。","使君能得几回来。","便使尊前醉倒、且徘徊。","沙河塘里灯初上。","水调谁家唱。","夜阑风静欲归时。","惟有一江明月、碧琉璃。"]},{"id":"c59-229","title":"虞美人·波声拍枕长淮晓","rhythmic":"虞美人","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["波声拍枕长淮晓。","隙月窥人小。","无情汴水自东流。","只载一船离恨、向西州。","竹溪花浦曾同醉。","酒味多於泪。","谁教风鉴在尘埃。","酝造一场烦恼、送人来。"]},{"id":"c59-230","title":"河满子·见说岷峨凄怆","rhythmic":"河满子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["见说岷峨凄怆，旋闻江汉澄清。","但觉秋来归梦好，西南自有长城。","东府三人最少，西山八国初平。","莫负花溪纵赏，何妨药市微行。","拭问当垆人在否，空教是处闻名。","唱著子渊新曲，应须分外含情。"]},{"id":"c59-231","title":"哨遍·为米折腰","rhythmic":"哨遍","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["为米折腰，因酒弃家，口体交相累。","归去来，谁不遣君归。","觉从前皆非今是。","露未晞。","征夫指予归路，门前笑语喧童稚。","嗟旧菊都荒，新松暗老，吾年今已如此。","但小窗容膝闭柴扉。","策杖看孤云暮鸿飞。","云出无心，鸟倦知还，本非有意。","噫。","归去来兮。","我今忘我兼忘世。","亲戚无浪语，琴书中有真味。","步翠麓崎岖，泛溪窈窕，涓涓暗谷流春水。","观草木欣荣，幽人自感，吾生行且休矣。","念寓形宇内复几时。","不自觉皇皇欲何之。","委吾心、去留谁计。","神仙知在何处，富贵非吾志。","但知临水登山啸咏，自引壶觞自醉。","此生天命更何疑。","且乘流、遇坎还止。"]},{"id":"c59-232","title":"哨遍·睡起画堂","rhythmic":"哨遍","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["睡起画堂，银蒜押帘，珠幕云垂地。","初雨歇，洗出碧罗天，正溶溶养花天气。","一霎暖风回芳草，荣光浮动，掩皱银塘水。","方杏靥匀酥，花鬚吐绣，园林排比红翠。","见乳燕捎蝶过繁枝。","忽一线炉香逐游丝。","昼永人闲，独立斜阳，晚来情味。","便乘兴携将佳丽。","深入芳菲里。","拨胡琴语，轻拢慢捻总伶俐。","看紧约罗裙，急趣檀板，霓裳入破惊鸿起。","颦月临眉，醉霞横脸，歌声悠扬云际。","任满头红雨落花飞。","渐鳷鹊楼西玉蟾低。","尚徘徊、未尽欢意。","君看今古悠悠，浮宦人间世。","这些百岁，光阴几日，三万六千而已。","醉乡路稳不妨行，但人生、要适情耳。"]},{"id":"c59-233","title":"点绛唇·我辈情锺","rhythmic":"点绛唇","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["我辈情锺，古来谁似龙山宴。","而今楚甸。","戏马馀飞观。","顾谓佳人，不觉秋强半。","筝声远。","鬓云吹乱。","愁入参差雁。"]},{"id":"c59-234","title":"点绛唇·不用悲秋","rhythmic":"点绛唇","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["不用悲秋，今年身健还高宴。","江村海甸。","总作空花观。","尚想横汾，兰菊纷相半。","楼船远。","白云飞乱。","空有年年雁。"]},{"id":"c59-235","title":"点绛唇·莫唱阳关","rhythmic":"点绛唇","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["莫唱阳关，风流公子方终宴。","秦山禹甸。","缥缈真奇观。","北望平原，落日山衔半。","孤帆远。","我歌君乱。","一送西飞雁。"]},{"id":"c59-236","title":"点绛唇·醉漾轻舟","rhythmic":"点绛唇","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["醉漾轻舟，信流引到花深处。","尘缘相误。","无计花间住。","烟水茫茫，千里斜阳暮。","山无数。","乱红如雨。","不记来时路。"]},{"id":"c59-237","title":"点绛唇·月转乌啼","rhythmic":"点绛唇","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["月转乌啼，画堂宫徵生离恨。","美人愁闷。","不管罗衣褪。","清泪斑斑，挥断柔肠寸。","嗔人问。","背灯偷搵。","拭尽残妆粉。"]},{"id":"c59-238","title":"人娇·满院桃花","rhythmic":"人娇","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["满院桃花，尽是刘郎未见。","於中更、一枝纤软。","仙家日月，笑人间春晚。","浓睡起，惊飞乱红千片。","密意难传，羞容易变。","平白地、为伊肠断。","问君终日，怎安排心眼。","须信道，司空自来见惯。"]},{"id":"c59-239","title":"人娇·白发苍颜","rhythmic":"人娇","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["白发苍颜，正是维摩境界。","空方丈、散花何碍。","朱唇箸点，更髻鬟生彩。","这些个，千生万生只在。","好事心肠，著人情态。","闲窗下、敛云凝黛。","明朝端午，待学纫兰为佩。","寻一首好诗，要书裙带。"]},{"id":"c59-240","title":"人娇·别驾来时","rhythmic":"人娇","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["别驾来时，灯火荧煌无数。","向青琐、隙中偷覰。","元来便是，共采鸾仙侣。","方见了，管须低声说与。","百子流苏，千枝宝炬。","人间有、洞房烟雾。","春来何事，故抛人别处。","坐望断，楼中远山归路。"]},{"id":"c59-241","title":"诉衷情·钱塘风景古来奇","rhythmic":"诉衷情","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["钱塘风景古来奇。","太守例能诗。","先驱负弩何在，心已誓江西。","花尽后，叶飞时。","雨凄凄。","若为情绪，更问新官，向旧官啼。"]},{"id":"c59-242","title":"诉衷情·海棠珠缀一重重","rhythmic":"诉衷情","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["海棠珠缀一重重。","清晓近帘栊。","胭脂谁与匀淡，偏向脸边浓。","看叶嫩，惜花红。","意无穷。","如花似叶，岁岁年年，共占春风。"]},{"id":"c59-243","title":"诉衷情·小莲初上琵琶弦","rhythmic":"诉衷情","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["小莲初上琵琶弦。","弹破碧云天。","分明绣阁幽恨，都向曲中传。","肤莹玉，鬓梳蝉。","绮窗前。","素蛾今夜，故故随人，似斗婵娟。"]},{"id":"c59-244","title":"更漏子·水涵空","rhythmic":"更漏子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["水涵空，山照市。","西汉二疏乡里。","新白发，旧黄金。","故人恩意深。","海东头，山尽处。","自古客槎来去。","槎有信，赴秋期。","使君行不归。"]},{"id":"c59-245","title":"华清引·平时十月幸兰汤","rhythmic":"华清引","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["平时十月幸兰汤。","玉甃琼梁。","五家车马如水，珠玑满路旁。","翠华一去掩方床。","独留烟树苍苍。","至今清夜月，依前过缭墙。"]},{"id":"c59-246","title":"桃源忆故人·华胥梦断人何处","rhythmic":"桃源忆故人","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["华胥梦断人何处。","听得莺啼红树。","几点蔷薇香雨。","寂寞闲庭户。","暖风不解留花住。","片片著人无数。","楼上望春归去。","芳草迷归路。"]},{"id":"c59-247","title":"醉落魄・一斛珠·醉醒醒醉","rhythmic":"醉落魄・一斛珠","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["醉醒醒醉。","凭君会取这滋味。","浓斟琥珀香浮蚁。","一到愁肠，别有阳春意。","须将幕席为天地。","歌前起舞花前睡。","从他落魄陶陶里。","犹胜醒醒，惹得闲憔悴。"]},{"id":"c59-248","title":"醉落魄・一斛珠·分携如昨","rhythmic":"醉落魄・一斛珠","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["分携如昨。","人生到处萍飘泊。","偶然相聚还离索。","多病多愁，须信从来错。","尊前一笑休辞却。","天涯同是伤沦落。","故山犹负平生约。","西望峨嵋，长羡归飞鹤。"]},{"id":"c59-249","title":"醉落魄・一斛珠·苍颜华发","rhythmic":"醉落魄・一斛珠","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["苍颜华发。","故山归计何时决。","旧交新贵音书绝。","惟有佳人，犹作殷勤别。","离亭欲去歌声咽。","潇潇细雨凉吹颊。","泪珠不用罗巾裛。","弹在罗衣，图得见时说。"]},{"id":"c59-250","title":"醉落魄・一斛珠·轻云微月","rhythmic":"醉落魄・一斛珠","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["轻云微月。","二更酒醒船初发。","孤城回望苍烟合。","公子佳人，不记归时节。","巾偏扇坠藤床滑。","觉来幽梦无人说。","此生飘荡何时歇。","家在西南，长作东南别。"]},{"id":"c59-251","title":"谒金门·秋帷里","rhythmic":"谒金门","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["秋帷里。","长漏伴人无寐。","低玉枕凉轻绣被。","一番秋气味。","晓色又侵窗纸。","窗外鸡声初起。","声断几声还到耳。","已明声未已。"]},{"id":"c59-252","title":"谒金门·秋池阁","rhythmic":"谒金门","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["秋池阁。","风傍晓庭帘幕。","霜叶未衰吹未落。","半惊鸦喜鹊。","自笑浮名情薄。","似与世人疏略。","一片懒心双懒脚。","好教闲处著。"]},{"id":"c59-253","title":"谒金门·今夜雨","rhythmic":"谒金门","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["今夜雨。","断送一年残暑。","坐听潮声来别浦。","明朝何处去。","孤负金尊绿醑。","来岁今宵圆否。","酒醒梦回愁几许。","夜阑还独语。"]},{"id":"c59-254","title":"如梦令·水垢何曾相受","rhythmic":"如梦令","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["水垢何曾相受。","细看两俱无有。","寄语揩背人，尽日劳君挥肘。","轻手。","轻手。","居士本来无垢。"]},{"id":"c59-255","title":"如梦令·自净方能净彼","rhythmic":"如梦令","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["自净方能净彼。","我自汗流呀气。","寄语澡浴人，且共肉身游戏。","但洗。","但洗。","俯为人间一切。"]},{"id":"c59-256","title":"如梦令·为向东坡传语","rhythmic":"如梦令","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["为向东坡传语。","人在玉堂深处。","别后有谁来，雪压小桥无路。","归去。","归去。","江上一犁春雨。"]},{"id":"c59-257","title":"如梦令·手种堂前桃李","rhythmic":"如梦令","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["手种堂前桃李。","无限绿阴青子。","帘外百舌儿，惊起五更春睡。","居士。","居士。","莫望小桥流水。"]},{"id":"c59-258","title":"阳关曲·暮云收尽溢清寒","rhythmic":"阳关曲","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["暮云收尽溢清寒。","银汗无声转玉盘。","此声此夜不长好，明月明年何处看。"]},{"id":"c59-259","title":"阳关曲·受降城下紫髯郎","rhythmic":"阳关曲","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["受降城下紫髯郎。","戏马台南旧战场。","恨君不取契丹首，金甲牙旗归故乡。"]},{"id":"c59-260","title":"阳关曲·济南春好雪初晴","rhythmic":"阳关曲","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["济南春好雪初晴。","才到龙山马足轻。","使君莫忘霅溪女，还作《阳关》肠断声。"]},{"id":"c59-261","title":"减字木兰花·郑庄好客","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["郑庄好客。","容我尊前先堕帻。","落笔生风。","籍籍声名不负公。","高山白早。","莹骨冰肤那解老。","从此南徐。","良夜清风月满湖。"]},{"id":"c59-262","title":"减字木兰花·云鬟倾倒","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["云鬟倾倒。","醉倚阑干风月好。","凭仗相扶。","误入仙家碧玉壶。","连天衰草。","下走湖南西去道。","一舸姑苏。","便逐鸱夷去得无。"]},{"id":"c59-263","title":"减字木兰花·闽溪珍献","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["闽溪珍献。","过海云帆来似箭。","玉座金盘。","不贡奇葩四百年。","轻红酿白。","雅称佳人纤手擘。","骨细肌香。","恰是当年十八娘。"]},{"id":"c59-264","title":"减字木兰花·贤哉令尹","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["贤哉令尹。","三仕已之无喜愠。","我独何人。","犹把虚名玷搢绅。","不如归去。","二顷良田无觅处。","归去来兮。","待有良田是几时。"]},{"id":"c59-265","title":"减字木兰花·玉觞无味","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["玉觞无味。","中有佳人千点泪。","学道忘忧。","一念还成不自由。","如今未见。","归去东园花似霰。","一语相开。","匹似当初本不来。"]},{"id":"c59-266","title":"减字木兰花·春光亭下","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["春光亭下。","流水如今何在也。","岁月如梭。","白首相看拟奈何。","故人重见。","世事年来千万变。","官况阑珊。","惭愧青松守岁寒。"]},{"id":"c59-267","title":"减字木兰花·惟熊佳梦","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["惟熊佳梦。","释氏老君亲抱送。","壮气横秋。","未满三朝已食牛。","犀钱玉果。","利市平分沾四坐。","多谢无功。","此事如何到得侬。"]},{"id":"c59-268","title":"减字木兰花·晓来风细","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["晓来风细。","不会鹊声来报喜。","却羡寒梅。","先觉春风一夜来。","香笺一纸。","写尽回文机上意。","欲卷重开。","读遍千回与万回。"]},{"id":"c59-269","title":"减字木兰花·天台旧路","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["天台旧路。","应恨刘郎来又去。","别酒频倾。","忍听《阳关》第四声。","刘郎未老。","怀恋仙乡重得到。","只恐因循。","不见如今劝酒人。"]},{"id":"c59-270","title":"减字木兰花·双龙对起","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["双龙对起。","白甲苍髯烟雨里。","疏影微香。","下有幽人昼梦长。","湖风清软。","双鹊飞来争噪晚。","翠飐红轻。","时下凌宵百尺英。"]},{"id":"c59-271","title":"减字木兰花·琵琶绝艺","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["琵琶绝艺。","年纪都来十一二。","拨弄么弦。","未解将心指下传。","主人瞋小。","欲向东风先醉倒。","已属君家。","且更从容等待他。"]},{"id":"c59-272","title":"减字木兰花·春牛春杖","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["春牛春杖。","无限春风来海上。","便与春工。","染得桃红似肉红。","春幡春胜。","一阵春风吹酒醒。","不似天涯。","卷起杨花似雪花。"]},{"id":"c59-273","title":"减字木兰花·云容皓白","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["云容皓白。","破晓玉英纷似织。","风力无端。","欲学杨花更耐寒。","相如未老。","梁苑犹能陪俊少。","莫惹闲愁。","且折江梅上小楼。"]},{"id":"c59-274","title":"减字木兰花·玉房金蕊","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["玉房金蕊。","宜在玉人纤手里。","淡月朦胧。","更有微微弄袖风。","温香熟美。","醉慢云鬟垂两耳。","多谢春工。","不是花红是玉红。"]},{"id":"c59-275","title":"减字木兰花·春庭月午","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["春庭月午。","摇荡香醪光欲舞。","步转迥廊。","半落梅花婉娩香。","轻云薄雾。","总是少年行乐处。","不似秋光。","只与离人照断肠。"]},{"id":"c59-276","title":"减字木兰花·天然宅院","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["天然宅院。","赛了千千并万万。","说与贤知。","表德元来是胜之。","今来十四。","海里猴儿奴子是。","要赌休痴。","六双骰儿六点儿。"]},{"id":"c59-277","title":"浣溪沙·风卷珠帘自上钩","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["风卷珠帘自上钩。","萧萧乱叶报新秋。","独携纤手上高楼。","缺月向人舒窈窕，三星当户照绸缪。","香生雾縠见纤柔。"]},{"id":"c59-278","title":"浣溪沙·山下兰芽短浸溪","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["山下兰芽短浸溪。","松间沙路净无泥。","萧萧暮雨子规啼。","谁道人生无再少，门前流水尚能西。","休将白发唱黄鸡。"]},{"id":"c59-279","title":"浣溪沙·西塞山边白鹭飞","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["西塞山边白鹭飞。","散花洲外片帆微。","桃花流水鳜鱼肥。","自庇一身青箬笠，相随到处绿蓑衣。","斜风细雨不须归。"]},{"id":"c59-280","title":"浣溪沙·覆块青青麦未苏","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["覆块青青麦未苏。","江南云叶暗随车。","临皋烟景世间无。","雨脚半收檐断线，雪林初下瓦疏珠。","归来冰颗乱黏须。"]},{"id":"c59-281","title":"浣溪沙·醉梦醺醺晓未苏","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["醉梦醺醺晓未苏。","门前辘辘使君车。","扶头一盏怎生无。","废圃寒蔬挑翠羽，小槽春酒冻真珠。","清香细细嚼梅须。"]},{"id":"c59-282","title":"浣溪沙·雪里餐毡例姓苏","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["雪里餐毡例姓苏。","使君载酒为回车。","天寒酒色转头无。","荐士已闻飞鹗表，报恩应不用蛇珠。","醉中还许揽桓须。"]},{"id":"c59-283","title":"浣溪沙·半夜银山上积苏","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["半夜银山上积苏。","朝来九陌带随车。","涛江烟渚一时无。","空腹有诗衣有结，湿薪如桂米如珠。","冻吟谁伴拈髭须。"]},{"id":"c59-284","title":"浣溪沙·万顷风涛不记苏","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["万顷风涛不记苏。","雪晴江上麦千车。","但令人饱我愁无。","翠袖倚风萦柳絮，绛唇得酒烂樱珠。","尊前呵手镊霜须。"]},{"id":"c59-285","title":"浣溪沙·珠桧丝杉冷欲霜","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["珠桧丝杉冷欲霜。","山城歌舞助凄凉。","且餐山色饮湖光。","共挽朱幡留半日，强揉青蕊作重阳。","不知明日为谁黄。"]},{"id":"c59-286","title":"浣溪沙·霜鬓真堪插拒霜","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["霜鬓真堪插拒霜。","哀弦危柱作《伊凉》。","暂时流转为风光。","未遣清尊空北海，莫因《长笛》赋山阳。","金钗玉腕泻鹅黄。"]},{"id":"c59-287","title":"浣溪沙·傅粉郎君又粉奴","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["傅粉郎君又粉奴。","莫教施粉与施朱。","自然冰玉照香酥。","有客能为《神女赋》，凭君送与雪儿书。","梦魂东去觅桑榆。"]},{"id":"c59-288","title":"浣溪沙·菊暗荷枯一夜霜","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["菊暗荷枯一夜霜。","新苞绿叶照林光。","竹篱茅舍出青黄。","香雾噀人惊半破，清泉流齿怯初尝。","吴姬三日手犹香。"]},{"id":"c59-289","title":"浣溪沙·雪颔霜髯不自惊","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["雪颔霜髯不自惊。","更将翦采发春荣。","羞颜未醉已先赪。","莫唱黄鸡并白发，且呼张丈唤殷兄。","有人归去欲卿卿。"]},{"id":"c59-290","title":"浣溪沙·料峭东风翠幕惊","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["料峭东风翠幕惊。","云何不饮对公荣。","水晶盘莹玉鳞赪。","花影莫孤三夜月，朱颜未称五年兄。","翰林子墨主人卿。"]},{"id":"c59-291","title":"浣溪沙·照日深红暖见鱼","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["照日深红暖见鱼。","连溪绿暗晚藏乌。","黄童白叟聚睢盱。","糜鹿逢人虽未惯，猿揉闻鼓不须呼。","归家说与采桑姑。"]},{"id":"c59-292","title":"浣溪沙·旋抹红妆看使君","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["旋抹红妆看使君。","三三五五棘篱门。","相挨踏破蒨罗裙。","老幼扶携收麦社，乌鸢翔舞赛神村。","道逢醉叟卧黄昏。"]},{"id":"c59-293","title":"浣溪沙·麻叶层层苘叶光","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["麻叶层层苘叶光。","谁家煮蚕一村香。","隔篱娇语络丝娘。","垂白杖藜抬醉眼，捋青捣麨软饥肠。","问言豆叶几时黄。"]},{"id":"c59-294","title":"浣溪沙·簌簌衣巾落枣花","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["簌簌衣巾落枣花。","村南村北响缲车。","牛衣古柳卖黄瓜。","酒困路长惟欲睡，日高人渴漫思茶。","敲门试问野人家。"]},{"id":"c59-295","title":"浣溪沙·软草平莎过雨新","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["软草平莎过雨新。","轻沙走马路无尘。","何时收拾耦耕身。","日暖桑麻光似泼，风来蒿艾气如薰。","使君元是此中人。"]},{"id":"c59-296","title":"浣溪沙·道字娇讹苦未成","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["道字娇讹苦未成。","未应春阁梦多情。","朝来何事绿鬟倾。","彩索身轻长趁燕，红窗睡重不闻莺。","困人天气近清明。"]},{"id":"c59-297","title":"浣溪沙·缥缈危楼紫翠间","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["缥缈危楼紫翠间。","良辰乐事古难全。","感时怀旧独凄然。","璧月琼枝空夜夜，菊花人貌自年年。","不知来岁与谁看。"]},{"id":"c59-298","title":"浣溪沙·桃李溪边驻画轮","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["桃李溪边驻画轮。","鹧鸪声里倒清尊。","夕阳虽好近黄昏。","香在衣裳妆在臂，水连芳草月连云。","几时归去不销魂。"]},{"id":"c59-299","title":"浣溪沙·四面垂杨十里荷","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["四面垂杨十里荷。","问云何处最花多。","画楼南畔夕阳和。","天气乍凉人寂寞，光阴须得酒消磨。","且来花里听笙歌。"]}]