{"严武":{"slug":"严武","name":"严武","dynasty":"唐","style":"字季鹰","life":"","origin":"","seal":"严","bio":["严武，字季鹰，华州人，工部侍郎挺之之子。以荫调太原府参军，累迁殿中侍御史。从明皇入蜀，擢谏议大夫。","至德初，房琯以其名臣子，荐为给事中。历劒南节度使，入为太子宾客兼御史大夫，改吏部侍郎，寻转黄门侍郎，再为成都尹。以破吐蕃功，进检校吏部尚书，封郑国公。","最善杜甫，其复镇劒南，甫往依之。诗六首。"],"works":[{"id":"t13-590","title":"寄题杜拾遗锦江野亭","kind":"诗"},{"id":"t13-591","title":"酬别杜二","kind":"诗"},{"id":"t13-592","title":"题巴州光福寺楠木","kind":"诗"},{"id":"t13-593","title":"班婕妤","kind":"诗"},{"id":"t13-594","title":"巴岭荅杜二见忆","kind":"诗"},{"id":"t13-595","title":"军城早秋","kind":"诗"},{"id":"t51-292","title":"题龙日寺西龛石壁","kind":"诗"}]},"公畿和尚":{"slug":"公畿和尚","name":"公畿和尚","dynasty":"唐","style":"","life":"","origin":"","seal":"公","bio":["公畿和尚，嗣章敬怀晖禅师，在河中府。诗一首。（《全唐诗》无公畿和尚诗）"],"works":[{"id":"t53-683","title":"偈","kind":"诗"}]},"向瓒":{"slug":"向瓒","name":"向瓒","dynasty":"唐","style":"","life":"","origin":"","seal":"向","bio":["瓒初事孟知祥为行军司马，后累加仆射。"],"works":[{"id":"t51-753","title":"乘烟观蒋炼师（蒋甚伟，非妇人之状。）","kind":"诗"}]},"张阁":{"slug":"张阁","name":"张阁","dynasty":"宋","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"c62-311","title":"声声慢·长天霞散","kind":"词"}]},"怀信":{"slug":"怀信","name":"怀信","dynasty":"唐","style":"","life":"","origin":"","seal":"怀","bio":["怀信，元和间僧。诗一首。（《全唐诗》无怀信诗）"],"works":[{"id":"t53-425","title":"题桂林七星岩栖霞洞诗（题拟）","kind":"诗"}]},"曹邺":{"slug":"曹邺","name":"曹邺","dynasty":"唐","style":"字业一作邺之","life":"","origin":"","seal":"曹","bio":["曹邺，字业一作邺之，桂州人。登大中进士第，由天平幕府迁太常博士，历祠部郎中、洋州刺史。诗二卷。"],"works":[{"id":"t32-962","title":"徒相逢","kind":"诗"},{"id":"t32-963","title":"杂诫","kind":"诗"},{"id":"t32-964","title":"捕渔谣","kind":"诗"},{"id":"t32-965","title":"四怨三愁五情诗十二首 其一怨","kind":"诗"},{"id":"t32-966","title":"四怨三愁五情诗十二首 其二怨","kind":"诗"},{"id":"t32-967","title":"四怨三愁五情诗十二首 其三怨","kind":"诗"},{"id":"t32-968","title":"四怨三愁五情诗十二首 其四怨","kind":"诗"},{"id":"t32-969","title":"四怨三愁五情诗十二首 其一愁","kind":"诗"},{"id":"t32-970","title":"四怨三愁五情诗十二首 其二愁","kind":"诗"},{"id":"t32-971","title":"四怨三愁五情诗十二首 其三愁","kind":"诗"},{"id":"t32-972","title":"四怨三愁五情诗十二首 其一情","kind