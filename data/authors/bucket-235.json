{"丁仲远":{"slug":"丁仲远","name":"丁仲远","dynasty":"宋","style":"","life":"","origin":"","seal":"丁","bio":[],"works":[{"id":"c78-585","title":"醉蓬莱·正霜融日暖","kind":"词"}]},"任右元":{"slug":"任右元","name":"任右元","dynasty":"唐","style":"","life":"","origin":"","seal":"任","bio":["右元，江南道士。诗一首。（《全唐诗》无任右元诗）"],"works":[{"id":"t55-479","title":"题常州忠烈王庙","kind":"诗"}]},"信安王祎":{"slug":"信安王祎","name":"信安王祎","dynasty":"唐","style":"","life":"","origin":"","seal":"信","bio":["信安王祎，太宗孙，吴王恪次子，特封嗣江王。开元时，徙封信安。历兵部尚书，朔方节度使，坐事，除衢州刺史。","天宝初，以太子少师致仕。诗一首。"],"works":[{"id":"t0-306","title":"石桥","kind":"诗"}]},"卫叶":{"slug":"卫叶","name":"卫叶","dynasty":"唐","style":"","life":"","origin":"","seal":"卫","bio":[],"works":[{"id":"t43-213","title":"晚投南村","kind":"诗"}]},"吕太一":{"slug":"吕太一","name":"吕太一","dynasty":"唐","style":"","life":"","origin":"","seal":"吕","bio":["吕太一，景云中为洹水令，魏知古表奏之。又尝与中书舍人苗延嗣，考功员嘉靖，侍御史崔训，皆为张嘉贞所荐，时语曰：“令君四俊，苗吕员训。”诗一首。"],"works":[{"id":"t5-222","title":"咏院中藂竹","kind":"诗"}]},"尉迟匡":{"slug":"尉迟匡","name":"尉迟匡","dynasty":"唐","style":"","life":"","origin":"","seal":"尉","bio":[],"works":[{"id":"t43-653","title":"句","kind":"诗"}]},"平曾":{"slug":"平曾","name":"平曾","dynasty":"唐","style":"","life":"","origin":"","seal":"平","bio":["平曾，穆宗时人，唐以府元被绌者九人，曾其一也。长庆初，同贾岛辈贬，谓之举场十恶。曾后谒李固言于蜀，幕中皆名士，曾轻忽无所畏，遂献《雪山赋》。","李览，命推出。不旬日，再献《鯸鱼赋》曰：“此鱼触物而怒，飜身上波，为乌鸢所获，奈鲂鲤笑何？”李览之，遂不至深罪。卒以恃才傲物，没于县曹。","诗三首。"],"works":[{"id":"t27-358","title":"谒李相不遇","kind":"诗"},{"id":"t27-359","title":"留别薛仆射","kind":"诗"},{"id":"t27-360","title":"絷白马诗上薛仆射","kind":"诗"}]},"张宣明":{"slug":"张宣明","name":"张宣明","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张宣明，有胆气，富辞翰，为郭元振判官。诗二首。"],"works":[{"id":"t5-491","title":"山行见孤松成咏","kind":"诗"},{"id":"t5-492","title":"使至三姓咽面","kind":"诗"}]},"张省躬":{"slug":"张省躬","name":"张省躬","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"t47-966","title":"梦张垂赠诗","kind":"诗"}]},"曹组":{"slug":"曹组","name":"曹组","dynasty":"宋","style":"字元宠","life":"","origin":"颍昌（今河南许昌）","seal":"曹","bio":["--字元宠，颍昌 (今河南许昌) 人，一说阳翟 (今河南禹县) 人。六举不第，宣和三年 (1121)，殿试中甲，赐同进士出身。官止门宣赞舍人，睿思殿应制。","有《箕颍集》，不传。词存于《乐府雅词》中，有《曹元宠词》。今辑本《箕颍词》。"],"works":[{"id":"c63-25","title":"蓦山溪·洗妆真态","kind":"词"},{"id":"c63-26","title":"点绛唇·秋劲风高","kind":"词"},{"id":"c63-27","title":"点绛唇·疏柳残蝉","kind":"词"},{"id":"c63-28","title":"点绛唇·密炬高烧","kind":"词"},{"id":"c63-29","title":"如梦令·门外绿阴千顷","kind":"词"},{"id":"c63-30","title":"扑蝴蝶·人生一世","kind":"词"},{"id":"c63-31","title":"忆少年·年时酒伴","kind":"词"},{"id":"c63-32","title":"蓦山溪·草熏风暖","kind":"词"},{"id":"c63-33","title":"相思会・千年调·人无百年人","kind":"词"},{"id":"c63-34","title":"品令·乍寂寞","kind":"词"},{"id":"c63-35","title":"小重山·帘卷东风日射窗","kind":"词"},{"id":"c63-36","title":"小重山·陌上花繁莺乱啼","kind":"词"},{"id":"c63-37","title":"青玉案·碧山锦树明秋霁","kind":"词"},{"id":"c63-38","title":"鹧鸪天·辇路薰风起绿槐","kind":"词"},{"id":"c63-39","title":"渔家傲·水上落红时片片","kind":"词"},{"id":"c63-40","title":"阮郎归·檐头风佩响丁东","kind":"词"},{"id":"c63-41","title":"临江仙·青琐窗深红兽暖","kind":"词"},{"id":"c63-42","title":"鹧鸪天·浅笑轻颦不在多","kind":"词"},{"id":"c63-43","title":"青门饮·山静烟沈","kind":"词"},{"id":"c63-44","title":"青玉案·田园有计归须早","kind":"词"},{"id":"c63-45","title":"好事近·茅舍竹篱边","kind":"词"},{"id":"c63-46","title":"醉花阴·九陌寒轻春尚早","kind":"词"},{"id":"c63-47","title":"点绛唇·小小朱桥","kind":"词"},{"id":"c63-48","title":"点绛唇·云透斜阳","kind":"词"},{"id":"c63-49","title":"点绛唇·沈醉归来","kind":"词"},{"id":"c63-50","title":"水龙吟·晓天谷雨晴时","kind":"词"},{"id":"c63-51","title":"声声慢·重檐飞峻","kind":"词"},{"id":"c63-52","title":"蝶恋花·帘卷真珠深院静","kind":"词"},{"id":"c63-53","title":"浣溪沙·柳絮池台淡淡风","kind":"词"},{"id":"c63-54","title":"点绛唇·霜落吴江","kind":"词"},{"id":"c63-55","title":"点绛唇·一片南云","kind":"词"},{"id":"c63-56","title":"婆罗门引·涨云暮卷","kind":"词"},{"id":"c63-57","title":"失调名·甚时得归京里去","kind":"词"},{"id":"c63-58","title":"卜算子·松竹翠萝寒","kind":"词"},{"id":"c63-59","title":"小重山·深拥熏篝倏已冥","kind":"词"},{"id":"c63-60","title":"脱银袍·济楚风光","kind":"词"},{"id":"c63-61","title":"忆瑶姬·雨细云轻","kind":"词"}]},"杨行敏":{"slug":"杨行敏","name":"杨行敏","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":[],"works":[{"id":"t43-153","title":"失题