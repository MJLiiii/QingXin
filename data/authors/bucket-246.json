{"刘洎":{"slug":"刘洎","name":"刘洎","dynasty":"唐","style":"字思道","life":"","origin":"","seal":"刘","bio":["刘洎，字思道，荆州江陵人。初授都督府长史。贞观中，拜给事中，转治书侍御史。","性疎峻，敢言，累官散骑常侍。太宗尝宴群臣，赐飞白字，或乘酒争取于帝手，洎登御座，引手得之，帝笑曰：“昔闻婕妤辞辇，今见常侍登床。”后迁侍中，被谮赐死。","集十卷，今存诗一首。"],"works":[{"id":"t2-501","title":"安德山池宴集","kind":"诗"},{"id":"t52-69","title":"五言春日侍宴望海应诏","kind":"诗"}]},"吴大有":{"slug":"吴大有","name":"吴大有","dynasty":"宋","style":"字有大 · 号松壑","life":"","origin":"","seal":"吴","bio":["--字有大，号松壑，嵊 (今属浙江) 人。宝祐间，游太学，率诸生上书斥贾似道，不报，退处林泉，与林、仇远、白等诗酒相娱。存词一首。"],"works":[{"id":"c74-365","title":"点绛唇·江上旗亭","kind":"词"}]},"庄若讷":{"slug":"庄若讷","name":"庄若讷","dynasty":"唐","style":"","life":"","origin":"","seal":"庄","bio":["庄若讷，天宝进士。诗一首。"],"works":[{"id":"t10-59","title":"湘灵鼓瑟","kind":"诗"}]},"张复元":{"slug":"张复元","name":"张复元","dynasty":"唐","style":"字复元","life":"","origin":"","seal":"张","bio":["《全唐诗》原列无世次。今按：《全唐诗》刘禹锡七绝有《扬州春夜李端公益、张侍御登、段侍郎平仲、密县李少府畤、秘书张正字复元，同会于水馆，对酒联句，追刻烛击铜钵故事，迟辄举觥以饮之》云云。知复元与禹锡、李益、张登等同时。","又据《徐松登科记考》十三，复元与柳宗元、刘禹锡为同年进士。"],"works":[{"id":"t43-260","title":"风光草际浮","kind":"诗"},{"id":"t51-358","title":"恩赐耆老布帛（《文苑英华》一八○《省试》）","kind":"诗"}]},"杨郁伯":{"slug":"杨郁伯","name":"杨郁伯","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":[],"works":[{"id":"t50-49","title":"句","kind":"诗"}]},"滕甫":{"slug":"滕甫","name":"滕甫","dynasty":"宋","style":"","life":"","origin":"","seal":"滕","bio":[],"works":[{"id":"c58-636","title":"蝶恋花·叶底无风池面静","kind":"词"},{"id":"c58-637","title":"蝶恋花·昼永无人深院静","kind":"词"}]},"申国章":{"slug":"申国章","name":"申国章","dynasty":"宋","style":"","life":"","origin":"","seal":"申","bio":[],"works":[{"id":"c78-617","title":"鹧鸪天·十载分符衣绣衣","kind":"词"}]},"范梦龙":{"slug":"范梦龙","name":"范梦龙","dynasty":"宋","style":"","life":"","origin":"","seal":"范","bio":[],"works":[{"id":"c64-503","title":"临江仙·试问前村深雪里","kind":"词"}]},"赵汝腾":{"slug":"赵汝腾","name":"赵汝腾","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"c73-399","title":"沁园春·人道耻堂","kind":"词"}]},"辛弃疾":{"slug":"辛弃疾","name":"辛弃疾","dynasty":"宋","style":"字幼安 · 号稼轩","life":"","origin":"历城（今属山东济南）","seal":"辛","bio":["(1140－1207) 字幼安，号稼轩，历城 (今属山东济南) 人。二十一岁参加抗金义军，曾任耿京军的掌书记，不久投归南宋。历任江阴签判、建康通判、江西提点刑狱、湖南、湖北转运使、湖南、江西安抚使等职。","四十二岁遭谗落职，退居江西信州，长达二十年之久，其间曾一度起为福建提点刑狱、福建安抚使。六十四岁再起为浙东安抚使、镇江知府，不久罢归。六十八岁病逝。","一生力主抗金北伐，并提出有关方略，均未被采纳。其词热情洋溢、慷慨激昂，富有爱国感情。有《稼轩长短句》以及今人辑本《辛稼轩诗文钞存》。"],"works":[{"id":"c60-847","title":"西江月·一柱中擎远碧","kind":"词"},{"id":"c60-848","title":"西江月·堂上谋臣帷幄","kind":"词"},{"id":"c60-849","title":"生查子·青山招不来","kind":"词"},{"id":"c60-850","title":"生查子·高人千丈崖","kind":"词"},{"id":"c60-851","title":"卜算子·盗跖傥名丘","kind":"词"},{"id":"c60-852","title":"卜算子·一个去学仙","kind":"词"},{"id":"c60-853","title":"卜算子·一饮动连宵","kind":"词"},{"id":"c60-854","title":"卜算子·刚者不坚牢","kind":"词"},{"id":"c60-855","title":"卜算子·一以我为牛","kind":"词"},{"id":"c60-856","title":"卜算子·夜雨醉瓜庐","kind":"词"},{"id":"c60-857","title":"卜算子·珠玉作泥沙","kind":"词"},{"id":"c60-858","title":"卜算子·千古李将军","kind":"词"},{"id":"c60-859","title":"哨遍·池上主人","kind":"词"},{"id":"c60-860","title":"兰陵王·恨之极","kind":"词"},{"id":"c60-861","title":"贺新郎·著厌霓裳素","kind":"词"},{"id":"c60-862","title":"贺新郎·碧海成桑野","kind":"词"},{"id":"c60-863","title":"贺新郎·鸟倦飞还矣","kind":"词"},{"id":"c60-864","title":"贺新郎·肘后俄生柳","kind":"词"},{"id":"c60-865","title":"念奴娇·风狂雨横","kind":"词"},{"id":"c60-866","title":"念奴娇·洞庭春晚","kind":"词"},{"id":"c60-867","title":"念奴娇·是谁调护","kind":"词"},{"id":"c60-868","title":"沁园春·老子平生","kind":"词"},{"id":"c60-869","title":"沁园春·有美人兮","kind":"词"},{"id":"c60-870","title":"沁园春·我试评君","kind":"词"},{"id":"c60-871","title":"沁园春·我醉狂吟","kind":"词"},{"id":"c60-872","title":"水调歌头·落日古城角","kind":"词"},{"id":"c60-873","title":"水调歌头·官事未易了","kind":"词"},{"id":"c60-874","title":"水调歌头·千里渥洼种","kind":"词"},{"id":"c60-875","title":"水调歌头·千古老蟾口","kind":"词"},{"id":"c60-876","title":"水调歌头·文字觑天巧","kind":"词"},{"id":"c60-877","title":"水调歌头·日月如磨蚁","kind":"词"},{"id":"c60-878","title":"水调歌头·说与西湖客","kind":"词"},{"id":"c60-879","title":"水调歌头·万事一杯酒","kind":"词"},{"id":"c60-880","title":"水调歌头·岁岁有黄菊","kind":"词"},{"id":"c60-881","title":"水调歌头·渊明最爱菊","kind":"词"},{"id":"c