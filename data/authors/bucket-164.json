":"诗"}]},"王巨仁":{"slug":"王巨仁","name":"王巨仁","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王巨仁，新罗国隐士。诗一首。"],"works":[{"id":"t41-162","title":"愤怨诗","kind":"诗"}]},"王柏":{"slug":"王柏","name":"王柏","dynasty":"宋","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"c73-41","title":"酹江月・念奴娇·今岁腊前","kind":"词"}]},"郑奕":{"slug":"郑奕","name":"郑奕","dynasty":"唐","style":"","life":"","origin":"","seal":"郑","bio":["奕，孟蜀时人。诗一首。（《全唐诗》无郑奕诗）"],"works":[{"id":"t56-260","title":"歌","kind":"诗"}]},"鄱阳护…":{"slug":"鄱阳护…","name":"鄱阳护…","dynasty":"宋","style":"","life":"","origin":"","seal":"鄱","bio":[],"works":[{"id":"c73-834","title":"望海潮·云收飞脚","kind":"词"}]},"陈蓬":{"slug":"陈蓬","name":"陈蓬","dynasty":"唐","style":"号白水仙","life":"","origin":"","seal":"陈","bio":["蓬，干符间驾舟从海来福州，家于后崎。后号白水仙。（《全唐诗》卷八六二收陈蓬《题松山》诗二句，为仙，无传，今据《淳熙三山志》卷六补传）"],"works":[{"id":"t47-831","title":"句","kind":"诗"},{"id":"t54-124","title":"无题","kind":"诗"},{"id":"t54-125","title":"谶","kind":"诗"},{"id":"t54-126","title":"诗","kind":"诗"}]},"鲍氏君徽":{"slug":"鲍氏君徽","name":"鲍氏君徽","dynasty":"唐","style":"字文姬","life":"","origin":"","seal":"鲍","bio":["鲍君徽，字文姬，鲍征君女。善诗，与尚宫五宋齐名。德宗尝召入宫，与侍臣赓和，赏赉甚厚。","存诗四首。"],"works":[{"id":"t0-311","title":"奉和麟德殿宴百僚应[制]","kind":"诗"},{"id":"t0-312","title":"关山月","kind":"诗"},{"id":"t0-313","title":"惜花吟","kind":"诗"},{"id":"t0-314","title":"东亭茶宴","kind":"诗"}]}}