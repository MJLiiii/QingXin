{"刘宪":{"slug":"刘宪","name":"刘宪","dynasty":"唐","style":"字元度","life":"","origin":"","seal":"刘","bio":["刘宪，字元度，宋州宁陵人。弱冠擢进士第，累迁左台监察御史，贬潾水令，召为凤阁舍人。神龙初，自吏部侍郎出刺渝州，寻入为修文馆学士，历太子詹事卒。","武后时，勅吏部糊名考判求高才，惟宪与王适、司马锽、梁载言入第二等。集三十卷，今编诗一卷。"],"works":[{"id":"t0-971","title":"横吹曲辞 折杨柳","kind":"诗"},{"id":"t3-952","title":"奉和圣制立春日侍宴内殿出剪彩花应制","kind":"诗"},{"id":"t3-953","title":"奉和人日清晖阁宴群臣遇雪应制","kind":"诗"},{"id":"t3-954","title":"奉和七夕宴两仪殿应制","kind":"诗"},{"id":"t3-955","title":"奉和九月九日圣制登慈恩寺浮图应制","kind":"诗"},{"id":"t3-956","title":"闰九月九日幸总持寺登浮图应制","kind":"诗"},{"id":"t3-957","title":"侍宴长宁公主东庄","kind":"诗"},{"id":"t3-958","title":"奉和送金城公主入西蕃应制","kind":"诗"},{"id":"t3-959","title":"奉和圣制登骊山高顶寓目应制","kind":"诗"},{"id":"t3-960","title":"奉和幸白鹿观应制","kind":"诗"},{"id":"t3-961","title":"折杨柳","kind":"诗"},{"id":"t3-962","title":"奉和立春日内出彩花树应制","kind":"诗"},{"id":"t3-963","title":"奉和春日幸望春宫应制","kind":"诗"},{"id":"t3-964","title":"奉和幸安乐公主山庄应制","kind":"诗"},{"id":"t3-965","title":"兴庆池侍宴应制","kind":"诗"},{"id":"t3-966","title":"奉和幸大荐福寺应制","kind":"诗"},{"id":"t3-967","title":"奉和幸三会寺应制","kind":"诗"},{"id":"t3-968","title":"奉和幸长安故城未央宫应制","kind":"诗"},{"id":"t3-969","title":"奉和幸礼部尚书窦希玠宅应制","kind":"诗"},{"id":"t3-970","title":"奉和圣制幸望春宫送朔方大总管张仁亶","kind":"诗"},{"id":"t3-971","title":"奉和幸韦嗣立山庄侍宴应制","kind":"诗"},{"id":"t3-972","title":"人日玩雪应制","kind":"诗"},{"id":"t3-973","title":"上巳日祓禊渭滨应制","kind":"诗"},{"id":"t3-974","title":"苑中遇雪应制","kind":"诗"},{"id":"t3-975","title":"夜宴安乐公主新宅","kind":"诗"},{"id":"t3-976","title":"奉和圣制幸韦嗣立山庄","kind":"诗"},{"id":"t3-977","title":"饯唐永昌","kind":"诗"}]},"吴士矩":{"slug":"吴士矩","name":"吴士矩","dynasty":"唐","style":"字方之","life":"","origin":"","seal":"吴","bio":["士矩，字方之，濮阳鄄城人。溆子。文学早就，喜与豪英游。","历任京兆司录、主客员外郎、郎中。大和七年为江西观察使，开成元年入朝为秘书监，次年因赃贬蔡州别驾，改流端州。（《全唐诗》卷八八七收士矩诗一首，无传，今据《元和姓纂》卷三、《新唐书》卷一五九、《郎官石柱题名考》卷二五、卷二六、《〈白氏长庆集〉人名笺证拟传》）"],"works":[{"id":"t49-29","title":"饮后献时相","kind":"诗"},{"id":"t53-696","title":"无题","kind":"诗"},{"id":"t53-697","title":"独酌谣","kind":"诗"},{"id":"t53-698","title":"赠元微之（题拟）","kind":"诗"}]},"周思钧":{"slug":"周思钧"