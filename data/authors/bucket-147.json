{"任希古":{"slug":"任希古","name":"任希古","dynasty":"唐","style":"字敬臣","life":"","origin":"","seal":"任","bio":["任希古，字敬臣，棣州人。五岁丧母，刻志从学。年十六，刺史崔枢欲举秀才，自以学未广，遯去。","后举孝廉，虞世南器之。永徽初，与郭正一、崔融等同为薛元超所荐，终太子舍人。诗六首。"],"works":[{"id":"t2-894","title":"奉和太子纳妃太平公主出降","kind":"诗"},{"id":"t2-895","title":"和东观群贤七夕临泛昆明池","kind":"诗"},{"id":"t2-896","title":"和左仆射燕公春日端居述怀","kind":"诗"},{"id":"t2-897","title":"和长孙秘监伏日苦热","kind":"诗"},{"id":"t2-898","title":"和李公七夕","kind":"诗"},{"id":"t2-899","title":"和长孙秘监七夕","kind":"诗"}]},"卢溵":{"slug":"卢溵","name":"卢溵","dynasty":"唐","style":"","life":"","origin":"","seal":"卢","bio":["卢溵，浙东处士，诗二首。"],"works":[{"id":"t31-351","title":"金灯","kind":"诗"},{"id":"t31-352","title":"和李尚书命妓饯崔侍御","kind":"诗"}]},"厉翼":{"slug":"厉翼","name":"厉翼","dynasty":"唐","style":"","life":"","origin":"","seal":"厉","bio":[],"works":[{"id":"t51-829","title":"送尹蔓回睦州","kind":"诗"}]},"唐思言":{"slug":"唐思言","name":"唐思言","dynasty":"唐","style":"字子文","life":"","origin":"","seal":"唐","bio":["唐思言，字子文，会昌三年进士第。诗一首。"],"works":[{"id":"t30-611","title":"和主司王起","kind":"诗"}]},"商则":{"slug":"商则","name":"商则","dynasty":"唐","style":"","life":"","origin":"","seal":"商","bio":[],"works":[{"id":"t48-347","title":"嘲廪丘令丞","kind":"诗"}]},"孙觌":{"slug":"孙觌","name":"孙觌","dynasty":"宋","style":"","life":"","origin":"","seal":"孙","bio":[],"works":[{"id":"c63-454","title":"浣溪沙·弱骨轻肌不耐春","kind":"词"}]},"宋务光":{"slug":"宋务光","name":"宋务光","dynasty":"唐","style":"字子昂","life":"","origin":"","seal":"宋","bio":["宋务光，字子昂，一名烈，汾州西河人。举进士及第，调洛阳尉，迁右衞骑曹参军。神龙初，上封事直谏，不省，俄以监察御史巡察河南道，考最，进殿中右台御史。","诗一首。"],"works":[{"id":"t5-227","title":"海上作","kind":"诗"},{"id":"t52-587","title":"七夕感逝","kind":"诗"},{"id":"t52-588","title":"七夕","kind":"诗"}]},"宋齐丘":{"slug":"宋齐丘","name":"宋齐丘","dynasty":"唐","style":"字子嵩","life":"","origin":"世为庐陵","seal":"宋","bio":["宋齐丘，字子嵩。世为庐陵人，父诚，为洪州副使，遂家焉。吴时，累官右仆射、平章事。","李昪代吴，以齐丘为丞相、同平章事，寻出为镇南军节度。李璟嗣位，召为中书令，显德末，放归，缢死。集六卷，今存诗三首。"],"works":[{"id":"t41-387","title":"陪游凤皇台献诗","kind":"诗"},{"id":"t41-388","title":"赠仰山慧度禅师","kind":"诗"},{"id":"t41-389","title":