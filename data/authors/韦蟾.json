{"slug":"韦蟾","name":"韦蟾","dynasty":"唐","style":"字隐珪","life":"","origin":"","seal":"韦","bio":["韦蟾，字隐珪，下杜人。大中登进士第，初为徐商掌书记。咸通末，终尚书左丞。","诗十首。"],"works":[{"id":"t31-414","title":"和柯古穷居苦日喜雨","kind":"诗"},{"id":"t31-415","title":"岳麓道林寺","kind":"诗"},{"id":"t31-416","title":"上元三首 一","kind":"诗"},{"id":"t31-417","title":"上元三首 二","kind":"诗"},{"id":"t31-418","title":"上元三首 三","kind":"诗"},{"id":"t31-419","title":"梅","kind":"诗"},{"id":"t31-420","title":"送卢潘尚书之灵武","kind":"诗"},{"id":"t31-421","title":"题僧壁","kind":"诗"},{"id":"t31-422","title":"赠商山僧","kind":"诗"},{"id":"t31-423","title":"长乐驿谑李汤给事题名","kind":"诗"},{"id":"t31-424","title":"句","kind":"诗"},{"id":"t48-267","title":"嘲李玚题名","kind":"诗"}]}