{"京兆韦氏子":{"slug":"京兆韦氏子","name":"京兆韦氏子","dynasty":"唐","style":"","life":"","origin":"","seal":"京","bio":[],"works":[{"id":"t43-356","title":"悼妓诗","kind":"诗"}]},"何仙姑":{"slug":"何仙姑","name":"何仙姑","dynasty":"唐","style":"","life":"","origin":"","seal":"何","bio":[],"works":[{"id":"t51-932","title":"无题","kind":"诗"},{"id":"t51-933","title":"凤台云母（所居春冈，地产云母。尝梦老人授服饵丹法，渐觉身轻健。有诗曰〖见下〗。后果有凤来集其上，遂改名凤台云。）","kind":"诗"},{"id":"t51-934","title":"将游罗浮留诗（江北与罗浮山相望，尝曰：「将游罗浮。」父母怪之，私为择配。结缡之夕，忽不知所之。留诗屏砚间曰〖见下〗。明早起视家侧井径，有遗履而已。）","kind":"诗"},{"id":"t51-935","title":"有道士自罗浮之增城口占三绝寄家（顷之，有道士来自罗浮，见姑在麻姑石上，顾谓道士曰：「而之增城，属吾亲收拾井上履，口占三绝寄其家曰〖见下〗。」其后增城李令世英与谢草堂者表其事。李令为天台黄岩人，始悟仙语无一不有验云。） 一","kind":"诗"},{"id":"t51-936","title":"有道士自罗浮之增城口占三绝寄家（顷之，有道士来自罗浮，见姑在麻姑石上，顾谓道士曰：「而之增城，属吾亲收拾井上履，口占三绝寄其家曰〖见下〗。」其后增城李令世英与谢草堂者表其事。李令为天台黄岩人，始悟仙语无一不有验云。） 二","kind":"诗"},{"id":"t51-937","title":"有道士自罗浮之增城口占三绝寄家（顷之，有道士来自罗浮，见姑在麻姑石上，顾谓道士曰：「而之增城，属吾亲收拾井上履，口占三绝寄其家曰〖见下〗。」其后增城李令世英与谢草堂者表其事。李令为天台黄岩人，始悟仙语无一不有验云。） 三","kind":"诗"},{"id":"t51-938","title":"柔珠庵东壁题诗（句）（仙姑又尝于柔珠庵壁题一绝，字比晋人差，清婉少骨。壁后半毁，惟余「百尺」十三字，其下必「风」字也。后二句无人能续之者。）","kind":"诗"},{"id":"c61-94","title":"八声甘州·千门万户","kind":"词"}]},"南粤":{"slug":"南粤","name":"南粤","dynasty":"唐","style":"","life":"","origin":"","seal":"南","bio":[],"works":[{"id":"t56-591","title":"题宝相寺","kind":"诗"}]},"天然":{"slug":"天然","name":"天然","dynasty":"唐","style":"","life":"","origin":"","seal":"天","bio":["天然，俗姓居里皆不详。少亲儒墨，与庞蕴善。后皈信佛法，师马祖、石头。","初住天台华顶，元和初上龙门香山，与伏牛禅师为莫逆交。元和十五年入南阳丹霞山结庵，世称丹霞和尚。长庆中卒，年八十六。","诗五首。（《全唐诗》无天然诗。传据《祖堂集》及《宋高僧传》卷十一。","其卒年，前书谓在长庆三年，后书作四年，未详孰是。）"],"works":[{"id":"t53-466","title":"孤寂吟","kind":"诗"},{"id":"t53-467","title":"玩珠吟","kind":"诗"},{"id":"t53-468","title":"又颂","kind":"诗"},{"id":"t53-469","title":"骊龙珠吟","kind":"诗"},{"id":"t53-470","title":"弄珠吟（《景德传灯录》卷三十作《玩珠吟二首》之一）","kind":"诗"}]},"张窈窕":{"slug":"张窈窕","name":"张窈窕","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张窈窕，寓居于蜀，当时诗人雅相推重。诗六首。"],"works":[{"id":"t44-116","title":"寄故人","kind":"诗"},{"id":"t44-117","title":"上成都在事","kind":"诗"},{"id":"t44-118","title":"春思二首 一","kind":"诗"},{"id":"t44-119","title":"春思二首 二","kind":"诗"},{"id":"t44-120","title":"西江行","kind":"诗"},{"id":"t44-121","title":"赠所思","kind":"诗"},{"id":"t44-122","title":"句","kind":"诗"}]},"张籍":{"slug":"张籍","name":"张籍","dynasty":"唐","style":"字文昌","life":"","origin":"","seal":"张","bio":["张籍，字文昌，苏州吴人，或曰和州乌江人。贞元十五年登进士第，授太常寺太祝。久之，迁秘书郎。","韩愈荐为国子博士，历水部员外郎、主客郎中。当时有名士皆与游，而愈贤重之。籍为诗长于乐府，多警句，仕终国子司业。","诗集七卷，今编为五卷。"],"works":[{"id":"t0-851","title":"鼓吹曲辞 朱鹭","kind":"诗"},{"id":"t0-914","title":"横吹曲辞 陇头","kind":"诗"},{"id":"t0-953","title":"横吹曲辞 出塞","kind":"诗"},{"id":"t0-984","title":"横吹曲辞 望行人","kind":"诗"},{"id":"t0-995","title":"横吹曲辞 关山月","kind":"诗"},{"id":"t1-49","title":"相和歌辞 江南曲","kind":"诗"},{"id":"t1-109","title":"相和歌辞 楚妃叹","kind":"诗"},{"id":"t1-110","title":"相和歌辞 楚妃怨","kind":"诗"},{"id":"t1-124","title":"相和歌辞 短歌行","kind":"诗"},{"id":"t1-158","title":"相和歌辞 猛虎行","kind":"诗"},{"id":"t1-224","title":"相和歌辞  董逃行","kind":"诗"},{"id":"t1-274","title":"相和歌辞 白头吟","kind":"诗"},{"id":"t1-416","title":"相和歌辞 乌栖曲","kind":"诗"},{"id":"t1-423","title":"相和歌辞 贾客乐","kind":"诗"},{"id":"t1-454","title":"相和歌辞 采莲曲","kind":"诗"},{"id":"t1-495","title":"舞曲歌辞 白纻歌","kind":"诗"},{"id":"t1-541","title":"琴曲歌辞 别鹤","kind":"诗"},{"id":"t1-587","title":"琴曲歌辞 乌夜啼引","kind":"诗"},{"id":"t1-592","title":"琴曲歌辞 宛转行","kind":"诗"},{"id":"t1-622","title":"杂曲歌辞 伤歌行","kind":"诗"},{"id":"t1-636","title":"杂曲歌辞 妾薄命","kind":"诗"},{"id":"t1-658","title":"杂曲歌辞 春日行","kind":"诗"},{"id":"t1-681","title":"杂曲歌辞 少年行","kind":"诗"},{"id":"t1-753","title":"杂曲歌辞 车遥遥","kind":"诗"},{"id":"t1-789","title":"杂曲歌辞 行路难","kind":"诗"},{"id":"t1-834","title":"杂曲歌辞 远别离","kind":"诗"},{"id":"t1-842","title":"杂曲歌辞 别离曲","kind":"诗"},{"id":"t1-885","title":"杂曲歌辞 筑城曲","kind":"诗"},{"id":"t1-904","title":"杂曲歌辞 秋夜长","kind":"诗"},{"id":"t1-915","title":"杂曲歌辞 春江曲","kind":"诗"},{"id":"t1-989","title":"杂曲歌辞 凉州词 一","kind":"诗"},{"id":"t1-990","title":"杂曲歌辞 凉州词 二","kind":"诗"},{"id":"t1-991","title":"杂曲歌辞 凉州词 三","kind":"诗"},{"id":"t2-338","title":"杂歌谣辞 吴楚歌","kind":"