nd":"词"},{"id":"c65-821","title":"眼儿媚·铃阁寻盟未肯寒","kind":"词"},{"id":"c65-822","title":"武陵春·门巷乌衣应好在","kind":"词"}]},"冯涓":{"slug":"冯涓","name":"冯涓","dynasty":"唐","style":"字信之","life":"","origin":"","seal":"冯","bio":["冯涓，字信之，东阳人，或曰信都人。举进士，登大中四年宏词科，为京兆府参军，寻隐商山。昭宗起为祠部郎中，擢眉州刺史。","田陈拒命，不令之任，涓于成都墨池灌园自给。王建据蜀，以为翰林学士，终御史大夫。集十三卷，今存诗二首。"],"works":[{"id":"t42-512","title":"蜀犸引 一","kind":"诗"},{"id":"t42-513","title":"蜀犸引 二","kind":"诗"},{"id":"t42-514","title":"句","kind":"诗"},{"id":"t48-308","title":"自嘲绝句","kind":"诗"},{"id":"t51-709","title":"生日歌（略）（太祖为蜀王时，方搆大业，莫不赋舆〖一作「役」〗增益，转运烦苛，百姓困穷，无敢言者。因太祖生辰，涓独献一歌，先纪王功，后陈生聚〖一作「众困」〗。太祖曰：「如卿忠谠，寡人王业何忧。」遂赐黄金十斤，以旌礼讽谏，于是徭役稍减矣。议者以君臣道合，黎庶泰来，苟非明王，何以采纳。《生日歌》略云：）","kind":"诗"},{"id":"t51-710","title":"崄竿歌","kind":"诗"},{"id":"t51-711","title":"酒令（涓与王司空锴等小酌，巡故字令。锴举一字三呼，两物相似。锴令曰：）","kind":"诗"},{"id":"t51-712","title":"酒令（涓与王司空锴等小酌，巡故字令。锴举一字三呼，两物相似。锴令曰：） 一","kind":"诗"},{"id":"t51-713","title":"酒令（涓与王司空锴等小酌，巡故字令。锴举一字三呼，两物相似。锴令曰：） 二","kind":"诗"}]},"刘子翼":{"slug":"刘子翼","name":"刘子翼","dynasty":"唐","style":"字小心","life":"","origin":"","seal":"刘","bio":["子翼，字小心，常州晋陵人。隋大业初，历秘书监。唐贞观间拜吴王府功曹，迁著作郎、弘文馆直学士，预修《晋书》。","永徽初卒。有集二十卷。诗二首。","（《全唐诗》无刘子翼诗，传据《旧唐书》卷八七本传）"],"works":[{"id":"t52-102","title":"五言奉和咏棋应诏 一","kind":"诗"},{"id":"t52-103","title":"五言奉和咏棋应诏 二","kind":"诗"}]},"卫时敏":{"slug":"卫时敏","name":"卫时敏","dynasty":"宋","style":"","life":"","origin":"","seal":"卫","bio":[],"works":[{"id":"c78-391","title":"水调歌头·骑鲸紫霞客","kind":"词"},{"id":"c78-392","title":"念奴娇·春风桃李","kind":"词"}]},"双渐":{"slug":"双渐","name":"双渐","dynasty":"宋","style":"","life":"","origin":"","seal":"双","bio":[],"works":[{"id":"c61-67","title":"人月圆·碧纱低映秦娥面","kind":"词"}]},"吉播":{"slug":"吉播","name":"吉播","dynasty":"唐","style":"","life":"","origin":"","seal":"吉","bio":["吉播，建中贞元间人。为范阳县丞吉逾姪。诗一首。","（《全唐诗》无吉播诗）"],"works":[{"id":"t50-634","title":"题云居上寺","kind":"诗"}]},"姚赞":{"slug":"姚赞","name":"姚赞","dynasty":"唐","style":"","life":"","origin":"","seal":"姚","bio":["赞，一名质，吴兴人，工八分书。诗一首。（《全唐诗》无姚赞诗，传据《书史会要》卷五）"],"works":[{"id":"t56-340","title":"无题","kind":"诗"},{"id":"t56-341","title":"八分书歌","kind":"诗"}]},"安守范":{"slug":"安守范","name":"安守范","dynasty":"唐","style":"","life":"","origin":"","seal":"安","bio":[],"works":[{"id":"t43-616","title":"天台禅院联句","kind":"诗"}]},"张峤":{"slug":"张峤","name":"张峤","dynasty":"唐","style":"字平云","life":"","origin":"","seal":"张","bio":["峤，字平云，蜀人。学释氏法，人谓之居士。著有《参玄录》、《玄珠集》、歌行句偈百余篇。"],"works":[{"id":"t51-757","title":"偈诗","kind":"诗"},{"id":"t51-758","title":"句 一（有勾居士问：「不拘生死者，愿师直指。」峤答云：）","kind":"诗"},{"id":"t51-759","title":"句 二（又问：「百亿往来非指的，光明终不碍山河时如何？」峤答云：）","kind":"诗"}]},"李恒":{"slug":"李恒","name":"李恒","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李恒，进士第，官安阳令。诗一首。"],"works":[{"id":"t5-318","title":"奉和九月九日登慈恩寺浮图应制","kind":"诗"}]},"洛中举子":{"slug":"洛中举子","name":"洛中举子","dynasty":"唐","style":"","life":"","origin":"","seal":"洛","bio":[],"works":[{"id":"t43-379","title":"赠妓茂英","kind":"诗"},{"id":"t43-380","title":"又赠妓茂英","kind":"诗"}]},"玄览":{"slug":"玄览","name":"玄览","dynasty":"唐","style":"","life":"","origin":"","seal":"玄","bio":[],"works":[{"id":"t51-300","title":"题竹","kind":"诗"},{"id":"t52-996","title":"投龙洞","kind":"诗"}]},"王克勤":{"slug":"王克勤","name":"王克勤","dynasty":"宋","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"c70-757","title":"朝中措·银河无际渺澄空","kind":"词"}]},"石仲元":{"slug":"石仲元","name":"石仲元","dynasty":"唐","style":"字庆宗","life":"","origin":"","seal":"石","bio":["仲元，字庆宗。五代末，桂林七星山道士。以能诗名。","有《桂华集》。"],"works":[{"id":"t51-782","title":"阳朔道中","kind":"诗"}]},"邵拙":{"slug":"邵拙","name":"邵拙","dynasty":"唐","style":"","life":"","origin":"","seal":"邵","bio":[],"works":[{"id":"t43-704","title":"句","kind":"诗"}]},"郭向":{"slug":"郭向","name":"郭向","dynasty":"唐","style":"","life":"","origin":"","seal":"郭","bio":["郭向，太子尉。诗一首。"],"works":[{"id":"t10-10","title":"途中口号","kind":"诗"}]},"陈季卿":{"slug":"陈季卿","name":"陈季卿","dynasty":"唐","style":"","life":"","origin":"","seal":"陈","bio":["陈季卿，江南人，辞家十年，举进士无成，羁栖辇下。常访青龙寺僧不值，时有终南山翁亦伺僧归，揖季卿同坐。适东壁有寰瀛图，季卿乃寻江南路，因长叹曰：“安得自渭泛于河，游于洛，渡淮济江，而达于家，亦不悔无成而归。","”翁笑曰：“此不难致。”乃命僧童折一竹叶作舟，置图中渭水上，曰：“公但注目此舟，则如公所愿耳，然至家慎勿久留。”季卿熟视之，觉渭水生波，叶舟渐大，席帆既张，恍若登舟。","始自渭及河，维舟至禅窟兰若，题诗于南楹。明日，次潼关，登崖，题句于关门东普通院门。凡所经历，一如前愿，旬余至家，妻子兄弟拜迎于门侧，题《江亭晚望诗》于书斋。","此夕谓妻曰：“吾试期近，不可久留，即当进櫂。”乃吟一章，别其妻，又别诸兄弟，一更后，复登舟而逝，家人恸哭，谓其死矣。复遵旧路，至于渭滨，寺宇宛然，见山翁拥褐而坐，季卿谢曰：“归则归矣，得非梦乎。","”翁曰：“不久当知。”各别去。后月余，妻子来访，始知果归作诗，非梦也。"],"works":[{"id":"t48-188","title":"题禅窟兰若","kind":"诗"},{"id":"t48-189","title":"题潼关普通院门","kind":"诗"},{"id":"t48-190","title":"江亭晚望题书斋","kind":"诗"},{"id":"t48-191","title":"别妻","kind":"诗"},{"id":"t48-192","title":"别兄弟","kind":"诗"}]},"青霞子":{"slug":"青霞子","name":"青霞子","dynasty":"唐","style":"","life":"","origin":"","seal":"青","bio":["青霞子，贞元间罗浮山隐士。诗七首。（《全唐诗》无青霞子诗）"],"works":[{"id":"t53-120","title":"无题","kind":"诗"},{"id":"t53-121","title":"龙虎元旨歌 一","kind":"诗"},{"id":"t53-122","title":"龙虎元旨歌 二","kind":"诗"},{"id":"t53-123","title":"龙虎元旨歌 三","kind":"诗"},{"id":"t53-124","title":"龙虎元旨歌 四","kind":"诗"},{"id":"t53-125","title":"龙虎元旨歌 五","kind":"诗"},{"id":"t53-126","title":"龙虎元旨歌 六","kind":"诗"},{"id":"t53-127","title":"龙虎元旨歌 七","kind":"诗"}]},"黄谈":{"slug":"黄谈","name":"黄谈","dynasty":"宋","style":"","life":"","origin":"","seal":"黄","bio":[],"works":[{"id":"c60-7","title":"念奴娇·午风清暑","kind":"词"}]}}