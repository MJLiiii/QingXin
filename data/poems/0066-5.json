[{"id":"c66-500","title":"烛影摇红·双阙中天","rhythmic":"烛影摇红","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["双阙中天，凤楼十二春寒浅。","去年元夜奉宸游，曾侍瑶池宴。","玉殿珠帘尽卷。","拥群仙、蓬壶阆苑。","五云深处，万烛光中，揭天丝管。","驰隙流年，恍如一瞬星霜换。","今宵谁念泣孤臣，回首长安远。","可是尘缘未断。","谩惆怅、华胥梦短。","满怀幽恨，数点寒灯，几声归雁。"]},{"id":"c66-501","title":"浣溪沙·筑室峥嵘占宝峰","rhythmic":"浣溪沙","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["筑室峥嵘占宝峰。","退朝燕坐万缘空，出尘高志抗冥鸿。","何日嘉招陪一笑，看君豪饮釂千锺。","试凭鄙句作先容。"]},{"id":"c66-502","title":"霜天晓角·晓风摇幕","rhythmic":"霜天晓角","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["晓风摇幕。","敧枕闻残角。","霜月可窗寒影，金猊冷、翠衾薄。","旧恨无处著。","新愁还又作。","夜夜单于声里，灯花共、泪珠落。"]},{"id":"c66-503","title":"点绛唇·何处春来","rhythmic":"点绛唇","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["何处春来，惠风初自东郊至。","柳条花蕊。","迤逦争明媚。","造化难穷，谁晓幽微理。","都来是。","自然天地。","一点冲和气。"]},{"id":"c66-504","title":"点绛唇·昨夜东风","rhythmic":"点绛唇","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["昨夜东风，又还吹遍闲花草。","翠轻红小。","触处惊春早。","草舍茅□，□□□□□。","谁□□。","□□丹灶。","别有阳和□。"]},{"id":"c66-505","title":"点绛唇·阳气初生","rhythmic":"点绛唇","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["阳气初生，万花潜动根荄暖。","暗藏芳艳。","未许东君见。","恰似温温，铅鼎丹初转。","功犹浅。","九回烹炼。","日月光华满。"]},{"id":"c66-506","title":"点绛唇·暖日迟迟","rhythmic":"点绛唇","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["暖日迟迟，乱莺声在垂杨里。","昼眠惊起。","花影间铺地。","试问荣名，何似花前醉。","陶陶地。","任他门外。","车驾喧朝市。"]},{"id":"c66-507","title":"点绛唇·花满名园","rhythmic":"点绛唇","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["花满名园，万红千翠交相映。","画阑幽径。","行乐迷芳景。","惟有幽人，不与浮华竞。","便幽静。","兴来独饮。","花下风吹醒。"]},{"id":"c66-508","title":"点绛唇·春入山家","rhythmic":"点绛唇","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["春入山家，杖藜独步登严岫。","野花争秀。","弄蕊香盈袖。","对景开怀，莫遣双眉皱。","春难久。","乱红飞后。","留得韶光否。"]},{"id":"c66-509","title":"点绛唇·气体冲融","rhythmic":"点绛唇","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["气体冲融，四时长在阳春里。","玉田琼蕊。","养就灵苗异。","堪笑□□，□□□□□。","□□□。","□□流水。","半落苍□□。"]},{"id":"c66-510","title":"点绛唇·乐事难并","rhythmic":"点绛唇","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["乐事难并，少年常恨春宵短。","万花丛畔。","只恐金杯浅。","方喜春来，又叹韶华晚。","频相劝。","且闻强健。","莫厌花经眼。"]},{"id":"c66-511","title":"点绛唇·一瞬光阴","rhythmic":"点绛唇","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["一瞬光阴，世人常被芳菲恼。","玉壶频倒。","惟恨春归早。","何似逍遥，物外寻三岛。","春长好。","瑞芝瑶草。","春又何曾老。"]},{"id":"c66-512","title":"点绛唇·浮世如何","rhythmic":"点绛唇","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["浮世如何，问花何事花无语。","夜来风雨。","已送韶华暮。","念此堪惊，得失休思虑。","从今去。","醉乡深处。","莫管流年度。"]},{"id":"c66-513","title":"阮郎归·亭亭槐柳午阴圆","rhythmic":"阮郎归","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["亭亭槐柳午阴圆。","薰风拂舜弦。","一轮红日贴中天。","乾坤如火然。","观上象，想丹田。","阳精色正鲜。","□从炼得体纯全。","朱颜无岁年。"]},{"id":"c66-514","title":"阮郎归·欲如臭腐化神奇","rhythmic":"阮郎归","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["欲如臭腐化神奇。","当观蝉蜕时。","脱然飞上绿槐枝。","炎炎昼景□。","□□□，□如斯。","□□□□迷。","灵躯一旦脱□□。","□□□□归。"]},{"id":"c66-515","title":"阮郎归·深亭邃馆锁清风","rhythmic":"阮郎归","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["深亭邃馆锁清风。","榴花芳艳浓。","阳光染就欲烧空。","谁能窥化工。","观物外，喻身中。","灵砂别有功。","若将一粒比花容。","金丹色又红。"]},{"id":"c66-516","title":"阮郎归·炎天何处可登临","rhythmic":"阮郎归","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["炎天何处可登临。","须於物外寻。","松风涧水杂清音。","空山如弄琴。","宜散发，称披襟。","都无烦暑侵。","莫将城市比山林。","山林兴味深。"]},{"id":"c66-517","title":"阮郎归·豪家大厦敞千楹","rhythmic":"阮郎归","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["豪家大厦敞千楹。","风摇玉柄轻。","金盆弄水复敲冰。","热从何处生。","低草舍，小茅亭。","如何安此身。","元来一念静无尘。","萧然心自清。"]},{"id":"c66-518","title":"阮郎归·金乌玉兔最无情","rhythmic":"阮郎归","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["金乌玉兔最无情。","驱驰不暂停。","春光才去又朱明。","年华只暗惊。","须省悟，莫劳神。","朱颜不再新。","灭除妄想养天真。","管无寒暑侵。"]},{"id":"c66-519","title":"阮郎归·动时思静暑思寒","rhythmic":"阮郎归","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["动时思静暑思寒。","尘劳扰扰间。","翻云复雨百千般。","几时心地闲。","□□□，□□难。","将□□□然。","自然寒暑不相□。","□□□地仙。"]},{"id":"c66-520","title":"阮郎归·谁言无处避炎光","rhythmic":"阮郎归","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["谁言无处避炎光。","山中有草堂。","安然一枕即仙乡。","竹风穿户凉。","名不恋，利都忘。","心闲日自长。","不须辛苦觅琼浆。","华池神水香。"]},{"id":"c66-521","title":"阮郎归·炎炎皦日正当中","rhythmic":"阮郎归","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["炎炎皦日正当中。","澄潭忽此逢。","金丹乍浴表深功。","通明照水红。","丹浴罢，乐无穷。","怡然百体融。","人间何处不清风。","此怀谁与同。"]},{"id":"c66-522","title":"阮郎归·寒来暑往几时休","rhythmic":"阮郎归","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["寒来暑往几时休。","光阴逐水流。","浮云身世两悠悠。","何劳身外求。","天上月，水边楼。","须将一醉酬。","陶然无喜亦无忧。","人生且自由。"]},{"id":"c66-523","title":"醉落魄・一斛珠·流光转毂","rhythmic":"醉落魄・一斛珠","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["流光转毂。","乌飞兔走争相逐。","火云方见奇峰簇。","飒飒西风，惊堕井梧绿。","隙驹莫叹年华速。","新凉且喜消炎酷。","休将闲事萦心曲。","红滴真珠，初醡玉醅熟。"]},{"id":"c66-524","title":"醉落魄・一斛珠·红芳紫陌","rhythmic":"醉落魄・一斛珠","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["红芳紫陌。","韶华□□□□□。","□花弄□□□色。","不比西风，吹落□□□。","乾坤造化□□□。","都缘一气潜相易。","观时感事成嗟惜。","惟有乔松，不改旧时碧。"]},{"id":"c66-525","title":"醉落魄・一斛珠·清秋夜寂","rhythmic":"醉落魄・一斛珠","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["清秋夜寂。","圆蟾素影流空碧。","都无一点浮云隔。","河汉光微，星斗淡无色。","日精欲炼须阴魄。","更深犹望清宵立。","坎离二物都收得。","独步瀛洲，方表大丹力。"]},{"id":"c66-526","title":"醉落魄・一斛珠·秋高气肃","rhythmic":"醉落魄・一斛珠","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["秋高气肃。","西风又拂盈盈菊。","挼金弄玉香芬馥。","桃李虽繁，其奈太粗俗。","渊明雅兴谁能续。","东篱千古遗高躅。","人生所贵无拘束。","且采芳英，潋滟泛醽醁。"]},{"id":"c66-527","title":"醉落魄・一斛珠·流年迅速","rhythmic":"醉落魄・一斛珠","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["流年迅速。","君看败叶初辞木。","若非寿有金丹续。","石火光中，难保鬓长绿。","区区何用争荣辱。","百年一梦黄梁熟。","人生要足何时足。","赢取清闲，即是世间福。"]},{"id":"c66-528","title":"醉落魄・一斛珠·秋光莹彻","rhythmic":"醉落魄・一斛珠","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["秋光莹彻。","园林□□□□□。","如何宋玉□□切。","作赋悲凉，草木□□□。","□人自与□□□。","长歌清啸无时节。","瓮头且饮□如雪。","不管春花，亦不管秋月。"]},{"id":"c66-529","title":"醉落魄・一斛珠·虚窗透月","rhythmic":"醉落魄・一斛珠","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["虚窗透月。","寒莎败壁蛩吟切。","沈沈永漏灯明灭。","只为愁人，不为道人设。","愁人对此成愁绝。","道人终是心如铁。","一般景趣情怀别。","笛里西风，吹下满庭叶。"]},{"id":"c66-530","title":"醉落魄・一斛珠·光辉皎洁","rhythmic":"醉落魄・一斛珠","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["光辉皎洁。","古今但赏中秋月。","寻思岂是月华别。","都为人间，天上气清彻。","广寒想望峨琼阙。","琤琤玉杵声奇绝。","何时赐我长生诀。","飞入蟾宫，折桂饵丹雪。"]},{"id":"c66-531","title":"醉落魄・一斛珠·湖光湛碧","rhythmic":"醉落魄・一斛珠","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["湖光湛碧。","亭亭照水芙蕖拆。","绿罗盖底争红白。","恍若凌波，仙子步罗袜。","如今霜落枯荷折。","清香无处重寻觅。","浮生似此初无别。","及取康强，一笑对风月。"]},{"id":"c66-532","title":"醉落魄・一斛珠·秋宵露结","rhythmic":"醉落魄・一斛珠","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["秋宵露结。","清晨□□□□□。","□□润□□□冽。","名体才分，功用□□□。","□儿本是□□□。","养成方见仙凡隔。","神仙不肯分明说。","多少迷人，海上访丹诀。"]},{"id":"c66-533","title":"西江月·有限光阴过隙","rhythmic":"西江月","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["有限光阴过隙，无情日月飞梭。","春花秋月暗消磨。","一岁相看又过。","逢酒须成痛饮，临风莫厌高歌。","虚名微利两如何。","识破方知恁麽。"]},{"id":"c66-534","title":"西江月·雪似琼花铺地","rhythmic":"西江月","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["雪似琼花铺地，月如宝鉴当空。","光辉上下两相通。","千古谁窥妙用。","若悟珠生蚌腹，方知非异非同。","阴阳相感有无中。","恍惚已萌真种。"]},{"id":"c66-535","title":"西江月·卷地朔风凛凛","rhythmic":"西江月","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["卷地朔风凛凛，漫天瑞雪霏霏。","园林万木变枯枝。","因甚松篁独翠。","只为春花竞发，却教秋叶争飞。","若无荣盛便无衰。","悟此方名达理。"]},{"id":"c66-536","title":"西江月·密布同云万里","rhythmic":"西江月","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["密布同云万里，六飞玉糁琼铺。","清歌妙舞拥红炉。","犹恨寒侵尊俎。","谁念山林路险，独行跣足樵夫。","莫惊苦乐□殊途。","阳□皆由阴注。"]},{"id":"c66-537","title":"西江月·雅士常多雅□","rhythmic":"西江月","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["雅士常多雅□，□□□□□怀。","雪溪□□□舟来。","兴尽何须见戴。","恰似□云出岫，岂拘宇内形骸。","超然物外远尘埃。","到此方为自在。"]},{"id":"c66-538","title":"西江月·冬至一阳初动","rhythmic":"西江月","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["冬至一阳初动，鼎炉光满帘帏。","五行造化太幽微。","颠倒难穷妙理。","遇此急须进火，速修犹恐迟迟。","茫茫何处问天机。","要悟须凭师指。"]},{"id":"c66-539","title":"西江月·一梦浮生未觉","rhythmic":"西江月","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["一梦浮生未觉，三冬短晷堪惊。","天高谁解挽长绳。","系住流年光景。","须信阴阳有定，非关岁月无情。","若教心地湛然清。","日在壶中自永。"]},{"id":"c66-540","title":"西江月·四序常如转毂","rhythmic":"西江月","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["四序常如转毂，百年须待春风。","江梅何事向严冬。","早有清香浮动。","只为六阴极处，一阳已肇黄宫。","阴阳迭用事何穷。","此是乾坤妙用。"]},{"id":"c66-541","title":"西江月·独坐闲观瑞雪","rhythmic":"西江月","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["独坐闲观瑞雪，方知造化无偏。","不论林木与山川。","白玉一时装遍。","梁苑休寻赋客，山阴莫上溪船。","三杯醉□意陶然。","梦后瑶台阆苑。"]},{"id":"c66-542","title":"西江月·仙道於人不□","rhythmic":"西江月","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["仙道於人不□，□□□□□□。","坎离□□□无穷。","不信浮生若梦。","君看□□窨雪，寻常见睍消熔。","能令新旧再相逢。","此是如何作用。"]},{"id":"c66-543","title":"踏莎行·朝锁烟霏","rhythmic":"踏莎行","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["朝锁烟霏，暮凝空翠。","千峰迥立层霄外。","阴睛变化百千般，丹青难写天然态。","人住山中，年华频改。","山花落尽山长在。","浮生一梦几多时，有谁得似青山耐。"]},{"id":"c66-544","title":"踏莎行·一道飞泉","rhythmic":"踏莎行","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["一道飞泉，来从何许。","空山积翠无人处。","潺湲时和七弦琴，溟濛忽散千岩雨。","不问春秋，何拘今古。","清音一听忘千虑。","缨尘濯尽百神间，飘然襟袖思轻举。"]},{"id":"c66-545","title":"踏莎行·一片闲云","rhythmic":"踏莎行","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["一片闲云，山头初起。","飘然直上虚空里。","残虹收雨耸奇峰，春晴鹤舞丹霄外。","出岫无心，为霖何意。","都缘行止难拘系。","幽人心已与云闲，逍遥自在谁能累。"]},{"id":"c66-546","title":"踏莎行·人远山深","rhythmic":"踏莎行","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["人远山深，草□□□。","□□□□天真性。","□□□长在山中，肯□□□□□□。","□似幽□，□□心尽。","超然心□□□隐。","□□□水作生涯，百年甘守空山静。"]},{"id":"c66-547","title":"踏莎行·堪笑山中","rhythmic":"踏莎行","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["堪笑山中，春来风景。","一声啼鸟烟林静。","山泉风暖奏笙簧。","山花雨过开云锦。","短棹桃溪，瘦藤兰径。","独来独往乘幽兴。","韶光回首即成空，及时乐取逍遥性。"]},{"id":"c66-548","title":"踏莎行·人问山中","rhythmic":"踏莎行","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["人问山中，因何无暑。","山堂恰在山深处。","藤阴满地走龙蛇，泉声万壑鸣风雨。","且弄青松，休挥白羽。","相逢况有烟霞侣。","长天一任火云飞，夜凉踏月相将去。"]},{"id":"c66-549","title":"踏莎行·秋入云山","rhythmic":"踏莎行","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["秋入云山，物情潇洒。","百般景物堪图画。","丹枫万叶碧云边，黄花千点幽岩下。","已喜佳辰，更怜清夜。","一轮明月林梢挂。","松醪常与野人期，忘形共说清闲话。"]},{"id":"c66-550","title":"踏莎行·雪拥群峰","rhythmic":"踏莎行","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["雪拥群峰，静□□□。","□□□□□居□。","□□破壳栗黄香，柴□□□□□□。","□□□□，□和衣倒。","寂寥气□□君好。","□□□贵足人争，山中恬淡能长保。"]},{"id":"c66-551","title":"踏莎行·割断凡缘","rhythmic":"踏莎行","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["割断凡缘，心安神定。","山中采药修身命。","青松林下茯苓多，白云深处黄精盛。","百味甘香，一身清净。","吾生可保长无病。","八珍五鼎不须贪，荤膻浊乱人情性。"]},{"id":"c66-552","title":"踏莎行·身世浮沤","rhythmic":"踏莎行","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["身世浮沤，利名缰锁。","省来万事都齐可。","寻花时傍碧溪行，看云独倚青松坐。","云片飞飞，花枝朵朵。","光阴且向闲中过。","世间萧散更何人，除非明月清风我。"]},{"id":"c66-553","title":"朝中措·吴松江影漾清辉","rhythmic":"朝中措","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["吴松江影漾清辉。","山远翠光微。","杨柳风轻日永，桃花浪暖鱼肥。","东来西往。","随情任性，本自无机。","何事沙边鸥鹭，一声欸乃惊飞。"]},{"id":"c66-554","title":"朝中措·湖光染翠□□□","rhythmic":"朝中措","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["湖光染翠□□□。","□□□□□。","□爱江湖光景，不曾别做□□。","□□□□，□□□□，□□侬家。","醉卧水云□□，□□□□□□。"]},{"id":"c66-555","title":"朝中措·碧波深处锦鳞游","rhythmic":"朝中措","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["碧波深处锦鳞游。","波面小渔舟。","不为来贪香饵，如何赚得吞钩。","缘蓑青箬，吾生自断，终老汀洲。","买断一江风月，胜如千户封侯。"]},{"id":"c66-556","title":"朝中措·沙明波净小汀洲","rhythmic":"朝中措","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["沙明波净小汀洲。","枫落洞庭秋。","红蓼白苹深处，晚风吹转船头。","鲈鱼钓得，银丝旋鲙，白酒新篘。","一笑月寒烟暝，人间万事都休。"]},{"id":"c66-557","title":"朝中措·松江西畔水连空","rhythmic":"朝中措","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["松江西畔水连空。","霜叶舞丹枫。","谩道金章清贵，何如蓑笠从容。","有时独醉，无人系缆，一任斜风。","不是芦花惹住，几回吹过桥东。"]},{"id":"c66-558","title":"朝中措·鸣榔惊起鹭鸶飞","rhythmic":"朝中措","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["鸣榔惊起鹭鸶飞。","山远水弥弥。","米贱茅柴酒美，霜清螃蟹螯肥。","人生所贵，逍遥快意，此外皆非。","却笑东山太傅，几曾梦见蓑衣。"]},{"id":"c66-559","title":"朝中措·午阴多处□□□","rhythmic":"朝中措","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["午阴多处□□□。","杨柳□□□。","翠羽无情飞去，红蕖有意□□。","□□□□，□□□□，□□吾生。","为报凌烟□□，□□□□□名。"]},{"id":"c66-560","title":"朝中措·红尘光景事如何","rhythmic":"朝中措","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["红尘光景事如何。","扰扰利名多。","若问侬家活计，扁舟小笠轻蓑。","一尊美酒，一轮皓月，一弄山歌。","选甚掀天白浪，未如人世风波。"]},{"id":"c66-561","title":"朝中措·萧萧芦叶暮寒生","rhythmic":"朝中措","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["萧萧芦叶暮寒生。","雪厌冻云平。","密洒一篷烟火，惊鸿飞起沙汀。","收纶罢钓，空江有浪，短棹无声。","便是天然图画，何须妙手丹青。"]},{"id":"c66-562","title":"朝中措·慕名人似蚁贪膻","rhythmic":"朝中措","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["慕名人似蚁贪膻。","扰扰几时闲。","输我吴松江上，一帆点破晴烟。","青莎卧月，红鳞荐酒，一醉陶然。","此是人间蓬岛，更於何处求仙。"]},{"id":"c66-563","title":"菩萨蛮·人间何处难忘酒","rhythmic":"菩萨蛮","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["人间何处难忘酒。","迟迟暖日群花秀。","红紫斗芳菲。","满园张锦机。","春光能几许。","多少闲风雨。","一盏此时疏。","非痴即是愚。"]},{"id":"c66-564","title":"菩萨蛮·人间何处难忘酒","rhythmic":"菩萨蛮","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["人间何处难忘酒。","小舟□□□杨柳。","柳影蘸湖光。","薰风拂□□。","□□□□□。","□□□□□。","一盏此时倾。","□□□□□。"]},{"id":"c66-565","title":"菩萨蛮·人间何处难忘酒","rhythmic":"菩萨蛮","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["人间何处难忘酒。","中秋皓月明如昼。","银汉洗晴空。","清辉万古同。","凉风生玉宇。","只怕云来去。","一盏此时迟。","阴晴未可知。"]},{"id":"c66-566","title":"菩萨蛮·人间何处难忘酒","rhythmic":"菩萨蛮","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["人间何处难忘酒。","素秋令节逢重九。","步屧绕东篱。","金英烂漫时。","折来惊岁晚。","心与南山远。","一盏此时休。","高怀何以酬。"]},{"id":"c66-567","title":"菩萨蛮·人间何处难忘酒","rhythmic":"菩萨蛮","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["人间何处难忘酒。","六花投隙琼瑶透。","火满地炉红。","萧萧屋角风。","飘摇飞絮乱。","浩荡银涛卷。","一盏此时乾。","清吟可那寒。"]},{"id":"c66-568","title":"菩萨蛮·人间何处难忘酒","rhythmic":"菩萨蛮","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["人间何处难忘酒。","闭门永日无交友。","何以乐天真。","云山发兴新。","听风松下坐。","趁蝶花边过。","一盏此时空。","幽怀谁与同。"]},{"id":"c66-569","title":"菩萨蛮·人间何处难忘酒","rhythmic":"菩萨蛮","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["人间何处难忘酒。","□□□□□□斗。","不是慕荣华。","惟愁月□□。","□□□□□。","□□□□□。","一盏此时悭。","□□□□□。"]},{"id":"c66-570","title":"菩萨蛮·人间何处难忘酒","rhythmic":"菩萨蛮","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["人间何处难忘酒。","山村野店清明后。","满路野花红。","一帘杨柳风。","田家春最好。","箫鼓村村闹。","一盏此时辞。","将何乐圣时。"]},{"id":"c66-571","title":"菩萨蛮·人间何处难忘酒","rhythmic":"菩萨蛮","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["人间何处难忘酒。","兴来独步登岩岫。","倚杖看云生。","时闻流水声。","山花明照眼。","更有提壶劝。","一盏此时斟。","都忘名利心。"]},{"id":"c66-572","title":"菩萨蛮·人间何处难忘酒","rhythmic":"菩萨蛮","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["人间何处难忘酒。","水边石上逢山友。","相约老山林。","幽居不怕深。","浮名心已尽。","倾倒都无隐。","一盏此时无。","交情何以舒。"]},{"id":"c66-573","title":"诉衷情·闲中一卷圣贤书","rhythmic":"诉衷情","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["闲中一卷圣贤书。","耽玩意□□。","潜心要游阃奥，须是下功夫。","今何异，古何殊。","本同途。","若明性理，一点灵台，万事都无。"]},{"id":"c66-574","title":"诉衷情·闲中一片□□□","rhythmic":"诉衷情","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["闲中一片□□□。","□□□□□。","□□□澄秋水，明月夜□□。","□□□，□□□。","□□□。","鹤长凫短，前定难□，□□□□。"]},{"id":"c66-575","title":"诉衷情·闲中一亩小□□","rhythmic":"诉衷情","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["闲中一亩小□□。","临水对遥岑。","茅茨□□低小，竹径要幽深。","逢酒醉，遇花吟。","日登临。","四时无限，好景良辰，莫负光阴。"]},{"id":"c66-576","title":"诉衷情·闲中一篆百花香","rhythmic":"诉衷情","author":"张抡","authorSlug":"张抡","dynasty":"宋","kind":"ci","paragraphs":["闲中一篆百花香。","袅袅翠□□。","低回宛转何似，行路绕羊肠。","深竹户，小山房。","雅相当。","清心默坐，燕寝无风，永日芬芳。"