":"诗"},{"id":"t6-358","title":"送綦毋三谒房给事","kind":"诗"},{"id":"t6-359","title":"送刘四","kind":"诗"},{"id":"t6-360","title":"送裴腾","kind":"诗"},{"id":"t6-361","title":"送司农崔丞","kind":"诗"},{"id":"t6-362","title":"送崔侍御赴京","kind":"诗"},{"id":"t6-363","title":"春送从叔游襄阳","kind":"诗"},{"id":"t6-364","title":"赠别高三十五","kind":"诗"},{"id":"t6-365","title":"崔五宅送刘跂入京","kind":"诗"},{"id":"t6-366","title":"送马录事赴永阳","kind":"诗"},{"id":"t6-367","title":"临别送张𬤇入蜀","kind":"诗"},{"id":"t6-368","title":"送王昌龄","kind":"诗"},{"id":"t6-369","title":"留别王卢二拾遗","kind":"诗"},{"id":"t6-370","title":"赠别穆元林","kind":"诗"},{"id":"t6-371","title":"不调归东川别业","kind":"诗"},{"id":"t6-372","title":"晚归东园","kind":"诗"},{"id":"t6-373","title":"龙门西峰晓望刘十八不至","kind":"诗"},{"id":"t6-374","title":"裴尹东溪别业","kind":"诗"},{"id":"t6-375","title":"无尽上人东林禅居","kind":"诗"},{"id":"t6-376","title":"题綦毋校书别业","kind":"诗"},{"id":"t6-377","title":"题卢道士房","kind":"诗"},{"id":"t6-378","title":"题神力师院","kind":"诗"},{"id":"t6-379","title":"题僧房双桐","kind":"诗"},{"id":"t6-380","title":"粲公院各赋一物得初荷","kind":"诗"},{"id":"t6-381","title":"李兵曹壁画山水各赋得桂水帆","kind":"诗"},{"id":"t6-382","title":"题合欢","kind":"诗"},{"id":"t6-383","title":"古从军行","kind":"诗"},{"id":"t6-384","title":"行路难","kind":"诗"},{"id":"t6-385","title":"缓歌行","kind":"诗"},{"id":"t6-386","title":"琴歌","kind":"诗"}]},"杨嗣复":{"slug":"杨嗣复","name":"杨嗣复","dynasty":"唐","style":"字继之","life":"","origin":"","seal":"杨","bio":["杨嗣复，字继之，於陵子也。贞元中擢第，初署幕府，进右拾遗，累迁中书舍人。牛僧孺、李宗闵引之，由户部侍郎擢尚书右丞。","太和中，宗闵罢相，嗣复出为剑南东川节度使，宗闵复知政事，入为户部侍郎，俄拜同中书门下平章事。武宗立，贬潮州刺史。宣宗大中初，以吏部尚书召。","卒，谥孝穆。诗五首。"],"works":[{"id":"t24-827","title":"丁巳岁八月祭武侯祠堂因题临淮公旧碑","kind":"诗"},{"id":"t24-828","title":"仪凤","kind":"诗"},{"id":"t24-829","title":"赠毛仙翁","kind":"诗"},{"id":"t24-830","title":"题李处士山居","kind":"诗"},{"id":"t24-831","title":"谢寄新茶","kind":"诗"}]},"杨浚":{"slug":"杨浚","name":"杨浚","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":["杨浚，官校书郎。开元中，尝作圣典三卷上之。诗三首。"],"works":[{"id":"t5-729","title":"题武陵草堂","kind":"诗"},{"id":"t5-730","title":"广武怀古","kind":"诗"},{"id":"t5-731","title":"赠李郎中","kind":"诗"}]},"某邑妓":{"slug":"某邑妓","name":"某邑妓","dynasty":"宋","style":"","life":"","origin":"","seal":"某","bio":[],"works":[{"id":"c76-392","title":"渔家傲·十月小春梅蕊破","kind":"词"}]},"烟萝子":{"slug":"烟萝子","name":"烟萝子","dynasty":"唐","style":"","life":"","origin":"王屋","seal":"烟","bio":["烟萝子，姓燕，名不详。王屋人。后晋天福间道士。","著有《内真通明歌》一卷、《内真通玄诀》一卷、《养神关鏁秘诀图》一卷、《上清金碧篇》一卷等。今存诗一首。（《全唐诗》无烟萝子诗，事迹据陈国符《道藏源流考》附录二《道藏札记·烟萝子》）"],"works":[{"id":"t55-249","title":"体壳歌","kind":"诗"}]},"王初":{"slug":"王初","name":"王初","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王初，并州人，仲舒之长子也。元和末，登进士第。诗十九首。"],"works":[{"id":"t26-169","title":"延平天庆观","kind":"诗"},{"id":"t26-170","title":"送叶秀才","kind":"诗"},{"id":"t26-171","title":"送王秀才谒池州吴都督","kind":"诗"},{"id":"t26-172","title":"青帝","kind":"诗"},{"id":"t26-173","title":"银河","kind":"诗"},{"id":"t26-174","title":"书秋","kind":"诗"},{"id":"t26-175","title":"自和书秋","kind":"诗"},{"id":"t26-176","title":"立春后作","kind":"诗"},{"id":"t26-177","title":"梅花二首 一","kind":"诗"},{"id":"t26-178","title":"梅花二首 二","kind":"诗"},{"id":"t26-179","title":"春日咏梅花二首 一","kind":"诗"},{"id":"t26-180","title":"春日咏梅花二首 二","kind":"诗"},{"id":"t26-181","title":"即夕","kind":"诗"},{"id":"t26-182","title":"送陈校勘入宿","kind":"诗"},{"id":"t26-183","title":"即夕","kind":"诗"},{"id":"t26-184","title":"早春咏雪","kind":"诗"},{"id":"t26-185","title":"望雪","kind":"诗"},{"id":"t26-186","title":"雪霁","kind":"诗"},{"id":"t26-187","title":"舟次汴堤","kind":"诗"}]},"裴坦":{"slug":"裴坦","name":"裴坦","dynasty":"唐","style":"字知进","life":"","origin":"","seal":"裴","bio":["坦，字知进，望出闻喜，大和八年进士，入宣州幕，拜左拾遗、史馆修撰，历楚州刺史、职方郎中、知制诰，进礼部侍郎。会昌间为江西观察使。咸通间出镇襄阳，迁华州刺史。","干符初入相，旋卒。（《全唐诗》无裴坦诗，传据《新唐书》卷一八二本传、《元氏长庆集》卷五五、《登科记考》卷二一、《唐方镇年表》卷四、卷六）"],"works":[{"id":"t54-95","title":"予自右辖出镇钟陵秘监家兄不忍远别亟见宰坐求替遂得同赴江西时也荐福大德显公禅门上首言归东林亦获结侣道路陪游每承清论今过寺因留题诗一首","kind":"诗"},{"id":"t54-96","title":"与大愿和尚诗（题拟）","kind":"诗"}]},"许孟容":{"slug":"许孟容","name":"许孟容","dynasty":"唐","style":"","life":"","origin":"","seal":"许","bio":["许孟容，京兆长安人，举进士甲科。贞元初，为张建封从事，四迁侍御史。德宗知其才，徴为礼部员外郎，迁给事中，多所论奏。","元和中，由太常卿为尚书左丞，居官守正，善拔士，议论人物，有大臣风采。诗三首。"],"works":[{"id":"t0-748","title":"郊庙歌辞 享文敬太子庙乐章 请神","kind":"诗"},{"id":"t17-548","title":"荅权载之离合诗","kind":"诗"},{"id":"t17-549","title":"奉和武相公春晓闻莺","kind":"诗"},{"id":"t17-550","title":"享文恭太子庙乐章","kind":"诗"}]},"贾驰":{"slug":"贾驰","name":"贾驰","dynasty":"唐","style":"","life":"","origin":"","seal":"贾","bio":["贾驰，与曹邺同时。诗二首。"],"works":[{"id":"t0-926","title":"横吹曲辞 入关","kind":"诗"},{"id":"t40-844","title":"复覩三乡题处留赠","kind":"诗"},{"id":"t40-845","title":"秋入关","kind":"诗"},{"id":"t53-872","title":"句","kind":"诗"}]},"赵淇":{"slug":"赵淇","name":"赵淇","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"c75-242","title":"谒金门·吟望直","kind":"词"}]},"郑澣":{"slug":"郑澣","name":"郑澣","dynasty":"唐","style":"","life":"","origin":"","seal":"郑","bio":["郑澣，余庆之子。贞元十年，举进士第，为右补阙，敢言，无所讳。文宗时，入翰林为侍讲学士，累进尚书左丞，出为山南西道节度使。","俄以户部尚书召，未拜，卒，谥曰宣。集三卷，今存诗五首。"],"works":[{"id":"t19-584","title":"赠毛仙翁","kind":"诗"},{"id":"t19-585","title":"和李德裕游汉州房公湖二首 一","kind":"诗"},{"id":"t19-586","title":"和李德裕游汉州房公湖二首 二","kind":"诗"},{"id":"t19-587","title":"中书相公任兵部侍郎日后阁植四松逾数年澣忝此官因献拙什","kind":"诗"},{"id":"t19-588","title":"和李德裕房公旧竹亭闻琴","kind":"诗"},{"id":"t19-589","title":"句","kind":"诗"}]},"郭密之":{"slug":"郭密之","name":"郭密之","dynasty":"唐","style":"字多出入","life":"","origin":"","seal":"郭","bio":["郭密之，天宝中诸暨县令。建义津桥，筑放生湖，溉田二千余顷，民便之。补诗一首。","（《两浙金石志》及《青田县志》载郭密之诗二首，其一为《使永嘉经谢公石门山作》，《全唐诗》卷八八七《补遗》六亦收之，无小传，与两书文字多出入，特以校稿附于后。其二为《永嘉怀古》则《全唐诗》所未收。）"],"works":[{"id":"t49-46","title":"永嘉经谢公石门山作","kind":"诗"},{"id":"t50-593","title":"永嘉怀古（题一作《石门山》）","kind":"诗"}]}}