{"丁位":{"slug":"丁位","name":"丁位","dynasty":"唐","style":"","life":"","origin":"","seal":"丁","bio":["丁位，大历进士第。诗一首。"],"works":[{"id":"t15-549","title":"小苑春望宫池柳色","kind":"诗"}]},"临淄县主":{"slug":"临淄县主","name":"临淄县主","dynasty":"唐","style":"","life":"","origin":"","seal":"临","bio":[],"works":[{"id":"t48-15","title":"与独孤穆冥会诗 一","kind":"诗"},{"id":"t48-16","title":"与独孤穆冥会诗 二","kind":"诗"},{"id":"t48-17","title":"与独孤穆冥会诗 三","kind":"诗"},{"id":"t48-18","title":"与独孤穆冥会诗 四","kind":"诗"},{"id":"t48-19","title":"与独孤穆冥会诗 五","kind":"诗"},{"id":"t48-20","title":"与独孤穆冥会诗 六","kind":"诗"},{"id":"t48-21","title":"与独孤穆冥会诗 七","kind":"诗"}]},"元德秀":{"slug":"元德秀","name":"元德秀","dynasty":"唐","style":"字紫芝","life":"","origin":"","seal":"元","bio":["德秀，字紫芝，河南人。少孤，事母孝。开元二十一年举进士，家贫，求为鲁山令。","岁满去职，爱陆浑佳山水乃居之。嗜酒，陶然弹琴以自娱。房琯每见叹息曰：「见紫芝眉宇，使人名利之心都尽。","」天宝十三载卒，年五十九。天下高其行，称曰元鲁山，谥曰文行先生。李华兄事德秀，而友萧颖士、刘迅，因作《三贤论》。"],"works":[{"id":"t51-243","title":"无题","kind":"诗"},{"id":"t51-244","title":"归隐","kind":"诗"}]},"张半湖":{"slug":"张半湖","name":"张半湖","dynasty":"宋","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"c76-501","title":"满江红·新绿池塘","kind":"词"},{"id":"c76-502","title":"扫花游・扫地游·柳丝曳绿","kind":"词"}]},"徐真君":{"slug":"徐真君","name":"徐真君","dynasty":"唐","style":"","life":"","origin":"","seal":"徐","bio":["徐真君，唐时道士，名不详。住天目山。诗一首。"],"works":[{"id":"t56-523","title":"石胆歌","kind":"诗"}]},"戴平之":{"slug":"戴平之","name":"戴平之","dynasty":"宋","style":"","life":"","origin":"","seal":"戴","bio":[],"works":[{"id":"c74-815","title":"鹧鸪天·笑擘黄柑酒半醒","kind":"词"}]},"李翺":{"slug":"李翺","name":"李翺","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t53-685","title":"洗墨池","kind":"诗"}]},"杨敬述":{"slug":"杨敬述","name":"杨敬述","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":["杨敬述，则天时右玉钤衞郎将，左奉宸内供奉。诗一首。"],"works":[{"id":"t4-310","title":"奉和圣制夏日游石淙山","kind":"诗"}]},"薛昌朝":{"slug":"薛昌朝","name":"薛昌朝","dynasty":"唐","style":"","life":"","origin":"","seal":"薛","bio":["薛昌朝，河东万泉人。薛嵩子。累官御史。","官至保信军节度使。（参《新唐书·宰相世系表》、《山右石刻丛编》卷七《薛