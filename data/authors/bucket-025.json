":"狄","bio":[],"works":[{"id":"t54-410","title":"悼孟昭图（题拟）","kind":"诗"}]},"玄宗皇帝李隆基":{"slug":"玄宗皇帝李隆基","name":"玄宗皇帝李隆基","dynasty":"唐","style":"","life":"","origin":"","seal":"玄","bio":[],"works":[{"id":"t52-902","title":"诗送玄静先生赴金坛（题拟）","kind":"诗"},{"id":"t52-903","title":"诗送玄静先生暂还广陵（并序）","kind":"诗"},{"id":"t52-904","title":"诗送玄静先生归广陵（并序）","kind":"诗"},{"id":"t52-905","title":"送道士薛季昌还山（补序）","kind":"诗"},{"id":"t52-906","title":"批答安禄山贺雪兼赐口号（题拟）","kind":"诗"}]},"琴操":{"slug":"琴操","name":"琴操","dynasty":"宋","style":"","life":"","origin":"","seal":"琴","bio":[],"works":[{"id":"c59-536","title":"满庭芳·山抹微云","kind":"词"},{"id":"c59-537","title":"卜算子·欲整别离情","kind":"词"}]},"罗隐":{"slug":"罗隐","name":"罗隐","dynasty":"唐","style":"字昭谏","life":"","origin":"","seal":"罗","bio":["罗隐，字昭谏，余杭人。本名横，十上不中第，遂更名，从事湖南淮润，无所合。久之，归投钱镠，累官钱塘令、镇海军掌书记、节度判官、盐铁发运副使、著作佐郎，奏授司勋郎。","朱全忠以谏议大夫召，不行。魏博罗绍威推为叔父，表荐给事中，年七十七卒。隐少聪敏，既不得志，其诗以风剌为主，有《歌诗集》十四卷，《甲乙集》三卷，外集一卷。","今编诗十一卷。罗隐，字昭谏，余杭人。本名横，十上不中第，遂更名。","从事湖南淮润，无所合，久之，归投钱镠，累官钱塘令、镇海军掌书记、节度判官、盐铁发运副使、著作佐郎，奏授司勋郎。朱全忠以谏议大夫召，不行。魏博罗绍威推为叔父，表荐给事中，年七十七卒。","隐少聪敏，既不得志，其诗以风剌为主，有歌诗集十四卷，甲乙集三卷，外集一卷。今编诗十一卷。罗隐，字昭谏，余杭人。","本名横，十上不中第，遂更名，从事湖南淮润，无所合，久之，归投钱镠，累官钱塘令、镇海军掌书记、节度判官、盐铁发运副使、著作佐郎，奏授司勋郎，朱全忠以谏议大夫召，不行。魏博罗绍威推为叔父，表荐给事中，年七十七卒。隐少聪敏，既不得志，其诗以风剌为主，有歌诗集十四卷，甲乙集三卷，外集一卷，今编诗十一卷。","罗隐字昭谏，余杭人。后梁太祖开平三年卒，年七十七。补诗一首。"],"works":[{"id":"t0-883","title":"鼓吹曲辞 芳树","kind":"诗"},{"id":"t0-924","title":"横吹曲辞 陇头水","kind":"诗"},{"id":"t1-50","title":"相和歌辞 江南曲","kind":"诗"},{"id":"t1-133","title":"相和歌辞 铜雀台","kind":"诗"},{"id":"t36-557","title":"曲江春感","kind":"诗"},{"id":"t36-558","title":"皇陂","kind":"诗"},{"id":"t36-559","title":"寄郑补阙","kind":"诗"},{"id":"t36-560","title":"牡丹花","kind":"诗"},{"id":"t36-561","title":"黄河","kind":"诗"},{"id":"t36-562","title":"汴河","kind":"诗"},{"id":"t36-563","title":"西京崇德里居","kind":"诗"},{"id":"t36-564","title":"投所思","kind":"诗"},{"id":"t36-565","title":"经张舍人旧居","kind":"诗"},{"id":"t36-566","title":"雒城作","kind":"诗"},{"id":"t36-567","title":"姑苏城南湖陪曹使君游","kind":"诗"},{"id":"t36-568","title":"秋日有寄姑苏曹使君","kind":