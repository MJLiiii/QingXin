tyle":"","life":"","origin":"","seal":"干","bio":["干康，零陵人。诗二首。"],"works":[{"id":"t47-191","title":"投谒齐己","kind":"诗"},{"id":"t47-192","title":"赋残雪","kind":"诗"},{"id":"t47-193","title":"句","kind":"诗"}]},"施枢":{"slug":"施枢","name":"施枢","dynasty":"宋","style":"","life":"","origin":"","seal":"施","bio":[],"works":[{"id":"c73-815","title":"摸鱼儿·柳蒙茸","kind":"词"},{"id":"c73-816","title":"疏影·低枝亚实","kind":"词"},{"id":"c73-817","title":"柳梢青·飞露初霜","kind":"词"}]},"杨凭":{"slug":"杨凭","name":"杨凭","dynasty":"唐","style":"字虚受 · 号杨穆许李","life":"","origin":"","seal":"杨","bio":["杨凭，字虚受，弘农人，与弟凝、凌皆工文辞。大历中，踵擢进士第，时称三杨。凭重交游，尚气节，与穆质、许孟容、李鄘相友善，号杨穆许李。","历事节度府，召为监察御史，累拜京兆尹。与李夷简素有隙，因擿发他罪，欲抵以死。宪宗以凭治京兆有绩，但贬临贺尉。","俄徙杭州长史，以太子詹事卒。诗一卷。"],"works":[{"id":"t15-557","title":"长安春夜宿开元观","kind":"诗"},{"id":"t15-558","title":"晚泊江戍","kind":"诗"},{"id":"t15-559","title":"巴江雨夜","kind":"诗"},{"id":"t15-560","title":"边塞行","kind":"诗"},{"id":"t15-561","title":"乐游园望月","kind":"诗"},{"id":"t15-562","title":"千叶桃花","kind":"诗"},{"id":"t15-563","title":"春中泛舟","kind":"诗"},{"id":"t15-564","title":"雨中怨秋","kind":"诗"},{"id":"t15-565","title":"秋日独游曲江","kind":"诗"},{"id":"t15-566","title":"寄别","kind":"诗"},{"id":"t15-567","title":"边情","kind":"诗"},{"id":"t15-568","title":"早发湘中","kind":"诗"},{"id":"t15-569","title":"海榴","kind":"诗"},{"id":"t15-570","title":"春情","kind":"诗"},{"id":"t15-571","title":"送客往荆州","kind":"诗"},{"id":"t15-572","title":"赠马炼师","kind":"诗"},{"id":"t15-573","title":"湘江泛舟","kind":"诗"},{"id":"t15-574","title":"送别","kind":"诗"},{"id":"t15-575","title":"赠窦牟","kind":"诗"}]},"杨续":{"slug":"杨续","name":"杨续","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":["杨续，师道之兄，有辞学。贞观中，为郓州刺史。诗一首。"],"works":[{"id":"t2-503","title":"安德山池宴集","kind":"诗"}]},"王重民辑录，刘修业整理。":{"slug":"王重民辑录，刘修业整理。","name":"王重民辑录，刘修业整理。","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"t50-242","title":"前言","kind":"诗"}]},"皇甫冉":{"slug":"皇甫冉","name":"皇甫冉","dynasty":"唐","style":"字茂政","life":"","origin":"","seal":"皇","bio":["皇甫冉，字茂政，润州丹阳人，晋高士谧之后。十岁能属文，张九龄深器之。天宝十五载，举进士第一，授无锡尉，历左金吾兵曹。","王缙为河南帅，表掌书记。大历初，累迁右补阙，奉使江表，卒于家。冉诗天机独得，远出情外。","集三卷，今编诗二卷。皇甫冉，字茂政，润州丹阳人。晋高士谧之后，十岁能属文，张九龄深器之。","天宝十五载，举进士第一，授无锡尉，历左金吾兵曹，王缙为河南帅，表掌书记。大历初，累迁右补阙，奉使江表，卒于家，冉诗天机独得，远出情外。集三卷，今编诗二卷。","皇甫冉字茂政，安定执行，避地寓居丹阳。天宝十五载卢庚榜进士。大历二年卒，年五十四（据独孤及撰《唐故左补阙安定皇甫公集序》）。","补诗一首。（复出一首）"],"works":[{"id":"t0-867","title":"鼓吹曲辞 巫山高","kind":"诗"},{"id":"t0-950","title":"横吹曲辞 出塞","kind":"诗"},{"id":"t1-336","title":"相和歌辞 倢伃怨","kind":"诗"},{"id":"t13-92","title":"润州南郭留别","kind":"诗"},{"id":"t13-93","title":"祭张公洞二首 一","kind":"诗"},{"id":"t13-94","title":"祭张公洞二首 二","kind":"诗"},{"id":"t13-95","title":"临平道赠同舟人","kind":"诗"},{"id":"t13-96","title":"巫山峡","kind":"诗"},{"id":"t13-97","title":"长安路","kind":"诗"},{"id":"t13-98","title":"送朱逸人","kind":"诗"},{"id":"t13-99","title":"西陵寄灵一上人","kind":"诗"},{"id":"t13-100","title":"赴无锡寄别灵一净虚二上人云门所居","kind":"诗"},{"id":"t13-101","title":"舟中送李八","kind":"诗"},{"id":"t13-102","title":"与张补阙王炼师自徐方清路同舟南下于台头寺留别赵员外裴补阙同赋杂题一首","kind":"诗"},{"id":"t13-103","title":"酬张二仲彝","kind":"诗"},{"id":"t13-104","title":"三月三日义兴李明府后亭泛舟","kind":"诗"},{"id":"t13-105","title":"少室山韦炼师升仙歌","kind":"诗"},{"id":"t13-106","title":"独孤中丞筵陪饯韦君赴升州","kind":"诗"},{"id":"t13-107","title":"送王绪剡中","kind":"诗"},{"id":"t13-108","title":"詶李郎中侍御秋夜登福州城楼见寄","kind":"诗"},{"id":"t13-109","title":"同李司直诸公暑夜南余馆","kind":"诗"},{"id":"t13-110","title":"赠普门上人","kind":"诗"},{"id":"t13-111","title":"与诸公同登无锡北楼","kind":"诗"},{"id":"t13-112","title":"同李苏州伤美人","kind":"诗"},{"id":"t13-113","title":"送李录事赴饶州","kind":"诗"},{"id":"t13-114","title":"同诸公有怀绝句","kind":"诗"},{"id":"t13-115","title":"题魏仲光淮山所居","kind":"诗"},{"id":"t13-116","title":"送郑判官赴徐州","kind":"诗"},{"id":"t13-117","title":"送顾苌往新安","kind":"诗"},{"id":"t13-118","title":"秋夜有怀高三十五兼呈空和尚","kind":"诗"},{"id":"t13-119","title":"途中送权三兄弟","kind":"诗"},{"id":"t13-120","title":"送裴阐","kind":"诗"},{"id":"t13-121","title":"杂言湖山歌送许鸣谦","kind":"诗"},{"id":"t13-122","title":"杂言迎神词二首 迎神","kind":"诗"},{"id":"t13-123","title":"杂言迎神词二首 送神","kind":"诗"},{"id":"t13-124","title":"屏风上各赋一物得携琴客","kind":"诗"},{"id":"t13-125","title":"江草歌送卢判官","kind":"诗"},{"id":"t13-126","title":"题画帐二首 山水","kind":"诗"},{"id":"t13-127","title":"题画帐二首 远帆","kind":"诗"},{"id":"t13-128","title":"落第后东游留别","kind":"诗"},{"id":"t13-129","title":"杂言月洲歌送赵冽还襄阳","kind":"诗"},{"id":"t13-130","title":"寄刘八山中","kind":"诗"},{"id":"t13-131","title":"答张𬤇刘方平兼呈贺兰广","kind":"诗"},{"id":"t13-132","title":"沣水送郑鄠县读书","kind":"诗"},{"id":"t13-133","title":"九日寄郑丰","kind":"诗"},{"id":"t13-134","title":"酬包评事壁画山水见寄","kind":"诗"},{"id":"t13-135","title":"渡汝水向太和山","kind":"诗"},{"id":"t13-136","title":"秋怨","kind":"诗"},{"id":"t13-137","title":"赠郑山人","kind":"诗"},{"id":"t13-138","title":"刘方平西斋对雪","kind":"诗"}]},"窦洵直":{"slug":"窦洵直","name":"窦洵直","dynasty":"唐","style":"","life":"","origin":"","seal":"窦","bio":["窦洵直，长庆进士。诗一首。"],"works":[{"id":"t27-319","title":"鸟散余花落","kind":"诗"}]},"范质":{"slug":"范质","name":"范质","dynasty":"唐","style":"字文素","life":"","origin":"","seal":"范","bio":["范质字文素，大名宗城人。后唐长兴四年进士，晋天福中为翰林学士，汉初加中书舍人、户部侍郎。周广顺初拜中书侍郎同中书门下平章事。","宋太祖受禅，加兼侍中。干德初封鲁国公。二年正月罢为太子太傅。","九月卒，诗一首。（《全唐诗》无范质诗。按质虽为宋初名臣，然曾历仕后晋、汉、周各朝。","其从五代主者久，而事宋之日浅，故仍录补于唐诗之列）"],"works":[{"id":"t50-975","title":"无题","kind":"诗"},{"id":"t50-976","title":"诫儿姪八百字","kind":"诗"},{"id":"t55-288","title":"贺李昉除翰林学士（题拟）","kind":"诗"},{"id":"t55-289","title":"岳阳楼诗（题拟） 一","kind":"诗"},{"id":"t55-290","title":"岳阳楼诗（题拟） 二","kind":"诗"},{"id":"t55-291","title":"岳阳楼诗（题拟） 三","kind":"诗"}]},"路应":{"slug":"路应","name":"路应","dynasty":"唐","style":"字从众","life":"","origin":"","seal":"路","bio":["路应，字从众，京兆三原人。大历间授温州刺史，筑堤横阳乐成界中，二邑得上田，除水害。补诗一首。","（《全唐诗》卷八八七收路应诗一首，无传。）"],"works":[{"id":"t49-40","title":"仙岩四瀑布即事寄上秘书包监侍郎七兄吏部李侍郎十七兄婺州赵中丞处州齐谏议明州李九郎十四韵","kind":"诗"},{"id":"t53-17","title":"无题","kind":"诗"},{"id":"t53-18","title":"游南雁荡","kind":"诗"}]},"韦检亡姬":{"slug":"韦检亡姬","name":"韦检亡姬","dynasty":"唐","style":"","life":"","origin":"","seal":"韦","bio":[],"works":[{"id":"t48-53","title":"和检诗","kind":"诗"},{"id":"t48-54","title":"检悼亡姬诗","kind":"诗"},{"id":"t48-55","title":"梦后自题","kind":"诗"}]}}