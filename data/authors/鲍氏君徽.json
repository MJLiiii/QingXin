{"slug":"鲍氏君徽","name":"鲍氏君徽","dynasty":"唐","style":"字文姬","life":"","origin":"","seal":"鲍","bio":["鲍君徽，字文姬，鲍征君女。善诗，与尚宫五宋齐名。德宗尝召入宫，与侍臣赓和，赏赉甚厚。","存诗四首。"],"works":[{"id":"t0-311","title":"奉和麟德殿宴百僚应[制]","kind":"诗"},{"id":"t0-312","title":"关山月","kind":"诗"},{"id":"t0-313","title":"惜花吟","kind":"诗"},{"id":"t0-314","title":"东亭茶宴","kind":"诗"}]}