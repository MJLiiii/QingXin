{"slug":"刘湾","name":"刘湾","dynasty":"唐","style":"字灵源","life":"","origin":"","seal":"刘","bio":["刘湾，字灵源，西蜀人，天宝进士。禄山之乱，以侍御史居衡阳，与元结相友善。诗六首。"],"works":[{"id":"t9-511","title":"出塞曲","kind":"诗"},{"id":"t9-512","title":"云南曲","kind":"诗"},{"id":"t9-513","title":"李陵别苏武","kind":"诗"},{"id":"t9-514","title":"虹县严孝子墓","kind":"诗"},{"id":"t9-515","title":"对雨愁闷寄钱大郎中","kind":"诗"},{"id":"t9-516","title":"即席赋露中菊","kind":"诗"}]}