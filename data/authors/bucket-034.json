{"丘为":{"slug":"丘为","name":"丘为","dynasty":"唐","style":"","life":"","origin":"","seal":"丘","bio":["丘为，苏州嘉兴人。事继母孝，常有灵芝生堂下。累官太子右庶子，致仕，给俸禄之半以终身，年八十余，母尚无恙。","及居忧，观察使韩滉以致仕官给禄，所以惠养老臣，不可在丧而异，惟罢春秋羊酒，卒年九十六。与刘长卿善，其赴上都也，长卿有诗送之，亦与王维为友。诗十三首。"],"works":[{"id":"t6-249","title":"寻西山隐者不遇","kind":"诗"},{"id":"t6-250","title":"题农父庐舍","kind":"诗"},{"id":"t6-251","title":"泛若耶溪","kind":"诗"},{"id":"t6-252","title":"湖中寄王侍御","kind":"诗"},{"id":"t6-253","title":"登润州城","kind":"诗"},{"id":"t6-254","title":"寻庐山崔征君","kind":"诗"},{"id":"t6-255","title":"留别王维","kind":"诗"},{"id":"t6-256","title":"竹下残雪","kind":"诗"},{"id":"t6-257","title":"送阎校书之越","kind":"诗"},{"id":"t6-258","title":"省试夏日可畏","kind":"诗"},{"id":"t6-259","title":"左掖梨花","kind":"诗"},{"id":"t6-260","title":"渡汉江","kind":"诗"},{"id":"t6-261","title":"冬至下寄舍弟时应赴入京","kind":"诗"},{"id":"t50-180","title":"答韩丈[一]（「韩丈」，原卷作「韩大」。疑非韩滉。）（伯二五六七下同）","kind":"诗"},{"id":"t50-181","title":"辛四卧病舟中群公招登慈和寺","kind":"诗"},{"id":"t50-182","title":"对雨闻鸎","kind":"诗"},{"id":"t50-183","title":"幽渚云","kind":"诗"},{"id":"t50-184","title":"伤河龛老人[一]","kind":"诗"}]},"先汪":{"slug":"先汪","name":"先汪","dynasty":"唐","style":"","life":"","origin":"","seal":"先","bio":["先汪，合江人，贞元中举孝廉。诗一首。"],"works":[{"id":"t25-209","title":"题安乐山","kind":"诗"}]},"刘得仁":{"slug":"刘得仁","name":"刘得仁","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":["刘得仁，贵主之子，长庆中即以诗名。自开成至大中三朝，昆弟皆历贵仕，而得仁出入举场三十年，卒无成。集一卷，今编诗二卷。","刘得仁，贵主之子，长庆中即以诗名。自开成至大中三朝，昆弟皆历贵仕，而得仁出入举场三十年，卒无成。集一卷，今编诗二卷。","刘得仁，贵主之子。补诗一首。"],"works":[{"id":"t30-15","title":"听歌","kind":"诗"},{"id":"t30-16","title":"青龙寺僧院","kind":"诗"},{"id":"t30-17","title":"夏夜会同人","kind":"诗"},{"id":"t30-18","title":"游崔监丞城南别业","kind":"诗"},{"id":"t30-19","title":"荅韦先辈春雨后见寄","kind":"诗"},{"id":"t30-20","title":"题吴先生山居","kind":"诗"},{"id":"t30-21","title":"晚游慈恩寺","kind":"诗"},{"id":"t30-22","title":"题王处士山居","kind":"诗"},{"id":"t30-23","title":"宿僧院","kind":"诗"},{"id":"t30-24","title":"晓别吕山人","kind":"诗"},{"id":"t30-25","title":"送知全禅师南游","kind":"诗"},{"id":"t30-26","title":"上张水部","kind":"诗"},{"id":"t30-27","title":"塞上行作","kind":"诗"},{"id":"t30-28","title":"赠江夏卢使君","kind":"诗"},{"id":"t30-29","title":"冬夜寄白阁僧","kind":"诗"},{"id":"t30-30","title":"送姚合郎中任杭州","kind":"诗"},{"id":"t30-31","title":"西园","kind":"诗"},{"id":"t30-32","title":"昊天观新栽竹","kind":"诗"},{"id":"t30-33","title":"晚步曲江因谒慈恩寺恭上人","kind":"诗"},{"id":"t30-34","title":"送姚处士归亳州","kind":"诗"},{"id":"t30-35","title":"寄楼子山云栖上人","kind":"诗"},{"id":"t30-36","title":"秋夜喜友人宿","kind":"诗"},{"id":"t30-37","title":"秋日同僧宿西池","kind":"诗"},{"id":"t30-38","title":"宿韦津山居","kind":"诗"},{"id":"t30-39","title":"夜携酒访崔正字","kind":"诗"},{"id":"t30-40","title":"送蔡京东归迎侍","kind":"诗"},{"id":"t30-41","title":"中秋","kind":"诗"},{"id":"t30-42","title":"池上宿","kind":"诗"},{"id":"t30-43","title":"秋夕即事","kind":"诗"},{"id":"t30-44","title":"晚夏","kind":"诗"},{"id":"t30-45","title":"夏日即事","kind":"诗"},{"id":"t30-46","title":"夏日通济里居酬诸先辈见访","kind":"诗"},{"id":"t30-47","title":"寄姚谏议","kind":"诗"},{"id":"t30-48","title":"和厉玄侍御题户部相公庐山草堂","kind":"诗"},{"id":"t30-49","title":"题山中故静禅师","kind":"诗"},{"id":"t30-50","title":"夏日游慈恩寺","kind":"诗"},{"id":"t30-51","title":"题终南麻先生寂禅师石室","kind":"诗"},{"id":"t30-52","title":"送灵武朱书记","kind":"诗"},{"id":"t30-53","title":"吊草堂禅师","kind":"诗"},{"id":"t30-54","title":"早春送湘潭李少府之任","kind":"诗"},{"id":"t30-55","title":"送越客归","kind":"诗"},{"id":"t30-56","title":"送周钺往江夏","kind":"诗"},{"id":"t30-57","title":"送河池李明府之任","kind":"诗"},{"id":"t30-58","title":"送蔡京侍御赴大梁幕","kind":"诗"},{"id":"t30-59","title":"哭鲍溶有感","kind":"诗"},{"id":"t30-60","title":"送僧归玉泉寺","kind":"诗"},{"id":"t30-61","title":"宣义池上","kind":"诗"},{"id":"t30-62","title":"回中夜访独孤从事","kind":"诗"},{"id":"t30-63","title":"宿宣义池亭","kind":"诗"},{"id":"t30-64","title":"送智玄首座归蜀中旧山","kind":"诗"}]},"周延翰":{"slug":"周延翰","name":"周延翰","dynasty":"唐","style":"","life":"","origin":"","seal":"周","bio":[],"works":[{"id":"t48-193","title":"梦中句","kind":"诗"}]},"孟蜀妃张太华":{"slug":"孟蜀妃张太华","name":"孟蜀妃张太华","dynasty":"唐","style":"","life":"","origin":"","seal":"孟","bio":[],"works":[{"id":"t48-50","title":"葬后见形诗","kind":"诗"},{"id":"t48-51","title":"谢李若冲","kind":"诗"}]},"张桂":{"slug":"张桂","name":"张桂","dynasty":"宋","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"c74-147","title":"菩萨蛮·东风忽骤无人见","kind":"词"},{"id":"c74-148","title":"浣溪沙·雨压杨花路半乾","kind":"词"}]},"张淑芳":{"slug":"张淑芳","name":"张淑芳","dynasty":"宋","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"c76-28","title":"更漏子·墨痕香","kind":"词"},{"id":"c76-29","title":"满路花・促拍满路花·罗襟湿未乾","kind":"词"},{"id":"c76-30","title":"浣溪沙·散步山前春草香","kind":"词"}]},"朱琳":{"slug":"朱琳","name":"朱琳","dynasty":"唐","style":"","life":"","origin":"","seal":"朱","bio":[],"works":[{"id":"t42-969","title":"开缄怨","kind":"诗"}]},"李新":{"slug":"李新","name":"李新","dynasty":"宋","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"c62-529","title":"临江仙·杨柳梢头春色重","kind":"词"},{"id":"c62-530","title":"浣溪沙·千古人生乐事稀","kind":"词"},{"id":"c62-531","title":"浣溪沙·雨霁笼山碧破赊","kind":"词"},{"id":"c62-532","title":"摊破浣溪沙・山花子·几度珠帘卷上钩","kind":"词"}]},"李虞仲":{"slug":"李虞仲","name":"李虞仲","dynasty":"唐","style":"字见之","life":"","origin":"","seal":"李","bio":["李虞仲，字见之，端之子。元和初，登进士第，累官中书舍人、知制诰，终吏部侍郎。诗集四卷，今存一首。"],"works":[{"id":"t25-725","title":"初日照凤楼","kind":"诗"}]},"梅娇":{"slug":"梅娇","name":"梅娇","dynasty":"宋","style":"","life":"","origin":"","seal":"梅","bio":[],"works":[{"id":"c61-54","title":"满庭芳·一种阳和","kind":"词"}]},"段谷":{"slug":"段谷","name":"段谷","dynasty":"唐","style":"","life":"","origin":"","seal":"段","bio":["段谷，累举进士不第，忽如狂，市中讴吟其诗。后死，及葬发视，但空棺耳。"],"works":[{"id":"t47-761","title":"市中狂吟","kind":"诗"}]},"王衍":{"slug":"王衍","name":"王衍","dynasty":"唐","style":"字化源","life":"","origin":"许州舞阳（今属河南）","seal":"王","bio":["--五代前蜀国主。本名宗衍，字化源。许州舞阳 (今属河南) 人。","公元 919－925 在位。咸康元年 (925) 降于后唐，遇害而死。有文才，能为浮艳之词。","著有《烟花集》。词存二首。"],"works":[{"id":"t56-249","title":"自制词","kind":"诗"},{"id":"t56-250","title":"曲子","kind":"诗"}]},"神秀":{"slug":"神秀","name":"神秀","dynasty":"唐","style":"","life":"","origin":"","seal":"神","bio":["神秀，开封尉氏李氏子。师黄梅弘忍（谥大满）禅师，奉楞伽为心要，为北宗之祖，亦称六祖。住荆州玉泉寺。","武后召至都，命于当阳山置度门寺以旌异之。神龙二年卒，年百余岁。谥大通禅师。"],"works":[{"id":"t51-234","title":"偈","kind":"诗"}]},"章谦亨":{"slug":"章谦亨","name":"章谦亨","dynasty":"宋","style":"字牧之","life":"","origin":"吴兴（今属浙江）","seal":"章","bio":["--字牧之，一字牧叔，吴兴 (今属浙江) 人。绍定间为铅山 (今属江西) 令，为政宽简，人称为“佛家”。嘉熙二年 (1238)，除直秘阁，浙东堤刑，兼知衢州。","词见《湖州词征》。"],"works":[{"id":"c73-858","title":"念奴娇·垂杨得地","kind":"词"},{"id":"c73-859","title":"步蟾宫·团圞小酌醺醺醉","kind":"词"},{"id":"c73-860","title":"摸鱼儿·想先生","kind":"词"},{"id":"c73-861","title":"念奴娇·画楼侧畔","kind":"词"},{"id":"c73-862","title":"浪淘沙·台上凭阑干","kind":"词"},{"id":"c73-863","title":"小重山·久雨初晴天气佳","kind":"词"},{"id":"c73-864","title":"石州引・石州慢·半角庭阴","kind":"词"},{"id":"c73-865","title":"水调歌头·解变西崑体","kind":"词"},{"id":"c73-866","title":"画堂春·连朝檐溜几曾乾","kind":"词"}]},"萧嵩":{"slug":"萧嵩","name":"萧嵩","dynasty":"唐","style":"","life":"","origin":"","seal":"萧","bio":["萧嵩，梁宣帝裔孙。初与陆象先为僚壻，象先，相门子。嵩尚未入仕，相者曰：“陆郎十年内，位极人臣，然不及萧郎，一门尽贵，官高多寿。","”景云元年，嵩为醴泉尉，时象先已为中书侍郎。引为监察御史，骤迁殿中。开元初，拜中书舍人，与王丘、齐澣同列。","未之异，独姚崇许其致远，三迁尚书左丞，寻以兵部尚书节度河西。以破吐蕃功，入为中书令，遥领河西节度，终太子太师，年八十余。子衡，尚新昌公主，以三品就养，时论荣之。","诗二首。"],"works":[{"id":"t5-374","title":"奉和圣制送张说上集贤学士赐宴","kind":"诗"},{"id":"t5-375","title":"奉和御制左丞相说右丞相璟太子少傅乾曜同日上官命宴都堂赐诗","kind":"诗"}]},"郑中丞":{"slug":"郑中丞","name":"郑中丞","dynasty":"唐","style":"","life":"","origin":"","seal":"郑","bio":[],"works":[{"id":"t43-341","title":"登汾上阁","kind":"诗"}]},"郭良":{"slug":"郭良","name":"郭良","dynasty":"唐","style":"","life":"","origin":"","seal":"郭","bio":["郭良，金部员外郎。诗二首。"],"works":[{"id":"t10-11","title":"题李将军山亭","kind":"诗"},{"id":"t10-12","title":"早行","kind":"诗"}]},"韦敬辨":{"slug":"韦敬辨","name":"韦敬辨","dynasty":"唐","style":"","life":"","origin":"","seal":"韦","bio":["敬辨，永淳元年官都云县今，后任廖州大首领、检校廖州刺史。诗一首。（《全唐诗》无韦敬辨诗）"],"works":[{"id":"t52-238","title":"澄州无虞县清泰乡都万里六合坚固大宅诗（五言）","kind":"诗"}]}}