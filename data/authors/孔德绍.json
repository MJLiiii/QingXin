{"slug":"孔德绍","name":"孔德绍","dynasty":"唐","style":"","life":"","origin":"","seal":"孔","bio":["孔德绍，会稽人，有清才，事窦建德。初为景城丞，后为内史侍郎，典书檄。建德败，太宗诛之。","诗十二首。"],"works":[{"id":"t41-172","title":"南隐游泉山","kind":"诗"},{"id":"t41-173","title":"行经太华","kind":"诗"},{"id":"t41-174","title":"夜宿荒村","kind":"诗"},{"id":"t41-175","title":"王泽岭遭洪水","kind":"诗"},{"id":"t41-176","title":"登白马山护明寺","kind":"诗"},{"id":"t41-177","title":"送舍利宿定普岩","kind":"诗"},{"id":"t41-178","title":"观太常奏新乐","kind":"诗"},{"id":"t41-179","title":"赋得涉江采芙蓉","kind":"诗"},{"id":"t41-180","title":"赋得华亭鹤","kind":"诗"},{"id":"t41-181","title":"送蔡君知入蜀二首 一","kind":"诗"},{"id":"t41-182","title":"送蔡君知入蜀二首 二","kind":"诗"},{"id":"t41-183","title":"落叶","kind":"诗"},{"id":"t41-184","title":"句","kind":"诗"}]}