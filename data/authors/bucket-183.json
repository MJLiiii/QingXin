{"万回":{"slug":"万回","name":"万回","dynasty":"唐","style":"","life":"","origin":"","seal":"万","bio":["万回，俗姓张，虢州阌乡人。住法云寺。景云二年卒，年八十。","诗一首。（《全唐诗》无万回诗，传据《释氏疑年录》卷四）"],"works":[{"id":"t52-584","title":"歌","kind":"诗"}]},"义忠":{"slug":"义忠","name":"义忠","dynasty":"唐","style":"","life":"","origin":"","seal":"义","bio":["义忠，姓杨，福州福唐县人。嗣大颠，在漳州。咸通十三年十一月卒，年九十二。","诗五首。（《全唐诗》无义忠诗）"],"works":[{"id":"t54-68","title":"答王侍郎讽问黑豆未生芽时颂（题拟）","kind":"诗"},{"id":"t54-69","title":"偈四首 一","kind":"诗"},{"id":"t54-70","title":"偈四首 二","kind":"诗"},{"id":"t54-71","title":"偈四首 三","kind":"诗"},{"id":"t54-72","title":"偈四首 四","kind":"诗"}]},"何敬":{"slug":"何敬","name":"何敬","dynasty":"唐","style":"","life":"","origin":"","seal":"何","bio":[],"works":[{"id":"t43-57","title":"题吉州龙溪","kind":"诗"}]},"史浩":{"slug":"史浩","name":"史浩","dynasty":"宋","style":"","life":"","origin":"","seal":"史","bio":[],"works":[{"id":"c65-606","title":"采莲延遍・采莲令·霞霄上","kind":"词"},{"id":"c65-607","title":"采莲摇捱遍・采莲令·南邻幄丹宫","kind":"词"},{"id":"c65-608","title":"采莲入破・采莲令·璇穹层云上覆","kind":"词"},{"id":"c65-609","title":"采莲衮遍・采莲令·遍此境","kind":"词"},{"id":"c65-610","title":"采莲实催・采莲令·露华霞液","kind":"词"},{"id":"c65-611","title":"采莲衮・采莲令·有珍馔","kind":"词"},{"id":"c65-612","title":"采莲歇拍・采莲令·其间有洞天侣","kind":"词"},{"id":"c65-613","title":"采莲煞衮・采莲令·吾皇喜","kind":"词"},{"id":"c65-614","title":"采莲舞·练光浮","kind":"词"},{"id":"c65-615","title":"采莲舞·蕊沼清冷涓滴水","kind":"词"},{"id":"c65-616","title":"采莲舞·翠盖参差森玉柄","kind":"词"},{"id":"c65-617","title":"采莲舞·草软沙平风掠岸","kind":"词"},{"id":"c65-618","title":"采莲舞·太华峰头冰玉沼","kind":"词"},{"id":"c65-619","title":"采莲舞·珠露漙漙清玉宇","kind":"词"},{"id":"c65-620","title":"采莲舞·彤霞出水弄幽姿","kind":"词"},{"id":"c65-621","title":"采莲舞·蕊宫阆苑","kind":"词"},{"id":"c65-622","title":"太清舞·武陵自古神仙府","kind":"词"},{"id":"c65-623","title":"太清舞·须臾却有人相顾","kind":"词"},{"id":"c65-624","title":"太清舞·当时脱得长城苦","kind":"词"},{"id":"c65-625","title":"太清舞·渔舟之子来何所","kind":"词"},{"id":"c65-626","title":"太清舞·我今来访烟霞侣","kind":"词"},{"id":"c65-627","title":"太清舞·云軿羽幰仙风举","kind":"词"},{"id":"c65-628","title":"太清舞·游尘世"