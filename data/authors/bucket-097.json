id":"t44-27","title":"宛转歌二首 一","kind":"诗"},{"id":"t44-28","title":"宛转歌二首 二","kind":"诗"},{"id":"t44-29","title":"长相思","kind":"诗"},{"id":"t44-30","title":"朝云引","kind":"诗"}]},"郑𬘡":{"slug":"郑𬘡","name":"郑𬘡","dynasty":"唐","style":"字文明","life":"","origin":"","seal":"郑","bio":["郑𬘡，字文明，荥阳人。擢进士、宏词，初为张延赏掌书记，入为起居郎、翰林学士，累迁中书舍人。宪宗立，拜中书侍郎同平章事。","太和中，以太子少傅致仕。𬘡少好学，大历中有高名，后践历华显，出入中外，逾四十年。守道寡欲，不为烜赫事，时推耆德。","集三十卷，今存诗五首。"],"works":[{"id":"t0-672","title":"郊庙歌辞 享太庙乐章 大顺舞","kind":"诗"},{"id":"t17-82","title":"奉和武相公省中宿斋酬李相公见寄","kind":"诗"},{"id":"t17-83","title":"寒夜闻霜钟","kind":"诗"},{"id":"t17-84","title":"奉酬宣上人九月十五日东亭望月见赠因怀紫阁旧游","kind":"诗"},{"id":"t17-85","title":"九日登高怀邵二","kind":"诗"},{"id":"t17-86","title":"享太庙乐章","kind":"诗"},{"id":"t17-87","title":"句","kind":"诗"},{"id":"t53-519","title":"咏诸葛亮（题拟）","kind":"诗"}]},"金车美人":{"slug":"金车美人","name":"金车美人","dynasty":"唐","style":"","life":"","origin":"","seal":"金","bio":[],"works":[{"id":"t48-62","title":"与谢翶赠荅诗 一","kind":"诗"},{"id":"t48-63","title":"与谢翶赠荅诗 二","kind":"诗"},{"id":"t48-64","title":"与谢翶赠荅诗 三","kind":"诗"},{"id":"t48-65","title":"与谢翶赠荅诗 四","kind":"诗"}]},"陈岩":{"slug":"陈岩","name":"陈岩","dynasty":"唐","style":"号九龙军","life":"","origin":"","seal":"陈","bio":["岩，颍川人。黄巢入闽，岩聚众号九龙军。福建观察使郑镒奏为团练副使。","中和四年，岩逐镒自称观察使，朝廷从之。大顺二年卒。诗二句。","（《全唐诗》无陈岩诗，传据《唐方镇年表》卷六）"],"works":[{"id":"t54-254","title":"句","kind":"诗"}]},"顾伟":{"slug":"顾伟","name":"顾伟","dynasty":"唐","style":"","life":"","origin":"","seal":"顾","bio":[],"works":[{"id":"t43-334","title":"云夜听猨吟","kind":"诗"}]},"黄水村":{"slug":"黄水村","name":"黄水村","dynasty":"宋","style":"","life":"","origin":"","seal":"黄","bio":[],"works":[{"id":"c76-458","title":"解连环·凤楼倚倦","kind":"词"}]}}