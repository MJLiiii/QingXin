{"何蓑衣道人":{"slug":"何蓑衣道人","name":"何蓑衣道人","dynasty":"宋","style":"","life":"","origin":"","seal":"何","bio":[],"works":[{"id":"c65-603","title":"临江仙·在世为仙须有分","kind":"词"}]},"卢诰":{"slug":"卢诰","name":"卢诰","dynasty":"唐","style":"","life":"","origin":"","seal":"卢","bio":[],"works":[{"id":"t51-723","title":"寄弟诗（唐末，卢拾遗议与郑中舍延休作赘，三年不归陕下。其兄诰以诗让之，诗意甚乖昆仲之礼。卢议呈其太山中舍，并女遣之。诰寄弟诗曰：）","kind":"诗"}]},"宋之问":{"slug":"宋之问","name":"宋之问","dynasty":"唐","style":"字延清","life":"","origin":"","seal":"宋","bio":["宋之问，一名少连，字延清，虢州弘农人。弱冠知名，初征，令与杨炯分直内教，俄授雒州参军，累转尚方监丞，预修《三教珠英》。后坐附张易之，左迁泷州参军。","武三思用事，起为鸿胪丞。景龙中，再转考功员外郎，时中宗增置修文馆学士，之问与薛稷、杜审言首膺其选，转越州长史。睿宗即位，徙钦州，寻赐死。","集十卷，今编诗三卷。宋之问，一名少连，字延清，虢州弘农人。弱冠知名，初征，令与杨炯分直内教，俄授雒州参军，累转尚方监丞，预修三教珠英，后坐附张易之，左迁泷州参军，武三思用事，起为鸿胪丞。","景龙中，再转考功员外郎，时中宗增置修文馆学士，之问与薛稷、杜审言首膺其选，转越州长史。睿宗即位，徙钦州，寻赐死。集十卷，今编诗三卷。","宋之问，字延清，虢州弘农人。弱冠知名，尤善五言诗。以附张易之、武三思，配徙钦州，先天元年赐死。","补诗五首。"],"works":[{"id":"t1-32","title":"相和歌辞 江南曲","kind":"诗"},{"id":"t1-111","title":"相和歌辞 王子乔","kind":"诗"},{"id":"t1-599","title":"琴曲歌辞 绿竹引","kind":"诗"},{"id":"t3-208","title":"息夫人","kind":"诗"},{"id":"t3-209","title":"初到陆浑山庄","kind":"诗"},{"id":"t3-210","title":"夜饮东亭","kind":"诗"},{"id":"t3-211","title":"芳树","kind":"诗"},{"id":"t3-212","title":"送赵六贞固","kind":"诗"},{"id":"t3-213","title":"题张老松树","kind":"诗"},{"id":"t3-214","title":"别之望后独宿蓝田山庄","kind":"诗"},{"id":"t3-215","title":"浣纱篇赠陆上人","kind":"诗"},{"id":"t3-216","title":"雨从箕山来","kind":"诗"},{"id":"t3-217","title":"初至崖口","kind":"诗"},{"id":"t3-218","title":"自湘源至潭州衡山县","kind":"诗"},{"id":"t3-219","title":"入崖口五渡寄李适","kind":"诗"},{"id":"t3-220","title":"洞庭湖","kind":"诗"},{"id":"t3-221","title":"景龙四年春祠海","kind":"诗"},{"id":"t3-222","title":"温泉庄卧病寄杨七炯","kind":"诗"},{"id":"t3-223","title":"荅田征君","kind":"诗"},{"id":"t3-224","title":"自衡阳至韶州谒能禅师","kind":"诗"},{"id":"t3-225","title":"见南山夕阳召监师不至","kind":"诗"},{"id":"t3-226","title":"游法华寺","kind":"诗"},{"id":"t3-227","title":"宿云门寺","kind":"诗"},{"id":"t3-228","title":"春湖古意","kind":"诗"},{"id":"t3-229","title":"游陆浑南山自歇马岭到枫香林以诗代书荅李舍人适","kind":"诗"},{"id":"t3-230","title