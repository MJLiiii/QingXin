{"伏牛上人":{"slug":"伏牛上人","name":"伏牛上人","dynasty":"唐","style":"","life":"","origin":"","seal":"伏","bio":["伏生上人，即释自在，事过迹详《宋高僧传》卷十一《唐洛京伏生山自在传》，俗姓李，吴兴人，在径山出家，从道一受法，元和中居洛下香山。「所著《三伤歌》，辞里俱美，警发迷蒙，有益于代」。长庆元年卒，年八十一。","《鉴诫录》云其诗前蜀时为人所颂，其事《宋高僧传》亦载之，非云其为王蜀时僧人。原收入前蜀卷，今移此。"],"works":[{"id":"t51-350","title":"三伤颂","kind":"诗"},{"id":"t51-351","title":"三伤颂 其一","kind":"诗"},{"id":"t51-352","title":"三伤颂 其二","kind":"诗"},{"id":"t51-353","title":"三伤颂 其三","kind":"诗"}]},"吴某":{"slug":"吴某","name":"吴某","dynasty":"宋","style":"","life":"","origin":"","seal":"吴","bio":[],"works":[{"id":"c76-394","title":"失调名·剪罗幡儿","kind":"词"},{"id":"c76-395","title":"南乡子·楼台里","kind":"词"},{"id":"c76-396","title":"南乡子·乍卷珠帘新燕入","kind":"词"},{"id":"c76-397","title":"多丽·几声天外归鸿","kind":"词"},{"id":"c76-398","title":"渔家傲·鶗鴂一声初报晓","kind":"词"}]},"周𣸣":{"slug":"周𣸣","name":"周𣸣","dynasty":"唐","style":"","life":"","origin":"","seal":"周","bio":[],"works":[{"id":"t43-46","title":"重门曲","kind":"诗"},{"id":"t43-47","title":"山下水","kind":"诗"},{"id":"t43-48","title":"逢邻女","kind":"诗"},{"id":"t43-49","title":"废宅","kind":"诗"},{"id":"t56-330","title":"红梅","kind":"诗"}]},"张仁宝":{"slug":"张仁宝","name":"张仁宝","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"t47-994","title":"题芭蕉叶上","kind":"诗"}]},"张格":{"slug":"张格","name":"张格","dynasty":"唐","style":"字义师","life":"","origin":"","seal":"张","bio":["张格，字义师，河间人。仕蜀，为翰林学士，拜中书侍郎同平章事，累加右仆射、太傅。诗一首。"],"works":[{"id":"t42-509","title":"寄禅月大师","kind":"诗"},{"id":"t56-254","title":"感皇恩","kind":"诗"}]},"慧宣":{"slug":"慧宣","name":"慧宣","dynasty":"唐","style":"","life":"","origin":"","seal":"慧","bio":["慧宣，常州法师，与道恭同召。诗三首。"],"works":[{"id":"t44-671","title":"奉和窦使君同恭法师咏高僧二首 竺佛图澄","kind":"诗"},{"id":"t44-672","title":"奉和窦使君同恭法师咏高僧二首 释僧肇","kind":"诗"},{"id":"t44-673","title":"秋日游东山寺寻殊昙二法师","kind":"诗"},{"id":"t44-674","title":"句","kind":"诗"}]},"智晖":{"slug":"智晖","name":"智晖","dynasty":"唐","style":"","life":"","origin":"","seal":"智","bio":["智晖，俗姓高，咸秦人。干化四年，自江表移住洛阳中滩浴院。显德三年卒。","诗一首。（《全唐诗》无智晖诗，传据《宋高僧传》卷二八、《景