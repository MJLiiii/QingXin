{"姚嵘":{"slug":"姚嵘","name":"姚嵘","dynasty":"唐","style":"","life":"","origin":"","seal":"姚","bio":[],"works":[{"id":"t48-294","title":"题大梁临汴驿","kind":"诗"}]},"崔玄亮":{"slug":"崔玄亮","name":"崔玄亮","dynasty":"唐","style":"字晦叔","life":"","origin":"","seal":"崔","bio":["崔玄亮，字晦叔，磁州人。贞元中，与元白同登第。宪宗时，为监察御史，历密、歙、湖三州刺史。","太和中，由谏议大夫迁散骑常侍，终虢州刺史。有《三州倡和集》，今存诗二首。"],"works":[{"id":"t24-930","title":"和白乐天","kind":"诗"},{"id":"t24-931","title":"临终诗","kind":"诗"},{"id":"t24-932","title":"句","kind":"诗"},{"id":"t53-606","title":"十二月四日寄乐天（题拟）","kind":"诗"},{"id":"t53-607","title":"登第后自咏（题拟）","kind":"诗"}]},"张连":{"slug":"张连","name":"张连","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张连，闽太常博士。"],"works":[{"id":"t55-841","title":"添撰享太庙乐章 敬宗庙奏","kind":"诗"},{"id":"t55-842","title":"添撰享太庙乐章 文宗庙奏","kind":"诗"}]},"晁祖道":{"slug":"晁祖道","name":"晁祖道","dynasty":"唐","style":"","life":"","origin":"","seal":"晁","bio":[],"works":[{"id":"t56-365","title":"咏屏风","kind":"诗"}]},"权审":{"slug":"权审","name":"权审","dynasty":"唐","style":"字子询","life":"","origin":"","seal":"权","bio":["权审，字子询，天水人，累官常侍。诗二首。"],"works":[{"id":"t30-154","title":"题山院","kind":"诗"},{"id":"t30-155","title":"绝句","kind":"诗"}]},"柳浑":{"slug":"柳浑","name":"柳浑","dynasty":"唐","style":"字夷旷","life":"","origin":"","seal":"柳","bio":["柳浑，字夷旷，一字惟深，本名载，襄州人。天宝初，擢进士第。大历中，累官至尚书右丞。","贞元三年，以兵部侍郎同中书门下平章事。集十卷，今存诗一首。"],"works":[{"id":"t9-522","title":"牡丹","kind":"诗"}]},"澄观":{"slug":"澄观","name":"澄观","dynasty":"唐","style":"","life":"","origin":"","seal":"澄","bio":["澄观，姓夏侯氏，越州山阴人。天台宗名僧，住五台山清凉寺。元和年卒，年七十余。","诗一首。（《全唐诗》无澄观诗，传据《宋高僧传》卷五）"],"works":[{"id":"t53-163","title":"答复礼禅师《真妄偈》（题拟）","kind":"诗"}]},"狄归昌":{"slug":"狄归昌","name":"狄归昌","dynasty":"唐","style":"","life":"","origin":"","seal":"狄","bio":["狄归昌，官侍郎。光化中，历尚书左丞。诗一首。"],"works":[{"id":"t38-625","title":"题马嵬驿","kind":"诗"}]},"王绩":{"slug":"王绩","name":"王绩","dynasty":"唐","style":"字无功 · 号东皐子","life":"","origin":"","seal":"王","bio":["王绩，字无功，绛州龙门人，文中子之弟。隋末，授秘书省正字，不乐在朝，求为六合丞，嗜酒不任事，寻还乡里。唐高祖武德初，以前官待诏门下省，时太乐署史焦革家善酿，绩求为丞。","革死，弃官归东皐著书，号东皐子。集五卷，今编诗一卷。王绩，字无功，绛州龙门人，文中子之弟。","隋末，授秘书省正字，不乐在朝，求为六合丞，嗜酒不任事，寻还乡里。唐高祖武德初，以前官待诏门下省，时太乐署史焦革家善酿，绩求为丞。革死，弃官归东臯著书，号东臯子，集五卷，今编诗一卷。"],"works":[{"id":"t2-607","title":"古意六首 一","kind":"诗"},{"id":"t2-608","title":"古意六首 二","kind":"诗"},{"id":"t2-609","title":"古意六首 三","kind":"诗"},{"id":"t2-610","title":"古意六首 四","kind":"诗"},{"id":"t2-611","title":"古意六首 五","kind":"诗"},{"id":"t2-612","title":"古意六首 六","kind":"诗"},{"id":"t2-613","title":"石竹咏","kind":"诗"},{"id":"t2-614","title":"田家三首 一","kind":"诗"},{"id":"t2-615","title":"田家三首 二","kind":"诗"},{"id":"t2-616","title":"田家三首 三","kind":"诗"},{"id":"t2-617","title":"赠李征君大寿","kind":"诗"},{"id":"t2-618","title":"山中敍志","kind":"诗"},{"id":"t2-619","title":"赠梁公","kind":"诗"},{"id":"t2-620","title":"薛记室收过庄见寻率题古意以赠","kind":"诗"},{"id":"t2-621","title":"晚年敍志示翟处士","kind":"诗"},{"id":"t2-622","title":"春日","kind":"诗"},{"id":"t2-623","title":"采药","kind":"诗"},{"id":"t2-624","title":"在京思故园见乡人问","kind":"诗"},{"id":"t2-625","title":"春桂问荅二首 一","kind":"诗"},{"id":"t2-626","title":"春桂问荅二首 二","kind":"诗"},{"id":"t2-627","title":"北山","kind":"诗"},{"id":"t2-628","title":"野望","kind":"诗"},{"id":"t2-629","title":"赠程处士","kind":"诗"},{"id":"t2-630","title":"九月九日赠崔使君善为","kind":"诗"},{"id":"t2-631","title":"独坐","kind":"诗"},{"id":"t2-632","title":"游仙四首 一","kind":"诗"},{"id":"t2-633","title":"游仙四首 二","kind":"诗"},{"id":"t2-634","title":"游仙四首 三","kind":"诗"},{"id":"t2-635","title":"游仙四首 四","kind":"诗"},{"id":"t2-636","title":"策杖寻隐士","kind":"诗"},{"id":"t2-637","title":"赠学仙者","kind":"诗"},{"id":"t2-638","title":"黄颊山","kind":"诗"},{"id":"t2-639","title":"建德破后入长安咏秋蓬示辛学士","kind":"诗"},{"id":"t2-640","title":"过酒家五首 一","kind":"诗"},{"id":"t2-641","title":"过酒家五首 二","kind":"诗"},{"id":"t2-642","title":"过酒家五首 三","kind":"诗"},{"id":"t2-643","title":"过酒家五首 四","kind":"诗"},{"id":"t2-644","title":"过酒家五首 五","kind":"诗"},{"id":"t2-645","title":"夜还东溪","kind":"诗"},{"id":"t2-646","title":"山中别李处士","kind":"诗"},{"id":"t2-647","title":"初春","kind":"诗"},{"id":"t2-648","title":"醉后","kind":"诗"},{"id":"t2-649","title":"题酒店壁","kind":"诗"},{"id":"t2-650","title":"戏题卜铺壁","kind":"诗"},{"id":"t2-651","title":"尝春酒","kind":"诗"},{"id":"t2-652","title":"独酌","kind":"诗"},{"id":"t2-653","title":"秋夜喜遇王处士","kind":"诗"},{"id":"t2-654","title":"山夜调琴","kind":"诗"},{"id":"t2-655","title":"看酿酒","kind":"诗"},{"id":"t2-656","title":"食后","kind":"诗"}]},"程嵩":{"slug":"程嵩","name":"程嵩","dynasty":"唐","style":"字明甫","life":"","origin":"","seal":"程","bio":["程嵩，字明甫，延津人。初举不第，遂不肯事场屋。年至八十余。","诗二句。（《全唐诗》无程嵩诗）"],"works":[{"id":"t55-981","title":"无题","kind":"诗"},{"id":"t55-982","title":"八十后作（题拟）","kind":"诗"}]},"窦群":{"slug":"窦群","name":"窦群","dynasty":"唐","style":"字丹列","life":"","origin":"","seal":"窦","bio":["窦群，字丹列，兄弟皆擢进士第，独群以处士客于毘陵。韦夏卿荐之，为左拾遗，转膳部员外郎，兼侍御史，知杂事，出为唐州刺史。武元衡、李吉甫共引之，召拜吏部郎中。","元衡辅政，复荐为中丞。后出为湖南观察使，改黔中，坐事，贬开州刺史。稍迁容管经略使，召还卒。","诗二十三首。"],"works":[{"id":"t14-277","title":"雪中遇直","kind":"诗"},{"id":"t14-278","title":"东山月下怀友人","kind":"诗"},{"id":"t14-279","title":"时兴","kind":"诗"},{"id":"t14-280","title":"题剑","kind":"诗"},{"id":"t14-281","title":"黔中书事","kind":"诗"},{"id":"t14-282","title":"冬日晓思寄杨二十七炼师","kind":"诗"},{"id":"t14-283","title":"贞元末东院尝接事今西川武相公于兹三周谬领中宪徘徊厅宇多获文篇夏日即事因寄四韵","kind":"诗"},{"id":"t14-284","title":"北地","kind":"诗"},{"id":"t14-285","title":"雨后月下寄怀羊二十七资州","kind":"诗"},{"id":"t14-286","title":"奉酬西川武相公晨兴赠友见示之作","kind":"诗"},{"id":"t14-287","title":"晨游昌师院","kind":"诗"},{"id":"t14-288","title":"同王晦伯朱遐景宿慧山寺","kind":"诗"},{"id":"t14-289","title":"草堂夜坐","kind":"诗"},{"id":"t14-290","title":"经潼关赠宇文十","kind":"诗"},{"id":"t14-291","title":"观画鹤","kind":"诗"},{"id":"t14-292","title":"晚自台中归永宁里南望山色怅然有怀呈上右司十一兄","kind":"诗"},{"id":"t14-293","title":"中牟县经鲁公庙","kind":"诗"},{"id":"t14-294","title":"初入谏司喜家室至","kind":"诗"},{"id":"t14-295","title":"春雨","kind":"诗"},{"id":"t14-296","title":"送内弟袁德师","kind":"诗"},{"id":"t14-297","title":"赠刘大兄院长","kind":"诗"},{"id":"t14-298","title":"假日寻花","kind":"诗"},{"id":"t14-299","title":"自京将赴黔南","kind":"诗"}]},"胡翼龙":{"slug":"胡翼龙","name":"胡翼龙","dynasty":"宋","style":"","life":"","origin":"","seal":"胡","bio":[],"works":[{"id":"c74-325","title":"宴清都·梦雨随春远","kind":"词"},{"id":"c74-326","title":"徵招·苹花又绿江南岸","kind":"词"},{"id":"c74-327","title":"八声甘州·甚年年","kind":"词"},{"id":"c74-328","title":"洞仙歌·半栏花雨","kind":"词"},{"id":"c74-329","title":"满庭芳·秋彻檐花","kind":"词"},{"id":"c74-330","title":"鹧鸪天·六曲银屏梦隔云","kind":"词"},{"id":"c74-331","title":"少年游·晓莺声脆雨花乾","kind":"词"},{"id":"c74-332","title":"霓裳中序第一·江郊雨正歇","kind":"词"},{"id":"c74-333","title":"夜飞鹊・夜飞鹊慢·星桥度情处","kind":"词"},{"id":"c74-334","title":"西江月·水霁芹香燕觜","kind":"词"},{"id":"c74-335","title":"踏莎行·合数冰莲","kind":"词"},{"id":"c74-336","title":"南歌子·山枕莺声晓","kind":"词"},{"id":"c74-337","title":"长相思·南山钟","kind":"词"}]},"薛苹":{"slug":"薛苹","name":"薛苹","dynasty":"唐","style":"","life":"","origin":"","seal":"薛","bio":["苹，河中宝鼎人。少以吏事进，建中三年为长安令，历虢州刺史。永贞元年，以课最擢湖南观察使。","元和三年，迁浙东观察使。元和五年，以治行调浙西。除左散骑常侍，年七十致仕，元和十四年卒。","诗一首。（《全唐诗》无薛苹诗，事迹据《旧唐书》卷一八五《良吏传》本传、卷十二《德宗纪》、卷十四《宪宗纪》、岑仲勉《唐集质疑·薛苹与薛平》）"],"works":[{"id":"t53-451","title":"禹庙神座顷服金紫苹自到镇申牒礼司重加衮冕今因祈雨偶成八韵","kind":"诗"}]},"许瑶":{"slug":"许瑶","name":"许瑶","dynasty":"唐","style":"","life":"","origin":"","seal":"许","bio":["许瑶，官御史。诗一首。"],"works":[{"id":"t10-65","title":"题怀素上人草书","kind":"诗"}]},"赵彦伯":{"slug":"赵彦伯","name":"赵彦伯","dynasty":"唐","style":"","life":"","origin":"","seal":"赵","bio":["赵彦伯，中宗时弘文馆学士。诗三首。赵彦伯，中宗时弘文馆学士，诗三首。"],"works":[{"id":"t5-303","title":"奉和九日幸临渭亭登高应制得花字","kind":"诗"},{"id":"t5-304","title":"从宴桃花园咏桃花应制","kind":"诗"},{"id":"t5-305","title":"苑中遇雪应制","kind":"诗"},{"id":"t48-794","title":"和九月九日登慈恩寺浮图应制","kind":"诗"}]}}