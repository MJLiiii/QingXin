{
  "id": "t7-31",
  "notes": [
    {
      "term": "上人",
      "def": "对 僧人的敬称。"
    },
    {
      "term": "孤云、野鹤",
      "def": "都用来比喻方外上人。将：与共。"
    },
    {
      "term": "沃洲山",
      "def": "在浙江新昌县东，上有支遁岭，放鹤峰、养马坡，相传为晋代名僧支遁放鹤、养马之地。时人：指时俗之人。"
    },
    {
      "term": "将",
      "def": "伴随。"
    }
  ],
  "translation": [
    "孤云陪伴着野鹤，怎么能在人间居住。不要买下沃洲山，现在已经有人知道那儿了。"
  ],
