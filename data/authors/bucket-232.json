{"乐伸":{"slug":"乐伸","name":"乐伸","dynasty":"唐","style":"","life":"","origin":"","seal":"乐","bio":[],"works":[{"id":"t43-272","title":"闰月定四时","kind":"诗"}]},"僧可":{"slug":"僧可","name":"僧可","dynasty":"唐","style":"","life":"","origin":"","seal":"僧","bio":[],"works":[{"id":"t56-594","title":"鹤诗","kind":"诗"}]},"南唐先主李昪":{"slug":"南唐先主李昪","name":"南唐先主李昪","dynasty":"唐","style":"字正伦","life":"","origin":"","seal":"南","bio":["昪，字正伦，徐州人。杨行密养为子，以乞徐温。初冒姓徐，名知诰。","代温秉政，受杨氏禅，僭帝位，谥烈祖。传国三十九年。诗一篇。"],"works":[{"id":"t0-316","title":"咏灯","kind":"诗"}]},"危稹":{"slug":"危稹","name":"危稹","dynasty":"宋","style":"","life":"","origin":"","seal":"危","bio":[],"works":[{"id":"c70-752","title":"水龙吟·洛阳九老图中","kind":"词"},{"id":"c70-753","title":"渔家傲·老去诸馀情味浅","kind":"词"},{"id":"c70-754","title":"沁园春·籍甚声名","kind":"词"}]},"周邦彦":{"slug":"周邦彦","name":"周邦彦","dynasty":"宋","style":"字美成 · 号清真居士","life":"","origin":"钱塘（今浙江杭州）","seal":"周","bio":["(1056－1121) 字美成，号清真居士，钱塘 (今浙江杭州) 人。元丰中，献《汴都赋》，自太学生一命为太学正。居五年，出为庐州教授，知溧水县，还京为国子主簿。","哲宗召对，除秘书省正字，历校书郎。徽宗时，仕至徽猷阁待制，提举大晟府，出知顺昌府，徙处州，提举南京鸿庆宫，卒。邦彦精通音律，在大晟府审古乐、制新调，对词乐的提高和发展有一定贡献。","其词多写闺情、旅思，亦有感慨身世及咏物之作。词风典丽精工，形象丰满，格律严谨，善于融化前人诗句入词而浑然天成。著有《清真居士文集》，已佚。","词有《清真集》，陈元龙为注"],"works":[{"id":"c61-966","title":"瑞龙吟·章台路","kind":"词"},{"id":"c61-967","title":"锁窗寒・琐寒窗·暗柳啼鸦","kind":"词"},{"id":"c61-968","title":"风流子·新绿小池塘","kind":"词"},{"id":"c61-969","title":"渡江云·晴岚低楚甸","kind":"词"},{"id":"c61-970","title":"应天长·条风布暖","kind":"词"},{"id":"c61-971","title":"荔枝香近・荔枝香·照水残红零乱","kind":"词"},{"id":"c61-972","title":"荔枝香近・荔枝香·夜来寒侵酒席","kind":"词"},{"id":"c61-973","title":"还京乐·禁烟近","kind":"词"},{"id":"c61-974","title":"扫地花・扫地游·晓阴翳日","kind":"词"},{"id":"c61-975","title":"解连环·怨怀无托","kind":"词"},{"id":"c61-976","title":"玲珑四犯·秾李夭桃","kind":"词"},{"id":"c61-977","title":"丹凤吟·迤逦春光无赖","kind":"词"},{"id":"c61-978","title":"满江红·昼日移阴","kind":"词"},{"id":"c61-979","title":"瑞鹤仙·悄郊原带郭","kind":"词"},{"id":"c61-980","title":"西平乐·稚柳苏晴","kind":"词"},{"id":"c61-981","title":"浪涛沙・浪淘沙·昼阴重","kind":"词"},{"id":"c61-982","title":"忆旧游·记愁横浅黛","kind":