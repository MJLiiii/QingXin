gin":"","seal":"陈","bio":["陈润，大历间人，终坊州鄜城县令。诗八首。"],"works":[{"id":"t14-377","title":"宿北乐馆","kind":"诗"},{"id":"t14-378","title":"东都所居寒食下作","kind":"诗"},{"id":"t14-379","title":"登西灵塔","kind":"诗"},{"id":"t14-380","title":"送骆征君","kind":"诗"},{"id":"t14-381","title":"赋得浦外虹送人","kind":"诗"},{"id":"t14-382","title":"赋得秋河曙耿耿","kind":"诗"},{"id":"t14-383","title":"赋得池塘生春草","kind":"诗"},{"id":"t14-384","title":"阙题","kind":"诗"},{"id":"t49-969","title":"句","kind":"诗"},{"id":"t51-316","title":"药（一见《宋之问集》）","kind":"诗"},{"id":"t53-21","title":"题潘岳六城南庄庄是源赞善处","kind":"诗"}]},"韦庄":{"slug":"韦庄","name":"韦庄","dynasty":"唐","style":"字端己","life":"","origin":"京兆杜凌（今陕西西安东南）","seal":"韦","bio":["(约 836－910) 字端己，京兆杜凌 (今陕西西安东南) 人。乾宁元年 (894) 进士，任校书郎。后仕蜀，官吏部侍郎兼平章事。","在成都时，曾居杜甫草堂故址，故名其集曰《浣花集》。词与温庭筠齐名，称温、韦。然风格有别。","韦能运密入疏，寓浓于淡，多用白描手法写闺情离愁和游乐生活，语言清丽。词存五十五首，在《花间集》、《尊前集》、《金奁集》中，今有王国维辑《浣花词》一卷。"],"works":[{"id":"t1-701","title":"杂曲歌辞 少年行","kind":"诗"},{"id":"t1-830","title":"杂曲歌辞 古离别","kind":"诗"},{"id":"t39-86","title":"章台夜思","kind":"诗"},{"id":"t39-87","title":"延兴门外作","kind":"诗"},{"id":"t39-88","title":"刘得仁墓","kind":"诗"},{"id":"t39-89","title":"下第题青龙寺僧房","kind":"诗"},{"id":"t39-90","title":"虢州涧东村居作","kind":"诗"},{"id":"t39-91","title":"送日本国僧敬龙归","kind":"诗"},{"id":"t39-92","title":"对酒","kind":"诗"},{"id":"t39-93","title":"尹喜宅","kind":"诗"},{"id":"t39-94","title":"途中望雨怀归","kind":"诗"},{"id":"t39-95","title":"古离别","kind":"诗"},{"id":"t39-96","title":"柳谷道中作却寄","kind":"诗"},{"id":"t39-97","title":"灞陵道中作","kind":"诗"},{"id":"t39-98","title":"秋日早行","kind":"诗"},{"id":"t39-99","title":"叹落花","kind":"诗"},{"id":"t39-100","title":"宫怨","kind":"诗"},{"id":"t39-101","title":"关河道中","kind":"诗"},{"id":"t39-102","title":"题盘豆驿水馆后轩","kind":"诗"},{"id":"t39-103","title":"梁氏水斋","kind":"诗"},{"id":"t39-104","title":"曲池作","kind":"诗"},{"id":"t39-105","title":"嘉会里闲居","kind":"诗"},{"id":"t39-106","title":"夏夜","kind":"诗"},{"id":"t39-107","title":"早发","kind":"诗"},{"id":"t39-108","title":"寓言","kind":"诗"},{"id":"t39-109","title":"对雪献薛常侍","kind":"诗"},{"id":"