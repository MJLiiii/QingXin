t4-959","title":"奉和幸安乐公主山庄应制","kind":"诗"},{"id":"t4-960","title":"兴庆池侍宴应制","kind":"诗"},{"id":"t4-961","title":"夜宴安乐公主宅","kind":"诗"},{"id":"t4-962","title":"饯唐永昌","kind":"诗"}]},"魏元忠":{"slug":"魏元忠","name":"魏元忠","dynasty":"唐","style":"","life":"","origin":"","seal":"魏","bio":["魏元忠，宋州人。初为太学生，累举不调。时有左史盩厔人江融撰九州设险图，备载古今用兵成败之事，元忠就传其术。","仪凤中，上封事驭吐蕃，授秘书正字。则天时，以平徐敬业功擢司刑，后拜凤阁侍郎，同平章事，独不附二张。中宗朝，迁中书令，以预节愍太子诛武三思谋，贬渠州司马。","诗二首。"],"works":[{"id":"t2-928","title":"修书院学士奉勅宴梁王宅","kind":"诗"},{"id":"t2-929","title":"银潢宫侍宴应制","kind":"诗"},{"id":"t52-504","title":"武三思席上咏绮娘（题拟）","kind":"诗"}]},"黄某":{"slug":"黄某","name":"黄某","dynasty":"宋","style":"","life":"","origin":"","seal":"黄","bio":[],"works":[{"id":"c70-965","title":"浪淘沙·八十加三迎九十","kind":"词"}]}}