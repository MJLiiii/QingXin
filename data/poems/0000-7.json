[{"id":"t0-700","title":"郊庙歌辞 仪坤庙乐章 肃和","rhythmic":null,"author":"张齐贤","authorSlug":"张齐贤","dynasty":"唐","kind":"shi","paragraphs":["祼圭既濯，郁鬯既陈。","画幕云举，黄流玉醇。","仪充献酌，礼盛众禋。","地察惟孝，愉焉飨亲。"]},{"id":"t0-701","title":"郊庙歌辞 仪坤庙乐章 雍和","rhythmic":null,"author":"郑善玉","authorSlug":"郑善玉","dynasty":"唐","kind":"shi","paragraphs":["酌郁既灌，芗萧方爇。","笾豆静器，簠簋芬飶。","鱼腊荐美，牲牷表洁。","是戢是将，载迎载列。"]},{"id":"t0-702","title":"郊庙歌辞 仪坤庙乐章 昭升","rhythmic":null,"author":"薛稷","authorSlug":"薛稷","dynasty":"唐","kind":"shi","paragraphs":["阳灵配德，阴魄昭升。","尧坛凤下，汉室龙兴。","伣天作对，前旒是凝。","化行南国，道盛西陵。","造舟集灌，无德而称。","我粢既絜，我醴既澄。","阴阴灵庙，光灵若凭。","德馨惟享，孝思烝烝。"]},{"id":"t0-703","title":"郊庙歌辞 仪坤庙乐章 坤贞","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["乾道既亨，坤元以贞。","肃雍攸在，辅佐斯成。","外睦九族，内光一庭。","克生睿哲，祚我休明。","钦若徽范，悠哉淑灵。","建兹清宫，于彼上京。","缩茅以献，絜秬惟馨。","实受其福，期乎亿龄。"]},{"id":"t0-704","title":"郊庙歌辞 仪坤庙乐章 寿和","rhythmic":null,"author":"徐坚","authorSlug":"徐坚","dynasty":"唐","kind":"shi","paragraphs":["於穆清庙，肃雍严祀。","合福受厘，介以繁[祉]。"]},{"id":"t0-705","title":"郊庙歌辞 仪坤庙乐章 舒和","rhythmic":null,"author":"胡雄","authorSlug":"胡雄","dynasty":"唐","kind":"shi","paragraphs":["送文迎武递参差，一始一终光圣仪。","四海生人歌有庆，千龄孝享肃无亏。"]},{"id":"t0-706","title":"郊庙歌辞 仪坤庙乐章 安和","rhythmic":null,"author":"刘子玄","authorSlug":"刘子玄","dynasty":"唐","kind":"shi","paragraphs":["妙筭申帷幄，神谋及庙庭。","两阶文物备，七德武功成。","校猎长杨苑，屯军细柳营。","将军献凯入，歌舞溢重城。"]},{"id":"t0-707","title":"郊庙歌辞 仪坤庙乐章 雍和","rhythmic":null,"author":"员半千","authorSlug":"员半千","dynasty":"唐","kind":"shi","paragraphs":["孝享云毕，惟彻有章。","云感玄羽，风凄素商。","瞻望神座，祗恋匪遑。","礼终乐阕，肃雍锵锵。"]},{"id":"t0-708","title":"郊庙歌辞 仪坤庙乐章 永和","rhythmic":null,"author":"祝钦明","authorSlug":"祝钦明","dynasty":"唐","kind":"shi","paragraphs":["閟宫实实，清庙微微。","降格无象，馨香有依。","式昭纂庆，方融嗣徽。","明禋是享，神保聿归。"]},{"id":"t0-709","title":"郊庙歌辞 仪坤庙乐章 迎神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["月灵降德，坤元授光。","娥英比秀，任姒均芳。","瑶台荐祉，金屋延祥。","迎神有乐，歆此嘉芗。"]},{"id":"t0-710","title":"郊庙歌辞 仪坤庙乐章 送神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["玉帛仪大，金丝奏广。","灵应有孚，冥征不爽。","降彼休福，歆兹禋享。","送乐有章，神麾其上。"]},{"id":"t0-711","title":"郊庙歌辞 昭德皇后庙乐章 永和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["穆清庙，荐严禋。","昭礼备，和乐新。","望灵光，集元辰。","祚无极，享万春。"]},{"id":"t0-712","title":"郊庙歌辞 昭德皇后庙乐章 肃和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["诚心达，娱乐分。","升箫膋，郁氛氲。","茅既缩，鬯既薰。","后来思，福如云。"]},{"id":"t0-713","title":"郊庙歌辞 昭德皇后庙乐章 雍和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["我将我享，尽明而诚。","载芬黍稷，载涤牺牲。","懿矣元良，万邦以贞。","心乎爱敬，若覩容声。"]},{"id":"t0-714","title":"郊庙歌辞 昭德皇后庙乐章 坤元","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["於穆先后，丽圣称崇。","母临万宇，道[被]六宫。","昌时协庆，理内成功。","殷荐明德，传芳国风。"]},{"id":"t0-715","title":"郊庙歌辞 昭德皇后庙乐章 寿和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["工祝致告，徽音不遐。","酒醴咸旨，馨香具嘉。","受厘献祉，永庆邦家。"]},{"id":"t0-716","title":"郊庙歌辞 昭德皇后庙乐章 舒和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["金枝羽部彻清歌，瑶台肃穆笙磬罗。","谐音遍响合明意，万类昭融灵应多。"]},{"id":"t0-717","title":"郊庙歌辞 昭德皇后庙乐章 凯安","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["辰位列四星，帝功参十乱。","进贤勤内辅，扈跸清多难。","承天厚载均，并耀宵光璨。","留徽蔼前躅，万古披图焕。"]},{"id":"t0-718","title":"郊庙歌辞 昭德皇后庙乐章 雍和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["公尸既起，享礼载终。","称歌进彻，尽敬繇衷。","泽流惠下，大小咸同。"]},{"id":"t0-719","title":"郊庙歌辞 昭德皇后庙乐章 永和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["昭事终，幽享余。","移月御，返仙居。","璇庭寂，灵幄虚。","顾裴回，感皇储。"]},{"id":"t0-720","title":"郊庙歌辞 让皇帝庙乐章 迎神","rhythmic":null,"author":"李舒","authorSlug":"李舒","dynasty":"唐","kind":"shi","paragraphs":["皇矣天宗，德先王季。","因心则友，克让以位。","爰命有司，式遵前志。","神其降灵，昭飨祀事。"]},{"id":"t0-721","title":"郊庙歌辞 让皇帝庙乐章 奠币","rhythmic":null,"author":"李舒","authorSlug":"李舒","dynasty":"唐","kind":"shi","paragraphs":["惟帝时若，去而上仙。","祀用商舞，乐备宫悬。","白璧加荐，玄𫄸告虔。","子孙拜后，承兹吉蠲。"]},{"id":"t0-722","title":"郊庙歌辞 让皇帝庙乐章 迎俎","rhythmic":null,"author":"李舒","authorSlug":"李舒","dynasty":"唐","kind":"shi","paragraphs":["祀盛体荐，礼协粢盛。","方周假庙，用鲁纯牲。","捧彻祗敬，击拊和鸣。","受厘归胙，既戒而平。"]},{"id":"t0-723","title":"郊庙歌辞 让皇帝庙乐章 酌献","rhythmic":null,"author":"李舒","authorSlug":"李舒","dynasty":"唐","kind":"shi","paragraphs":["八音具举，三寿既盥。","洁兹宗彝，瑟彼圭瓒。","兰肴重错，椒醑飘散。","降胙维城，永为藩翰。"]},{"id":"t0-724","title":"郊庙歌辞 让皇帝庙乐章 亚献终献","rhythmic":null,"author":"李舒","authorSlug":"李舒","dynasty":"唐","kind":"shi","paragraphs":["秩礼有序，和音既同。","九仪不忒，三揖将终。","孝感藩后，相维辟公。","四时之典，永永无穷。"]},{"id":"t0-725","title":"郊庙歌辞 让皇帝庙乐章 送神","rhythmic":null,"author":"李舒","authorSlug":"李舒","dynasty":"唐","kind":"shi","paragraphs":["奠献已事，昏昕载分。","风摇雨散，灵卫𬘡缊。","龙驾帝服，上腾五云。","泮宫复閟，寂寞无闻。"]},{"id":"t0-726","title":"郊庙歌辞 享隐太子庙乐章 诚和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["道閟鹤关，运缠鸠里。","门集大命，俾歆嘉祀。","礼亚六瑚，诚殚二簋。","有诚颙若，神斯戾止。"]},{"id":"t0-727","title":"郊庙歌辞 享隐太子庙乐章 肃和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["岁肇春宗，干开震长。","瑶山既寂，戾园斯享。","玉肃其事，物昭其象。","弦诵成风，笙歌合响。"]},{"id":"t0-728","title":"郊庙歌辞 享隐太子庙乐章 雍和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["明典肃陈，神居邃启。","春伯联事，秋官相礼。","有来雍雍，登歌济济。","缅维主鬯，庶歆芳醴。"]},{"id":"t0-729","title":"郊庙歌辞 享隐太子庙乐章 舒和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["三县已判歌钟列，六佾将开羽鏚分。","尚想燕飞来蔽日，终疑鹤影降凌云。"]},{"id":"t0-730","title":"郊庙歌辞 享隐太子庙乐章 凯安","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["天步昔将开，商郊初欲践。","抚戎金阵廓，贰极瑶图阐。","鸡戟遂崇仪，龙楼期好善。","弄兵隳震业，启圣隆嗣典。"]},{"id":"t0-731","title":"郊庙歌辞 隐太子庙乐章 迎神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["苍震有位，黄离蔽明。","江充祸结，戾据灾成。","衔冤昔痛，赠典今荣。","享灵有秩，奉乐以迎。"]},{"id":"t0-732","title":"郊庙歌辞 隐太子庙乐章 送神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["皇情悼往，祀议增设。","钟鼓铿锵，羽旄昭晰。","掌礼云备，司筵告彻。","乐以送神，灵其鉴阕。"]},{"id":"t0-733","title":"郊庙歌辞 享章怀太子庙乐章 迎神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["副君昭象，道应黄离。","铜楼备德，玉裕成规。","仙气霭霭，灵从师师。","前驱戾止，控鹤来仪。"]},{"id":"t0-734","title":"郊庙歌辞 享章怀太子庙乐章 登歌酌鬯","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["忠孝本著，羽翼先成。","寝门昭德，驰道为程。","币帛有典，容卫无声。","司存既肃，庙享惟清。"]},{"id":"t0-735","title":"郊庙歌辞 享章怀太子庙乐章 迎俎酌献","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["通三锡胤，明两承英。","太山比赫，伊水闻笙。","宗祧是寄，礼乐其亨。","嘉辰荐俎，以发声明。"]},{"id":"t0-736","title":"郊庙歌辞 享章怀太子庙乐章 送文舞迎武舞","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["羽籥崇文礼以毕，干鏚奋武事将行。","用舍繇来其有致，壮志宣威乐太平。"]},{"id":"t0-737","title":"郊庙歌辞 享章怀太子庙乐章 武舞作","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["绿林炽炎历，黄虞格有苗。","沙尘惊塞外，帷幄命嫖姚。","七德干戈止，三边云雾消。","宝祚长无极，歌舞盛今朝。"]},{"id":"t0-738","title":"郊庙歌辞 享懿德太子庙乐章 迎神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["甲观昭祥，画堂升位。","礼绝群后，望尊储贰。","启诵慙德，庄丕掩粹。","伊浦凤翔，缑峰鹤至。"]},{"id":"t0-739","title":"郊庙歌辞 享懿德太子庙乐章 登歌酌鬯","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["誉阐元储，寄崇明两。","玉裕虽晦，铜楼可想。","弦诵辍音，笙歌罢响。","币帛言设，礼容无爽。"]},{"id":"t0-740","title":"郊庙歌辞 享懿德太子庙乐章 迎俎酌献","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["雍雍盛典，肃肃灵祠。","宾天有圣，对日无期。","飘飖羽服，掣曳云旗。","眷言主鬯，心乎怆兹。"]},{"id":"t0-741","title":"郊庙歌辞 享懿德太子庙乐章 送文舞迎武舞","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["八音协奏陈金石，六佾分行整礼容。","沧溟赴海还称少，素月开轮即是重。"]},{"id":"t0-742","title":"郊庙歌辞 享懿德太子庙乐章 武舞作","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["隋季昔云终，唐年初启圣。","纂戎将禁暴，崇儒更敷政。","威略静三边，仁恩覃万姓。"]},{"id":"t0-743","title":"郊庙歌辞 享节愍太子庙乐章 迎神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["储后望崇，元良寄切。","寝门是仰，驰道不绝。","仙袂云会，灵旗电晰。","煌煌而来，礼物攸设。"]},{"id":"t0-744","title":"郊庙歌辞 享节愍太子庙乐章 登歌酌鬯","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["灼灼重明，仰承元首。","既贤且哲，惟孝与友。","惟孝虽遥，灵规不朽。","礼因诚致，备絜玄酒。"]},{"id":"t0-745","title":"郊庙歌辞 享节愍太子庙乐章 迎俎酌献","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["嘉荐有典，至诚莫骞。","画梁云亘，雕俎星连。","乐器周列，礼容备宣。","依稀如在，若未宾天。"]},{"id":"t0-746","title":"郊庙歌辞 享节愍太子庙乐章 送文舞出迎武舞入","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["邕邕阐化凭文德，赫赫宣威藉武功。","既执羽旄先拂吹，还持玉鏚更挥空。"]},{"id":"t0-747","title":"郊庙歌辞 享节愍太子庙乐章 武舞作","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["武德谅雍雍，由来扫寇戎。","劒光挥作电，旗影列成虹。","雾廓三边静，波澄四海同。","睿图今已盛，相共舞皇风。"]},{"id":"t0-748","title":"郊庙歌辞 享文敬太子庙乐章 请神","rhythmic":null,"author":"许孟容","authorSlug":"许孟容","dynasty":"唐","kind":"shi","paragraphs":["觞牢具品，管磬有节。","祝道夤恭，神仪昭晰。","桐圭早贵，象辂追设。","声达乐成，降歆丰洁。"]},{"id":"t0-749","title":"郊庙歌辞 享文敬太子庙乐章 登歌","rhythmic":null,"author":"陈京","authorSlug":"陈京","dynasty":"唐","kind":"shi","paragraphs":["歌以德发，声以乐贵。","乐善名存，追仙礼异。","鸾旌拱修，凤鸣合吹。","神听皇慈，仲月皆至。"]},{"id":"t0-750","title":"郊庙歌辞 享文敬太子庙乐章 迎俎酌献","rhythmic":null,"author":"冯伉","authorSlug":"冯伉","dynasty":"唐","kind":"shi","paragraphs":["撰日瞻景，诚陈乐张。","礼容秩秩，羽舞煌煌。","肃将涤濯，祗荐芬芳。","永锡繁祉，思深飨尝。"]},{"id":"t0-751","title":"郊庙歌辞 享文敬太子庙乐章 送文舞迎武舞","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["干旄羽籥相亏蔽，一进一退殊行缀。","昔献三雍盛礼容，今陈六佾崇仪制。"]},{"id":"t0-752","title":"郊庙歌辞 享文敬太子庙乐章 亚献终献","rhythmic":null,"author":"崔邠","authorSlug":"崔邠","dynasty":"唐","kind":"shi","paragraphs":["醴齐泛尊彝，轩县动干戚。","入室僾如在，升阶虔所历。","奋疾合威容，定利舒皦绎。","方崇庙貌礼，永被君恩锡。"]},{"id":"t0-753","title":"郊庙歌辞 享文敬太子庙乐章 送神","rhythmic":null,"author":"张荐","authorSlug":"张荐","dynasty":"唐","kind":"shi","paragraphs":["三献具举，九旗将旋。","追劳表德，罢享宾天。","风引仙管，堂虚画筵。","芳馨常在，瞻望悠然。"]},{"id":"t0-754","title":"郊庙歌辞 享惠昭太子庙乐章 请神","rhythmic":null,"author":"归登","authorSlug":"归登","dynasty":"唐","kind":"shi","paragraphs":["嘉荐既陈，祀事孔明。","闲歌在堂，万舞在庭。","外则尽物，内则尽诚。","凤笙如闻，歌其洁精。"]},{"id":"t0-755","title":"郊庙歌辞 享惠昭太子庙乐章 登歌","rhythmic":null,"author":"杜羔","authorSlug":"杜羔","dynasty":"唐","kind":"shi","paragraphs":["因心克孝，位震遗芬。","宾天道茂，轸怀气分。","发祗乃祀，咳叹如闻。","二歌斯升，以咏德薰。"]},{"id":"t0-756","title":"郊庙歌辞 享惠昭太子庙乐章 迎俎酌献","rhythmic":null,"author":"李逢吉","authorSlug":"李逢吉","dynasty":"唐","kind":"shi","paragraphs":["既洁酒醴，聿陈熟腥。","肃将震念，昭格储灵。","展矣礼典，薰然德馨。","愔愔管磬，亦具是听。"]},{"id":"t0-757","title":"郊庙歌辞 享惠昭太子庙乐章 送文舞出迎武舞入","rhythmic":null,"author":"孟简","authorSlug":"孟简","dynasty":"唐","kind":"shi","paragraphs":["喧喧金石容既缺，肃肃羽驾就行列。","缑山遗响昔所闻，庙庭进旅今攸设。"]},{"id":"t0-758","title":"郊庙歌辞 享惠昭太子庙乐章 亚献终献","rhythmic":null,"author":"裴度","authorSlug":"裴度","dynasty":"唐","kind":"shi","paragraphs":["重轮始发祥，齿胄方兴学。","冥然升紫府，铿尔荐清乐。","奠斝致馨香，在庭纷羽籥。","礼成神既醉，髣髴缑山鹤。"]},{"id":"t0-759","title":"郊庙歌辞 享惠昭太子庙乐章 送神","rhythmic":null,"author":"王涯","authorSlug":"王涯","dynasty":"唐","kind":"shi","paragraphs":["威仪毕陈，备乐将阕。","苞茅酒缩，膋萧香彻。","宫臣展事，肃雍在列。","迎精送往，厥鉴昭晰。"]},{"id":"t0-760","title":"郊庙歌辞 武后崇先庙乐章","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["先德谦㧑冠昔，严规节素超今。","奉国忠诚每竭，承家至孝纯深。","追崇惧乖尊意，显号恐玷徽音。","既迫王公屡请，方乃俯遂群心。","有限无由展敬，奠醑每阙亲斟。","大礼虔申典册，苹藻敬荐翘襟。"]},{"id":"t0-761","title":"郊庙歌辞 襃德庙乐章 昭德","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["道赫梧宫，悲盈蒿里。","爰赐徽烈，载敷嘉祀。","享洽四时，规陈二簋。","灵应昭格，神其戾止。"]},{"id":"t0-762","title":"郊庙歌辞 襃德庙乐章 进德","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["涂山懿戚，妫汭崇姻。","祠筵肇启，祭典方申。","礼以备物，乐以感神。","用隆敦敍，载穆彝伦。"]},{"id":"t0-763","title":"郊庙歌辞 襃德庙乐章 襃德","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["家著累仁，门昭积善。","瑶篚既列，金县式展。"]},{"id":"t0-764","title":"郊庙歌辞 襃德庙乐章 武舞作","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["昭昭竹殿开，奕奕兰宫启。","懿范隆丹掖，殊荣辟朱邸。","六佾荐徽容，三簋陈芳醴。","万石覃贻厥，分珪崇祖祢。"]},{"id":"t0-765","title":"郊庙歌辞 襃德庙乐章 彰德","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["名隆五岳，秩映三台。","严祠已备，[睟]影方回。"]},{"id":"t0-766","title":"舞曲歌辞 功成庆善乐舞词","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["寿丘惟旧迹，酆邑乃前基。","粤余承累圣，悬弧亦在兹。","弱龄逢运改，提劒郁匡时。","指麾八荒定，怀柔万国夷。","梯山盛入欵，驾海亦来思。","单于陪武帐，日逐卫文㮰。","端扆朝四岳，无为任百司。","霜节明秋景，轻冰结水湄。","芸黄遍原隰，禾颕积京坻。","共乐还谯宴，欢此大风诗。"]},{"id":"t0-767","title":"舞曲歌辞 中和乐舞词","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["芳岁肇佳节，物华当仲春。","乾坤既昭泰，烟景含氤氲。","德浅荷玄贶，乐成思治人。","前庭列钟鼓，广殿延群臣。","八卦随舞意，五音转曲新。","顾非咸池奏，庶协南风薰。","式宴礼所重，浃欢情必均。","同和谅在兹，万国希可亲。"]},{"id":"t0-768","title":"舞曲歌辞 凯乐歌辞 破阵乐","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["受律辞元首，相将讨叛臣。","咸歌破阵乐，共赏太平人。"]},{"id":"t0-769","title":"舞曲歌辞 凯乐歌辞 应圣期","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["圣德期昌运，雍熙万宇清。","乾坤资化育，海岳共休明。","辟土欣耕稼，销戈遂偃兵。","殊方歌帝泽，执贽贺升平。"]},{"id":"t0-770","title":"舞曲歌辞 凯乐歌辞 贺圣欢","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["四海皇风被，千年德水清。","戎衣更不著，今日告功成。"]},{"id":"t0-771","title":"舞曲歌辞 凯乐歌辞 君臣同庆乐","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["主圣开昌历，臣忠奉大猷。","君看偃革后，便是太平秋。"]},{"id":"t0-772","title":"郊庙歌辞 梁郊祀乐章 庆和 一","rhythmic":null,"author":"赵光逢、张衮","authorSlug":"赵光逢、张衮","dynasty":"唐","kind":"shi","paragraphs":["就阳位，升圆丘。","佩双玉，御大裘。","膺天命，拥神休。","万灵感，百禄遒。"]},{"id":"t0-773","title":"郊庙歌辞 梁郊祀乐章 庆和 二","rhythmic":null,"author":"赵光逢、张衮","authorSlug":"赵光逢、张衮","dynasty":"唐","kind":"shi","paragraphs":["秉黄钺，建朱旗。","震八表，清二仪。","帝业显，王道夷。","受景命，启皇基。"]},{"id":"t0-774","title":"郊庙歌辞 梁郊祀乐章 庆和 三","rhythmic":null,"author":"赵光逢、张衮","authorSlug":"赵光逢、张衮","dynasty":"唐","kind":"shi","paragraphs":["开九门，怀百神。","通肸蚃，接氤氲。","明粢荐，广乐陈。","奠嘉璧，燎芳薪。"]},{"id":"t0-775","title":"郊庙歌辞 梁郊祀乐章 庆和 四","rhythmic":null,"author":"赵光逢、张衮","authorSlug":"赵光逢、张衮","dynasty":"唐","kind":"shi","paragraphs":["膺宝图，执左契。","德应天，圣飨帝。","荐表衷，荷灵惠。","寿万年，祚百世。"]},{"id":"t0-776","title":"郊庙歌辞 梁郊祀乐章 庆和 五","rhythmic":null,"author":"赵光逢、张衮","authorSlug":"赵光逢、张衮","dynasty":"唐","kind":"shi","paragraphs":["惟德动天，有感必通。","秉兹一德，禋于六宗。","钦夤宝命，恭肃礼容。","来顾来享，永穆皇风。"]},{"id":"t0-777","title":"郊庙歌辞 梁郊祀乐章 庆和 六","rhythmic":null,"author":"赵光逢、张衮","authorSlug":"赵光逢、张衮","dynasty":"唐","kind":"shi","paragraphs":["天惟佑德，辟乃奉天。","交感斯在，昭事罔愆。","岁功已就，王道无偏。","于焉报本，是用告虔。"]},{"id":"t0-778","title":"郊庙歌辞 梁郊祀乐章 庆顺","rhythmic":null,"author":"赵光逢、张衮","authorSlug":"赵光逢、张衮","dynasty":"唐","kind":"shi","paragraphs":["圣皇戾止，天步舒迟。","干干睿相，穆穆皇仪。","进退必肃，陟降是祗。","六变克协，万灵协随。"]},{"id":"t0-779","title":"郊庙歌辞 梁郊祀乐章 庆平","rhythmic":null,"author":"赵光逢、张衮","authorSlug":"赵光逢、张衮","dynasty":"唐","kind":"shi","paragraphs":["天命降鉴，帝德惟馨。","享祀不忒，礼容孔明。","奠璧布币，荐神献精。","神佑以答，敷锡永宁。"]},{"id":"t0-780","title":"郊庙歌辞 梁郊祀乐章 庆肃","rhythmic":null,"author":"赵光逢、张衮","authorSlug":"赵光逢、张衮","dynasty":"唐","kind":"shi","paragraphs":["笾豆簠簋，黍稷非馨。","懿兹彝器，厥德惟明。","金石匏革，以和以平。","繇此无体，期乎永宁。"]},{"id":"t0-781","title":"郊庙歌辞 梁郊祀乐章 庆熙","rhythmic":null,"author":"赵光逢、张衮","authorSlug":"赵光逢、张衮","dynasty":"唐","kind":"shi","paragraphs":["哲后躬享，旨酒斯陈。","王恭无斁，严祀维夤。","皇祖以配，大孝以振。","宜锡景福，永休下民。"]},{"id":"t0-782","title":"郊庙歌辞 梁郊祀乐章 庆隆","rhythmic":null,"author":"赵光逢、张衮","authorSlug":"赵光逢、张衮","dynasty":"唐","kind":"shi","paragraphs":["恭祀上帝，于国之阳。","爵醴是荷，鸿基永昌。"]},{"id":"t0-783","title":"郊庙歌辞 梁郊祀乐章 庆融","rhythmic":null,"author":"赵光逢、张衮","authorSlug":"赵光逢、张衮","dynasty":"唐","kind":"shi","paragraphs":["道和气兮袭氤氲，宣皇规兮彰圣神。","服遐裔兮敷质文，格苗扈兮息烟尘。"]},{"id":"t0-784","title":"郊庙歌辞 梁郊祀乐章 庆休","rhythmic":null,"author":"赵光逢、张衮","authorSlug":"赵光逢、张衮","dynasty":"唐","kind":"shi","paragraphs":["大业来四夷，仁风和万国。","白日体无私，皇天辅有德。","七旬罪已服，六月师方克。","伟哉帝道隆，终始常作则。"]},{"id":"t0-785","title":"郊庙歌辞 梁郊祀乐章 庆和","rhythmic":null,"author":"赵光逢、张衮","authorSlug":"赵光逢、张衮","dynasty":"唐","kind":"shi","paragraphs":["烟燎升，礼容彻。","诚感达，人神悦。","灵贶彰，圣情结。","玉座寂，金炉歇。"]},{"id":"t0-786","title":"郊庙歌辞 周郊祀乐章 昭顺乐","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["五兵勿用，万国咸安。","告功圆盖，受命云坛。","乐鸣凤律，礼备鸡竿。","神光欲降，众目遐观。"]},{"id":"t0-787","title":"郊庙歌辞 周郊祀乐章 治顺乐","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["羽卫离丹阙，金轩赴泰坛。","珠旗明月色，玉佩晓霜寒。","黼黻龙衣备，琮璜宝器完。","百神将受职，宗社保长安。"]},{"id":"t0-788","title":"郊庙歌辞 周郊祀乐章 感顺乐","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["明君陈大礼，展币祀圆丘。","雅乐声其发，祥云色正浮。"]},{"id":"t0-789","title":"郊庙歌辞 周郊祀乐章 禋顺乐","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["黄彝将献，特牲预迎。","既修昭事，潜达明诚。"]},{"id":"t0-790","title":"郊庙歌辞 周郊祀乐章 福顺乐","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["相承五运，取法三才。","大礼爰展，率土咸来。","卿云秘室，甘泉宝台。","象樽初酌，受福不回。"]},{"id":"t0-791","title":"郊庙歌辞 周郊祀乐章 福顺乐","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["昊天成命，邦国盛仪。","多士齐列，六龙载驰。","坛升泰一，乐奏咸池。","高明祚德，永致昌期。"]},{"id":"t0-792","title":"郊庙歌辞 周郊祀乐章 福顺乐","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["上天垂景贶，哲后举鸾觞。","明德今方祚，邦家万世昌。"]},{"id":"t0-793","title":"郊庙歌辞 周郊祀乐章 忠顺乐","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["木铎敷音文德昌，朱干成列武功彰。","雷鼗鹭羽今休用，玉鏚相参正发扬。"]},{"id":"t0-794","title":"郊庙歌辞 周郊祀乐章 武舞乐","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["圭瓒方陈礼，干旄乃象功。","成文非羽籥，猛势若罴熊。"]},{"id":"t0-795","title":"郊庙歌辞 周郊祀乐章 昭顺乐","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["云门孤竹，苍璧黄琮。","既祀天地，克配祖宗。","虔修盛礼，仰荅玄功。","神归碧落，福降无穷。"]},{"id":"t0-796","title":"郊庙歌辞 梁太庙乐舞辞 开平舞","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["黍稷馨，醴𨣧清。","牲牷洁，金石铿。","恭祀事，结皇情。","神来格，歌颂声。"]},{"id":"t0-797","title":"郊庙歌辞 梁太庙乐舞辞 皇帝行","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["莫高者天，攀跻弗克。","𬯀天有方，累仁积德。","祖宗隆之，子孙履之。","配天明祀，永永孝思。"]},{"id":"t0-798","title":"郊庙歌辞 梁太庙乐舞辞 帝盥","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["庄肃莅事，周旋礼容。","裸鬯严洁，穆穆雍雍。"]},{"id":"t0-799","title":"郊庙歌辞 梁太庙乐舞辞 登歌","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["于赫我皇，建中立极。","动以武功，静以文德。","昭事上帝，欢心万国。","大报严禋，四海述职。"]}]