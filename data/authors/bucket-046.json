o":[],"works":[{"id":"c62-204","title":"步蟾宫·玉京此去春犹浅","kind":"词"}]},"浩虚舟":{"slug":"浩虚舟","name":"浩虚舟","dynasty":"唐","style":"","life":"","origin":"","seal":"浩","bio":["浩虚舟，隰州刺史，聿之子，中宏词科。诗一首。"],"works":[{"id":"t25-241","title":"赋得琢玉成器","kind":"诗"}]},"王去疾":{"slug":"王去疾","name":"王去疾","dynasty":"宋","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"c76-350","title":"菩萨蛮·吴波深处波声急","kind":"词"}]},"王晙":{"slug":"王晙","name":"王晙","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王晙，沧州景城人。擢明经第，调清苑尉，历殿中侍御史，出为渭南尉。景龙末，授桂州都督，累迁太仆少卿、陇右群牧使。","开元二年，袭吐蕃于临洮，以功加银青光禄大夫，进并州都督长史。又以破突厥功，拜兵部尚书，朔方军大总管。后代张说为兵部尚书，同中书门下三品，充朔方军节度大使，终户部尚书，朔方节度。","诗一首。"],"works":[{"id":"t0-538","title":"郊庙歌辞 祭汾阴乐章 太和","kind":"诗"},{"id":"t5-185","title":"祭汾阴乐章 太和","kind":"诗"}]},"王炎1":{"slug":"王炎1","name":"王炎1","dynasty":"宋","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"c66-210","title":"菩萨蛮·远风江急潮来晚","kind":"词"},{"id":"c66-211","title":"梅花引·裁征衣","kind":"词"}]},"省吏":{"slug":"省吏","name":"省吏","dynasty":"唐","style":"","life":"","origin":"","seal":"省","bio":[],"works":[{"id":"t48-206","title":"嘲崔左丞","kind":"诗"}]},"贾纬":{"slug":"贾纬","name":"贾纬","dynasty":"唐","style":"","life":"","origin":"","seal":"贾","bio":["纬，镇州获鹿人。唐末举进士不第，州辟参军、邑宰。天成中，辟赵州军事判官，迁石邑令。","天福中，为太常博士，累迁至给事中。任史馆修擢，与修《唐书》。广顺元年贬平卢军行军司马；明年卒于青州。","著有《唐年补录》六十五卷。诗一首。（《全唐诗》无贾纬诗，小传节录《新五代史》卷五七本传）"],"works":[{"id":"t55-253","title":"与监修国史赵莹诗","kind":"诗"}]},"赵光逢":{"slug":"赵光逢","name":"赵光逢","dynasty":"唐","style":"","life":"","origin":"","seal":"赵","bio":["赵光逢，京兆奉天人。干符五年，登进士第，释褐凤翔推官，入为监察御史。干宁三年，从驾幸华州，拜御史中丞，改礼部侍郎。","后仕梁，至宰辅，封齐国公。诗八首。"],"works":[{"id":"t41-220","title":"梁郊祀乐章 庆和 一","kind":"诗"},{"id":"t41-221","title":"梁郊祀乐章 庆和 二","kind":"诗"},{"id":"t41-222","title":"梁郊祀乐章 庆和 三","kind":"诗"},{"id":"t41-223","title":"梁郊祀乐章 庆和 四","kind":"诗"},{"id":"t41-224","title":"梁郊祀乐章 庆和 五","kind":"诗"},{"id":"t41-225","title":"梁郊祀乐章 庆和 六","kind":"诗"},{"id":"t41-226","title":"梁郊祀乐章 庆顺","kind":"诗"},{"id":"t41-227","title":"梁郊祀乐章 庆平","kind":"诗"}]