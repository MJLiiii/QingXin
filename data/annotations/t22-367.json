  "notes": [
    {
      "term": "叶声",
      "def": "树叶掉落的声音。"
    },
    {
      "term": "方",
      "def": "正在，正当。"
    },
    {
      "term": "拂",
      "def": "拭，掸去。"
    }
  ],
  "translation": [
    "夜风拂过，树叶纷纷下落好似雨声闯入耳中，皎洁的月光似清霜铺满大地。",
    "正当夜深人静要独自睡去，不禁感慨有谁愿来为我拭去床上的灰尘。"
  ],
  "appreciation": [],
  "background": [],
  "source": "gushiwen"
}
