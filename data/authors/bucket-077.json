藏烟","kind":"词"},{"id":"c71-969","title":"祝英台近·结垂杨","kind":"词"}]},"董武子":{"slug":"董武子","name":"董武子","dynasty":"宋","style":"","life":"","origin":"","seal":"董","bio":[],"works":[{"id":"c61-339","title":"失调名·畴昔寻芳秘殿西","kind":"词"}]},"赵汝迕":{"slug":"赵汝迕","name":"赵汝迕","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"c72-656","title":"清平乐·初莺细雨","kind":"词"}]},"韦承庆":{"slug":"韦承庆","name":"韦承庆","dynasty":"唐","style":"字延休","life":"","origin":"","seal":"韦","bio":["韦承庆，字延休，郑州阳武人，事继母以孝闻。举进士，官太子司议，屡有谏纳。长寿中，累迁凤阁侍郎，三掌天官选事，铨授平允，寻知政事。","神龙初，坐附张易之，流岭表，起为秘书少监，授黄门侍郎，未拜卒。集六十卷，今存诗七首。"],"works":[{"id":"t0-973","title":"横吹曲辞 折杨柳","kind":"诗"},{"id":"t2-930","title":"折杨柳","kind":"诗"},{"id":"t2-931","title":"寒食应制","kind":"诗"},{"id":"t2-932","title":"凌朝浮江旅思","kind":"诗"},{"id":"t2-933","title":"直中书省","kind":"诗"},{"id":"t2-934","title":"南行别弟","kind":"诗"},{"id":"t2-935","title":"南中咏雁","kind":"诗"},{"id":"t2-936","title":"江楼","kind":"诗"},{"id":"t52-509","title":"九成宫山","kind":"诗"}]}}