[{"id":"c68-100","title":"千秋岁·梅妆竹外","rhythmic":"千秋岁","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["梅妆竹外。","未洗唇红退。","酥脸腻，檀心碎。","临溪闲自照，爱雪春犹带。","沙路晓，亭亭浅立人无对。","似恨谁能会。","迟见江头盖。","和鼎事，终应在。","落残知未免，韵胜何曾改。","牵醉梦，随香欲渡三山海。"]},{"id":"c68-101","title":"千秋岁·征鸿天外","rhythmic":"千秋岁","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["征鸿天外。","风急惊飞退。","云彩重，窗声碎。","初凝铺径絮，渐卷随车带。","凝望处，巫山秀耸寒相对。","高卧传都会。","茅屋倾冠盖。","空往事，今谁在。","梅梢春意动，泽国年华改。","楼上好，与君浩荡浮银海。"]},{"id":"c68-102","title":"千秋岁·窥檐窗外","rhythmic":"千秋岁","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["窥檐窗外。","酒力冲寒退。","风絮乱，琼瑶碎。","凌波争缭绕，点舞相萦带。","应惬当，凝香燕寝佳人对。","恰与花时会。","小阻寻芳盖。","犹自得，春多在。","日烘梅柳竞，翠入山林改。","但只恐，别离恨远如云海。"]},{"id":"c68-103","title":"汉宫春·横笛吹梅","rhythmic":"汉宫春","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["横笛吹梅，记南楼夜月，疏蕊纤枝。","香尘软红自暖，不怕寒欺。","人归梦悄，怅凭阑、密约深期。","身渐老，风流纵在，逢花那似当时。","东阁占春宜早，甚开迟也似，雪屋疏篱。","须公彩毫度曲，锦帐题诗。","多应见我，怪尊前、华发其谁。","烦道与，巡檐共笑，元是旧日相知。"]},{"id":"c68-104","title":"汉宫春·闻说瓢泉","rhythmic":"汉宫春","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["闻说瓢泉，占烟霏空翠，中著精庐。","旁连吹台燕榭，人境清殊。","犹疑未足，称主人、胸次恢疏。","天自与，相攸佳处，除今禹会应无。","选胜卧龙东畔，望篷莱对起，岩壑屏如。","秋风夜凉弄笛，明月邀予。","三英笑粲，更吴天、不隔莼鲈。","新度曲，银钩照眼，争看阿素工书。"]},{"id":"c68-105","title":"水龙吟·蕊珠仙籍标名","rhythmic":"水龙吟","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["蕊珠仙籍标名，绛纱覆玉云霞里。","銮坡凤掖，丝絇鸣佩，甘泉近侍。","濯柳临春，饤梨照座，绝尘风味。","记青蒲、夜半论兵，万人惊诵回天意。","麟组遥临万里。","谈笑处、江山增丽。","遐冲坐折，风流馀事，唯应燕喜。","新筑沙堤，暂占熊梦，恰经长至。","过佳辰献寿，双旌便好，作朝天计。"]},{"id":"c68-106","title":"念奴娇·烛花渐暗","rhythmic":"念奴娇","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["烛花渐暗，似梦来非梦，今夕何夕。","帘幕生香人醉里，家住深深密密。","松客难为，独留无计，此意谁知得。","相看无语，可怜心绪如织。","缓辔踏月归来，空馀襟袖，有多情脂泽。","浅笑轻颦追想处，眼底如今历历。","著意新词，於人好语，过后应难必。","今宵酒醒，断肠人正愁寂。"]},{"id":"c68-107","title":"扑蝴蝶·鸣鸠乳燕","rhythmic":"扑蝴蝶","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["鸣鸠乳燕。","春在梨花院。","重门镇掩。","沈沈帘不卷。","纱窗红日三竿，睡鸭馀香一线。","佳眠悄无人唤。","谩消遣。","行云无定，楚雨难凭梦魂断。","清明渐近，天涯人正远。","尽教闲了秋千，觑著海棠开遍。","难禁旧愁新怨。"]},{"id":"c68-108","title":"祝英台・祝英台近·聚春工","rhythmic":"祝英台・祝英台近","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["聚春工，开绝艳，天巧信无比。","旧日京华，应也只如此。","等闲一尺娇红，燕脂微点，宛然印、昭阳玉指。","最好是。","乐岁台府官闲，风流剩欢意。","痛饮连宵，花也为人醉。","可堪银烛烧残，红妆归去，任春在、宝钗云髻。"]},{"id":"c68-109","title":"江城梅花引·轻煤一曲染霜纨","rhythmic":"江城梅花引","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["轻煤一曲染霜纨。","小屏山。","有无间。","宛是西湖，雪后未晴天。","水外几家篱落晚，半开关。","有梅花、傲峭寒。","渐看。","渐远。","水弥漫。","小舟轻，去又还。","野桥断岸，隐萧寺、□出晴峦。","忆得孤山，山下竹溪前。","佳致不妨随处有，小窗闲，与词人、伴醉眠。"]},{"id":"c68-110","title":"西河·清似水","rhythmic":"西河","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["清似水。","不了眼中供泪。","今宵忍听唱阳关，暮云千里。","可堪客里送行人，家山空老春荠。","道别去、如许易。","离合定非人意。","几年回首望龙门，近才御李。","也知追诏有来时，匆匆今见归骑。","整弓刀，徒御喜。","举离觞、饮釂无味。","端的慰人愁悴。","想天心，注倚方深，应是日日传宣公来未。"]},{"id":"c68-111","title":"夜合花·雨过凉生","rhythmic":"夜合花","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["雨过凉生，风来香远，柳塘池馆清幽。","圆荷万柄，芙蓉困倚轻柔。","暮霞映，日初收。","更满意、绿密红稠。","是牵情处，低回照影，特地娇羞。","惆怅好景难酬。","慰家山梦绕，十顷新秋。","庭空吏散，依然兴在沧州。","未容短棹轻舟。","谩赢得、终日迟留。","笑空归去，篮舆路转，月上西楼。"]},{"id":"c68-112","title":"垂丝钓·夕烽戍鼓","rhythmic":"垂丝钓","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["夕烽戍鼓。","悲凉江岸淮浦。","雾隐孤城，水荒沙聚。","人共语。","尽向来胜处。","谩怀古。","问柳津花渡。","露桥夜月，吹箫人在何许。","缭嫱望篽。","粉黛成黄土。","惟有江东注。","都无虏。","似旧时得否。"]},{"id":"c68-113","title":"黄河清·鼓角清雄占云祲","rhythmic":"黄河清","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["鼓角清雄占云祲。","喜边尘、今度还静。","一线乍添，长觉皇州日永。","楼外崇牙影转，拥千骑、欢声万井。","太平官府人初见，梦熊三占佳景。","皇恩夜出天闱，云章粲、凤鸾飞动相映。","宝带万钉，与作今朝佳庆。","勋业如斯得也，况整顿、江淮大定。","这回恰好，归朝去、共调金鼎。"]},{"id":"c68-114","title":"蓦山溪·风传芳信","rhythmic":"蓦山溪","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["风传芳信，晓色便清霁。","帘幕护春寒，篆香温、笙簧韵美。","使华容与，星动帝王州，花上脸，柳边眉，竞报占熊喜。","欢娱好是，玉塞无尘起。","鞭计小迟留，要长折、遐冲万里。","传闻有诏，宣室待归来，醽醁满，叵罗深，莫负春葱指。"]},{"id":"c68-115","title":"鹧鸪天·怀抱环奇懒叩阍","rhythmic":"鹧鸪天","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["怀抱环奇懒叩阍。","朝阳独赋远人村。","即看飞下芝封诏，会见趣归金马门。","今夕饮，拼濡裙。","一时尊俎尽诗人。","唯馀阿买真才劣，醉后犹能写八分。"]},{"id":"c68-116","title":"鹧鸪天·陆海蓬壶自有山","rhythmic":"鹧鸪天","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["陆海蓬壶自有山。","光风霁月未应悭。","但将歌舞酬佳节，却信阴晴是等闲。","花照夜，烛烘盘。","明年公更酒肠宽。","奉陪黄伞传柑宴，莫望红妆拥座欢。"]},{"id":"c68-117","title":"鹧鸪天·准拟关门度一秋","rhythmic":"鹧鸪天","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["准拟关门度一秋。","强扶衰病起相酬。","不辞酩酊还吹帽，自笑鬅鬙怯露头。","江日晚，更迟留。","争传五马足风流。","论车载酒浑闲事，著笼藏花说未休。"]},{"id":"c68-118","title":"鹧鸪天·两两维舟近柳堤","rhythmic":"鹧鸪天","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["两两维舟近柳堤。","菱歌迤逦过前溪。","曲中自诉衷肠事，岸上行人那得知。","金齿屐，翠云篦。","女萝为带蕙为衣。","惜花贪折归时晚，急桨相呼入翠微。"]},{"id":"c68-119","title":"鹧鸪天·玳瑁宴中见绿珠","rhythmic":"鹧鸪天","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["玳瑁宴中见绿珠。","淡然高韵胜施朱。","揉兰雾縠蔷薇浅，半露冰肌玉不如。","餐秀色，味肤腴。","轻红端合与为奴。","只愁宴罢翻成恨，赢得偏怜不似初。"]},{"id":"c68-120","title":"夜行船·水满平湖香满路","rhythmic":"夜行船","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["水满平湖香满路。","绕重城、藕花无数。","小艇红妆，疏帘轻盖，烟柳画桥斜渡。","恣乐追凉忘日暮。","箫鼓动、月明人去。","犹有清歌，随风迢递，声在芰荷深处。"]},{"id":"c68-121","title":"夜行船·一舸鸱夷云水路","rhythmic":"夜行船","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["一舸鸱夷云水路。","贪游戏、悄忘尘数。","明月长随，清风满载，那向急流争渡。","邂逅占星来已暮。","芝封待、却催归处。","倚玉蒹葭，论文尊俎，回首笑谈何处。"]},{"id":"c68-122","title":"夜行船·飞舄朝天云作路","rhythmic":"夜行船","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["飞舄朝天云作路。","长安近、更无程数。","梧竹当年，丝纶弈世，咫尺凤池平渡。","青眼相逢何太暮。","眉黄透、却愁君去。","官事无多，丰年有暇，莫负赏心佳处。"]},{"id":"c68-123","title":"夜行船·万柄荷花红绕路","rhythmic":"夜行船","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["万柄荷花红绕路。","锦连空、望无层数。","照水旌旗，临风鼓吹，行遍月桥烟渡。","堪笑年华今已暮。","身西上、梦魂东去。","一曲亭边，五云门外，犹记最花多处。"]},{"id":"c68-124","title":"临江仙·天上玉卮称万寿","rhythmic":"临江仙","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["天上玉卮称万寿，人间湛露初匀。","种萱堂上阅青春。","薰风频送喜，同日拜丝纶。","班在蕊珠仙缀立，等闲历遍燕秦。","紫皇先付与佳名。","宜家更宜国，宜子又宜孙。"]},{"id":"c68-125","title":"感皇恩·时节近中秋","rhythmic":"感皇恩","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["时节近中秋，桂花天气。","忆得熊罴梦呈瑞。","向来三度，恨被一官萦系。","今朝称寿，也休辞醉。","斑衣戏彩，薄罗初试。","华发双亲剩欢喜。","功名荣贵，未要匆匆深计。","一杯先要祝，千百岁。"]},{"id":"c68-126","title":"蝶恋花·梅子著花当献寿","rhythmic":"蝶恋花","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["梅子著花当献寿。","得得天工，有意还知否。","教在岁寒双雪后。","长年不羡松筠茂。","莫厌杯深歌舞奏。","约略丝纶，正是来时候。","富贵明年公自有。","天香公烛黄封酒。"]},{"id":"c68-127","title":"蝶恋花·鼓吹东方天欲晓","rhythmic":"蝶恋花","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["鼓吹东方天欲晓。","打彻伊州，梅柳都开了。","尽道鄞江春许早。","使君未到春先到。","号令只凭花信报。","旗垒精明，家世临淮妙。","遥想明年元夕好。","玉人更著华灯照。"]},{"id":"c68-128","title":"蝶恋花·逼砌筠窗围小院","rhythmic":"蝶恋花","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["逼砌筠窗围小院。","日照花枝，疏影重重见。","金鸭无风香自暖。","腊寒才比春寒浅。","画景温温烘笔砚。","闲把安西，六纸都临遍。","茗碗不禁幽梦远。","鹊来唤起斜阳晚。"]},{"id":"c68-129","title":"一翦梅·潇洒佳人淡淡妆","rhythmic":"一翦梅","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["潇洒佳人淡淡妆。","特地凌寒，秀出孤芳。","雪为肌体练为裳。","韵处天姿，不御铅黄。","古样铜壶湿篆章。","浅浸横斜，净几明窗。","何妨三弄点苔苍。","但有疏枝，依旧清香。"]},{"id":"c68-130","title":"天仙子·畏暑只嫌秋较晚","rhythmic":"天仙子","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["畏暑只嫌秋较晚。","不道玉楼人渐远。","此情那解却清凉，肠欲断。","愁无限。","安得冰壶还照眼。","妙舞蹁跹歌宛转。","走遍京华何处见。","清眠无梦到西州，馀香浅。","银钩软。","唯仗锦书聊自遣。"]},{"id":"c68-131","title":"朝中措·晚风斜日折梅花","rhythmic":"朝中措","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["晚风斜日折梅花。","楼外卷残霞。","领略一城春气，华灯十万人家。","轻衫短帽，风前趁马，月下随车。","道个小来脚定，那人笑隔笼纱。"]},{"id":"c68-132","title":"朝中措·几回相与叹高才","rhythmic":"朝中措","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["几回相与叹高才。","忽报驭风来。","谁道亟朝天阕，更能同上春台。","主人早晚，班联玉笋，行听连催。","湖上饱赓新唱，思堂快泻深杯。"]},{"id":"c68-133","title":"朝中措·尊前宾主角多才","rhythmic":"朝中措","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["尊前宾主角多才。","亦许我同来。","诗思竞翻三峡，酒狂欲拗连台。","身闲有限，莫辞光景，刻烛相催。","沙路即看联辔，上林趁赏流杯。"]},{"id":"c68-134","title":"菩萨蛮·壶边击断歌无节","rhythmic":"菩萨蛮","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["壶边击断歌无节。","山川一带伤情切。","依旧石头城。","夕阳天外明。","行人谁是侣。","遗唱今何许。","对酒转愁多。","愁多奈酒何。"]},{"id":"c68-135","title":"菩萨蛮·秋声夜到秋香园","rhythmic":"菩萨蛮","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["秋声夜到秋香园。","重帘拭卷都开遍。","只似旧时香。","更添些子黄。","绮窗人共赋。","犹忆分香句。","别后几回秋。","见花空复愁。"]},{"id":"c68-136","title":"菩萨蛮·云林带水山横阁","rhythmic":"菩萨蛮","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["云林带水山横阁。","故人去尽添萧索。","反照射微茫。","临分愁夕阳。","传柑当令节。","连璧朝天阕。","还有雁西飞。","慰人新别离。"]},{"id":"c68-137","title":"西江月·恰好轻篷短棹","rhythmic":"西江月","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["恰好轻篷短棹，绝胜锦缆牙樯。","一声横笛起微茫。","十里红莲步障。","小待山头吐月，何妨说剑杯长。","更看风露洗湖光。","水底金盘滉漾。"]},{"id":"c68-138","title":"西江月·明日又还重九","rhythmic":"西江月","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["明日又还重九，黄昏小雨疏风。","菊英萸糁一尊同。","付与今宵号梦。","寒意梧桐叶上，客愁画角声中。","小楼何日却从容。","千里此情应共。"]},{"id":"c68-139","title":"梅弄影·雨晴风定","rhythmic":"梅弄影","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["雨晴风定。","一任春寒逞。","要勒群芳未醒。","不废梅花，晚来妆面靓。","曲阑斜凭。","水栏临清镜。","翠竹箫骚相映。","付与幽人，巡池看弄影。"]},{"id":"c68-140","title":"诉衷情·东风罨岸进船难","rhythmic":"诉衷情","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["东风罨岸进船难。","酒醒篆香残。","不堪客里无绪，那更晚来寒。","思往事，耿无眠。","掩屏山。","夜深人静，何处一声，月子弯弯。"]},{"id":"c68-141","title":"诉衷情·素衣苍狗不成妍","rhythmic":"诉衷情","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["素衣苍狗不成妍。","何意妒蝉娟。","不知高处难掩，终自十分圆。","涵万象，独当天。","照无边。","乾坤呈露，何况人间，大地山川。"]},{"id":"c68-142","title":"诉衷情·芙蓉深径小肩舆","rhythmic":"诉衷情","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["芙蓉深径小肩舆。","相并语徐徐。","红妆著处迎笑，遮路索踟蹰。","锦步障，绣储胥。","绕重湖。","更添月照，人面花枝，疑在蓬壶。"]},{"id":"c68-143","title":"诉衷情·十分风味似诗人","rhythmic":"诉衷情","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["十分风味似诗人。","有些子太清生。","只应最嫌俗子，消瘦却盈盈。","风乍静，雪初晴。","月微明。","泊然疏淡，莫是无情，作个关情。"]},{"id":"c68-144","title":"锦帐春·翠竹如屏","rhythmic":"锦帐春","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["翠竹如屏，浅山如画。","小池面、危桥一跨。","著棕亭临水，宛然郊野。","竹篱茅舍。","好是天寒，倍添幽雅。","正雪意、垂垂欲下。","更朦胧月影，弄明初夜。","梅花动也。"]},{"id":"c68-145","title":"谒金门·风又雨","rhythmic":"谒金门","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["风又雨。","吹面落花红舞。","把酒不禁春思苦。","别离闻杜宇。","叠嶂楼头佳处。","犹想襞笺容与。","思入云山便好语。","莫辞频寄取。"]},{"id":"c68-146","title":"谒金门·槐阴绿","rhythmic":"谒金门","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["槐阴绿。","帘卷翠屏山曲。","照眼冰壶寒并玉。","赐衣便雾縠。","熊梦又惊初卜。","好在掖垣梧竹。","应讶人归犹未速。","已颁新诏墨。"]},{"id":"c68-147","title":"谒金门·罗袖薄","rhythmic":"谒金门","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["罗袖薄。","玉臂镂花金约。","起晚欠伸莲步弱。","倚床娇韵恶。","独自青楼珠箔。","怎向日长花落。","门掩东风春寂寞。","误人瞋喜鹊。"]},{"id":"c68-148","title":"谒金门·花雨润","rhythmic":"谒金门","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["花雨润。","烟锁玉炉香韵。","笑度华年春不尽。","寿觞寒食近。","甲子才周一瞬。","争羡珠颜青鬓。","咫尺朝元仙路稳。","碧云新有信。"]},{"id":"c68-149","title":"好事近·空涧落鸣泉","rhythmic":"好事近","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["空涧落鸣泉，千骑雨霖衣铁。","金奏欲终人醉，有玉声清越。","夜深纤手怯轻寒，馀韵寄愁绝。","玉树梦回何处，但满庭霜月。"]},{"id":"c68-150","title":"好事近·整整一冬晴","rhythmic":"好事近","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["整整一冬晴，雨后不论朝夕。","麦陇救得一半，莫妨他寒食。","试看天气定乘除，宽更待三日。","桃李且须宁耐，有无边春色。"]},{"id":"c68-151","title":"浣溪沙·铁锁星桥永夜通","rhythmic":"浣溪沙","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["铁锁星桥永夜通。","万家帘幕度香风。","俊游人在笑声中。","罗绮十行眉黛绿，银花千炬簇莲红。","座中争看黑头公。"]},{"id":"c68-152","title":"浣溪沙·胜子幡儿袅鬓云","rhythmic":"浣溪沙","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["胜子幡儿袅鬓云。","钗头绝唱旧曾闻。","江城喜见又班春。","拂柳和风初有信，欺梅残雪已无痕。","只应笑语作春温。"]},{"id":"c68-153","title":"浪淘沙·潇洒无湖仙","rhythmic":"浪淘沙","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["潇洒无湖仙。","踏遍尘寰。","吟哦长忆两松闲。","邂逅天涯还一笑，璧合珠连。","风采照衰残。","妙语冷然。","妓围香暖簇金蝉。","端为故人情未减，醉玉颓山。"]},{"id":"c68-154","title":"定风波·月殿移根入帝乡","rhythmic":"定风波","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["月殿移根入帝乡。","风流犹是旧时妆。","猩血染成丹杏脸。","浓点。","郁金笼就赭衣黄。","浪说锦城元自少。","不道。","只今何啻五枝芳。","试问司花谁是主。","传语。","且烦都与十分香。"]},{"id":"c68-155","title":"卜算子·翠被怯轻寒","rhythmic":"卜算子","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["翠被怯轻寒，花气撩幽梦。","梦蹑飞云驾彩鸾，惊觉花枝动。","宿酒未全醒，屋角闻晴哢。","爱著荼シ彻骨香，嗅了还重□。"]},{"id":"c68-156","title":"柳梢青·风佩珊珊","rhythmic":"柳梢青","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["风佩珊珊。","云屏曲曲，愁绝春悭。","无奈馀寒。","半醒宿酒，御夹成单。","深沈院落人闲。","凭阑处、眉颦黛残。","彩笔慵拈。","新声微度，兴入云山。"]},{"id":"c68-157","title":"点绛唇·花落花开","rhythmic":"点绛唇","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["花落花开，等闲不管流年度。","旧游何处。","浅立空凝伫。","惊拍栏干，忍见春将暮。","凭风絮。","为人飞去。","散作愁无数。"]},{"id":"c68-158","title":"醉花阴·碧玉槎桠金粟小","rhythmic":"醉花阴","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["碧玉槎桠金粟小。","山路惊秋老。","倒倚湿寒烟，似怯秋风，阁泪啼清晓。","铜壶冷浸宜深窈。","人试新妆巧。","云鬓一枝斜，小阁幽窗，是处都香了。"]},{"id":"c68-159","title":"愁倚阑・春光好·风雨骤","rhythmic":"愁倚阑・春光好","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["风雨骤，妒花黄。","忽斜阳。","急手打开君会否，是伊凉。","深深密密传觞。","似差胜、落帽清狂。","满引休辞还醉倒，却何妨。"]},{"id":"c68-160","title":"如梦令·门外绮罗入绣","rhythmic":"如梦令","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["门外绮罗入绣。","堂上华灯入昼。","领略一番春，共醉连宵歌酒。","今后。","今后。","如此遨头少有。"]},{"id":"c68-161","title":"如梦令·小小峰峦对起","rhythmic":"如梦令","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["小小峰峦对起。","芳树重重相倚。","清溜绕阶除，聊备一池春水。","游戏。","游戏。","适意随缘足矣。"]},{"id":"c68-162","title":"太常引·憎人虎豹守天关","rhythmic":"太常引","author":"丘崈","authorSlug":"丘崈","dynasty":"宋","kind":"ci","paragraphs":["憎人虎豹守天关。","嗟蜀道、十分难。","说与沐猴冠。","这富贵、於人怎谩。","忘形尊俎，能言桃李，日日在东山。","不醉有馀欢。","唱好个、风流谢安。"]},{"id":"c68-163","title":"南歌子·影落三秋月","rhythmic":"南歌子","author":"朱晞颜","authorSlug":"朱晞颜","dynasty":"宋","kind":"ci","paragraphs":["影落三秋月，寒生六月霜。","是谁幻出玉篔筜。","乞与一枝和雪、钓漓湘。","劲节依琳馆，虚心漏草堂。","笔端元自有雌黄。","疑是化龙蜚到、葛仙旁。"]},{"id":"c68-164","title":"沁园春·月晃西窗","rhythmic":"沁园春","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["月晃西窗，风掀斗帐，晓来梦回。","见满川惊鹭，长空瑞鹤，联翩来下，翔舞徘徊。","旋放金磐承积块，更轻撼琼壶撩冻澌。","毡帏小，近宝炉兽炭，沈水兰煤。","寒威。","酒力相欺。","荐绿蚁霜螯左右持。","问岁岁祯祥，如何中断，年年梅月，因甚愆期。","上绀碧楼，城高百尺，看白玉虬龙奔四围。","纷争罢，正残鳞败甲，天上交飞。"]},{"id":"c68-165","title":"醉桃源・阮郎归·山翁可是爱登台","rhythmic":"醉桃源・阮郎归","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["山翁可是爱登台。","看云日几回。","恨无语似谪仙才。","空教云去来。","思往事，引深杯。","长歌感壮怀。","霜风晚下扫阴霾。","天心宝鉴开。"]},{"id":"c68-166","title":"醉桃源・阮郎归·马蹄西路赏春妍","rhythmic":"醉桃源・阮郎归","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["马蹄西路赏春妍。","重来十五年。","好山如带水如环。","红楼罨画闲。","人易老，景如前。","停杯俯逝川。","归舟回首望云烟。","秦人隔洞天。"]},{"id":"c68-167","title":"醉桃源・阮郎归·去年手种十株梅","rhythmic":"醉桃源・阮郎归","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["去年手种十株梅。","而今犹未开。","山翁一日走千迥。","今朝蝶也来。","高树杪，暗香微。","悭香越恼怀。","更烧银烛引春回。","英英露粉腮。"]},{"id":"c68-168","title":"蝶恋花·墙角栽梅分两下","rhythmic":"蝶恋花","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["墙角栽梅分两下。","夹竹穿松，巧傍柴门亚。","不似西湖明月夜。","展开一片江南画。","老子寻芳心已罢。","为爱孤高，结约如莲社。","清静界中观物化。","憧憧门外驰车马。"]},{"id":"c68-169","title":"蝶恋花·天际行云红一缕","rhythmic":"蝶恋花","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["天际行云红一缕。","无尽青山，江水悠悠去。","更上层楼凭远处。","凄凉今古悲三楚。","心事多端谁共语。","酒醒愁来，望望家何所。","薄宦漂零成久旅。","天涯却羡鸿遵渚。"]},{"id":"c68-170","title":"蝶恋花·姑射真仙蓬海会","rhythmic":"蝶恋花","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["姑射真仙蓬海会。","驭气乘龙，作意游方外。","冬后翦花飞素彩。","腊前陨璞抛团块。","幂幂锦云相映带。","川谷林峦，混一乾坤大。","白玉装成全世界。","江湖点染微瑕颣。"]},{"id":"c68-171","title":"蝶恋花·屈指瓜期犹渺渺","rhythmic":"蝶恋花","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["屈指瓜期犹渺渺。","羡子征鞍，去上长安道。","到得故园春正好。","桃腮杏脸迎门笑。","闻道难兄登显要。","雁子云宵，花萼应同调。","旧恨新愁须拼了。","功名趁取方年少。"]},{"id":"c68-172","title":"蝶恋花·眼约心期常未足","rhythmic":"蝶恋花","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["眼约心期常未足。","邂逅今朝，暂得论心曲。","忽堕鲛珠红簌簌。","双眸翦水明如烛。","可恨匆匆归去速。","去去行云，望断凄心目。","何似当初情未熟。","免教添得愁千斛。"]},{"id":"c68-173","title":"蝶恋花·天色沈沈云色赭","rhythmic":"蝶恋花","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["天色沈沈云色赭。","风扰阴寒，浩荡吹平野。","万斛珠玑天弃舍。","长空撒下鸣鸳瓦。","玉女凝愁金阕下。","褪粉残妆，和泪轻挥洒。","欲降尘凡飙驭驾。","翩翩白凤先来也。"]},{"id":"c68-174","title":"长相思·体夭夭","rhythmic":"长相思","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["体夭夭。","步飘飘。","绶带金泥缕绛绡。","珑璁趁步摇。","浅霞消。","两峰遥。","斜插层楼金系腰。","花羞人面娇。"]},{"id":"c68-175","title":"长相思·展颦蛾","rhythmic":"长相思","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["展颦蛾。","抹流波。","并插玲珑碧玉梭。","松分两髻螺。","晓霜和。","冻轻呵。","拍罢阳春白雪歌。","偎人春意多。"]},{"id":"c68-176","title":"长相思·冒寒吹","rhythmic":"长相思","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["冒寒吹。","访琼姬。","行到青山遇玉肌。","凝情欲待谁。","山疏篱。","手同携。","踏月随香清夜归。","乘欢拨冻醅。"]},{"id":"c68-177","title":"浣溪沙·浅著铅华素净妆","rhythmic":"浣溪沙","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["浅著铅华素净妆。","翩跹翠袖拂云裳。","傍人作意捧金觞。","曲度清悲云冉冉，花飞零乱月茫茫。","梦回人去似高唐。"]},{"id":"c68-178","title":"浣溪沙·直系腰围鹤间霞","rhythmic":"浣溪沙","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["直系腰围鹤间霞。","双垂项帕凤穿花。","新妆全学内人家。","惠性芳心谁得似，饶嗔□恶也还他。","只消凡事与饶些。"]},{"id":"c68-179","title":"清平乐·红尘久住","rhythmic":"清平乐","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["红尘久住。","仙驭凌波去。","本似行云无定处。","那更腊残风雨。","瑶芳片片轻飞。","但留青子栾枝。","孤负岁寒幽意，如今却与春宜。"]},{"id":"c68-180","title":"清平乐·灵心暗属","rhythmic":"清平乐","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["灵心暗属。","髻垒黄金粟。","寂静虚堂情不足。","微步徘徊山麓。","蕊珠宫里新妆。","生香全似瑶芳。","应为莺花留恋，人间暂歇鸾凤。"]},{"id":"c68-181","title":"促拍满路花·名花无影迹","rhythmic":"促拍满路花","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["名花无影迹，寒气日凄凉。","人间千万树，歇芬芳。","紫微宫女，仙驭降霓裳。","名在仙班簿，不属尘凡，洞天密锁云窗。","遗珰连宝珥，人间识天香。","凝寒承雨露，傲冰霜。","凌仙仙子，邂逅水云乡。","更约南枝友，游遍江南，共归三岛扶桑。"]},{"id":"c68-182","title":"谒金门·花满树","rhythmic":"谒金门","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["花满树。","两个黄鹂相语。","恰似碧城双玉女。","对歌还对舞。","可惜娟娟楚楚。","同伴彩云归去。","居士心如泥上絮。","那能无恨处。"]},{"id":"c68-183","title":"谒金门·嗟久客","rhythmic":"谒金门","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["嗟久客。","又见他乡寒食。","流水断桥春寂寂。","孤村烟火息。","白去红飞无迹。","千树总成新碧。","醉里伤春愁似织。","东风欺酒力。"]},{"id":"c68-184","title":"谒金门·芳思切","rhythmic":"谒金门","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["芳思切，旧事不堪重说。","浓露凝香花喷血。","花心双蛱蝶。","燕语莺啼都歇。","又过清明时节。","记得离歌三两阕。","未歌先哽咽。"]},{"id":"c68-185","title":"谒金门·花满树","rhythmic":"谒金门","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["花满树。","两个黄鹂相语。","恰似碧城双玉女。","对歌还对舞。","可惜娟娟楚楚。","同伴彩云归去。","居士心如泥上絮。","那能无恨处。"]},{"id":"c68-186","title":"谒金门·嗟久客","rhythmic":"谒金门","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["嗟久客。","又见他乡寒食。","流水断桥春寂寂。","孤村烟火息。","白去红飞无迹。","千树总成新碧。","醉里伤春愁似织。","东风欺酒力。"]},{"id":"c68-187","title":"谒金门·芳思切","rhythmic":"谒金门","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["芳思切，旧事不堪重说。","浓露凝香花喷血。","花心双蛱蝶。","燕语莺啼都歇。","又过清明时节。","记得离歌三两阕。","未歌先哽咽。"]},{"id":"c68-188","title":"谒金门·春又过","rhythmic":"谒金门","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["春又过。","那更雨摧风挫。","留得浅红三两朵。","竹梢烟雾锁。","把酒对花危坐。","多病多愁都可。","舞蝶游蜂迷道左。","惜春忙似我。"]},{"id":"c68-189","title":"谒金门·秋夜静","rhythmic":"谒金门","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["秋夜静。","屋上狂风初定。","两两啼蛄相答应。","灯蛾摇烛影。","枕上鸡声遥听。","起舞良宵偏永。","明日谩寻弓剑整。","衰颜重揽镜。"]},{"id":"c68-190","title":"谒金门·芳信拆","rhythmic":"谒金门","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["芳信拆。","漏泄东君消息。","帝殿宝炉烟未熄。","龙香飘片白。","点缀枯梢的皪。","疏影摇荡寒碧。","指与纤纤教自摘。","枝横云鬓侧。"]},{"id":"c68-191","title":"谒金门·天气暖","rhythmic":"谒金门","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["天气暖。","开了荼䕷一半。","红日迟迟风拂面。","阶前花影乱。","俊雅风流不见。","定被莺花留恋。","千尺游丝舒又罥。","系人心上线。"]},{"id":"c68-192","title":"谒金门·歌罢奏","rhythmic":"谒金门","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["歌罢奏。","敛步拂开罗袖。","宝扇轻摇香汗透。","软香沾素手。","小立偎人良久。","一寸娇波横溜。","心事未言眉已皱。","无端催劝酒。"]},{"id":"c68-193","title":"南乡子·斗笠棹边舟","rhythmic":"南乡子","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["斗笠棹边舟。","碧水湾头放自流。","尽日垂丝鱼不上，优游。","更觉心松奈得愁。","行客语沧洲。","笑道渔翁太拙休。","万事要求须有道，何由。","教与敲针换曲钩。"]},{"id":"c68-194","title":"南乡子·纵棹越溪船","rhythmic":"南乡子","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["纵棹越溪船。","破浪冲涛到碧湾。","种就长堤千亩竹，无边。","插玉屯云满渭川。","平日乐归田。","不恋荣华不慕仙。","得个容身栖隐处，宽闲。","每日江边理钓竿。"]},{"id":"c68-195","title":"减字木兰花·烟云变化","rhythmic":"减字木兰花","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["烟云变化。","面面青山如展画。","俯对平川。","野水烟村远接天。","有时纵目。","景物繁华观不足。","月下风头。","一曲清讴博见楼。"]},{"id":"c68-196","title":"瑞鹤仙·南州春又到","rhythmic":"瑞鹤仙","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["南州春又到。","向腊尽冬残，冰姑先报。","芳心爱春早。","露生香馥馥，靓妆皎皎。","诗人最巧。","道竹外、斜枝更好。","旋移根引水，浇培松竹，凑成三妙。","回首。","当年客里，荆棘途中，幸陪欢笑。","闲愁似扫。","记风雪、关山道。","待飘花结子，和羹煮酒，还我山居送老。","那青红、浪蕊浮花，尽锄去了。"]},{"id":"c68-197","title":"瑞鹤仙·倚阑观四远","rhythmic":"瑞鹤仙","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["倚阑观四远。","近有客登临，故相磨难。","山形欠舒展。","小峰峦云树，晦明更变。","江淮楚甸。","又何曾、分明在眼。","但临深、自觉身高，未可便名博见。","休辨。","吾心乐处，不要他人，共同称善。","痴儿浅浅。","因他谩说一遍。","问还知宴坐，回光收视，大地河山尽现。","待於中、会得些时，举觞奉劝。"]},{"id":"c68-198","title":"瑞鹤仙·人生如意少","rhythmic":"瑞鹤仙","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["人生如意少。","谁得似仙翁，身名俱好。","亨衢腾踏早。","驾双旌五马，便居蓬岛。","闽山蜀道。","秉玉节、油幢屡到。","号当今、有脚阳春，处处变愁成笑。","尤妙。","晚陪论道。","密赞调元，虎符重剖。","去劳自保。","奉香火、归来了。","见煌煌甲第，两两龙驹，绿鬓朱颜未到。","是平生、种德阴功，自天有报。"]},{"id":"c68-199","title":"瑞鹤仙·金枝联玉叶","rhythmic":"瑞鹤仙","author":"吕胜己","authorSlug":"吕胜己","dynasty":"宋","kind":"ci","paragraphs":["金枝联玉叶。","世代有宗英，声华烨烨。","君侯更超绝。","抱不群才气，壮图英发。","津途轨辙。","□武上、青宵迥别。","自玉阶、契合君王，拍拍满怀风月。","奇绝。","身居萧散，志在功名，眼高天阔。","恩来魏阕。","长江上、驻旌节。","待胡尘有警，纶巾羽扇，谈笑周郎事业。","恁时看、国倚强宗，诏褒伟烈。"]}]