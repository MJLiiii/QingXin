{"乔潭":{"slug":"乔潭","name":"乔潭","dynasty":"唐","style":"字德源","life":"","origin":"","seal":"乔","bio":["潭，字德源，梁人。师元德秀。天宝十三年进士，后官陆浑尉。","诗四首。（《全唐诗》无乔潭诗。兹据《新唐书》卷一九四《卓行传》、《全唐文》卷三一七、卷四五一、《登科记考》卷九录其事迹）"],"works":[{"id":"t52-835","title":"裴将军剑舞赋附歌","kind":"诗"},{"id":"t52-836","title":"群玉山赋附歌","kind":"诗"},{"id":"t52-837","title":"秋晴曲江望太一纳归云赋附歌","kind":"诗"},{"id":"t52-838","title":"同前赋附归云之曲","kind":"诗"}]},"南诏骠信":{"slug":"南诏骠信","name":"南诏骠信","dynasty":"唐","style":"","life":"","origin":"","seal":"南","bio":["骠信，南诏酋也。诗一首。"],"works":[{"id":"t41-155","title":"星回节游避风台与清平官赋","kind":"诗"}]},"崔中":{"slug":"崔中","name":"崔中","dynasty":"宋","style":"","life":"","origin":"","seal":"崔","bio":[],"works":[{"id":"c61-123","title":"沁园春·自己阳生","kind":"词"}]},"延禅师":{"slug":"延禅师","name":"延禅师","dynasty":"唐","style":"","life":"","origin":"","seal":"延","bio":["延禅师，嗣广德义禅师，仍住襄州广德山。诗一首。（《全唐诗》无延禅师诗）"],"works":[{"id":"t55-293","title":"偈","kind":"诗"}]},"张侹":{"slug":"张侹","name":"张侹","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"t43-120","title":"寄人","kind":"诗"}]},"李元纮":{"slug":"李元纮","name":"李元纮","dynasty":"唐","style":"字大纲","life":"","origin":"","seal":"李","bio":["李元纮，字大纲，京兆万年人。本姓丙氏，曾祖粲率众归高祖，因赐姓。元纮初为雍州司户，太平公主占民碾硙，元纮断还民，雍州长史窦怀贞惧势，促令改断。","元纮大署判后曰：“南山可移，此断不可摇。”开元初，擢京兆尹。帝欲用为尚书，执政以其资浅，乃拜户部侍郎，寻进中书侍郎，同中书门下平章事。","元纮当国峻崖，检抑奔竞，家无储积，宋璟尝称之。诗三首。"],"works":[{"id":"t5-366","title":"奉和圣制送张说上集贤学士赐宴","kind":"诗"},{"id":"t5-367","title":"绿墀怨","kind":"诗"},{"id":"t5-368","title":"相思怨","kind":"诗"}]},"杨持":{"slug":"杨持","name":"杨持","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":[],"works":[{"id":"t43-157","title":"寄朗陵兄","kind":"诗"}]},"楼颕":{"slug":"楼颕","name":"楼颕","dynasty":"唐","style":"","life":"","origin":"","seal":"楼","bio":["楼颕，天宝中进士，作《国秀集序》。诗五首。"],"works":[{"id":"t10-43","title":"伊水门","kind":"诗"},{"id":"t10-44","title":"东郊纳凉忆左威卫李录事收昆季太原崔参军三首 一","kind":"诗"},{"id":"t10-45","title":"东郊纳凉忆左威卫李录事收昆季太原崔参军三首 二","kind":"诗"},{"id":"t10-46","title":"东郊纳凉忆左威卫李录事收昆季太原崔参军三首 三","kind":"诗"},{"id":"t