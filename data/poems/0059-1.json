[{"id":"c59-100","title":"临江仙·尊酒何人怀李白","rhythmic":"临江仙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["尊酒何人怀李白，草堂遥指江东。","珠帘十里卷香风。","花开又花谢，离恨几千重。","轻舸渡江连夜到，一时惊笑衰容。","语音犹自带吴侬。","夜阑对酒处，依旧梦魂中。"]},{"id":"c59-101","title":"临江仙·九十日春都过了","rhythmic":"临江仙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["九十日春都过了，贪忙何处追游。","三分春色一分愁。","雨翻榆荚阵，风转柳花球。","阆苑先生须自责，蟠桃动是千秋。","不知人世苦厌求。","东皇不拘束，肯为使君留。"]},{"id":"c59-102","title":"临江仙·四大从来都遍满","rhythmic":"临江仙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["四大从来都遍满，此间风水何疑。","故应为我发新诗。","幽花香涧谷，寒藻舞沦漪。","借与玉川生两腋，天仙未必相思。","还凭流水送人归。","层巅馀落日，草露已沾衣。"]},{"id":"c59-103","title":"临江仙·一别都门三改火","rhythmic":"临江仙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["一别都门三改火，天涯踏尽红尘。","依然一笑作春温。","无波真古井，有节是秋筠。","惆怅孤帆连夜发，送行淡月微云。","尊前不用翠眉颦。","人生如逆旅，我亦是行人。"]},{"id":"c59-104","title":"临江仙·多病休文都瘦损","rhythmic":"临江仙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["多病休文都瘦损，不堪金带垂腰。","望湖楼上暗香飘。","和风春弄袖，明月夜闻箫。","酒醒梦回清漏永，隐床无限更潮。","佳人不见董娇饶。","徘徊花上月，空度可怜宵。"]},{"id":"c59-105","title":"临江仙·夜饮东坡醒复醉","rhythmic":"临江仙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["夜饮东坡醒复醉，归来仿佛三更。","家童鼻息已雷鸣。","敲门都不应，倚杖听江声。","长恨此身非我有，何时忘却营营。","夜阑风静縠纹平。","小舟从此逝，江海寄馀生。"]},{"id":"c59-106","title":"临江仙·冬夜夜寒冰合井","rhythmic":"临江仙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["冬夜夜寒冰合井，画堂明月侵帏。","青缸明灭照悲啼。","青缸挑欲尽，粉泪裛还垂。","未尽一尊先掩泪，歌声半带清悲。","情声两尽莫相违。","欲知肠断处，梁上暗尘飞。"]},{"id":"c59-107","title":"渔家傲·千古龙蟠并虎踞","rhythmic":"渔家傲","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["千古龙蟠并虎踞。","从公一吊兴亡处。","渺渺斜风吹细雨。","芳草渡。","江南父老留公住。","公驾飞车凌彩雾。","红鸾骖乘青鸾驭。","却讶此洲名白鹭。","非吾侣。","翩然欲下还飞去。"]},{"id":"c59-108","title":"渔家傲·送客归来灯火尽","rhythmic":"渔家傲","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["送客归来灯火尽。","西楼淡月凉生晕。","明日潮来无定准。","潮来稳。","舟横渡口重城近。","江水似知孤客恨。","南风为解佳人愠。","莫学时流轻久困。","频寄问。","钱塘江上须忠信。"]},{"id":"c59-109","title":"渔家傲·皎皎牵牛河汉女","rhythmic":"渔家傲","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["皎皎牵牛河汉女。","盈盈临水无由语。","望断碧云空日暮。","无寻处。","梦回芳草生春浦。","鸟散馀花纷似雨。","汀洲苹老香风度。","明月多情来照户。","但揽取。","清光长送人归去。"]},{"id":"c59-110","title":"渔家傲·一曲《阳关》情","rhythmic":"渔家傲","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["一曲《阳关》情几许。","知君欲向秦川去。","白马皂貂留不住。","回首处。","孤城不见天霖雾。","到日长安花似雨。","故关杨柳初飞絮。","渐见靴刀迎夹路。","谁得似。","风流膝上王文度。"]},{"id":"c59-111","title":"鹧鸪天·林断山明竹隐墙","rhythmic":"鹧鸪天","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["林断山明竹隐墙。","乱蝉衰草小池塘。","翻空白鸟时时见，照水红蕖细细香。","村舍外，古城旁。","杖藜徐步转斜阳。","殷勤昨夜三更雨，又得浮生一日凉。"]},{"id":"c59-112","title":"鹧鸪天·笑拈红梅亸翠翘","rhythmic":"鹧鸪天","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["笑拈红梅亸翠翘。","扬州十里最妖饶。","夜来绮席亲曾见，撮得精神滴滴娇。","娇后眼，舞时腰。","刘郎几度欲魂消。","明朝酒醒知何处，肠断云间《紫玉箫》。"]},{"id":"c59-113","title":"少年游·银塘朱槛曲尘波","rhythmic":"少年游","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["银塘朱槛曲尘波。","圆绿卷新荷。","兰条荐浴，菖花酿酒，天气尚清和。","好将沈醉酬佳节，十分酒、一分歌。","狱草烟深，讼庭人悄，无吝宴游过。"]},{"id":"c59-114","title":"少年游·去年相送","rhythmic":"少年游","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["去年相送，馀杭门外，飞雪似杨花。","今年春尽，杨花似雪，犹不见还家。","对酒卷帘邀明月，风露透窗纱。","恰似姮娥怜双燕，分明照、画梁斜。"]},{"id":"c59-115","title":"定风波·两两轻红半晕腮","rhythmic":"定风波","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["两两轻红半晕腮。","依依独为使君回。","若道使君无此意。","何为。","双花不向别人开。","但看低昂烟雨里。","不已。","劝君休诉十分杯。","更问尊前狂副使。","来岁。","花开时节与谁来。"]},{"id":"c59-116","title":"定风波·莫听穿林打叶声","rhythmic":"定风波","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["莫听穿林打叶声。","何妨吟啸且徐行。","竹杖芒鞋轻胜马。","谁怕。","一蓑烟雨任平生。","料峭春风吹酒醒。","微冷。","山头斜照却相迎。","回首向来潇洒处。","归去。","也无风雨也无晴。"]},{"id":"c59-117","title":"定风波·与客携壶上翠微","rhythmic":"定风波","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["与客携壶上翠微。","江涵秋影雁初飞。","尘世难逢开口笑。","年少。","菊花须插满头归。","酩酊但酬佳节了。","云峤。","登临不用怨斜晖。","古往今来谁不老。","多少。","牛山何必更沾衣。"]},{"id":"c59-118","title":"定风波·莫怪鸳鸯绣带长","rhythmic":"定风波","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["莫怪鸳鸯绣带长。","腰轻不胜舞衣裳。","薄幸只贪游冶去。","何处。","垂杨系马恣轻狂。","花谢絮飞春又尽。","堪恨。","断弦尘管伴啼妆。","不信归来但自看。","怕见。","为郎憔悴却羞郎。"]},{"id":"c59-119","title":"定风波·千古风流阮步兵","rhythmic":"定风波","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["千古风流阮步兵。","平生游宦爱东平。","千里远来还不住。","归去。","空留风韵照人清。","红粉尊前深懊恼。","休道。","怎生留得许多情。","记得明年花絮乱。","须看。","泛西湖是断肠声。"]},{"id":"c59-120","title":"定风波·雨洗娟娟嫩叶光","rhythmic":"定风波","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["雨洗娟娟嫩叶光。","风吹细细绿筠香。","秀色乱侵书帙晚。","帘卷。","清阴微过酒尊凉。","人画竹身肥拥肿。","何用。","先生落笔胜萧郎。","记得小轩岑寂夜。","廊下。","月和疏影上东墙。"]},{"id":"c59-121","title":"定风波·好睡慵开莫厌迟","rhythmic":"定风波","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["好睡慵开莫厌迟。","自怜冰脸不时宜。","偶作小红桃杏色，闲雅，尚馀孤瘦雪霜姿。","休把闲心随物态，何事，酒生微晕沁瑶肌。","诗老不知梅格在，吟咏，更看绿叶与青枝。"]},{"id":"c59-122","title":"定风波·月满苕溪照夜堂","rhythmic":"定风波","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["月满苕溪照夜堂。","五星一老斗光芒。","十五年间真梦里。","何事。","长庚对月独凄凉。","绿鬓苍颜同一醉。","还是。","六人吟笑水云乡。","宾主谈锋谁得似。","看取。","曹刘今对两苏张。"]},{"id":"c59-123","title":"定风波·常羡人间琢玉郎","rhythmic":"定风波","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["常羡人间琢玉郎。","天应乞与点酥娘。","尽道清歌传皓齿。","风起。","雪飞炎海变清凉。","万里归来颜愈少。","微笑。","笑时犹带岭梅香。","试问岭南应不好。","却道。","此心安处是吾乡。"]},{"id":"c59-124","title":"南乡子·晚景落琼杯","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["晚景落琼杯。","照眼云山翠作堆。","认得岷峨春雪浪，初来。","万顷蒲萄涨渌醅。","暮雨暗阳台。","乱洒高楼湿粉腮。","一阵东风来卷地，吹回。","落照江天一半开。"]},{"id":"c59-125","title":"南乡子·寒雀满疏篱","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["寒雀满疏篱。","争抱寒柯看玉蕤。","忽见客来花下坐，惊飞。","蹋散芳英落酒卮。","痛饮又能诗。","坐客无毡醉不知。","花尽酒阑春到也，离离。","一点微酸已著枝。"]},{"id":"c59-126","title":"南乡子·不到谢公台","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["不到谢公台。","明月清风好在哉。","旧日髯孙何处去，重来。","短李风流更上才。","秋色渐摧颓。","满院黄英映酒杯。","看取桃花春二月，争开。","尽是刘郎去后栽。"]},{"id":"c59-127","title":"南乡子·霜降水痕收","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["霜降水痕收。","浅碧鳞鳞露远洲。","酒力渐消风力软，飕飕。","破帽多情却恋头。","佳节若为酬。","但把清尊断送秋。","万事到头都是梦，休休。","明日黄花蝶也愁。"]},{"id":"c59-128","title":"南乡子·回首乱山横","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["回首乱山横。","不见居人只见城。","谁似临平山上塔，亭亭。","迎客西来送客行。","归路晚风清。","一枕初寒梦不成。","今夜残灯斜照处，荧荧。","秋雨晴时泪不晴。"]},{"id":"c59-129","title":"南乡子·冰雪透香肌","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["冰雪透香肌。","姑射仙人不似伊。","濯锦江头新样锦，非宜。","故著寻常淡薄衣。","暖日下重帏。","春睡香凝索起迟。","曼倩风流缘底事，当时。","爱被西真唤作儿。"]},{"id":"c59-130","title":"南乡子·东武望馀杭","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["东武望馀杭。","云海天涯两杳茫。","何日功成名遂了，还乡。","醉笑陪公三万场。","不用诉离觞。","痛饮从来别有肠。","今夜送归灯火冷，河塘。","堕泪羊公却姓杨。"]},{"id":"c59-131","title":"南乡子·凉簟碧纱厨","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["凉簟碧纱厨。","一枕清风昼睡馀。","睡听晚衙无一事，徐徐。","读尽床头几卷书。","搔首赋归欤。","自觉功名懒更疏。","若问使君才与术，何如。","占得人间一味愚。"]},{"id":"c59-132","title":"南乡子·裙带石榴红","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["裙带石榴红。","却水殷勤解赠侬。","应许逐鸡鸡莫怕，相逢。","一点灵犀必暗通。","何处遇良工。","琢刻天真半欲空。","愿作龙香双凤拨，轻拢。","长在环儿白雪胸。"]},{"id":"c59-133","title":"南乡子·旌旆满江湖","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["旌旆满江湖。","诏发楼船万舳舻。","投笔将军因笑我，迂儒。","帕首腰刀是丈夫。","粉泪怨离居。","喜子垂窗报捷书。","试问伏波三万语，何如。","一斛明珠换绿珠。"]},{"id":"c59-134","title":"南乡子·天与化工知","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["天与化工知。","赐得衣裳总是绯。","每向华堂深处见，怜伊。","两个心肠一片儿。","自小便相随。","绮席歌筵不暂离。","苦恨人人分拆破，东西。","怎得成双似旧时。"]},{"id":"c59-135","title":"南乡子·寒玉细凝肤","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["寒玉细凝肤。","清歌一曲《倒金壶》。","冶叶倡条遍相识，争如。","豆蔻花梢二月初。","年少即须臾。","芳时偷得醉工夫。","罗帐细垂银烛背，欢娱。","豁得平生俊气无。"]},{"id":"c59-136","title":"南乡子·怅望送春杯","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["怅望送春杯。","渐老逢春能几回。","花满楚城愁远别，伤怀。","何况清丝急管催。","吟断望乡台。","万里归心独上来。","景物登临闲始见，徘徊。","一寸相思一寸灰。"]},{"id":"c59-137","title":"南乡子·何处倚阑干","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["何处倚阑干。","弦管高楼月正圆。","胡蝶梦中家万里，依然。","老去愁来强自宽。","明镜借红颜。","须著人间比梦间。","蜡烛半笼金翡翠，更阑。","绣被焚香独自眠。"]},{"id":"c59-138","title":"南歌子·山与歌眉敛","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["山与歌眉敛，波同醉眼流。","游人都上十三楼。","不羡竹西歌吹、古扬州。","菰黍连昌歜，琼彝倒玉舟。","谁家《水调》唱歌头。","声绕碧山飞去、晚云留。"]},{"id":"c59-139","title":"南歌子·古岸开青葑","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["古岸开青葑，新渠走碧流。","会看光满万家楼。","记取他年扶路、入西州。","佳节连梅雨，馀生寄叶舟。","只将菱角与鸡头。","更有月明千顷、一时留。"]},{"id":"c59-140","title":"南乡子·雨暗初疑夜","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["雨暗初疑夜，风回忽报晴。","淡云斜照著山明。","细草软沙溪路、马蹄轻。","卯酒醒还困，仙材梦不成。","蓝桥何处觅云英。","只有多情流水、伴人行。"]},{"id":"c59-141","title":"南歌子·日出西山雨","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["日出西山雨，无晴又有晴。","乱山深处过清明。","不见彩绳花板、细腰轻。","尽日行桑野，无人与目成。","且将新句琢琼英。","我是世间闲客、此闲行。"]},{"id":"c59-142","title":"南歌子·带酒冲山雨","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["带酒冲山雨，和衣睡晚晴。","不知钟鼓报天明。","梦里栩然蝴蝶、一身轻。","老去才都尽，归来计未成。","求田问舍笑豪英。","自爱湖边沙路、免泥行。"]},{"id":"c59-143","title":"南歌子·日薄花房绽","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["日薄花房绽，风和麦浪轻。","夜来微雨洗郊坰。","正是一年春好、近清明。","已改煎茶火，犹调入粥饧。","使君高会有馀清。","此乐无声无味、最难名。"]},{"id":"c59-144","title":"南歌子·海上乘槎侣","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["海上乘槎侣，仙人萼绿华。","飞升元不用丹砂。","住在潮头来处、渺天涯。","雷辊夫差国，云翻海若家。","坐中安得弄琴牙。","写取馀声归向、水仙夸。"]},{"id":"c59-145","title":"南歌子·苒苒中秋过","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["苒苒中秋过，萧萧两鬓华。","寓身化世一尘沙。","笑看潮来潮去、了生涯。","方士三山路，渔人一叶家。","早知身世两聱牙。","好伴骑鲸公子、赋雄夸。"]},{"id":"c59-146","title":"南歌子·师唱谁家曲","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["师唱谁家曲，宗风嗣阿谁。","借君拍板与门槌。","我也逢场作戏、莫相疑。","溪女方偷眼，山僧莫眨眉。","却愁弥勒下生迟。","不见老婆三五、少年时。"]},{"id":"c59-147","title":"南歌子·欲执河梁手","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["欲执河梁手，还升月旦堂。","酒阑人散月侵廊。","北客明朝归去、雁南翔。","窈窕高明玉，风流郑季庄。","一时分散水云乡。","惟有落花芳草、断人肠。"]},{"id":"c59-148","title":"南歌子·山雨潇潇过","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["山雨潇潇过，溪桥浏浏清。","小园幽榭枕苹汀。","门外月华如水、彩舟横。","苕岸霜花尽，江湖雪阵平。","两山遥指海门青。","回首水云何处、觅孤城。"]},{"id":"c59-149","title":"南歌子·紫陌寻春去","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["紫陌寻春去，红尘拂面来。","无人不道看花回。","惟见石榴新蕊、一枝开。","冰簟堆云髻，金尊滟玉醅。","绿阴青子莫相催。","留取红巾千点、照池台。"]},{"id":"c59-150","title":"南歌子·卫霍元勋后","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["卫霍元勋后，韦平外族贤。","吹笙只合在缑山。","闲驾彩峦归去、趁新年。","烘暖烧香阁，轻寒浴佛天。","他时一醉画堂前。","莫忘故人憔悴、老江边。"]},{"id":"c59-151","title":"南歌子·笑怕蔷薇罥","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["笑怕蔷薇罥，行忧宝瑟僵。","美人依约在西厢。","祗恐暗中迷路、认馀香。","午夜风翻幔，三更月到床。","簟纹如水玉肌凉。","何物与侬归去、有残妆。"]},{"id":"c59-152","title":"南歌子·寸恨谁云短","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["寸恨谁云短，绵绵岂易裁。","半年眉绿未曾开。","明月好风闲处、是人猜。","春雨消残冻，温风到冷灰。","尊前一曲为谁哉。","留取曲终一拍、待君来。"]},{"id":"c59-153","title":"南歌子·绀绾双蟠髻","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["绀绾双蟠髻，云敧小偃巾。","轻盈红脸小腰身。","叠鼓忽催花拍、斗精神。","空阔轻红歇，风和约柳春。","蓬山才调最清新。","胜似缠头千锦、共藏珍。"]},{"id":"c59-154","title":"南歌子·琥珀装腰佩","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["琥珀装腰佩，龙香入领巾。","只应飞燕是前身。","共看剥葱纤手、舞凝神。","柳絮风前转，梅花雪里春。","鸳鸯翡翠两争新。","但得周郎一顾、胜珠珍。"]},{"id":"c59-155","title":"好事近·红粉莫悲啼","rhythmic":"好事近","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["红粉莫悲啼，俯仰半年离别。","看取雪堂坡下，老农夫凄切。","明年春水漾桃花，柳岸隘舟楫。","从此满城歌吹，看黄州阗咽。"]},{"id":"c59-156","title":"好事近·湖上雨晴时","rhythmic":"好事近","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["湖上雨晴时，秋水半篙初没。","朱槛俯窥寒鉴，照衰颜华发。","醉中吹堕白纶巾，溪风漾流月。","独棹小舟归去，任烟波飘兀。"]},{"id":"c59-157","title":"鹊桥仙·缑山仙子","rhythmic":"鹊桥仙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["缑山仙子，高情云渺，不学痴牛呆女。","凤箫声断月明中，举手谢、时人欲去。","客槎曾犯，银河微浪，尚带天风海雨。","相逢一醉是前缘，风雨散、飘然何处。"]},{"id":"c59-158","title":"鹊桥仙·乘槎归去","rhythmic":"鹊桥仙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["乘槎归去，成都何在，万里江沱汉漾。","与君各赋一篇诗，留织女、鸳鸯机上。","还将旧曲，重赓新韵，须信吾侪天放。","人生何处不儿嬉，看乞巧、朱楼彩舫。"]},{"id":"c59-159","title":"望江南・忆江南·春已老","rhythmic":"望江南・忆江南","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["春已老，春服几时成。","曲水浪低蕉叶稳，舞雩风软纻罗轻。","酣咏乐升平。","微雨过，何处不催耕。","百舌无言桃李尽，柘林深处鹁鸪鸣。","春色属芜菁。"]},{"id":"c59-160","title":"望江南・忆江南·春未老","rhythmic":"望江南・忆江南","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["春未老，风细柳斜斜。","试上超然台上看，半壕春水一城花。","烟雨暗千家。","寒食后，酒醒却咨嗟。","休对故人思故国，且将新火试新茶。","诗酒趁年华。"]},{"id":"c59-161","title":"卜算子·蜀客到江南","rhythmic":"卜算子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["蜀客到江南，长忆吴山好。","吴蜀风流自古同，归去应须早。","还与去年人，共藉西湖草。","莫惜尊前仔细看，应是容颜老。"]},{"id":"c59-162","title":"卜算子·缺月挂疏桐","rhythmic":"卜算子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["缺月挂疏桐，漏断人初静。","时见幽人独往来，缥缈孤鸿影。","惊起却回头，有恨无人省。","拣尽寒枝不肯栖，枫落吴江冷。"]},{"id":"c59-163","title":"瑞鹧鸪·碧山影里小红旗","rhythmic":"瑞鹧鸪","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["碧山影里小红旗。","侬是江南踏浪儿。","拍手欲嘲山简醉，齐声争唱《浪婆词》。","西兴渡口帆初落，渔浦山头日未敧。","侬欲送潮歌底曲，尊前还唱使君诗。"]},{"id":"c59-164","title":"十拍子・破阵子·白酒新开九酝","rhythmic":"十拍子・破阵子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["白酒新开九酝，黄花已过重阳。","身外傥来都似梦，醉里无何即是乡。","东坡日月长。","玉粉旋烹茶乳，金齑新捣橙香。","强染霜髭扶翠袖，莫道狂夫不解狂。","狂夫老更狂。"]},{"id":"c59-165","title":"清平乐·清淮蜀汴","rhythmic":"清平乐","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["清淮蜀汴。","更在江西岸。","红旆到时黄叶乱。","霜入梁王故苑。","秋原何处携壶。","停骖访古踟蹰。","双庙遗风尚在，漆园傲吏应无。"]},{"id":"c59-166","title":"昭君怨·谁作桓伊《三弄","rhythmic":"昭君怨","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["谁作桓伊《三弄》。","惊破绿窗幽梦。","新月与愁烟。","满江天。","欲去又还不去。","明日落花飞絮。","飞絮送行舟。","水东流。"]},{"id":"c59-167","title":"戚氏·玉龟山","rhythmic":"戚氏","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["玉龟山。","东皇灵媲统群仙。","绛阙岧嶢，翠房深迥，倚霏烟。","幽闲。","志萧然。","金城千里锁婵娟。","当时穆满巡狩。","翠华曾到海西边。","风露明霁，鲸波极目，势浮舆盖方圆。","正迢迢丽日。","玄圃清寂，琼草芊绵。","争解绣勒香鞯。","鸾辂驻跸，八马戏芝田。","瑶池近、画楼隐隐，翠鸟翩翩。","肆华筵。","间作脆管鸣弦。","宛若帝所钧天。","稚颜皓齿，绿发方瞳，圆极恬淡高妍。","尽倒琼壶酒，献金鼎药，固大椿年。","缥缈飞琼妙舞，命双成、奏曲醉留连。","云璈韵响泻寒泉。","浩歌畅饮，斜月低河汉。","渐渐绮霞、天际红深浅。","动归思、回首尘寰。","烂漫游、玉辇东还。","杏花风、数里响鸣鞭。","望长安路，依稀柳色，翠点春妍。"]},{"id":"c59-168","title":"醉蓬莱·笑劳生一梦","rhythmic":"醉蓬莱","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["笑劳生一梦，羁旅三年，又还重九。","华发萧萧，对荒园搔首。","赖有多情，好饮无事，似古人贤守。","岁岁登高，年年落帽，物华依旧。","此会应须烂醉，仍把紫菊茱萸，细看重嗅。","摇落霜风，有手栽双柳。","来岁今朝，为我西顾，酹羽觞江口。","会与州人，饮公遗爱，一江醇酎。"]},{"id":"c59-169","title":"贺新郎·乳燕飞华屋","rhythmic":"贺新郎","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["乳燕飞华屋。","悄无人、桐阴转午，晚凉新浴。","手弄生绡白团扇，扇手一时似玉。","渐困倚、孤眠清熟。","帘外谁来推绣户，枉教人、梦断瑶台曲。","又却是，风敲竹。","石榴半吐红巾蹙。","待浮花、浪蕊都尽，伴君幽独。","秾艳一枝细看取，芳心千重似束。","又恐被、秋风惊绿。","若待得君来向此，花前对酒不忍触。","共粉泪，两蔌蔌。"]},{"id":"c59-170","title":"洞仙歌·江南腊尽","rhythmic":"洞仙歌","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["江南腊尽，早梅花开后。","分付新春与垂柳。","细腰肢、自有入格风流，仍更是、骨体清英雅秀。","永丰坊那畔，尽日无人，惟见金丝弄晴昼。","断肠是，飞絮时，绿叶成阴，无个事、一成消瘦。","又莫是、东风逐君来，便吹散眉间，一点春皱。"]},{"id":"c59-171","title":"洞仙歌·冰肌玉骨","rhythmic":"洞仙歌","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["冰肌玉骨，自清凉无汗。","水殿风来暗香满。","绣帘开、一点明月窥人，人未寝、敧枕钗横鬓乱。","起来携素手，庭户无声，时见疏星渡河汉。","试问夜如何，夜已三更，金波淡、玉绳低转。","但屈指、西风几时来，又不道、流年暗中偷换。"]},{"id":"c59-172","title":"八声甘州·有情风","rhythmic":"八声甘州","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["有情风、万里卷潮来，无情送潮归。","问钱塘江上，西兴浦口，几度斜晖。","不用思量今古，俯仰昔人非。","谁似东坡老，白首忘机。","记取西湖西畔，正暮山好处，空翠烟霏。","算诗人相得，如我与君稀。","约他年、东还海道，愿谢公、雅志莫相违。","西州路，不应回首，为我沾衣。"]},{"id":"c59-173","title":"三部乐·美人如月","rhythmic":"三部乐","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["美人如月。","乍见掩暮云，更增妍绝。","算应无恨，安用阴晴圆缺。","娇甚空只成愁，待下床又懒，未语先咽。","数日不来，落尽一庭红叶。","今朝置酒强起，问为谁减动，一分香雪。","何事散花却病，维摩无疾。","却低眉、惨然不答。","唱金缕、一声怨切。","堪折便折。","且惜取、少年花发。"]},{"id":"c59-174","title":"阮郎归·绿槐高柳咽新蝉","rhythmic":"阮郎归","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["绿槐高柳咽新蝉。","薰风初入弦。","碧纱窗下水沈烟。","棋声惊昼眠。","微雨过，小荷翻。","榴花开欲然。","玉盆纤手弄清泉。","琼珠碎却圆。"]},{"id":"c59-175","title":"阮郎归·暗香浮动月黄昏","rhythmic":"阮郎归","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["暗香浮动月黄昏。","堂前一树春。","东风何事入西邻。","儿家常闭门。","雪肌冷，玉容真。","香腮粉未匀。","折花欲寄岭头人。","江南日暮云。"]},{"id":"c59-176","title":"阮郎归·一年三度过苏台","rhythmic":"阮郎归","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["一年三度过苏台。","清尊长是开。","佳人相问苦相猜。","这回来不来。","情未尽，老先催。","人生真可咍，他年桃李阿谁栽。","刘郎双鬓衰。"]},{"id":"c59-177","title":"江神子・江城子·梦中了了醉中醒","rhythmic":"江神子・江城子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["梦中了了醉中醒。","只渊明。","是前生。","走遍人间，依旧却躬耕。","昨夜东坡春雨足，乌鹊喜，报新晴。","雪堂西畔暗泉鸣。","北山倾。","小溪横。","南望亭丘，孤秀耸曾城。","都是斜川当日境，吾老矣，寄馀龄。"]},{"id":"c59-178","title":"江神子・江城子·翠蛾羞黛怯人看","rhythmic":"江神子・江城子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["翠蛾羞黛怯人看。","掩霜纨。","泪偷弹。","且尽一尊，收泪唱阳关。","漫道帝城天样远，天易见，见君难。","画堂新拘近孤山。","曲阑干。","为谁安。","飞絮落花，春色属明年。","欲棹小舟寻旧事，无处问，水连天。"]},{"id":"c59-179","title":"江神子・江城子·凤凰山下雨初晴","rhythmic":"江神子・江城子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["凤凰山下雨初晴。","水风清。","晚霞明。","一朵芙蕖，开过尚盈盈。","何处飞来双白鹭，如有意，慕娉婷。","忽闻江上弄哀筝。","苦含情，遣谁听。","烟敛云收，依约是湘灵。","欲待曲终寻问取，人不见，数峰青。"]},{"id":"c59-180","title":"江神子・江城子·老夫聊发少年狂","rhythmic":"江神子・江城子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["老夫聊发少年狂。","左牵黄。","右擎苍。","锦帽貂裘，千骑卷平冈。","为报倾城随太守，亲射虎，看孙郎。","酒酣胸胆尚开张。","鬓微霜。","又何妨。","持节云中，何日遣冯唐。","会挽雕弓如满月，西北望，射天狼。"]},{"id":"c59-181","title":"江神子・江城子·天涯流落思无穷","rhythmic":"江神子・江城子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["天涯流落思无穷。","既相逢。","却匆匆。","携手佳人，和泪折残红。","为问东风馀几许，春纵在，与谁同。","隋堤三月水溶溶。","背归鸿。","去吴中。","回首彭城，清泗与淮通。","寄我相思千点泪，流不到，楚江东。"]},{"id":"c59-182","title":"江神子・江城子·相逢不觉又初寒","rhythmic":"江神子・江城子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["相逢不觉又初寒。","对尊前。","惜流年。","风紧离亭，冰结泪珠圆。","雪意留君君不住，从此去，少清欢。","转头山下转头看。","路漫漫。","玉花翻。","银海光宽，何处是超然。","知道故人相念否，携翠袖，倚朱阑。"]},{"id":"c59-183","title":"江神子・江城子·黄昏犹是雨纤纤","rhythmic":"江神子・江城子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["黄昏犹是雨纤纤。","晓开帘。","欲平檐。","江阔天低，无处认青帘。","孤坐冻吟谁伴我，揩病目，拈衰髯。","使君留客醉厌厌。","水晶盐。","为谁甜。","手把梅花，东望忆陶潜。","雪似故人人似雪，虽可爱，有人嫌。"]},{"id":"c59-184","title":"江神子・江城子·玉人家在凤凰山","rhythmic":"江神子・江城子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["玉人家在凤凰山。","水云间。","掩门关。","门外行人，立马看弓弯。","十里春风谁指似，斜日映，绣帘斑。","多情好事与君还。","闵新鳏。","拭馀潸。","明月空江，香雾著云鬟。","陌上花开春尽也，闻旧曲，破朱颜。"]},{"id":"c59-185","title":"江神子・江城子·十年生死两茫茫","rhythmic":"江神子・江城子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["十年生死两茫茫。","不思量。","自难忘。","千里孤坟，无处话凄凉。","纵使相逢应不识，尘满面，鬓如霜。","夜来幽梦忽还乡。","小轩窗。","正梳妆。","相顾无言，惟有泪千行。","料得年年断肠处，明月夜，短松冈。"]},{"id":"c59-186","title":"蝶恋花·花褪残红青杏小","rhythmic":"蝶恋花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["花褪残红青杏小。","燕子飞时，绿水人家绕。","枝上柳绵吹又少。","天涯何处无芳草。","墙里秋千墙外道。","墙外行人，墙里佳人笑。","笑渐不闻声渐悄。","多情却被无情恼。"]},{"id":"c59-187","title":"蝶恋花·一颗樱桃樊素口","rhythmic":"蝶恋花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["一颗樱桃樊素口。","不爱黄金，只爱人长久。","学画鸦儿犹未就。","眉间已作伤春皱。","扑蝶西园随伴走。","花落花开，渐解相思瘦。","破镜重圆人在否。","章台折尽青青柳。"]},{"id":"c59-188","title":"蝶恋花·雨后春容清更丽","rhythmic":"蝶恋花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["雨后春容清更丽。","只有离人，幽恨终难洗。","北固山前三面水。","碧琼梳拥青螺髻。","一纸乡书来万里。","问我何年，真个成归计。","白首送春拼一醉。","东风吹破千行泪。"]},{"id":"c59-189","title":"蝶恋花·簌簌无风花自亸","rhythmic":"蝶恋花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["簌簌无风花自亸。","寂寞园林，柳老樱桃过。","落日多情还照坐。","山青一点横云破。","路尽河回千转柁。","系缆渔村，月暗孤灯火。","凭仗飞魂招楚些。","我思君处君思我。"]},{"id":"c59-190","title":"蝶恋花·灯火钱塘三五夜","rhythmic":"蝶恋花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["灯火钱塘三五夜。","明月如霜，照见人如画。","帐底吹笙香吐麝。","此般风味应无价。","寂寞山城人老也。","击鼓吹箫，乍入农桑社。","火冷灯稀霜露下。","昏昏雪意云垂野。"]},{"id":"c59-191","title":"蝶恋花·帘外东风交雨霰","rhythmic":"蝶恋花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["帘外东风交雨霰。","帘里佳人，笑语如莺燕。","深惜今年正月暖。","灯光酒色摇金盏。","掺鼓《渔阳》挝未遍。","舞褪琼钗，汗湿香罗软。","今夜何人吟古怨。","清诗未就冰生砚。"]},{"id":"c59-192","title":"蝶恋花·自古涟漪佳绝地","rhythmic":"蝶恋花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["自古涟漪佳绝地。","绕郭荷花，欲把吴兴比。","倦客尘埃何处洗。","真君堂下寒泉水。","左海门前酤酒市。","夜半潮来，月下孤舟起。","倾盖相逢拼一醉。","双凫飞去人千里。"]},{"id":"c59-193","title":"蝶恋花·云水萦回溪上路","rhythmic":"蝶恋花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["云水萦回溪上路。","叠叠青山，环绕溪东注。","月白沙汀翘宿鹭。","更无一点尘来处。","溪叟相看私自语。","底事区区，苦要为官去。","尊酒不空田百亩。","归来分得闲中趣。"]},{"id":"c59-194","title":"采桑子·多情多感仍多病","rhythmic":"采桑子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["多情多感仍多病，多景楼中。","尊酒相逢。","乐事回头一笑空。","停杯且听琵琶语，细拈轻拢。","醉脸春融。","斜照江天一抹红。"]},{"id":"c59-195","title":"千秋岁·浅霜侵绿","rhythmic":"千秋岁","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["浅霜侵绿。","发少仍新沐。","冠直缝，巾横幅。","美人怜我老，玉手簪黄菊。","秋露重，真珠落袖沾馀馥。","坐上人如玉。","花映花奴肉。","蜂蝶乱，飞相逐。","明年人纵健，此会应难复。","须细看，晚来月上和银烛。"]},{"id":"c59-196","title":"苏幕遮·暑笼晴","rhythmic":"苏幕遮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["暑笼晴，风解愠。","雨后馀清，暗袭衣裾润。","一局选仙逃暑困。","笑指尊前、谁向青霄近。","整金盆，轮玉笋。","凤驾鸾车，谁敢争先进。","重五休言升最紧。","纵有碧油，到了输堂印。"]},{"id":"c59-197","title":"永遇乐·长忆别时","rhythmic":"永遇乐","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["长忆别时，景疏楼上，明月如水。","美酒清歌，留连不住，月随人千里。","别来三度，孤光又满，冷落共谁同醉。","卷珠帘，凄然顾影，共伊到明无寐。","今朝有客，来从淮上，能道使君深意。","凭仗清淮，分明到海，中有相思泪。","而今何在，西垣清禁，夜永露华侵被。","此时看，回廊晓月，也应暗记。"]},{"id":"c59-198","title":"永遇乐·明月如霜","rhythmic":"永遇乐","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["明月如霜，好风如水，清景无限。","曲港跳鱼，圆荷泻露，寂寞无人见。","紞如三鼓，铿然一叶，黯黯梦云惊断。","夜茫茫，重寻无处，觉来小园行遍。","天涯倦客，山中归路，望断故园心眼。","燕子楼空，佳人何在，空锁楼中燕。","古今如梦，何曾梦觉，但有旧欢新怨。","异时对，黄楼夜景，为余浩叹。"]},{"id":"c59-199","title":"行香子·绮席才终","rhythmic":"行香子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["绮席才终。","欢意犹浓。","酒阑时、高兴无穷。","共夸君赐，初拆臣封。","看分香饼，黄金缕，密云龙。","斗赢一水，功敌千锺。","觉凉生、两腋清风。","暂留红袖，少却纱笼。","放笙歌散，庭馆静，略从容。"]}]