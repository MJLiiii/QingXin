","kind":"诗"},{"id":"t43-67","title":"从军","kind":"诗"},{"id":"t43-68","title":"宫词二首 一","kind":"诗"},{"id":"t43-69","title":"宫词二首 二","kind":"诗"},{"id":"t53-413","title":"长句赠微之（题拟）","kind":"诗"}]}}