{"张建封":{"slug":"张建封","name":"张建封","dynasty":"唐","style":"字本立","life":"","origin":"","seal":"张","bio":["张建封，字本立，南阳人。少喜文章，尚气节，历官御史大夫、徐泗濠节度使。有诗文二百三十篇，今存诗二首。","张建封字本立，邓州南阳人。少任侠，喜文章。贞元四年拜御史大夫、徐泗濠节度使，十六年病卒，年六十六。","补句二。"],"works":[{"id":"t14-697","title":"竞渡歌","kind":"诗"},{"id":"t14-698","title":"酬韩校书愈打毬歌","kind":"诗"},{"id":"t50-625","title":"句（朝天行）","kind":"诗"}]},"张珍奴":{"slug":"张珍奴","name":"张珍奴","dynasty":"宋","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"c66-992","title":"失调名·逢师许多时","kind":"词"}]},"徐巡官":{"slug":"徐巡官","name":"徐巡官","dynasty":"唐","style":"","life":"","origin":"","seal":"徐","bio":["徐巡官，名不详，李崧同时人。（《全唐诗》无徐巡官诗）"],"works":[{"id":"t55-242","title":"送宾","kind":"诗"},{"id":"t55-243","title":"贻友生","kind":"诗"}]},"李宣远":{"slug":"李宣远","name":"李宣远","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李宣远，贞元进士登第。诗二首。"],"works":[{"id":"t24-918","title":"并州路","kind":"诗"},{"id":"t24-919","title":"近无西耗","kind":"诗"}]},"游子西":{"slug":"游子西","name":"游子西","dynasty":"宋","style":"","life":"","origin":"","seal":"游","bio":[],"works":[{"id":"c73-967","title":"念奴娇·暑尘收尽","kind":"词"}]},"窦弘余":{"slug":"窦弘余","name":"窦弘余","dynasty":"唐","style":"","life":"","origin":"","seal":"窦","bio":[],"works":[{"id":"t49-191","title":"广谪仙怨","kind":"诗"}]},"翁合":{"slug":"翁合","name":"翁合","dynasty":"宋","style":"","life":"","origin":"","seal":"翁","bio":[],"works":[{"id":"c73-822","title":"贺新郎·世事今如许","kind":"词"},{"id":"c73-823","title":"卜算子·口诵百中经","kind":"词"}]},"萧微":{"slug":"萧微","name":"萧微","dynasty":"唐","style":"","life":"","origin":"","seal":"萧","bio":[],"works":[{"id":"t47-965","title":"题少陵别墅","kind":"诗"}]},"郑元璹":{"slug":"郑元璹","name":"郑元璹","dynasty":"唐","style":"字德芳","life":"","origin":"","seal":"郑","bio":["元璹，字德芳，荥阳开封人。隋封莘国公，大业末为文城郡守。入唐，官太常卿。","尝使突厥，被留数年，归拜鸿胪卿。贞观间封沛国公，二十年卒。诗一首。","（《全唐诗》无郑元璹诗，传据《旧唐书》卷六二本传）"],"works":[{"id":"t52-71","title":"四言曲池酺饮座铭","kind":"诗"}]},"陆凭":{"slug":"陆凭","name":"陆凭","dynasty":"唐","style":"","life":"","origin":"","seal":"陆","bio":[],"works":[{"id":"t47-957","title":"咏浮云","kind":"诗"}]},"陈子良":{"slug":"陈子良","name":"陈子良","dynasty":"唐","style":"","life":"","origin":"","seal":"陈","bio":["陈子良，吴人。在隋时为杨素记室。入唐，官右卫率府长史，与萧德言、庾抱同为隐太子学士，贞观六年卒。","集十卷，今存诗十三首。"],"works":[{"id":"t2-692","title":"上之回","kind":"诗"},{"id":"t2-693","title":"新成安乐宫","kind":"诗"},{"id":"t2-694","title":"夏晚寻于政世置酒赋韵","kind":"诗"},{"id":"t2-695","title":"入蜀秋夜宿江渚","kind":"诗"},{"id":"t2-696","title":"赋得妓","kind":"诗"},{"id":"t2-697","title":"詶萧侍中春园听妓","kind":"诗"},{"id":"t2-698","title":"游侠篇","kind":"诗"},{"id":"t2-699","title":"春晚看群公朝还人为八韵","kind":"诗"},{"id":"t2-700","title":"赞德上越国公杨素","kind":"诗"},{"id":"t2-701","title":"于塞北春日思归","kind":"诗"},{"id":"t2-702","title":"送别","kind":"诗"},{"id":"t2-703","title":"七夕看新妇隔巷停车","kind":"诗"},{"id":"t2-704","title":"咏春雪","kind":"诗"},{"id":"t51-988","title":"学小庾体","kind":"诗"}]}}