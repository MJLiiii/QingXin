"","seal":"拓","bio":[],"works":[{"id":"t51-725","title":"和韦庄贺陈咏归蜀（句）（唐前朝进士陈咏，眉州青神人，有诗名，善弈棋。昭宗劫迁，驻跸陕郊，是岁策名归蜀，韦书记庄以诗贺之。又有乡人拓善者，属和韦诗，其略云云，讥其比涤器当垆也。谬称冯副使涓诗，以涓多谐戏故也。或云：蜀之拓善者作此诗，假冯公之名也。）","kind":"诗"}]},"曾协":{"slug":"曾协","name":"曾协","dynasty":"宋","style":"","life":"","origin":"","seal":"曾","bio":[],"works":[{"id":"c66-194","title":"点绛唇·小驻征骖","kind":"词"},{"id":"c66-195","title":"点绛唇·乱叠香罗","kind":"词"},{"id":"c66-196","title":"浣溪沙·昼漏新来一倍长","kind":"词"},{"id":"c66-197","title":"秦楼月・忆秦娥·清秋月","kind":"词"},{"id":"c66-198","title":"桃源忆故人·野亭问柳今朝试","kind":"词"},{"id":"c66-199","title":"踏莎行·柳眼传情","kind":"词"},{"id":"c66-200","title":"凤栖梧・蝶恋花·柳弄轻黄花泣露","kind":"词"},{"id":"c66-201","title":"祝英台・祝英台近·放花开","kind":"词"},{"id":"c66-202","title":"水调歌头·今日复何日","kind":"词"},{"id":"c66-203","title":"水调歌头·日永向槐夏","kind":"词"},{"id":"c66-204","title":"酹江月・念奴娇·一年好处","kind":"词"},{"id":"c66-205","title":"酹江月・念奴娇·苕溪古岸","kind":"词"},{"id":"c66-206","title":"酹江月・念奴娇·一年好处","kind":"词"},{"id":"c66-207","title":"水龙吟·楚乡菰黍初尝","kind":"词"}]},"李敬伯":{"slug":"李敬伯","name":"李敬伯","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李敬伯，西川观察巡官、试大理评事。诗二首。"],"works":[{"id":"t17-567","title":"和段相公登武担寺西台","kind":"诗"},{"id":"t17-568","title":"奉陪段相公晚夏登张仪楼","kind":"诗"}]},"李溟":{"slug":"李溟","name":"李溟","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李溟，与贾岛同时。诗一首。"],"works":[{"id":"t25-157","title":"无题","kind":"诗"}]},"李璟":{"slug":"李璟","name":"李璟","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t51-603","title":"应天长（〖1〗后主云：「先皇御制歌词。」墨迹在晁公留家○王国维辑《南唐二主词》。今按：《全唐诗》八八九作李煜词。）","kind":"诗"}]},"温会":{"slug":"温会","name":"温会","dynasty":"唐","style":"","life":"","origin":"","seal":"温","bio":["温会，以殿中侍御史为西川安抚判官。诗二首。"],"works":[{"id":"t17-565","title":"和段相公登武担寺西台","kind":"诗"},{"id":"t17-566","title":"奉陪段相公晚夏登张仪楼","kind":"诗"}]},"萧遘":{"slug":"萧遘","name":"萧遘","dynasty":"唐","style":"","life":"","origin":"","seal":"萧","bio":["萧遘，徐国公嵩之四代孙。咸通五年，登进士第，僖宗幸蜀，拜相，后为伪煴所污，赐死。诗三首。"],"works":[{"id":"t33-336","title":"春诗","kind":"诗"},{"id":"t33-337","title":"和王侍中谒张恶子庙","kind":"诗"},{"id":"t33-338","title":"成都","kind":"诗"},{"id":"t33-339","title":"句","kind":"诗"}]},"陈孙":{"slug":"陈孙","name":"陈孙","dynasty":"唐","style":"","life":"","origin":"","seal":"陈","bio":["陈孙，明皇时人。诗一首。"],"works":[{"id":"t13-513","title":"移耶溪旧居呈陈元初校书","kind":"诗"}]},"魏璀":{"slug":"魏璀","name":"魏璀","dynasty":"唐","style":"","life":"","origin":"","seal":"魏","bio":["魏璀，天宝进士。一首。"],"works":[{"id":"t10-60","title":"湘灵鼓瑟","kind":"诗"}]},"黄庭坚":{"slug":"黄庭坚","name":"黄庭坚","dynasty":"宋","style":"字鲁直 · 号山谷道人","life":"1045 — 1105","origin":"分宁（今江西修水）","seal":"黄","bio":["(1045-1105) 字鲁直，号山谷道人、涪翁。分宁 (今江西修水) 人。治平四年 (1067) 举进士。","历著作佐郎、秘书丞。绍圣初，以校书郎坐修《神宗实录》失实贬涪州别驾，黔州安置。徽宗立，召知太平州，九日而罢，复除名，编管宜州。","三年而徙永州，未闻命而卒。“苏门四学士”之一。诗与苏轼齐名，世称苏黄。","江西诗派之宗主，影响极大。词与秦观齐名，号秦七、黄九。词风疏宕，俚俗处甚于柳永。","晁无咎谓其小词固高妙，然非当行家语，自是著腔子唱好诗。著有《豫章集》、《山谷词》。"],"works":[{"id":"c60-255","title":"念奴娇·断虹霁雨","kind":"词"},{"id":"c60-256","title":"水调歌头·瑶草一何碧","kind":"词"},{"id":"c60-257","title":"水调歌头·落日塞垣路","kind":"词"},{"id":"c60-258","title":"满庭芳·初绾云鬟","kind":"词"},{"id":"c60-259","title":"满庭芳·北苑春风","kind":"词"},{"id":"c60-260","title":"鼓笛慢・水龙吟·早秋明月新圆","kind":"词"},{"id":"c60-261","title":"洞仙歌·月中丹桂","kind":"词"},{"id":"c60-262","title":"雨中花・夜行船·政乐中和","kind":"词"},{"id":"c60-263","title":"忆帝京·鸣鸠乳燕春闲暇","kind":"词"},{"id":"c60-264","title":"醉蓬莱·对朝云叆叇","kind":"词"},{"id":"c60-265","title":"南歌子·诗有渊明语","kind":"词"},{"id":"c60-266","title":"蓦山溪·鸳鸯翡翠","kind":"词"},{"id":"c60-267","title":"转调丑奴儿・采桑子·得意许多时","kind":"词"},{"id":"c60-268","title":"品令·败叶霜天晓","kind":"词"},{"id":"c60-269","title":"踏莎行·画鼓催春","kind":"词"},{"id":"c60-270","title":"踏莎行·临水夭桃","kind":"词"},{"id":"c60-271","title":"定风波·自断此生休问天","kind":"词"},{"id":"c60-272","title":"定风波·万里黔中一漏天","kind":"词"},{"id":"c60-273","title":"定风波·晚岁监州闻荔枝","kind":"词"},{"id":"c60-274","title":"定风波·准拟阶前摘荔枝","kind":"词"},{"id":"c60-275","title":"鹊桥仙·八年不见","kind":"词"},{"id":"c60-276","title":"鹊桥仙·朱楼彩舫","kind":"词"},{"id":"c60-277","title":"阮郎归·黔中桃李可寻芳","kind":"词"}