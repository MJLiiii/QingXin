[{"id":"c58-200","title":"江南好・忆江南·丞相有才裨造化","rhythmic":"江南好・忆江南","author":"叶清臣","authorSlug":"叶清臣","dynasty":"宋","kind":"ci","paragraphs":["丞相有才裨造化，圣皇宽诏养疏顽。","赢取十年闲。"]},{"id":"c58-201","title":"贺圣朝·满斟绿醑留君住","rhythmic":"贺圣朝","author":"叶清臣","authorSlug":"叶清臣","dynasty":"宋","kind":"ci","paragraphs":["满斟绿醑留君住。","莫匆匆归去。","三分春色二分愁，更一分风雨。","花开花谢、都来几许。","且高歌休诉。","不知来岁牡丹时，再相逢何处。"]},{"id":"c58-202","title":"折红梅·喜冰澌初泮","rhythmic":"折红梅","author":"吴感","authorSlug":"吴感","dynasty":"宋","kind":"ci","paragraphs":["喜冰澌初泮，微和渐入、东郊时节。","春消息，夜来顿觉，红梅数枝争发。","玉溪仙馆，不是个、寻常标格。","化工别与、一种风情，似匀点胭脂，染成香雪。","重吟细阅。","比繁杏夭桃，品格真别。","只愁共、彩云易散，冷落谢池风月。","凭谁向说。","三弄处、龙吟休咽。","大家留取，时倚阑干，闻有花堪折，劝君须折。"]},{"id":"c58-203","title":"映山红·遂请后","rhythmic":"映山红","author":"文彦博","authorSlug":"文彦博","dynasty":"宋","kind":"ci","paragraphs":["遂请后。","愿频醉、石楼溪口。"]},{"id":"c58-204","title":"西湖念语·昔者王子猷之爱","rhythmic":"西湖念语","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["昔者王子猷之爱竹，造门不问于主人，陶渊明之卧舆，遇酒便留于道士。","况西湖之胜概，擅东颍之佳名。","虽美景良辰，固多于高会。","而清风明月，幸属于闲人。","并游或结于良朋，乘兴有时而独往。","鸣蛙暂听，安问属官而属私。","曲水临流，自可一觞而一咏。","至欢然而会意，亦傍若于无人。","乃知偶来常胜於特来，前言可信。","所有虽非于己有，其得已多。","因翻旧阕之辞，写以新声之调，敢阵薄伎，聊佐清欢。"]},{"id":"c58-205","title":"采桑子·轻舟短棹西湖好","rhythmic":"采桑子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["轻舟短棹西湖好，绿水逶迤。","芳草长堤。","隐隐笙歌处处随。","无风水面琉璃滑，不觉船移。","微动涟漪。","惊起沙禽掠岸飞。"]},{"id":"c58-206","title":"采桑子·春深雨过西湖好","rhythmic":"采桑子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["春深雨过西湖好，百卉争妍。","蝶乱蜂喧。","晴日催花暖欲然。","兰桡画舸悠悠去，疑是神仙。","返照波间。","水阔风高扬管弦。"]},{"id":"c58-207","title":"采桑子·画船载酒西湖好","rhythmic":"采桑子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["画船载酒西湖好，急管繁弦。","玉盏催传。","稳泛平波任醉眠。","行云却在行舟下，空水澄鲜。","俯仰留连。","疑是湖中别有天。"]},{"id":"c58-208","title":"采桑子·群芳过后西湖好","rhythmic":"采桑子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["群芳过后西湖好，狼籍残红。","飞絮濛濛。","垂柳阑干尽日风。","笙歌散尽游人去，始觉春空。","垂下帘栊。","双燕归来细雨中。"]},{"id":"c58-209","title":"采桑子·何人解赏西湖好","rhythmic":"采桑子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["何人解赏西湖好，佳景无时。","飞盖相追。","贪向花间醉玉卮。","谁知闲凭阑干处，芳草斜晖。","水远烟微。","一点沧洲白鹭飞。"]},{"id":"c58-210","title":"采桑子·清明上巳西湖好","rhythmic":"采桑子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["清明上巳西湖好，满目繁华。","争道谁家。","绿柳朱轮走钿车。","游人日暮相将去，醒醉喧哗。","路转堤斜。","直到城头总是花。"]},{"id":"c58-211","title":"采桑子·荷花开后西湖好","rhythmic":"采桑子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["荷花开后西湖好，载酒来时。","不用旌旗。","前后红幢绿盖随。","画船撑入花深处，香泛金卮。","烟雨微微。","一片笙歌醉里归。"]},{"id":"c58-212","title":"采桑子·天容水色西湖好","rhythmic":"采桑子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["天容水色西湖好，云物俱鲜。","鸥鹭闲眠。","应惯寻常听管弦。","风清月白偏宜夜，一片琼田。","谁羡骖鸾。","人在舟中便是仙。"]},{"id":"c58-213","title":"采桑子·残霞夕照西湖好","rhythmic":"采桑子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["残霞夕照西湖好，花坞苹汀。","十顷波平。","野岸无人舟自横。","西南月上浮云散，轩槛凉生。","莲芰香清。","水面风来酒面醒。"]},{"id":"c58-214","title":"采桑子·平生为爱西湖好","rhythmic":"采桑子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["平生为爱西湖好，来拥朱轮。","富贵浮云。","俯仰流年二十春。","归来恰似辽东鹤，城郭人民。","触目皆新。","谁识当年旧主人。"]},{"id":"c58-215","title":"采桑子·画楼钟动君休唱","rhythmic":"采桑子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["画楼钟动君休唱，往事无踪。","聚散匆匆。","今日欢娱几客同。","去年绿鬓今年白，不觉衰容。","明月清风。","把酒何人忆谢公。"]},{"id":"c58-216","title":"采桑子·十年一别流光速","rhythmic":"采桑子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["十年一别流光速，白首相逢。","莫话衰翁。","但斗尊前语笑同。","劝君满酌君须醉，尽日从容。","画鹢牵风。","即去朝天沃舜聪。"]},{"id":"c58-217","title":"采桑子·十年前是尊前客","rhythmic":"采桑子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["十年前是尊前客，月白风清。","忧患凋零。","老去光阴速可惊。","鬓华虽改心无改，试把金觥。","旧曲重听。","犹是当年醉里声。"]},{"id":"c58-218","title":"朝中措·平山阑槛倚晴空","rhythmic":"朝中措","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["平山阑槛倚晴空。","山色有无中。","手种堂前垂柳，别来几度春风。","文章太守，挥毫万字，一饮千锺。","行乐直须年少，尊前看取衰翁。"]},{"id":"c58-219","title":"长相思·苹满溪","rhythmic":"长相思","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["苹满溪。","柳绕堤。","相送行人溪水西。","回时陇月低。","烟霏霏。","风凄凄。","重倚朱门听马嘶。","寒鸥相对飞。"]},{"id":"c58-220","title":"长相思·花似伊","rhythmic":"长相思","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["花似伊。","柳似伊。","花柳青春人别离。","低头双泪垂。","长江东。","长江西。","两岸鸳鸯两处飞。","相逢知几时。"]},{"id":"c58-221","title":"长相思·深花枝","rhythmic":"长相思","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["深花枝。","浅花枝。","深浅花枝相并时。","花枝难似伊。","玉如肌。","柳如眉。","爱著鹅黄金缕衣。","啼妆更为谁。"]},{"id":"c58-222","title":"诉衷情·清晨帘幕卷轻霜","rhythmic":"诉衷情","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["清晨帘幕卷轻霜。","呵手试梅妆。","都缘自有离恨，故画作远山长。","思往事，惜流芳。","易成伤。","拟歌先敛，欲笑还颦，最断人肠。"]},{"id":"c58-223","title":"踏莎行·候馆梅残","rhythmic":"踏莎行","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["候馆梅残，溪桥柳细。","草熏风暖摇征辔。","离愁渐远渐无穷，迢迢不断如春水。","寸寸柔肠，盈盈粉泪。","楼高莫近危阑倚。","平芜尽处是春山，行人更在春山外。"]},{"id":"c58-224","title":"踏莎行·雨霁风光","rhythmic":"踏莎行","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["雨霁风光，春分天气。","千花百卉争明媚。","画梁新燕一双双，玉笼鹦鹉愁孤睡。","薜荔依墙，莓苔满地。","青楼几处歌声丽。","蓦然旧事心上来，无言敛皱眉山翠。"]},{"id":"c58-225","title":"望江南・忆江南·江南蝶","rhythmic":"望江南・忆江南","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["江南蝶，斜日一双双。","身似何郎全傅粉，心如韩寿爱偷香。","天赋与轻狂。","微雨后，薄翅腻烟光。","才伴游蜂来小院，又随飞絮过东墙。","长是为花忙。"]},{"id":"c58-226","title":"减字木兰花·留春不住","rhythmic":"减字木兰花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["留春不住。","燕老莺慵无觅处。","说似残春。","一老应无却少人。","风和月好。","办得黄金须买笑。","爱惜芳时。","莫待无花空折枝。"]},{"id":"c58-227","title":"减字木兰花·伤怀离抱","rhythmic":"减字木兰花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["伤怀离抱。","天若有情天亦老。","此意如何。","细似轻丝渺似波。","扁舟岸侧。","枫叶荻花秋索索。","细想前欢。","须著人间比梦间。"]},{"id":"c58-228","title":"减字木兰花·楼台向晓","rhythmic":"减字木兰花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["楼台向晓。","淡月低云天气好。","翠幕风微。","宛转梁州入破时。","香生舞袂。","楚女腰肢天与细。","汗粉重匀。","酒后轻寒不著人。"]},{"id":"c58-229","title":"减字木兰花·画堂雅宴","rhythmic":"减字木兰花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["画堂雅宴。","一抹朱弦初入遍。","慢拈轻笼。","玉指纤纤嫩剥葱。","拨头憁利。","怨月愁花无限意。","红粉轻盈。","倚暖香檀曲未成。"]},{"id":"c58-230","title":"减字木兰花·歌檀敛袂","rhythmic":"减字木兰花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["歌檀敛袂。","缭绕雕梁尘暗起。","柔润清圆。","百琲明珠一线穿。","樱唇玉齿。","天上仙音心下事。","留往行云。","满坐迷魂酒半醺。"]},{"id":"c58-231","title":"生查子·去年元夜时","rhythmic":"生查子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["去年元夜时，花市灯如昼。","月到柳梢头，人约黄昏后。","今年元夜时，月与灯依旧。","不见去年人，泪满春衫袖。"]},{"id":"c58-232","title":"生查子·含羞整翠鬟","rhythmic":"生查子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["含羞整翠鬟，得意频相顾。","雁柱十三弦，一一春莺语。","娇云容易飞，梦断知何处。","深院锁黄昏，阵阵芭蕉雨。"]},{"id":"c58-233","title":"清商怨·关河愁思望处满","rhythmic":"清商怨","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["关河愁思望处满。","渐素秋向晚。","雁过南云，行人回泪眼。","双鸾衾裯悔展。","夜又永、枕孤人远。","梦未成归，梅花闻塞管。"]},{"id":"c58-234","title":"阮郎归·刘郎何日是来时","rhythmic":"阮郎归","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["刘郎何日是来时。","无心云胜伊。","行云犹解傍山飞。","郎行去不归。","强匀画，又芳菲。","春深轻薄衣。","桃花无语伴相思。","阴阴月上时。"]},{"id":"c58-235","title":"阮郎归·落花浮水树临池","rhythmic":"阮郎归","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["落花浮水树临池。","年前心眼期。","见来无事去还思。","而今花又飞。","浅螺黛，淡燕脂。","闲妆取次宜。","隔帘风雨闭门时。","此情风月知。"]},{"id":"c58-236","title":"蝶恋花·帘幕东风寒料峭","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["帘幕东风寒料峭。","雪里香梅，先报春来早。","红蜡枝头双燕小。","金刀剪彩呈纤巧。","旋暖金炉薰蕙藻。","酒入横波，困不禁烦恼。","绣被五更春睡好。","罗帏不觉纱窗晓。"]},{"id":"c58-237","title":"蝶恋花·南雁依稀回侧阵","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["南雁依稀回侧阵。","雪霁墙阴，遍觉兰芽嫩。","中夜梦馀消酒困。","炉香卷穗灯生晕。","急景流年都一瞬。","往事前欢，未免萦芳寸。","腊后花期知渐近。","东风已作寒梅信。"]},{"id":"c58-238","title":"蝶恋花·腊雪初销梅蕊绽","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["腊雪初销梅蕊绽。","梅雪相和，喜鹊穿花转。","睡起夕阳迷醉眼。","新愁长向东风乱。","瘦觉玉肌罗带缓。","红杏梢头，二月春犹浅。","望极不来芳信断。","音书纵有争如见。"]},{"id":"c58-239","title":"蝶恋花·海燕双来归画栋","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["海燕双来归画栋。","帘影无风，花影频移动。","半醉腾腾春睡重。","绿鬟堆枕香云拥。","翠被双盘金缕凤。","忆得前春，有个人人共。","花里黄莺时一弄。","日斜惊起相思梦。"]},{"id":"c58-240","title":"蝶恋花·面旋落花风荡漾","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["面旋落花风荡漾。","柳重烟深，雪絮飞来往。","雨后轻寒犹未放。","春愁酒病成惆怅。","枕畔屏山围碧浪。","翠被华灯，夜夜空相向。","寂寞起来褰绣幌。","月明正在梨花上。"]},{"id":"c58-241","title":"蝶恋花·帘幕风轻双语燕","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["帘幕风轻双语燕。","午后醒来，柳絮飞撩乱。","心事一春犹未见。","红英落尽青苔院。","百尺朱楼闲倚遍。","薄雨浓云，抵死遮人面。","羌管不须吹别怨。","无肠更为新声断。"]},{"id":"c58-242","title":"蝶恋花·永日环堤乘彩舫","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["永日环堤乘彩舫。","烟草萧疏，恰似晴江上。","水浸碧天风皱浪。","菱花荇蔓随双桨。","红粉佳人翻丽唱。","惊起鸳鸯，两两飞相向。","且把金尊倾美酿。","休思往事成惆怅。"]},{"id":"c58-243","title":"蝶恋花·越女采莲秋水畔","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["越女采莲秋水畔。","窄袖轻罗，暗露双金钏。","照影摘花花似面。","芳心只共丝争乱。","鸂鶒滩头风浪晚。","雾重烟轻，不见来时伴。","隐隐歌声归棹远。","离愁引著江南岸。"]},{"id":"c58-244","title":"蝶恋花·水浸秋天风皱浪","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["水浸秋天风皱浪。","缥缈仙舟，只似秋天上。","和露采莲愁一饷。","看花却是啼妆样。","折得莲茎丝未放。","莲断丝牵，特地成惆怅。","归棹莫随花荡漾。","江头有个人相望。"]},{"id":"c58-245","title":"蝶恋花·梨叶初红婵韵歇","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["梨叶初红婵韵歇。","银汉风高，玉管声凄切。","枕簟乍凉铜漏彻。","谁教社燕轻离别。","草际虫吟秋露结。","宿酒醒来，不记归时节。","多少衷肠犹未说。","珠帘夜夜朦胧月。"]},{"id":"c58-246","title":"蝶恋花·独倚危楼风细细","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["独倚危楼风细细。","望极离愁，黯黯生天际。","草色山光残照里。","无人会得凭阑意。","也拟疏狂图一醉。","对酒当歌，强饮还无味。","衣带渐宽都不悔。","况伊销得人憔悴。"]},{"id":"c58-247","title":"蝶恋花·帘下清歌帘外宴","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["帘下清歌帘外宴。","虽爱新声，不见如花面。","牙板数敲珠一串。","梁尘暗落琉璃盏。","桐树花深孤凤怨。","渐遏遥天，不放行云散。","坐上少年听未惯。","玉山将倒肠先断。"]},{"id":"c58-248","title":"蝶恋花·翠苑红芳晴满目","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["翠苑红芳晴满目。","绮席流莺，上下长相逐。","紫陌闲随金轹辘。","马蹄踏遍春郊绿。","一觉年华春梦促。","往事悠悠，百种寻思足。","烟雨满楼山断续。","人闲倚遍阑干曲。"]},{"id":"c58-249","title":"蝶恋花·小院深深门掩亚","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["小院深深门掩亚。","寂寞珠帘，画阁重重下。","欲近禁烟微雨罢。","绿杨深处秋千挂。","傅粉狂游犹未舍。","不念芳时，眉黛无人画。","薄幸未归春去也。","杏花零落香红谢。"]},{"id":"c58-250","title":"蝶恋花·欲过清明烟雨细","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["欲过清明烟雨细。","小槛临窗，点点残花坠。","梁燕语多惊晓睡。","银屏一半堆香被。","新岁风光如旧岁。","所恨征轮，渐渐程迢递。","纵有远情难写寄。","何妨解有相思泪。"]},{"id":"c58-251","title":"蝶恋花·画阁归来春又晚","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["画阁归来春又晚。","燕子双飞，柳软桃花浅。","细雨满天风满院。","愁眉敛尽无人见。","独倚阑干心绪乱。","芳草芊绵，尚忆江南岸。","风月无情人暗换。","旧游如梦空肠断。"]},{"id":"c58-252","title":"蝶恋花·尝爱西湖春色早","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["尝爱西湖春色早。","腊雪方销，已见桃开小。","顷刻光阴都过了。","如今绿暗红英少。","且趁馀花谋一笑。","况有笙歌，艳态相萦绕。","老去风情应不到。","凭君剩把芳尊倒。"]},{"id":"c58-253","title":"渔家傲·一派潺湲流碧涨","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["一派潺湲流碧涨。","新亭四面山相向。","翠竹岭头明月上。","迷俯仰。","月轮正在泉中漾。","更待高秋天气爽。","菊花香里开新酿。","酒美宾嘉真胜赏。","红粉唱。","山深分外歌声响。"]},{"id":"c58-254","title":"渔家傲·十月小春梅蕊绽","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["十月小春梅蕊绽。","红炉画阁新妆遍。","锦帐美人贪睡暖。","羞起晚。","玉壶一夜冰澌满。","楼上四垂帘不卷。","天寒山色偏宜远。","风急雁行吹字断。","红日短。","江天雪意云撩乱。"]},{"id":"c58-255","title":"渔家傲·四纪才名天下重","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["四纪才名天下重。","三朝构厦为梁栋。","定册功成身退勇。","辞荣宠。","归来白首笙歌拥。","顾我薄才无可用。","君恩近许归田垅。","今日一觞难得共。","聊对捧。","官奴为我高歌送。"]},{"id":"c58-256","title":"渔家傲·暖日迟迟花袅袅","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["暖日迟迟花袅袅。","人将红粉争花好。","花不能言惟解笑。","金壶倒。","花开未老人年少。","车马九门来扰扰。","行人莫羡长安道。","丹禁漏声衢鼓报。","催昏晓。","长安城里人先老。"]},{"id":"c58-257","title":"渔家傲·红粉墙头花几树","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["红粉墙头花几树。","落花片片和惊絮。","墙外有楼花有主。","寻花去。","隔墙遥见秋千侣。","绿索红旗双彩柱。","行人只得偷回顾。","肠断楼南金锁户。","天欲暮。","流莺飞到秋千处。"]},{"id":"c58-258","title":"渔家傲·妾本钱塘苏小妹","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["妾本钱塘苏小妹。","芙蓉花共门相对。","昨日为逢青伞盖。","慵不采。","今朝斗觉凋零晒。","愁倚画楼无计奈。","乱红飘过秋塘外。","料得明年秋色在。","香可爱。","其如镜里花颜改。"]},{"id":"c58-259","title":"渔家傲·花底忽闻敲两桨","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["花底忽闻敲两桨。","逡巡女伴来寻访。","酒盏旋将荷叶当。","莲舟荡。","时时盏里生红浪。","花气酒香清厮酿。","花腮酒面红相向。","醉倚绿阴眠一饷。","惊起望。","船头阁在沙滩上。"]},{"id":"c58-260","title":"渔家傲·叶有清风花有露","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["叶有清风花有露。","叶笼花罩鸳鸯侣。","白锦顶丝红锦羽。","莲女妒。","惊飞不许长相聚。","日脚沈红天色暮。","青凉伞上微微雨。","早是水寒无宿处。","须回步。","枉教雨里分飞去。"]},{"id":"c58-261","title":"渔家傲·荷叶田田青照水","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["荷叶田田青照水。","孤舟挽在花阴底。","昨夜萧萧疏雨坠。","愁不寐。","朝来又觉西风起。","雨摆风摇金蕊碎。","合欢枝上香房翠。","莲子与人长厮类。","无好意。","年年苦在中心里。"]},{"id":"c58-262","title":"渔家傲·叶重如将青玉亚","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["叶重如将青玉亚。","花轻疑是红绡挂。","颜色清新香脱洒。","堪长价。","牡丹怎得称王者。","雨笔露笺匀彩画。","日炉风炭薰兰麝。","天与多情丝一把。","谁厮惹。","千条万缕萦心下。"]},{"id":"c58-263","title":"渔家傲·粉蕊丹青描不得","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["粉蕊丹青描不得。","金针线线功难敌。","谁傍暗香轻采摘。","风淅淅。","船头触散双鸂鶒。","夜雨染成天水碧。","朝阳借出胭脂色。","欲落又开人共惜。","秋气逼。","盘中已见新荷的。"]},{"id":"c58-264","title":"渔家傲·幽鹭谩来窥品格","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["幽鹭谩来窥品格。","双鱼岂解传消息。","绿柄嫩香频采摘。","心似织。","条条不断谁牵役。","珠泪暗和清露滴。","罗衣染尽秋江色。","对面不言情脉脉。","烟水隔。","无人说似长相忆。"]},{"id":"c58-265","title":"渔家傲·楚国细腰元自瘦","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["楚国细腰元自瘦。","文君腻脸谁描就。","日夜鼓声催箭漏。","昏复昼。","红颜岂得长如旧。","醉拆嫩房红蕊嗅。","天丝不断清香透。","却傍小阑凝望久。","风满袖。","西池月上人归后。"]},{"id":"c58-266","title":"渔家傲·喜鹊填河仙浪浅","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["喜鹊填河仙浪浅。","云軿早在星桥畔。","街鼓黄昏霞尾暗。","炎光敛。","金钩侧倒天西面。","一别经年今始见。","新欢往恨知何限。","天上佳期贪眷恋。","良宵短。","人间不合催银箭。"]},{"id":"c58-267","title":"渔家傲·乞巧楼头云幔卷","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["乞巧楼头云幔卷。","浮花催洗严妆面。","花上蛛丝寻得遍。","颦笑浅。","双眸望月牵红线。","奕奕天河光不断。","有人正在长生殿。","暗付金钗清夜半。","千秋愿。","年年此会长相见。"]},{"id":"c58-268","title":"渔家傲·别恨长长欢计短","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["别恨长长欢计短。","疏锺促漏真堪怨。","此会此情都未半。","星初转。","鸾琴凤乐匆匆卷。","河鼓无言西北盼。","香蛾有恨东南远。","脉脉横波珠泪满。","归心乱。","离肠便逐星桥断。"]},{"id":"c58-269","title":"渔家傲·九日欢游何处好","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["九日欢游何处好。","黄花万蕊雕阑绕。","通体清香无俗调。","天气好。","烟滋露结功多少。","日脚清寒高下照。","宝钉密缀圆斜小。","落叶西园风袅袅。","催秋老。","丛边莫厌金尊倒。"]},{"id":"c58-270","title":"渔家傲·青女霜前催得绽","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["青女霜前催得绽。","金钿乱散枝头遍。","落帽台高开雅宴。","芳尊满。","挼花吹在流霞面。","桃李三春虽可羡。","莺来蝶去芳心乱。","争似仙潭秋水岸。","香不断。","年年自作茱萸伴。"]},{"id":"c58-271","title":"渔家傲·露裛娇黄风摆翠","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["露裛娇黄风摆翠。","人间晚秀非无意。","仙格淡妆天与丽。","谁可比。","女真装束真相似。","筵上佳人牵翠袂。","纤纤玉手挼新蕊。","美酒一杯花影腻。","邀客醉。","红琼共作熏熏媚。"]},{"id":"c58-272","title":"渔家傲·对酒当歌劳客劝","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["对酒当歌劳客劝。","惜花只惜年华晚。","寒艳冷香秋不管。","情眷眷。","凭栏尽日愁无限。","思抱芳期随塞雁。","悔无深意传双燕。","怅望一枝难寄远。","人不见。","楼头望断相思眼。"]},{"id":"c58-273","title":"玉楼春·风迟日媚烟光好","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["风迟日媚烟光好。","绿树依依芳意早。","年华容易即凋零，春色只宜长恨少。","池塘隐隐惊雷晓。","柳眼未开梅萼小。","尊前贪爱物华新，不道物新人渐老。"]},{"id":"c58-274","title":"玉楼春·西亭饮散清歌阕","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["西亭饮散清歌阕。","花外迟迟宫漏发。","涂金烛引紫骝嘶，柳曲西头归路别。","佳辰只恐幽期阔。","密赠殷勤衣上结。","翠屏魂梦莫相寻，禁断六街清夜月。"]},{"id":"c58-275","title":"玉楼春·春山敛黛低歌扇","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["春山敛黛低歌扇。","暂解吴钩登祖宴。","画楼钟动已魂销，何况马嘶芳草岸。","青门柳色随人远。","望欲断时肠已断。","洛城春色待君来，莫到落花飞似霰。"]},{"id":"c58-276","title":"玉楼春·尊前拟把归期说","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["尊前拟把归期说。","未语春容先惨咽。","人生自是有情痴，此恨不关风与月。","离歌且莫翻新阕。","一曲能教肠寸结。","直须看尽洛城花，始共春风容易别。"]},{"id":"c58-277","title":"玉楼春·洛阳正值芳菲节","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["洛阳正值芳菲节。","秾艳清香相间发。","游丝有意苦相萦，垂柳无端争赠别。","杏花红处青山缺。","山畔行人山下歇。","今宵谁肯远相随，惟有寂寥孤馆月。"]},{"id":"c58-278","title":"玉楼春·残春一夜狂风雨","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["残春一夜狂风雨。","断送红飞花落树。","人心花意待留春，春色无情容易去。","高楼把酒愁独语。","借问春归何处所。","暮云空阔不知音，惟有绿杨芳草路。"]},{"id":"c58-279","title":"玉楼春·常忆洛阳风景媚","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["常忆洛阳风景媚。","烟暖风和添酒味。","莺啼宴席似留人，花出墙头如有意。","别来已隔千山翠。","望断危楼斜日坠。","关心只为牡丹红，一片春愁来梦里。"]},{"id":"c58-280","title":"玉楼春·池塘水绿春微暖","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["池塘水绿春微暖。","记得玉真初见面。","从头歌韵响铮鏦，入破舞腰红乱旋。","玉钩帘下香阶畔。","醉后不知红日晚。","当时共我赏花人，点检如今无一半。"]},{"id":"c58-281","title":"玉楼春·两翁相遇逢佳节","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["两翁相遇逢佳节。","正值柳绵飞似雪。","便须豪饮敌青春，莫对新花羞白发。","人生聚散如弦筈。","老去风情尤惜别。","大家金盏倒垂莲，一任西楼低晓月。"]},{"id":"c58-282","title":"玉楼春·西湖南北烟波阔","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["西湖南北烟波阔。","风里丝簧声韵咽。","舞馀裙带绿双垂，酒入香腮红一抹。","杯深不觉琉璃滑。","贪看六么花十八。","明朝车马各西东，惆怅画桥风与月。"]},{"id":"c58-283","title":"玉楼春·燕鸿过后春归去","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["燕鸿过后春归去。","细算浮生千万绪。","来如春梦几多时，去似朝云无觅处。","闻琴解珮神仙侣。","挽断罗衣留不住。","劝君莫作独醒人，烂醉花间应有数。"]},{"id":"c58-284","title":"玉楼春·蝶飞芳草花飞路","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["蝶飞芳草花飞路。","把酒已嗟春色暮。","当时枝上落残花，今日水流何处去。","楼前独绕鸣蝉树。","忆把芳条吹暖絮。","红莲绿芰亦芳菲，不奈金风兼玉露。"]},{"id":"c58-285","title":"玉楼春·别后不知君远近","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["别后不知君远近。","触目凄凉多少闷。","渐行渐远渐无书，水阔鱼沈何处问。","夜深风竹敲秋韵。","万叶千声皆是恨。","故欹单枕梦中寻，梦又不成灯又尽。"]},{"id":"c58-286","title":"玉楼春·红条约束琼肌稳","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["红条约束琼肌稳。","拍碎香檀催急衮。","陇头呜咽水声繁，叶下间关莺语近。","美人才子传芳信。","明月清风伤别恨。","未知何处有知音，常为此情留此恨。"]},{"id":"c58-287","title":"玉楼春·檀槽碎响金丝拨","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["檀槽碎响金丝拨。","露湿浔阳江上月。","不知商妇为谁愁，一曲行人留夜发。","画堂花月新声别。","红蕊调长弹未彻。","暗将深意祝胶弦，唯愿弦弦无断绝。"]},{"id":"c58-288","title":"玉楼春·春葱指甲轻拢拈","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["春葱指甲轻拢拈。","五彩垂条双袖卷。","雪香浓透紫檀槽，胡语急随红玉腕。","当头一曲情何限。","入破铮鏦金凤战。","百分芳酒祝长春，再拜敛容抬粉面。"]},{"id":"c58-289","title":"玉楼春·金花盏面红烟透","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["金花盏面红烟透。","舞急香茵随步皱。","青春才子有新词，红粉佳人重劝酒。","也知自为伤春瘦。","归骑休交银烛候。","拟将沈醉为清欢，无奈醒来还感旧。"]},{"id":"c58-290","title":"玉楼春·雪云乍变春云簇","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["雪云乍变春云簇。","渐觉年华堪送目。","北枝梅蕊犯寒开，南浦波纹如酒绿。","芳菲次第还相续。","不奈情多无处足。","尊前百计得春归，莫为伤春歌黛蹙。"]},{"id":"c58-291","title":"玉楼春·黄金弄色轻於粉","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["黄金弄色轻於粉。","濯濯春条如水嫩。","为缘力薄未禁风，不奈多娇长似困。","腰柔乍怯人相近。","眉小未知春有恨。","劝君著意惜芳菲，莫待行人攀折尽。"]},{"id":"c58-292","title":"玉楼春·珠帘半下香销印","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["珠帘半下香销印。","二月东风催柳信。","琵琶傍畔且寻思，鹦鹉前头休借问。","惊鸿过后生离恨。","红日长时添酒困。","未知心在阿谁边，满眼泪珠言不尽。"]},{"id":"c58-293","title":"玉楼春·沈沈庭院莺吟弄","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["沈沈庭院莺吟弄。","日暖烟和春气重。","绿杨娇眼为谁回，芳草深心空自动。","倚阑无语伤离凤。","一片风情无处用。","寻思还有旧家心，蝴蝶时时来役梦。"]},{"id":"c58-294","title":"玉楼春·去时梅萼初凝粉","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["去时梅萼初凝粉。","不觉小桃风力损。","梨花最晚又凋零，何事归期无定准。","阑干倚遍重来凭。","泪粉偷将红袖印。","蜘蛛喜鹊误人多，似此无凭安足信。"]},{"id":"c58-295","title":"玉楼春·酒美春浓花世界","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["酒美春浓花世界。","得意人人千万态。","莫教辜负艳阳天，过了堆金何处买。","已去少年无计奈。","且愿芳心长恁在。","闲愁一点上心来，算得东风吹不解。"]},{"id":"c58-296","title":"玉楼春·湖边柳外楼高处","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["湖边柳外楼高处。","望断云山多少路。","阑干倚遍使人愁，又是天涯初日暮。","轻无管系狂无数。","水畔花飞风里絮。","算伊浑似薄情郎，去便不来来便去。"]},{"id":"c58-297","title":"玉楼春·南园粉蝶能无数","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["南园粉蝶能无数。","度翠穿红来复去。","倡条冶叶恣留连，飘荡轻於花上絮。","朱阑夜夜风兼露。","宿粉栖香无定所。","多情翻却似无情，赢得百花无限妒。"]},{"id":"c58-298","title":"玉楼春·江南三月春光老","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["江南三月春光老。","月落禽啼天未晓。","露和啼血染花红，恨过千家烟树杪。","云垂玉枕屏山小。","梦欲成时惊觉了。","人心应不似伊心，若解思归归合早。"]},{"id":"c58-299","title":"玉楼春·东风本是开花信","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["东风本是开花信。","及至花时风更紧。","吹开吹谢苦匆匆，春意到头无处问。","把酒临风千万恨。","欲扫残红犹未忍。","夜来风雨转离披，满眼凄凉愁不尽。"]}]