nd":"诗"}]},"竟脱":{"slug":"竟脱","name":"竟脱","dynasty":"唐","style":"","life":"","origin":"","seal":"竟","bio":["竟脱，嗣文偃住郢州林溪。诗五首。（《全唐诗》无竟脱和尚诗，传据《景德传灯录》卷二十二）"],"works":[{"id":"t56-56","title":"入道浅深颂 一","kind":"诗"},{"id":"t56-57","title":"入道浅深颂 二","kind":"诗"},{"id":"t56-58","title":"入道浅深颂 三","kind":"诗"},{"id":"t56-59","title":"入道浅深颂 四","kind":"诗"},{"id":"t56-60","title":"入道浅深颂 五","kind":"诗"}]},"章谒":{"slug":"章谒","name":"章谒","dynasty":"唐","style":"","life":"","origin":"","seal":"章","bio":["章碣，孝标之子。登干符进士第，后流落不知所终。诗一卷。"],"works":[{"id":"t37-225","title":"城南偶题","kind":"诗"},{"id":"t37-226","title":"赠边将","kind":"诗"},{"id":"t37-227","title":"桃源","kind":"诗"},{"id":"t37-228","title":"曲江","kind":"诗"},{"id":"t37-229","title":"送韦岫郎中典泗州","kind":"诗"},{"id":"t37-230","title":"赠婺州苏员外","kind":"诗"},{"id":"t37-231","title":"寄友人","kind":"诗"},{"id":"t37-232","title":"雨","kind":"诗"},{"id":"t37-233","title":"观锡宴","kind":"诗"},{"id":"t37-234","title":"城东即事","kind":"诗"},{"id":"t37-235","title":"夏日湖上即事寄晋陵萧明府","kind":"诗"},{"id":"t37-236","title":"对月","kind":"诗"},{"id":"t37-237","title":"浙西送杜晦侍御入关","kind":"诗"},{"id":"t37-238","title":"寄江东道友","kind":"诗"},{"id":"t37-239","title":"下第有怀","kind":"诗"},{"id":"t37-240","title":"春日经湖上友人别业","kind":"诗"},{"id":"t37-241","title":"长安春日","kind":"诗"},{"id":"t37-242","title":"陪浙西王侍郎夜宴","kind":"诗"},{"id":"t37-243","title":"春别","kind":"诗"},{"id":"t37-244","title":"送谢进士还闽","kind":"诗"},{"id":"t37-245","title":"焚书坑","kind":"诗"},{"id":"t37-246","title":"东都望幸","kind":"诗"},{"id":"t37-247","title":"旅舍早起","kind":"诗"},{"id":"t37-248","title":"癸卯岁毘陵登高会中贻同志","kind":"诗"},{"id":"t37-249","title":"上元夜建元寺观灯呈智通上人","kind":"诗"},{"id":"t37-250","title":"变体诗","kind":"诗"}]},"罗让":{"slug":"罗让","name":"罗让","dynasty":"唐","style":"字景宣","life":"","origin":"","seal":"罗","bio":["罗让，字景宣，迥之子。少以文学知名，举进士、宏辞、贤良方正，皆高第。历尚书郎，散骑常侍，终江西观察使。","集三十卷，今存诗二首。"],"works":[{"id":"t16-817","title":"梢云","kind":"诗"},{"id":"t16-818","title":"闰月定四时","kind":"诗"}]},"萧项":{"slug":"萧项","name":"萧项","dynasty":"唐","style":"","life":"","origin":"","seal":"萧","bio":["萧项，萧田人，官侍郎。昭宗末年，尝同翁承赞为册礼使使闽。诗一首。"],"works":[{"id":"t40-852","title":"赠翁承赞漆林书堂诗","kind":"诗"}]},"虞某":{"slug":"虞某","name":"虞某","dynasty":"宋","style":"","life":"","origin":"","seal":"虞","bio":[],"works":[{"id":"c64-765","title":"江神子・江城子·相逢只怕有分离","kind":"词"}]},"袁皓":{"slug":"袁皓","name":"袁皓","dynasty":"唐","style":"","life":"","origin":"","seal":"袁","bio":["袁皓，宜春人，登咸通进士第。僖宗狩蜀，擢仓部员外郎。龙纪中，为集贤殿图书使，自称碧池处士。","《碧池书》三十卷，今存诗四首。"],"works":[{"id":"t33-366","title":"重归宜春偶成十六韵寄朝中知己","kind":"诗"},{"id":"t33-367","title":"及第后作","kind":"诗"},{"id":"t33-368","title":"重归宜春经过萍川题梵林寺","kind":"诗"},{"id":"t33-369","title":"寄岳阳严使君","kind":"诗"}]},"裴度":{"slug":"裴度","name":"裴度","dynasty":"唐","style":"字中立","life":"","origin":"度状貌不逾中","seal":"裴","bio":["裴度，字中立，河东闻喜人。贞元中擢第，授河阴县尉，迁监察御史，出为河南府功曹，迁起居舍人。宪宗元和六年，以司封员外郎、知制诰，寻转本司郎中。","使魏州，还拜中书舍人，改御史中丞，寻兼刑部侍郎。十六年，拜门下侍郎同中书门下平章事。于时讨蔡，度请身自督战。","诏以度充淮西宣慰招讨处置使，蔡平，封晋国公，复知政事。为皇甫镈所构，出为太原尹、北都留守、河东节度使。穆宗长庆元年，河朔复乱，诏度以本官充镇州四面行营招讨使。","元稹拜平章事，罢度兵权，充东都留守，寻以守司徒同平章事，复知政事，李逢吉沮之，出为山南西道节度使。敬宗宝历元年，度入觐京师，帝礼遇隆厚，数日宣制，复知政事。文宗立，加门下侍郎，集贤殿大学士，进阶特进，以病恳辞机务，诏加守司徒，兼侍中，充山南东道节度等使。","太和八年，以本官判东都尚书省事，充东都留守，进位中书令，寻复兼太原尹、北都留守、河东节度使。度固辞，不允。至镇，病甚，乞还东都养病，诏许还京。","卒，赠太傅。度状貌不逾中人，而风彩俊爽，占对雄辩，出入中外，经事四朝，以身系国之安危者二十年。集二卷，今编诗一卷。","裴度字中立，河东闻喜人。以讨平淮蔡，擒吴元济，封晋国公。其后诛宦官刘克明，迎立文宗，屡秉国政，身系天下重轻者垂三十年，时人以比郭汾阳。","开成四年卒，年七十五。补诗一首。"],"works":[{"id":"t0-758","title":"郊庙歌辞 享惠昭太子庙乐章 亚献终献","kind":"诗"},{"id":"t17-896","title":"享惠昭太子庙乐章","kind":"诗"},{"id":"t17-897","title":"夏日对雨","kind":"诗"},{"id":"t17-898","title":"白二十二侍郎有双鹤留在洛下予西园多野水长松可以栖息遂以诗请之","kind":"诗"},{"id":"t17-899","title":"窦七中丞见示初至夏口献元戎诗辄戏和之","kind":"诗"},{"id":"t17-900","title":"酬张秘书因寄马赠诗","kind":"诗"},{"id":"t17-901","title":"真慧寺","kind":"诗"},{"id":"t17-902","title":"中书即事","kind":"诗"},{"id":"t17-903","title":"中和节诏赐公卿尺","kind":"诗"},{"id":"t17-904","title":"至日登乐游园","kind":"诗"},{"id":"t17-905","title":"奉酬中书相公至日圆丘摄事合于中书后阁宿斋移止于集贤院叙怀见寄之作","kind":"诗"},{"id":"t17-906","title":"太原题厅壁","kind":"诗"},{"id":"t17-907","title":"溪居","kind":"诗"},{"id":"t17-908","title":"喜遇刘二十八","kind":"诗"},{"id":"t17-909","title":"送刘","kind":"诗"},{"id":"t17-910","title":"再送","kind":"诗"},{"id":"t17-911","title":"凉风亭睡觉","kind":"诗"},{"id":"t17-912","title":"雪中讶诸公不相访","kind":"诗"},{"id":"t17-913","title":"傍水闲行","kind":"诗"},{"id":"t17-914","title":"句","kind":"诗"},{"id":"t43-555","title":"春池泛舟联句","kind":"诗"},{"id":"t43-556","title":"西池落泉联句","kind":"诗"},{"id":"t43-557","title":"首夏犹清和联句","kind":"诗"},{"id":"t43-558","title":"蔷薇花联句","kind":"诗"},{"id":"t43-559","title":"喜遇刘二十八偶书两韵联句","kind":"诗"},{"id":"t43-560","title":"刘二十八自汝赴左冯涂经洛中相见联句","kind":"诗"},{"id":"t43-561","title":"度自到洛中与乐天为文酒之会时时搆咏乐不可支则慨然共忆梦得而梦得亦分司至止欢惬可知因为联句","kind":"诗"},{"id":"t43-562","title":"宴兴化池亭送白二十二东归联句","kind":"诗"},{"id":"t43-563","title":"西池送白二十二东归兼寄令狐相公联句","kind":"诗"},{"id":"t50-626","title":"厅事之西因依墉壑为山数仞有悬水焉予理戎之暇聊以息䜩此相国张公之所作也缅怀高致时濯尘缨即事寄言而赋斯什","kind":"诗"},{"id":"t53-712","title":"新开龙泉晋水二池","kind":"诗"},{"id":"t53-713","title":"夏中雨后游城南庄示乐天八韵（题拟）","kind":"诗"}]},"赵崇":{"slug":"赵崇","name":"赵崇","dynasty":"唐","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"t54-355","title":"无题","kind":"诗"},{"id":"t54-356","title":"赠崔垂休诗（题拟）","kind":"诗"}]},"邵升":{"slug":"邵升","name":"邵升","dynasty":"唐","style":"","life":"","origin":"","seal":"邵","bio":["邵升，中宗时人。诗一首。"],"works":[{"id":"t3-933","title":"奉和初春幸太平公主南庄应制","kind":"诗"}]},"颜奎":{"slug":"颜奎","name":"颜奎","dynasty":"宋","style":"","life":"","origin":"","seal":"颜","bio":[],"works":[{"id":"c75-228","title":"醉太平·茶边水经","kind":"词"},{"id":"c75-229","title":"清平乐·留君少住","kind":"词"},{"id":"c75-230","title":"归平遥・归国遥·春□□拂拂","kind":"词"},{"id":"c75-231","title":"浣溪沙·梦泊游丝画影移","kind":"词"},{"id":"c75-232","title":"菩萨蛮·燕姬越女初相见","kind":"词"},{"id":"c75-233","title":"忆秦娥·水云幽","kind":"词"},{"id":"c75-234","title":"大·唱古荼䕷","kind":"词"},{"id":"c75-235","title":"摸鱼儿·对琴台","kind":"词"}]}}