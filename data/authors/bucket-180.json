{"傅伯达":{"slug":"傅伯达","name":"傅伯达","dynasty":"宋","style":"","life":"","origin":"","seal":"傅","bio":[],"works":[{"id":"c78-604","title":"沁园春·白帝司权","kind":"词"}]},"刘子翬":{"slug":"刘子翬","name":"刘子翬","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c63-822","title":"蓦溪山・蓦山溪·浮烟冷雨","kind":"词"},{"id":"c63-823","title":"满庭芳·秋入微阴","kind":"词"},{"id":"c63-824","title":"南歌子·卜夜容三献","kind":"词"},{"id":"c63-825","title":"南歌子·伎俩无多子","kind":"词"}]},"刘孝孙":{"slug":"刘孝孙","name":"刘孝孙","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":["刘孝孙，荆州人。弱冠知名，与虞世南、蔡君和、孔德绍、庾抱、庾自直、刘斌等登临山水，结为文会。武德初，历虞州录事参军，补文学馆学士。","贞观中，迁太子洗马，撰《古今诗苑》四十卷。集三十卷，今存诗七首。"],"works":[{"id":"t2-504","title":"游清都观寻沈道士得仙字","kind":"诗"},{"id":"t2-505","title":"早发成皐望河","kind":"诗"},{"id":"t2-506","title":"游灵山寺","kind":"诗"},{"id":"t2-507","title":"冬日宴于庶子宅各赋一字得鲜","kind":"诗"},{"id":"t2-508","title":"送刘散员同赋陈思王诗游人久不归","kind":"诗"},{"id":"t2-509","title":"咏笛","kind":"诗"},{"id":"t2-510","title":"赋得春莺送友人","kind":"诗"}]},"吕温":{"slug":"吕温","name":"吕温","dynasty":"唐","style":"字和叔","life":"","origin":"","seal":"吕","bio":["吕温，字和叔，一字化光，河中人。贞元末，擢进士第，因善王叔文，再迁为左拾遗。以侍御史使吐蕃，元和元年乃还。","柳宗元等皆坐叔文贬，温独免，进户部员外郎，与窦群、羊士谔相昵。群为御史中丞，荐温知杂事，士谔为御史，宰相李吉甫持之不报，温乘间奏吉甫阴事，诘辩皆妄，贬均州刺史，议者不厌。再贬道州，久之，徙衡州卒。","集十卷，内诗二卷，今编诗二卷。"],"works":[{"id":"t19-646","title":"白云起封中诗","kind":"诗"},{"id":"t19-647","title":"终南精舍月中闻磬声诗","kind":"诗"},{"id":"t19-648","title":"青出蓝诗","kind":"诗"},{"id":"t19-649","title":"奉和李相公早朝于中书候传点偶书所怀奉呈门下武相公中书郑相公","kind":"诗"},{"id":"t19-650","title":"奉和武中丞秋日台中寄怀简诸僚友","kind":"诗"},{"id":"t19-651","title":"吐蕃别馆和周十一郎中杨七录事望白水山作","kind":"诗"},{"id":"t19-652","title":"奉和张舍人阁中直夜思闻雅琴因书事通简僚友","kind":"诗"},{"id":"t19-653","title":"和舍弟惜花绝句","kind":"诗"},{"id":"t19-654","title":"和恭听晓笼中山鹊","kind":"诗"},{"id":"t19-655","title":"和舍弟让笼中鹰","kind":"诗"},{"id":"t19-656","title":"同恭夏日题寻真观李宽中秀才书院","kind":"诗"},{"id":"t19-657","title":"同舍弟恭岁暮寄晋州李六协律三十韵","kind":"诗"},{"id":"t19-658","title":"青海西寄窦三端公","kind":"诗"},{"id":"t19-659","title":"蕃中拘留岁余回至陇石先寄城中亲故","kind":"诗"},{"id":"t19-660","title":"吐蕃别馆卧病寄朝中诸友","kind":"诗"},{"id":"t19-661","title":"吐蕃别馆中和日寄朝中僚旧","kind":"诗"},{"id":"t19-662","title":"及第后荅潼关主人","kind":"诗"},{"id":"t19-663","title":"河中城南姚家浴后题赠主人","kind":"诗"},{"id":"t19-664","title":"看浑中丞山桃花初有他客不通晚方得入因有戏赠","kind":"诗"},{"id":"t19-665","title":"赠友人","kind":"诗"},{"id":"t19-666","title":"道州夏日郡内北桥新亭书怀赠何元二处士","kind":"诗"},{"id":"t19-667","title":"道州弘道县主簿知县三年颇著廉慎秩满县阙申使请留将赴衡州题其厅事","kind":"诗"},{"id":"t19-668","title":"道州将赴衡州酬别江华毛令","kind":"诗"},{"id":"t19-669","title":"道州夏日早访荀参军林园敬酬见赠","kind":"诗"},{"id":"t19-670","title":"道州敬酬何处士怀郡楼月夜之作","kind":"诗"},{"id":"t19-671","title":"道州敬酬何处士书情见赠","kind":"诗"},{"id":"t19-672","title":"戏赠灵澈上人","kind":"诗"},{"id":"t19-673","title":"二月一日是贞元旧节有感绝句寄黔南窦三洛阳卢七","kind":"诗"},{"id":"t19-674","title":"初发道州荅崔三连州题海阳亭见寄绝句","kind":"诗"},{"id":"t19-675","title":"荅段秀才","kind":"诗"},{"id":"t19-676","title":"宗礼欲往桂州苦雨因以戏赠","kind":"诗"},{"id":"t19-677","title":"道州奉寄襄阳裴相公","kind":"诗"},{"id":"t19-678","title":"吐蕃别馆月夜","kind":"诗"},{"id":"t19-679","title":"望思台作","kind":"诗"},{"id":"t19-680","title":"孟冬蒲津关河亭作","kind":"诗"},{"id":"t19-681","title":"巩路感怀","kind":"诗"},{"id":"t19-682","title":"题梁宣帝陵二首 一","kind":"诗"},{"id":"t19-683","title":"题梁宣帝陵二首 二","kind":"诗"},{"id":"t19-684","title":"岳阳怀古","kind":"诗"},{"id":"t19-685","title":"道州途中即事","kind":"诗"},{"id":"t19-686","title":"登少陵原望秦中诸川太原王至德妙用有水术因用感叹","kind":"诗"},{"id":"t19-687","title":"奉敕祭南岳十四韵","kind":"诗"},{"id":"t19-688","title":"经河源军汉邨作","kind":"诗"},{"id":"t19-689","title":"题河州赤岸桥","kind":"诗"},{"id":"t19-690","title":"题阳人城","kind":"诗"},{"id":"t19-691","title":"晋王龙骧墓","kind":"诗"},{"id":"t19-692","title":"题石勒城二首 一","kind":"诗"},{"id":"t19-693","title":"题石勒城二首 二","kind":"诗"},{"id":"t19-694","title":"刘郎浦口号","kind":"诗"},{"id":"t19-695","title":"自江华之衡阳途中作","kind":"诗"}]},"崔日知":{"slug":"崔日知","name":"崔日知","dynasty":"唐","style":"字子骏 · 号为尚书里行","life":"","origin":"","seal":"崔","bio":["崔日知，字子骏，日用从父兄也，有吏干。景云中，为洺州司马。以讨谯王重福功，累迁京兆尹。","为御史李如璧所劾，左迁歙县丞，后为太常卿。自以历任年久，每朝士参集，常与尚书同列，时人号为尚书里行。诗二首。"],"works":[{"id":"t4-871","title":"奉酬韦祭酒偶游龙门北溪忽怀骊山别业因以言志示弟淑并呈诸大僚之作","kind":"诗"},{"id":"t4-872","title":"冬日述怀奉呈韦祭酒张左丞兰台名贤","kind":"诗"}]},"张翔":{"slug":"张翔","name":"张翔","dynasty":"唐","style":"字子翼","life":"","origin":"","seal":"张","bio":["张翔，字子翼，安定人。天宝初自前斋郎调补济王府参军，历阌乡尉，屡辟使府，累迁殿中侍御史。大历十四年卒，年五十六。","有文集十卷。（《全唐诗》无张翔诗，传据《千唐志斋藏志》九四一页独孤良弼撰《大唐故朝议郎行殿中侍御史赐绯鱼袋安定张府君墓志并序》）"],"works":[{"id":"t53-26","title":"无题","kind":"诗"},{"id":"t53-27","title":"经罗渊吊屈原","kind":"诗"}]},"彦楚":{"slug":"彦楚","name":"彦楚","dynasty":"唐","style":"","life":"","origin":"","seal":"彦","bio":["彦楚，大中间长安崇先寺僧。诗一首。（《全唐诗》无彦楚诗）"],"works":[{"id":"t53-935","title":"五言述瓜沙（一下有「州」字）僧献款诗一首","kind":"诗"}]},"曹邍":{"slug":"曹邍","name":"曹邍","dynasty":"宋","style":"","life":"","origin":"","seal":"曹","bio":[],"works":[{"id":"c74-770","title":"齐天乐·翠箫声断青鸾翼","kind":"词"},{"id":"c74-771","title":"瑞鹤仙·炉烟销篆碧","kind":"词"},{"id":"c74-772","title":"兰陵王·杏花坼","kind":"词"},{"id":"c74-773","title":"玲珑四犯·一架幽芳","kind":"词"},{"id":"c74-774","title":"惜馀妍・惜余妍·同根异色","kind":"词"},{"id":"c74-775","title":"宴山亭・燕山亭·香月玲珑","kind":"词"}]},"李乂":{"slug":"李乂","name":"李乂","dynasty":"唐","style":"字尚真","life":"","origin":"","seal":"李","bio":["李乂，字尚真，赵州房子人。年十二，工属文，第进士，茂才异等，调万年尉。长安中，擢监察御史，迁中书舍人，修文馆学士。","睿宗朝，进吏部侍郎，改黄门侍郎，中山郡公。开元初，转紫微侍郎，未几，除刑部尚书，卒，年六十八。居官沈正方雅，识治体，时称有宰相器，与兄尚一、尚贞，俱以文章见称，有《李氏花萼集》。","乂与苏颋对掌纶诰，明皇比之味道与峤，并称苏李。今编诗一卷。"],"works":[{"id":"t0-597","title":"郊庙歌辞 享龙池乐章 第八章","kind":"诗"},{"id":"t4-880","title":"招谕有怀赠同行人","kind":"诗"},{"id":"t4-881","title":"春日侍宴芙蓉园应制","kind":"诗"},{"id":"t4-882","title":"奉和登骊山高顶寓目应制","kind":"诗"},{"id":"t4-883","title":"奉和七夕两仪殿会宴应制","kind":"诗"},{"id":"t4-884","title":"奉和春日游苑喜雨应诏","kind":"诗"},{"id":"t4-885","title":"奉和人日清晖阁宴群臣遇雪应制","kind":"诗"},{"id":"t4-886","title":"陪幸临渭亭遇雪应制","kind":"诗"},{"id":"t4-887","title":"奉和九日侍宴应制得浓字","kind":"诗"},{"id":"t4-888","title":"送沙门弘景道俊玄奘还荆州应制","kind":"诗"},{"id":"t4-889","title":"奉和九月九日登慈恩寺浮图应制","kind":"诗"},{"id":"t4-890","title":"闰九月九日幸总持寺登浮图应制","kind":"诗"},{"id":"t4-891","title":"侍宴长宁公主东庄应制","kind":"诗"},{"id":"t4-892","title":"幸白鹿观应制","kind":"诗"},{"id":"t4-893","title":"次苏州","kind":"诗"},{"id":"t4-894","title":"寄胡皓时在南中","kind":"诗"},{"id":"t4-895","title":"饯许州宋司马赴任","kind":"诗"},{"id":"t4-896","title":"饯唐州高使君赴任","kind":"诗"},{"id":"t4-897","title":"哭仆射鄂公杨再思","kind":"诗"},{"id":"t4-898","title":"故赵王属赠黄门侍郎上官公挽词","kind":"诗"},{"id":"t4-899","title":"淮阳公主挽歌","kind":"诗"},{"id":"t4-900","title":"故西台侍郎上官公挽歌","kind":"诗"},{"id":"t4-901","title":"高安公主挽歌二首 一","kind":"诗"},{"id":"t4-902","title":"高安公主挽歌二首 二","kind":"诗"},{"id":"t4-903","title":"奉和初春幸太平公主南庄应制","kind":"诗"},{"id":"t4-904","title":"兴庆池侍宴应制","kind":"诗"},{"id":"t4-905","title":"侍宴安乐公主山庄应制","kind":"诗"},{"id":"t4-906","title":"奉和春日幸望春宫应制","kind":"诗"},{"id":"t4-907","title":"人日重宴大明宫恩赐彩缕人胜应制","kind":"诗"},{"id":"t4-908","title":"享龙池乐第八章","kind":"诗"},{"id":"t4-909","title":"奉和幸礼部尚书窦希玠宅应制","kind":"诗"},{"id":"t4-910","title":"奉和晦日幸昆明池应制","kind":"诗"},{"id":"t4-911","title":"奉和幸长安故城未央宫应制","kind":"诗"},{"id":"t4-912","title":"陪幸韦嗣立山庄应制","kind":"诗"},{"id":"t4-913","title":"奉和幸望春宫送朔方军大总管张仁亶","kind":"诗"},{"id":"t4-914","title":"奉和幸三会寺应制","kind":"诗"},{"id":"t4-915","title":"奉和幸大荐福寺","kind":"诗"},{"id":"t4-916","title":"夏日都门送司马员外逸客孙员外佺北征","kind":"诗"},{"id":"t4-917","title":"元日恩赐柏叶应制","kind":"诗"},{"id":"t4-918","title":"侍宴桃花园咏桃花应制","kind":"诗"},{"id":"t4-919","title":"奉和三日祓禊渭滨","kind":"诗"},{"id":"t4-920","title":"奉和幸韦嗣立山庄侍宴应制","kind":"诗"},{"id":"t4-921","title":"侍宴安乐公主新宅应制","kind":"诗"},{"id":"t4-922","title":"饯唐永昌","kind":"诗"}]},"李彦和":{"slug":"李彦和","name":"李彦和","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["彦和，天宝初人。诗一首。（《全唐诗》无李彦和诗）"],"works":[{"id":"t52-788","title":"送贺秘监归会稽诗","kind":"诗"}]},"翟奉达":{"slug":"翟奉达","name":"翟奉达","dynasty":"唐","style":"字行","life":"","origin":"","seal":"翟","bio":["奉达，名再温，以字行，长于历学。天复二年二十岁，为敦煌郡州学上足子弟。天成三年任随军参谋。","天福十年为州学博士。显德三年署登仕郎守州学博士。六年为朝议郎尚书工部员外行沙州经学博士兼殿中侍御史。","今存其《寿昌县地境》、同光四年、天成三年、天福十年、显德三年、六年《具注历》。诗三首。（《全唐诗》无翟奉达诗，事迹据向达文整理）"],"works":[{"id":"t55-283","title":"抄逆刺占后题（题拟） 一","kind":"诗"},{"id":"t55-284","title":"抄逆刺占后题（题拟） 二","kind":"诗"},{"id":"t55-285","title":"抄逆刺占后题（题拟） 三","kind":"诗"}]},"苏涣":{"slug":"苏涣","name":"苏涣","dynasty":"唐","style":"号为弩跖","life":"","origin":"","seal":"苏","bio":["苏涣，尝访杜甫于江浦，甫请诵新作，有诗美之。涣善放白弩，巴中号为弩跖。后变节从学，乡赋擢第。","累迁至侍御史，佐湖南崔中丞瓘幕府。崔遇害，遂逾岭，扇动哥舒晃跋扈交广，伏诛。诗四首。"],"works":[{"id":"t13-446","title":"变律 一","kind":"诗"},{"id":"t13-447","title":"变律 二","kind":"诗"},{"id":"t13-448","title":"变律 三","kind":"诗"},{"id":"t13-449","title":"赠零陵僧","kind":"诗"}]},"萧至忠":{"slug":"萧至忠","name":"萧至忠","dynasty":"唐","style":"","life":"","origin":"","seal":"萧","bio":["萧至忠，德言曾孙。少为畿尉，以清谨称。神龙初，自吏部员外擢御史中丞。","迁吏部侍郎，掌选事，请谒杜绝。寻迁中书侍郎，兼中书令。睿宗立，出为晋州刺史。","先天二年，复为中书令，与窦怀贞、魏知古、崔湜、陆象先、徐坚等撰《姓族系录》二百卷，书成，加爵。后坐附太平公主伏诛。诗九首。"],"works":[{"id":"t5-281","title":"奉和九日幸临渭亭登高应制得余字","kind":"诗"},{"id":"t5-282","title":"奉和九月九日登慈恩寺浮图应制","kind":"诗"},{"id":"t5-283","title":"奉和幸安乐公主山庄应制","kind":"诗"},{"id":"t5-284","title":"送张亶赴朔方应制","kind":"诗"},{"id":"t5-285","title":"陪幸长宁公主林亭","kind":"诗"},{"id":"t5-286","title":"陪幸五王宅","kind":"诗"},{"id":"t5-287","title":"三会寺应制","kind":"诗"},{"id":"t5-288","title":"荐福寺应制","kind":"诗"},{"id":"t5-289","title":"陪游上苑遇雪","kind":"诗"}]},"许彬":{"slug":"许彬","name":"许彬","dynasty":"唐","style":"","life":"","origin":"","seal":"许","bio":["许彬，睦州人。举进士不第，与郑谷同时。诗一卷。"],"works":[{"id":"t37-848","title":"中秋夜有怀","kind":"诗"},{"id":"t37-849","title":"寻白石山人涧","kind":"诗"},{"id":"t37-850","title":"游头陀寺上方","kind":"诗"},{"id":"t37-851","title":"归山夜发湖中","kind":"诗"},{"id":"t37-852","title":"同友人会裴明府县楼","kind":"诗"},{"id":"t37-853","title":"荆山夜泊与亲友遇","kind":"诗"},{"id":"t37-854","title":"北游夜怀","kind":"诗"},{"id":"t37-855","title":"重经汉南","kind":"诗"},{"id":"t37-856","title":"湘江","kind":"诗"},{"id":"t37-857","title":"黔中书事","kind":"诗"},{"id":"t37-858","title":"经李翰林庐山屏风叠所居","kind":"诗"},{"id":"t37-859","title":"酬简寂熊尊师以赵员外庐山草堂见借","kind":"诗"},{"id":"t37-860","title":"寄怀孙处士","kind":"诗"},{"id":"t37-861","title":"汉南怀友人","kind":"诗"},{"id":"t37-862","title":"送人下第归江州","kind":"诗"},{"id":"t37-863","title":"送苏处士归西山","kind":"诗"},{"id":"t37