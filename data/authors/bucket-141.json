{"克符道者":{"slug":"克符道者","name":"克符道者","dynasty":"唐","style":"","life":"","origin":"","seal":"克","bio":["克符道者，即纸衣和尚，嗣临济义玄，住涿州。诗四十二首。（《全唐诗》无克符道者诗）"],"works":[{"id":"t54-297","title":"颂 一","kind":"诗"},{"id":"t54-298","title":"颂 二","kind":"诗"},{"id":"t54-299","title":"颂 三","kind":"诗"},{"id":"t54-300","title":"颂 四","kind":"诗"},{"id":"t54-301","title":"初祖熊耳峰","kind":"诗"},{"id":"t54-302","title":"二祖漳川凤","kind":"诗"},{"id":"t54-303","title":"三祖山谷麟","kind":"诗"},{"id":"t54-304","title":"四祖双峰松","kind":"诗"},{"id":"t54-305","title":"五祖东山月","kind":"诗"},{"id":"t54-306","title":"六祖曹溪宝","kind":"诗"},{"id":"t54-307","title":"毗卢印","kind":"诗"},{"id":"t54-308","title":"熊耳岩","kind":"诗"},{"id":"t54-309","title":"马祖麟","kind":"诗"},{"id":"t54-310","title":"百丈松","kind":"诗"},{"id":"t54-311","title":"临济龙","kind":"诗"},{"id":"t54-312","title":"龙潭月","kind":"诗"},{"id":"t54-313","title":"双林桂","kind":"诗"},{"id":"t54-314","title":"药山刀","kind":"诗"},{"id":"t54-315","title":"丹霞日","kind":"诗"},{"id":"t54-316","title":"鸟窠柏树居","kind":"诗"},{"id":"t54-317","title":"石巩弓","kind":"诗"},{"id":"t54-318","title":"归宗石","kind":"诗"},{"id":"t54-319","title":"大梅霜","kind":"诗"},{"id":"t54-320","title":"灌溪水","kind":"诗"},{"id":"t54-321","title":"天皇竹","kind":"诗"},{"id":"t54-322","title":"牛头雪","kind":"诗"},{"id":"t54-323","title":"五泄泉","kind":"诗"},{"id":"t54-324","title":"鲁祖岩","kind":"诗"},{"id":"t54-325","title":"汾州玉","kind":"诗"},{"id":"t54-326","title":"疎山松","kind":"诗"},{"id":"t54-327","title":"关南鼓","kind":"诗"},{"id":"t54-328","title":"韵山壁","kind":"诗"},{"id":"t54-329","title":"南岳让禅师凤","kind":"诗"},{"id":"t54-330","title":"吉州鲤","kind":"诗"},{"id":"t54-331","title":"南泉竹","kind":"诗"},{"id":"t54-332","title":"石头松","kind":"诗"},{"id":"t54-333","title":"夹山雷","kind":"诗"},{"id":"t54-334","title":"洞山泉","kind":"诗"},{"id":"t54-335","title":"赵州关","kind":"诗"},{"id":"t54-336","title":"云居月","kind":"诗"},{"id":"t54-337","title":"都颂","kind":"诗"}]},"常雅":{"slug":"常雅","name":"常雅","dynasty":"唐","style":"","life":"","origin":"","seal":"常","bio":[],"works":[{"id":"t47-218","title":"题伍相庙","kind":"诗"}]},"清闲":{"slug":"清闲","name":"清闲","dynasty":"唐","style":"","life":"","origin":"","seal":"清","bio":[],"works":[{"id":"t50-86","title":"句","kind":"诗"}]},"王公亮":{"slug":"王公亮","name":"王公亮","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王公亮，登贞元进士第。长庆初，自司门郎中为商州刺史。诗一首。"],"works":[{"id":"t24-926","title":"鱼上冰","kind":"诗"}]},"王梵志":{"slug":"王梵志","name":"王梵志","dynasty":"唐","style":"字作告","life":"","origin":"","seal":"王","bio":["王梵志，卫州黎阳人。编诗一卷，计一百十一首。王梵志，卫州黎阳人也。","去黎阳城东十五里，有王德祖者，当隋文帝时，家有林擒树，生瘿，大如斗。经三年，其瘿朽烂。德祖见之，乃剖（撤）其皮，遂见一孩儿抱胎而出。","德祖收养之，至七岁，能语，问曰：「谁人育我？复何姓名？」德祖具以实语之。（二字作告）因名曰：「林木而生曰梵天。」后改曰梵志，[曰]：「王家育我，（我家长育）可姓王也。","」梵志乃作诗示（讽）人，甚有义志（旨），盖菩萨示化也。（《太平广记》八二，参以《永乐大典》六八三八[王]字韵引《桂苑业谈·史遗》。）○《云溪友议》下《蜀僧喻》云：「或有愚士昧学之流，欲其开悟，别吟以王梵志诗。","梵志者，生于西域林木之上，因以梵志为名。其言虽鄙，其理归真，所谓归真悟道，徇俗乖真也。」○王维《与胡居士皆病寄此诗兼示学人诗二首》，注云：「梵志体。","」"],"works":[{"id":"t50-388","title":"无题","kind":"诗"},{"id":"t50-389","title":"一","kind":"诗"},{"id":"t50-390","title":"二","kind":"诗"},{"id":"t50-391","title":"三","kind":"诗"},{"id":"t50-392","title":"四","kind":"诗"},{"id":"t50-393","title":"五","kind":"诗"},{"id":"t50-394","title":"六","kind":"诗"},{"id":"t50-395","title":"七","kind":"诗"},{"id":"t50-396","title":"八","kind":"诗"},{"id":"t50-397","title":"九","kind":"诗"},{"id":"t50-398","title":"十","kind":"诗"},{"id":"t50-399","title":"十一","kind":"诗"},{"id":"t50-400","title":"十二","kind":"诗"},{"id":"t50-401","title":"十三","kind":"诗"},{"id":"t50-402","title":"十四","kind":"诗"},{"id":"t50-403","title":"十五","kind":"诗"},{"id":"t50-404","title":"十六","kind":"诗"},{"id":"t50-405","title":"十七","kind":"诗"},{"id":"t50-406","title":"十八","kind":"诗"},{"id":"t50-407","title":"十九","kind":"诗"},{"id":"t50-408","title":"二十","kind":"诗"},{"id":"t50-409","title":"二一","kind":"诗"},{"id":"t50-410","title":"二二","kind":"诗"},{"id":"t50-411","title":"二三","kind":"诗"},{"id":"t50-412","title":"二四","kind":"诗"},{"id":"t50-413","title":"二五","kind":"诗"},{"id":"t50-414","title":"二六","kind":"诗"},{"id":"t50-415","title":"二七","kind":"诗"},{"id":"t50-416","title":"二八","kind":"诗"},{"id":"t50-417","title":"二九","kind":"诗"},{"id":"t50-418","title":"三十","kind":"诗"},{"id":"t50-419","title":"三一","kind":"诗"},{"id":"t50-420","title":"三二","kind":"诗"},{"id":"t50-421","title":"三三","kind":"诗"},{"id":"t50-422","title":"三四","kind":"诗"},{"id":"t50-423","title":"三五","kind":"诗"},{"id":"t50-424","title":"三六","kind":"诗"},{"id":"t50-425","title":"三七","kind":"诗"},{"id":"t50-426","title":"三八","kind":"诗"},{"id":"t50-427","title":"三九","kind":"诗"},{"id":"t50-428","title":"四十","kind":"诗"},{"id":"t50-429","title":"四一","kind":"诗"},{"id":"t50-430","title":"四二","kind":"诗"},{"id":"t50-431","title":"四三","kind":"诗"},{"id":"t50-432","title":"四四","kind":"诗"},{"id":"t50-433","title":"四五","kind":"诗"},{"id":"t50-434","title":"四六","kind":"诗"},{"id":"t50-435","title":"四七","kind":"诗"},{"id":"t50-436","title":"四八","kind":"诗"},{"id":"t50-437","title":"四九","kind":"诗"}]},"翁洮":{"slug":"翁洮","name":"翁洮","dynasty":"唐","style":"字子平","life":"","origin":"","seal":"翁","bio":["翁洮，字子平，睦州人。光启三年进士第，官主客员外郎，归隐青山，征召不起。诗十三首。"],"works":[{"id":"t37-166","title":"枯木诗辞召命作","kind":"诗"},{"id":"t37-167","title":"赠进士王雄","kind":"诗"},{"id":"t37-168","title":"渔者","kind":"诗"},{"id":"t37-169","title":"上子男寿昌宰","kind":"诗"},{"id":"t37-170","title":"赠方干先生","kind":"诗"},{"id":"t37-171","title":"赠进士李德新接海棠梨","kind":"诗"},{"id":"t37-172","title":"春日题航头桥","kind":"诗"},{"id":"t37-173","title":"和方干题李频庄","kind":"诗"},{"id":"t37-174","title":"苇藂","kind":"诗"},{"id":"t37-175","title":"春","kind":"诗"},{"id":"t37-176","title":"夏","kind":"诗"},{"id":"t37-177","title":"秋","kind":"诗"},{"id":"t37-178","title":"冬","kind":"诗"}]},"苏源明":{"slug":"苏源明","name":"苏源明","dynasty":"唐","style":"字弱夫","life":"","origin":"","seal":"苏","bio":["苏源明，字弱夫，武功人。天宝中登第，累迁国子司业。禄山之乱，不受伪署。","肃宗复两京，擢考功郎中，终秘书少监。与杜甫、郑虔善。诗二首。"],"works":[{"id":"t13-437","title":"小洞庭洄源亭䜩四郡太守诗","kind":"诗"},{"id":"t13-438","title":"秋夜小洞庭离䜩诗","kind":"诗"}]},"苏轼":{"slug":"苏轼","name":"苏轼","dynasty":"宋","style":"字子瞻 · 号东坡居士","life":"1037 — 1101","origin":"眉州眉山（今属四川）","seal":"苏","bio":["(1037―1101) 字子瞻，号东坡居士。眉州眉山 (今属四川) 人。苏洵长子。","嘉二年 (1057) 进士。累除中书舍人、翰林学士、端明殿学士、礼部尚书。曾通判杭州，知密州、徐州、湖州、颍州等。","元丰三年 (1080) 以谤新法贬谪黄州。绍圣初，又贬惠州、儋州。徽宗立，赦还。","卒于常州。追谥文忠。博学多才，善文，工诗词，书画俱佳。","于词“豪放，不喜剪裁以就声律”，题材丰富，意境开阔，突破晚唐五代和宋初以来“词为艳科”的传统樊篱，以诗为词，开创豪放清旷一派，对后世产生巨大影响。代表作有《念奴娇・赤壁怀古》、《江神子・猎"],"works":[{"id":"c59-55","title":"水龙吟·古来云海茫茫","kind":"词"},{"id":"c59-56","title":"水龙吟·楚山修竹如云","kind":"词"},{"id":"c59-57","title":"水龙吟·似花还似非花","kind":"词"},{"id":"c59-58","title":"水龙吟·小舟横截春江","kind":"词"},{"id":"c59-59","title":"满庭芳·归去来兮","kind":"词"},{"id":"c59-60","title":"满庭芳·香叆雕盘","kind":"词"},{"id":"c59-61","title":"满庭芳·蜗角虚名","kind":"词"},{"id":"c59-62","title":"满庭芳·三十三年","kind":"词"},{"id":"c59-63","title":"满庭芳·三十三年","kind":"词"},{"id":"c59-64","title":"水调歌头·落日绣帘卷","kind":"词"},{"id":"c59-65","title":"水调歌头·安石在东海","kind":"词"},{"id":"c59-66","title":"水调歌头·明月几时有","kind":"词"},{"id":"c59-67","title":"水调歌头·昵昵儿女语","kind":"词"},{"id":"c59-68","title":"满江红·忧喜相寻","kind":"词"},{"id":"c59-69","title":"满江红·江汉西来","kind":"词"},{"id":"c59-70","title":"满江红·东武南城","kind":"词"},{"id":"c59-71","title":"满江红·清颖东流","kind":"词"},{"id":"c59-72","title":"满江红·天岂无情","kind":"词"},{"id":"c59-73","title":"归朝欢·我梦扁舟浮震泽","kind":"词"},{"id":"c59-74","title":"念奴娇·大江东去","kind":"词"},{"id":"c59-75","title":"雨中花・夜行船·今岁花时深院","kind":"词"},{"id":"c59-76","title":"沁园春·孤馆灯青","kind":"词"},{"id":"c59-77","title":"劝金船·无情流水多情客","kind":"词"},{"id":"c59-78","title":"一丛花·今年春浅腊侵年","kind":"词"},{"id":"c59-79","title":"木兰花令·霜馀已失长淮阔","kind":"词"},{"id":"c59-80","title":"木兰花令·知君仙骨无寒暑","kind":"词"},{"id":"c59-81","title":"木兰花令·梧桐叶上三更雨","kind":"词"},{"id":"c59-82","title":"西江月·公子眼花乱发","kind":"词"},{"id":"c59-83","title":"西江月·小院朱阑几曲","kind":"词"},{"id":"c59-84","title":"西江月·怪此花枝怨泣","kind":"词"},{"id":"c59-85","title":"西江月·闻道双衔凤带","kind":"词"},{"id":"c59-86","title":"西江月·点点楼头细雨","kind":"词"},{"id":"c59-87","title":"西江月·龙焙今年绝品","kind":"词"},{"id":"c59-88","title":"西江月·别梦已随流水","kind":"词"},{"id":"c59-89","title":"西江月·世事一场大梦","kind":"词"},{"id":"c59-90","title":"西江月·莫叹平原落落","kind":"词"},{"id":"c59-91","title":"西江月·玉骨那愁瘴雾","kind":"词"},{"id":"c59-92","title":"西江月·照野弥弥浅浪","kind":"词"},{"id":"c59-93","title":"西江月·三过平山堂下","kind":"词"},{"id":"c59-94","title":"西江月·昨夜扁舟京口","kind":"词"},{"id":"c59-95","title":"临江仙·细马远驮双侍女","kind":"词"},{"id":"c59-96","title":"临江仙·诗句端来磨我钝","kind":"词"},{"id":"c59-97","title":"临江仙·我劝髯张归去好","kind":"词"},{"id":"c59-98","title":"临江仙·自古相从休务日","kind":"词"},{"id":"c59-99","title":"临江仙·忘却成都来十载","kind":"词"},{"id":"c59-100","title":"临江仙·尊酒何人怀李白","kind":"词"},{"id":"c59-101","title":"临江仙·九十日春都过了","kind":"词"},{"id":"c59-102","title":"临江仙·四大从来都遍满","kind":"词"},{"id":"c59-103","title":"临江仙·一别都门三改火","kind":"词"},{"id":"c59-104","title":"临江仙·多病休文都瘦损","kind":"词"}]},"裴大章":{"slug":"裴大章","name":"裴大章","dynasty":"唐","style":"","life":"","origin":"","seal":"裴","bio":[],"works":[{"id":"t43-306","title":"恩赐魏文贞公诸孙旧第以导直臣","kind":"诗"}]},"贾逋":{"slug":"贾逋","name":"贾逋","dynasty":"宋","style":"","life":"","origin":"","seal":"贾","bio":[],"works":[{"id":"c78-649","title":"清平乐·薰梅染柳","kind":"词"}]},"陈从道":{"slug":"陈从道","name":"陈从道","dynasty":"唐","style":"字象先","life":"","origin":"","seal":"陈","bio":["从道，字象先。（《全唐诗》无陈从道诗）"],"works":[{"id":"t56-386","title":"无题","kind":"诗"},{"id":"t56-387","title":"咏扇诗","kind":"诗"}]},"陈裕":{"slug":"陈裕","name":"陈裕","dynasty":"唐","style":"","life":"","origin":"","seal":"陈","bio":["裕，秀才。下第游蜀，唯事唇喙，覩物便嘲。其中数篇，亦堪采择，虽无教化于当代，诚可取笑于一时。"],"works":[{"id":"t51-715","title":"咏浑家乐（二首） 一","kind":"诗"},{"id":"t51-716","title":"咏浑家乐（二首） 二","kind":"诗"},{"id":"t51-717","title":"过旧居","kind":"诗"},{"id":"t51-718","title":"有一秀才忽赎酒家青衣为妇（一作活）因嘲之","kind":"诗"},{"id":"t51-719","title":"咏大慈寺斋头鲜于阇梨","kind":"诗"},{"id":"t51-720","title":"放生池（大慈寺东北有池，号曰放生池。蜀人竞以三元日，多将鹅鸭放在池中。裕因谒主池僧不遇，当门书一绝句，自此放生稍息矣。）","kind":"诗"},{"id":"t51-721","title":"咏深沙（裕后咏深沙一绝，因暴疾而终，亦由神折天年，抑又神其灵也。诗曰：）","kind":"诗"}]},"韦澳":{"slug":"韦澳","name":"韦澳","dynasty":"唐","style":"","life":"","origin":"","seal":"韦","bio":[],"works":[{"id":"t43-673","title":"句","kind":"诗"}]}}