[{"id":"t0-600","title":"郊庙歌辞 享太庙乐章 永和","rhythmic":null,"author":"魏征、褚亮","authorSlug":"魏征、褚亮","dynasty":"唐","kind":"shi","paragraphs":["於穆烈祖，弘此丕基。","永言配命，子孙保之。","百神既洽，万国在兹。","是用孝享，神其格思。"]},{"id":"t0-601","title":"郊庙歌辞 享太庙乐章 肃和","rhythmic":null,"author":"魏征、褚亮","authorSlug":"魏征、褚亮","dynasty":"唐","kind":"shi","paragraphs":["大哉至德，允兹明圣。","格于上下，聿遵诚敬。","嘉乐斯登，鸣球以咏。","神其降止，式隆景命。"]},{"id":"t0-602","title":"郊庙歌辞 享太庙乐章 雍和","rhythmic":null,"author":"魏征、褚亮","authorSlug":"魏征、褚亮","dynasty":"唐","kind":"shi","paragraphs":["崇兹享祀，诚敬兼至。","乐以感灵，礼以昭事。","粢盛咸絜，牲牷孔备。","永言孝思，庶几不匮。"]},{"id":"t0-603","title":"郊庙歌辞 享太庙乐章 长发舞","rhythmic":null,"author":"魏征、褚亮","authorSlug":"魏征、褚亮","dynasty":"唐","kind":"shi","paragraphs":["睿哲维唐，长发其祥。","帝命斯祐，王业克昌。","配天载德，就日重光。","本支百代，申锡无疆。"]},{"id":"t0-604","title":"郊庙歌辞 享太庙乐章 大基舞","rhythmic":null,"author":"魏征、褚亮","authorSlug":"魏征、褚亮","dynasty":"唐","kind":"shi","paragraphs":["猗与祖业，皇矣帝先。","翦商德厚，封唐庆延。","在姬犹稷，方晋喻宣。","基我鼎运，于万斯年。"]},{"id":"t0-605","title":"郊庙歌辞 享太庙乐章 大成舞","rhythmic":null,"author":"魏征、褚亮","authorSlug":"魏征、褚亮","dynasty":"唐","kind":"shi","paragraphs":["周称王季，晋美帝文。","明明盛德，穆穆齐芬。","藏用四履，屈道三分。","铿锵钟石，载纪鸿勋。"]},{"id":"t0-606","title":"郊庙歌辞 享太庙乐章 大明舞","rhythmic":null,"author":"魏征、褚亮","authorSlug":"魏征、褚亮","dynasty":"唐","kind":"shi","paragraphs":["五纪更运，三正递升。","勋华既没，禹汤勃兴。","神武命代，灵睠是膺。","望云彰德，察纬告征。","上纽天维，下安地轴。","征师涿野，万国咸服。","偃伯灵台，九官允穆。","殊域委賮，怀生介福。","大礼既饰，大乐已和。","黑章扰囿，赤字浮河。","功宣载籍，德被咏歌。","克昌厥后，百禄是荷。"]},{"id":"t0-607","title":"郊庙歌辞 享太庙乐章 寿和","rhythmic":null,"author":"魏征、褚亮","authorSlug":"魏征、褚亮","dynasty":"唐","kind":"shi","paragraphs":["八音斯奏，三献毕陈。","宝祚惟永，晖光日新。"]},{"id":"t0-608","title":"郊庙歌辞 享太庙乐章 舒和","rhythmic":null,"author":"魏征、褚亮","authorSlug":"魏征、褚亮","dynasty":"唐","kind":"shi","paragraphs":["圣敬通神光七庙，灵心荐祚和万方。","严禋克配鸿基远，明德惟馨凤历昌。"]},{"id":"t0-609","title":"郊庙歌辞 享太庙乐章 雍和","rhythmic":null,"author":"魏征、褚亮","authorSlug":"魏征、褚亮","dynasty":"唐","kind":"shi","paragraphs":["於穆清庙，聿修严祀。","四县载陈，三献斯止。","笾豆彻荐，人祇介祉。","神维格思，锡祚不已。"]},{"id":"t0-610","title":"郊庙歌辞 享太庙乐章 永和","rhythmic":null,"author":"魏征、褚亮","authorSlug":"魏征、褚亮","dynasty":"唐","kind":"shi","paragraphs":["肃肃清祀，烝烝孝思。","荐享昭备，虔恭在兹。","雍歌彻俎，祝嘏陈辞。","用光武志，永固鸿基。"]},{"id":"t0-611","title":"郊庙歌辞 享太庙乐章 崇德舞","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["五运改卜，千龄启圣。","彤云晓聚，黄星夜映。","叶阐珠囊，基开玉镜。","下临万宇，上齐七政。","雾开三象，尘清九服。","海溓星晖，远安迩肃。","天地交泰，华夷辑睦。","翔泳归仁，中外禔福。","绩逾黜夏，勋高翦商。","武陈七德，刑设三章。","祥禽巢阁，仁兽游梁。","卜年惟永，景福无疆。"]},{"id":"t0-612","title":"郊庙歌辞 享太庙乐章 钧天[舞]","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["承天抚箓，纂圣登皇。","遐清万宇，仰协三光。","功成日用，道济时康。","璇图载永，宝历斯昌。","日月扬晖，烟云烂色。","河岳修贡，神祇効职。","舜风攸偃，尧曦先就。","睿感通寰，孝思浃宙。","奉扬先德，虔遵曩狩。","展义天扄，飞英云岫。","化逸王表，神凝帝先。","乘云厌俗，驭日登玄。"]},{"id":"t0-613","title":"郊庙歌辞 享太庙乐章 太和舞","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["广乐既备，嘉荐既新。","述先惟德，孝飨惟亲。","七献具举，五齐毕陈。","锡兹祚福，于万斯春。"]},{"id":"t0-614","title":"郊庙歌辞 享太庙乐章 景云舞","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["惟睿作圣，惟圣登皇。","精感耀魄，时膺会昌。","舜慙大孝，尧推让王。","能事斯极，振古谁方。","文明履运，车书同轨。","巍巍赫赫，尽善尽美。","衢室凝旒，大庭端扆。","释负之寄，事光复子。","脱屣高天，登遐上玄。","龙湖超忽，象野芊绵。","游衣复道，荐果初年。","新庙奕奕，明德配天。"]},{"id":"t0-615","title":"郊庙歌辞 享太庙乐章 光大舞","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["大业龙祉，徽音骏尊。","潜居皇德，赫嗣天昆。","展仪宗祖，重诚孝孙。","春秋无极，享奏存存。"]},{"id":"t0-616","title":"郊庙歌辞 享太庙乐章 迎神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["七庙观德，百灵攸仰。","俗荷财成，物资含养。","道光执契，化笼提象。","肃肃雍雍，神其来飨。"]},{"id":"t0-617","title":"郊庙歌辞 享太庙乐章 金奏","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["肃肃清庙，巍巍盛唐。","配天立极，累圣重光。","乐和管磬，礼备烝尝。","永惟来格，降福无疆。"]},{"id":"t0-618","title":"郊庙歌辞 享太庙乐章 送神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["五声备奏，三献终祠。","车移凤辇，斾转虹旗。","礼周笾豆，诚效虔祗。","皇灵徙跸，簪绅拜辞。"]},{"id":"t0-619","title":"郊庙歌辞 武后享清庙乐章十首 第一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["建清庙，赞玄功。","择吉日，展禋宗。","乐已变，礼方崇。","望神驾，降仙宫。"]},{"id":"t0-620","title":"郊庙歌辞 武后享清庙乐章十首 第二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["隆周创业，宝命惟新。","敬宗茂典，爰表虔禋。","声明已备，文物斯陈。","肃容如在，恳志方申。"]},{"id":"t0-621","title":"郊庙歌辞 武后享清庙乐章十首 第三登歌","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["肃敷大礼，上谒尊灵。","敬[陈]筐币，载表丹诚。"]},{"id":"t0-622","title":"郊庙歌辞 武后享清庙乐章十首 第四迎神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["敬奠苹藻，式罄虔襟。","洁诚斯展，伫降灵歆。"]},{"id":"t0-623","title":"郊庙歌辞 武后享清庙乐章十首 第五饮福","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["爰陈玉醴，式奠琼浆。","灵心有穆，介福无疆。"]},{"id":"t0-624","title":"郊庙歌辞 武后享清庙乐章十首 第六送文舞","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["帝图草创，皇业初开。","功高佐命，业赞云雷。"]},{"id":"t0-625","title":"郊庙歌辞 武后享清庙乐章十首 第七迎武舞","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["赫赫玄功被穹壤，皇皇至德洽生灵。","开基拨乱妖氛廓，佐命宣威海内清。"]},{"id":"t0-626","title":"郊庙歌辞 武后享清庙乐章十首 第八武舞作","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["荷恩承顾托，执契恭临抚。","庙畧静边荒，天兵耀神武。"]},{"id":"t0-627","title":"郊庙歌辞 武后享清庙乐章十首 第九彻俎","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["登歌已阕，献礼方周。","钦承景福，肃奉鸿休。"]},{"id":"t0-628","title":"郊庙歌辞 武后享清庙乐章十首 第十送神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["大礼言毕，仙卫将归。","莫申丹恳，空瞻紫微。"]},{"id":"t0-629","title":"郊庙歌辞 享太庙乐章 严和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["肃肃清庙，赫赫玄猷。","功高万古，化奄十洲。","中兴丕业，上荷天休。","祗奉先构，礼备怀柔。"]},{"id":"t0-630","title":"郊庙歌辞 享太庙乐章 升和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["顾惟菲薄，纂历应期。","中外同轨，夷狄来思。","乐用崇德，礼以陈词。","夕惕若厉，钦奉弘基。"]},{"id":"t0-631","title":"郊庙歌辞 享太庙乐章 虔和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["礼标荐鬯，肃事祠庭。","敬申如在，敢托非馨。"]},{"id":"t0-632","title":"郊庙歌辞 享太庙乐章 歆和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["崇禋已备，粢盛聿修。","洁诚斯展，钟石方遒。"]},{"id":"t0-633","title":"郊庙歌辞 享太庙乐章 承光舞","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["金相载穆，玉裕重辉。","养德清禁，承光紫微。","干宫候色，震象增威。","监国方永，宾天不归。","孝友自衷，温文性与。","龙楼正启，鹤驾斯举。","丹扆流念，鸿名式序。","中兴考室，永陈彝俎。"]},{"id":"t0-634","title":"郊庙歌辞 享太庙乐章 延和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["巍巍累圣，穆穆重光。","奄有区夏，祚启隆唐。","百蛮饮泽，万国来王。","本枝亿载，鼎祚逾长。"]},{"id":"t0-635","title":"郊庙歌辞 享太庙乐章 同和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["惟圣配天敷盛礼，惟天为大阐洪名。","恭禋展敬光先德，苹藻申虔表志诚。"]},{"id":"t0-636","title":"郊庙歌辞 享太庙乐章 宁和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["炎驭失天纲，土德承天命。","英猷被寰宇，懿躅隆邦政。","七德已绥边，九夷咸底定。","景化覃遐迩，深仁洽翔泳。"]},{"id":"t0-637","title":"郊庙歌辞 享太庙乐章 恭和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["礼周三献，乐阕九成。","肃承灵福，悚惕兼盈。"]},{"id":"t0-638","title":"郊庙歌辞 享太庙乐章 通和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["祠容既毕，仙座爰兴。","停停凤举，霭霭云升。","长隆宝运，永锡休征。","福覃贻厥，恩被黎蒸。"]},{"id":"t0-639","title":"郊庙歌辞 享太庙乐章 昭和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["道洽二仪交泰，时休四宇和平。","环珮肃于庭实，钟石扬乎颂声。"]},{"id":"t0-640","title":"郊庙歌辞 享太庙乐章 诚敬","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["顾惟菲质，忝位椒宫。","虔奉苹藻，肃事神宗。","敢申诚絜，庶罄深衷。","睟容有裕，灵享无穷。"]},{"id":"t0-641","title":"郊庙歌辞 享太庙乐章 肃和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["月礼已周，云和将变。","爰献其醑，载迁其奠。","明德逾隆，非馨是荐。","泽沾动植，仁覃宇县。"]},{"id":"t0-642","title":"郊庙歌辞 享太庙乐章 昭感","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["铿锵韶濩，肃穆神容。","洪规赫赫，祠典雍雍。","已周三献，将乘六龙。","虔诚有托，恳志无从。"]},{"id":"t0-643","title":"郊庙歌辞 享太庙乐章 永和三章 一","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["肃九室，谐八音。","歌皇慕，动神心。","礼宿设，乐妙寻。","声明备，[祼]奠临。"]},{"id":"t0-644","title":"郊庙歌辞 享太庙乐章 永和三章 二","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["律迓气，音入玄。","依玉几，御黼筵。","聆忾息，僾周旋。","九韶遍，百福传。"]},{"id":"t0-645","title":"郊庙歌辞 享太庙乐章 永和三章 三","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["信工祝，永颂声。","来祖考，听和平。","相百辟，贡九瀛。","神休委，帝孝成。"]},{"id":"t0-646","title":"郊庙歌辞 享太庙乐章 太和","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["时文圣后，清庙肃邕。","致诚勤荐，在貌思恭。","玉节肆夏，金锵五钟。","绳绳云步，穆穆天容。"]},{"id":"t0-647","title":"郊庙歌辞 享太庙乐章 肃和","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["天子享孝，工歌溥将。","躬[祼]郁鬯，乃焚膋芗。","臭以达阴，声以求阳。","奉时烝尝，永代不忘。"]},{"id":"t0-648","title":"郊庙歌辞 享太庙乐章 雍和二章 一","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["在涤嘉豢，丽碑敬牲。","角握之牡，色纯之骍。","火传阳燧，水溉阴精。","太公胖俎，[傅]说和羹。"]},{"id":"t0-649","title":"郊庙歌辞 享太庙乐章 雍和二章 二","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["俎豆有馥，粢盛絜丰。","亦有和羹，既戒既平。","鼓钟管磬，肃唱和鸣。","皇皇后祖，来我思成。"]},{"id":"t0-650","title":"郊庙歌辞 享太庙乐章 文舞","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["圣謩九德，真言五千。","庆集昌胄，符开帝先。","高文杖钺，克配彼天。","三宗握镜，六合涣然。","帝其承祀，率礼罔愆。","图书雾出，日月清悬。","舞形德类，咏谂功传。","黄龙蜿蟺，彩云蹁跹。","五行气顺，八佾风宣。","介此百禄，于皇万年。"]},{"id":"t0-651","title":"郊庙歌辞 享太庙乐章 光大舞","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["肃肃艺祖，滔滔濬源。","有雄玉剑，作镇金门。","玄王贻绪，后稷谋孙。","肇禋九庙，四海来尊。"]},{"id":"t0-652","title":"郊庙歌辞 享太庙乐章 长发舞","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["具礼崇德，备乐承风。","魏推幢主，周赠司空。","不行而至，无成有终。","神兴王业，天归帝功。"]},{"id":"t0-653","title":"郊庙歌辞 享太庙乐章 大政舞","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["于赫元命，权舆帝文。","天齐八柱，地半三分。","宗庙观德，笙镛乐勋。","封唐之兆，成天下君。"]},{"id":"t0-654","title":"郊庙歌辞 享太庙乐章 大成舞","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["帝舞季历，龙圣生昌。","后歌有蟜，胎炎孕黄。","天地合德，日月齐光。","肃雝孝享，祚我万方。"]},{"id":"t0-655","title":"郊庙歌辞 享太庙乐章 大明舞","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["赤精乱德，四海困穷。","黄旗举义，三灵会同。","旱望春雨，云披大风。","溥天来祭，高祖之功。"]},{"id":"t0-656","title":"郊庙歌辞 享太庙乐章 崇德舞","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["皇合一德，朝宗百神。","削平天地，大拯生人。","上帝配食，单于入臣。","戎歌陈舞，晔晔震震。"]},{"id":"t0-657","title":"郊庙歌辞 享太庙乐章 钧天舞","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["高皇迈道，端拱无为。","化怀獯鬻，兵赋句骊。","礼尊封禅，乐盛来仪。","合位娲后，同称伏羲。"]},{"id":"t0-658","title":"郊庙歌辞 享太庙乐章 大和舞","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["退居江水，郁起丹陵。","礼物还旧，朝章中兴。","龙图友及，骏命恭膺。","鸣球香瓒，大糦是承。"]},{"id":"t0-659","title":"郊庙歌辞 享太庙乐章 景云舞","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["景云霏烂，告我帝符。","噫帝冲德，与天为徒。","笙镛遥远，俎豆虚无。","春秋孝献，回复此都。"]},{"id":"t0-660","title":"郊庙歌辞 享太庙乐章 福和","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["备礼用乐，崇亲致尊。","诚通慈降，敬彻爱存。","献怀称寿，啐感承恩。","皇帝孝德，子孙千亿。","大包天域，长亘不极。"]},{"id":"t0-661","title":"郊庙歌辞 享太庙乐章 舒和","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["六钟翕协六变成，八佾徜徉八风生。","乐九韶兮人神感，美七德兮天地清。"]},{"id":"t0-662","title":"郊庙歌辞 享太庙乐章 凯安四章 一","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["瑟彼瑶爵，亚惟上公。","室如屏气，门不容躬。","礼殷其本，乐执其中。","圣皇永慕，天地幽通。"]},{"id":"t0-663","title":"郊庙歌辞 享太庙乐章 凯安四章 二","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["礼匝三献，乐遍九成。","降循轩陛，仰欷皇情。","福与仁合，德因孝明。","百年[神畏]，四海风行。"]},{"id":"t0-664","title":"郊庙歌辞 享太庙乐章 凯安四章 三","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["总总干戚，填填鼓钟。","奋扬争气，坐作为容。","离若鸷鸟，合如战龙。","万方观德，肃肃雝雝。"]},{"id":"t0-665","title":"郊庙歌辞 享太庙乐章 凯安四章 四","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["烈祖顺三灵，文宗威四海。","黄钺诛群盗，朱旗扫多罪。","戢兵天下安，约法人心改。","大哉干羽意，长见风云在。"]},{"id":"t0-666","title":"郊庙歌辞 享太庙乐章 登歌","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["止笙磬，撤豆笾。","廓无响，窅入玄。","主在室，神在天。","情余慕，礼罔愆。","喜黍稷，屡丰年。"]},{"id":"t0-667","title":"郊庙歌辞 享太庙乐章 永和","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["眇嘉乐，授灵爽。","感若来，思如往。","休气散，回风上。","返寂寞，还惚恍。","怀灵驾，结空想。"]},{"id":"t0-668","title":"郊庙歌辞 享太庙乐章 广运舞","rhythmic":null,"author":"郭子仪","authorSlug":"郭子仪","dynasty":"唐","kind":"shi","paragraphs":["于赫皇祖，昭明有融。","惟文之德，惟武之功。","河海静谧，车书混同。","虔恭孝飨，穆穆玄风。"]},{"id":"t0-669","title":"郊庙歌辞 享太庙乐章 惟新舞","rhythmic":null,"author":"刘晏","authorSlug":"刘晏","dynasty":"唐","kind":"shi","paragraphs":["汉祚惟永，神功中兴。","风驱氛祲，天覆黎蒸。","三光再朗，庶绩其凝。","重熙累洽，景命是膺。"]},{"id":"t0-670","title":"郊庙歌辞 享太庙乐章 保大舞","rhythmic":null,"author":"郭子仪","authorSlug":"郭子仪","dynasty":"唐","kind":"shi","paragraphs":["於穆文考，圣神昭章。","肃勺群慝，含光远方。","万物茂遂，九夷宾王。","愔愔云韶，德音不忘。"]},{"id":"t0-671","title":"郊庙歌辞 享太庙乐章 文明舞","rhythmic":null,"author":"郑余庆","authorSlug":"郑余庆","dynasty":"唐","kind":"shi","paragraphs":["开邸除暴，时迈勋尊。","三元告命，四极骏奔。","金枝翠叶，辉烛瑶琨。","象德亿载，贻庆汤孙。"]},{"id":"t0-672","title":"郊庙歌辞 享太庙乐章 大顺舞","rhythmic":null,"author":"郑𬘡","authorSlug":"郑𬘡","dynasty":"唐","kind":"shi","paragraphs":["於穆时文，受天明命。","允恭玄默，化成理定。","出震嗣德，应干传圣。","猗欤缉熙，千亿流庆。"]},{"id":"t0-673","title":"郊庙歌辞 享太庙乐章 象德舞","rhythmic":null,"author":"段文昌","authorSlug":"段文昌","dynasty":"唐","kind":"shi","paragraphs":["肃肃清庙，登显至德。","泽周八荒，兵定四极。","生物咸遂，群盗灭息。","明圣钦承，子孙千亿。"]},{"id":"t0-674","title":"郊庙歌辞 享太庙乐章 和宁舞","rhythmic":null,"author":"牛僧孺","authorSlug":"牛僧孺","dynasty":"唐","kind":"shi","paragraphs":["湜湜颀颀，融昭德辉。","不纽不舒，贯成九围。","武烈文经，敷施当宜。","纂尧付启，亿万熙熙。"]},{"id":"t0-675","title":"郊庙歌辞 享太庙乐章 大定舞","rhythmic":null,"author":"李回","authorSlug":"李回","dynasty":"唐","kind":"shi","paragraphs":["受天明命，敷佑下土。","化时以俭，卫文以武。","氛消夷夏，俗臻往古。","亿万斯年，形于律吕。"]},{"id":"t0-676","title":"郊庙歌辞 享太庙乐章 宣宗室舞","rhythmic":null,"author":"夏侯孜","authorSlug":"夏侯孜","dynasty":"唐","kind":"shi","paragraphs":["于铄令主，圣祚重昌。","兴起教义，申明典章。","俗尚素朴，人皆乐康。","积德可报，流庆无疆。"]},{"id":"t0-677","title":"郊庙歌辞  懿宗室舞","rhythmic":null,"author":"萧倣","authorSlug":"萧倣","dynasty":"唐","kind":"shi","paragraphs":["圣祚无疆，庆传乐章。","金枝繁茂，玉叶延长。","海渎常[晏]，波涛不扬。","汪汪美化，垂范今王。"]},{"id":"t0-678","title":"郊庙歌辞 享太庙乐章 咸宁舞","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["于铄丕嗣，惟帝之光。","羽籥象德，金石荐祥。","圣系无极，景命永昌。","神降上哲，维天配长。"]},{"id":"t0-679","title":"郊庙歌辞 太清宫乐章 煌煌","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["煌煌道宫，肃肃太清。","礼光尊祖，乐备充庭。","罄竭诚至，希夷降灵。","云凝翠盖，风燄红旌。","众真以从，九奏初迎。","永惟休祐，是锡和平。"]},{"id":"t0-680","title":"郊庙歌辞 太清宫乐章 冲和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["虚无结思，钟磬和音。","歌以颂德，香以达心。","礼殊祼鬯，义感昭临。","云车至止，庆垂愔愔。"]},{"id":"t0-681","title":"郊庙歌辞 太清宫乐章 香初上","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["肃肃我祖，緜緜道宗。","至感潜达，灵心暗通。","云軿御气，芝盖随风。","四时禋祀，万国来同。"]},{"id":"t0-682","title":"郊庙歌辞 太清宫乐章 再上","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["仙宗绩道，我李承天。","庆深虚极，符光象先。","俗登仁寿，化阐蟺涓。","五千贻范，亿万斯年。"]},{"id":"t0-683","title":"郊庙歌辞 太清宫乐章 终上","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["不宰元功，无为上圣。","洪源长发，诞受天命。","金奏迎真，璇宫展盛。","备礼周乐，垂光储庆。"]},{"id":"t0-684","title":"郊庙歌辞 太清宫乐章 紫极舞","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["至道生元气，重圆法混成。","无为观大象，冲用体常名。","仙乐临丹阙，云车出玉京。","灵符百代应，瑞节九贞迎。","宝运开皇极，天临映太清。","长垂一德庆，永庇万方宁。"]},{"id":"t0-685","title":"郊庙歌辞 太清宫乐章 序入破第一奏","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["真宗开妙理，冲教统清虚。","化演无为日，言昭有象初。","瑶台肃灵瑞，金阙映仙居。","一奏三清乐，长回八景舆。"]},{"id":"t0-686","title":"郊庙歌辞 太清宫乐章 序入破第二奏","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["虚极仙宗本，希夷象帝先。","百灵朝太上，万法祖重圆。","善贷惟冲德，功成谓自然。","云门达和气，思用合钧天。"]},{"id":"t0-687","title":"郊庙歌辞 太清宫乐章 序入破第三奏","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["元符传紫极，宝祚启高真。","道德先垂裕，冲和已化淳。","人风齐太古，天瑞叶惟新。","仙乐清都上，长明交泰辰。"]},{"id":"t0-688","title":"郊庙歌辞 太清宫乐章 登歌","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["严禋展事，理洁烝尝。","皇矣圣祖，德惟馨香。","盛荐既撤，工歌载扬。","大来之庆，降福穰穰。"]},{"id":"t0-689","title":"郊庙歌辞 太清宫乐章 真和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["玉磬含香，金炉既馥。","风驭泠泠，云坛肃肃。","杳归大象，霈流嘉福。","俾宁万邦，无思不服。"]},{"id":"t0-690","title":"郊庙歌辞 德明兴圣庙乐章 迎神","rhythmic":null,"author":"李舒","authorSlug":"李舒","dynasty":"唐","kind":"shi","paragraphs":["元尊九德，佐尧光宅。","烈祖太宗，方周作伯。","响怀霜露，乐变金石。","白云清风，髣髴来格。"]},{"id":"t0-691","title":"郊庙歌辞 德明兴圣庙乐章 登歌奠币","rhythmic":null,"author":"李舒","authorSlug":"李舒","dynasty":"唐","kind":"shi","paragraphs":["四时有典，百事来祭。","尊祖奉宗，严禋大帝。","礼先苍璧，奠币黝制。","于斯万年，熙成帝系。"]},{"id":"t0-692","title":"郊庙歌辞 德明兴圣庙乐章 迎俎","rhythmic":null,"author":"李舒","authorSlug":"李舒","dynasty":"唐","kind":"shi","paragraphs":["盛牲实俎，涓选休成。","鼎煁阳燧，玉盥阴精。","有飶嘉豆，既和大羹。","侑以清乐，细齐人情。"]},{"id":"t0-693","title":"郊庙歌辞 德明兴圣庙乐章 德明酌献","rhythmic":null,"author":"李舒","authorSlug":"李舒","dynasty":"唐","kind":"shi","paragraphs":["清庙奕奕，和乐雍雍。","器尊牺象，礼属宗公。","白水方祼，黄流在中。","谟明之德，万古清风。"]},{"id":"t0-694","title":"郊庙歌辞 德明兴圣庙乐章 兴圣酌献","rhythmic":null,"author":"李舒","authorSlug":"李舒","dynasty":"唐","kind":"shi","paragraphs":["閟宫静谧，合乐周张。","泰尊始献，百末重觞。","震澹存诚，庶几迪尝。","遥源之祚，天汉灵长。"]},{"id":"t0-695","title":"郊庙歌辞 德明兴圣庙乐章 亚献终献","rhythmic":null,"author":"李舒","authorSlug":"李舒","dynasty":"唐","kind":"shi","paragraphs":["惟清惟肃，靡闻靡见。","举备九成，俛终三献。","庆彰曼寿，胙彻嘉荐。","瘗玉埋牲，礼神斯徧。"]},{"id":"t0-696","title":"郊庙歌辞 德明兴圣庙乐章 送神","rhythmic":null,"author":"李舒","authorSlug":"李舒","dynasty":"唐","kind":"shi","paragraphs":["元精回复，灵贶繁滋。","风洒兰路，云摇桂旗。","高丘缅邈，凉部逶迟。","瞻望靡及，缠绵永思。"]},{"id":"t0-697","title":"郊庙歌辞 仪坤庙乐章 永和","rhythmic":null,"author":"徐彦伯","authorSlug":"徐彦伯","dynasty":"唐","kind":"shi","paragraphs":["猗若清庙，肃肃荧荧。","国荐严祀，坤兴淑灵。","有几在室，有乐在庭。","临兹孝享，百禄惟宁。"]},{"id":"t0-698","title":"郊庙歌辞 仪坤庙乐章 金奏","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["阴灵曜祉，轩曜降精。","祥符淑气，庆集柔明。","瑶俎既列，雕桐发声。","徽猷永远，比德皇英。"]},{"id":"t0-699","title":"郊庙歌辞 仪坤庙乐章 太和","rhythmic":null,"author":"丘说","authorSlug":"丘说","dynasty":"唐","kind":"shi","paragraphs":["孝哉我后，冲乎迺圣。","道映重华，德辉文命。","慕深视箧，情殷抚镜。","万国移风，兆人承庆。"]}]