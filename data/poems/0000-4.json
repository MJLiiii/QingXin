[{"id":"t0-400","title":"郊庙歌辞 中宗祀昊天乐章 舒和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["已陈粢盛敷严祀，更奏笙镛协雅声。","璇图宝历欣宁谧，晏俗淳风乐太平。"]},{"id":"t0-401","title":"郊庙歌辞 中宗祀昊天乐章 凯安","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["堂堂圣祖兴，赫赫昌基泰。","戎车盟津偃，玉帛涂山会。","舜日启祥晖，尧云卷征斾。","风猷被有截，声教覃无外。"]},{"id":"t0-402","title":"郊庙歌辞 明皇祀圜丘乐章 豫和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["至矣丕搆，烝哉太平。","授牺膺箓，复禹继明。","草木仁化，凫鹥颂声。","祀宗陈德，无媿斯诚。"]},{"id":"t0-403","title":"郊庙歌辞 明皇祀圜丘乐章 太和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["郊坛斋帝，礼乐祀天。","丹青寰宇，宫征山川。","神祇毕降，行止重旋。","融融穆穆，纳祉洪延。"]},{"id":"t0-404","title":"郊庙歌辞 明皇祀圜丘乐章 肃和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["止奏潜聆，登仪宿啭。","太玉躬奉，参钟首奠。","簠簋聿升，牺牲遰荐。","昭事颙若，存存以伣。"]},{"id":"t0-405","title":"郊庙歌辞 明皇祀圜丘乐章 雍和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["烂云普洽，律风无外。","千品其凝，九宾斯会。","禋尊晋烛，纯牺涤汰。","玄覆攸广，鸿休汪濊。"]},{"id":"t0-406","title":"郊庙歌辞 明皇祀圜丘乐章 寿和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["六变爰阕，八阶载虔。","祐我皇祚，于万斯年。"]},{"id":"t0-407","title":"郊庙歌辞 明皇祀圜丘乐章 寿和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["于赫圣祖，龙飞晋阳。","底定万国，奄有四方。","功格上下，道冠农黄。","郊天配享，德合无疆。"]},{"id":"t0-408","title":"郊庙歌辞 明皇祀圜丘乐章 寿和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["崇崇泰畤，肃肃严禋。","粢盛既洁，金石毕陈。","上帝来享，介福爰臻。","受厘合祉，宝祚维新。"]},{"id":"t0-409","title":"郊庙歌辞 明皇祀圜丘乐章 舒和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["祝史正辞，人神叶庆。","福以德招，享以诚应。","六变云备，百礼斯浃。","祀事孔明，祚流万叶。"]},{"id":"t0-410","title":"郊庙歌辞 明皇祀圜丘乐章 凯安","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["馨香惟后德，明命光天保。","肃和崇圣灵，陈信表皇道。","玉鏚初蹈厉，金匏既静好。"]},{"id":"t0-411","title":"郊庙歌辞 明皇祀圜丘乐章 豫和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["大号成命，思文配天。","神光肸蚃，龙驾言旋。","眇眇阊阖，昭昭上玄。","俾昌而大，于斯万年。"]},{"id":"t0-412","title":"郊庙歌辞 明皇祀圜丘乐章 太和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["六成既阕，三荐云终。","神心具醉，圣敬愈崇。","受厘皇邸，回跸帷宫。","穰穰之福，永永无穷。"]},{"id":"t0-413","title":"郊庙歌辞 封泰山乐章 豫和 一","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["款泰坛，柴泰清。","受天命，报天成。","竦皇心，荐乐声。","志上达，歌下迎。"]},{"id":"t0-414","title":"郊庙歌辞 封泰山乐章 豫和 二","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["亿上帝，临下庭。","骑日月，陪列星。","嘉祝信，大糦馨。","澹神心，醉皇灵。"]},{"id":"t0-415","title":"郊庙歌辞 封泰山乐章 豫和 三","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["相百辟，贡八荒。","九歌敍，万舞翔。","肃振振，铿皇皇。","帝欣欣，福穰穰。"]},{"id":"t0-416","title":"郊庙歌辞 封泰山乐章 豫和 四","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["高在上，道光明。","物资始，德难名。","承眷命，牧苍生。","寰宇谧，太阶平。"]},{"id":"t0-417","title":"郊庙歌辞 封泰山乐章 豫和 五","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["天道无亲，至诚与邻。","山川遍礼，宫征维新。","玉帛非盛，聪明会真。","正斯一德，通乎百神。"]},{"id":"t0-418","title":"郊庙歌辞 封泰山乐章 豫和 六","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["飨帝飨亲，维孝维圣。","缉熙懿德，敷扬成命。","华夷志同，笙镛礼盛。","明灵降止，感此诚敬。"]},{"id":"t0-419","title":"郊庙歌辞 封泰山乐章 太和","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["孝敬中发，和容外彰。","腾华照宇，如升太阳。","贞璧就奠，玄灵垂光。","礼乐具举，济济洋洋。"]},{"id":"t0-420","title":"郊庙歌辞 封泰山乐章 肃和","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["奠祖配天，承天享帝。","百灵咸秩，四海来祭。","植我苍璧，布我玄制。","华日裴回，神烟容裔。"]},{"id":"t0-421","title":"郊庙歌辞 封泰山乐章 雍和","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["俎豆有馥，粢盛洁丰。","亦有和羹，既戒既平。","钟鼓管磬，肃唱和鸣。","皇皇后祖，来我思成。"]},{"id":"t0-422","title":"郊庙歌辞 封泰山乐章 寿和","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["烝烝我后，享献惟夤。","躬酌郁鬯，跪奠明神。","孝莫孝乎，配上帝亲。","敬莫敬乎，教天下臣。"]},{"id":"t0-423","title":"郊庙歌辞 封泰山乐章 寿和","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["皇祖严配，配享皇天。","皇皇降嘏，天子万年。"]},{"id":"t0-424","title":"郊庙歌辞 封泰山乐章 舒和","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["六钟翕协六变成，八佾倘佯八风生。","乐九[韶]兮人神感，美七德兮天地清。"]},{"id":"t0-425","title":"郊庙歌辞 封泰山乐章 凯安","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["烈祖顺三灵，文宗威四海。","黄钺诛群盗，朱旗扫多罪。","戢兵天下安，约法人心改。","大哉干羽意，长见风云在。"]},{"id":"t0-426","title":"郊庙歌辞 封泰山乐章 豫和","rhythmic":null,"author":"张说","authorSlug":"张说","dynasty":"唐","kind":"shi","paragraphs":["乐已终，[烟]燎上。","怀灵惠，结皇想。","归风疾，回风爽。","百[福]来，众神往。"]},{"id":"t0-427","title":"郊庙歌辞 祈谷乐章 肃和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["履艮斯绳，居中体正。","龙运垂祉，昭符启圣。","式事严禋，聿怀嘉庆。","惟帝永锡，时皇休命。"]},{"id":"t0-428","title":"郊庙歌辞 祈谷乐章 雍和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["殷荐乘春，太坛临曙。","八簋盈和，六瑚登御。","嘉稷匪歆，德馨斯饫。","祝嘏无易，灵心有豫。"]},{"id":"t0-429","title":"郊庙歌辞 祈谷乐章 舒和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["玉帛牺牲申敬享，金丝鏚羽盛音容。","庶俾亿龄禔景福，长欣万宇洽时邕。"]},{"id":"t0-430","title":"郊庙歌辞 明堂乐章 肃和","rhythmic":null,"author":"褚亮","authorSlug":"褚亮","dynasty":"唐","kind":"shi","paragraphs":["象天御宇，乘时布政。","严配申虔，宗禋展敬。","罇罍盈列，树羽交映。","玉币通诚，祚隆皇圣。"]},{"id":"t0-431","title":"郊庙歌辞 明堂乐章 雍和","rhythmic":null,"author":"褚亮","authorSlug":"褚亮","dynasty":"唐","kind":"shi","paragraphs":["八牖晨披，五精朝奠。","雾凝璇篚，风清金县。","神涤备全，明粢丰衍。","载絜彝俎，陈诚以荐。"]},{"id":"t0-432","title":"郊庙歌辞 明堂乐章 舒和","rhythmic":null,"author":"褚亮","authorSlug":"褚亮","dynasty":"唐","kind":"shi","paragraphs":["御扆合宫承宝历，席图重馆奉明灵。","偃武修文九围泰，沈烽静柝八荒宁。"]},{"id":"t0-433","title":"郊庙歌辞 武后明堂乐章 外办将出","rhythmic":null,"author":"武则天","authorSlug":"武则天","dynasty":"唐","kind":"shi","paragraphs":["总章陈昔典，衢室礼惟神。","宏规则天地，神用叶陶钧。","负扆三春旦，充庭万宇宾。","顾己诚虚薄，空慙亿兆人。"]},{"id":"t0-434","title":"郊庙歌辞 武后明堂乐章 皇帝行","rhythmic":null,"author":"武则天","authorSlug":"武则天","dynasty":"唐","kind":"shi","paragraphs":["仰膺历数，俯顺讴歌。","远安迩肃，俗阜时和。","化光玉镜，讼息金科。","方兴典礼，永戢干戈。"]},{"id":"t0-435","title":"郊庙歌辞 武后明堂乐章 皇嗣出入升降","rhythmic":null,"author":"武则天","authorSlug":"武则天","dynasty":"唐","kind":"shi","paragraphs":["至人光俗，大孝通神。","谦以表性，恭惟立身。","洪规载启，茂典方陈。","誉隆三善，祥开万春。"]},{"id":"t0-436","title":"郊庙歌辞 武后明堂乐章 迎送王公","rhythmic":null,"author":"武则天","authorSlug":"武则天","dynasty":"唐","kind":"shi","paragraphs":["千官肃事，万国朝宗。","载延百辟，爰集三宫。","君臣德合，鱼水斯同。","睿图方永，周历长隆。"]},{"id":"t0-437","title":"郊庙歌辞 武后明堂乐章 登歌","rhythmic":null,"author":"武则天","authorSlug":"武则天","dynasty":"唐","kind":"shi","paragraphs":["礼崇宗祀，志表严禋。","笙镛合奏，文物维新。","敬遵茂典，敢择良辰。","絜诚斯著，奠谒方申。"]},{"id":"t0-438","title":"郊庙歌辞 武后明堂乐章 配飨","rhythmic":null,"author":"武则天","authorSlug":"武则天","dynasty":"唐","kind":"shi","paragraphs":["笙镛间玉宇，文物昭清晖。","睟影临芳奠，休光下太微。","孝思期有感，明絜庶无违。"]},{"id":"t0-439","title":"郊庙歌辞 武后明堂乐章 宫音","rhythmic":null,"author":"武则天","authorSlug":"武则天","dynasty":"唐","kind":"shi","paragraphs":["履艮包群望，居中冠百灵。","万方资广运，庶品荷财成。","神功谅匪测，盛德实难名。","藻奠申诚敬，恭祀表惟馨。"]},{"id":"t0-440","title":"郊庙歌辞 武后明堂乐章 角音","rhythmic":null,"author":"武则天","authorSlug":"武则天","dynasty":"唐","kind":"shi","paragraphs":["出震位，开平秩。","扇条风，乘甲乙。","龙德盛，鸟星出。","荐珪篚，陈诚实。"]},{"id":"t0-441","title":"郊庙歌辞 武后明堂乐章 徵音","rhythmic":null,"author":"武则天","authorSlug":"武则天","dynasty":"唐","kind":"shi","paragraphs":["赫赫离精御炎陆，滔滔炽景开隆暑。","冀延神鉴俯兰罇，式表虔襟陈桂俎。"]},{"id":"t0-442","title":"郊庙歌辞 武后明堂乐章 商音","rhythmic":null,"author":"武则天","authorSlug":"武则天","dynasty":"唐","kind":"shi","paragraphs":["律中夷则，序应收成。","功宣建武，义表惟明。","爰申礼奠，庶展翘诚。","九秋是式，百谷斯盈。"]},{"id":"t0-443","title":"郊庙歌辞 武后明堂乐章 羽音","rhythmic":null,"author":"武则天","authorSlug":"武则天","dynasty":"唐","kind":"shi","paragraphs":["葭律肇启隆冬，苹藻攸陈飨祭。","黄钟既陈玉烛，红粒方殷稔岁。"]},{"id":"t0-444","title":"郊庙歌辞 雩祀乐章 肃和","rhythmic":null,"author":"褚亮","authorSlug":"褚亮","dynasty":"唐","kind":"shi","paragraphs":["朱鸟开辰，苍龙启映。","大帝昭飨，群生展敬。","礼备怀柔，功宣舞咏。","旬液应序，年祥协庆。"]},{"id":"t0-445","title":"郊庙歌辞 雩祀乐章 雍和","rhythmic":null,"author":"褚亮","authorSlug":"褚亮","dynasty":"唐","kind":"shi","paragraphs":["绀筵分彩，珤图吐绚。","风管晨凝，云歌晓啭。","肃事兰羞，虔申桂奠。","百谷斯登，万箱攸荐。"]},{"id":"t0-446","title":"郊庙歌辞 雩祀乐章 舒和","rhythmic":null,"author":"褚亮","authorSlug":"褚亮","dynasty":"唐","kind":"shi","paragraphs":["凤曲登歌调令序，龙雩集舞泛祥风。","彩旞云回昭睿德，朱干电发表神功。"]},{"id":"t0-447","title":"郊庙歌辞 雩祀乐章 豫和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["鸟纬迁序，龙星见辰。","纯阳在律，明德崇禋。","五方降帝，万宇安人。","恭以致享，肃以迎神。"]},{"id":"t0-448","title":"郊庙歌辞 雩祀乐章 豫和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["祀遵经设，享缘诚举。","献毕于樽，彻临于俎。","舞止干戚，乐停柷敔。","歌以送神，神还其所。"]},{"id":"t0-449","title":"郊庙歌辞 五郊乐章 黄帝宫音","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["黄中正位，含章居贞。","既长六律，兼和五声。","毕陈万舞，乃荐斯牲。","神其下降，永祚休平。"]},{"id":"t0-450","title":"郊庙歌辞 五郊乐章 黄帝宫音 肃和","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["眇眇方舆，苍苍圜盖。","至哉枢纽，宅中图大。","气调四序，风和万籁。","祚我明德，时雍道泰。"]},{"id":"t0-451","title":"郊庙歌辞 五郊乐章 黄帝宫音 雍和","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["金县夕肆，玉俎朝陈。","飨荐黄道，芬流紫宸。","迺诚迺敬，载享载禋。","崇荐斯在，惟皇是宾。"]},{"id":"t0-452","title":"郊庙歌辞 五郊乐章 黄帝宫音 舒和","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["御征乘宫出郊甸，安歌率舞递将迎。","自有云门符帝赏，犹持雷鼓答天成。"]},{"id":"t0-453","title":"郊庙歌辞 五郊乐章 青帝角音","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["鹤云旦起，鸟星昏集。","律候新风，阳开初蛰。","至德可飨，行潦斯挹。","锡以无疆，蒸人乃粒。"]},{"id":"t0-454","title":"郊庙歌辞 五郊乐章 青帝角音 肃和","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["玄鸟司春，苍龙登岁。","节物变柳，光风转蕙。","瑶席降神，朱弦飨帝。","诚备祝嘏，礼殚珪币。"]},{"id":"t0-455","title":"郊庙歌辞 五郊乐章 青帝角音 雍和","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["大乐稀音，至诚简礼。","文物棣棣，声明济济。","六变有成，三登无体。","乃眷丰洁，恩覃恺悌。"]},{"id":"t0-456","title":"郊庙歌辞 五郊乐章 青帝角音 舒和","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["笙歌籥舞属年韶，鹭鼓凫钟展时豫。","调露初迎绮春节，承云遽践苍霄驭。"]},{"id":"t0-457","title":"郊庙歌辞 五郊乐章 赤帝徵音","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["青阳告谢，朱明戒序。","延长是祈，敬陈椒醑。","博硕斯荐，笙镛备举。","庶尽肃恭，非馨稷黍。"]},{"id":"t0-458","title":"郊庙歌辞 五郊乐章 赤帝徵音 肃和","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["离位克明，火中宵见。","峰云暮起，景风晨扇。","木槿初荣，含桃可荐。","芬馥百品，铿锵三变。"]},{"id":"t0-459","title":"郊庙歌辞 五郊乐章 赤帝徵音 雍和","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["昭昭丹陆，奕奕炎方。","礼陈牲币，乐备篪簧。","琼羞溢俎，玉醑浮觞。","恭惟正直，歆此馨香。"]},{"id":"t0-460","title":"郊庙歌辞 五郊乐章 赤帝徵音 舒和","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["千里温风飘绛羽，十枝炎景賸朱干。","陈觞荐俎歌二献，拊石摐金会七盘。"]},{"id":"t0-461","title":"郊庙歌辞 五郊乐章 白帝商音","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["白藏应节，天高气清。","岁功既阜，庶类收成。","万方静谧，九土和平。","馨香是荐，受祚聪明。"]},{"id":"t0-462","title":"郊庙歌辞 五郊乐章 白帝商音 肃和","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["金行在节，素灵居正。","气肃霜严，林雕草劲。","豺祭隼击，潦收川镜。","九谷已登，万箱流咏。"]},{"id":"t0-463","title":"郊庙歌辞 五郊乐章 白帝商音 雍和","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["律应西成，气躔南吕。","珪币咸列，笙竽备举。","苾苾兰羞，芬芬桂醑。","式资宴贶，用调霜序。"]},{"id":"t0-464","title":"郊庙歌辞 五郊乐章 白帝商音 舒和","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["璇仪气爽惊缇籥，玉吕灰飞含素商。","鸣鞞奏管芳羞荐，会舞安歌葆眊扬。"]},{"id":"t0-465","title":"郊庙歌辞 五郊乐章 黑帝羽音","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["严冬季月，星回风厉。","享祀报功，方祚来岁。"]},{"id":"t0-466","title":"郊庙歌辞 五郊乐章 黑帝羽音 肃和","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["律回玉琯，星周金度。","次极阳乌，纪穷阴兔。","火林霰雪，阳泉凝冱。","八蜡已登，三农息务。"]},{"id":"t0-467","title":"郊庙歌辞 五郊乐章 黑帝羽音 雍和","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["阳月斯纪，应钟在候。","载洁牲牷，爰登俎豆。","既高既远，无声无臭。","静言格思，惟神保祐。"]},{"id":"t0-468","title":"郊庙歌辞 五郊乐章 黑帝羽音 舒和","rhythmic":null,"author":"魏征","authorSlug":"魏征","dynasty":"唐","kind":"shi","paragraphs":["执籥持羽初终曲，朱干玉鏚始分行。","七德九功咸已畅，明灵降福具穰穰。"]},{"id":"t0-469","title":"郊庙歌辞 五郊乐章 黄郊迎神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["朱明季序，黄郊王辰。","厚以载物，甘以养人。","毓金为体，禀火成身。","宫音式奏，奏以迎神。"]},{"id":"t0-470","title":"郊庙歌辞 五郊乐章 送神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["春末冬暮，徂夏杪秋。","土王四月，时季一周。","黍稷已享，笾豆宜收。","送神有乐，神其赐休。"]},{"id":"t0-471","title":"郊庙歌辞 五郊乐章 青郊迎神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["缇幕移候，青郊启蛰。","淑景迟迟，和风习习。","璧玉宵备，旌旄曙立。","张乐以迎，帝神其入。"]},{"id":"t0-472","title":"郊庙歌辞 五郊乐章 送神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["文物流彩，声明动色。","人竭其恭，灵昭其饬。","歆荐不已，垂祯无极。","送礼有章，惟神还轼。"]},{"id":"t0-473","title":"郊庙歌辞 五郊乐章 赤郊迎神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["青阳节谢，朱明候改。","靡草雕华，含桃流彩。","虡列钟磬，筵陈脯醢。","乐以迎神，神其如在。"]},{"id":"t0-474","title":"郊庙歌辞 五郊乐章 送神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["炎精式降，苍生攸仰。","羞列豆笾，酒陈牺象。","昭祀有应，冥期不爽。","送乐张音，惟灵之往。"]},{"id":"t0-475","title":"郊庙歌辞 五郊乐章 白郊迎神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["序移玉律，节应金商。","天严杀气，吹警秋方。","槱燎既积，稷奠并芳。","乐以迎奏，庶降神光。"]},{"id":"t0-476","title":"郊庙歌辞 五郊乐章 送神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["祀遵五礼，时属三秋。","人怀肃敬，灵降祯休。","奠歆旨酒，荐享珍羞。","载张送乐，神其上游。"]},{"id":"t0-477","title":"郊庙歌辞 五郊乐章 黑郊迎神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["玄英戒序，黑郊临候。","掌礼陈彝，司筵执豆。","寒氛敛色，沍泉凝漏。","乐以迎神，八音斯奏。"]},{"id":"t0-478","title":"郊庙歌辞 五郊乐章 送神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["北郊时冽，南陆辉处。","奠本虔诚，献弥恭虑。","上延祉福，下承欢豫。","广乐送神，神其整驭。"]},{"id":"t0-479","title":"郊庙歌辞 朝日乐章 肃和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["惟圣格天，惟明飨日。","帝郊肆类，王宫戒吉。","珪奠春舒，钟歌晓溢。","礼云克备，斯文有秩。"]},{"id":"t0-480","title":"郊庙歌辞 朝日乐章 雍和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["晨仪式荐，明祀惟光。","神物爰止，灵晖载扬。","玄端肃事，紫幄兴祥。","福履攸假，于昭允王。"]},{"id":"t0-481","title":"郊庙歌辞 朝日乐章 舒和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["崇牙树羽延调露，旋宫扣律掩承云。","诞敷懿德昭神武，载集丰功表睿文。"]},{"id":"t0-482","title":"郊庙歌辞 朝日乐章 迎神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["太阳朝序，王宫有仪。","蟠桃彩驾，细柳光驰。","轩祥表合，汉历彰奇。","礼和乐备，神其降斯。"]},{"id":"t0-483","title":"郊庙歌辞 朝日乐章 送神","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["五齐兼酌，百羞具陈。","乐终广奏，礼毕崇禋。","明鉴万宇，照临兆人。","永流洪庆，式动曦轮。"]},{"id":"t0-484","title":"郊庙歌辞 夕月乐章 肃和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["测妙为神，通微曰圣。","坎祀贻则，郊禋展敬。","璧荐登光，金歌动映。","以载嘉德，以流曾庆。"]},{"id":"t0-485","title":"郊庙歌辞 夕月乐章 雍和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["朏晨争举，天宗礼辟。","夜典凉秋，阴明湛夕。","有𨣧斯旨，有牲斯硕。","穆穆其晖，穰穰是积。"]},{"id":"t0-486","title":"郊庙歌辞 夕月乐章 舒和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["合吹八风金奏动，分容万舞玉鞘惊。","词昭茂典光前列，夕曜乘功表盛明。"]},{"id":"t0-487","title":"郊庙歌辞 祀九宫贵神乐章 豫和 一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["于昭上穹，临下有光。","羽翼五佐，周流八荒。","谁其飨之，时文对敭。","虞经夏典，兹礼未遑。"]},{"id":"t0-488","title":"郊庙歌辞 祀九宫贵神乐章 豫和 二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["黑帝旋驭，青躔导日。","金箓上玄，玉堂初吉。","钩陈夕次，銮和先跸。","蔼蔼群灵，昭昭咸秩。"]},{"id":"t0-489","title":"郊庙歌辞 祀九宫贵神乐章 豫和 三","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["帝临中坛，受厘元神。","皇灵萃止，羽旄肃陈。","摄提运衡，招摇移轮。","光光宇宙，电耀雷震。"]},{"id":"t0-490","title":"郊庙歌辞 祀九宫贵神乐章 豫和 四","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["夜如何其，明星煌煌。","天清容卫，露结坛场。","树羽幢幢，佩玉锵锵。","凝精驻目，瞻望神光。"]},{"id":"t0-491","title":"郊庙歌辞 祀九宫贵神乐章 豫和 五","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["九位既肃，万灵毕会。","天门启扄，日驭飞盖。","焕兮棽离，傧兮暗霭。","如山之福，惟圣时对。"]},{"id":"t0-492","title":"郊庙歌辞 祀九宫贵神乐章 豫和 六","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["崇崇泰坛，灵具临兮。","铿锽大乐，振动心兮。","神之降矣，卿云郁兮。","神之至止，清风肃兮。"]},{"id":"t0-493","title":"郊庙歌辞 祀九宫贵神乐章 太和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["帝在灵坛，大明登光。","天回云粹，穆穆皇皇。","金奏九夏，圭陈八芗。","旷哉动植，如熙春阳。"]},{"id":"t0-494","title":"郊庙歌辞 祀九宫贵神乐章 肃和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["歌工既奏，神位既秩。","天符众星，运行太一。","声和十管，气应中律。","肃肃明廷，介兹元吉。"]},{"id":"t0-495","title":"郊庙歌辞 祀九宫贵神乐章 雍和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["俎豆有践，黄流在尊。","九宫之祀，三代莫存。","乐变六宫，坛开八门。","圣皇昭对，祐我黎元。"]},{"id":"t0-496","title":"郊庙歌辞 祀九宫贵神乐章 寿和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["时文哲后，肃事严禋。","馨我明德，享于贵神。","大庖载盈，旨酒斯醇。","精意所属，期于利人。"]},{"id":"t0-497","title":"郊庙歌辞 祀九宫贵神乐章 福和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["祀既云毕，明灵告旋。","礼洽和应，神歆福延。","动植咸若，阴阳不愆。","锡兹纯嘏，天子万年。"]},{"id":"t0-498","title":"郊庙歌辞 祀九宫贵神乐章 舒和","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["羽籥既阕干戚陈，八音克谐六变新。","愉贵神兮般以乐，保皇祚兮万斯春。"]},{"id":"t0-499","title":"郊庙歌辞 祀九宫贵神乐章 凯安","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["盛德陈万舞，威棱畅九垓。","风云交律候，日月丽昭回。","行庆休祥发，乘和春气来。","百神肃临享，荡荡天门开。"]}]