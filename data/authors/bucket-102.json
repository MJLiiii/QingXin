{"刘子实":{"slug":"刘子实","name":"刘子实","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c73-820","title":"念奴娇·一门相种","kind":"词"},{"id":"c73-821","title":"沁园春·腊后寒收","kind":"词"}]},"刘松":{"slug":"刘松","name":"刘松","dynasty":"唐","style":"字嵇美","life":"","origin":"","seal":"刘","bio":["松，字嵇美，袁州人。进士，与李咸用有过往。尝集其州天宝以后诗四百七十篇为《宜阳集》六卷。","诗一首。（《全唐诗》无刘松诗。事迹据《新唐书》卷六十《艺文志》四及《李推官披沙集》卷中、卷下）"],"works":[{"id":"t54-263","title":"题九疑山","kind":"诗"}]},"刘湾":{"slug":"刘湾","name":"刘湾","dynasty":"唐","style":"字灵源","life":"","origin":"","seal":"刘","bio":["刘湾，字灵源，西蜀人，天宝进士。禄山之乱，以侍御史居衡阳，与元结相友善。诗六首。"],"works":[{"id":"t9-511","title":"出塞曲","kind":"诗"},{"id":"t9-512","title":"云南曲","kind":"诗"},{"id":"t9-513","title":"李陵别苏武","kind":"诗"},{"id":"t9-514","title":"虹县严孝子墓","kind":"诗"},{"id":"t9-515","title":"对雨愁闷寄钱大郎中","kind":"诗"},{"id":"t9-516","title":"即席赋露中菊","kind":"诗"}]},"刘驾":{"slug":"刘驾","name":"刘驾","dynasty":"唐","style":"字司南","life":"","origin":"","seal":"刘","bio":["刘驾，字司南，江东人。登大中进士第，官国子博士。诗一卷。"],"works":[{"id":"t0-858","title":"鼓吹曲辞 战城南","kind":"诗"},{"id":"t0-954","title":"横吹曲辞 出塞","kind":"诗"},{"id":"t1-218","title":"相和歌辞 苦寒行","kind":"诗"},{"id":"t1-317","title":"相和歌辞 长门怨","kind":"诗"},{"id":"t1-425","title":"相和歌辞 贾客词","kind":"诗"},{"id":"t1-751","title":"杂曲歌辞 空城雀","kind":"诗"},{"id":"t32-508","title":"皎皎词","kind":"诗"},{"id":"t32-509","title":"长安旅舍纾情投先达","kind":"诗"},{"id":"t32-510","title":"送友下第游鴈门","kind":"诗"},{"id":"t32-511","title":"读史","kind":"诗"},{"id":"t32-512","title":"反贾客乐","kind":"诗"},{"id":"t32-513","title":"送李垣先辈归嵩少旧居","kind":"诗"},{"id":"t32-514","title":"苦寒吟","kind":"诗"},{"id":"t32-515","title":"上巳日","kind":"诗"},{"id":"t32-516","title":"春台","kind":"诗"},{"id":"t32-517","title":"钓台怀古","kind":"诗"},{"id":"t32-518","title":"励志","kind":"诗"},{"id":"t32-519","title":"桑妇","kind":"诗"},{"id":"t32-520","title":"上马叹","kind":"诗"},{"id":"t32-521","title":"唐乐府十首 送征夫","kind":"诗"},{"id":"t32-522","title":"唐乐府十首 轮者讴","kind":"诗"},{"id":"t32-523","title":"唐乐府十首 吊西人","kind":"诗"},{"id":"t32-524","title":"唐乐府十首 边军过","kind":"诗"},{"id":"t32-525","title":"唐乐府十首 望归马","kind":"诗"},{"id":"t32-526","title":"唐乐府十首 祝河水","kind":"诗"},{"id":"t32-527","title":"唐乐府十首 田西边","kind":"诗"},{"id":"t32-528","title":"唐乐府十首 昆山","kind":"诗"},{"id":"t32-529","title":"唐乐府十首 乐边人","kind":"诗"},{"id":"t32-530","title":"唐乐府十首 献贺觞","kind":"诗"},{"id":"t32-531","title":"且可怜行","kind":"诗"},{"id":"t32-532","title":"筑台词","kind":"诗"},{"id":"t32-533","title":"邻女","kind":"诗"},{"id":"t32-534","title":"山中夜坐","kind":"诗"},{"id":"t32-535","title":"秦娥","kind":"诗"},{"id":"t32-536","title":"牧童","kind":"诗"},{"id":"t32-537","title":"古出塞","kind":"诗"},{"id":"t32-538","title":"寄远","kind":"诗"},{"id":"t32-539","title":"下第后屏居长安书怀寄太原从事","kind":"诗"},{"id":"t32-540","title":"早行","kind":"诗"},{"id":"t32-541","title":"青门路","kind":"诗"},{"id":"t32-542","title":"效古","kind":"诗"},{"id":"t32-543","title":"战城南","kind":"诗"},{"id":"t32-544","title":"曲江春霁","kind":"诗"},{"id":"t32-545","title":"赠先达","kind":"诗"},{"id":"t32-546","title":"有感","kind":"诗"},{"id":"t32-547","title":"姑苏台","kind":"诗"},{"id":"t32-548","title":"豪家","kind":"诗"},{"id":"t32-549","title":"山中有招","kind":"诗"},{"id":"t32-550","title":"空城雀","kind":"诗"},{"id":"t32-551","title":"冯叟居","kind":"诗"}]},"匡慧":{"slug":"匡慧","name":"匡慧","dynasty":"唐","style":"号玄悟禅师","life":"","origin":"","seal":"匡","bio":["匡慧，俗姓高，福州福唐人。出家罗汉院，嗣曹山，后居抚州荷玉山，世称荷玉和尚。昭宗大顺二年被召，辞之，赐号玄悟禅师。"],"works":[{"id":"t54-387","title":"颂","kind":"诗"}]},"卢骈":{"slug":"卢骈","name":"卢骈","dynasty":"唐","style":"","life":"","origin":"","seal":"卢","bio":["卢骈，咸通进士，官员外。诗一首。"],"works":[{"id":"t33-377","title":"题青龙精舍","kind":"诗"}]},"吴琚":{"slug":"吴琚","name":"吴琚","dynasty":"宋","style":"字居父 · 号云壑","life":"","origin":"","seal":"吴","bio":["--字居父，号云壑，汴 (今河南开封) 人。宋高宗吴皇后之侄。特授添差临安府通判，历尚书郎，除知明州等地。","嘉泰二年 (1202) 迁少保。有《云壑集》。"],"works":[{"id":"c70-418","title":"念奴娇·我来浮玉","kind":"词"},{"id":"c70-419","title":"柳梢青·彩仗鞭春","kind":"词"},{"id":"c70-420","title":"浪淘沙·云叶弄轻阴","kind":"词"},{"id":"c70-421","title":"浪淘沙·岸柳可藏鸦","kind":"词"},{"id":"c70-422","title":"水龙吟·紫皇高宴萧台","kind":"词"},{"id":"c70-423","title":"酹江月・念奴娇·玉虹遥挂","kind":"词"}]},"唐扶":{"slug":"唐扶","name":"唐扶","dynasty":"唐","style":"字云翔","life":"","origin":"","seal":"唐","bio":["唐扶，字云翔，晋阳人，莒公俭之后。元和五年，登进士第，为侍御史，终福州团练观察使。诗二首。"],"works":[{"id":"t26-121","title":"使南海道长沙题道林岳麓寺","kind":"诗"},{"id":"t26-122","title":"和兵部郑侍郎省中四松诗","kind":"诗"}]},"宗茝":{"slug":"宗茝","name":"宗茝","dynasty":"唐","style":"","life":"","origin":"","seal":"宗","bio":["宗茝，大中间长安千福寺僧。诗二首。（《全唐诗》无宗茝诗）"],"works":[{"id":"t53-940","title":"七言美瓜沙僧献款诗二首 一","kind":"诗"},{"id":"t53-941","title":"七言美瓜沙僧献款诗二首 二","kind":"诗"}]},"崔建":{"slug":"崔建","name":"崔建","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":[],"works":[{"id":"t50-66","title":"句","kind":"诗"}]},"廉氏":{"slug":"廉氏","name":"廉氏","dynasty":"唐","style":"","life":"","origin":"","seal":"廉","bio":[],"works":[{"id":"t44-65","title":"峡中即事","kind":"诗"},{"id":"t44-66","title":"怀远","kind":"诗"},{"id":"t44-67","title":"寄征人","kind":"诗"}]},"怀浦":{"slug":"怀浦","name":"怀浦","dynasty":"唐","style":"","life":"","origin":"","seal":"怀","bio":[],"works":[{"id":"t47-201","title":"赠智舟三藏","kind":"诗"},{"id":"t47-202","title":"初冬旅舍早怀","kind":"诗"}]},"文宗皇帝":{"slug":"文宗皇帝","name":"文宗皇帝","dynasty":"唐","style":"","life":"","origin":"后代词","seal":"文","bio":["帝讳昂，穆宗第二子。初名涵，封江王。宝历二年，即位。","恭俭儒雅，听政之暇，博通群籍。顾谓左右曰：“若不甲夜视事，乙夜观书，何以为人君？”每试进士，新裁题目。及所司进所试，披览吟咏，终日忘倦。","延学士于内庭，讨论经义，好制五言，古调清峻，常欲置诗博士。李珏言：“今翰林学士皆能文词，且古今篇什，足可怡悦。”圣情乃止。","又尝与宰相论诗之工拙，郑覃曰：“诗之工者，无若《三百篇》，皆国人作之以刺美时政，王者采之以观风俗。后代词人，华而不实，无补于事。”帝甚重其言。","在位十三年，谥曰昭献。今存诗七首。"],"works":[{"id":"t0-200","title":"暮春喜雨诗","kind":"诗"},{"id":"t0-201","title":"题程修己竹障","kind":"诗"},{"id":"t0-202","title":"宫中题","kind":"诗"},{"id":"t0-203","title":"上巳日赐裴度","kind":"诗"},{"id":"t0-204","title":"上元日二首 一","kind":"诗"},{"id":"t0-205","title":"上元日二首 二","kind":"诗"},{"id":"t0-206","title":"夏日联句","kind":"诗"}]},"朱千乘":{"slug":"朱千乘","name":"朱千乘","dynasty":"唐","style":"","life":"","origin":"","seal":"朱","bio":[],"works":[{"id":"t50-9","title":"句","kind":"诗"},{"id":"t53-386","title":"山庄早春连雨即事","kind":"诗"},{"id":"t53-387","title":"早春霁后山庄即事","kind":"诗"},{"id":"t53-388","title":"送日本国三藏空海上人朝宗我唐兼贡方物而归海东诗（并序）","kind":"诗"}]},"李敬玄":{"slug":"李敬玄","name":"李敬玄","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李敬玄，亳州谯人，博览群书，特善五礼。贞观末，高宗在东宫，以马周荐，召入崇贤馆侍读。历西台侍郎，检校司列常伯，典铨有序，选者岁万余人，每于街衢见之，无不知其姓名，时人服其强记。","仪凤中，为中书令，刘仁轨奏镇河西，敬玄自知非边将才，上强遣之，败于湟州，坐贬。集三十卷，今存诗二首。"],"works":[{"id":"t2-883","title":"奉和别鲁王","kind":"诗"},{"id":"t2-884","title":"奉和别越王","kind":"诗"}]},"李芸子":{"slug":"李芸子","name":"李芸子","dynasty":"宋","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"c73-965","title":"木兰花慢·占西风早处","kind":"词"}]},"柳道伦":{"slug":"柳道伦","name":"柳道伦","dynasty":"唐","style":"","life":"","origin":"","seal":"柳","bio":["柳道伦，贞元中进士。诗一首。"],"works":[{"id":"t18-401","title":"赋得春风扇微和","kind":"诗"}]},"步非烟":{"slug":"步非烟","name":"步非烟","dynasty":"唐","style":"","life":"","origin":"","seal":"步","bio":["步非烟，河南功曹武公业妾也。邻生赵象以诗诱之，非烟荅以诗。象因逾垣相从，事露，笞死。","诗四首。"],"works":[{"id":"t44-5","title":"荅赵子","kind":"诗"},{"id":"t44-6","title":"又荅赵象独坐","kind":"诗"},{"id":"t44-7","title":"寄怀","kind":"诗"},{"id":"t44-8","title":"荅赵象","kind":"诗"}]},"殷潜之":{"slug":"殷潜之","name":"殷潜之","dynasty":"唐","style":"","life":"","origin":"","seal":"殷","bio":["殷潜之，自称野人，与杜牧同时，诗一首。"],"works":[{"id":"t30-159","title":"题筹笔驿","kind":"诗"}]},"王仙乔":{"slug":"王仙乔","name":"王仙乔","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王仙乔，开元天宝间南岳九真观道士。诗句二。（《全唐诗》无王仙乔诗）"],"works":[{"id":"t51-54","title":"句","kind":"诗"}]},"范祖禹":{"slug":"范祖禹","name":"范祖禹","dynasty":"宋","style":"","life":"","origin":"","seal":"范","bio":[],"works":[{"id":"c59-589","title":"导引·思齐文母","kind":"词"},{"id":"c59-590","title":"六州·太平功","kind":"词"},{"id":"c59-591","title":"十二时・忆少年·转招摇","kind":"词"},{"id":"c59-592","title":"虞神歌·驾玉龙","kind":"词"},{"id":"c59-593","title":"导引·延和幄座","kind":"词"}]},"贺遂亮":{"slug":"贺遂亮","name":"贺遂亮","dynasty":"唐","style":"","life":"","origin":"","seal":"贺","bio":["贺遂亮，官御史。诗一首。"],"works":[{"id":"t2-910","title":"赠韩思彦","kind":"诗"}]},"邵怀英":{"slug":"邵怀英","name":"邵怀英","dynasty":"宋","style":"","life":"","origin":"","seal":"邵","bio":[],"works":[{"id":"c68-262","title":"水调歌头·香亲紫荷陌","kind":"词"}]},"钱元瓘":{"slug":"钱元瓘","name":"钱元瓘","dynasty":"唐","style":"字明宝","life":"","origin":"","seal":"钱","bio":["元瓘，镠第七子，初名传瓘，嗣位后更今名。字明宝，长兴三年镠卒，袭封吴越国王。善抚将士，好儒学，善为诗。","尝置择能院，选吴中文士录用之。然性奢侈，好治宫室。在位十年。","天福六年，因火焚其宫，惊惧病狂卒，年五十五。谥文穆，著有《锦楼集》十卷。"],"works":[{"id":"t51-664","title":"送别十七哥","kind":"诗"},{"id":"t51-665","title":"题得铜香炉（并序）","kind":"诗"},{"id":"t55-595","title":"句","kind":"诗"}]},"陈亮":{"slug":"陈亮","name":"陈亮","dynasty":"宋","style":"字同甫 · 号龙川","life":"","origin":"婺州永康（今属浙江）","seal":"陈","bio":["(1143－1194) 字同甫，号龙川，婺州永康 (今属浙江) 人。绍熙四年 (1193) 进士。授签书建康府判官厅公事，未赴而卒。","亮曾力主抗金，反对和议，遭忌被诬入狱。为人才气超迈，喜谈兵，议论风生。文章气势纵横，笔锋犀利。","词作感情激越，风格豪放，多议论，与辛弃疾相唱和。有《龙川文集》《龙川词》。"],"works":[{"id":"c69-950","title":"水调歌头·不见南师久","kind":"词"},{"id":"c69-951","title":"念奴娇·江南春色","kind":"词"},{"id":"c69-952","title":"贺新郎·修竹更深处","kind":"词"},{"id":"c69-953","title":"满江红·曾洗乾坤","kind":"词"},{"id":"c69-954","title":"桂枝香·天高气肃","kind":"词"},{"id":"c69-955","title":"三部乐·小屈穹庐","kind":"词"},{"id":"c69-956","title":"水调歌头·人物从来少","kind":"词"},{"id":"c69-957","title":"念奴娇·危楼远望","kind":"词"},{"id":"c69-958","title":"贺新郎·老去凭谁说","kind":"词"},{"id":"c69-959","title":"瑞云浓慢·蔗浆酪粉","kind":"词"},{"id":"c69-960","title":"阮郎归·波光渺渺浸晴陂","kind":"词"},{"id":"c69-961","title":"祝英台近·驾扁舟","kind":"词"},{"id":"c69-962","title":"蝶恋花·手拈黄花还自笑","kind":"词"},{"id":"c69-963","title":"水调歌头·人爱新来景","kind":"词"},{"id":"c69-964","title":"念奴娇·西风带暑","kind":"词"},{"id":"c69-965","title":"卜算子·悄静菊花天","kind":"词"},{"id":"c69-966","title":"贺新郎·离乱从头说","kind":"词"},{"id":"c69-967","title":"垂丝钓·菊花细雨","kind":"词"},{"id":"c69-968","title":"彩凤飞·人立玉","kind":"词"},{"id":"c69-969","title":"鹧鸪天·落魄行歌记昔游","kind":"词"},{"id":"c69-970","title":"谒金门·新雨足","kind":"词"},{"id":"c69-971","title":"天仙子·一夜秋光先著柳","kind":"词"},{"id":"c69-972","title":"水调歌头·事业随人品","kind":"词"},{"id":"c69-973","title":"洞仙歌·秋容一洗","kind":"词"},{"id":"c69-974","title":"祝英台近·嫩寒天","kind":"词"},{"id":"c69-975","title":"踏莎行·书册如仇","kind":"词"},{"id":"c69-976","title":"南乡子·人物满东瓯","kind":"词"},{"id":"c69-977","title":"三部乐·入脚西风","kind":"词"},{"id":"c69-978","title":"贺新郎·话杀浑闲说","kind":"词"},{"id":"c69-979","title":"点绛唇·一夜相思","kind":"词"},{"id":"c69-980","title":"点绛唇·电绕璇枢","kind":"词"},{"id":"c69-981","title":"点绛唇·碧落蟠桃","kind":"词"},{"id":"c69-982","title":"点绛唇·烟雨楼台","kind":"词"},{"id":"c69-983","title":"南歌子·池草抽新碧","kind":"词"},{"id":"c69-984","title":"好事近·篱菊吐寒花","kind":"词"},{"id":"c69-985","title":"好事近·横玉叫清宵","kind":"词"},{"id":"c69-986","title":"好事近·的皪两三枝","kind":"词"},{"id":"c69-987","title":"浣溪沙·小雨翻花落画檐","kind":"词"},{"id":"c69-988","title":"采桑子·桃花已作东风笑","kind":"词"},{"id":"c69-989","title":"朝中措·蓼花风淡水云纤","kind":"词"},{"id":"c69-990","title":"柳梢青·柳丝烟织","kind":"词"},{"id":"c69-991","title":"浪淘沙·霞尾卷轻绡","kind":"词"},{"id":"c69-992","title":"浪淘沙·院落晓风酸","kind":"词"},{"id":"c69-993","title":"小重山·碧幕霞绡一缕红","kind":"词"},{"id":"c69-994","title":"转调踏莎行・踏莎行·洛浦尘生","kind":"词"},{"id":"c69-995","title":"品令·潇洒林塘暮","kind":"词"},{"id":"c69-996","title":"最高楼·春乍透","kind":"词"},{"id":"c69-997","title":"青玉案·武陵溪上桃花路","kind":"词"},{"id":"c69-998","title":"诉衷情·独凭江槛思悠悠","kind":"词"},{"id":"c69-999","title":"南乡子·风雨满苹洲","kind":"词"}]},"韦斌":{"slug":"韦斌","name":"韦斌","dynasty":"唐","style":"","life":"","origin":"","seal":"韦","bio":["斌，安石之子。尚文艺，与兄陟齐名。景云初授太子通事舍人。","开元十七年迁秘书丞。天宝间历任国子司业、中书舍人、礼部侍郎、太常少卿。五载，坐事贬巴陵太守，移临太守。","十四载，为安史乱军所得，伪授黄门侍郎，忧愤而卒。诗一首。（《全唐诗》无韦斌诗，兹据《旧唐书》卷九二本传录其事迹）"],"works":[{"id":"t52-862","title":"送贺秘监归会稽诗","kind":"诗"}]},"骆仲舒":{"slug":"骆仲舒","name":"骆仲舒","dynasty":"唐","style":"","life":"","origin":"入宋为起居舍","seal":"骆","bio":["骆仲舒，连州人。后周显德三年进士。入宋为起居舍人。","（《全唐诗》无骆仲舒诗，传据康熙《连州志》）"],"works":[{"id":"t55-313","title":"无题","kind":"诗"},{"id":"t55-314","title":"句","kind":"诗"}]},"黄廷璹":{"slug":"黄廷璹","name":"黄廷璹","dynasty":"宋","style":"","life":"","origin":"","seal":"黄","bio":[],"works":[{"id":"c74-848","title":"忆旧游·乍梅黄雨过","kind":"词"}]}}