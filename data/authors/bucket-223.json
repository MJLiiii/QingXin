{"元寂":{"slug":"元寂","name":"元寂","dynasty":"唐","style":"","life":"","origin":"","seal":"元","bio":["元寂，俗姓高，居升元寺。保大中，授左街僧录，内供奉，赐紫。坐饮酒狂歌落职，后醉死于石子冈。","诗一首。"],"works":[{"id":"t45-544","title":"歌","kind":"诗"}]},"刘仁轨":{"slug":"刘仁轨","name":"刘仁轨","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":["仁轨，汴州尉氏人。武德间为陈仓尉，太宗时擢栎阳丞、新安令、给事中。高宗初为青州刺史、带方州刺史，干封后屡次入相。","垂拱元年卒，年八十四。所著有《河洛行年记》。（《全唐诗》无刘仁轨诗，据《旧唐书》卷八四本传录其事迹。","）"],"works":[{"id":"t52-493","title":"句","kind":"诗"}]},"周繇":{"slug":"周繇","name":"周繇","dynasty":"唐","style":"字为宪","life":"","origin":"","seal":"周","bio":["周繇，字为宪，池州人。咸通十二年登第，调建德令，辟襄阳徐商幕府，检校御史中丞。诗一卷。"],"works":[{"id":"t35-170","title":"送边上从事","kind":"诗"},{"id":"t35-171","title":"送洛阳崔员外","kind":"诗"},{"id":"t35-172","title":"送人尉黔中","kind":"诗"},{"id":"t35-173","title":"送宇文虞","kind":"诗"},{"id":"t35-174","title":"题东林寺虎掊泉","kind":"诗"},{"id":"t35-175","title":"登甘露寺","kind":"诗"},{"id":"t35-176","title":"甘露寺东轩","kind":"诗"},{"id":"t35-177","title":"甘露寺北轩","kind":"诗"},{"id":"t35-178","title":"咏萤","kind":"诗"},{"id":"t35-179","title":"望海","kind":"诗"},{"id":"t35-180","title":"送杨环校书归广南","kind":"诗"},{"id":"t35-181","title":"经故宅有感","kind":"诗"},{"id":"t35-182","title":"送入蕃使","kind":"诗"},{"id":"t35-183","title":"白石潭秋霁作","kind":"诗"},{"id":"t35-184","title":"题金陵栖霞寺赠月公","kind":"诗"},{"id":"t35-185","title":"嘲段成式","kind":"诗"},{"id":"t35-186","title":"送江州薛尚书","kind":"诗"},{"id":"t35-187","title":"津头望白水","kind":"诗"},{"id":"t35-188","title":"公子行","kind":"诗"},{"id":"t35-189","title":"看牡丹赠段成式","kind":"诗"},{"id":"t35-190","title":"以人葠遗段成式","kind":"诗"},{"id":"t35-191","title":"和段成式 一","kind":"诗"},{"id":"t35-192","title":"和段成式 二","kind":"诗"},{"id":"t53-957","title":"惜春","kind":"诗"}]},"宜芬公主":{"slug":"宜芬公主","name":"宜芬公主","dynasty":"唐","style":"","life":"","origin":"","seal":"宜","bio":["公主本豆卢氏女，有才色。天宝四载，奚霫无主，安禄山请立其质子，而以公主配之。上遣中使护送，至虚池驿，悲愁作诗一首。"],"works":[{"id":"t0-307","title":"虚池驿题屏风","kind":"诗"}]},"寇准":{"slug":"寇准","name":"寇准","dynasty":"宋","style":"字平仲","life":"961 — 1023","origin":"华州下（今陕西渭南）","seal":"寇","bio":["--(961-1023) 字平仲，华州下 (今陕西渭南) 人。太平兴国五年 (1980) 进士。累官至中书侍郎同中书下平章事。","二次罢相，封莱国公。乾兴初，为丁谓所，贬雷州司户参军，卒于贬所。有《寇莱公集》。","存词五首，以《江南春》较著名。"],"works":[{"id":"c57-612","title":"甘草子·春早","kind":"词"},{"id":"c57-613","title":"踏莎行·春色将阑","kind":"词"},{"id":"c57-614","title":"阳关引·塞草烟光阔","kind":"词"},{"id":"c57-615","title":"点绛唇·水陌轻寒","kind":"词"},{"id":"c57-616","title":"江南春・秋风清·波渺渺","kind":"词"},{"id":"c57-617","title":"夜度娘·烟波渺渺一千里","kind":"词"},{"id":"c78-227","title":"蝶恋花·四十年来身富贵","kind":"词"}]},"寒山":{"slug":"寒山","name":"寒山","dynasty":"唐","style":"","life":"","origin":"","seal":"寒","bio":["寒山，不知何许人，居天台唐兴县寒岩。时往还国清寺，以桦皮为冠，布裘弊履，或长廊唱咏，或村墅歌啸，人莫识之。闾丘胤宦丹丘，临行，遇丰干师，言从天台来，闾丘问彼地有何贤堪师。","师曰：“寒山文殊，拾得普贤，在国清寺库院厨中著火。”闾丘到官三日，亲往寺中，见二人，便礼拜。二人大笑曰：“丰干饶舌，饶舌，阿弥不识，礼我何为？”即走出寺，归寒岩，寒山子入穴而去，其穴自合。","尝于竹木石壁书诗，并村墅屋壁所写文句三百余首。今编诗一卷。"],"works":[{"id":"t44-304","title":"诗三百三首 一","kind":"诗"},{"id":"t44-305","title":"诗三百三首 二","kind":"诗"},{"id":"t44-306","title":"诗三百三首 三","kind":"诗"},{"id":"t44-307","title":"诗三百三首 四","kind":"诗"},{"id":"t44-308","title":"诗三百三首 五","kind":"诗"},{"id":"t44-309","title":"诗三百三首 六","kind":"诗"},{"id":"t44-310","title":"诗三百三首 七","kind":"诗"},{"id":"t44-311","title":"诗三百三首 八","kind":"诗"},{"id":"t44-312","title":"诗三百三首 九","kind":"诗"},{"id":"t44-313","title":"诗三百三首 十","kind":"诗"},{"id":"t44-314","title":"诗三百三首 十一","kind":"诗"},{"id":"t44-315","title":"诗三百三首 十二","kind":"诗"},{"id":"t44-316","title":"诗三百三首 十三","kind":"诗"},{"id":"t44-317","title":"诗三百三首 十四","kind":"诗"},{"id":"t44-318","title":"诗三百三首 十五","kind":"诗"},{"id":"t44-319","title":"诗三百三首 十六","kind":"诗"},{"id":"t44-320","title":"诗三百三首 十七","kind":"诗"},{"id":"t44-321","title":"诗三百三首 十八","kind":"诗"},{"id":"t44-322","title":"诗三百三首 十九","kind":"诗"},{"id":"t44-323","title":"诗三百三首 二十","kind":"诗"},{"id":"t44-324","title":"诗三百三首 二十一","kind":"诗"},{"id":"t44-325","title":"诗三百三首 二十二","kind":"诗"},{"id":"t44-326","title":"诗三百三首 二十三","kind":"诗"},{"id":"t44-327","title":"诗三百三首 二十四","kind":"诗"},{"id":"t44-328","title":"诗三百三首 二十五","kind":"诗"},{"id":"t44-329","title":"诗三百三首 二十六","kind":"诗"},{"id":"t44-330","title":"诗三百三首 二十七","kind":"诗"},{"id":"t44-331","title":"诗三百三首 二十八","kind":"诗"},{"id":"t44-332","title":"诗三百三首 二十九","kind":"诗"},{"id":"t44-333","title":"诗三百三首 三十","kind":"诗"},{"id":"t44-334","title":"诗三百三首 三十一","kind":"诗"},{"id":"t44-335","title":"诗三百三首 三十二","kind":"诗"},{"id":"t44-336","title":"诗三百三首 三十三","kind":"诗"},{"id":"t44-337","title":"诗三百三首 三十四","kind":"诗"},{"id":"t44-338","title":"诗三百三首 三十五","kind":"诗"},{"id":"t44-339","title":"诗三百三首 三十六","kind":"诗"},{"id":"t44-340","title":"诗三百三首 三十七","kind":"诗"},{"id":"t44-341","title":"诗三百三首 三十八","kind":"诗"},{"id":"t44-342","title":"诗三百三首 三十九","kind":"诗"},{"id":"t44-343","title":"诗三百三首 四十","kind":"诗"},{"id":"t44-344","title":"诗三百三首 四十一","kind":"诗"},{"id":"t44-345","title":"诗三百三首 四十二","kind":"诗"},{"id":"t44-346","title":"诗三百三首 四十三","kind":"诗"},{"id":"t44-347","title":"诗三百三首 四十四","kind":"诗"},{"id":"t44-348","title":"诗三百三首 四十五","kind":"诗"},{"id":"t44-349","title":"诗三百三首 四十六","kind":"诗"},{"id":"t44-350","title":"诗三百三首 四十七","kind":"诗"},{"id":"t44-351","title":"诗三百三首 四十八","kind":"诗"},{"id":"t44-352","title":"诗三百三首 四十九","kind":"诗"},{"id":"t44-353","title":"诗三百三首 五十","kind":"诗"}]},"朱勰":{"slug":"朱勰","name":"朱勰","dynasty":"唐","style":"","life":"","origin":"","seal":"朱","bio":[],"works":[{"id":"t43-697","title":"句","kind":"诗"}]},"李建勋":{"slug":"李建勋","name":"李建勋","dynasty":"唐","style":"字致尧 · 号钟山公","life":"","origin":"","seal":"李","bio":["李建勋，字致尧，陇西人。少好学，能属文，尤工诗。南唐主李昪镇金陵，用为副使，预禅代之策，拜中书侍郎同平章事。","升元五年，放还私第，嗣主璟召拜司空，寻以司徒致仕，赐号钟山公。集二十卷，今编诗一卷。李建勋字致尧，陇西人。","工诗能文，其诗少犹浮靡，晚岁清淡平易，为南唐李昪、李璟所重。补诗一首并诗句二。"],"works":[{"id":"t41-408","title":"中酒寄刘行军","kind":"诗"},{"id":"t41-409","title":"白雁","kind":"诗"},{"id":"t41-410","title":"早春寄怀","kind":"诗"},{"id":"t41-411","title":"春日东山正堂作","kind":"诗"},{"id":"t41-412","title":"春日小园晨看兼招同舍","kind":"诗"},{"id":"t41-413","title":"惜花寄孙员外","kind":"诗"},{"id":"t41-414","title":"春日病中","kind":"诗"},{"id":"t41-415","title":"殴妓","kind":"诗"},{"id":"t41-416","title":"踏青罇前","kind":"诗