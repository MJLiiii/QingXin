{"僧鸾":{"slug":"僧鸾","name":"僧鸾","dynasty":"唐","style":"","life":"","origin":"","seal":"僧","bio":["僧鸾，少有逸才，不事拘检，谒薛能尚书，以其颠率，令之出家。后入京，为文章供奉，赐紫。或云：即鲜于凤。","诗二首。"],"works":[{"id":"t45-474","title":"苦热行","kind":"诗"},{"id":"t45-475","title":"赠李粲秀才","kind":"诗"},{"id":"t54-227","title":"句","kind":"诗"}]},"刘克逊":{"slug":"刘克逊","name":"刘克逊","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c72-627","title":"水调歌头·解变西崑体","kind":"词"}]},"刘晏":{"slug":"刘晏","name":"刘晏","dynasty":"唐","style":"字士安","life":"","origin":"","seal":"刘","bio":["刘晏，字士安，曹州南华人。年七岁，举神童。累官殿中侍御史，迁度支郎中，杭、陇、华三州刺史。","寻迁河南尹，入为京兆尹，再拜户部侍郎，举颜真卿以自代。宝应二年，迁吏部尚书平章事，领度支盐铁转运租庸使。坐事罢相，诸使如故。","晏以转运为己任，开三门渠津遗迹，岁运米数百万石，以济关中。晏理家俭约，而重交敦旧，视事敏速，乘机无滞，在职十余年，权势之重，邻于宰相。后为杨炎诬构死。","诗二首。"],"works":[{"id":"t0-669","title":"郊庙歌辞 享太庙乐章 惟新舞","kind":"诗"},{"id":"t5-732","title":"咏王大娘戴卒","kind":"诗"},{"id":"t5-733","title":"享太庙乐章","kind":"诗"}]},"吴氏2":{"slug":"吴氏2","name":"吴氏2","dynasty":"宋","style":"","life":"","origin":"","seal":"吴","bio":[],"works":[{"id":"c76-447","title":"好事近·腊近渐知春","kind":"词"}]},"姚发":{"slug":"姚发","name":"姚发","dynasty":"唐","style":"","life":"","origin":"","seal":"姚","bio":["姚发，天宝十二年登进士。诗一首。"],"works":[{"id":"t10-264","title":"送萧颖士赴东府得草字","kind":"诗"}]},"巴陵馆鬼":{"slug":"巴陵馆鬼","name":"巴陵馆鬼","dynasty":"唐","style":"","life":"","origin":"","seal":"巴","bio":[],"works":[{"id":"t47-983","title":"柱上诗","kind":"诗"}]},"懿宗朝举子":{"slug":"懿宗朝举子","name":"懿宗朝举子","dynasty":"唐","style":"","life":"","origin":"","seal":"懿","bio":[],"works":[{"id":"t43-366","title":"刺安南事诗","kind":"诗"}]},"曹唐":{"slug":"曹唐","name":"曹唐","dynasty":"唐","style":"字尧宾","life":"","origin":"","seal":"曹","bio":["曹唐，字尧宾，桂州人。初为道士，后举进士不第。咸通中，累为使府从事。","诗三卷，今编二卷。"],"works":[{"id":"t35-410","title":"升平词五首 一","kind":"诗"},{"id":"t35-411","title":"升平词五首 二","kind":"诗"},{"id":"t35-412","title":"升平词五首 三","kind":"诗"},{"id":"t35-413","title":"升平词五首 四","kind":"诗"},{"id":"t35-414","title":"升平词五首 五","kind":"诗"},{"id":"t35-415","title":"洛东兰若归","kind":"诗"},{"id":"t35-416","