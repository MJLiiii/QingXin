{"slug":"阎防","name":"阎防","dynasty":"唐","style":"","life":"","origin":"","seal":"阎","bio":["阎防，开元、天宝间有文名。谪官长沙司户，孟浩然有《湖中旅泊寄阎九司户》诗。又尝与薛据读书终南丰德寺。","诗五首。"],"works":[{"id":"t13-392","title":"晚秋石门礼拜","kind":"诗"},{"id":"t13-393","title":"百丈溪新理茅茨读书","kind":"诗"},{"id":"t13-394","title":"宿岸道人精舍","kind":"诗"},{"id":"t13-395","title":"夕次鹿门山作","kind":"诗"},{"id":"t13-396","title":"与永乐诸公夜泛黄河作","kind":"诗"},{"id":"t13-397","title":"句","kind":"诗"}]}