:"包何","dynasty":"唐","style":"字幼嗣","life":"","origin":"","seal":"包","bio":["包何，字幼嗣，润州延陵人。融之子，与弟佶齐名，世称二包。登天宝进士第，大历中，为起居舍人。","诗一卷。"],"works":[{"id":"t10-239","title":"送泉州李使君之任","kind":"诗"},{"id":"t10-240","title":"和孟虔州闲斋即事","kind":"诗"},{"id":"t10-241","title":"同李郎中净律院梡子树","kind":"诗"},{"id":"t10-242","title":"同阎伯均宿道士观有述","kind":"诗"},{"id":"t10-243","title":"送乌程王明府贬巴江","kind":"诗"},{"id":"t10-244","title":"同舍弟佶班韦二员外秋苔对之成咏","kind":"诗"},{"id":"t10-245","title":"送王汶宰江阴","kind":"诗"},{"id":"t10-246","title":"和苗员外寓直中书","kind":"诗"},{"id":"t10-247","title":"阙下芙蓉","kind":"诗"},{"id":"t10-248","title":"江上田家","kind":"诗"},{"id":"t10-249","title":"送韦侍御奉使江岭诸道催青苗钱","kind":"诗"},{"id":"t10-250","title":"和程员外春日东郊即事","kind":"诗"},{"id":"t10-251","title":"裴端公使院赋得隔帘见春雨","kind":"诗"},{"id":"t10-252","title":"相里使君第七男生日","kind":"诗"},{"id":"t10-253","title":"同诸公寻李方直不遇","kind":"诗"},{"id":"t10-254","title":"婺州留别邓使君","kind":"诗"},{"id":"t10-255","title":"寄杨侍御","kind":"诗"},{"id":"t10-256","title":"赋得秤送孟孺卿","kind":"诗"},{"id":"t10-257","title":"长安晓望寄崔补阙","kind":"诗"}]},"周存":{"slug":"周存","name":"周存","dynasty":"唐","style":"","life":"","origin":"","seal":"周","bio":["周存，与陆贽同时。诗二首。"],"works":[{"id":"t15-544","title":"禁中春松","kind":"诗"},{"id":"t15-545","title":"西戎献马","kind":"诗"},{"id":"t51-324","title":"白云向空尽（原注：《类诗》作焦郁。《全唐诗》五○五作焦郁诗〖1〗）","kind":"诗"},{"id":"t52-958","title":"授衣赋附歌","kind":"诗"}]},"张渐":{"slug":"张渐","name":"张渐","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张渐，循之从子也。天宝中，杨国忠辟为幕佐，与窦华、宋昱、郑昂、魏仲犀同列，官至翰林学士。国忠败，坐诛。","诗一首。"],"works":[{"id":"t5-752","title":"朗月行","kind":"诗"}]},"曾逮":{"slug":"曾逮","name":"曾逮","dynasty":"宋","style":"","life":"","origin":"","seal":"曾","bio":[],"works":[{"id":"c66-209","title":"好事近·满树叶繁枝重","kind":"词"}]},"李善宁之子":{"slug":"李善宁之子","name":"李善宁之子","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李善宁之子，名不详，临川人。十岁能即席赋诗。诗一首。","（《全唐诗》无李善宁之子诗）"],"works":[{"id":"t55-332","title":"贫家壁","kind":"诗"}]},"杨乘":{"slug":"杨乘","name":"杨乘","dynasty":"唐","style":"号修行杨家","life":"","origin":"发兄弟四","seal":"杨","bio":["杨乘，发之子，大中初，登进士第，终殿中侍御史。发兄弟四人，与诸群从，皆以文学登高第，时号修行杨家。诗五首。"],"works":[{"id":"t28-77","title":"甲子岁书事","kind":"诗"},{"id":"t28-78","title":"南徐春日怀古","kind":"诗"},{"id":"t28-79","title":"吴中书事","kind":"诗"},{"id":"t28-80","title":"建邺怀古","kind":"诗"},{"id":"t28-81","title":"牓句","kind":"诗"}]},"牛承直":{"slug":"牛承直","name":"牛承直","dynasty":"唐","style":"","life":"","origin":"","seal":"牛","bio":["牛承直，唐巩县令。诗一首。（《全唐诗》无牛承直诗。","）"],"works":[{"id":"t56-290","title":"石窟寺","kind":"诗"}]},"纥干讽":{"slug":"纥干讽","name":"纥干讽","dynasty":"唐","style":"","life":"","origin":"","seal":"纥","bio":[],"works":[{"id":"t43-274","title":"新阳改故阴","kind":"诗"}]},"赵必":{"slug":"赵必","name":"赵必","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"c74-741","title":"摸鱼子·倚西风","kind":"词"}]},"郑审":{"slug":"郑审","name":"郑审","dynasty":"唐","style":"","life":"","origin":"","seal":"郑","bio":["郑审，繇之子。乾元中袁州刺史，大历初秘书监，出为江陵少尹。诗二首。"],"works":[{"id":"t16-760","title":"酒席赋得匏瓢","kind":"诗"},{"id":"t16-761","title":"奉使巡检两京路种果树事毕入秦因咏","kind":"诗"}]},"郭绍兰":{"slug":"郭绍兰","name":"郭绍兰","dynasty":"唐","style":"","life":"","origin":"","seal":"郭","bio":["郭绍兰，长安人，巨商任宗妻也。诗一首。"],"works":[{"id":"t43-927","title":"寄夫","kind":"诗"}]},"钟辰翁":{"slug":"钟辰翁","name":"钟辰翁","dynasty":"宋","style":"","life":"","origin":"","seal":"钟","bio":[],"works":[{"id":"c76-415","title":"水调歌头·皓皓一何洁","kind":"词"},{"id":"c76-416","title":"齐天乐·南墙槐竹风摇翠","kind":"词"}]},"韦安石":{"slug":"韦安石","name":"韦安石","dynasty":"唐","style":"","life":"","origin":"","seal":"韦","bio":["韦安石，京兆万年人，举明经。久视中，以鸾台侍郎同凤阁鸾台平章事，数折辱二张、三思。复相中宗，不附太平公主。","睿宗时，为姜皎所搆，贬卒。诗三首。"],"works":[{"id":"t5-296","title":"奉和九日幸临渭亭登高应制得枝字","kind":"诗"},{"id":"t5-297","title":"侍宴旋师喜捷应制","kind":"诗"},{"id":"t5-298","title":"梁王宅侍宴应制同用风字","kind":"诗"}]},"韩昭裔":{"slug":"韩昭裔","name":"韩昭裔","dynasty":"唐","style":"","life":"","origin":"","seal":"韩","bio":["韩昭裔，后唐清泰时宰相。诗一首。"],"works":[{"id":"t41-381","title":"与李专美","kind":"诗"}]},"高迈":{"slug":"高迈","name":"高迈","dynasty":"唐","style":"","life":"","origin":"","seal":"高","bio":["迈，中宗初年人，有赋一卷。今存诗一首。（《全唐诗》无高迈诗，传据《新唐书·艺文志》、《全唐文》卷二七六）"],"works":[{"id":"t52-589","title":"三五七言体诗","kind":"诗"}]}}