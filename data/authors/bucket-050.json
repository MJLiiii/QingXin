{"丁谓":{"slug":"丁谓","name":"丁谓","dynasty":"宋","style":"","life":"","origin":"","seal":"丁","bio":[],"works":[{"id":"c57-632","title":"凤栖梧・蝶恋花·十二层楼春色早","kind":"词"},{"id":"c57-633","title":"凤栖梧・蝶恋花·朱阙玉城通阆苑","kind":"词"}]},"严嶷":{"slug":"严嶷","name":"严嶷","dynasty":"唐","style":"","life":"","origin":"","seal":"严","bio":[],"works":[{"id":"t50-215","title":"别宋侍御","kind":"诗"}]},"傅自得":{"slug":"傅自得","name":"傅自得","dynasty":"宋","style":"","life":"","origin":"","seal":"傅","bio":[],"works":[{"id":"c78-349","title":"蓦山溪·洪钧转处","kind":"词"}]},"南唐失名僧":{"slug":"南唐失名僧","name":"南唐失名僧","dynasty":"唐","style":"","life":"","origin":"","seal":"南","bio":[],"works":[{"id":"t47-225","title":"月","kind":"诗"}]},"史凤":{"slug":"史凤","name":"史凤","dynasty":"唐","style":"","life":"","origin":"","seal":"史","bio":["史凤，宣城妓也。诗七首。"],"works":[{"id":"t44-124","title":"迷香洞","kind":"诗"},{"id":"t44-125","title":"神鸡枕","kind":"诗"},{"id":"t44-126","title":"锁莲灯","kind":"诗"},{"id":"t44-127","title":"鲛红被","kind":"诗"},{"id":"t44-128","title":"传香枕","kind":"诗"},{"id":"t44-129","title":"八分羊","kind":"诗"},{"id":"t44-130","title":"闭门羮","kind":"诗"}]},"后唐厨官":{"slug":"后唐厨官","name":"后唐厨官","dynasty":"唐","style":"","life":"","origin":"","seal":"后","bio":[],"works":[{"id":"t55-233","title":"咏魏王继岌羹丞相卢澄粥（题拟）","kind":"诗"}]},"唐求":{"slug":"唐求","name":"唐求","dynasty":"唐","style":"","life":"","origin":"","seal":"唐","bio":["唐求，居蜀之味江山，至性纯悫。王建帅蜀，召为参谋，不就。放旷疎逸，邦人谓之唐隐居。","为诗撚稿为圆，纳之大瓢，后卧病，投瓢于江，曰：“斯文苟不沉没，得者方知吾苦心尔。”至新渠，有识者曰：“唐山人瓢也。”接得之，十才二三。","今编诗一卷。"],"works":[{"id":"t40-764","title":"酬友生早秋","kind":"诗"},{"id":"t40-765","title":"晓发","kind":"诗"},{"id":"t40-766","title":"客行","kind":"诗"},{"id":"t40-767","title":"题郑处士隐居","kind":"诗"},{"id":"t40-768","title":"古寺","kind":"诗"},{"id":"t40-769","title":"赠著上人","kind":"诗"},{"id":"t40-770","title":"马嵬感事","kind":"诗"},{"id":"t40-771","title":"赠行如上人","kind":"诗"},{"id":"t40-772","title":"送友人归邛州","kind":"诗"},{"id":"t40-773","title":"和舒上人山居即事","kind":"诗"},{"id":"t40-774","title":"发邛州寄友人","kind":"诗"},{"id":"t40-775","title":"舟