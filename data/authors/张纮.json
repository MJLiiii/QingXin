{"slug":"张纮","name":"张纮","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张纮，久视中登第，与吕太一同官监察御史，后自左拾遗贬许州司户。诗三首。"],"works":[{"id":"t1-773","title":"杂曲歌辞 行路难","kind":"诗"},{"id":"t5-223","title":"和吕御史咏院中藂竹","kind":"诗"},{"id":"t5-224","title":"闺怨","kind":"诗"},{"id":"t5-225","title":"行路难","kind":"诗"}]}