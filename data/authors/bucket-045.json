","title":"题竹林寺","kind":"诗"},{"id":"t16-869","title":"答陆[澧]","kind":"诗"},{"id":"t16-870","title":"杨子津送人","kind":"诗"},{"id":"t16-871","title":"山中谒皇甫曾","kind":"诗"},{"id":"t16-872","title":"剡山夜月","kind":"诗"},{"id":"t16-873","title":"九日与杨凝崔淑期登江上山会有故不得往因赠之","kind":"诗"},{"id":"t16-874","title":"山中听子规","kind":"诗"},{"id":"t16-875","title":"乱后经淮阴岸","kind":"诗"},{"id":"t16-876","title":"送张山人","kind":"诗"},{"id":"t16-877","title":"别李季兰","kind":"诗"},{"id":"t16-878","title":"游石涧寺","kind":"诗"},{"id":"t16-879","title":"新安所居答相访人所居萧使君为制","kind":"诗"},{"id":"t16-880","title":"送魏校书","kind":"诗"},{"id":"t16-881","title":"送温台","kind":"诗"},{"id":"t16-882","title":"句","kind":"诗"},{"id":"t51-332","title":"留别刘员外","kind":"诗"},{"id":"t53-73","title":"和萧郎中游兰若","kind":"诗"}]},"杨元亨":{"slug":"杨元亨","name":"杨元亨","dynasty":"宋","style":"","life":"","origin":"","seal":"杨","bio":[],"works":[{"id":"c76-616","title":"沁园春·一棹横江","kind":"词"}]},"江纬":{"slug":"江纬","name":"江纬","dynasty":"宋","style":"","life":"","origin":"","seal":"江","bio":[],"works":[{"id":"c62-957","title":"向湖边·退处相关","kind":"词"}]},"程东湾":{"slug":"程东湾","name":"程东湾","dynasty":"宋","style":"","life":"","origin":"","seal":"程","bio":[],"works":[{"id":"c76-570","title":"沁园春·毓德婺虚","kind":"词"}]},"臧馀庆":{"slug":"臧馀庆","name":"臧馀庆","dynasty":"宋","style":"","life":"","origin":"","seal":"臧","bio":[],"works":[{"id":"c78-607","title":"南歌子·桔里风烟好","kind":"词"},{"id":"c78-608","title":"鹧鸪天·天与君王管晏才","kind":"词"},{"id":"c78-609","title":"鹧鸪天·寿菊才开三四葩","kind":"词"},{"id":"c78-610","title":"感皇恩·消息近春来","kind":"词"},{"id":"c78-611","title":"感皇恩·南岳有真仙","kind":"词"},{"id":"c78-612","title":"感皇恩·交广出沉香","kind":"词"}]},"苏焜":{"slug":"苏焜","name":"苏焜","dynasty":"唐","style":"","life":"","origin":"","seal":"苏","bio":["苏焜，武后时拾遗。诗一首。（《全唐诗》无苏焜诗）"],"works":[{"id":"t52-505","title":"武三思席上咏绮娘（题拟）","kind":"诗"}]},"蔡允恭":{"slug":"蔡允恭","name":"蔡允恭","dynasty":"唐","style":"","life":"","origin":"","seal":"蔡","bio":["蔡允恭，荆州江陵人。有风采，善缀文。仕隋，历著作佐郎，起居舍人，炀帝属词赋，多令讽诵之。","入唐，为文学馆学士。贞观初，除太子洗马。集二十卷，今存诗一首。"],"works":[{"id":"t2-683","title":"奉和出颖至淮应令","kind":"诗"}]},"赵昂":{"slug":"赵昂","name":"赵昂","dynasty":"唐","style":"字里不详","life":"","origin":"","seal":"赵","bio":["--生平和字里不详。孝宗时御前应对。存词一首。"],"works":[{"id":"t52-907","title":"攻玉赋附卞生追怨之歌","kind":"诗"},{"id":"c70-471","title":"婆罗门引·暮霞照水","kind":"词"}]},"郑俞":{"slug":"郑俞","name":"郑俞","dynasty":"唐","style":"","life":"","origin":"","seal":"郑","bio":["郑俞，贞元十六年登进士第，为长水县令。诗一首。"],"works":[{"id":"t24-819","title":"赋得玉水记方流","kind":"诗"}]},"钱惟治":{"slug":"钱惟治","name":"钱惟治","dynasty":"唐","style":"字和世","life":"","origin":"","seal":"钱","bio":["钱惟治字和世，吴越废王钱倧长子，忠懿王钱俶养为己子。入宋。领镇国军节度使、左骁卫上将军，卒，追封彭城郡王。","生平慕皮、陆为诗，有集。诗二首。（《全唐诗》无钱惟治诗）"],"works":[{"id":"t50-995","title":"无题","kind":"诗"},{"id":"t50-996","title":"春日登大悲阁回文（二首） 一","kind":"诗"},{"id":"t50-997","title":"春日登大悲阁回文（二首） 二","kind":"诗"},{"id":"t55-709","title":"春日登大悲阁二首（一字至七字）","kind":"诗"},{"id":"t55-710","title":"春日登大悲阁二首（一字至七字） 一","kind":"诗"},{"id":"t55-711","title":"春日登大悲阁二首（一字至七字） 二","kind":"诗"},{"id":"t55-712","title":"春日登大悲阁（四言回文）","kind":"诗"}]}}