{
  "id": "t22-516",
  "notes": [
    {
      "term": "不得",
      "def": "南方方言，不许，不要。"
    },
    {
      "term": "语",
      "def": "言语，说话。"
    },
    {
      "term": "暗",
      "def": "暗自。暗地里。"
    },
    {
      "term": "相思",
      "def": "互相思念。后多指男女相悦而无法接近所引起的想念。"
    },
    {
      "term": "深笼",
      "def": "幽深的鸟笼。"
    },
    {
      "term": "夜锁",
      "def": "夜里铁链囚锁。"
    },
    {
      "term": "独栖鸟",
      "def": "孤独栖息的飞鸟。喻有情人被禁锢。"
    },
    {
      "term": "利剑",
      "def": "锋利的长剑。"
    },
    {
      "term": "舂chōng断",
      "def": "在石臼或乳钵里捣碎折断。有说‘春断’春季里折断。"
    },
    {
      "term": "连理枝",
      "def": "两棵树的枝干合生在一起称作连理枝。又称相思树、夫妻树、生死树，比喻夫妻恩爱。"
    },
    {
      "term": "虽浊",
      "def": "虽然浑浊。"
    },
    {
      "term": "清日",
      "def": "清澈的日子。"
    },
    {
      "term": "乌头",
      "def": "乌黑的头发。"
    },
    {
      "term": "白时",
      "def": "变白的时刻。"
    },
    {
      "term": "唯有",
      "def": "唯独只有。"
    },
    {
      "term": "潜离",
      "def": "潜藏着或秘密的离别。"
    },
    {
      "term": "暗别",
      "def": "暗自的辞别。"
    },
    {
      "term": "彼此",
      "def": "指你我、双方。那个和这个。"
    },
    {
      "term": "甘心",
      "def": "心甘情愿。此处指死心。"
    },
    {
      "term": "无后期",
      "def": "无有以后会合之日期。"
    }
  ],
  "translation": [
    "不要哭，悄悄的离开。",
    "不要说话，暗地里互相思念。",
    "两个人的心情没有外人知晓",
    "幽深的鸟笼在夜里用铁链囚锁孤独栖息的飞鸟，锋利的长剑折断连理枝。",
    "河水虽然浑浊，但终究会有清澈的日子，头发虽然乌黑，但也有变白的时刻。",
    "唯独只有秘密的离别，你我才会死心，再无相会之日期。"
  ],
  "appreciation": [
    "《潜别离》是一首杂言诗，此诗通过生动的比喻和形象的描绘，表达了诗人对这种近在眼前实则远在天边的爱情的感伤，展现了相爱之人因种种原因无法公开表达情感的挣扎和痛苦。全文在表现出无奈与遗憾的同时，暗含一丝渺茫的希望，让人深感同情与惋惜。"
  ],
  "background": [
    "白居易早年有一初恋情人，然而唐朝注重礼法，讲究门当户对，出生世家大族的诗人碍于门第与礼法，无法公开两人的恋情。虽不甘心，他终究没有勇气去捅开封建礼法的迷雾，而是选择了“潜离和暗别”。这首《潜别离》便是诗人情感的表白。"
  ],
  "source": "gushiwen-web"
}
