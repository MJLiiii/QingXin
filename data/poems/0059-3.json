[{"id":"c59-300","title":"浣溪沙·一别姑苏已四年","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["一别姑苏已四年。","秋风南浦送归船。","画帘重见水中仙。","霜鬓不须催我老，杏花依旧驻君颜。","夜阑相对梦魂间。"]},{"id":"c59-301","title":"浣溪沙·惟见眉间一点黄","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["惟见眉间一点黄。","诏书催发羽书忙。","从教娇泪洗红妆。","上殿云宵生羽翼，论兵齿颊带风霜。","归来衫袖有天香。"]},{"id":"c59-302","title":"浣溪沙·长记鸣琴子贱堂","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["长记鸣琴子贱堂。","朱颜绿发映垂杨。","如今秋鬓数茎霜。","聚散交游如梦寐，升沈闲事莫思量。","仲卿终不避桐乡。"]},{"id":"c59-303","title":"浣溪沙·风压轻云贴水飞","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["风压轻云贴水飞。","乍晴池馆燕争泥。","沈郎多病不胜衣。","沙上不闻鸿雁信，竹间时听鹧鸪啼。","此情惟有落花知。"]},{"id":"c59-304","title":"浣溪沙·罗袜空飞洛浦尘","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["罗袜空飞洛浦尘。","锦袍不见谪仙人。","携壶藉草亦天真。","玉粉轻黄千岁药，雪花浮动万家春。","醉归江路野梅新。"]},{"id":"c59-305","title":"浣溪沙·白雪清词出坐间","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["白雪清词出坐间。","爱君才器两俱全。","异乡风景却依然。","可恨相逢能几日，不知重会是何年。","茱萸仔细更重看。"]},{"id":"c59-306","title":"浣溪沙·细雨斜风作晓寒","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["细雨斜风作晓寒。","淡烟疏柳媚晴滩。","入淮清洛渐漫漫。","雪沫乳花浮午盏，蓼茸蒿笋试春盘。","人间有味是清欢。"]},{"id":"c59-307","title":"浣溪沙·门外东风雪洒裾","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["门外东风雪洒裾。","山头回首望三吴。","不应弹铗为无鱼。","上党从来天下脊，先生元是古之儒。","时平不用鲁连书。"]},{"id":"c59-308","title":"浣溪沙·惭愧今年二麦丰","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["惭愧今年二麦丰。","千畦细浪舞晴空。","化工馀力染夭红。","归去山公应倒载，阑街拍手笑儿童。","甚时名作锦薰笼。"]},{"id":"c59-309","title":"浣溪沙·芍药樱桃两斗新","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["芍药樱桃两斗新。","名园高会送芳辰。","洛阳初夏广陵春。","红玉半开菩萨面，丹砂浓点柳枝唇。","尊前还有个中人。"]},{"id":"c59-310","title":"浣溪沙·学画鸦儿正妙年","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["学画鸦儿正妙年。","阳城下蔡困嫣然。","凭君莫唱短因缘。","雾帐吹笙香袅袅，霜庭按舞月娟娟。","曲终红袖落双缠。"]},{"id":"c59-311","title":"浣溪沙·一梦江湖费五年","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["一梦江湖费五年。","归来风物故依然。","相逢一醉是前缘。","迁客不应常眊矂，使君为出小婵娟。","翠鬟聊著小诗缠。"]},{"id":"c59-312","title":"浣溪沙·轻汗微微透碧纨","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["轻汗微微透碧纨。","明朝端午浴芳兰。","流香涨腻满晴川。","彩线轻缠红玉臂，小符斜挂绿云鬟。","佳人相见一千年。"]},{"id":"c59-313","title":"浣溪沙·徐邈能中酒圣贤","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["徐邈能中酒圣贤。","刘伶席地幕青天。","潘郎白璧为谁连。","无可奈何新白发，不如归去旧青山。","恨无人借买山钱。"]},{"id":"c59-314","title":"浣溪沙·倾盖相逢胜白头","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["倾盖相逢胜白头。","故山空复梦松楸。","此心安处是菟裘。","卖剑买牛吾欲老，乞浆得酒更何求。","愿为辞社宴春秋。"]},{"id":"c59-315","title":"浣溪沙·炙手无人傍屋头","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["炙手无人傍屋头。","萧萧晚雨脱梧楸。","谁怜季子敞貂裘。","顾我已无当世望，似君须向古人求。","岁寒松柏肯惊秋。"]},{"id":"c59-316","title":"浣溪沙·画隼横江喜再游","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["画隼横江喜再游。","老鱼跳槛识清讴。","流年未肯付东流。","黄菊篱边无怅望，白云乡里有温柔。","挽回霜鬓莫教休。"]},{"id":"c59-317","title":"双荷叶・忆秦娥·双溪月","rhythmic":"双荷叶・忆秦娥","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["双溪月。","清光遍照双荷叶。","双荷叶。","红心未偶，绿衣偷结。","背风迎雨流珠滑。","轻舟短棹先秋折。","先秋折。","烟鬟未上，玉杯微缺。"]},{"id":"c59-318","title":"皂罗特髻·采菱拾翠","rhythmic":"皂罗特髻","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["采菱拾翠，算似此佳名，阿谁消得。","采菱拾翠，称使君知客。","千金买、采菱拾翠，更罗裙、满把珍珠结。","采菱拾翠，正髻鬟初合。","真个、采菱拾翠，但深怜轻拍。","一双手、采菱拾翠，绣衾下、抱著俱香滑。","采菱拾翠，待到京寻觅。"]},{"id":"c59-319","title":"调笑令·渔父","rhythmic":"调笑令","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["渔父。","渔父。","江上微风细雨。","青蓑黄箬裳衣。","红酒白鱼暮归。","归暮。","归暮。","长笛一声何处。"]},{"id":"c59-320","title":"调笑令·归雁","rhythmic":"调笑令","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["归雁。","归雁。","饮啄江南南岸。","将飞却下盘桓。","塞外春来苦寒。","寒苦。","寒苦。","藻荇欲生且住。"]},{"id":"c59-321","title":"荷华媚·霞苞电荷碧","rhythmic":"荷华媚","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["霞苞电荷碧。","天然地、别是风流标格。","重重青盖下，千娇照水，好红红白白。","每怅望、明月清风夜，甚低迷不语，妖邪无力。","终须放、船儿去，清香深处住，看伊颜色。"]},{"id":"c59-322","title":"青玉案·三年枕上吴中路","rhythmic":"青玉案","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["三年枕上吴中路。","遣黄耳、随君去。","若到松江呼小渡。","莫惊鸥鹭，四桥尽是，老子经行处。","辋川图上看春暮。","常记高人右丞句。","作个归期天已许。","春衫犹是，小蛮针线，曾湿西湖雨。"]},{"id":"c59-323","title":"渔家傲·些小白须何用染","rhythmic":"渔家傲","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["些小白须何用染。","几人得见星星点。","作郡浮光虽似箭。","君莫厌。","也应胜我三年贬。","我欲自嗟还不敢。","向来三郡宁非忝。","婚嫁事稀年冉冉。","知有渐。","千钧重担从头减。"]},{"id":"c59-324","title":"江城子·前瞻马耳九仙山","rhythmic":"江城子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["前瞻马耳九仙山。","碧连天。","晚云闲。","城上高台，真个是超然。","莫使匆匆云雨散，今夜里，月婵娟。","小溪鸥鹭静联拳。","去翩翩。","点轻烟。","人事凄凉，回首便他年。","莫忘使君歌笑处，垂柳下，矮槐前。"]},{"id":"c59-325","title":"江城子·墨云拖雨过西楼","rhythmic":"江城子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["墨云拖雨过西楼。","水东流。","晚烟收。","柳外残阳，回照动帘钩。","今夜巫山真个好，花未落，酒新篘。","美人微笑转星眸。","月华羞。","捧金瓯。","歌扇萦风，吹散一春愁。","拭问江南诸伴侣，谁似我，醉扬州。"]},{"id":"c59-326","title":"南乡子·未倦长卿游","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["未倦长卿游。","漫舞夭歌烂不收。","不是使君能矫世，谁留。","教有琼梳脱麝油。","香粉镂金球。","花艳红笺笔欲流。","从此丹唇并皓齿，清柔。","唱遍山东一百州。"]},{"id":"c59-327","title":"南乡子·绣鞅玉环游","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["绣鞅玉环游。","灯晃帘疏笑却收。","久立香车催欲上，还留。","更且檀唇点杏油。","花遍六么球。","面旋回风带雪流。","春入腰肢金缕细，轻柔。","种柳应须柳柳州。"]},{"id":"c59-328","title":"菩萨蛮·娟娟侵鬓妆痕浅","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["娟娟侵鬓妆痕浅。","双颦相媚弯如翦。","一瞬百般宜。","无论笑与啼。","酒阑思翠被。","特故腾腾地。","生怕促归轮。","微波先注人。"]},{"id":"c59-329","title":"菩萨蛮·涂香莫惜莲承步","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["涂香莫惜莲承步。","长愁罗袜凌波去。","只见舞迥风。","都无行处踪。","偷穿宫样稳。","并立双趺困。","纤妙说应难。","须从掌上看。"]},{"id":"c59-330","title":"菩萨蛮·玉环坠耳黄金饰","rhythmic":"菩萨蛮","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["玉环坠耳黄金饰。","轻衫罩体香罗碧。","缓步困春醪。","春融脸上桃。","花钿从委地。","谁与郎为意。","常爱月华清。","此时憎月明。"]},{"id":"c59-331","title":"蝶恋花·别酒劝君君一醉","rhythmic":"蝶恋花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["别酒劝君君一醉。","清润潘郎，又是何郎婿。","记取钗头新利市。","莫将分付东邻子。","回首长安佳丽地。","三十年前，我是风流帅。","为向青楼寻旧事。","花枝缺处馀名字。"]},{"id":"c59-332","title":"蝶恋花·泛泛东风初破五","rhythmic":"蝶恋花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["泛泛东风初破五。","江柳微黄，万万千千缕。","佳气郁葱来绣户。","当年江上生奇女。","一盏寿觞谁与举。","三个明珠，膝上王文度。","放尽穷鳞看圉圉。","天公为下曼陀雨。"]},{"id":"c59-333","title":"浣溪沙·入袂轻风不破尘","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["入袂轻风不破尘。","玉簪犀璧醉佳辰。","一番红粉为谁新。","团扇只堪题往事，新丝那解系行人。","酒阑滋味思残春。"]},{"id":"c59-334","title":"浣溪沙·几共查梨到雪霜","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["几共查梨到雪霜。","一经题品便生光。","木奴何处避雌黄。","北客有来初未识，南金无价喜新尝。","含滋嚼句齿牙香。"]},{"id":"c59-335","title":"浣溪沙·山色横侵蘸晕霞","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["山色横侵蘸晕霞。","湘川风静吐寒花。","远林屋散尚啼鸦。","梦到故园多少路，酒醒南望隔天涯。","月明千里照平沙。"]},{"id":"c59-336","title":"减字木兰花·神闲意定","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["神闲意定。","万籁收声天地静。","玉指冰弦。","未动宫商意已传。","悲风流水。","写处寥寥千古意。","归去无眠。","一夜馀音在耳边。"]},{"id":"c59-337","title":"减字木兰花·银铮旋品","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["银铮旋品。","不用缠头千尺锦。","妙思如泉。","一洗闲愁十五年。","为公少止。","起舞属公《公莫》起。","风里银山。","摆撼鱼龙我自闲。"]},{"id":"c59-338","title":"减字木兰花·柔和性气","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["柔和性气。","雅称佳名呼懿懿。","解舞能讴。","绝妙年中有品流。","眉长眼细。","淡淡梳妆新绾髻。","懊恼风情。","春著花枝百态生。"]},{"id":"c59-339","title":"减字木兰花·莺初解语","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["莺初解语。","最是一年春好处。","微雨如酥。","草色遥看近却无。","休辞醉倒。","花不看开人易老。","莫待春回。","颠倒红英间绿苔。"]},{"id":"c59-340","title":"减字木兰花·江南游女","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["江南游女。","问我何年归得去。","雨细风微。","雨足如霜挽纻衣。","江亭夜语。","喜见京华新样舞。","莲步轻飞。","迁客今朝始是归。"]},{"id":"c59-341","title":"减字木兰花·娇多媚","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["娇多媚。","体柳轻盈千万态。","殢主尤宾。","敛黛含嚬喜又嗔。","徐君乐饮。","笑谑从伊情意恁。","脸嫩敷红。","花倚朱阑裹住风。"]},{"id":"c59-342","title":"减字木兰花·双鬟绿坠","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["双鬟绿坠。","娇眼横波眉黛翠。","妙舞蹁跹。","掌上身轻意态妍。","曲穷力困。","笑倚人旁香喘喷。","老大逢欢。","昏眼犹能仔细看。"]},{"id":"c59-343","title":"减字木兰花·天真雅丽","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["天真雅丽。","容态温柔心性慧。","响亮歌喉。","遏住行云翠不收。","妙词佳曲。","啭出新声能断续。","重客多情。","满劝金卮玉手擎。"]},{"id":"c59-344","title":"南歌子·见说东园好","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["见说东园好，能消北客愁。","虽非吾土且登楼。","行尽江南南岸、此淹留。","短日明枫缬，清霜暗菊逑。","流年回首付东流。","凭仗挽回潘鬓、莫教秋。"]},{"id":"c59-345","title":"如梦令·城上层楼叠巘","rhythmic":"如梦令","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["城上层楼叠巘。","城下清淮古汴。","举手揖吴云，人与暮天俱远。","魂断。","魂断。","后夜松江月满。"]},{"id":"c59-346","title":"瑞鹧鸪·城头月落尚啼乌","rhythmic":"瑞鹧鸪","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["城头月落尚啼乌。","朱舰红船早满湖。","鼓吹未容迎五马，水云先已漾双凫。","映山黄帽螭头舫，夹岸青烟鹊尾炉。","老病逢春只思睡，独求僧榻寄须臾。"]},{"id":"c59-347","title":"临江仙·谁道东阳都瘦损","rhythmic":"临江仙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["谁道东阳都瘦损，凝然点漆精神。","瑶林终自隔风尘，试看披鹤氅，仍是谪仙人。","省可清言挥玉麈，真须保器全真。","风流何似道家纯。","不应同蜀客，惟爱卓文君。"]},{"id":"c59-348","title":"少年游·玉肌铅粉傲秋霜","rhythmic":"少年游","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["玉肌铅粉傲秋霜。","准拟凤呼凰。","伶伦不见，清香未吐，且糠秕吹扬。","到处成双君独只，空无数、烂文章。","一点香檀，谁能借箸，无复似张良。"]},{"id":"c59-349","title":"一斛珠·洛城春晚","rhythmic":"一斛珠","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["洛城春晚。","垂杨乱掩红楼半。","小池轻浪纹如篆。","烛下花前，曾醉离歌宴。","自惜风流云雨散。","关山有限情无限。","待君重见寻芳伴。","为说相思、目断西楼燕。"]},{"id":"c59-350","title":"点绛唇·闲倚胡床","rhythmic":"点绛唇","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["闲倚胡床，庾公楼外峰千朵。","与谁同坐。","明月清风我。","别乘一来，有唱应须和。","还知麽。","自从添个。","风月平分破。"]},{"id":"c59-351","title":"点绛唇·红杏飘香","rhythmic":"点绛唇","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["红杏飘香，柳含烟翠拖轻缕。","水边朱户。","尽卷黄昏雨。","烛影摇风，一枕伤春绪。","归不去。","凤楼何处。","芳草迷归路。"]},{"id":"c59-352","title":"虞美人·持杯遥劝天边月","rhythmic":"虞美人","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["持杯遥劝天边月。","愿月圆无缺。","持杯复更劝花枝。","且愿花枝长在、莫离披。","持杯月下花前醉。","休问荣枯事。","此欢能有几人知。","对酒逢花不饮、待何时。"]},{"id":"c59-353","title":"天仙子·走马探花花发未","rhythmic":"天仙子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["走马探花花发未。","人与化工俱不易。","千回来绕百回看，蜂作婢。","莺为使。","谷雨清明空屈指。","白发卢郎情未已。","一夜翦刀收玉蕊。","尊前还对断肠红，人有泪。","花无意。","明日酒醒应满地。"]},{"id":"c59-354","title":"满庭芳·归去来兮","rhythmic":"满庭芳","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["归去来兮，清溪无底，上有千仞嵯峨。","画楼东畔，天远夕阳多。","老去君恩未报，空回首、弹铗悲歌。","船头转，长风万里，归马驻平坡。","无何。","何处有，银潢尽处，天女停梭。","问何事人间，久戏风波。","顾谓同来稚子，应烂汝、腰下长柯。","青衫破，群仙笑我，千缕挂烟蓑。"]},{"id":"c59-355","title":"南乡子·千骑试春游","rhythmic":"南乡子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["千骑试春游。","小雨如酥落便收。","能使江东归老客，迟留。","白酒无声滑泻油。","飞火乱星逑。","浅黛横波翠欲流。","不似白云乡外冷，温柔。","此去淮南第一州。"]},{"id":"c59-356","title":"浣溪沙·缥缈红妆照浅溪","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["缥缈红妆照浅溪。","薄云疏雨不成泥。","送君何处古台西。","废沼夜来秋水满，茂林深处晚莺啼。","行人肠断草凄迷。"]},{"id":"c59-357","title":"浣溪沙·阳羡姑苏已买田","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["阳羡姑苏已买田。","相逢谁信是前缘。","莫教便唱水如天。","我作洞霄君作守，白头相对故依然。","西湖知有几同年。"]},{"id":"c59-358","title":"减字木兰花·空床响琢","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["空床响琢。","花上春禽冰上雹。","醉梦尊前。","惊起湖风入坐寒。","转关镬索。","春水流弦霜入拨。","月堕更阑。","更请宫高奏独弹。"]},{"id":"c59-359","title":"减字木兰花·回风落景","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["回风落景。","散乱东墙疏竹影。","满坐清微。","入袖寒泉不湿衣。","梦回酒醒。","百尺飞澜鸣碧井。","雪洒冰麾。","散落佳人白玉肌。"]},{"id":"c59-360","title":"减字木兰花·海南奇宝","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["海南奇宝。","铸出团团如栲栳。","曾到昆仑。","乞得山头玉女盆。","绛州王老。","百岁痴顽推不倒。","海口如门。","一派黄流已电奔。"]},{"id":"c59-361","title":"行香子·北望平川","rhythmic":"行香子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["北望平川。","野水荒湾。","共寻春、飞步孱颜。","和风弄袖，香雾萦鬟。","正酒酣时，人语笑，白云间。","飞鸿落照，相将归去，澹娟娟、玉宇清闲。","何人无事，宴坐空山。","望长桥上，灯火乱，使君还。"]},{"id":"c59-362","title":"画堂春·柳花飞处麦摇波","rhythmic":"画堂春","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["柳花飞处麦摇波。","晚湖净鉴新磨。","小舟飞棹去如梭。","齐唱采菱歌。","平野水云溶漾，小楼风日晴和。","济南何在暮云多。","归去奈愁何。"]},{"id":"c59-363","title":"浣溪沙·花满银塘水漫流","rhythmic":"浣溪沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["花满银塘水漫流。","犀槌玉板奏《凉州》。","顺风环佩过秦楼。","远汉碧云轻漠漠，今宵人在鹊桥头。","一声敲彻绛河秋。"]},{"id":"c59-364","title":"好事近·烟外倚危楼","rhythmic":"好事近","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["烟外倚危楼，初见远灯明灭。","却跨玉虹归去，看洞天星月。","当时张范风流在，况一尊浮雪。","莫问世间何事，与剑头微吷。"]},{"id":"c59-365","title":"占春芳·红杏了","rhythmic":"占春芳","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["红杏了，夭桃尽，独自占春芳。","不比人间兰麝，自然透骨生香。","对酒莫相忘。","似佳人、兼合明光。","只忧长笛吹花落，除是宁王。"]},{"id":"c59-366","title":"南歌子·云鬓裁新绿","rhythmic":"南歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["云鬓裁新绿，霞衣曳晓红。","待歌凝立翠筵中。","一朵彩云何事、下巫峰。","趁拍鸾飞镜，回身燕漾空。","莫翻红袖过帘栊。","怕被杨花句引、嫁东风。"]},{"id":"c59-367","title":"浪淘沙·昨日出东城","rhythmic":"浪淘沙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["昨日出东城。","拭探春情。","墙头红杏暗如倾。","槛内群芳芽未吐，早已回春。","绮陌敛香尘。","雪霁前村。","东君用意不辞辛。","料想春光先到处，吹绽梅英。"]},{"id":"c59-368","title":"木兰花令·元宵似是欢游好","rhythmic":"木兰花令","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["元宵似是欢游好。","何况公庭民讼少。","万家游赏上春台，十里神仙迷海岛。","平原不似高阳傲。","促席雍容陪语笑。","坐中有客醉多情，不惜玉山拼醉倒。"]},{"id":"c59-369","title":"木兰花令·经旬未识东君信","rhythmic":"木兰花令","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["经旬未识东君信。","一夕薰风来解愠。","红绡衣薄麦秋寒，绿绮韵低梅雨润。","瓜头绿染山光嫩。","弄色金桃新傅粉。","日高慵卷水晶帘，犹带春醪红玉困。"]},{"id":"c59-370","title":"木兰花令·高平四面开雄垒","rhythmic":"木兰花令","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["高平四面开雄垒。","三月风光初觉媚。","园中桃李使君家，城上亭台游客醉。","歌翻《杨柳》金尊沸。","饮散凭阑无限意。","云深不见玉关遥，草细山重残照里。"]},{"id":"c59-371","title":"虞美人·冰肌自是生来瘦","rhythmic":"虞美人","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["冰肌自是生来瘦。","那更分飞后。","日长帘暮望黄昏。","及至黄昏时候、转销魂。","君还知道相思苦。","怎忍抛奴去。","不辞迢递过关山。","只恐别郎容易、见郎难。"]},{"id":"c59-372","title":"虞美人·深深庭院清明过","rhythmic":"虞美人","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["深深庭院清明过。","桃李初红破。","柳丝搭在玉阑干。","帘外潇潇微雨、做轻寒。","晚晴台榭增明媚。","已拼花前醉。","更阑人静月侵廊。","独自行来行去、好思量。"]},{"id":"c59-373","title":"临江仙·昨夜渡江何处宿","rhythmic":"临江仙","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["昨夜渡江何处宿，望中疑是秦淮。","月明谁起笛中哀。","多情王谢女，相逐过江来。","云雨未成还又散，思量好事难谐。","凭陵急桨两相催。","想伊归去后，应似我情怀。"]},{"id":"c59-374","title":"蝶恋花·春事阑珊芳草歇","rhythmic":"蝶恋花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["春事阑珊芳草歇。","客里风光，又过清明节。","小院黄昏人忆别。","落红处处闻啼鴂。","咫尺江山分楚越。","目断魂销，应是音尘绝。","梦破五更心欲折。","角声吹落梅花月。"]},{"id":"c59-375","title":"蝶恋花·记得画屏初会遇","rhythmic":"蝶恋花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["记得画屏初会遇。","好梦惊回，望断高唐路。","燕子双飞来又去。","纱窗几度春光暮。","那日绣帘相见处。","低眼佯行，笑整香云缕。","敛尽春山羞不语。","人前深意难轻诉。"]},{"id":"c59-376","title":"蝶恋花·昨夜秋风来万里","rhythmic":"蝶恋花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["昨夜秋风来万里。","月上屏帏，冷透人衣袂。","有客抱衾愁不寐。","那堪玉漏长如岁。","羁舍留连归计未。","梦断魂销，一枕相思泪。","衣带渐宽无别意。","新书报我添憔悴。"]},{"id":"c59-377","title":"蝶恋花·雨霰疏疏经泼火","rhythmic":"蝶恋花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["雨霰疏疏经泼火。","巷陌秋千。","犹未清明过。","杏子梢头香蕾破。","淡红褪白胭脂涴。","苦被多情相折挫。","病绪厌厌，浑似年时个。","绕遍回廊还独坐。","月笼云暗重门锁。"]},{"id":"c59-378","title":"蝶恋花·蝶懒莺慵春过半","rhythmic":"蝶恋花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["蝶懒莺慵春过半。","花落狂风，小院残红满。","午醉未醒红日晚。","黄昏帘暮无人卷。","云鬓蓬松眉黛浅。","总是愁媒，欲诉谁消遣。","未信此情难系绊。","杨花犹有东风管。"]},{"id":"c59-379","title":"渔家傲·临水纵横回晚鞚","rhythmic":"渔家傲","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["临水纵横回晚鞚。","归来转觉情怀动。","梅笛烟中闻几弄。","秋阴重。","西山雪淡云凝冻。","美酒一杯谁与共。","尊前舞雪狂歌送。","腰跨金鱼旌旆拥。","将何用。","只堪妆点浮生梦。"]},{"id":"c59-380","title":"江城子·腻红匀脸衬檀唇","rhythmic":"江城子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["腻红匀脸衬檀唇。","晚妆新。","暗伤春。","手拈花枝，谁会两眉颦。","连理带头双□□，留待与、个中人。","淡烟笼月绣帘阴。","画堂深。","夜沈沈。","谁道□□，□系得人心。","一自绿窗偷见后，便憔悴、到如今。"]},{"id":"c59-381","title":"祝英台近·挂轻帆","rhythmic":"祝英台近","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["挂轻帆，飞急桨，还过钓台路。","酒病无聊，敧枕听鸣橹。","断肠簇簇云山，重重烟树，回首望、孤城何处。","闲离阻。","谁念萦损襄王，何曾梦云雨。","旧恨前欢，心事两无据。","要知欲见无由，痴心犹自，倩人道、一声传语。"]},{"id":"c59-382","title":"雨中花慢·邃院重帘何处","rhythmic":"雨中花慢","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["邃院重帘何处，惹得多情，愁对风光。","睡起酒阑花谢，蝶乱蜂忙。","今夜何人，吹笙北岭，待月西厢。","空怅望处，一株红杏，斜倚低墙。","羞颜易变，傍人先觉，到处被著猜防。","谁信道，些儿恩爱，无限凄凉。","好事若无间阻，幽欢却是寻常。","一般滋味，就中香美，除是偷尝。"]},{"id":"c59-383","title":"雨中花慢·嫩脸羞蛾","rhythmic":"雨中花慢","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["嫩脸羞蛾，因甚化作行云，却返巫阳。","但有寒灯孤枕，皓月空床。","长记当初，乍谐云雨，便学鸾凰。","又岂料、正好三春桃李，一夜风霜。","丹青□画，无言无笑，看了漫结愁肠。","襟袖上，犹存残黛，渐减馀香。","一自醉中忘了，奈何酒后思量。","算应付你，枕前珠泪，万点千行。"]},{"id":"c59-384","title":"念奴娇·凭高眺远","rhythmic":"念奴娇","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["凭高眺远，见长空万里，云无留迹。","桂魄飞来光射处，冷浸一天秋碧。","玉宇琼楼，乘鸾来去，人在清凉国。","江山如画，望中烟树历历。","我醉拍手狂歌，举杯邀月，对影成三客。","起舞徘徊风露下，今夕不知何夕。","便欲乘风，翻然归去，何用骑鹏翼。","水晶宫里，一声吹断横笛。"]},{"id":"c59-385","title":"水龙吟·小沟东接长江","rhythmic":"水龙吟","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["小沟东接长江，柳堤苇岸连云际。","烟村潇洒，人闲一哄，渔樵早市。","永昼端居，寸阴虚度，了成何事。","但丝莼玉藕，珠粳锦鲤，相留恋，又经岁。","因念浮丘旧侣，惯瑶池、羽觞沈醉。","青鸾歌舞，铢衣摇曳，壶中天地。","飘堕人间，步虚声断，寒露风细。","抱素琴，独向银蟾影里，此怀难寄。"]},{"id":"c59-386","title":"水龙吟·露寒烟冷蒹葭老","rhythmic":"水龙吟","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["露寒烟冷蒹葭老，天外征鸿寥唳。","银河秋晚，长门灯悄，一声初至。","应念潇湘，岸遥人静，水多菰米。","□望极平田，徘徊欲下，依前被、风惊起。","须信衡阳万里。","有谁家、锦书遥寄。","万重云外，斜行横阵，才疏又缀。","仙掌月明，石头城下，影摇寒水。","念征衣未捣，佳人拂杵，有盈盈泪。"]},{"id":"c59-387","title":"渔父・渔歌子·渔父饮","rhythmic":"渔父・渔歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["渔父饮，谁家去。","鱼蟹一时分付。","酒无多少醉为期，彼此不论钱数。"]},{"id":"c59-388","title":"渔父・渔歌子·渔父醉","rhythmic":"渔父・渔歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["渔父醉，蓑衣舞。","醉里却寻归路。","轻舟短棹任斜横，醒后不知何处。"]},{"id":"c59-389","title":"渔父・渔歌子·渔父醒","rhythmic":"渔父・渔歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["渔父醒，春江午。","梦断落花飞絮。","酒醒还醉醉还醒，一笑人间今古。"]},{"id":"c59-390","title":"渔父・渔歌子·渔父笑","rhythmic":"渔父・渔歌子","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["渔父笑，轻鸥举。","漠漠一江风雨。","江边骑马是官人，借我孤舟南渡。"]},{"id":"c59-391","title":"醉翁操·琅然","rhythmic":"醉翁操","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["琅然。","清圜。","谁弹。","响空山。","无言。","惟翁醉中知其天。","月明风露娟娟。","人未眠。","荷蒉过山前。","曰有心也哉此贤。","醉翁啸咏，声和流泉。","醉翁去后，空有朝吟夜怨。","山有时而童巅。","水有时而回川。","思翁无岁年。","翁今为飞仙。","此意在人间。","拭听徽外三两弦。"]},{"id":"c59-392","title":"导引·帝城父老","rhythmic":"导引","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["帝城父老，三岁望尧心。","天远玉楼深。","龙颜仿佛笙箫远，肠断属车音。","离宫春色琐瑶林。","云阙海沈沈。","遗民犹唱当时曲，秋雁起汾阴。"]},{"id":"c59-393","title":"导引·经文纬武","rhythmic":"导引","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["经文纬武，十有九年中。","遗烈震羌戎。","渭桥夹道千君长，犹是建元功。","西瞻温洛与神崧。","莲宇照琼宫。","人间俯仰成今古，流泽自无穷。"]},{"id":"c59-394","title":"瑶池燕·飞花成阵","rhythmic":"瑶池燕","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["飞花成阵。","春心困。","寸寸。","别肠多少愁闷。","无人问。","偷啼自搵。","残妆粉。","抱瑶琴、寻出新韵。","玉纤趁。","南风来解幽愠。","低云鬟、眉峰敛晕。","娇和恨。"]},{"id":"c59-395","title":"千秋岁·岛边天外","rhythmic":"千秋岁","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["岛边天外。","未老身先退。","珠泪溅，丹衷碎。","声摇苍玉佩。","色重黄金带。","一万里。","斜阳正与长安对。","道远谁云会。","罪大天能盖。","君命重，臣节在。","新恩犹可觊。","旧学终难改。","吾已矣。","乘桴且恁浮於海。"]},{"id":"c59-396","title":"减字木兰花·凭谁妙笔","rhythmic":"减字木兰花","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["凭谁妙笔。","横扫素缣三百尺。","天下应无。","此是钱塘湖上图。","一般奇绝。","云淡天高秋夜月。","费尽丹青。","只这些儿画不成。"]},{"id":"c59-397","title":"失调名·高安更过几重山","rhythmic":"失调名","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["高安更过几重山。"]},{"id":"c59-398","title":"失调名·过湖携手屡沾襟","rhythmic":"失调名","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["过湖携手屡沾襟。"]},{"id":"c59-399","title":"失调名·谁教幽梦里","rhythmic":"失调名","author":"苏轼","authorSlug":"苏轼","dynasty":"宋","kind":"ci","paragraphs":["谁教幽梦里，插他花。"]}]