，封琅琊郡公。","大和初，检校尚书左仆射，卒于官。（《新唐书》卷一百九十一有传附于《王同皎传》。）诗一首。","（《全唐诗》无王潜诗。）（本诗作者王潜建中二年已官「节度都巡使太常卿上柱国」，其子王同皎孙王潜，恐非一人。）"],"works":[{"id":"t50-638","title":"题云居上寺","kind":"诗"}]},"程和仲":{"slug":"程和仲","name":"程和仲","dynasty":"宋","style":"","life":"","origin":"","seal":"程","bio":[],"works":[{"id":"c76-432","title":"沁园春·呼伯雅来","kind":"词"}]},"葛胜仲":{"slug":"葛胜仲","name":"葛胜仲","dynasty":"宋","style":"","life":"","origin":"","seal":"葛","bio":[],"works":[{"id":"c59-610","title":"蓦山溪·出门西笑","kind":"词"},{"id":"c59-611","title":"西江月·艳曲醉歌金缕","kind":"词"},{"id":"c59-612","title":"西江月·靺鞨斜红带柳","kind":"词"},{"id":"c59-613","title":"西江月·清樾已生昼寂","kind":"词"},{"id":"c59-614","title":"西江月·瑞兽香云轻袅","kind":"词"},{"id":"c59-615","title":"浣溪沙·楼子包金照眼新","kind":"词"},{"id":"c59-616","title":"虞美人·三年曾不窥园树","kind":"词"},{"id":"c59-617","title":"虞美人·一轮丹桂窅窊树","kind":"词"},{"id":"c59-618","title":"瑞鹧鸪·火云欲避金风至","kind":"词"},{"id":"c59-619","title":"鹊桥仙·鹊桥仙偶","kind":"词"},{"id":"c59-620","title":"江城子·浮家重过水晶宫","kind":"词"},{"id":"c59-621","title":"江城子·飞身疑到广寒宫","kind":"词"},{"id":"c59-622","title":"蝶恋花·安石榴花浓绿映","kind":"词"},{"id":"c59-623","title":"南乡子·晴日乱云收","kind":"词"},{"id":"c59-624","title":"南乡子·拂槛晓云鲜","kind":"词"},{"id":"c59-625","title":"减字木兰花·葛山仙隐","kind":"词"},{"id":"c59-626","title":"临江仙·倦客身同舟不系","kind":"词"},{"id":"c59-627","title":"临江仙·宝观岧嶢飞雉堞","kind":"词"},{"id":"c59-628","title":"减字木兰花·辛勤场屋","kind":"词"},{"id":"c59-629","title":"减字木兰花·杏花零乱","kind":"词"},{"id":"c59-630","title":"虞美人·严陵滩畔香醪好","kind":"词"},{"id":"c59-631","title":"鹧鸪天·玉琯还飞换岁灰","kind":"词"},{"id":"c59-632","title":"西江月·万卷旧推鸿博","kind":"词"},{"id":"c59-633","title":"浪淘沙·我爱菊花枝","kind":"词"},{"id":"c59-634","title":"鹧鸪天·黄菊鲜鲜带露浓","kind":"词"},{"id":"c59-635","title":"鹧鸪天·采采黄花鹄彩浓","kind":"词"},{"id":"c59-636","title":"木兰花・玉楼春·谈围曾蔽青绫帐","kind":"词"},{"id":"c59-637","title":"醉花阴·东皇已有来归耗","kind":"词"},{"id":"c59-638","title":"浣溪沙·东阁郎官巧写真","kind":"词"},{"id":"c59-639","title":"浣溪沙·盘里明珠芡实香","kind":"词"},{"id":"c59-640","title":"临江仙·二月风光浓似酒","kind":"词"},{"id":"c59-641","title":"临江仙·雪