":["易重，字鼎臣，宜春人。会昌五年进士第，官至大理评事。诗一首。"],"works":[{"id":"t30-928","title":"寄宜阳兄弟","kind":"诗"}]},"杨德辉":{"slug":"杨德辉","name":"杨德辉","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":["德辉，道门威仪，住玉局观。"],"works":[{"id":"t51-744","title":"征青州长老嘲僧门 一","kind":"诗"},{"id":"t51-745","title":"征青州长老嘲僧门 二","kind":"诗"},{"id":"t51-746","title":"嘲僧门祝辟支佛牙","kind":"诗"}]},"武三思":{"slug":"武三思","name":"武三思","dynasty":"唐","style":"","life":"","origin":"","seal":"武","bio":["武三思，则天兄子，累官右衞将军。则天临朝，擢夏官尚书。及革命，封梁王，寻拜天官尚书。","圣历初，检校内史，进太子宾客。长安中，其子崇训尚安乐公主，时三思用事于朝，欲宠异其礼，乃自重光门内行迎亲礼，归于天津桥南私第，又令宰臣李峤、苏味道、词人沈佺期、宋之问等赋花烛行以美之。中宗复位，拜司空，同中书门下三品，猜嫉正士，干黩时政，为节愍太子所诛。","诗八首。"],"works":[{"id":"t4-289","title":"奉和圣制夏日游石淙山","kind":"诗"},{"id":"t4-290","title":"仙鹤篇","kind":"诗"},{"id":"t4-291","title":"宴龙泓","kind":"诗"},{"id":"t4-292","title":"凝碧池侍宴应制得出水槎","kind":"诗"},{"id":"t4-293","title":"奉和宴小山池赋得溪字应制","kind":"诗"},{"id":"t4-294","title":"奉和过梁王宅即目应制","kind":"诗"},{"id":"t4-295","title":"奉和春日游龙门应制","kind":"诗"},{"id":"t4-296","title":"秋日于天中寺寻复礼上人","kind":"诗"},{"id":"t4-297","title":"句","kind":"诗"},{"id":"t52-508","title":"五言和波仑师登佛授记阁一首","kind":"诗"}]},"董初":{"slug":"董初","name":"董初","dynasty":"唐","style":"","life":"","origin":"","seal":"董","bio":[],"works":[{"id":"t42-973","title":"昭君怨","kind":"诗"}]},"黄岩叟":{"slug":"黄岩叟","name":"黄岩叟","dynasty":"宋","style":"","life":"","origin":"","seal":"黄","bio":[],"works":[{"id":"c68-260","title":"望海潮·梅天雨歇","kind":"词"}]}}