{"姚崇":{"slug":"姚崇","name":"姚崇","dynasty":"唐","style":"号称名相","life":"","origin":"","seal":"姚","bio":["姚崇，初名元崇，又名元之，陕州人。贞观中，应下笔成章举，授濮州司仓，五迁夏官郎中。时契丹扰河北，军机填委，元崇剖析若流，则天奇之，超迁夏官侍郎，寻同凤阁鸾台平章事。","中宗朝，出为刺史。睿宗立，拜兵部尚书，同中书门下，进中书令，后复贬刺史。先天中，还为尚书，知政事，迁紫微令。","开元中，与卢怀慎、源乾曜同居宰执。崇独当重任，明于庶务，断割不滞，号称名相。寻荐宋璟自代，以开府仪同三司罢政，仍五日一参，入阁供奉。","集十卷，今存诗六首。"],"works":[{"id":"t0-590","title":"郊庙歌辞 享龙池乐章 第一章","kind":"诗"},{"id":"t3-825","title":"奉和圣制夏日游石淙山","kind":"诗"},{"id":"t3-826","title":"故洛阳城侍宴应制","kind":"诗"},{"id":"t3-827","title":"春日洛阳城侍宴","kind":"诗"},{"id":"t3-828","title":"秋夜望月","kind":"诗"},{"id":"t3-829","title":"夜渡江","kind":"诗"},{"id":"t3-830","title":"奉和圣制龙池篇","kind":"诗"},{"id":"t3-831","title":"句","kind":"诗"},{"id":"t52-627","title":"五言过栖岩寺","kind":"诗"},{"id":"t52-628","title":"奉使蒲州返辔奉答圣制（题拟）","kind":"诗"}]},"张垍":{"slug":"张垍","name":"张垍","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张垍，说次子。尚宁亲公主，拜驸马都尉。许于禁中置内宅，侍为文章，坐事，出为卢溪司马，入为太常卿。","禄山乱，受伪相命，死贼中。诗一首。"],"works":[{"id":"t4-861","title":"奉和岳州山城","kind":"诗"},{"id":"t52-883","title":"同房侍御竹园新亭与邢大判官同游","kind":"诗"}]},"景导":{"slug":"景导","name":"景导","dynasty":"唐","style":"","life":"","origin":"","seal":"景","bio":["景导，大中间长安左街保寿寺僧。诗一首。（《全唐诗》无景导诗）"],"works":[{"id":"t53-944","title":"无题","kind":"诗"},{"id":"t53-945","title":"赠沙州僧悟真上人兼送归","kind":"诗"}]},"朱松":{"slug":"朱松","name":"朱松","dynasty":"宋","style":"","life":"","origin":"","seal":"朱","bio":[],"works":[{"id":"c65-250","title":"蝶恋花·清晓方塘开一镜","kind":"词"}]},"朱湾":{"slug":"朱湾","name":"朱湾","dynasty":"唐","style":"字巨川 · 号沧洲子","life":"","origin":"","seal":"朱","bio":["朱湾，字巨川，西蜀人，自号沧洲子。贞元元和间，为李勉永平从事。诗一卷。"],"works":[{"id":"t16-585","title":"九日登青山","kind":"诗"},{"id":"t16-586","title":"秋夜宴王郎中宅赋得露中菊","kind":"诗"},{"id":"t16-587","title":"奉使设宴戏掷笼筹","kind":"诗"},{"id":"t16-588","title":"咏双陆骰子","kind":"诗"},{"id":"t16-589","title":"咏壁上酒瓢呈萧明府","kind":"诗"},{"id":"t16-590","title":"咏玉","kind":"诗"},{"id":"t16-591","title":"送陈偃赋得白鸟翔翠微","kind":"诗"},{"id":"t16-592","title":"题段上人院壁画古松","kind":"诗"},{"id":"t16-593","title":"逼寒节寄崔七","kind":"诗"},{"id":"t16-594","title":"长安喜雪","kind":"诗"},{"id":"t16-595","title":"宴杨驸马山亭","kind":"诗"},{"id":"t16-596","title":"过宣上人湖上兰若","kind":"诗"},{"id":"t16-597","title":"同达奚宰游窦子明仙坛","kind":"诗"},{"id":"t16-598","title":"平陵寓居再逢寒食","kind":"诗"},{"id":"t16-599","title":"寻隐者韦九山人于东溪草堂","kind":"诗"},{"id":"t16-600","title":"假摄池州留别东溪隐居","kind":"诗"},{"id":"t16-601","title":"咏柏板","kind":"诗"},{"id":"t16-602","title":"筝柱子","kind":"诗"},{"id":"t16-603","title":"送李司直归浙东幕兼寄鲍行军持节大夫初拜东平郡王","kind":"诗"},{"id":"t16-604","title":"七贤庙","kind":"诗"},{"id":"t16-605","title":"同清江师月夜听坚正二上人为怀州转法华经歌","kind":"诗"},{"id":"t16-606","title":"寒城晚角","kind":"诗"},{"id":"t16-607","title":"重阳日陪韦卿䜩","kind":"诗"},{"id":"t53-19","title":"赠饶州韦之晋别驾","kind":"诗"},{"id":"t53-20","title":"韦使君席咏拗笼筹得兹字","kind":"诗"}]},"沈佺期":{"slug":"沈佺期","name":"沈佺期","dynasty":"唐","style":"字云卿 · 号为沈宋","life":"","origin":"历中书舍","seal":"沈","bio":["沈佺期，字云卿，相州内黄人。善属文，尤长七言之作，擢进士第。长安中，累迁通事舍人，预修《三教珠英》，转考功郎给事中，坐交张易之，流驩州，稍迁台州录事参军。","神龙中，召见，拜起居郎，修文馆直学士。历中书舍人，太子少詹事，开元初卒。建安后，讫江左，诗律屡变，至沈约、庾信，以音韵相婉附，属对精密。","及佺期与宋之问，尤加靡丽，回忌声病，约句准篇，如锦绣成文，学者宗之，号为沈宋。语曰，苏李居前，沈宋比肩。集十卷，今编诗三卷。","沈佺期，字云卿，相州内黄人，善属文，尤长七言之作，擢进士第，长安中，累迁通事舍人，预修三教珠英，转考功郎给事中，坐交张易之，流驩州，稍迁台州录事参军。神龙中，召见，拜起居郎，修文馆直学士，历中书舍人，太子少詹事，开元初卒，建安后，讫江左，诗律屡变，至沈约、庾信，以音韵相婉附，属对精密，及佺期与宋之问，尤加靡丽，回忌声病，约句准篇，如锦绣成文，学者宗之，号为沈宋。语曰，苏李居前，沈宋比肩。","集十卷，今编诗三卷。"],"works":[{"id":"t0-592","title":"郊庙歌辞 享龙池乐章 第三章","kind":"诗"},{"id":"t0-862","title":"鼓吹曲辞 巫山高二首 一","kind":"诗"},{"id":"t0-863","title":"鼓吹曲辞 巫山高二首 二","kind":"诗"},{"id":"t0-878","title":"鼓吹曲辞 芳树","kind":"诗"},{"id":"t0-884","title":"鼓吹曲辞 有所思","kind":"诗"},{"id":"t0-895","title":"鼓吹曲辞 钓竿篇","kind":"诗"},{"id":"t0-931","title":"横吹曲辞 出塞","kind":"诗"},{"id":"t0-969","title":"横吹曲辞 折杨柳","kind":"诗"},{"id":"t0-986","title":"横吹曲辞 关山月","kind":"诗"},{"id":"t1-9","title":"横吹曲辞 长安道","kind":"诗"},{"id":"t1-11","title":"横吹曲辞 梅花落","kind":"诗"},{"id":"t1-83","title":"相和歌辞 王昭君","kind":"诗"},{"id":"t1-139","title":"相和歌辞 铜雀妓","kind":"诗"},{"id":"t1-301","title":"相和歌辞 长门怨","kind":"诗"},{"id":"t