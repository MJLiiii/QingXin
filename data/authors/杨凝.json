{"slug":"杨凝","name":"杨凝","dynasty":"唐","style":"字懋功","life":"","origin":"","seal":"杨","bio":["杨凝，字懋功。由协律郎三迁侍御史，为司封员外郎，徙吏部。稍迁右司郎中，终兵部郎中。","集二十卷，今存一卷。"],"works":[{"id":"t15-576","title":"送别","kind":"诗"},{"id":"t15-577","title":"送客东归","kind":"诗"},{"id":"t15-578","title":"送客归湖南","kind":"诗"},{"id":"t15-579","title":"送客归淮南","kind":"诗"},{"id":"t15-580","title":"春情","kind":"诗"},{"id":"t15-581","title":"秋夜听捣衣","kind":"诗"},{"id":"t15-582","title":"从军行","kind":"诗"},{"id":"t15-583","title":"和直禁省","kind":"诗"},{"id":"t15-584","title":"留别","kind":"诗"},{"id":"t15-585","title":"送客往洞庭","kind":"诗"},{"id":"t15-586","title":"别友人","kind":"诗"},{"id":"t15-587","title":"初渡淮北岸","kind":"诗"},{"id":"t15-588","title":"咏雨","kind":"诗"},{"id":"t15-589","title":"柳絮","kind":"诗"},{"id":"t15-590","title":"花枕","kind":"诗"},{"id":"t15-591","title":"送客往鄜州","kind":"诗"},{"id":"t15-592","title":"送客往夏州","kind":"诗"},{"id":"t15-593","title":"春霁晚望","kind":"诗"},{"id":"t15-594","title":"唐昌观玉蘂花","kind":"诗"},{"id":"t15-595","title":"别李协","kind":"诗"},{"id":"t15-596","title":"初次巴陵","kind":"诗"},{"id":"t15-597","title":"上巳","kind":"诗"},{"id":"t15-598","title":"春怨","kind":"诗"},{"id":"t15-599","title":"送客归常州","kind":"诗"},{"id":"t15-600","title":"送别","kind":"诗"},{"id":"t15-601","title":"送客入蜀","kind":"诗"},{"id":"t15-602","title":"送别","kind":"诗"},{"id":"t15-603","title":"残花","kind":"诗"},{"id":"t15-604","title":"戏赠友人","kind":"诗"},{"id":"t15-605","title":"赠同游","kind":"诗"},{"id":"t15-606","title":"送人出塞","kind":"诗"},{"id":"t15-607","title":"寻僧元皎因病","kind":"诗"},{"id":"t15-608","title":"夜泊渭津","kind":"诗"},{"id":"t15-609","title":"晚夏逢友人","kind":"诗"},{"id":"t15-610","title":"别谪者","kind":"诗"},{"id":"t15-611","title":"行思","kind":"诗"},{"id":"t15-612","title":"感怀题从舅宅","kind":"诗"},{"id":"t15-613","title":"与友人会","kind":"诗"},{"id":"t15-614","title":"下第后蒙侍郎示意指于新先辈宣恩感谢","kind":"诗"}]}