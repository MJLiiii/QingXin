[{"id":"c74-900","title":"点绛唇·燕子池塘","rhythmic":"点绛唇","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["燕子池塘，乱红过尽秋千晚。","絮飞欲倦。","正是帘初卷。","睡起无情，犹道天涯远。","羞匀面。","乍惊红浅。","梦自无人见。"]},{"id":"c74-901","title":"点绛唇·韝指春寒","rhythmic":"点绛唇","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["韝指春寒，陇禽一片飞来雪。","无言可说。","暗啄相思结。","双影年深，也作关山别。","翻成拙。","落花时节。","倩子规声绝。"]},{"id":"c74-902","title":"点绛唇·虹玉横箫","rhythmic":"点绛唇","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["虹玉横箫，纤纤指按新声作。","参差重约。","昨夜梁伊错。","几许闲愁，品字都忘却。","沉吟觉。","一声哀角。","满院残花落。"]},{"id":"c74-903","title":"浣溪沙·高卧何须说打乖","rhythmic":"浣溪沙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["高卧何须说打乖。","小篱过雨翠长街。","缃桃定有踏青鞋。","晴日又思花处所，东风绝似柳情怀。","人间安得酒如淮。"]},{"id":"c74-904","title":"浣溪沙·身是去年人尚健","rhythmic":"浣溪沙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["身是去年人尚健。","心知十日事如常。","眼前杯酒是重阳。","破帽簪萸携素手，长歌藉草慰寒香。","儿童怪我老来狂。"]},{"id":"c74-905","title":"浣溪沙·春日春风掠鬓须","rhythmic":"浣溪沙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["春日春风掠鬓须。","乱山相对拥寒炉。","彩鞭金胜一时无。","自缕青丝成细柳，更堆残雪当凝酥。","儿童且莫唱皇都。"]},{"id":"c74-906","title":"浣溪沙·身是高人欲寝冰","rhythmic":"浣溪沙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["身是高人欲寝冰。","引年可待进豨苓。","无忧无患也身轻。","雪里放囚天亦喜，平安骑鹤到家庭。","今年春早为长生。"]},{"id":"c74-907","title":"浣溪沙·十日千机可复谐","rhythmic":"浣溪沙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["十日千机可复谐。","郭郎感运岂仙才。","人间自是少行媒。","直上扶摇须九万，满前星斗共昭回。","又传贾客向曾来。"]},{"id":"c74-908","title":"浣溪沙·暮暮相望夕甫谐","rhythmic":"浣溪沙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["暮暮相望夕甫谐。","针楼巧巧似身材。","下头无数老人媒。","昨夜竹林那得见，朝来乾鹊是空回。","人间五日后能来。"]},{"id":"c74-909","title":"摊破浣溪沙・山花子·醉里微寒著面醒","rhythmic":"摊破浣溪沙・山花子","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["醉里微寒著面醒。","天风不展帽敧倾。","行过溪深松雪下，夜三更。","白白野田铺似月，瑽瑽沙路踏如冰。","不见剡溪三百曲，一舟横。"]},{"id":"c74-910","title":"摊破浣溪沙・山花子·澹澹胭脂浅著梅","rhythmic":"摊破浣溪沙・山花子","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["澹澹胭脂浅著梅。","温柔不上避风台。","若比杏桃真未识，夺银胎。","汗面试来慵传粉，酒香浓后暗潮腮。","娇嫩不应醒似醉，倩谁猜。"]},{"id":"c74-911","title":"霜天晓角·柳梢欲雪","rhythmic":"霜天晓角","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["柳梢欲雪。","十里烟明灭。","曲曲阑干转影，教人忆、夜来月。","家人相对说。","灯花还又结。","冻雨村村□鼓，终不似、上元节。"]},{"id":"c74-912","title":"霜天晓角·乌云汗漫","rhythmic":"霜天晓角","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["乌云汗漫。","浊浪翻河汉。","过尽千重魔障，堂堂地、一轮满。","秋光还又半。","檐声初漏断。","不管满身花露，已办著、二更看。"]},{"id":"c74-913","title":"霜天晓角·骑台千骑","rhythmic":"霜天晓角","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["骑台千骑。","有菊知何世。","想见登高无处，淮以北、是平地。","老来无复味。","老来无复泪。","多谢白衣迢递，吾病矣、不能醉。"]},{"id":"c74-914","title":"霜天晓角·经年寂寞","rhythmic":"霜天晓角","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["经年寂寞。","已负花前约。","忽向红梅侧畔，开点雪、有人觉。","不开何似莫。","百梢才一萼。","欲问寿阳宫额，两三蕊、怎能著。"]},{"id":"c74-915","title":"霜天晓角·臞然如竹","rhythmic":"霜天晓角","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["臞然如竹。","自是天仙福。","小小画堂锦样，听人唱、鹤飞曲。","橙橘黄又绿。","蟹到新篘熟。","便做月三十斛，饮不尽、菊潭菊。"]},{"id":"c74-916","title":"霜天晓角·朝来微雪","rhythmic":"霜天晓角","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["朝来微雪。","又近长生节。","造就一枝清绝，梅与雪、怎分别。","两年心似月。","除是天知得。","手种春风千树，一颗颗、待儿摘。"]},{"id":"c74-917","title":"霜天晓角·明年七十","rhythmic":"霜天晓角","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["明年七十。","歌彩桥仙夕。","见说严君平道，年年是、月初一。","同时同里密。","后今今又昔。","便做伏生年纪，也未到、蹇吃吃。"]},{"id":"c74-918","title":"霜天晓角·良宵七七","rhythmic":"霜天晓角","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["良宵七七。","又近中元日。","桥上老人有约，后五日、重来觅。","婵娟银海出。","木犀新雨湿。","惟有延平剑气，箕斗外、广寒逼。"]},{"id":"c74-919","title":"霜天晓角·归来把菊","rhythmic":"霜天晓角","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["归来把菊。","春瓮今朝熟。","苦苦留君不得，携孺子、到汾曲。","庐山真面目。","冰清还映玉。","长笑欧公老懒，君且住，饮螺绿。"]},{"id":"c74-920","title":"霜天晓角·问春来未","rhythmic":"霜天晓角","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["问春来未。","也似辛壬癸。","如此男儿五十，又过却、孔融二。","画堂孙子子。","新桃如故垒。","不管明朝后日，春满眼、是千岁。"]},{"id":"c74-921","title":"霜天晓角·□□□□","rhythmic":"霜天晓角","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["□□□□。","□□□□□。","□□□□□□，□□□、□□□。","治中心似佛。","治中心似日。","人祝治中千岁，似翁福、似翁德。"]},{"id":"c74-922","title":"卜算子·不是重看灯","rhythmic":"卜算子","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["不是重看灯，重见河边女。","长是蛾儿作队行，路转风吹去。","十载废元宵，满耳番腔鼓。","欲识尊前太守谁，起向尊前舞。"]},{"id":"c74-923","title":"卜算子·早已是三年","rhythmic":"卜算子","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["早已是三年，父老依依借。","顾与天公借几年，保我鸡豚社。","□□□□□，□□□□□。","□□□□□□□，□□□□□。"]},{"id":"c74-924","title":"菩萨蛮·芭蕉叶上三更雨","rhythmic":"菩萨蛮","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["芭蕉叶上三更雨。","人生只合随他去。","便不到天涯。","天涯也是家。","屏山三五叠。","处处飞胡蝶。","正是菊堪看。","东篱独自寒。"]},{"id":"c74-925","title":"菩萨蛮·黄鸡喔喔催人起","rhythmic":"菩萨蛮","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["黄鸡喔喔催人起。","困不成眠窗似水。","清露不曾寒。","朝来起自难。","家人当睡美。","又忆归程几。","不管湿阑干。","芙蓉花自看。"]},{"id":"c74-926","title":"菩萨蛮·画梁语透帘栊晓","rhythmic":"菩萨蛮","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["画梁语透帘栊晓。","坼桐风送杨花老。","细雨绿阴寒。","罗襟只似单。","青门三里道。","个个游芳草。","比似嫁来看。","踏青难更难。"]},{"id":"c74-927","title":"菩萨蛮·江波何似西湖曲","rhythmic":"菩萨蛮","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["江波何似西湖曲。","村烟相对峰南北。","何处不青青。","青青是汉茔。","长亭芳草路。","寒食谁家墓。","旧日厌残红。","人行九里松。"]},{"id":"c74-928","title":"菩萨蛮·殷勤欲送春归去","rhythmic":"菩萨蛮","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["殷勤欲送春归去。","白首题将断肠句。","春去自依依。","欲归无处归。","天涯同是寓。","握手留春住。","小住碧桃枝。","桃根不属谁。"]},{"id":"c74-929","title":"菩萨蛮·八仙名姓当时少","rhythmic":"菩萨蛮","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["八仙名姓当时少。","污尊牛饮同倾倒。","惟有我公荣。","旁人笑独醒。","多年村落走。","泥饮无升斗。","入了玉门关。","人生一醉难。"]},{"id":"c74-930","title":"好事近·□后百年闲","rhythmic":"好事近","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["□后百年闲，元度自伤来暮。","打破虚空无碍，共乘龙飞去。","更参末后句如何，此事未能付。","前遇小桥风雪，是君诗成处。"]},{"id":"c74-931","title":"谒金门·娇点点","rhythmic":"谒金门","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["娇点点。","困倚春光欲软。","滴尽守宫难可染。","浓欺红烛艳。","寂寂露珠啼脸。","翠袖不禁风飐。","芳径相逢惊笑靥。","日长初睡转。"]},{"id":"c74-932","title":"谒金门·花露湿","rhythmic":"谒金门","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["花露湿。","红泪裛成珠粒。","比似昭阳恩未得。","睡来添醉色。","一笑娇波滴滴。","再顾羞潮拂拂。","恨血千年明的皪。","千年人共忆。"]},{"id":"c74-933","title":"谒金门·游赏竞","rhythmic":"谒金门","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["游赏竞。","看取落红阵阵。","花睡不成娇似病。","春寒空受尽。","旧日不知繁盛。","欲饮如今无兴。","恨满东风无绿鬓。","东风还自恨。"]},{"id":"c74-934","title":"长相思·上元晴","rhythmic":"长相思","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["上元晴。","上元晴。","待得晴时坐触屏。","山禽三两声。","欲归城。","未归城。","见说城中处处灯。","明年处处行。"]},{"id":"c74-935","title":"忆秦娥·烧灯节","rhythmic":"忆秦娥","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["烧灯节。","朝京道上风和雪。","风和雪。","江山如旧，朝京人绝。","百年短短兴亡别。","与君犹对当时月。","当时月。","照人烛泪，照人梅发。"]},{"id":"c74-936","title":"忆秦娥·惊雷节","rhythmic":"忆秦娥","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["惊雷节。","梅花冉冉销成雪。","销成雪。","一年一度，为君肠绝。","古人长恨中年别。","馀年又过新正月。","新正月。","不堪临镜，不堪垂发。"]},{"id":"c74-937","title":"忆秦娥·梅花节","rhythmic":"忆秦娥","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["梅花节。","白头卧起餐毡雪。","餐毡雪。","上林雁断，上林书绝。","伤心最是河梁别。","无人共拜天边月。","天边月。","一尊对影，一编残发。"]},{"id":"c74-938","title":"忆秦娥·收灯节","rhythmic":"忆秦娥","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["收灯节。","霖铃又似龟山雪。","龟山雪。","今宵清绝，今宵愁绝。","老人似少终然别。","痴痴更望春三月。","春三月。","花如人面，自羞余发。"]},{"id":"c74-939","title":"忆秦娥·春如昨","rhythmic":"忆秦娥","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["春如昨。","晓风吹透胭脂阁。","胭脂阁。","满园茅草，冷烟城郭。","青衫泪尽楼头角。","佳人梦断花间约。","花间约。","黄昏细雨，一枝零落。"]},{"id":"c74-940","title":"西江月·天上低昂似旧","rhythmic":"西江月","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["天上低昂似旧，人间儿女成狂。","夜来处处试新妆。","却是人间天上。","不觉新凉似水，相思两鬓如霜。","梦从海底跨枯桑。","阅尽银河风浪。"]},{"id":"c74-941","title":"西江月·曾与回翁把手","rhythmic":"西江月","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["曾与回翁把手，自宜老子如龙。","怀胎不敢问春冬。","等待鞭鸾笞凤。","昨夜又迟黄石，今朝重叩鸿濛。","碧桃花下醉相逢。","说尽鹏游蝶梦。"]},{"id":"c74-942","title":"西江月·玉帐传心如镜","rhythmic":"西江月","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["玉帐传心如镜，青龙绕指成轮。","尘中多少白头人。","乾里寻壬难认。","世事说来都了，鬼神见也须瞋。","迷槎问我是何津。","向道先生昼困。"]},{"id":"c74-943","title":"清平乐·深红半面","rhythmic":"清平乐","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["深红半面。","一似墙头见。","草树池塘青一片。","独倚阑干几遍。","更谁绛袖朱唇。","火云相对英英。","笑杀牡丹正午，离披不任看承。"]},{"id":"c74-944","title":"清平乐·君词为寿","rhythmic":"清平乐","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["君词为寿。","绝妙孙辛妇。","但恨杯无露添酒。","空等待梅花久。","喜君白首还玄。","人间合信天缘。","如此相从至老，我亦何倦馀年。"]},{"id":"c74-945","title":"归国遥·初雨歇","rhythmic":"归国遥","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["初雨歇。","照水绿腰裙带熟。","杨花不做人情雪。","风流欲过前村蝶。","羞成别。","回头却恨春三月。"]},{"id":"c74-946","title":"昭君怨·月出东山之上","rhythmic":"昭君怨","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["月出东山之上。","长忆御街人唱。","恨我不能琴。","有琴心。","徙倚秋波平莹。","渐久玉肌清冷。","待更下阑干。","起来看。"]},{"id":"c74-947","title":"浣溪沙·远远游蜂不记家","rhythmic":"浣溪沙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["远远游蜂不记家。","数行新柳自啼鸦。","寻思旧事即天涯。","睡起有情和画卷，燕归无语傍人斜。","晚风吹落小瓶花。"]},{"id":"c74-948","title":"浣溪沙·点点疏林欲雪天","rhythmic":"浣溪沙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["点点疏林欲雪天。","竹篱斜闭自清妍。","为伊憔悴得人怜。","欲与那人携素手，粉香和泪落君前。","相逢恨恨总无言。"]},{"id":"c74-949","title":"减字木兰花·何须翦纸","rhythmic":"减字木兰花","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["何须翦纸。","依旧一团圆照水。","莫倚空寒。","柳下池边也只般。","君何忽忽。","宇宙人生都是客。","月在云端。","人自愁人不解看。"]},{"id":"c74-950","title":"减字木兰花·旧游山路","rhythmic":"减字木兰花","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["旧游山路。","落在秋阴最深处。","风雨重阳。","无蝶无花更断肠。","天知老矣。","莫累门生与儿子。","不用登高。","高处风吹帽不牢。"]},{"id":"c74-951","title":"减字木兰花·东风似客","rhythmic":"减字木兰花","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["东风似客。","醉里落花南又北。","客似东风。","携手斜阳一笑中。","佳人怨我。","不寄江南春一朵。","我怨佳人。","憔悴江南不似春。"]},{"id":"c74-952","title":"减字木兰花·腊销三五","rhythmic":"减字木兰花","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["腊销三五。","月向雪山云外吐。","烟水黄昏。","梅柳依稀笛断魂。","今宵豫赏。","便作香尘随步想。","莫待元宵。","灯火零星雨寂寥。"]},{"id":"c74-953","title":"减字木兰花·无灯可看","rhythmic":"减字木兰花","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["无灯可看。","雨水从教正月半。","探茧推盘。","探得千秋字字看。","铜驼故老。","说著宣和似天宝。","五百年前。","曾向杭州看上元。"]},{"id":"c74-954","title":"减字木兰花·送春待晓","rhythmic":"减字木兰花","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["送春待晓。","春是五更先去了。","我醉方知。","春正怜伊怕别伊。","留君不可。","归到海边方忆我。","做尽花归。","欲赠君时少一枝。"]},{"id":"c74-955","title":"减字木兰花·相州锦好","rhythmic":"减字木兰花","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["相州锦好。","待到相州人已老。","颍水归田。","白鹭惊猜已十年。","太师尚父。","晚遇明时方用武。","大笑相逢。","把酒家乡是客中。"]},{"id":"c74-956","title":"减字木兰花·不能管得","rhythmic":"减字木兰花","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["不能管得。","欲雨能教天地黑。","待得开晴。","不用吾言也自行。","一杯亦醉。","万事无能吾欲睡。","旧亦能诗。","说旧时诗问是谁。"]},{"id":"c74-957","title":"减字木兰花·清欢昨日","rhythmic":"减字木兰花","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["清欢昨日。","十事不如人六七。","试数从前。","素素相从得几年。","子兮子兮。","再拣一枝何处起。","翠斧峰驼。","客好其如良夜何。"]},{"id":"c74-958","title":"减字木兰花·脾神喜乐","rhythmic":"减字木兰花","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["脾神喜乐。","寿酒一杯胜服药。","过却明朝。","顶上新霜也合销。","小春三日。","便觉春暄梅影出。","醉把梅看。","比似茱萸更耐寒。"]},{"id":"c74-959","title":"山花子·东风解手即天涯","rhythmic":"山花子","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["东风解手即天涯。","曲曲青山不可遮。","如此苍茫君莫怪，是归家。","阊阖相迎悲最苦，英雄知道鬓先华。","更欲徘徊春尚肯，已无花。"]},{"id":"c74-960","title":"山花子·此处情怀欲问天","rhythmic":"山花子","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["此处情怀欲问天。","相期相就复何年。","行过章江三十里，泪依然。","早宿半程芳草路，犹寒欲雨暮春天。","小小桃花三两处，得人怜。"]},{"id":"c74-961","title":"柳梢青·铁马蒙毡","rhythmic":"柳梢青","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["铁马蒙毡，银花洒泪，春人愁城。","笛里番腔，街头戏鼓，不是歌声。","那堪独坐青灯。","想故国、高台月明。","辇下风光，山中岁月，海上心情。"]},{"id":"c74-962","title":"南歌子·搔困麻仙爪","rhythmic":"南歌子","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["搔困麻仙爪，含暄忍客衣。","夜长窗月露成帏。","不说明朝风雨、自当归。"]},{"id":"c74-963","title":"南歌子·篘熟双投美","rhythmic":"南歌子","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["篘熟双投美，香飘一缕丝。","霜前雁到蟹螯持。","自试小窗醉墨、作新诗。"]},{"id":"c74-964","title":"朝中措·炼花为露玉为瓶","rhythmic":"朝中措","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["炼花为露玉为瓶。","佳客为频倾。","耐得风霜满鬓，此身合是金茎。","墙头竹外，洞房初就，画阁新成。","嚼得梅花透骨，何愁不会长生。"]},{"id":"c74-965","title":"太常引·便晴也是不曾晴","rhythmic":"太常引","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["便晴也是不曾晴。","不怕金吾禁行。","风雨动乡情。","梦灯火、扬州化城。","少年跌宕，谁家娇小，绕带到天明。","昨夜月还生。","但惊破、霓裳数声。"]},{"id":"c74-966","title":"太常引·此公去暑似新秋","rhythmic":"太常引","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["此公去暑似新秋。","吏毒一句句。","行县胜监州。","觉甘雨、随车应求。","鹭清为酒，螺清为寿，起舞祝君侯。","急召也须留。","廿四考、中书到头。"]},{"id":"c74-967","title":"玉楼春·霜风不动晴明好","rhythmic":"玉楼春","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["霜风不动晴明好。","探梅有约城东道。","桥边失却老仙期，城门落日人归早。","野田一望迷芳草。","除是腾空君后到。","立马三周黛佛头，参差中路令人老。"]},{"id":"c74-968","title":"玉楼春·龙山歌舞无人道","rhythmic":"玉楼春","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["龙山歌舞无人道。","只说先生狂落帽。","秋风亦是可怜人，要令天意知人老。","菊花不为重阳早。","自爱古人诗句恼。","与君郑重说□□，残年惟有重阳好。"]},{"id":"c74-969","title":"乌夜啼·犹疑薰透帘栊","rhythmic":"乌夜啼","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["犹疑薰透帘栊。","是东风。","不分榴花更胜、一春红。","新雨过，绿连空。","蝶飞慵。","间过绿阴深院、小花浓。"]},{"id":"c74-970","title":"乌夜啼·素娥醉语曾留","rhythmic":"乌夜啼","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["素娥醉语曾留。","又中秋。","待得重圆谁妒、两悠悠。","向愁旱，今愁水，没中洲。","看取明朝晴去、不须愁。"]},{"id":"c74-971","title":"乌夜啼·何年似永和年","rhythmic":"乌夜啼","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["何年似永和年。","记湖船。","如此晴天无处、望新烟。","江南女，裙四尺，合秋千。","昨日老人曾见、久潸然。"]},{"id":"c74-972","title":"行香子·雪履无痕","rhythmic":"行香子","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["雪履无痕。","溪影传神。","著坡诗、请自清温。","朝朝不去，夕夕空勤。","似梦中云，云外雪，雪中春。","四野昏昏。","匹马巡巡。","拣一枝、寄与芳尊。","更谁兴到，於我情真。","是白家宾，江南路，陇头人。"]},{"id":"c74-973","title":"行香子·玉立风尘","rhythmic":"行香子","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["玉立风尘。","光动黄银。","便谈文、也到夜分。","无人烛下，壁上传神。","记老婆心，寒士语，道人身。","极意形容，下语难亲。","更万分、无一分真。","醉翁去后，往往愁人。","顾滴山泉，衔丘冢，化龙云。"]},{"id":"c74-974","title":"行香子·海水成尘","rhythmic":"行香子","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["海水成尘。","河水无银。","恨幽明、我与公分。","青山独往，回首伤神。","叹魏阙心，磻石魄，汨罗身。","除却相思，四海无亲。","识风流、还贺季真。","而今天上，笑谪仙人。","但病伤春，愁厌雨，泪看云。"]},{"id":"c74-975","title":"行香子·月露吾痕","rhythmic":"行香子","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["月露吾痕。","雪得吾神。","更荒寒、不傍人温。","山人去后，车马来勤。","但梦朝云，愁暮雨，怨阳春。","说著东昏。","记著南巡。","泪盈盈、檀板金尊。","怜君素素，念我真真。","叹古来言，新样客，旧时人。"]},{"id":"c74-976","title":"品令·满庭芳草","rhythmic":"品令","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["满庭芳草。","更昨日、落红如扫。","绿阴正似人怀抱。","一声睍睆，春色何曾老。","幸自不须人起早。","寂寞如相恼。","旧时闻处青门道。","禁烟时候，柳下人家好。"]},{"id":"c74-977","title":"鹊桥仙·乘鸾著色","rhythmic":"鹊桥仙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["乘鸾著色，痴蝇误拂。","不及羲之醉墨。","偶然入手送东阳，便看取、薰时清适。","清风去暑，闲题当日。","宰相纱笼谁识。","封丘门外定何人，这一点、瞒他不得。"]},{"id":"c74-978","title":"鹊桥仙·看人掷果","rhythmic":"鹊桥仙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["看人掷果，看人罢织。","难得团栾七夕。","蟠桃只在屋东头，庆西母、年开八ど。","去年今日。","今年今日。","添个曾孙抱膝。","人间乐事有多般，算此乐、人间第一。"]},{"id":"c74-979","title":"鹊桥仙·轻风澹月","rhythmic":"鹊桥仙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["轻风澹月，年年去路。","谁识小年初度。","桥边曾弄碧莲花，悄不记、人间今古。","吹箫江上，沾衣微露。","依约凌波曾步。","寒机何意待人归，但寂历、小窗斜雨。"]},{"id":"c74-980","title":"鹊桥仙·天香吹下","rhythmic":"鹊桥仙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["天香吹下，烟霏成路。","飒飒神光暗度。","桥边犹记泛槎人，看赤岸、苔痕如古。","长空皓月，小风斜露。","寂寞江头独步。","人间何处得飘然，归梦入、梨花春雨。"]},{"id":"c74-981","title":"一翦梅·万事如花不可期","rhythmic":"一翦梅","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["万事如花不可期。","花不堪持。","酒不堪持。","江天雪意使人迷。","翦一枝枝。","歌一枝枝。","歌者不来今几时。","姜影无词。","张影无词。","不歌不醉不成诗。","歌也迟迟。","雪也迟迟。"]},{"id":"c74-982","title":"一翦梅·人生总受业风吹","rhythmic":"一翦梅","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["人生总受业风吹。","三岁儿儿。","八十儿儿。","深闺空谷把还持。","啼看人知。","啼怕人知。","客中自种绿猗猗。","月下横枝。","雪下横枝。","尊前百岁且开眉。","今岁今时。","前岁今时。"]},{"id":"c74-983","title":"夜飞鹊・夜飞鹊慢·何曾见飞渡","rhythmic":"夜飞鹊・夜飞鹊慢","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["何曾见飞渡，年又年痴。","今古相望犹疑。","朱颜一去似流水，断桥魂梦参差。","何堪更嗟迟暮，听旁人说与，此夕佳期。","深深代籍，盼悠悠、北地胭脂。","谁寄扬州破镜，遍海角天涯，空待人归。","自小秦楼望巧，吴机回锦，歌舞为谁。","星萍耿耿，算欢娱，未省流离。","但秋衾梦浅，云闲曲远，薄命同时。"]},{"id":"c74-984","title":"疏影·香篝素被","rhythmic":"疏影","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["香篝素被。","听花犯低低，瑶花开未。","长记那时，炽炭围炉，瘦妻换酒行试。","当家人在销金帐，约莫是、打围归际。","又谁知、别忆烹茶，冷落故家愁思。","闻道滕骄巽懒，今朝待檄与，翻云须易。","白白不成，又不教晴，做尽黄昏情味。","银河本是冰冰底。","怎忍向、东风成水。","待满城、玉宇琼楼，却报卧庐人起。"]},{"id":"c74-985","title":"摘红英·花朝月","rhythmic":"摘红英","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["花朝月。","朦胧别。","朦胧也胜檐声咽。","亲曾说。","令人悦。","落花情绪，上坟时节。","花阴雪。","花阴灭。","柳风一似秋千掣。","晴未决。","晴还缺。","一番寒食，满村啼鴂。"]},{"id":"c74-986","title":"千秋岁·新篘熟也","rhythmic":"千秋岁","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["新篘熟也，借问谁家早。","梅影里，蜂儿绕。","三更残月上，一夜霜天晓。","溪桥小，春风有意年年到。","当年青鸟去，落叶无人扫。","铜柱仄，瑶池老。","残钟长乐树，坠马咸阳道。","空回首，御街人卖南京枣。"]},{"id":"c74-987","title":"促拍丑奴儿·送岁可无诗","rhythmic":"促拍丑奴儿","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["送岁可无诗。","得团栾、忍不开眉。","不记去年今夕梦，江东怀抱，江西信息，舍北妻儿。","五十扊扅炊。","待五十、富贵成痴。","百年苦乐乘除看，今年一半，明年一半，更似儿时。"]},{"id":"c74-988","title":"促拍丑奴儿·世事莫寻思","rhythmic":"促拍丑奴儿","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["世事莫寻思。","待说来、天也应悲。","百年已是中年后，西州垂泪，东山携手，几个斜晖。","也莫苦吟诗。","苦吟诗，待有谁知。","多□不是无才气，文时不遇，武时不遇，更说今时。"]},{"id":"c74-989","title":"最高楼·银河水","rhythmic":"最高楼","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["银河水，洗得世间清。","山色雨馀青。","老子纶巾棋别墅，人家鼾睡柝秋城。","定谁劳，定谁福，定谁能。","常恨著、景升儿不似。","又恨著、景升牛小耳。","空相望，愧平生。","我欲临风扶玉树，自攀承露酌金茎。","看昆明，鳞石长，海桑晴。"]},{"id":"c74-990","title":"最高楼·朱顶字","rhythmic":"最高楼","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["朱顶字，八十正平头。","添作八千秋。","无能也自收郿坞，到今恨不贬潮州。","看几人，炎又冷，老还羞。","也不学、太公忙把火。","也不学、申公轮转磨。","休莫莫，莫休休。","小迟授业何曾吃，更迟食乳不须愁。","且从容，某水钓，某丘游。"]},{"id":"c74-991","title":"最高楼·非是雪","rhythmic":"最高楼","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["非是雪，只是玉楼成。","屑不尽云英。","东边老树颓然折，西头稚柳爆然声。","试平安，松丈丈，竹兄兄。","有谁向、金船呼小玉，又谁怜、纸帐梦飞琼。","怪疏影，坠娉婷。","唤起老张寒蔌蔌，好歌白雪与君听。","但党家，人笑道，太粗生。"]},{"id":"c74-992","title":"最高楼·花上雪","rhythmic":"最高楼","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["花上雪。","信手捻来成。","屑不就琼英。","昨朝已见诗成卷，今朝又试曲成声。","更催催，莫不做，水仙兄。","终须待、晴时携斗酒。","更须待、老夫吟数首。","休更叠，□娉婷。","已无翠鸟传花信，又无羯鼓与花听。","更催催，迟数日，是春生。"]},{"id":"c74-993","title":"桂枝香·吹箫人去","rhythmic":"桂枝香","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["吹箫人去。","但桂影徘徊，荒杯承露。","东望鞭芙缥缈，寒光如注。","去年夜半横江梦，倚危樯，参差曾赋。","茫茫角动，回舟尽兴，未惊鸥鹭。","情知道、明年何处。","漫待客黄楼，尘波前度。","二十四桥，颇有杜书记否。","二三字者今如此，看使君、角巾东路。","人间俯仰，悲欢何限，团圆如故。"]},{"id":"c74-994","title":"临江仙·丞相衮衣朝戏彩","rhythmic":"临江仙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["丞相衮衣朝戏彩，年年庆事如新。","尊前一笑共儿孙。","人间传寿酒，天上送麒麟。","缥缈祥烟连北阙，天颜有喜生春。","蓬莱清浅海光平。","今年初甲子，重试碧桃根。"]},{"id":"c74-995","title":"临江仙·闻道城东鹤会","rhythmic":"临江仙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["闻道城东鹤会，欣然一笑乘风。","不知一鹤在墙东。","神仙人不识，未始出吾宗。","弟子有年於此，先生之道如龙。","碧桃花子落壶中。","化为三五粒，元是北边松。"]},{"id":"c74-996","title":"临江仙·天际何分南与北","rhythmic":"临江仙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["天际何分南与北，五更纵又成横。","夜来拾得断河星。","化为一片石，持去问君平。","老大看天一笑，儿童问我须应。","向来牛女本无名。","要知天上事，亦似谤先生。"]},{"id":"c74-997","title":"临江仙·二十年前此日","rhythmic":"临江仙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["二十年前此日，女兄庆我生儿。","簪萱弄彩听孙啼。","典衣沽美酒，数待冠昏时。","乱后飘零独在，紫荆墓棘风吹。","尊前万事莫寻思。","儿童看有子，白发故应衰。"]},{"id":"c74-998","title":"临江仙·旧日诗肠论斗酒","rhythmic":"临江仙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["旧日诗肠论斗酒，风流怀抱如倾。","几年不听渭城声。","尊前无贺老，卷里少弥明。","闻说语言都好，便应步履全轻。","长生第一是风僧。","额前书八十，能说又能行。"]},{"id":"c74-999","title":"临江仙·西曲罥衣迷去路","rhythmic":"临江仙","author":"刘辰翁","authorSlug":"刘辰翁","dynasty":"宋","kind":"ci","paragraphs":["西曲罥衣迷去路，雪销断岸无痕。","寻花不拟到前村。","暖风初转袖，小径忽开门。","却忆临塘桥下马，暗香不是黄昏。","人生南北与谁论。","岭梅花树下，闲听蜜蜂喧。"]}]