{"冥吏":{"slug":"冥吏","name":"冥吏","dynasty":"唐","style":"","life":"","origin":"","seal":"冥","bio":[],"works":[{"id":"t47-893","title":"示韦泛禄命","kind":"诗"}]},"刘言史":{"slug":"刘言史","name":"刘言史","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":["刘言史，邯郸人，与李贺同时。歌诗美丽恢赡，自贺外，世莫能比，亦与孟郊友善。初客镇冀，王武俊奏为枣强令，辞疾不受，人因称为刘枣强。","后客汉南，李夷简署司空掾，寻卒。歌诗六卷，今编一卷。"],"works":[{"id":"t1-307","title":"相和歌辞 长门怨","kind":"诗"},{"id":"t1-930","title":"杂曲歌辞 乐府二首 一","kind":"诗"},{"id":"t1-931","title":"杂曲歌辞 乐府二首 二","kind":"诗"},{"id":"t25-22","title":"苦妇词","kind":"诗"},{"id":"t25-23","title":"与孟郊洛北野泉上煎茶","kind":"诗"},{"id":"t25-24","title":"七夕歌","kind":"诗"},{"id":"t25-25","title":"立秋日","kind":"诗"},{"id":"t25-26","title":"题茅山仙台药院","kind":"诗"},{"id":"t25-27","title":"送婆罗门归本国","kind":"诗"},{"id":"t25-28","title":"潇湘游","kind":"诗"},{"id":"t25-29","title":"放萤怨","kind":"诗"},{"id":"t25-30","title":"观绳伎","kind":"诗"},{"id":"t25-31","title":"买花谣","kind":"诗"},{"id":"t25-32","title":"王中丞宅夜观舞胡腾","kind":"诗"},{"id":"t25-33","title":"竹里梅","kind":"诗"},{"id":"t25-34","title":"春过赵墟","kind":"诗"},{"id":"t25-35","title":"初下东周赠孟郊","kind":"诗"},{"id":"t25-36","title":"过春秋峡","kind":"诗"},{"id":"t25-37","title":"长门怨","kind":"诗"},{"id":"t25-38","title":"春游曲 一","kind":"诗"},{"id":"t25-39","title":"春游曲 二","kind":"诗"},{"id":"t25-40","title":"广州王园寺伏日即事寄北中亲友","kind":"诗"},{"id":"t25-41","title":"立秋","kind":"诗"},{"id":"t25-42","title":"别落花","kind":"诗"},{"id":"t25-43","title":"登甘露台","kind":"诗"},{"id":"t25-44","title":"夜泊润州江口","kind":"诗"},{"id":"t25-45","title":"看山木瓜花二首 一","kind":"诗"},{"id":"t25-46","title":"看山木瓜花二首 二","kind":"诗"},{"id":"t25-47","title":"题十三弟竹园","kind":"诗"},{"id":"t25-48","title":"乐府杂词三首 一","kind":"诗"},{"id":"t25-49","title":"乐府杂词三首 二","kind":"诗"},{"id":"t25-50","title":"乐府杂词三首 三","kind":"诗"},{"id":"t25-51","title":"岁暮题杨录事江亭","kind":"诗"},{"id":"t25-52","title":"冬日峡中旅泊","kind":"诗"},{"id":"t25-53","title":"泊花石浦","kind":"诗"},{"id":"t25-54","title":"闻崔倚旅葬","kind":"诗"},{"id":"t25-55","title":"赋蕃子牧马","kind":"诗"},{"id":"t25-56","t