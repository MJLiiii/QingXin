{"slug":"胡玢","name":"胡玢","dynasty":"唐","style":"","life":"","origin":"","seal":"胡","bio":["胡玢，隐庐山，苦心五言，李腾廉问江西，弓旌不至，人惜之。诗三首。"],"works":[{"id":"t42-913","title":"巢燕","kind":"诗"},{"id":"t42-914","title":"庐山桑落洲","kind":"诗"},{"id":"t42-915","title":"石楠树","kind":"诗"},{"id":"t42-916","title":"句","kind":"诗"}]}