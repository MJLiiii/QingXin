{"slug":"朱放","name":"朱放","dynasty":"唐","style":"字长通","life":"","origin":"","seal":"朱","bio":["朱放，字长通，襄州人。隐于越之剡溪，嗣曹王臯镇江西，辟节度参谋。贞元初，召为拾遗，不就。","诗一卷。"],"works":[{"id":"t1-148","title":"相和歌辞 铜雀妓","kind":"诗"},{"id":"t16-857","title":"剡溪行却寄新别者","kind":"诗"},{"id":"t16-858","title":"九日陪刘中丞宴昌乐寺送梁廷评","kind":"诗"},{"id":"t16-859","title":"经故贺宾客镜湖道士观","kind":"诗"},{"id":"t16-860","title":"送著公归越","kind":"诗"},{"id":"t16-861","title":"秣陵送客入京","kind":"诗"},{"id":"t16-862","title":"灵门寺赠灵一上人","kind":"诗"},{"id":"t16-863","title":"江上送别","kind":"诗"},{"id":"t16-864","title":"归桐庐旧居寄严长史","kind":"诗"},{"id":"t16-865","title":"竹","kind":"诗"},{"id":"t16-866","title":"铜雀妓","kind":"诗"},{"id":"t16-867","title":"毘陵留别","kind":"诗"},{"id":"t16-868","title":"题竹林寺","kind":"诗"},{"id":"t16-869","title":"答陆[澧]","kind":"诗"},{"id":"t16-870","title":"杨子津送人","kind":"诗"},{"id":"t16-871","title":"山中谒皇甫曾","kind":"诗"},{"id":"t16-872","title":"剡山夜月","kind":"诗"},{"id":"t16-873","title":"九日与杨凝崔淑期登江上山会有故不得往因赠之","kind":"诗"},{"id":"t16-874","title":"山中听子规","kind":"诗"},{"id":"t16-875","title":"乱后经淮阴岸","kind":"诗"},{"id":"t16-876","title":"送张山人","kind":"诗"},{"id":"t16-877","title":"别李季兰","kind":"诗"},{"id":"t16-878","title":"游石涧寺","kind":"诗"},{"id":"t16-879","title":"新安所居答相访人所居萧使君为制","kind":"诗"},{"id":"t16-880","title":"送魏校书","kind":"诗"},{"id":"t16-881","title":"送温台","kind":"诗"},{"id":"t16-882","title":"句","kind":"诗"},{"id":"t51-332","title":"留别刘员外","kind":"诗"},{"id":"t53-73","title":"和萧郎中游兰若","kind":"诗"}]}