{"slug":"德诚","name":"德诚","dynasty":"唐","style":"","life":"","origin":"","seal":"德","bio":["德诚，遂宁府人。嗣药山惟俨，与云岩昙晟、道吾宗智为同道交。住秀州华亭，泛一小舟，随缘度日，世称船子和尚、华亭和尚。","诗四十首。（《全唐诗》无德诚诗）"],"works":[{"id":"t53-640","title":"拨櫂歌 一","kind":"诗"},{"id":"t53-641","title":"拨櫂歌 二","kind":"诗"},{"id":"t53-642","title":"拨櫂歌 三","kind":"诗"},{"id":"t53-643","title":"拨櫂歌 四","kind":"诗"},{"id":"t53-644","title":"拨櫂歌 五","kind":"诗"},{"id":"t53-645","title":"拨櫂歌 六","kind":"诗"},{"id":"t53-646","title":"拨櫂歌 七","kind":"诗"},{"id":"t53-647","title":"拨櫂歌 八","kind":"诗"},{"id":"t53-648","title":"拨櫂歌 九","kind":"诗"},{"id":"t53-649","title":"拨櫂歌 十","kind":"诗"},{"id":"t53-650","title":"拨櫂歌 十一","kind":"诗"},{"id":"t53-651","title":"拨櫂歌 十二","kind":"诗"},{"id":"t53-652","title":"拨櫂歌 十三","kind":"诗"},{"id":"t53-653","title":"拨櫂歌 十四","kind":"诗"},{"id":"t53-654","title":"拨櫂歌 十五","kind":"诗"},{"id":"t53-655","title":"拨櫂歌 十六","kind":"诗"},{"id":"t53-656","title":"拨櫂歌 十七","kind":"诗"},{"id":"t53-657","title":"拨櫂歌 十八","kind":"诗"},{"id":"t53-658","title":"拨櫂歌 十九","kind":"诗"},{"id":"t53-659","title":"拨櫂歌 二十","kind":"诗"},{"id":"t53-660","title":"拨櫂歌 二十一","kind":"诗"},{"id":"t53-661","title":"拨櫂歌 二十二","kind":"诗"},{"id":"t53-662","title":"拨櫂歌 二十三","kind":"诗"},{"id":"t53-663","title":"拨櫂歌 二十四","kind":"诗"},{"id":"t53-664","title":"拨櫂歌 二十五","kind":"诗"},{"id":"t53-665","title":"拨櫂歌 二十六","kind":"诗"},{"id":"t53-666","title":"拨櫂歌 二十七","kind":"诗"},{"id":"t53-667","title":"拨櫂歌 二十八","kind":"诗"},{"id":"t53-668","title":"拨櫂歌 二十九","kind":"诗"},{"id":"t53-669","title":"拨櫂歌 三十","kind":"诗"},{"id":"t53-670","title":"拨櫂歌 三十一","kind":"诗"},{"id":"t53-671","title":"拨櫂歌 三十二","kind":"诗"},{"id":"t53-672","title":"拨櫂歌 三十三","kind":"诗"},{"id":"t53-673","title":"拨櫂歌 三十四","kind":"诗"},{"id":"t53-674","title":"拨櫂歌 三十五","kind":"诗"},{"id":"t53-675","title":"拨櫂歌 三十六","kind":"诗"},{"id":"t53-676","title":"拨櫂歌 三十七","kind":"诗"},{"id":"t53-677","title":"拨櫂歌 三十八","kind":"诗"},{"id":"t53-678","title":"拨櫂歌 三十九","kind":"诗"},{"id":"t53-679","title":"偈","kind":"诗"}]}