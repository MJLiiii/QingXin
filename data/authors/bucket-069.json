id":"t1-710","title":"杂曲歌辞 长安少年行十首 七","kind":"诗"},{"id":"t1-711","title":"杂曲歌辞 长安少年行十首 八","kind":"诗"},{"id":"t1-712","title":"杂曲歌辞 长安少年行十首 九","kind":"诗"},{"id":"t1-713","title":"杂曲歌辞 长安少年行十首 十","kind":"诗"},{"id":"t2-337","title":"杂歌谣辞 鸡鸣曲","kind":"诗"},{"id":"t25-746","title":"夏日途中","kind":"诗"},{"id":"t25-747","title":"长安少年行 一","kind":"诗"},{"id":"t25-748","title":"长安少年行 二","kind":"诗"},{"id":"t25-749","title":"长安少年行 三","kind":"诗"},{"id":"t25-750","title":"长安少年行 四","kind":"诗"},{"id":"t25-751","title":"长安少年行 五","kind":"诗"},{"id":"t25-752","title":"长安少年行 六","kind":"诗"},{"id":"t25-753","title":"长安少年行 七","kind":"诗"},{"id":"t25-754","title":"长安少年行 八","kind":"诗"},{"id":"t25-755","title":"长安少年行 九","kind":"诗"},{"id":"t25-756","title":"长安少年行 十","kind":"诗"},{"id":"t25-757","title":"鸡鸣曲","kind":"诗"},{"id":"t25-758","title":"镜听词","kind":"诗"},{"id":"t25-759","title":"猛士行","kind":"诗"},{"id":"t25-760","title":"送振武将军","kind":"诗"},{"id":"t25-761","title":"落第","kind":"诗"},{"id":"t25-762","title":"赠商山东于岭僧","kind":"诗"},{"id":"t25-763","title":"上令狐舍人","kind":"诗"},{"id":"t50-654","title":"忆钱塘","kind":"诗"}]},"李结":{"slug":"李结","name":"李结","dynasty":"宋","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"c59-785","title":"浣溪沙·花圃萦回曲径通","kind":"词"},{"id":"c59-786","title":"西江月·若将花卉论行藏","kind":"词"}]},"杨鼎夫":{"slug":"杨鼎夫","name":"杨鼎夫","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":["杨鼎夫，成都人，举进士，为蜀安思谦幕吏，判搉盐院事。诗一首。"],"works":[{"id":"t42-521","title":"记皂江堕水事","kind":"诗"}]},"沙门日进":{"slug":"沙门日进","name":"沙门日进","dynasty":"唐","style":"","life":"","origin":"","seal":"沙","bio":[],"works":[{"id":"t50-239","title":"登灵岩寺（伯三六一九）","kind":"诗"}]},"灵业":{"slug":"灵业","name":"灵业","dynasty":"唐","style":"","life":"","origin":"","seal":"灵","bio":[],"works":[{"id":"t50-87","title":"句","kind":"诗"}]},"王炎午":{"slug":"王炎午","name":"王炎午","dynasty":"宋","style":"字鼎翁 · 号梅边","life":"","origin":"庐陵（今江西吉安）","seal":"王","bio":["--(1252－1324) 初名应梅，字鼎翁，别号梅边。庐陵 (今江西吉安) 人。咸淳间，补太学生。","元兵攻陷临安，文天祥被扣元营，炎午作生祭文勉励他坚持民族气节。著有《吾汶稿》。元《草堂诗馀》录其词一首。"],"works":[{"id":"c76-348","title":"沁园春·又是年时","kind":"词"}]},"祝钦明":{"slug":"祝钦明","name":"祝钦明","dynasty":"唐","style":"字文思","life":"","origin":"","seal":"祝","bio":["祝钦明，字文思，京兆始平人，举明经。长安元年，累迁太子率更令，兼崇文馆学士。中宗在春宫，钦明充侍读。","及即位，擢拜国子祭酒，同中书门下三品，历刑部、礼部二尚书。尝与群臣侍宴，钦明自言能八风舞，据地摇头，睆目顾盼。吏部侍郎卢藏用叹曰：“祝公是举，五经扫地矣。","”景云初，为侍御史倪若水所劾，贬饶州刺史。诗一首。"],"works":[{"id":"t0-708","title":"郊庙歌辞 仪坤庙乐章 永和","kind":"诗"},{"id":"t4-981","title":"仪坤庙乐章","kind":"诗"}]},"纪唐夫":{"slug":"纪唐夫","name":"纪唐夫","dynasty":"唐","style":"","life":"","origin":"","seal":"纪","bio":["纪唐夫，开成中中书舍人，诗三首。"],"works":[{"id":"t29-909","title":"送友人归宜春","kind":"诗"},{"id":"t29-910","title":"骢马曲","kind":"诗"},{"id":"t29-911","title":"送温庭筠尉方城","kind":"诗"}]},"褚生":{"slug":"褚生","name":"褚生","dynasty":"宋","style":"","life":"","origin":"","seal":"褚","bio":["--德时太学生。"],"works":[{"id":"c76-20","title":"百字令・念奴娇·半堤花雨","kind":"词"},{"id":"c76-21","title":"祝英台近·倚危栏","kind":"词"}]},"道常":{"slug":"道常","name":"道常","dynasty":"唐","style":"","life":"","origin":"","seal":"道","bio":["道常，嗣盐官，在襄阳，世称关南和尚。诗一首。（《全唐诗》无道常诗，传据《祖堂集》卷十七、《五灯会元》卷四。","《景德传灯录》卷二五有传之道常，为另一僧）"],"works":[{"id":"t53-741","title":"乐道歌（《灯录》作「获珠吟」）","kind":"诗"}]},"邵博":{"slug":"邵博","name":"邵博","dynasty":"宋","style":"","life":"","origin":"","seal":"邵","bio":[],"works":[{"id":"c64-135","title":"念奴娇·天然潇洒","kind":"词"}]},"钱元㺷":{"slug":"钱元㺷","name":"钱元㺷","dynasty":"唐","style":"","life":"","origin":"","seal":"钱","bio":["元㺷，镠子。累官土客马步都指挥使、静江节度使兼中书令。封扶南侯。","钱元瓘立，出判温州。天福二年，为人告谋反而见杀。诗一首。","（《全唐诗》无钱元㺷诗，兹据《十国春秋》卷八三本传、卷七九《文穆王世家》拟传）"],"works":[{"id":"t55-578","title":"游鴈荡","kind":"诗"}]},"鲍防":{"slug":"鲍防","name":"鲍防","dynasty":"唐","style":"字子慎 · 号鲍谢","life":"","origin":"","seal":"鲍","bio":["鲍防，字子慎，襄阳人。天宝末进士第，历福建江西观察使。贞元中，累礼部侍郎，迁工部尚书致仕。","防善属文，尤工诗，与中书舍人谢良弼友善，时号鲍谢。诗八首。"],"works":[{"id":"t16-625","title":"忆长安 二月","kind":"诗"},{"id":"t16-626","title":"状江南 孟春","kind":"诗"},{"id":"t16-627","title":"杂感","kind":"诗"},{"id":"t16-628","title":"送薛补阙入朝","kind":"诗"},{"id":"t16-629","title":"人日陪宣州范中丞传正与范侍御传真宴东峰亭","kind":"诗"},{"id":"t16-630","title":"上巳寄孟中丞","kind":"诗"},{"id":"t16-631","title":"秋暮忆中秋夜与王璠侍御赏月因怆远离聊以奉寄","kind":"诗"},{"id":"t16-632","title":"元日早朝行","kind":"诗"}]},"黄土县尉":{"slug":"黄土县尉","name":"黄土县尉","dynasty":"唐","style":"","life":"","origin":"","seal":"黄","bio":["黄土县尉，姓名不详，开元十七年在职。"],"works":[{"id":"t52-654","title":"同前","kind":"诗"}]}}