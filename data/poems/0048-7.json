[{"id":"t48-700","title":"山阴老人伪谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["欲识圣人姓，千里草青青。","欲识圣人名，日从日上生。"]},{"id":"t48-701","title":"胡楚宾谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["胡楚宾，李翰林。","词同三峡水，字值双南金。"]},{"id":"t48-702","title":"后唐军士谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["除去菩萨，扶立生铁。"]},{"id":"t48-703","title":"周显德中齐州谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["蹋阳春人间二月雨和尘阳春蹋尽西风起肠断人间白发人。"]},{"id":"t48-704","title":"天祐中江南童谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["东海鲤鱼飞上天。"]},{"id":"t48-705","title":"真人谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["有一真人在冀川，开口持弓向外边。"]},{"id":"t48-706","title":"李后主童谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["索得娘来忘却家，后院桃李不生花。","猪儿狗儿都死尽，养得猫儿患赤瘕。"]},{"id":"t48-707","title":"秦人竹𧳽谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["𧳽𧳽引黑牛，天差不自由。","但看戊寅岁，扬在蜀江头。"]},{"id":"t48-708","title":"蜀人谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["黑牛无系绊，椶绳一时断。"]},{"id":"t48-709","title":"秦城芭蕉谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["花开来里，花谢也里。"]},{"id":"t48-710","title":"蜀童谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["我有一帖药，其名曰阿魏，卖与十八子。"]},{"id":"t48-711","title":"蜀中埽地和尚","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["水行仙，怕秦川。"]},{"id":"t48-712","title":"福州谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["骑马来，骑马去。"]},{"id":"t48-713","title":"闽人谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["风吹杨菜鼓山下，不得钱郎戈不罢。"]},{"id":"t48-714","title":"广州童谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["羊头二四，白天雨至。"]},{"id":"t48-715","title":"桂管童谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["大虫来。"]},{"id":"t48-716","title":"湖南童谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["湖南城郭好长街，竟栽柳树不栽槐。","百姓奔窜无一事，只是椎芒织草鞋。"]},{"id":"t48-717","title":"长沙童谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["鞭打马，马急走。"]},{"id":"t48-718","title":"湘中童谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["马去不用鞭，齩牙过今年。"]},{"id":"t48-719","title":"长沙童谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["三羊五马，马子离群，羊子无舍。"]},{"id":"t48-720","title":"丹阳语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["待钱来，待钱来。"]},{"id":"t48-721","title":"辽述律后谣","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["青牛妪，曾避路。"]},{"id":"t48-722","title":"招手令","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["亚其虎膺，曲其松根。","以蹲鸱间虎膺之下，以钩戟差玉柱之旁。","潜虬阔玉柱三分，奇兵阔潜虬一寸。","死其三洛，生其五峰。"]},{"id":"t48-723","title":"打令口号","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["送摇招，由三方。","一圆分成四片，送在摇前。"]},{"id":"t48-724","title":"龙朔中酒令","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["子母相去离，连台拗倒。"]},{"id":"t48-725","title":"沈亚之 一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["伐木丁丁，鸟鸣嘤嘤。","东行西行，遇饭遇羹。"]},{"id":"t48-726","title":"沈亚之 二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["如切如磋，如琢如磨。","欺客打妇，不当娄罗。"]},{"id":"t48-727","title":"令狐楚顾非熊 一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["水里取一鼍，岸上取一驼。","将者驼，来驮者鼍，是为驼驮鼍。"]},{"id":"t48-728","title":"令狐楚顾非熊 二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["屋里取一鸽，水里取一蛤。","将者鸽，来合者蛤，是谓鸽合蛤。"]},{"id":"t48-729","title":"张祜 一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["上水船，风大急。","帆下人，须好立。"]},{"id":"t48-730","title":"张祜 二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["上水船，船底破。","好看客，莫倚柁。"]},{"id":"t48-731","title":"卢发 一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["十姓胡中第六胡，也曾金阙掌洪炉。","少年从事夸门第，莫向尊前气色粗。"]},{"id":"t48-732","title":"卢发 二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["十姓胡中第六胡，文章官职胜崔卢。","暂来关外分优寄，不称宾筵语气粗。"]},{"id":"t48-733","title":"沈询","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["莫打南来雁，从他向北飞。","打时双打取，莫遣两分离。"]},{"id":"t48-734","title":"姚岩杰","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["遥望渔舟，不阔尺八。","凭阑一呕，已觉空喉。"]},{"id":"t48-735","title":"裴勋父子 一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["矬人饶舌，破车饶楔。"]},{"id":"t48-736","title":"裴勋父子 二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["蝙蝠不自见，笑他梁上燕。"]},{"id":"t48-737","title":"方干李主簿改令 一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["措大吃酒点盐，将军吃酒点酱。","只见门外著篱，未见眼中安鄣。"]},{"id":"t48-738","title":"方干李主簿改令 二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["措大吃酒点盐，下人吃酒点鲊。","只见半臂著篱，不见口唇开袴。"]},{"id":"t48-739","title":"高骈薛涛 一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["口，有似没量斗。"]},{"id":"t48-740","title":"高骈薛涛 二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["川，有似三条椽。"]},{"id":"t48-741","title":"南唐烈祖酒令 一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["雪下纷纷，便是白起。"]},{"id":"t48-742","title":"南唐烈祖酒令 二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["著履过街，必须雍齿。"]},{"id":"t48-743","title":"南唐烈祖酒令 三","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["明朝日出，争奈萧何。"]},{"id":"t48-744","title":"吴越王与陶谷酒令 一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["白玉石，碧波亭上迎仙客。"]},{"id":"t48-745","title":"吴越王与陶谷酒令 二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["口耳王，圣明天子要钱塘。"]},{"id":"t48-746","title":"夷陵女郎鬼","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["鸾老头脑好，好头脑鸾老。"]},{"id":"t48-747","title":"城阳公主卜繇","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["二火皆食，始同荣，末同戚。"]},{"id":"t48-748","title":"冯存澄为明皇占","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["合同斩关，铸印乘轩。","始当果断，终得嗣天。"]},{"id":"t48-749","title":"钱知微卜卖天津桥","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["两头点土，中心虚悬。","人足踏跋，不肯下钱。"]},{"id":"t48-750","title":"王山人为李卫公按冥","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["位极人臣，寿六十四。"]},{"id":"t48-751","title":"钟传客占历日包橘","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["太岁当头坐，诸神不敢当。","其中有一物，常带洞庭香。"]},{"id":"t48-752","title":"马重绩占随卦繇辞","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["南瞻析木，木不自续。","虚而动之，动随其覆。"]},{"id":"t48-753","title":"方龟精为钱元懿卜词","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["太乙接天河，金华宝贝多。","郡侯六十六，别处不经过。"]},{"id":"t48-754","title":"叶简占失牛","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["占失牛，已被家边载上州。","欲知贼姓一斤求，欲知贼名十干头。"]},{"id":"t48-755","title":"又射覆橘子","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["圆似珠，色如丹。","傥能擘破同分吃，争不慙媿洞庭山。"]},{"id":"t48-756","title":"射覆巾子","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["近来好裹束，各自竞尖新。","秤无三五两，因何号一斤。"]},{"id":"t48-757","title":"射覆二鸡子","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["此物不难知，一雄兼一雌。","谁将打破看，方明混沌时。"]},{"id":"t48-758","title":"天冲星占","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["天冲抱极泣帝前，血浊雾下天下冤。"]},{"id":"t48-759","title":"占月语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["月如弯弓，少雨多风。","月如仰瓦，不求自下。"]},{"id":"t48-760","title":"占雨 一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["干星照湿土，明日依旧雨。"]},{"id":"t48-761","title":"占雨 二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["云行西，星照泥。"]},{"id":"t48-762","title":"占雨 三","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["朝霞不出门，暮霞行千里。"]},{"id":"t48-763","title":"占雨 四","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["天将雨，鸠逐妇。"]},{"id":"t48-764","title":"占四时甲子雨","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["春雨甲子，赤地千里。","夏雨甲子，乘船入市。","秋雨甲子，禾头生耳。","冬雨甲子，牛羊冻死。","鹊巢下地，其年大水。"]},{"id":"t48-765","title":"占年 一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["要见麦，见三白。"]},{"id":"t48-766","title":"占年 二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["正月三白，田公笑赫赫。"]},{"id":"t48-767","title":"树稼谚","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["树稼，达官怕。"]},{"id":"t48-768","title":"相书语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["目有四白，五夫守宅。"]},{"id":"t48-769","title":"葬书语 一","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["葬压龙角，其棺必斲。"]},{"id":"t48-770","title":"葬书语 二","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["朱雀和鸣，子孙盛荣。"]},{"id":"t48-771","title":"葬书语 三","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["朱雀悲哀，棺中见灰。"]},{"id":"t48-772","title":"葬书语 四","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["安龙头，枕龙角。","不三年，自消铄。"]},{"id":"t48-773","title":"葬书语 五","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["安龙头，枕龙耳。","不三年，万乘至。"]},{"id":"t48-774","title":"阴阳书语","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["乔木先枯，众子必孤。"]},{"id":"t48-775","title":"本草采萍时日歌","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["不在山，不在岸，采我之时七月半。","选甚瘫风与缓风，些小微风都不算。","豆淋酒内下三丸，铁幞头上也出汗。"]},{"id":"t48-776","title":"和剂方补骨脂丸方诗","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["三年时节向边隅，人信方知药力殊。","夺得春光来在手，青娥休笑白髭须。"]},{"id":"t48-777","title":"李廷珪藏墨诀","rhythmic":null,"author":"不详","authorSlug":"不详","dynasty":"唐","kind":"shi","paragraphs":["赠尔乌玉玦，泉清硏须洁。","避暑悬葛囊，临风度梅月。"]},{"id":"t48-778","title":"蒙求","rhythmic":null,"author":"李瀚","authorSlug":"李瀚","dynasty":"唐","kind":"shi","paragraphs":["王戎简要，裴楷清通。","孔明卧龙，吕望非熊。","杨震关西，丁宽易东。","谢安高洁，王导公忠。","匡衡凿壁，孙敬闭户。","郅都苍鹰，宁成乳虎。","周嵩狼抗，梁冀跋扈。","郗超䫇参，王珣短簿。","伏波标柱，博望寻河。","李陵初诗，田横感歌。","武仲不休，士衡患多。","桓谭非谶，王商止讹。","嵇吕命驾，程孔倾盖。","剧孟一敌，周处三害。","胡广补阙，袁安倚赖。","黄霸政殊，梁习治最。","墨子悲丝，杨朱泣岐。","朱博乌集，萧芝雉随。","杜后生齿，灵王出髭。","贾谊忌鵩，庄周畏牺。","燕昭筑台，郑庄置驿。","瓘靖二妙，岳湛连璧。","郄诜一枝，戴冯重席。","邹阳长裾，王符逢掖。","鸣鹤日下，士龙云间。","晋宣狼顾，汉祖龙颜。","鲍靓记井，羊祜识环。","仲容青云，叔夜玉山。","毛义捧檄，子路负米。","江革忠孝，王览友弟。","萧何定律，叔孙制礼。","葛丰刺举，息躬历诋。","管宁割席，和峤专车。","时苗留犊，羊续悬鱼。","樊哙排闼，辛毘引裾。","孙楚漱石，郝隆晒书。","枚臯诣阙，充国自赞。","王衍风鉴，许劭月旦。","贺循儒宗，孙绰才冠。","太叔辨洽，挚仲辞翰。","山涛识量，毛玠公方。","袁盎却座，卫瓘抚床。","于公高门，曹参趣装。","庶女振风，邹衍降霜。","范丹生尘，晏婴脱粟。","诘汾兴魏，鼈灵王蜀。","不疑诬金，卞和泣玉。","檀卿沐猴，谢尚鸲鹆。","泰初日月，季野阳秋。","荀陈德星，李郭仙舟。","王忳绣被，张氏铜钩。","丁公遽戮，雍齿先侯。","陈雷胶漆，范张鸡黍。","周侯山嶷，会稽霞举。","季布一诺，阮瞻三语。","郭文游山，袁宏泊渚。","黄琬对日，秦宓论天。","孟轲养素，扬雄草玄。","向秀闻笛，伯牙绝弦。","郭槐自屈，南郡犹怜。","鲁恭驯雉，宋均去兽。","广客蛇影，殷师牛鬬。","元礼模楷，季彦领袖。","鲁褒钱神，崔烈铜臭。","梁竦庙食，赵温雄飞。","枚乘蒲轮，郑均白衣。","陵母伏劒，轲亲断机。","齐后破环，谢女解围。","凿齿尺牍，荀勗音律。","胡威推缣，陆绩怀橘。","罗含吞鸟，江淹梦笔。","李𫷷清贞，刘𬴊高率。","蒋诩三径，许由一瓢。","杨仆移关，杜预建桥。","寿王议鼎，杜林駮尧。","西施捧心，孙寿折腰。","灵辄扶轮，魏颗结草。","逸少倾写，平子绝倒。","澹台毁璧，子罕辞宝。","东平为善，司马称好。","公超雾市，鲁般云梯。","田单火牛，江逌爇鸡。","蔡裔殒盗，张辽止啼。","陈平多辙，李广成蹊。","陈遵投辖，山简倒载。","渊客泣珠，交甫解佩。","龚胜不屈，孙宝自劾。","吕安题凤，子猷访戴。","董宣彊项，翟璜直言。","纪昌贯虱，养由号猨。","冯衍归里，张昭塞门。","苏韶鬼灵，卢充幽婚。","震畏四知，秉去三惑。","柳下直道，叔敖阴德。","张汤巧诋，杜周深刻。","三王尹京，二鲍纠慝。","孙康映雪，车胤聚萤。","李充四部，井春五经。","谷永笔札，顾恺丹青。","戴逵破琴，谢敷应星。","阮宣杖头，毕卓瓮下。","文伯羞鼈，孟宗寄鲊。","史丹青蒲，张湛白马。","隐之感邻，王修辍社。","阮放八隽，江臮四凶。","华歆忤旨，陈群蹙容。","王濬悬刀，丁固生松。","姜维胆斗，卢植音钟。","桓温奇骨，邓艾大志。","杨修捷对，罗友默记。","杜康造酒，苍颉制字。","樗里智囊，边韶经笥。","滕公佳城，王果石崖。","买妻耻醮，泽室犯斋。","马后大练，孟光荆钗。","颜叔秉烛，宋弘不谐。","邓通铜山，郭况金穴。","秦彭攀辕，侯霸卧辙。","淳于炙輠，彦国吐屑。","太真玉台，武子金埓。","巫马戴星，宓贱弹琴。","郝廉留钱，雷义送金。","逢萌挂冠，胡昭投簪。","王乔双凫，华佗五禽。","程邈隶书，史籀大篆。","王承鱼盗，丙吉牛喘。","贾琮褰帷，郭贺露冕。","冯媛当熊，班女辞辇。","王充阅市，董生下帷。","平叔傅粉，弘治凝脂。","杨生黄雀，毛子白龟。","宿瘤采桑，漆室忧葵。","韦贤满籯，夏侯拾芥。","阮简旷达，袁耽俊迈。","苏武持节，郑众不拜。","郭巨将坑，董永自卖。","仲连蹈海，范蠡泛湖。","文宝缉柳，温舒截蒲。","伯道无儿，嵇绍不孤。","绿珠坠楼，文君当垆。","伊尹负鼎，甯戚叩角。","赵壹坎壈，颜驷蹇剥。","龚遂劝农，文翁兴学。","晏御扬扬，五鹿岳岳。","萧珠结绶，王贡弹冠。","庞统展骥，仇览栖鹰。","葛亮顾庐，韩信升坛。","王褒柏惨，闵损衣单。","蒙恬制笔，蔡伦造纸。","孔伋缊袍，祭遵布被。","周公握发，蔡邕倒屣。","王敦倾室，纪瞻出妓。","暴胜持斧，张纲埋轮。","灵运曲笠，林宗折巾。","屈原泽畔，渔父江滨。","魏勃埽门，潘岳望尘。","京房推律，翼奉观性。","甘宁奢侈，陆凯贵盛。","干木富义，于陵辞聘。","元凯传癖，伯英草圣。","冯异大树，千秋小车。","漂母进食，孙钟设瓜。","壶公谪天，蓟训历家。","刘玄刮席，晋惠闻蟆。","伊籍一拜，郦生长揖。","马安四至，应璩三入。","郭解借交，朱家脱急。","虞延克期，盛吉垂泣。","豫让吞炭，鉏麑触槐。","阮孚蜡屐，祖约好财。","初平起石，左慈掷杯。","武陵桃源，刘阮天台。","王俭坠车，褚渊落水。","季伦锦障，春申珠履。","甄后出拜，刘桢平视。","胡嫔争摴，晋武伤指。","石庆数马，孔光温树。","翟汤隐操，许询胜具。","优旃滑稽，落下历数。","曼容自免，子平毕娶。","师旷清耳，离娄明目。","仲文照镜，临江折轴。","栾巴噀酒，偃师舞木。","德润佣书，君平卖卜。","叔宝玉润，彦辅冰清。","卫后发鬒，飞燕体轻。","玄石沉湎，刘伶解酲。","赵胜谢躄，楚庄绝缨。","恶来多力，飞廉善走。","赵孟疵面，田骈天口。","张凭理窟，裴𬱟谈薮。","仲宣独步，子建八斗。","广汉钩距，弘羊心计。","卫青拜幕，去病辞第。","郦寄卖友，纪信诈帝。","济叔不痴，周兄无慧。","虞卿担簦，苏章负笈。","南风掷孕，商受斮涉。","广德从桥，君章拒猎。","应奉五行，安世三箧。","相如题柱，终军弃𦈡。","孙晨槀席，原宪桑枢。","端木辞金，钟离委珠。","季札挂劒，徐穉致刍。","朱云折槛，申屠断鞅。","卫玠羊车，王恭鹤氅。","管仲随马，苍舒称象。","丁兰刻木，伯瑜泣杖。","陈逵豪爽，田方简傲。","黄向访主，陈寔遗盗。","庞俭凿井，阴方祀灶。","韩寿窃香，王蒙市帽。","句践投醪，陆抗尝药。","孔愉放龟，张颢堕鹊。","田豫俭素，李恂清约。","义纵攻剽，周阳暴虐。","孟阳掷瓦，贾氏如臯。","颜回箪瓢，仲蔚蓬蒿。","糜竺收资，桓景登高。","雷焕送劒，吕虔佩刀。","老莱斑衣，黄香扇枕。","王祥守奈，蔡顺分椹。","淮南食时，左思十稔。","刘惔倾酿，孝伯痛饮。","女娲补天，长房缩地。","季珪士首，长孺国器。","陆玩无人，贾诩非次。","何晏神伏，郭奕心醉。","常林带经，高凤漂麦。","孟嘉落帽，庾凯堕帻。","龙逢板出，张华台坼。","董奉活燮，扁鹊起虢。","寇恂借一，何武去思。","韩子孤愤，梁鸿五噫。","蔡琰辨琴，王粲覆棋。","西门投巫，何谦焚祠。","孟尝还珠，刘昆反火。","姜肱共被，孔融让果。","端康相代，亮陟隔坐。","赵伦鹠怪，梁孝牛祸。","桓典避马，王尊叱驭。","鼌错峭直，赵禹廉倨。","亮遗巾帼，备失匕箸。","张翰适意，陶潜归去。","魏储南馆，汉相东阁。","楚元置醴，陈蕃下榻。","广利泉涌，王霸冰合。","孔融坐满，郑崇门杂。","张堪折辕，周镇漏船。","郭伋竹马，刘宽蒲鞭。","许史侯盛，韦平相延。","雍伯种玉，黄寻飞钱。","王允千里，黄宪万顷。","虞𩦎才望，戴渊锋颖。","史鱼黜殡，子囊城郢。","戴封积薪，耿恭拜井。","汲黯开仓，冯驩折券。","齐景驷千，何曾食万。","顾荣锡炙，田文比饭。","稚珪蛙鸣，彦伦鹤怨。","廉颇负荆，须贾擢发。","孔翊绝书，申嘉私谒。","渊明把菊，真长望月。","子房取履，释之结韤。","郭丹约关，祖逖誓江。","贾逵问事，许慎无双。","娄敬和亲，白起坑降。","萧史凤台，宋宗鸡窗。","王阳囊衣，马援薏苡。","刘整交质，五伦十起。","张敞画眉，谢鲲折齿。","盛彦感螬，姜诗跃鲤。","宗资主诺，成瑨坐啸。","伯成辞耕，严陵去钓。","董遇三余，谯周独笑。","将闾仰天，王凌呼庙。","二疏散金，陆贾分橐。","慈明八龙，祢衡一鹗。","不占陨车，子云投阁。","魏舒堂堂，周舍谔谔。","无盐如漆，姑射若冰。","邾子投火，王思怒蝇。","符朗皂白，易牙淄渑。","周勃织薄，灌婴贩缯。","马良白眉，阮籍青眼。","黥布开关，张良烧栈。","陈遗饭感，陶侃酒限。","楚昭萍实，束皙竹简。","曼倩三冬，陈思七步。","刘宠一钱，廉范五袴。","泛毓字孤，郗鉴吐哺。","苟弟转酷，严母埽墓。","洪乔掷水，陈泰挂壁。","王述忿狷，荀粲惑溺。","宋女愈谨，敬姜犹绩。","鲍照篇翰，陈琳书檄。","浩浩万古，不可备甄。","芟繁摭华，尔曹勉旃。"]},{"id":"t48-779","title":"宗庙九德之歌辞","rhythmic":null,"author":"褚亮","authorSlug":"褚亮","dynasty":"唐","kind":"shi","paragraphs":["皇祖诞庆，于昭于天。","积德斯远，茂攸绪先。","维文应历，神武弘宣。","肇迹□水，成功坂泉。","道光覆载，声穆吉先。","式备牺象，用□牲牷。","礼终九献，乐展四悬。","神贶景福，遐哉永年。"]},{"id":"t48-780","title":"太庙祼地歌辞","rhythmic":null,"author":"陈叔达","authorSlug":"陈叔达","dynasty":"唐","kind":"shi","paragraphs":["清庙既裸，郁鬯推礼。","大哉孝思，严恭祖祢。","龙衮以祭，鸾刀思启。","发德朱弦，升歌丹陛。","遥享粢盛，堂斟况齐。","降福穰穰，来仪济济。"]},{"id":"t48-781","title":"堦前石行","rhythmic":null,"author":"王绩","authorSlug":"王绩","dynasty":"唐","kind":"shi","paragraphs":["上天布甘雨，万物咸均平。","自顾微且贱，亦得蒙滋荣。","萋萋结绿枝，晔晔垂朱英。","常恐零露降，不得全其生。","叹息聊自思，此生岂我情。","昔我未生时，谁者令我萌。","弃置勿重陈，委化何所营。"]},{"id":"t48-782","title":"九月九日","rhythmic":null,"author":"崔善为","authorSlug":"崔善为","dynasty":"唐","kind":"shi","paragraphs":["九日重阳节，三秋季月残。","菊花催晚气，萸房辟早寒。","霜浓鹰击远，雾重雁飞难。","谁忆龙山外，萧条边兴阑。"]},{"id":"t48-783","title":"奉和九月九日应制","rhythmic":null,"author":"许敬宗","authorSlug":"许敬宗","dynasty":"唐","kind":"shi","paragraphs":["爽气申时豫，临秋肆武功。","太液荣光发，曾城佳气融。","紫霄寒暑丽，黄山极望通。","讲艺遵先𮜿，覩德畅宸衷。","鹫岭飞夏服，娥魄乱雕弓。","汗浃镳流赭，尘生埓散红。","饮羽惊开石，中叶遽凋丛。","雁殚云路静，乌坠日轮空。","九流参广宴，万宇抃恩隆。"]},{"id":"t48-784","title":"奉和守岁应制","rhythmic":null,"author":"许敬宗","authorSlug":"许敬宗","dynasty":"唐","kind":"shi","paragraphs":["玉琯移玄序，金奏赏彤闱。","祥鸾歌里转，春燕舞前归。","寿爵传三礼，灯枝丽九微。","运广薰风积，恩深湛露晞。","送寒终此夜，延宴待晨晖。"]},{"id":"t48-785","title":"凌晨","rhythmic":null,"author":"卢照隣","authorSlug":"卢照隣","dynasty":"唐","kind":"shi","paragraphs":["日掩鸿都夕，河低乱箭移。","虫飞明月户，鹊绕落花枝。","兰襟帐北壑，玉匣鼓文漪。","闻有啼莺处，暗幄晓云披。"]},{"id":"t48-786","title":"登北固山","rhythmic":null,"author":"宋之问","authorSlug":"宋之问","dynasty":"唐","kind":"shi","paragraphs":["京镇周天险，东南作北关。","埭横江曲路，戍入海中山。","望越心初切，思秦鬓已斑。","空怜上林雁，朝夕待春还。"]},{"id":"t48-787","title":"陪群公登箕山赋得群字","rhythmic":null,"author":"宋之问","authorSlug":"宋之问","dynasty":"唐","kind":"shi","paragraphs":["许由去已远，冥莫见幽坟。","世薄人不贵，兹山唯白云。","宁知三千岁，复有尧为君。","时佐激颓俗，登箕挹清芬。","高节虽旦暮，邈与洪崖群。"]},{"id":"t48-788","title":"人日兼立春小园宴","rhythmic":null,"author":"苏颋","authorSlug":"苏颋","dynasty":"唐","kind":"shi","paragraphs":["黄山积高次，表里望京邑。","白日最灵朝，登攀尽原隰。","年灰律象动，阳气开迎入。","烟霭长薄含，临流小溪涩。","宾朋莫我弃，词赋当春立。","更与韶物期，不孤东园集。"]},{"id":"t48-789","title":"和黄门舅十五夜作","rhythmic":null,"author":"苏颋","authorSlug":"苏颋","dynasty":"唐","kind":"shi","paragraphs":["闻君陌上来，歌管沸相催。","孤月连明照，千灯合暗开。","宝装游骑出，香绕看车回。","独有归闲意，春庭伴落梅。"]},{"id":"t48-790","title":"登绵州富乐山别李道士䇿","rhythmic":null,"author":"薛曜","authorSlug":"薛曜","dynasty":"唐","kind":"shi","paragraphs":["珠阙昆山远，银宫涨海悬。","送君从此路，城郭几千年。","云雾含丹景，桑麻覆细田。","笙歌未尽曲，风驭独泠然。"]},{"id":"t48-791","title":"九城寻山水","rhythmic":null,"author":"薛曜","authorSlug":"薛曜","dynasty":"唐","kind":"shi","paragraphs":["菊浦桃源瞰九城，鸾歌凤啸忽将迎。","千岩杂树云霞色，百道流泉风雨声。","上客由来轩盖重，幽人自觉薜萝轻。","疑是昔年栖息地，山中日暮有余情。"]},{"id":"t48-792","title":"邙山古意","rhythmic":null,"author":"薛曜","authorSlug":"薛曜","dynasty":"唐","kind":"shi","paragraphs":["昔掩佳城路，曾惊壑易迁。","今接宜都里，翻疑海作田。","镂鼎名应大，生金字不传。","风飙吹白日，罗绮拭黄泉。","象凤笙留国，成龙劒上天。","长乐移新垄，咸阳失旧阡。","川流徒漫漫，神理竟绵绵。","伫见飞来鹤，沈嗟不学仙。"]},{"id":"t48-793","title":"凤阁南厅槐树半生死虽遇阳和终呈枯朽托根清禁颇觉非宜感物缘情率尔为咏","rhythmic":null,"author":"李怀远","authorSlug":"李怀远","dynasty":"唐","kind":"shi","paragraphs":["庭槐岁月深，半死尚抽心。","叶少宁障日，枝疎不碍禽。","帷幄谅无取，栋梁非所在。","媿在龙楼侧，羞处凤池阴。","未能辞雨露，犹得款衣簪。","惜悲生意尽，空余古木吟。"]},{"id":"t48-794","title":"和九月九日登慈恩寺浮图应制","rhythmic":null,"author":"赵彦伯","authorSlug":"赵彦伯","dynasty":"唐","kind":"shi","paragraphs":["出豫垂佳节，凭高陟梵宫。","皇心满尘界，佛迹现虚空。","日月宜长寿，天人得大通。","喜闻题宝偈，受记莫由同。"]},{"id":"t48-795","title":"秋夜巫山","rhythmic":null,"author":"乔备","authorSlug":"乔备","dynasty":"唐","kind":"shi","paragraphs":["巫峡裴回雨，阳台淡荡云。","江山空窈窕，朝暮自纷氲。","萤色寒秋露，猨啼清夜闻。","谁怜梦魂远，肠断思纷纷。"]},{"id":"t48-796","title":"晦日与卢舍人同诣补阙城南林园","rhythmic":null,"author":"孙逖","authorSlug":"孙逖","dynasty":"唐","kind":"shi","paragraphs":["芳年正月晦，假日早朝回。","欲尽三春赏，还钦二阮才。","柳迎郊骑入，花近□庭开。","宛是人寰外，真情寓物来。"]},{"id":"t48-797","title":"赠刘蓝田","rhythmic":null,"author":"卢象","authorSlug":"卢象","dynasty":"唐","kind":"shi","paragraphs":["篱中犬迎吠，出屋候柴扉。","岁晏输井税，山村人暮归。","晚田始家食，余布成我衣。","对此能无事，劳君问是非。"]},{"id":"t48-798","title":"清明日青龙寺上方","rhythmic":null,"author":"刘长卿","authorSlug":"刘长卿","dynasty":"唐","kind":"shi","paragraphs":["上方偏可适，季月况堪过。","远近人都至，东西山色多。","夕阳留径草，新叶变庭柯。","已度清明节，春愁如客何。"]},{"id":"t48-799","title":"羽山","rhythmic":null,"author":"萧颕士","authorSlug":"萧颕士","dynasty":"唐","kind":"shi","paragraphs":["九山方荡潏，三考伫良材。","夏祖何屯圯，迁殛此山隈。","空余下泉客，谁复辨黄能。"]}]