{"刘太真":{"slug":"刘太真","name":"刘太真","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":["刘太真，宣州人，师萧颕士。天宝末，举进士，大历中，拜起居郎，历台阁，自中书舍人转工部、邢部二侍郎，坐事贬信州刺史。贞元四年重九，赐宴曲江亭，帝制诗序，赐群僚各一本，命简文词之士应制，同用清字，明日于延英门进之。","于是朝臣毕和，上自考定，以太真、李纾等为上等。集三十卷，今存诗三首。"],"works":[{"id":"t13-353","title":"宣州东峰亭各赋一物得古壁苔","kind":"诗"},{"id":"t13-354","title":"顾十二况左迁过韦苏州房杭州韦睦州三使君皆有郡中燕集诗辞章高丽鄙夫之所仰慕顾生既至留连笑语因亦成篇以继三君子之风焉","kind":"诗"},{"id":"t13-355","title":"贡院寄前主司萧尚书听","kind":"诗"}]},"吕从庆":{"slug":"吕从庆","name":"吕从庆","dynasty":"唐","style":"号丰溪渔叟","life":"","origin":"","seal":"吕","bio":["吕从庆，本大梁人，从其祖吕伸宦金陵。广明元年，黄巢率义军渡江攻金陵。时伸已卒，从庆偕弟从善走歙之堨田。","朱梁代唐，又自歙迁隐于旌德之丰溪。海以陶彭对泽自况，自号丰溪渔叟。历十七年而后唐代梁，又十四年而石晋代唐，其在江南则南唐方受吴禅。","从庆喜曰：「吾今而后始终为唐民矣。」卒，年九十有找。诗一卷，计四十五首。"],"works":[{"id":"t50-919","title":"无题","kind":"诗"},{"id":"t50-920","title":"幽居","kind":"诗"},{"id":"t50-921","title":"登纠峰顶","kind":"诗"},{"id":"t50-922","title":"题画","kind":"诗"},{"id":"t50-923","title":"钓鱼","kind":"诗"},{"id":"t50-924","title":"过金鸡石","kind":"诗"},{"id":"t50-925","title":"怀严子陵前辈","kind":"诗"},{"id":"t50-926","title":"喜晴","kind":"诗"},{"id":"t50-927","title":"献题金鳌山","kind":"诗"},{"id":"t50-928","title":"山中作","kind":"诗"},{"id":"t50-929","title":"贼警","kind":"诗"},{"id":"t50-930","title":"行次歙州寓之","kind":"诗"},{"id":"t50-931","title":"小园","kind":"诗"},{"id":"t50-932","title":"游多宝寺","kind":"诗"},{"id":"t50-933","title":"村径中即事","kind":"诗"},{"id":"t50-934","title":"对月有感","kind":"诗"},{"id":"t50-935","title":"草堂坐雨","kind":"诗"},{"id":"t50-936","title":"偶兴","kind":"诗"},{"id":"t50-937","title":"溪西村","kind":"诗"},{"id":"t50-938","title":"冬尽","kind":"诗"},{"id":"t50-939","title":"平原","kind":"诗"},{"id":"t50-940","title":"章氏幽居","kind":"诗"},{"id":"t50-941","title":"忆弟从善","kind":"诗"},{"id":"t50-942","title":"夏日即事","kind":"诗"},{"id":"t50-943","title":"梅","kind":"诗"},{"id":"t50-944","title":"薄暮步村径","kind":"诗"},{"id":"t50-945","title":"避乱","kind":"诗"},{"id":"t50-946","title":"春更书怀","kind":"诗"},{"id":"t50-947","title":"赠野僧","kind":"诗"},{"id":"t50-948","title":"永丰桥闲坐","kind":"诗"},{"id":"t50-949","title":"阅田禾","kind":"诗"},{"id":"t50-950","title":"传婆井","kind":"诗"},{"id":"t50-951","title":"葺丰溪桥成志喜一绝","kind":"诗"},{"id":"t50-952","title":"醉卧田间赖里人章氏子扶归作诗以谢之","kind":"诗"},{"id":"t50-953","title":"题英济石","kind":"诗"},{"id":"t50-954","title":"观野烧","kind":"诗"},{"id":"t50-955","title":"菊","kind":"诗"},{"id":"t50-956","title":"栅山","kind":"诗"},{"id":"t50-957","title":"漫兴","kind":"诗"},{"id":"t50-958","title":"马蹄痕","kind":"诗"},{"id":"t50-959","title":"春日往栅山吟诗于驴子背上未即就误入侧径为丛莽所缚卒成之","kind":"诗"},{"id":"t50-960","title":"又","kind":"诗"},{"id":"t50-961","title":"寄弟","kind":"诗"},{"id":"t50-962","title":"纠峰别业","kind":"诗"},{"id":"t50-963","title":"德山老人送茶至","kind":"诗"},{"id":"t50-964","title":"丰溪秋社","kind":"诗"}]},"崔李二生":{"slug":"崔李二生","name":"崔李二生","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":[],"works":[{"id":"t43-742","title":"句","kind":"诗"}]},"张鹭":{"slug":"张鹭","name":"张鹭","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张鹭，开成中人，诗一首。"],"works":[{"id":"t30-168","title":"莺出谷","kind":"诗"}]},"徐凝":{"slug":"徐凝","name":"徐凝","dynasty":"唐","style":"","life":"","origin":"","seal":"徐","bio":["徐凝，睦州人，元和中官至侍郎。诗一卷。徐凝，与白居易沈亚之辈友善，元和中官至侍郎。","补诗一首。"],"works":[{"id":"t25-275","title":"送马向入蜀","kind":"诗"},{"id":"t25-276","title":"送李补阙归朝","kind":"诗"},{"id":"t25-277","title":"送日本使还","kind":"诗"},{"id":"t25-278","title":"题开元寺牡丹","kind":"诗"},{"id":"t25-279","title":"香炉峰","kind":"诗"},{"id":"t25-280","title":"白铜鞮","kind":"诗"},{"id":"t25-281","title":"杨叛儿","kind":"诗"},{"id":"t25-282","title":"春寒","kind":"诗"},{"id":"t25-283","title":"庐山独夜","kind":"诗"},{"id":"t25-284","title":"天台独夜","kind":"诗"},{"id":"t25-285","title":"送寒岩归士","kind":"诗"},{"id":"t25-286","title":"送陈司马","kind":"诗"},{"id":"t25-287","title":"武夷山仙城","kind":"诗"},{"id":"t25-288","title":"避暑二首 一","kind":"诗"},{"id":"t25-289","title":"避暑二首 二","kind":"诗"},{"id":"t25-290","title":"浙西李尚书奏毁淫昏庙","kind":"诗"},{"id":"t25-291","title":"酬相公再游云门寺","kind":"诗"},{"id":"t25-292","title":"杭州祝涛头二首 一","kind":"诗"},{"id":"t25-293","title":"杭州祝涛头二首 二","kind":"诗"},{"id":"t25-294","title":"问渔叟","kind":"诗"},{"id":"t25-295","title":"云封庵","kind":"诗"},{"id":"t25-296","title":"汉宫曲","kind":"诗"},{"id":"t25-297","title":"和嵩阳客月夜忆上清人","kind":"诗"},{"id":"t25-298","title":"八月望夕雨","kind":"诗"},{"id":"t25-299","title":"观浙江涛","kind":"诗"},{"id":"t25-300","title":"庐山瀑布","kind":"诗"},{"id":"t25-301","title":"嘉兴寒食","kind":"诗"},{"id":"t25-302","title":"忆扬州","kind":"诗"},{"id":"t25-303","title":"八月灯夕寄游越施秀才","kind":"诗"},{"id":"t25-304","title":"八月十五夜","kind":"诗"},{"id":"t25-305","title":"题伍员庙","kind":"诗"},{"id":"t25-306","title":"员峤先生","kind":"诗"},{"id":"t25-307","title":"莫愁曲","kind":"诗"},{"id":"t25-308","title":"寄白司马","kind":"诗"},{"id":"t25-309","title":"相思林","kind":"诗"},{"id":"t25-310","title":"寄海峤丈人","kind":"诗"},{"id":"t25-311","title":"寄潘先生","kind":"诗"},{"id":"t25-312","title":"宫中曲二首 一","kind":"诗"},{"id":"t25-313","title":"宫中曲二首 二","kind":"诗"},{"id":"t25-314","title":"七夕","kind":"诗"},{"id":"t25-315","title":"八月九月望夕雨","kind":"诗"},{"id":"t25-316","title":"喜雪","kind":"诗"},{"id":"t25-317","title":"春饮","kind":"诗"},{"id":"t25-318","title":"二月望日","kind":"诗"},{"id":"t25-319","title":"读远书","kind":"诗"},{"id":"t25-320","title":"古树","kind":"诗"},{"id":"t25-321","title":"独住僧","kind":"诗"},{"id":"t25-322","title":"伤画松道芬上人","kind":"诗"},{"id":"t25-323","title":"观钓台画图","kind":"诗"},{"id":"t25-324","title":"荆巫梦思","kind":"诗"}]},"惠文太子":{"slug":"惠文太子","name":"惠文太子","dynasty":"唐","style":"","life":"","origin":"","seal":"惠","bio":["太子名范，睿宗第四子。好学工书，爱儒士，无贵贱为尽礼，与阎朝隐、刘廷琦、张谔、郑繇等善，常饮酒赋诗相娱乐。初王郑，改封卫，俄降封巴陵。","从诛太平公主，以功赐封岐，薨。册书赠太子及谥。"],"works":[{"id":"t50-4","title":"句","kind":"诗"}]},"戴光乂":{"slug":"戴光乂","name":"戴光乂","dynasty":"唐","style":"","life":"","origin":"","seal":"戴","bio":["光乂，袁州人。有《回文诗》一卷，今不传。诗一首。","（《全唐诗》无戴光乂诗）"],"works":[{"id":"t56-417","title":"山居（七言）","kind":"诗"}]},"普闻":{"slug":"普闻","name":"普闻","dynasty":"唐","style":"","life":"","origin":"","seal":"普","bio":["普闻，初为唐僖宗太子。僖宗幸蜀，遂断发为僧。嗣石霜。","后住邵武龙湖寺三十余年。诗一首。（《全唐诗》无普闻诗）"],"works":[{"id":"t55-728","title":"临示寂声钟集众说偈","kind":"诗"}]},"李存勗":{"slug":"李存勗","name":"李存勗","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t55-219","title":"皇帝癸未年膺运灭梁再兴（缺）迎太后七言诗","kind":"诗"},{"id":"t55-220","title":"题北京西山童子寺七言","kind":"诗"},{"id":"t55-221","title":"题南岳山七言（直在江南）","kind":"诗"},{"id":"t55-222","title":"题幽州盘山七言（在幽州北）","kind":"诗"},{"id":"t55-223","title":"题幽州石经山（在南）","kind":"诗"}]},"李淛":{"slug":"李淛","name":"李淛","dynasty":"宋","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"c67-856","title":"踏莎行·红药香残","kind":"词"},{"id":"c67-857","title":"满庭芳·油幕新开","kind":"词"},{"id":"c67-858","title":"千秋岁·鄮峰凝瑞","kind":"词"}]},"李绛":{"slug":"李绛","name":"李绛","dynasty":"唐","style":"字深之","life":"","origin":"","seal":"李","bio":["李绛，字深之，赞皇人。登宏词科，授秘书省校书郎。贞元末，拜监察御史。","元和中，以本官充翰林学士，改中书舍人，寻拜中书侍郎，辅政多所匡益。以疾求罢，出为河中观察使，改兖海节度使。宝历初，入为尚书左仆射。","李逢吉恶之，罢为太子少师，分司东都。文宗即位，徴为太常卿，复出为山南西道节度使，兵乱遇害。集二十二卷，今存诗二首。"],"works":[{"id":"t17-142","title":"省试恩赐耆老布帛","kind":"诗"},{"id":"t17-143","title":"和裴相国荅张秘书赠马诗","kind":"诗"},{"id":"t43-564","title":"杏园联句","kind":"诗"},{"id":"t43-565","title":"花下醉中联句","kind":"诗"}]},"柳棠":{"slug":"柳棠","name":"柳棠","dynasty":"唐","style":"","life":"","origin":"","seal":"柳","bio":["柳棠，东川人，应进士举，才思优赡。开成中，杨汝士镇东川，棠每于座上赋诗狂纵，后参越巂军事卒。诗二首。","柳棠，东川人，应进士举，才思优赡。开成中，杨汝士镇东川，棠每于座上赋诗狂纵，后参越巂军事卒。诗二首。"],"works":[{"id":"t28-58","title":"荅杨尚书","kind":"诗"},{"id":"t28-59","title":"席上戏东川杨尚书","kind":"诗"},{"id":"t48-272","title":"荅杨尚书","kind":"诗"},{"id":"t48-273","title":"又忤杨尚书诗","kind":"诗"}]},"王丽真":{"slug":"王丽真","name":"王丽真","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"t48-30","title":"与曾季衡冥会诗 一","kind":"诗"},{"id":"t48-31","title":"与曾季衡冥会诗 二","kind":"诗"}]},"王希明":{"slug":"王希明","name":"王希明","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["希明，开元中任右拾遗内供奉。著有《太一金镜式经》十卷、《丹元子步天歌》一卷。诗三十一首。","（《全唐诗》无王希明诗，传据《新唐书·艺文志》）"],"works":[{"id":"t52-719","title":"丹元子步天歌 东方七宿 一","kind":"诗"},{"id":"t52-720","title":"丹元子步天歌 东方七宿 二","kind":"诗"},{"