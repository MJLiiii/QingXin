:"诗"},{"id":"t30-935","title":"长信宫","kind":"诗"},{"id":"t30-936","title":"闺情","kind":"诗"},{"id":"t30-937","title":"莲塘","kind":"诗"},{"id":"t30-938","title":"还淮却寄睢阳","kind":"诗"},{"id":"t30-939","title":"乌江","kind":"诗"},{"id":"t30-940","title":"新安故关","kind":"诗"},{"id":"t30-941","title":"广陵城","kind":"诗"},{"id":"t30-942","title":"过骊山","kind":"诗"},{"id":"t30-943","title":"吴故宫","kind":"诗"},{"id":"t30-944","title":"兰昌宫","kind":"诗"},{"id":"t30-945","title":"宫人斜","kind":"诗"},{"id":"t30-946","title":"句","kind":"诗"}]},"张正元":{"slug":"张正元","name":"张正元","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张正元，登贞元五年进士第，诗二首。"],"works":[{"id":"t17-129","title":"冬日可爱","kind":"诗"},{"id":"t17-130","title":"临川羡鱼","kind":"诗"}]},"悟真":{"slug":"悟真","name":"悟真","dynasty":"唐","style":"","life":"","origin":"","seal":"悟","bio":["悟真，瓜沙僧。大中五年入长安，诏奖之，赐紫，许巡礼两街诸寺，长安诗僧多赠以诗什。后任河西都僧统，年逾七十。","诗一首。（《全唐诗》无悟真诗）"],"works":[{"id":"t53-943","title":"辞谢辨章大德（题拟）","kind":"诗"}]},"李淮":{"slug":"李淮","name":"李淮","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t50-47","title":"句","kind":"诗"}]},"杏俏":{"slug":"杏俏","name":"杏俏","dynasty":"宋","style":"","life":"","origin":"","seal":"杏","bio":[],"works":[{"id":"c61-55","title":"满庭芳·景傍清明","kind":"词"}]},"江无□":{"slug":"江无□","name":"江无□","dynasty":"宋","style":"","life":"","origin":"","seal":"江","bio":[],"works":[{"id":"c76-642","title":"满江红·使节行秋","kind":"词"}]},"沈注":{"slug":"沈注","name":"沈注","dynasty":"宋","style":"","life":"","origin":"","seal":"沈","bio":[],"works":[{"id":"c58-676","title":"踏莎行·竹阁云深","kind":"词"}]},"洪子舆":{"slug":"洪子舆","name":"洪子舆","dynasty":"唐","style":"","life":"","origin":"","seal":"洪","bio":["洪子舆，睿宗时官侍御史，姜晦时为中丞，讽劾韦安石，子舆不从。诗一首。"],"works":[{"id":"t5-241","title":"严陵祠","kind":"诗"}]},"潘咸":{"slug":"潘咸","name":"潘咸","dynasty":"唐","style":"","life":"","origin":"","seal":"潘","bio":["潘咸，与喻凫同时，集一卷，今存诗五首。潘咸，与喻凫同时，集一卷，今存诗五首。"],"works":[{"id":"t29-932","title":"登明戍堡","kind":"诗"},{"id":"t29-933","title":"送陈明府之任","kind":"诗"},{"id":"t29-934","title":"长安春暮","kind":"诗"},{"id":"t29-935","title":"舟行","kind":"诗"},{"id":"t29-936","title":"送僧","kind":"诗"},{"id":"t29-937","title":"句","kind":"诗"},{"id":"t48-860","title":"芍药","kind":"诗"},{"id":"t53-739","title":"皇恩寺（题拟）","kind":"诗"}]},"罗弘信":{"slug":"罗弘信","name":"罗弘信","dynasty":"唐","style":"字德孚","life":"","origin":"","seal":"罗","bio":["罗弘信（新旧《唐书》并作弘信）字德孚，魏州贵乡人。僖宗时加金紫光禄大夫检校尚书右仆射，充魏博节度观察处置等使，卒昭宗光化元年，年六十三。（复出二首）（罗弘信，原作罗宏信，为《宛委别藏》本《分门纂类唐歌诗》抄写进奏时避清高宗讳而致，今予改回。","）"],"works":[{"id":"t50-911","title":"白菊（见《分门纂类唐歌诗》残本第六册《草本虫鱼类》卷五。按《全唐诗》卷七三四作罗绍威诗。绍威乃弘信之子。一作罗隐诗。）","kind":"诗"},{"id":"t50-912","title":"柳（见《分门纂类唐歌诗》残本第七册《草本虫鱼类》卷八。按《全唐诗》卷七三四亦作罗绍威诗。）","kind":"诗"}]},"罗汉和尚":{"slug":"罗汉和尚","name":"罗汉和尚","dynasty":"唐","style":"","life":"","origin":"","seal":"罗","bio":["罗汉和尚，始从襄州关南道常禅师学，后住漳州。诗二首。（《全唐诗》无罗汉和尚诗）"],"works":[{"id":"t54-142","title":"歌","kind":"诗"},{"id":"t54-143","title":"偈","kind":"诗"}]},"萧钧":{"slug":"萧钧","name":"萧钧","dynasty":"唐","style":"","life":"","origin":"","seal":"萧","bio":["钧，梁宗室之后。父珣，隋迁州刺史、梁国公。钧博学有才望。","贞观中，累除中书舍人，为房、魏所重。永徽二年，历迁谏议大夫，兼弘文馆学士，寻为太子率更令，兼崇贤馆学士。显庆中卒。","撰《韵旨》二十卷，有集三十卷，均不传。诗一首。（《全唐诗》无萧钧诗，传据《旧唐书》卷六三本传）"],"works":[{"id":"t52-110","title":"晚景游泛怀友诗","kind":"诗"}]},"薛媛":{"slug":"薛媛","name":"薛媛","dynasty":"唐","style":"","life":"","origin":"","seal":"薛","bio":["薛媛，濠梁人，南楚材妻也。诗一首。"],"works":[{"id":"t43-952","title":"写真寄夫","kind":"诗"}]},"薛涛":{"slug":"薛涛","name":"薛涛","dynasty":"唐","style":"字洪度 · 号薛涛笺","life":"","origin":"","seal":"薛","bio":["薛涛，字洪度。本长安良家女，随父宦，流落蜀中，遂入乐籍，辨慧工时，有林下风致。韦臯镇蜀，召令侍酒赋诗，称为女校书。","出入幕府，历事十一镇，皆以诗受知。暮年屏居浣花溪，著女冠服，好制松花小笺，时号薛涛笺。有《洪度集》一卷，今存编诗一卷。","薛涛字洪度，本长安人，随父宦流落蜀中。文宗大和五年卒，年六十四。补诗二首。"],"works":[{"id":"t44-142","title":"酬人雨后玩竹","kind":"诗"},{"id":"t44-143","title":"春望词四首 一","kind":"诗"},{"id":"t44-144","title":"春望词四首 二","kind":"诗"},{"id":"t44-145","title":"春望词四首 三","kind":"诗"},{"id":"t44-146","title":"春望词四首 四","kind":"诗"},{"id":"t44-147","title":"宣上人见示与诸公唱和","kind":"诗"},{"id":"t44-148","title":"风","kind":"诗"},{"id":"t44-149","title":"月","kind":"诗"},{"id":"t44-150","title":"蝉","kind":"诗"},{"id":"t44-151","title":"池上双鸟","kind":"诗"},{"id":"t44-152","title":"鸳鸯草","kind":"诗"},{"id":"t44-153","title":"罚赴边有怀上韦令公二首 一","kind":"诗"},{"id":"t44-154","title":"罚赴边有怀上韦令公二首 二","kind":"诗"},{"id":"t44-155","title":"咏八十一颗","kind":"诗"},{"id":"t44-156","title":"谒巫山庙","kind":"诗"},{"id":"t44-157","title":"牡丹","kind":"诗"},{"id":"t44-158","title":"贼平后上高相公","kind":"诗"},{"id":"t44-159","title":"送友人","kind":"诗"},{"id":"t44-160","title":"听僧吹芦管","kind":"诗"},{"id":"t44-161","title":"酬郭简州寄柑子","kind":"诗"},{"id":"t44-162","title":"上川主武元衡相国二首 一","kind":"诗"},{"id":"t44-163","title":"上川主武元衡相国二首 二","kind":"诗"},{"id":"t44-164","title":"忆荔枝","kind":"诗"},{"id":"t44-165","title":"斛石山晓望寄吕侍御","kind":"诗"},{"id":"t44-166","title":"寄词","kind":"诗"},{"id":"t44-167","title":"斛石山书事","kind":"诗"},{"id":"t44-168","title":"送姚员外","kind":"诗"},{"id":"t44-169","title":"酬祝十三秀才","kind":"诗"},{"id":"t44-170","title":"别李郎中","kind":"诗"},{"id":"t44-171","title":"送扶炼师","kind":"诗"},{"id":"t44-172","title":"摩诃池赠萧中丞","kind":"诗"},{"id":"t44-173","title":"乡思","kind":"诗"},{"id":"t44-174","title":"和李书记席上见赠","kind":"诗"},{"id":"t44-175","title":"棠梨花和李太尉","kind":"诗"},{"id":"t44-176","title":"酬文使君","kind":"诗"},{"id":"t44-177","title":"酬吴随君","kind":"诗"},{"id":"t44-178","title":"酬李校书","kind":"诗"},{"id":"t44-179","title":"赋凌云寺二首 一","kind":"诗"},{"id":"t44-180","title":"赋凌云寺二首 二","kind":"诗"},{"id":"t44-181","title":"九日遇雨二首 一","kind":"诗"},{"id":"t44-182","title":"九日遇雨二首 二","kind":"诗"},{"id":"t44-183","title":"酬雍秀才贻巴峡图","kind":"诗"},{"id":"t44-184","title":"上王尚书","kind":"诗"},{"id":"t44-185","title":"和刘宾客玉蕣","kind":"诗"},{"id":"t44-186","title":"江边","kind":"诗"},{"id":"t44-187","title":"送卢员外","kind":"诗"},{"id":"t44-188","title":"题竹郎庙","kind":"诗"},{"id":"t44-189","title":"赠苏十三中丞","kind":"诗"},{"id":"t44-190","title":"和郭员外题万里桥","kind":"诗"},{"id":"t44-191","title":"送郑眉州","kind":"诗"}]},"谭峭":{"slug":"谭峭","name":"谭峭","dynasty":"唐","style":"字景升","life":"","origin":"","seal":"谭","bio":["谭峭，字景升，国子司业洙之子。博涉经史，属文清丽。洙训以进士业，而峭酷好黄老书，辞父远游，师嵩山道士，得辟谷养气之术，后入青城山仙去。"],"works":[{"id":"t47-741","title":"大言诗","kind":"诗"},{"id":"t47-742","title":"大言诗","kind":"诗"},{"id":"t47-743","title":"句","kind":"诗"}]},"钟谟":{"slug":"钟谟","name":"钟谟","dynasty":"唐","style":"字仲益","life":"","origin":"","seal":"钟","bio":["钟谟，字仲益，其先会稽人，徙闽之崇安，已而侨居金陵。李璟时，为翰林学士，进礼部侍郎、判尚书省。诗三首。"],"works":[{"id":"t42-409","title":"贻耀州将","kind":"诗"},{"id":"t42-410","title":"献周世宗","kind":"诗"},{"id":"t42-411","title":"代京妓越宾荅徐铉","kind":"诗"},{"id":"t55-473","title":"招徐鼎臣（题拟）","kind":"诗"}]},"钱弘儇":{"slug":"钱弘儇","name":"钱弘儇","dynasty":"唐","style":"字智仁","life":"","origin":"","seal":"钱","bio":["钱弘儇字智仁，文穆王第二子。本名弘偁，能书有文而自晦。后周时为静海军节度使判军州事，政尚宽惠，民悦慕之。","久之改彰武军节度使知福州事，温人皆行啼巷哭，亦有擕家以从者，谓之随使百姓。诗一首。（《全唐诗》无钱宏儇诗）"],"works":[{"id":"t55-584","title":"游南雁荡","kind":"诗"}]},"隐峰":{"slug":"隐峰","name":"隐峰","dynasty":"唐","style":"","life":"","origin":"","seal":"隐","bio":["隐峰，俗姓邓，邵武人。嗣马祖。元和中，移住五台山，时称邓隐峰和尚。","诗一首。（《全唐诗》无隐峰诗，传据《五灯会元》卷三）"],"works":[{"id":"t53-418","title":"偈","kind":"诗"}]},"韩倩":{"slug":"韩倩","name":"韩倩","dynasty":"唐","style":"","life":"","origin":"","seal":"韩","bio":["倩，京兆长安人，休弟，仕至左庶子、殿中丞。诗一首。（《全唐诗》无韩倩诗。","事迹据《元和姓纂》卷四、《旧唐书》卷九八《韩休传》、《新唐书》卷七三上《宰相世系表》）"],"works":[{"id":"t52-795","title":"送贺秘监归会稽诗","kind":"诗"}]}}