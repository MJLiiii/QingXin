[{"id":"c61-600","title":"□□□・更漏子·酒三行","rhythmic":"□□□・更漏子","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["酒三行，琴再弄。","宛是和鸣双凤。","罗斗帐，绣屏风。","浓香夜夜同。","去年欢，今夕梦。","怊怅晓钟初动。","休道梦，觉来空。","当时亦梦中。"]},{"id":"c61-601","title":"弄珠英・蓦山溪·楚乡新岁","rhythmic":"弄珠英・蓦山溪","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["楚乡新岁。","不放残寒退。","月晓桂娥闲，弄珠英、因风委坠。","清淮铺练，十二玉峰前，上帘栊，招佳丽。","置酒成高会。","江南芳信，目断何人寄。","应占镜边春，想晨妆、膏浓压翠。","此时乘兴，半道忍回桡，五云溪，门深闭。","碧月长相对。"]},{"id":"c61-602","title":"梦相亲・玉楼春·清琴再鼓求凰弄","rhythmic":"梦相亲・玉楼春","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["清琴再鼓求凰弄。","紫陌屡盘骄马鞚。","远山眉样认心期，流水车音牵目送。","归来翠被和衣拥。","醉解寒生钟鼓动。","此欢只许梦相亲，每向梦中还说梦。"]},{"id":"c61-603","title":"罗敷歌・采桑子·高楼帘卷秋风里","rhythmic":"罗敷歌・采桑子","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["高楼帘卷秋风里，目送斜阳。","衾枕遗香。","今夜还如昨夜长。","玉人望月销凝处，应在西厢。","半掩兰堂。","惟有纱灯伴绣床。"]},{"id":"c61-604","title":"罗敷歌・采桑子·河阳官罢文园病","rhythmic":"罗敷歌・采桑子","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["河阳官罢文园病，触绪萧然。","犀麈流连。","喜见清蟾似旧圆。","人生聚散浮云似，回首明年。","何处尊前。","怅望星河共一天。"]},{"id":"c61-605","title":"罗敷歌・采桑子·东南自古繁华地","rhythmic":"罗敷歌・采桑子","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["东南自古繁华地，歌吹扬州。","十二青楼。","最数秦娘第一流。","季鹰久负鲈鱼兴，不住今秋。","已办归舟。","伴我江湖作胜游。"]},{"id":"c61-606","title":"罗敷歌・采桑子·自怜楚客悲秋思","rhythmic":"罗敷歌・采桑子","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["自怜楚客悲秋思，难写丝桐。","目断书鸿。","平淡江山落照中。","谁家水调声声怨，黄叶西风。","罨画桥东。","十二玉楼空更空。"]},{"id":"c61-607","title":"罗敷歌・采桑子·东亭南馆逢迎地","rhythmic":"罗敷歌・采桑子","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["东亭南馆逢迎地，几醉红裙。","凄怨临分。","四叠阳关忍泪闻。","谁怜今夜篷窗雨，何处渔村。","酒冷灯昏。","不许愁人不断魂。"]},{"id":"c61-608","title":"小重山·玉指金徽一再弹","rhythmic":"小重山","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["玉指金徽一再弹。","新声传访戴，雪溪寒。","两行墨妙破冰纨。","牵情处，幽恨寄毫端。","昵语强羞难。","相逢真许似，镜中鸾。","小梅疏影近杯盘。","东风里，谁共倚阑干。"]},{"id":"c61-609","title":"小重山·帘影新妆一破颜","rhythmic":"小重山","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["帘影新妆一破颜。","玳筵回雪舞，小云鬟。","琼枝擢秀望难攀。","凝情处，千里望蓬山。","歌断酒阑珊。","画船箫鼓转，绿杨湾。","坠钿残燎水堂关。","斜阳里，双燕伴人闲。"]},{"id":"c61-610","title":"小重山·枕上阊门五报更","rhythmic":"小重山","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["枕上阊门五报更。","蜡灯香灺冷，恨天明。","青苹风转彩帆轻。","樯头燕，多谢伴人行。","临镜想倾城。","两尖愁黛浅，泪波横。","艳歌重记遣离情。","缠绵处，翻是断肠声。"]},{"id":"c61-611","title":"小重山·月月相逢只旧圆","rhythmic":"小重山","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["月月相逢只旧圆。","迢迢三十夜，夜如年。","伤心不照绮罗筵。","孤舟里，单枕若为眠。","茂苑想依然。","花楼连苑起，压漪涟。","玉人千里共婵娟。","清琴怨，肠断亦如弦。"]},{"id":"c61-612","title":"河传·华堂张燕","rhythmic":"河传","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["华堂张燕。","向尊前妙选，舞裙歌扇。","彼美个人，的的风流心眼。","恨寻芳来晚。","曲街灯火香尘散。","犹约晨妆，一觇春风面。","惆怅善和坊里，平桥南畔。","小青楼、帘不卷。"]},{"id":"c61-613","title":"河传·华堂重厦","rhythmic":"河传","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["华堂重厦，向尊前更听，碧云新怨。","玉指钿徽，总是挑人心眼。","恨随红蜡短。","彩旗影动船头转。","双桨凌波，惟念人留恋。","江上暮潮，隐隐山横南岸。","奈离愁、分不断。"]},{"id":"c61-614","title":"侍香金童·楚梦方回","rhythmic":"侍香金童","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["楚梦方回，翠被寒如水。","尚想见、扬州桃李。","姿秀韵闲何物比。","玉管秋风，漫声流美。","燕堂开，双按秦弦呈素指。","宝雁参差飞不起。","三五彩蟾明夜是。","屈曲阑干，断肠千里。"]},{"id":"c61-615","title":"凤栖梧・蝶恋花·独立江东人婉娈","rhythmic":"凤栖梧・蝶恋花","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["独立江东人婉娈。","粉本花真，千里依稀见。","闲弄彩毫濡玉砚。","缠绵春思□歌扇。","爱我竹窗新句练。","小砑凌笺、偷寄西风燕。","乍可问名赊识面。","十年多病风情浅。"]},{"id":"c61-616","title":"更漏子·芳草斜曛","rhythmic":"更漏子","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["芳草斜曛。","映画桥□□，翠阁临津。","数阕清歌，两行红粉，厌厌别酒初曛。","芳意赠我殷勤。","罗巾双黛痕。","便兰舟独上，洞府人闲，素手轻分。","十里绮陌香尘。","望紫云车远，已掩青门。","迤逦黄昏，景阳钟动，临风隐隐犹闻。","明朝水馆渔村。","凭谁招断魂。","恨不如今夜，明月多情，应待归云。"]},{"id":"c61-617","title":"玉京秋·陇首霜晴","rhythmic":"玉京秋","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["陇首霜晴，泗滨云晚，乍摇落。","废榭苍苔，破台荒草，西楚霸图冥漠。","记登临事，九日胜游，千载如昨。","更想像，晋客□归，谢生能赋继高作。","飘泊。","尘埃倦客，风月羁心，潘鬓晓来清镜觉。","蜡屐纶巾，羽觞象管，且追随、隼旟行乐。","东山□，应笑个侬风味薄。","念故园黄花，自有年年约。"]},{"id":"c61-618","title":"蕙清风·何许最悲秋","rhythmic":"蕙清风","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["何许最悲秋，凄风残照。","临水复登山，莞然西笑。","车马几番尘，自古长安道。","问谁是、后来年少。","飞集两悠悠，江滨海岛。","乘雁与双凫，强分多少。","传语酒家胡，岁晚从吾好。","待做个、醉乡遗老。"]},{"id":"c61-619","title":"虞美人·粉娥齐敛千金笑","rhythmic":"虞美人","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["粉娥齐敛千金笑。","愁结眉峰小。","渭城才唱浥轻尘。","无奈两行红泪、湿香巾。","伤心风月南城道。","几纵朱轓到。","明年载酒洛阳春。","还念淮山楼上、倚阑人。"]},{"id":"c61-620","title":"下水船·芳草青门路","rhythmic":"下水船","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["芳草青门路。","还拂京尘东去。","回想当年离绪。","送君南浦。","愁几许。","尊酒流连薄暮。","帘卷津楼风雨。","凭阑语。","草草蘅皋赋。","分首惊鸿不驻。","灯火虹桥，难寻弄波微步。","漫凝伫。","莫怨无情流水，明月扁舟何处。"]},{"id":"c61-621","title":"点绛唇·见面无多","rhythmic":"点绛唇","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["见面无多，坐来百媚生馀态。","后庭春在。","折取残红戴。","小小兰舟，荡桨东风快。","何愁载。","缠绵难解。","不似罗裙带。"]},{"id":"c61-622","title":"渔家傲·莫厌香醪斟绣履","rhythmic":"渔家傲","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["莫厌香醪斟绣履。","吐茵也是风流事。","今夜夜寒愁不睡。","披衣起。","挑灯开卷花生纸。","倩问尊前桃与李。","重来若个犹相记。","前度刘郎应老矣。","行乐地。","兔葵燕麦春风里。"]},{"id":"c61-623","title":"感皇恩·歌笑见馀妍","rhythmic":"感皇恩","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["歌笑见馀妍，情生眄睐。","拥髻扬蛾黛。","多态。","小花深院，漏促离襟将解。","恼人红蜡泪。","啼相对。","芳草唤愁，愁来难奈。","兰叶犹堪向谁采。","小楼妆晚，应念斑骓何在。","碧云长有待。","斜阳外。"]},{"id":"c61-624","title":"菩萨蛮·彩舟载得离愁动","rhythmic":"菩萨蛮","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["彩舟载得离愁动。","无端更借樵风送。","波渺夕阳迟。","销魂不自持。","良宵谁与共。","赖有窗间梦。","可奈梦回时。","一番新别离。"]},{"id":"c61-625","title":"菩萨蛮·章台游冶金龟婿","rhythmic":"菩萨蛮","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["章台游冶金龟婿。","归来犹带醺醺醉。","花漏怯春宵。","云屏无限娇。","绛纱灯影背。","玉枕钗声碎。","不待宿酲销。","马嘶催早朝。"]},{"id":"c61-626","title":"菩萨蛮·曲门南与鸣珂接","rhythmic":"菩萨蛮","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["曲门南与鸣珂接。","小园绿径飞胡蝶。","下马访婵娟。","笑迎妆阁前。","鹧鸪声几叠。","艳艳金蕉叶。","未许被香鞯。","月生楼外天。"]},{"id":"c61-627","title":"菩萨蛮·绿窗残梦闻鶗鴂","rhythmic":"菩萨蛮","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["绿窗残梦闻鶗鴂。","曲屏映枕春山叠。","梳□发如蝉。","镜生波上莲。","绛裙金缕褶。","学舞腰肢怯。","帘下小凭肩。","与人双翠钿。"]},{"id":"c61-628","title":"菩萨蛮·绿杨眠后拖烟穗","rhythmic":"菩萨蛮","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["绿杨眠后拖烟穗。","日长扫尽青苔地。","香断入帘风。","炉心檀烬红。","兰溪修祓禊。","上巳明朝是。","不许放春慵。","景阳临晓钟。"]},{"id":"c61-629","title":"菩萨蛮·粉香映叶花羞日","rhythmic":"菩萨蛮","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["粉香映叶花羞日。","窗间宛转蜂寻蜜。","欢罢卷帘时。","玉纤匀面脂。","舞裙金斗熨。","绛襭鸳鸯密。","翠带一双垂。","索人题艳诗。"]},{"id":"c61-630","title":"菩萨蛮·子规啼梦罗窗晓","rhythmic":"菩萨蛮","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["子规啼梦罗窗晓。","开奁拂镜严妆早。","彩碧画丁香。","背垂裙带长。","钿筝寻旧曲。","愁结眉心绿。","犹恨夜来时。","酒狂归太迟。"]},{"id":"c61-631","title":"菩萨蛮·虚堂向壁青灯灭","rhythmic":"菩萨蛮","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["虚堂向壁青灯灭。","觉来惊见横窗月。","起看月平西。","城头乌夜啼。","兰衾羞更入。","敧枕偷声泣。","肠断数残更。","望明天未明。"]},{"id":"c61-632","title":"菩萨蛮·芭蕉衬雨秋声动","rhythmic":"菩萨蛮","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["芭蕉衬雨秋声动。","罗窗恼破鸳鸯梦。","愁倚□帘栊。","灯花落地红。","枕横衾浪拥。","好夜无人共。","莫道粉墙东。","蓬山千万重。"]},{"id":"c61-633","title":"菩萨蛮·朱甍碧树莺声晓","rhythmic":"菩萨蛮","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["朱甍碧树莺声晓。","残醺残梦犹相恼。","薄雨隔轻帘。","寒侵白纻衫。","锦屏人起早。","惟见馀妆好。","眉样学新蟾。","春愁入翠尖。"]},{"id":"c61-634","title":"菩萨蛮·炉烟微度流苏帐","rhythmic":"菩萨蛮","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["炉烟微度流苏帐。","孤衾冷叠芙蓉浪。","蟋蟀不离床。","伴人愁夜长。","玉人飞阁上。","见月还相望。","相望莫相忘。","应无未断肠。"]},{"id":"c61-635","title":"于飞乐·日薄云融","rhythmic":"于飞乐","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["日薄云融。","满城罗绮芳丛。","一枝粉淡香浓。","几销魂，偏健羡、紫蝶黄蜂。","繁华梦断，酒醒来、扫地春空。","武陵原、回头何处，情随流水无穷。","寄两行清泪，想几许残红。","惜花人老，年年奈、依旧东风。"]},{"id":"c61-636","title":"浣溪沙·双鹤横桥阿那边","rhythmic":"浣溪沙","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["双鹤横桥阿那边。","静坊深院闭婵娟。","五度花开三处见，两依然。","水眄难禁频领□，歌云犹许小流连。","破得尊前何限恨，不论钱。"]},{"id":"c61-637","title":"品令·怀彼美","rhythmic":"品令","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["怀彼美。","愁与泪。","分占眉丛眼尾。","求好梦、闲拥鸳鸯绮。","恨啼鸟、唤人起。","目断清淮楼上，心寄长洲坊里。","迢迢地。","七百三十里。","几重山，几重水。"]},{"id":"c61-638","title":"海月谣·楼平叠巘","rhythmic":"海月谣","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["楼平叠巘。","瞰瀛海、波三面。","碧云扫尽，桂轮滉玉，鲸波张练。","化出无边宝界，是名壮观。","追游汗漫。","愿少借、长风便。","麻姑相顾，□然笑指，寒潮清浅。","顿觉蓬莱方丈，去人不远。"]},{"id":"c61-639","title":"风流子·何处最难忘","rhythmic":"风流子","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["何处最难忘。","方豪健，放乐五云乡。","彩笔赋诗，禁池芳草，香鞯调马，辇路垂杨。","绮筵上，扇偎歌黛浅，汗浥舞罗香。","兰烛伴归，绣轮同载，闭花别馆，隔水深坊。","零落少年场。","琴心漫流怨，带眼偷长。","无奈占床燕月，侵鬓吴霜。","念北里音尘，鱼封永断，便桥烟雨，鹤表相望。","好在后庭桃李，应记刘郎。"]},{"id":"c61-640","title":"鹧鸪天·轰醉王孙玳瑁筵","rhythmic":"鹧鸪天","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["轰醉王孙玳瑁筵。","渴虹垂地吸长川。","侧商调里清歌送，破尽穷愁直几钱。","孤棹舣，小江边。","爱而不见酒中仙。","伤心两岸官杨柳，已带斜阳又带蝉。"]},{"id":"c61-641","title":"忆仙姿・如梦令·白纻春衫新制","rhythmic":"忆仙姿・如梦令","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["白纻春衫新制。","准拟采兰修禊。","遮日走京尘，何啻分阴如岁。","留滞。","留滞。","不似行云难系。"]},{"id":"c61-642","title":"忆仙姿・如梦令·日日春风楼上","rhythmic":"忆仙姿・如梦令","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["日日春风楼上。","不见石城双桨。","鸳枕梦回时，烛泪屏山相向。","流荡。","流荡。","门外白苹溪涨。"]},{"id":"c61-643","title":"忆仙姿・如梦令·相见时难别易","rhythmic":"忆仙姿・如梦令","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["相见时难别易。","何限玉琴心意。","眉黛只供愁，羞见双鸳鸯字。","憔悴。","憔悴。","蜡烛销成红泪。"]},{"id":"c61-644","title":"忆仙姿・如梦令·罗绮丛中初见","rhythmic":"忆仙姿・如梦令","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["罗绮丛中初见。","理鬓横波流转。","半醉不胜情，帘影犹招歌扇。","留恋。","留恋。","秋夜辞巢双燕。"]},{"id":"c61-645","title":"忆仙姿・如梦令·雨后一分春减","rhythmic":"忆仙姿・如梦令","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["雨后一分春减。","深院落红如糁。","柳外出秋千，度日彩旗风飐。","销黯。","销黯。","门共宝奁长掩。"]},{"id":"c61-646","title":"忆仙姿・如梦令·柳下玉骢双鞚","rhythmic":"忆仙姿・如梦令","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["柳下玉骢双鞚。","蝉鬓宝钿浮动。","半醉倚迷楼，聊送斜阳三弄。","豪纵。","豪纵。","一觉扬州春梦。"]},{"id":"c61-647","title":"忆仙姿・如梦令·何处偷谐心赏","rhythmic":"忆仙姿・如梦令","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["何处偷谐心赏。","促坐绮罗筵上。","不记下楼时，醉□月侵书幌。","怀想。","怀想。","清丽歌声妆样。"]},{"id":"c61-648","title":"忆仙姿・如梦令·江上潮回风细","rhythmic":"忆仙姿・如梦令","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["江上潮回风细。","红袖倚楼凝睇。","天际认归舟，但见平林如荠。","迢递。","迢递。","人更远於天际。"]},{"id":"c61-649","title":"忆仙姿・如梦令·梦想山阴游冶","rhythmic":"忆仙姿・如梦令","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["梦想山阴游冶。","深径碧桃花谢。","曲水稳流觞，暖絮芳兰堪藉。","萧洒。","萧洒。","月棹烟蓑东下。"]},{"id":"c61-650","title":"凤栖梧・蝶恋花·挑菜踏青都过却","rhythmic":"凤栖梧・蝶恋花","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["挑菜踏青都过却。","杨柳风轻，摆动秋千索。","啼鸟自惊花自落。","有人同在真珠箔。","淡净衣裳妆□薄。","闲凭银筝，睡鬓慵梳掠。","试问为谁添瘦弱。","娇羞只把眉颦著。"]},{"id":"c61-651","title":"相思引·终日怀归翻送客","rhythmic":"相思引","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["终日怀归翻送客。","春风祖席。","南成陌。","便莫惜。","离觞频卷白。","动管色。","催行色。","动管色。","催行色。","何处投鞍风雨夕。","临水驿。","空山驿。","临水驿。","空山驿。","纵明月相思千里隔。","梦咫尺。","勤书尺。","梦咫尺。","勤书尺。"]},{"id":"c61-652","title":"芳草渡・系裙腰·留征辔","rhythmic":"芳草渡・系裙腰","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["留征辔，送离杯。","羞泪下，拈青梅。","低声问道几时回。","秦筝雁促，此夜为谁排。","君去也，远蓬莱。","千里地，信音乖。","相思成病底情怀。","和烦恼，寻个便，送将来。"]},{"id":"c61-653","title":"雨中花・夜行船·回首扬州","rhythmic":"雨中花・夜行船","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["回首扬州，猖狂十载，依然一梦归来。","但觉安仁愁鬓，几点尘埃。","醉墨碧纱犹锁，春衫白纻新裁。","认鸣珂曲里，旧日朱扉，闲闭青苔。","人非物是，半晌鸾肠易断，宝勒空回。","徒怅望、碧云销散，明月徘徊。","忍过阳台折柳，难凭陇驿传梅。","一番桃李，迎风无语，谁是怜才。"]},{"id":"c61-654","title":"花心动·西郭园林","rhythmic":"花心动","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["西郭园林，远尘烦，门临绿杨堤路。","画□簟长，水馆帘空，竟日素襟销暑。","小湾红芰清香里，深隐映、风标鸳鹭。","指□□，相将故故，背人飞去。","翻念多情自苦。","当置酒徵歌，梦云难驻。","醉眼渐迷，花拂墙低，误认宋邻偷顾。","彩阑倚遍平桥晚，空相望、凌波仙步。","断魂处，黄昏翠荷□雨。"]},{"id":"c61-655","title":"浪淘沙·把酒欲歌骊","rhythmic":"浪淘沙","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["把酒欲歌骊。","浓醉何辞。","玉京烟柳欲黄时。","明日景阳门外路，相背春归。","敛泪复牵衣。","私语迟迟。","可怜谁会两心期。","惟有画帘斜月见，应共人知。"]},{"id":"c61-656","title":"浪淘沙·一十二都门","rhythmic":"浪淘沙","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["一十二都门。","梦想能频。","无言桃李几经春。","艳粉鲜香开自落，还为何人。","白纻别时新。","苒苒征尘。","镜中消瘦老於真。","赖有天涯风月在，依旧相亲。"]},{"id":"c61-657","title":"浪淘沙·潮涨湛芳桥","rhythmic":"浪淘沙","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["潮涨湛芳桥。","难渡兰桡。","卷帘红袖莫相招。","十二阑干今夜月，谁伴吹箫。","烟草接亭皋。","归思迢迢。","兰成老去转无憀。","偏恨秋风添鬓雪，不共魂销。"]},{"id":"c61-658","title":"浪淘沙·雨过碧云秋","rhythmic":"浪淘沙","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["雨过碧云秋。","烟草汀洲。","远山相对一眉愁。","可惜芳年桥畔柳，不系兰舟。","为问木兰舟。","何处淹留。","相思今夜忍登楼。","楼下谁家歌水调，明月扬州。"]},{"id":"c61-659","title":"夜游宫·江面波纹皱縠","rhythmic":"夜游宫","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["江面波纹皱縠。","江南岸、草和烟绿。","初过寒食一百六。","采苹游，□香裙，鸣佩玉。","心事偷相属。","赋春恨、彩笺双幅。","今夜小楼吹凤竹。","谢东风，寄情人，肠断曲。"]},{"id":"c61-660","title":"忆仙姿・如梦令·莲叶初生南浦","rhythmic":"忆仙姿・如梦令","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["莲叶初生南浦。","两岸绿杨飞絮。","向晚鲤鱼风，断送彩帆何处。","凝伫。","凝伫。","楼外一江烟雨。"]},{"id":"c61-661","title":"忆仙姿・如梦令·彩舫解维官柳","rhythmic":"忆仙姿・如梦令","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["彩舫解维官柳。","楼上谁家红袖。","团扇弄微风，如为行人招手。","回首。","回首。","云断武陵溪口。"]},{"id":"c61-662","title":"菱花怨·叠鼓嘲喧","rhythmic":"菱花怨","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["叠鼓嘲喧，彩旗挥霍，苹汀薄晚，兰舟催解。","别浦潮平，小山云断，十幅饱帆风快。","回想牵衣，愁掩啼妆，一襟香在。","纨扇惊秋，菱花怨晚，谁共蛾黛。","何处玉尊空，对松陵正美，鲈鱼苽菜。","露洗凉蟾，潦吞平野，三万顷非尘界。","览胜情无奈。","恨难招、越人同载。","会凭紫燕西飞，更约黄鹂相待。"]},{"id":"c61-663","title":"望扬州・长相思慢·铁瓮城高","rhythmic":"望扬州・长相思慢","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["铁瓮城高，蒜山渡阔，干云十二层楼。","开尊待月，卷箔披风，依然灯火扬州。","绣陌南头。","记歌名宛转，乡号温柔。","曲槛俯清流。","想花阴、谁系兰舟。","念凄绝秦弦，感深荆赋，相望几许凝愁。","殷勤裁尺素，奈双鱼、难渡瓜洲。","晓鉴堪羞。","潘鬓点、吴霜渐稠。","幸于飞、鸳鸯未老，不应同是悲秋。"]},{"id":"c61-664","title":"定情曲·沈水浓熏","rhythmic":"定情曲","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["沈水浓熏，眉粉淡妆，露华鲜映春晓。","浅颦轻笑。","真物外，一种闲花风调。","可待合欢翠被，不见忘忧芳草。","拥膝浑忘羞，回身就郎抱。","两点灵犀心颠倒。","念乐事稀逢，归期须早。","五云闻道。","星桥畔、油壁车迎苏小。","引领西陵自远，携手东山偕老。","殷勤制、双凤新声，定情永为好。"]},{"id":"c61-665","title":"拥鼻吟・吴音子·别酒初销","rhythmic":"拥鼻吟・吴音子","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["别酒初销，怃然弭棹蒹葭浦。","回首不见高城，青楼更何许。","大艑轲峨，越商巴贾。","万恨龙锺，篷下对语。","指征路。","山缺处，孤烟起，历历闻津鼓。","江豚吹浪，晚来风转夜深雨。","拥鼻微吟，断肠新句。","粉碧罗笺，封泪寄与。"]},{"id":"c61-666","title":"思越人・朝天子·京口瓜洲记梦间","rhythmic":"思越人・朝天子","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["京口瓜洲记梦间。","朱扉犹想映花关。","东风太是无情思，不许扁舟兴尽还。","春水漫，夕阳闲。","乌樯几转绿杨湾。","红尘十里扬州过，更上迷楼一借山。"]},{"id":"c61-667","title":"清平乐·吴波不动","rhythmic":"清平乐","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["吴波不动。","四际晴山拥。","载酒一尊谁与共。","回首江湖旧梦。","长艚珠箔青篷。","橹声鸦轧征鸿。","泪□镂檀香枕，醉眠摇□春风。"]},{"id":"c61-668","title":"清平乐·宋邻东畔","rhythmic":"清平乐","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["宋邻东畔。","明月关深院。","玉指金徽调旧怨。","楚客归心欲断。","城隅芳草初春。","佳期重约临分。","丽句漫题双带，也愁系住行云。"]},{"id":"c61-669","title":"清平乐·厌厌别酒","rhythmic":"清平乐","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["厌厌别酒。","更执纤纤手。","指似归期庭下柳。","一叶西风前后。","无端不系孤舟。","载将多少离愁。","又是十分明月，照人两处登楼。"]},{"id":"c61-670","title":"木兰花・玉楼春·嫣然何啻千金价","rhythmic":"木兰花・玉楼春","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["嫣然何啻千金价。","意远态闲难入画。","更无方便只尊前，说尽牵情多少话。","别来乐事经春罢。","枉度佳春抛好夜。","如今触绪易销魂，最是不堪风月下。"]},{"id":"c61-671","title":"木兰花・玉楼春·朝来著眼沙头认","rhythmic":"木兰花・玉楼春","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["朝来著眼沙头认。","五两竿摇风色顺。","佳期学取弄潮儿，人纵无情潮有信。","纷纷花雨红成阵。","冷酒青梅寒食近。","漫将江水比闲愁，水尽江头愁不尽。"]},{"id":"c61-672","title":"减字木兰花·春容秀润","rhythmic":"减字木兰花","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["春容秀润。","二十四番花有信。","鸾镜佳人。","得得浓妆样样新。","情无远近。","水阔山长分不尽。","一断音尘。","泪眼花前只见春。"]},{"id":"c61-673","title":"减字木兰花·闲情减旧","rhythmic":"减字木兰花","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["闲情减旧。","无奈伤春能作瘦。","桂楫兰舟。","几送人归我滞留。","西门官柳。","满把青青临别手。","谁共登楼。","分取烟波一段愁。"]},{"id":"c61-674","title":"减字木兰花·南园清夜","rhythmic":"减字木兰花","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["南园清夜。","临水朱阑垂柳下。","从坐莲花。","潋滟觥船泛露华。","酒阑歌罢。","双□前愁东去也。","回想人家。","芳草平桥一径斜。"]},{"id":"c61-675","title":"减字木兰花·多情多病","rhythmic":"减字木兰花","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["多情多病。","万斛闲愁量有剩。","一顾倾城。","惟觉尊前笑不成。","探香幽径。","好住东风谁主领。","多谢流莺。","欲别频啼四五声。"]},{"id":"c61-676","title":"摊破木兰花・木兰花·南浦东风落暮潮","rhythmic":"摊破木兰花・木兰花","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["南浦东风落暮潮。","祓禊人归，相并兰桡。","回身昵语不胜娇。","犹碍华灯，扇影频摇。","重泛青翰顿寂寥。","魂断高城手漫招。","佳期应待鹊成桥。","为问行云，谁伴朝朝。"]},{"id":"c61-677","title":"摊破木兰花・木兰花·芳草裙腰一尺围","rhythmic":"摊破木兰花・木兰花","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["芳草裙腰一尺围。","粉郎香润，清洒蔷薇。","为嫌风日下楼稀。","杨柳青阴，深闭朱扉。","枉是尊前调玉徽。","彩鸾何事逐鸡飞。","楚台赋客莫相违。","留住行云，好待郎归。"]},{"id":"c61-678","title":"南乡子·秋半雨凉天","rhythmic":"南乡子","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["秋半雨凉天。","望后清蟾未破圆。","二十四桥游冶处，留连。","携手娇饶步步莲。","眉宇有馀妍。","初破瓜时正妙年。","玉局弹棋无限意，缠绵。","肠断吴蚕两处眠。"]},{"id":"c61-679","title":"南乡子·柳岸舣兰舟","rhythmic":"南乡子","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["柳岸舣兰舟。","更结东山谢氏游。","红泪清歌催落景，回头。","□出尊前一段愁。","东水漫西流。","谁道行云肯驻留。","无限鲜飙吹芷若，汀洲。","生羡鸳鸯得自由。"]},{"id":"c61-680","title":"临江仙·暂假临淮东道主","rhythmic":"临江仙","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["暂假临淮东道主，每逃歌舞华筵。","经年未办买山钱。","筋骸难强，久坐沐猴禅。","行拥一舟称浪士，五湖春水如天。","越人相顾足嫣然。","何须绣被，来伴拥蓑眠。"]},{"id":"c61-681","title":"罗敷歌・采桑子·东山未办终焉计","rhythmic":"罗敷歌・采桑子","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["东山未办终焉计，聊尔西来。","花苑平台。","倦客登临第几回。","连延复道通驰道，十二门开。","车马尘埃。","怅望江南雪后梅。"]},{"id":"c61-682","title":"点绛唇·一幅霜绡","rhythmic":"点绛唇","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["一幅霜绡，麝煤熏腻纹丝缕。","掩妆无语。","的是销凝处。","薄暮兰桡，漾下苹花渚。","风留住。","绿杨归路。","燕子西飞去。"]},{"id":"c61-683","title":"南歌子·绣幕深朱户","rhythmic":"南歌子","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["绣幕深朱户，熏炉小象床。","扶肩醉被冒明珰。","绣履可怜分破、两鸳鸯。","梦枕初回雨，啼钿半□妆。","一钩新月渡横塘。","谁认凌波微步、袜尘香。"]},{"id":"c61-684","title":"南歌子·心蹙黄金缕","rhythmic":"南歌子","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["心蹙黄金缕，梢垂白玉团。","孤芳不怕雪霜寒。","先向百花头上、探春□。","傍水添新韵，横墙露粉颜。","夜来和月起凭阑。","认得暗香微度、有无间。"]},{"id":"c61-685","title":"小重山·一叶西风生嫩凉","rhythmic":"小重山","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["一叶西风生嫩凉。","彩舟旗影动，背斜阳。","溪流几曲似回肠。","高城远，今夜为谁长。","正节号清狂。","苎萝标韵美，倚新妆。","月华歌调转清商。","尊酒畔，好住伴刘郎。"]},{"id":"c61-686","title":"清平乐·林皋叶脱","rhythmic":"清平乐","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["林皋叶脱。","楼下清江阔。","船里琵琶金捍拨。","弹断么弦再抹。","夜潮州渚生寒。","城头星斗阑干。","忍话旧游新梦，三千里外长安。"]},{"id":"c61-687","title":"清平乐·沈侯销瘦","rhythmic":"清平乐","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["沈侯销瘦。","八咏新题就。","惆怅酒醒兼梦后。","带眼如何复旧。","几时一叶兰舟。","画桡鸦轧东流。","新市小桥西畔，有人长倚妆楼。"]},{"id":"c61-688","title":"木兰花・玉楼春·罗巾粉汗和香浥","rhythmic":"木兰花・玉楼春","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["罗巾粉汗和香浥。","纤指留痕红一捻。","离亭再卜和欢期，寻见石榴双翠叶。","危楼欲上危肠怯。","纵得鸾胶难寸接。","西风燕子会来时，好付小笺封泪帖。"]},{"id":"c61-689","title":"玉连环・一落索·别酒更添红粉泪","rhythmic":"玉连环・一落索","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["别酒更添红粉泪。","促成愁醉。","相逢浅笑合微吟，撩惹到、缠绵地。","花下解携重附耳。","佳期深记。","青翰舟稳绣衾香，谁禁断、东流水。"]},{"id":"c61-690","title":"惜奴娇·玉立佳人","rhythmic":"惜奴娇","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["玉立佳人，韵不减、吴苏小。","赋深情、华年韶妙。","叠鼓新歌，最能作、江南调。","缥缈。","似阳台、娇云弄晓。","有客临风，梦后拟、池塘草。","竟装怀、□愁多少。","绿绮芳尊，映花月、东山道。","正要。","个卿卿、嫣然一笑。"]},{"id":"c61-691","title":"蓦山溪·画桥流水","rhythmic":"蓦山溪","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["画桥流水，宛是南州路。","转柁绿杨湾，恍然间、青楼旧处。","回肠断尽，犹剩尔多愁，记新声，怀昵语。","依约对眉宇。","袜罗香在，祗欠莲随步。","无物比朝云，恨难续、高唐后赋。","迢遥此夜，泪枕不成眠，月侵窗，灯映户。","应见可怜许。"]},{"id":"c61-692","title":"西江月·携手看花深径","rhythmic":"西江月","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["携手看花深径，扶肩待月斜廊。","临分少伫已伥伥。","此段不堪回想。","欲寄书如天远，难销夜似年长。","小窗风雨碎人肠。","更在孤舟枕上。"]},{"id":"c61-693","title":"摊破木兰花・木兰花·桂叶眉丛恨自成","rhythmic":"摊破木兰花・木兰花","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["桂叶眉丛恨自成。","锦瑟弦调，双凤和鸣。","钗梁玉胜挂兰缨。","帘影沈沈，月堕参横。","屏护文茵翠织成。","摘佩牵裾，燕样腰轻。","清溪百曲可怜生。","大抵新欢，此夜□情。"]},{"id":"c61-694","title":"点绛唇·十二层楼","rhythmic":"点绛唇","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["十二层楼，梦回缥缈非烟里。","此情何寄。","赖尔荆江水。","莫谓东君，触处逢桃李。","留深意。","温柔乡里。","自有终焉计。"]},{"id":"c61-695","title":"诉衷情·不堪回首卧云乡","rhythmic":"诉衷情","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["不堪回首卧云乡。","羁宦负清狂。","年来镜湖风月，鱼鸟两相忘。","秦塞险，楚山苍。","更斜阳。","画桥流水，曾见扁舟，几度刘郎。"]},{"id":"c61-696","title":"诉衷情·半销檀粉睡痕新","rhythmic":"诉衷情","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["半销檀粉睡痕新。","背镜照樱唇。","临风再歌团扇，深意属何人。","轻调笑，浅凝颦。","认情亲。","最难堪酒，似不胜情，依样伤春。"]},{"id":"c61-697","title":"怨三三·玉津春水如蓝","rhythmic":"怨三三","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["玉津春水如蓝。","宫柳毵毵。","桥上东风侧帽檐。","记佳节、约是重三。","飞楼十二珠帘。","恨不贮、当年彩蟾。","对梦雨廉纤。","愁随芳草，绿遍江南。"]},{"id":"c61-698","title":"醉春风·楼外屏山秀","rhythmic":"醉春风","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["楼外屏山秀。","凭阑新梦后。","归云何许误心期，候候候。","到陇梅花，渡江桃叶，断魂招手。","楚制汗衫旧。","啼妆曾枕袖。","东阳咏罢不胜情，瘦瘦瘦。","隋岸伤离，渭城怀远，一枝烟柳。"]},{"id":"c61-699","title":"忆秦娥·晓朦胧","rhythmic":"忆秦娥","author":"贺铸","authorSlug":"贺铸","dynasty":"宋","kind":"ci","paragraphs":["晓朦胧。","前溪百鸟啼匆匆。","啼匆匆。","凌波人去，拜月楼空。","去年今日东门东。","鲜妆辉映桃花红。","桃花红。","吹开吹落，一任东风。"]}]