{"令狐楚":{"slug":"令狐楚","name":"令狐楚","dynasty":"唐","style":"字壳士","life":"","origin":"","seal":"令","bio":["令狐楚，字壳士，宜州华原人。贞元七年及第，由太原掌书记至判官。德宗好文，每省太原奏，必能辨楚所为。","数称之，召授右拾遗。宪宗时，累擢职方员外郎、知制诰。皇甫镈荐为翰林学士，进中书舍人，出为华州刺史。","镈既相，复荐楚为中书侍郎同平章事。穆宗即位，进门下侍郎，寻出为宣歙观察使，贬衡州刺史，再徙太子宾客，分司东都。长庆二年，擢陕虢观察使。","敬宗立，拜楚为河南尹，迁宣武节度使，入为户部尚书，俄拜东都留守，徙天平节度使，召为吏部尚书，检校尚书右仆射，进拜左仆射，彭阳郡公。开成元年，上疏辞位，拜山南西道节度使。卒，赠司空，谥曰文。","集一百三十卷，歌诗一卷，今编诗一卷。"],"works":[{"id":"t1-101","title":"相和歌辞 王昭君","kind":"诗"},{"id":"t1-198","title":"相和歌辞 从军行五首 一","kind":"诗"},{"id":"t1-199","title":"相和歌辞 从军行五首 二","kind":"诗"},{"id":"t1-200","title":"相和歌辞 从军行五首 三","kind":"诗"},{"id":"t1-201","title":"相和歌辞 从军行五首 四","kind":"诗"},{"id":"t1-202","title":"相和歌辞 从军行五首 五","kind":"诗"},{"id":"t1-553","title":"琴曲歌辞  游春辞三首 一","kind":"诗"},{"id":"t1-554","title":"琴曲歌辞  游春辞三首 二","kind":"诗"},{"id":"t1-555","title":"琴曲歌辞  游春辞三首 三","kind":"诗"},{"id":"t1-686","title":"杂曲歌辞 少年行四首 一","kind":"诗"},{"id":"t1-687","title":"杂曲歌辞 少年行四首 二","kind":"诗"},{"id":"t1-688","title":"杂曲歌辞 少年行四首 三","kind":"诗"},{"id":"t1-689","title":"杂曲歌辞 少年行四首 四","kind":"诗"},{"id":"t1-767","title":"杂曲歌辞 长相思二首 一","kind":"诗"},{"id":"t1-768","title":"杂曲歌辞 长相思二首 二","kind":"诗"},{"id":"t1-835","title":"杂曲歌辞 远别离二首 一","kind":"诗"},{"id":"t1-836","title":"杂曲歌辞 远别离二首 二","kind":"诗"},{"id":"t2-75","title":"杂曲歌辞 圣明乐","kind":"诗"},{"id":"t2-254","title":"杂曲歌辞 宫中乐 一","kind":"诗"},{"id":"t2-255","title":"杂曲歌辞 宫中乐 二","kind":"诗"},{"id":"t2-256","title":"杂曲歌辞 宫中乐 三","kind":"诗"},{"id":"t2-257","title":"杂曲歌辞 宫中乐 四","kind":"诗"},{"id":"t2-258","title":"杂曲歌辞 宫中乐 五","kind":"诗"},{"id":"t17-836","title":"夏至日衡阳郡斋书怀","kind":"诗"},{"id":"t17-837","title":"八月十七日夜书怀","kind":"诗"},{"id":"t17-838","title":"九日言怀","kind":"诗"},{"id":"t17-839","title":"和寄窦七中丞","kind":"诗"},{"id":"t17-840","title":"立秋日悲怀","kind":"诗"},{"id":"t17-841","title":"秋怀寄钱侍郎","kind":"诗"},{"id":"t17-842","title":"立秋日","kind":"诗"},{"id":"t17-843","title":"赠毛仙翁","kind":"诗"},{"id":"t17-844","title":"游义兴寺寄上李逢吉相公","kind":"诗"},{"id":"t17-845","title":"游晋祠上李逢吉相公","kind":"诗"},{"id":"t17-846","title":"节度宣武酬乐天梦得","kind":"诗"},{"id":"t17-847","title":"奉和严司空重阳日同崔常侍崔郎及诸公登龙山落帽台佳宴","kind":"诗"},{"id":"t17-848","title":"立春后言怀招汴州李匡衙推","kind":"诗"},{"id":"t17-849","title":"奉和仆射相公酬忠武李相公见寄之作","kind":"诗"},{"id":"t17-850","title":"郡斋左偏栽竹百余竿炎凉已周青翠不改而为墙垣所蔽有乖爱赏假日命去斋居之东墙由是俯临轩阶低映帷户日夕相对颇有翛然之趣","kind":"诗"},{"id":"t17-851","title":"省中直夜对雪寄李师素侍郎","kind":"诗"},{"id":"t17-852","title":"南宫夜直宿见李给事封题其所下制敕知奏直在东省因以诗寄","kind":"诗"},{"id":"t17-853","title":"将赴洛下旅次汉南献上相公二十兄言怀八韵","kind":"诗"},{"id":"t17-854","title":"青云干吕","kind":"诗"},{"id":"t17-855","title":"圣明乐","kind":"诗"},{"id":"t17-856","title":"春闺思","kind":"诗"},{"id":"t17-857","title":"宫中乐五首 一","kind":"诗"},{"id":"t17-858","title":"宫中乐五首 二","kind":"诗"},{"id":"t17-859","title":"宫中乐五首 三","kind":"诗"},{"id":"t17-860","title":"宫中乐五首 四","kind":"诗"},{"id":"t17-861","title":"宫中乐五首 五","kind":"诗"},{"id":"t17-862","title":"春游曲三首 一","kind":"诗"}]},"伊用昌":{"slug":"伊用昌","name":"伊用昌","dynasty":"唐","style":"","life":"","origin":"","seal":"伊","bio":["伊用昌，不知何许人。与其妻乞食，多在江右庐陵、宜春诸郡。出语轻忽，常为人殴击，呼之为伊风子。","爱作望《江南词》，与妻唱和，词皆有旨。妻有殊色，豪富子弟以言笑戏调，不可犯。夫妻至南城县，丐死牛肉食之死，后人有见之者，夫妻皆蹑虚而行，发视所埋处，惟有烂牛肉，无别物。"],"works":[{"id":"t47-744","title":"望江南词咏鼓","kind":"诗"},{"id":"t47-745","title":"题茶陵县门","kind":"诗"},{"id":"t47-746","title":"题酒楼壁","kind":"诗"},{"id":"t47-747","title":"题游帷观真君殿后","kind":"诗"},{"id":"t47-748","title":"留题阁皂观","kind":"诗"},{"id":"t47-749","title":"湖南闯斋吟","kind":"诗"},{"id":"t49-941","title":"忆江南","kind":"诗"}]},"刘沆":{"slug":"刘沆","name":"刘沆","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c76-66","title":"甘州・八声甘州·爱累累","kind":"词"}]},"刘绮庄":{"slug":"刘绮庄","name":"刘绮庄","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"t48-912","title":"共佳人守岁","kind":"诗"}]},"卢尚书":{"slug":"卢尚书","name":"卢尚书","dynasty":"唐","style":"","life":"","origin":"","seal":"卢","bio":[],"works":[{"id":"t43-339","title":"哭李远","kind":"诗"},{"id":"t43-347","title":"题安国观","kind":"诗"}]},"姚合":{"slug":"姚合","name":"姚合","dynasty":"唐","style":"","life":"","origin":"","seal":"姚","bio":["姚合，陕州硖石人，宰相崇曾孙。登元和进士第，授武功主簿，调富平、万年尉。宝历中监察御史、户部员外郎，出荆、杭州刺史，后为给事中、陕虢观察使。","开成末，终秘书监，与马戴、与冠卿、殷尧藩、张籍游，李频师之。合诗名重于时，人称姚武功云。诗七卷。","姚合，陕州硖石人，宰相崇曾孙。登元和进士第，授武功主簿，调富平、万年尉。宝历中监察御史、户部员外郎，出荆、杭州刺史，后为给事中、陕虢观察使。","开成末，终秘书监，与马戴、与冠卿、殷尧藩、张籍游，李频师之，合诗名重于时，人称姚武功云。诗七卷。"],"works":[{"id":"t26-526","title":"送狄尚书镇太原","kind":"诗"},{"id":"t26-527","title":"送杨尚书祭西岳","kind":"诗"},{"id":"t26-528","title":"送李侍御过夏州","kind":"诗"},{"id":"t26-529","title":"送李起居赴池州","kind":"诗"},{"id":"t26-530","title":"送刘詹事赴寿州","kind":"诗"},{"id":"t26-531","title":"送裴大夫赴亳州","kind":"诗"},{"id":"t26-532","title":"送徐州韦仅行军","kind":"诗"},{"id":"t26-533","title":"送刘禹锡郎中赴苏州 一","kind":"诗"},{"id":"t26-534","title":"送刘禹锡郎中赴苏州 二","kind":"诗"},{"id":"t26-535","title":"送贾謩赴共城营田","kind":"诗"},{"id":"t26-536","title":"送裴宰君","kind":"诗"},{"id":"t26-537","title":"送顾非熊下第归越","kind":"诗"},{"id":"t26-538","title":"送雍陶游蜀","kind":"诗"},{"id":"t26-539","title":"送崔约下第归扬州","kind":"诗"},{"id":"t26-540","title":"送李廓侍御赴西川行营","kind":"诗"},{"id":"t26-541","title":"送杨尚书赴东川","kind":"诗"},{"id":"t26-542","title":"送邢郎中赴太原","kind":"诗"},{"id":"t26-543","title":"送裴中丞赴华州","kind":"诗"},{"id":"t26-544","title":"送徐员外赴河中从事","kind":"诗"},{"id":"t26-545","title":"送殷尧藩侍御赴同州","kind":"诗"},{"id":"t26-546","title":"送崔中丞赴郑州","kind":"诗"},{"id":"t26-547","title":"送丁端公赴河阴","kind":"诗"},{"id":"t26-548","title":"送郑尚书赴兴元","kind":"诗"},{"id":"t26-549","title":"送田使君赴蔡州","kind":"诗"},{"id":"t26-550","title":"送无可上人游边","kind":"诗"},{"id":"t26-551","title":"送僧 一","kind":"诗"},{"id":"t26-552","title":"送僧 二","kind":"诗"},{"id":"t26-553","title":"送宋慎言","kind":"诗"},{"id":"t26-554","title":"送家兄赴任昭义","kind":"诗"},{"id":"t26-555","title":"送崔玄亮赴果州冬夜宴韩卿宅","kind":"诗"},{"id":"t26-556","title":"送喻凫校书归毘陵","kind":"诗"},{"id":"t26-557","title":"送董正字武归常州觐亲","kind":"诗"},{"id":"t26-558","title":"送萧正字往蔡州贺裴相淮西平","kind":"诗"},{"id":"t26-559","title":"送进士田卓入华山","kind":"诗"},{"id":"t26-560","title":"送右司薛员外赴处州","kind":"诗"},{"id":"t26-561","title":"送王建秘书往渭南庄","kind":"诗"},{"id":"t26-562","t