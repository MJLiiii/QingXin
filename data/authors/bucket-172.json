","life":"","origin":"","seal":"唐","bio":[],"works":[{"id":"t43-179","title":"金陵怀古","kind":"诗"}]},"孟匡明":{"slug":"孟匡明","name":"孟匡明","dynasty":"唐","style":"","life":"","origin":"","seal":"孟","bio":[],"works":[{"id":"t43-313","title":"饯王将军赴云中","kind":"诗"}]},"张泌":{"slug":"张泌","name":"张泌","dynasty":"唐","style":"字里无考","life":"","origin":"南唐常州（今属江苏）","seal":"张","bio":["--字里无考。《花间集》称张舍人，列于牛峤和毛文锡之间，当为前蜀时人。存词二十七首见《花间》、《尊前》集。","王国维辑有《张舍人词》一卷。认为张泌乃南唐人。一说泌作，字子澄，南唐常州 (今属江苏) 人。","历考功员侍郎，进中书舍人，改内史舍人。随李煜归宋，官虞部郎中。又，李调元《全五代诗》称泌淮南人，为句容县尉，曾向李后主上书极谏。","按《花间集》不收南唐人词，后二说当非是。"],"works":[{"id":"t41-547","title":"惜花","kind":"诗"},{"id":"t41-548","title":"寄人 一","kind":"诗"},{"id":"t41-549","title":"寄人 二","kind":"诗"},{"id":"t41-550","title":"边上","kind":"诗"},{"id":"t41-551","title":"长安道中早行","kind":"诗"},{"id":"t41-552","title":"洞庭阻风","kind":"诗"},{"id":"t41-553","title":"春日旅泊桂州","kind":"诗"},{"id":"t41-554","title":"晚次（一作「歇」）湘源县","kind":"诗"},{"id":"t41-555","title":"惆怅吟","kind":"诗"},{"id":"t41-556","title":"秋晚过洞庭","kind":"诗"},{"id":"t41-557","title":"题华严寺木塔","kind":"诗"},{"id":"t41-558","title":"经旧游","kind":"诗"},{"id":"t41-559","title":"碧户","kind":"诗"},{"id":"t41-560","title":"芍药","kind":"诗"},{"id":"t41-561","title":"春晚谣","kind":"诗"},{"id":"t41-562","title":"所思","kind":"诗"},{"id":"t41-563","title":"春夕言怀","kind":"诗"},{"id":"t41-564","title":"春江雨","kind":"诗"},{"id":"t41-565","title":"送容州中丞赴镇","kind":"诗"},{"id":"t41-566","title":"赠韩道士","kind":"诗"},{"id":"t49-772","title":"浣溪沙 一","kind":"诗"},{"id":"t49-773","title":"浣溪沙 二","kind":"诗"},{"id":"t49-774","title":"浣溪沙 三","kind":"诗"},{"id":"t49-775","title":"浣溪沙 四","kind":"诗"},{"id":"t49-776","title":"浣溪沙 五","kind":"诗"},{"id":"t49-777","title":"浣溪沙 六","kind":"诗"},{"id":"t49-778","title":"浣溪沙 七","kind":"诗"},{"id":"t49-779","title":"浣溪沙 八","kind":"诗"},{"id":"t49-780","title":"浣溪沙 九","kind":"诗"},{"id":"t49-781","title":"临江仙","kind":"诗"},{"id":"t49-782","title":"女冠子","kind":"诗"},{"id":"t49-783","title":"河传 一","kind":"诗"},{"id":"t49-784","title":"河传 二","kind":"诗"},{"id":"t49-785","title":"酒泉子 一","kind":"诗"},{"id":"t49-786","title":"酒泉子 二","kind":"诗"},{"id":"t49-787","title":"生查子","kind":"诗"},{"id":"t49-788","title":"思越人","kind":"诗"},{"id":"t49-789","title":"满宫花","kind":"诗"},{"id":"t49-790","title":"柳枝","kind":"诗"},{"id":"t49-791","title":"南歌子 一","kind":"诗"},{"id":"t49-792","title":"南歌子 二","kind":"诗"},{"id":"t49-793","title":"南歌子 三","kind":"诗"},{"id":"t49-794","title":"江城子 一","kind":"诗"},{"id":"t49-795","title":"江城子 二","kind":"诗"},{"id":"t49-796","title":"江城子 三","kind":"诗"},{"id":"t49-797","title":"河渎神","kind":"诗"},{"id":"t49-798","title":"胡蝶儿","kind":"诗"},{"id":"t51-620","title":"岳阳楼（句）","kind":"诗"},{"id":"t51-621","title":"浣溪沙（〖1〗词《全唐诗》八九一作张曙词，第二句「苦」，《花间集》作「两」。○《花间集》〖2〗《北梦琐言》卷八作张曙词，《全唐诗》沿之。或疑张曙、张泌为同一人。）","kind":"诗"}]},"李贺":{"slug":"李贺","name":"李贺","dynasty":"唐","style":"字长吉","life":"","origin":"","seal":"李","bio":["李贺，字长吉，系出郑王后。七岁能辞章，韩愈、皇甫湜始闻未信，过其家，使贺赋诗，援笔輙就，自目曰《高轩过》，二人大惊，自是有名。贺每旦日出，骑弱马，从小奚奴，背古锦囊，遇所得，书投囊中，及暮归，足成之，率为常。","以父名晋肃，不肯举进士。诗尚奇诡，绝去畦径，当时无能效者。乐府数十篇，云韶诸工皆合之弦管，仕为协律郎，卒年二十七。","诗四卷，外集一卷，今编诗五卷。"],"works":[{"id":"t0-852","title":"鼓吹曲辞 艾如张","kind":"诗"},{"id":"t0-855","title":"鼓吹曲辞 上之回","kind":"诗"},{"id":"t0-872","title":"鼓吹曲辞 巫山高","kind":"诗"},{"id":"t0-875","title":"鼓吹曲辞 将进酒","kind":"诗"},{"id":"t0-876","title":"鼓吹曲辞 将进酒","kind":"诗"},{"id":"t1-27","title":"相和歌辞 箜篌引","kind":"诗"},{"id":"t1-45","title":"相和歌辞 江南曲","kind":"诗"},{"id":"t1-78","title":"相和歌辞 日出行","kind":"诗"},{"id":"t1-112","title":"相和歌辞 蜀国弦","kind":"诗"},{"id":"t1-145","title":"相和歌辞 铜雀妓","kind":"诗"},{"id":"t1-154","title":"相和歌辞 长歌续短歌","kind":"诗"},{"id":"t1-159","title":"相和歌辞 猛虎行","kind":"诗"},{"id":"t1-231","title":"相和歌辞 难忘曲","kind":"诗"},{"id":"t1-232","title":"相和歌辞 塘上行","kind":"诗"},{"id":"t1-251","title":"相和歌辞 安乐宫","kind":"诗"},{"id":"t1-257","title":"相和歌辞 雁门太守行","kind":"诗"},{"id":"t1-398","title":"相和歌辞 神弦曲","kind":"诗"},{"id":"t1-399","title":"相和歌辞 神弦别曲","kind":"诗"},{"id":"t1-420","title":"相和歌辞 莫愁曲","kind":"诗"},{"id":"t1-434","title":"相和歌辞 大堤曲","kind":"诗"},{"id":"t1-441","