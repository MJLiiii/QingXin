{"三槐":{"slug":"三槐","name":"三槐","dynasty":"宋","style":"","life":"","origin":"","seal":"三","bio":[],"works":[{"id":"c76-569","title":"百字谣・念奴娇·武夷秀气","kind":"词"}]},"于邵":{"slug":"于邵","name":"于邵","dynasty":"唐","style":"字相门","life":"","origin":"","seal":"于","bio":["于邵，字相门，京兆万年人。天宝末，进士登科，书判超绝，授崇文馆校书郎。历比部郎中，出为巴州刺史。","时夷獠聚众围州，邵遣使谕降，儒服出城，群盗罗拜解散。节度使李抱玉以闻，迁梓州。后为礼部侍郎、史馆修撰，当时大诏令皆出其手。","贞元中重阳应制诗，居次等，今不传，存乐章五首。"],"works":[{"id":"t0-585","title":"郊庙歌辞 释奠武成王乐章 迎神","kind":"诗"},{"id":"t0-586","title":"郊庙歌辞 释奠武成王乐章 奠币登歌","kind":"诗"},{"id":"t0-587","title":"郊庙歌辞 释奠武成王乐章 迎俎酌献","kind":"诗"},{"id":"t0-588","title":"郊庙歌辞 释奠武成王乐章 亚献终献","kind":"诗"},{"id":"t0-589","title":"郊庙歌辞 释奠武成王乐章 送神","kind":"诗"},{"id":"t13-381","title":"释奠武成王乐章 迎神","kind":"诗"},{"id":"t13-382","title":"释奠武成王乐章 奠币登歌","kind":"诗"},{"id":"t13-383","title":"释奠武成王乐章 迎俎酌献","kind":"诗"},{"id":"t13-384","title":"释奠武成王乐章 亚献终献","kind":"诗"},{"id":"t13-385","title":"释奠武成王乐章 送神","kind":"诗"}]},"伍乔":{"slug":"伍乔","name":"伍乔","dynasty":"唐","style":"","life":"","origin":"","seal":"伍","bio":["伍乔，庐江人。南唐时，举进士第一，仕至考功员外郎。诗一卷。"],"works":[{"id":"t41-595","title":"僻居谢何明府见访","kind":"诗"},{"id":"t41-596","title":"冬日道中","kind":"诗"},{"id":"t41-597","title":"僻居酬友人","kind":"诗"},{"id":"t41-598","title":"游西山龙泉禅寺","kind":"诗"},{"id":"t41-599","title":"宿灊山","kind":"诗"},{"id":"t41-600","title":"游西禅","kind":"诗"},{"id":"t41-601","title":"寄史处士","kind":"诗"},{"id":"t41-602","title":"僻居秋思寄友人","kind":"诗"},{"id":"t41-603","title":"寄落星史虚白处士","kind":"诗"},{"id":"t41-604","title":"九江旅夜寄山中故人","kind":"诗"},{"id":"t41-605","title":"闻杜牧赴阙","kind":"诗"},{"id":"t41-606","title":"题西林寺水阁","kind":"诗"},{"id":"t41-607","title":"林居喜崔三博远至","kind":"诗"},{"id":"t41-608","title":"观华夷图","kind":"诗"},{"id":"t41-609","title":"庐山书堂送祝秀才还乡","kind":"诗"},{"id":"t41-610","title":"暮冬送何秀才毘陵","kind":"诗"},{"id":"t41-611","title":"龙潭张道者","kind":"诗"},{"id":"t41-612","title":"晚秋同何秀才溪上","kind":"诗"},{"id":"t41-613","title":"送江少府授延陵后寄","kind":"诗"},{"id":"t41-614","title":"观山水障子","kind":"诗"},{"id":"t41-615","title":