[{"id":"c57-900","title":"恨春迟·欲借红梅荐饮","rhythmic":"恨春迟","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["欲借红梅荐饮。","望陇驿、音信沈沈。","住在柳州东岸，彼此相思，梦去难寻。","乳燕来时花期寝。","淡月坠、将晓还阴。","争奈多情易感，音信无凭，如何消遣得初心。"]},{"id":"c57-901","title":"庆佳节·莫风流","rhythmic":"庆佳节","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["莫风流。","莫风流。","风流后、有闲愁。","花满南园月满楼。","偏使我、忆欢游。","我忆欢游无计奈，除却且醉金瓯。","醉了醒来春复秋。","我心事、几时休。"]},{"id":"c57-902","title":"庆佳节·芳菲节","rhythmic":"庆佳节","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["芳菲节。","芳菲节。","天意应不虚设。","对酒高歌玉壶阙。","慎莫负、狂风月。","人间万事何时歇。","空赢得、鬓成雪。","我有闲愁与君说。","且莫用、轻离别。"]},{"id":"c57-903","title":"采桑子·水云薄薄天同色","rhythmic":"采桑子","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["水云薄薄天同色，竟日清辉。","风影轻飞。","花发瑶林春未知。","剡溪不辨沙头路，粉水平堤。","姑射人归。","记得歌声与舞时。"]},{"id":"c57-904","title":"御街行·画船横倚烟溪半","rhythmic":"御街行","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["画船横倚烟溪半。","春入吴山遍。","主人凭客且迟留，程入花溪远远。","数声芦叶，两行霓袖，几处成离宴。","纷纷归骑亭皋晚。","风顺樯乌转。","古今为别最消魂，因别有情须怨。","更独自、尽上高台望，望尽飞云断。"]},{"id":"c57-905","title":"玉联环・解连环·都人未逐风云散","rhythmic":"玉联环・解连环","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["都人未逐风云散。","愿留离宴。","不须都爱洛城春，黄花讶、归来晚。","叶落灞陵如翦。","泪沾歌扇。","无由重肯日边来，上马便、长安远。"]},{"id":"c57-906","title":"玉联环・解连环·来时露裛衣香润","rhythmic":"玉联环・解连环","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["来时露裛衣香润。","彩绦垂鬓。","卷帘还喜月相亲，把酒更、花相近。","西去阳关休问。","未歌先恨。","玉峰山下水长流，流水尽、情无尽。"]},{"id":"c57-907","title":"武陵春·秋染青溪天外水","rhythmic":"武陵春","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["秋染青溪天外水，风棹采菱还。","波上逢郎密意传。","语近隔丛莲。","相看忘却归来路，遮日小荷圆。","菱蔓虽多不上船。","心眼在郎边。"]},{"id":"c57-908","title":"定风波·素藕抽条未放莲","rhythmic":"定风波","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["素藕抽条未放莲。","晚蚕将茧不成眠。","若比相思如乱絮。","何异。","两心俱被暗丝牵。","暂觉欲归还是恨。","莫问。","有情谁信道无缘。","有似中秋云外月。","皎洁。","不团圆待几时圆。"]},{"id":"c57-909","title":"百媚娘·珠阙五云仙子","rhythmic":"百媚娘","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["珠阙五云仙子。","未省有谁能似。","百媚算应天乞与，净饰艳妆俱美。","若取次芳华皆可意。","何处比桃李。","蜀被锦纹铺水。","不放彩鸳双戏。","乐事也知存后会，争奈眼前心里。","绿皱小池红叠砌。","花外东风起。"]},{"id":"c57-910","title":"梦仙乡·江东苏小","rhythmic":"梦仙乡","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["江东苏小。","夭斜窈窕。","都不胜、彩鸾娇妙。","春艳上新妆。","肌肉过人香。","佳树阴阴池院。","华灯绣幔。","花月好、可能长见。","离聚此生缘。","无计问天天。"]},{"id":"c57-911","title":"归朝欢·声转辘轳闻露井","rhythmic":"归朝欢","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["声转辘轳闻露井。","晓引银瓶牵素绠。","西园人语夜来风，丛英飘坠红成径。","宝猊烟未冷。","莲台香蜡残痕凝。","等身金，谁能得意，买此好光景。","粉落轻妆红玉莹。","月枕横钗云坠领。","有情无物不双栖，文禽只合常交颈。","昼长欢岂定。","争如翻作春消永。","日曈昽，娇柔懒起，帘押残花影。"]},{"id":"c57-912","title":"相思令・相思儿令·苹满溪","rhythmic":"相思令・相思儿令","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["苹满溪。","柳绕堤。","相送行人溪水西。","回时陇月低。","烟霏霏。","风凄凄。","重倚朱门听马嘶。","寒鸥相对飞。"]},{"id":"c57-913","title":"少年游·红叶黄花秋又老","rhythmic":"少年游","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["红叶黄花秋又老，疏雨更西风。","山重水远，云闲天淡，游子断肠中。","青楼薄幸何时见，细说与、这忡忡。","念远离情，感时愁绪，应解与人同。"]},{"id":"c57-914","title":"贺圣朝·淡黄衫子浓妆了","rhythmic":"贺圣朝","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["淡黄衫子浓妆了。","步缕金鞋小。","爱来书幌绿窗前，半和娇笑。","谢家姊妹，诗名空杳。","何曾机巧。","争如奴道，春来情思，乱如芳草。"]},{"id":"c57-915","title":"生查子·当初相见时","rhythmic":"生查子","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["当初相见时，彼此心萧洒。","近日见人来，却恁相谩諕。","休休休便休，美底教他且。","匹似没伊时，更不思量也。"]},{"id":"c57-916","title":"夜厌厌・夜行船·昨夜小筵欢纵","rhythmic":"夜厌厌・夜行船","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["昨夜小筵欢纵。","烛房深、舞鸾歌凤。","酒迷花困共厌厌，倚朱弦、未成归弄。","峡雨忽收寻断梦。","依前是、画楼钟动。","争拂雕鞍葱葱去，万千恨、不能相送。"]},{"id":"c57-917","title":"迎春乐·城头画角催夕宴","rhythmic":"迎春乐","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["城头画角催夕宴。","忆前时、小楼晚。","残虹数尺云中断。","愁送目、天涯远。","枕清风、停画扇。","逗蛮簟、碧纱零乱。","怎生得伊来，今夜里、银蟾满。"]},{"id":"c57-918","title":"凤栖梧・蝶恋花·密宴厌厌池馆暮","rhythmic":"凤栖梧・蝶恋花","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["密宴厌厌池馆暮。","天汉沈沈，借得春光住。","红翠斗为长袖舞。","香檀拍过惊鸿翥。","明日不知花在否。","今夜圆蟾，后夜忧风雨。","可惜歌云容易去。","东城杨柳东城路。"]},{"id":"c57-919","title":"双燕儿·榴花帘外飘红","rhythmic":"双燕儿","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["榴花帘外飘红。","藕丝罩、小屏风。","东山别后，高唐梦短，犹喜相逢。","几时再与眠香翠，悔旧欢、何事匆匆。","芳心念我，也应那里，蹙破眉峰。"]},{"id":"c57-920","title":"卜算子慢·溪山别意","rhythmic":"卜算子慢","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["溪山别意，烟树去程，日落采苹春晚。","欲上征鞍，更掩翠帘相眄。","惜弯弯浅黛长长眼。","奈画阁欢游，也学狂花乱絮轻散。","水影横池馆。","对静夜无人，月高云远。","一饷凝思，两袖泪痕还满。","恨私书、又逐东风断。","纵西北层楼万尺，望重城那见。"]},{"id":"c57-921","title":"更漏子·锦筵红","rhythmic":"更漏子","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["锦筵红，罗幕翠。","侍宴美人姝丽。","十五六，解怜才。","劝人深酒杯。","黛眉长，檀口小。","耳畔向人轻道。","柳阴曲，是儿家。","门前红杏花。"]},{"id":"c57-922","title":"更漏子·相君家","rhythmic":"更漏子","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["相君家，宾宴集。","秋叶晓霜红湿。","帘额动，水纹浮。","缬花相对流。","薄霞衣，酣酒面。","重抱琵琶轻按。","回画拨，抹幺弦。","一声飞露蝉。"]},{"id":"c57-923","title":"南歌子·醉后和衣倒","rhythmic":"南歌子","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["醉后和衣倒，愁来殢酒醺。","困人天气近清明。","尽日厌厌□脸、浅含颦。","睡觉□□恨，依然月映门。","楚天何处觅行云。","唯有暗灯残漏、伴消魂。"]},{"id":"c57-924","title":"南歌子·蝉抱高高柳","rhythmic":"南歌子","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["蝉抱高高柳，莲开浅浅波。","倚风疏叶下庭柯。","况是不寒不暖、正清和。","浮世欢会少，劳生怨别多。","相逢休惜醉颜酡。","赖有西园明月、照笙歌。"]},{"id":"c57-925","title":"南歌子·残照催行棹","rhythmic":"南歌子","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["残照催行棹，乘春拂去衣。","海棠花下醉芳菲。","无计少留君住、泪双垂。","烟染春江暮，云藏阁道危。","行行听取杜鹃啼。","是妾此时离恨、尽呼伊。"]},{"id":"c57-926","title":"蝶恋花·临水人家深宅院","rhythmic":"蝶恋花","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["临水人家深宅院。","阶下残花，门外斜阳岸。","柳舞麴尘千万线。","青楼百尺临天半。","楼上东风春不浅。","十二阑干，尽日珠帘卷。","有个离人凝泪眼。","淡烟芳草连云远。"]},{"id":"c57-927","title":"蝶恋花·槛菊愁烟兰泣露","rhythmic":"蝶恋花","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["槛菊愁烟兰泣露。","罗幕轻寒，燕子双来去。","明月不谙离恨苦。","斜光到晓穿朱户。","昨夜西风雕碧树。","独上高楼，望尽天涯路。","欲寄彩笺兼尺素。","山长水阔知何处。"]},{"id":"c57-928","title":"蝶恋花·绿水波平花烂漫","rhythmic":"蝶恋花","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["绿水波平花烂漫。","照影红妆，步转垂杨岸。","别后深情将为断。","相逢添得人留恋。","絮软丝轻无系绊。","烟惹风迎，并入春心乱。","和泪语娇声又颤。","行行尽远犹回面。"]},{"id":"c57-929","title":"蝶恋花·移得绿杨栽后院","rhythmic":"蝶恋花","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["移得绿杨栽后院。","学舞宫腰，二月青犹短。","不比灞陵多送远。","残丝乱絮东西岸。","几叶小眉寒不展。","莫唱阳关，真个肠先断。","分付与春休细看。","条条尽是离人怨。"]},{"id":"c57-930","title":"诉衷情·花前月下暂相逢","rhythmic":"诉衷情","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["花前月下暂相逢。","苦恨阻从容。","何况酒醒梦断，花谢月朦胧。","花不尽，月无穷。","两心同。","此时愿作，杨柳千丝，绊惹春风。"]},{"id":"c57-931","title":"诉衷情·数枝金菊对芙蓉","rhythmic":"诉衷情","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["数枝金菊对芙蓉。","零落意忡忡。","不知多少幽怨，和泪泣东风。","人散后，月明中。","夜寒浓。","谢娘愁卧，潘令闲眠，往事何穷。"]},{"id":"c57-932","title":"木兰花・玉楼春·青钱贴水萍无数","rhythmic":"木兰花・玉楼春","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["青钱贴水萍无数。","临晓西湖春涨雨。","泥新轻燕面前飞，风慢落花衣上住。","红裙空引烟娥聚。","云月却能随马去。","明朝何处上高台，回认玉峰山下路。"]},{"id":"c57-933","title":"木兰花・玉楼春·西湖杨柳风流绝","rhythmic":"木兰花・玉楼春","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["西湖杨柳风流绝。","满缕青春看赠别。","墙头簌簌暗飞花，山外阴阴初落月。","秦姬秾丽云梳发。","持酒唱歌留晚发。","骊驹应解恼人情，欲出重城嘶不歇。"]},{"id":"c57-934","title":"木兰花・玉楼春·楼下雪飞楼上宴","rhythmic":"木兰花・玉楼春","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["楼下雪飞楼上宴。","歌咽笙簧声韵颤。","尊前有个好人人，十二阑干同倚遍。","帘重不知金屋晚。","信马归来肠欲断。","多情无奈苦相思，醉眼开时犹似见。"]},{"id":"c57-935","title":"减字木兰花·垂螺近额","rhythmic":"减字木兰花","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["垂螺近额。","走上红裀初趁拍。","只恐轻飞。","拟倩游丝惹住伊。","文鸳绣履。","去似杨花尘不起。","舞彻伊州。","头上宫花颤未休。"]},{"id":"c57-936","title":"少年游·碎霞浮动晓朦胧","rhythmic":"少年游","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["碎霞浮动晓朦胧。","春意与花浓。","银瓶素绠，玉泉金甃，真色浸朝红。","花枝人面难常见，青子小丛丛。","韶华长在，明年依旧，相与笑春风。"]},{"id":"c57-937","title":"少年游·帽檐风细马蹄尘","rhythmic":"少年游","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["帽檐风细马蹄尘。","常记探花人。","露英千样，粉香无尽，蓦地酒初醒。","探花人向花前老，花上旧时春。","行歌声外，靓妆丛里，须贵少年身。"]},{"id":"c57-938","title":"醉落魄・一斛珠·云轻柳弱","rhythmic":"醉落魄・一斛珠","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["云轻柳弱。","内家髻要新梳掠。","生香真色人难学。","横管孤吹，月淡天垂暮。","朱唇浅破桃花萼。","倚楼谁在阑干角。","夜寒手冷罗衣薄。","声入霜林，簌簌惊梅落。"]},{"id":"c57-939","title":"喜朝天・踏莎行·晓云开","rhythmic":"喜朝天・踏莎行","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["晓云开。","睨仙馆陵虚，步入蓬莱。","玉宇琼甃，对青林近，归鸟徘徊。","风月顿消清暑，野色对、江山助诗才。","潇鼓宴，璇题宝字，浮动持杯。","人多送目天际，识渡舟帆小，时见潮回。","故国千里，共十万室，日日春台。","睢社朝京非远，正和羹、民口渴盐梅。","佳景在，吴侬还望，分阃重来。"]},{"id":"c57-940","title":"破阵乐·四堂互映","rhythmic":"破阵乐","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["四堂互映，双门并丽，龙阁开府。","郡美东南第一，望故苑、楼台霏雾。","垂柳池塘，流泉巷陌，吴歌处处。","近黄昏，渐更宜良夜，簇簇繁星灯烛，长衢如昼，暝色韶光，几许粉面，飞甍朱户。","和煦。","雁齿桥红，裙腰草绿，云际寺、林下路。","酒熟梨花宾客醉，但觉满山潇鼓。","尽朋游、同民乐，芳菲有主。","自此归从泥诏，去指沙堤，南屏水石，西湖风月，好作千骑行春，画图写取。"]},{"id":"c57-941","title":"菊花新·堕髻慵妆来日暮","rhythmic":"菊花新","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["堕髻慵妆来日暮。","家在画桥堤下住。","衣缓绛绡垂，琼树袅、一枝红雾。","院深池静娇相妒。","粉墙低、乐声时度。","长恐舞筵空，轻化作、彩云飞去。"]},{"id":"c57-942","title":"虞美人·苕花飞尽汀风定","rhythmic":"虞美人","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["苕花飞尽汀风定。","苕水天摇影。","画船罗绮满溪春。","一曲石城清响、入高云。","壶觞昔岁同歌舞。","今日无欢侣。","南园花少故人稀。","月照玉楼依旧、似当时。"]},{"id":"c57-943","title":"醉红妆·琼枝玉树不相饶","rhythmic":"醉红妆","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["琼枝玉树不相饶。","薄云衣、细柳腰。","一般妆样百般娇。","眉眼细、好如描。","东风摇草百花飘。","恨无计、上青条。","更起双歌郎且饮，郎未醉、有金貂。"]},{"id":"c57-944","title":"天仙子·水调数声持酒听","rhythmic":"天仙子","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["水调数声持酒听。","午醉醒来愁未醒。","送春春去几时回，临晚镜。","伤流景。","往事后期空记省。","沙上并禽池上暝。","云破月来花弄影。","重重帘幕密遮灯，风不定。","人初静。","明日落红应满径。"]},{"id":"c57-945","title":"天仙子·持节来时初有雁","rhythmic":"天仙子","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["持节来时初有雁。","十万人家春已满。","龙标名第凤池身，堂阜远。","江桥晚。","一见湖山看未遍。","障扇欲收歌泪溅。","亭下花空罗绮散。","樯竿渐向望中疏，旗影转。","鼙声断。","惆怅不如船尾燕。"]},{"id":"c57-946","title":"菩萨蛮·玉人又是匆匆去","rhythmic":"菩萨蛮","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["玉人又是匆匆去。","马蹄何处垂杨路。","残日倚楼时。","断魂郎未知。","阑干移倚遍。","薄幸教人怨。","明月却多情。","随人处处行。"]},{"id":"c57-947","title":"怨春风・一斛珠·无由且住","rhythmic":"怨春风・一斛珠","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["无由且住。","绵绵恨似春蚕绪。","见来时饷还须去。","月浅灯收，多在偷期处。","今夜掩妆花下语。","明朝芳草东西路。","愿身不学相思树。","但愿罗衣，化作双飞羽。"]},{"id":"c57-948","title":"于飞乐令・于飞乐·宝奁开","rhythmic":"于飞乐令・于飞乐","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["宝奁开，菱鉴静，一掏清蟾。","新妆脸、旋学花添。","蜀红衫，双绣蝶，裙缕鹣鹣。","寻思前事，小屏风、巧画江南。","怎空教、草解宜男。","柔桑暗、又过春蚕。","正阴晴天气，更暝色相兼。","幽期消息，曲房西、碎月筛帘。"]},{"id":"c57-949","title":"临江仙·自古伤心惟远别","rhythmic":"临江仙","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["自古伤心惟远别，登山临水迟留。","暮尘衰草一番秋。","寻常景物，到此尽成愁。","况与佳人分凤侣，盈盈粉泪难收。","高城深处是青楼。","红尘远道，明日忍回头。"]},{"id":"c57-950","title":"江城子·镂牙歌板齿如犀","rhythmic":"江城子","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["镂牙歌板齿如犀。","串珠齐。","画桥西。","杂花池院，风幕卷金泥。","酒入四肢波入鬓，娇不尽，翠眉低。"]},{"id":"c57-951","title":"转声虞美人・桃源忆故人·使君欲醉离亭酒","rhythmic":"转声虞美人・桃源忆故人","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["使君欲醉离亭酒。","酒醒离愁转有。","紫禁多时虚右。","苕霄留难久。","一声歌掩双罗袖。","日落乱山春后。","犹有东城烟柳。","青荫长依旧。"]},{"id":"c57-952","title":"燕归梁·去岁中秋玩桂轮","rhythmic":"燕归梁","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["去岁中秋玩桂轮。","河汉净无云。","今年江上共瑶尊。","都不是、去年人。","水精宫殿，琉璃台阁，红翠两行分。","点唇机动秀眉颦。","清影外、见微尘。"]},{"id":"c57-953","title":"燕归梁·夜月啼乌促乱弦","rhythmic":"燕归梁","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["夜月啼乌促乱弦。","江树远无烟。","缺多圆少奈何天。","愁只恐、下关山。","粉香生润，衣珠弄彩，人月两蝉娟。","留连残夜惜馀欢。","人月在、又明年。"]},{"id":"c57-954","title":"定西番·年少登瀛词客","rhythmic":"定西番","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["年少登瀛词客，飘逸气，拂晴霓。","尽带江南春色、过长淮。","一曲艳歌留别，翠蝉摇宝钗。","此后吴姬难见、且徘徊。"]},{"id":"c57-955","title":"河传·花暮","rhythmic":"河传","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["花暮。","春去。","都门东路。","嘶马将行。","江南江北，十里五里邮亭。","几程程。","高城望远看回睇。","烟细。","晚碧空无际。","今夜何处，冷落衾帏。","欲眠时。"]},{"id":"c57-956","title":"偷声木兰花·雪笼琼苑梅花瘦","rhythmic":"偷声木兰花","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["雪笼琼苑梅花瘦。","外院重扉联宝兽。","海月新生。","上得高楼无奈情。","帘波不动凝釭小。","今夜夜长争得晓。","欲梦高唐。","只恐觉来添断肠。"]},{"id":"c57-957","title":"偷声木兰花·画桥浅映横塘路","rhythmic":"偷声木兰花","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["画桥浅映横塘路。","流水滔滔春共去。","目送残晖。","燕子双高蝶对飞。","风花将尽持杯送。","往事只成清夜梦。","莫更登楼。","坐想行思已是愁。"]},{"id":"c57-958","title":"醉桃源・阮郎归·双花连袂近香猊","rhythmic":"醉桃源・阮郎归","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["双花连袂近香猊。","歌随镂板齐。","分明珠索漱烟溪。","凝云定不飞。","唇破点，齿编犀。","春莺莫乱啼。","阳关更在碧峰西。","相看翠黛低。"]},{"id":"c57-959","title":"千秋岁·数声鶗鴂","rhythmic":"千秋岁","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["数声鶗鴂。","又报芳菲歇。","惜春更把残红折。","雨轻风色暴，梅子青时节。","永丰柳，无人尽日飞花雪。","莫把幺弦拨。","怨极弦能说。","天不老，情难绝。","心似双丝网，中有千千结。","夜过也，东窗未白凝残月。"]},{"id":"c57-960","title":"天仙子·醉笑相逢能几度","rhythmic":"天仙子","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["醉笑相逢能几度。","为报江头春且住。","主人今日是行人，红袖舞。","清歌女。","凭仗东风教点取。","三月柳枝柔似缕。","落絮尽飞还恋树。","有情宁不忆西园，莺解语。","花无数。","应讶使君何处去。"]},{"id":"c57-961","title":"渔家傲·巴子城头青草暮","rhythmic":"渔家傲","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["巴子城头青草暮。","巴山重叠相逢处。","燕子占巢花脱树。","杯且举。","瞿塘水阔舟难渡。","天外吴门清霅路。","君家正在吴门住。","赠我柳枝情几许。","春满缕。","为君将入江南去。"]},{"id":"c57-962","title":"天仙子·十岁手如芽子笋","rhythmic":"天仙子","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["十岁手如芽子笋。","固爱弄妆偷傅粉。","金蕉并为舞时空，红脸嫩。","轻衣褪。","春重日浓花觉困。","斜雁轧弦随步趁。","小凤累珠光绕鬓。","密教持履恐仙飞，催拍紧。","惊鸿奔。","风袂飘摇无定准。"]},{"id":"c57-963","title":"天仙子·坐治吴州成乐土","rhythmic":"天仙子","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["坐治吴州成乐土。","诏卷风飞来圣语。","亲舆乞得便藩归，瑶席主。","杯休数。","清夜为君歌白苎。","花接旧枝新蕊吐。","造化不知人有助。","看花岁岁比甘棠，嘉月暮。","东门路。","只恐带将春色去。"]},{"id":"c57-964","title":"南乡子·相并细腰身","rhythmic":"南乡子","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["相并细腰身。","时样宫妆一样新。","曲项胡琴鱼尾拨，离人。","入塞弦声水上闻。","天碧染衣巾。","血色轻罗碎摺裙。","百卉已随霜女妒，东君。","暗折双花借小春。"]},{"id":"c57-965","title":"少年游·听歌持酒且休行","rhythmic":"少年游","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["听歌持酒且休行。","云树几程程。","眼看檐牙，手搓花蕊，未必两无情。","拓夫滩上闻新雁，离袖掩盈盈。","此恨无穷，远如江水，东去几时平。"]},{"id":"c57-966","title":"定风波令・定风波·碧玉篦扶坠髻云","rhythmic":"定风波令・定风波","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["碧玉篦扶坠髻云。","莺黄衫子退红裙。","妆样巧将花草竞。","相并。","要教人意胜於春。","酒眼茸茸香拂面。","□见。","丹青宁似镜中真。","自是有情偏小小。","向道。","江东谁信更无人。"]},{"id":"c57-967","title":"定风波令・定风波·浴殿词臣亦议兵","rhythmic":"定风波令・定风波","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["浴殿词臣亦议兵。","禁中颇牧党羌平。","诏卷促归难自缓。","溪馆。","彩花千数酒泉清。","春草未青秋叶暮。","□去。","一家行色万家情。","可恨黄莺相识晚。","望断。","湖边亭上不闻声。"]},{"id":"c57-968","title":"定风波令・定风波·谈辨才疏堂上兵","rhythmic":"定风波令・定风波","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["谈辨才疏堂上兵。","画船齐岸暗潮平。","万乘靴袍曾好问。","须信。","文章传口齿牙清。","三百寺应游未遍。","□算。","湖山风物岂无情。","不独渠丘歌叔度。","行路。","吴谣终日有馀声。"]},{"id":"c57-969","title":"定风波令・定风波·西阁明呈奉诏行","rhythmic":"定风波令・定风波","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["西阁明呈奉诏行。","南床吏部锦衣荣。","中有瀛仙宾与主。","相遇。","平津选首更神清。","溪上玉楼同宴喜。","欢醉。","对堤杯叶惜秋英。","尽道贤人聚吴分。","试问。","也应旁有老人星。"]},{"id":"c57-970","title":"木兰花・玉楼春·人意共怜花月满","rhythmic":"木兰花・玉楼春","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["人意共怜花月满。","花好月圆人又散。","欢情去逐远云空，往事过如幽梦断。","草树争春红影乱。","一唱鸡声千万怨。","任教迟日更添长，能得几时抬眼看。"]},{"id":"c57-971","title":"木兰花・玉楼春·相离徒有相逢梦","rhythmic":"木兰花・玉楼春","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["相离徒有相逢梦。","门外马蹄尘已动。","怨歌留待醉时听，远目不堪空际送。","今宵风月知谁共。","声咽琵琶槽上凤。","人生无物比多情，江水不深山不重。"]},{"id":"c57-972","title":"木兰花・玉楼春·檀槽碎响金丝拨","rhythmic":"木兰花・玉楼春","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["檀槽碎响金丝拨。","露湿浔阳江上月。","不知商妇为谁愁，一曲行人留晚发。","画堂花入新声别。","红蕊调高弹未彻。","暗将深意语胶弦，长愿弦丝无断绝。"]},{"id":"c57-973","title":"木兰花・玉楼春·插花劝酒盐桥馆","rhythmic":"木兰花・玉楼春","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["插花劝酒盐桥馆。","召节促行龙阙远。","吴船渐起晚潮生，蛮榼未空寒日短。","庆门奕世隆宸眷。","归到月陂梅已绽。","有情愿寄向南枝，图得洛阳春色看。"]},{"id":"c57-974","title":"木兰花・玉楼春·去年春入芳菲国","rhythmic":"木兰花・玉楼春","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["去年春入芳菲国。","青蕊如梅终忍摘。","阑边徒欲说相思，绿蜡密缄朱粉饰。","归来故苑重寻觅。","花满旧枝心更惜。","鸳鸯从小自相双，若不多情头不白。"]},{"id":"c57-975","title":"木兰花・玉楼春·龙头舴艋吴儿竞","rhythmic":"木兰花・玉楼春","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["龙头舴艋吴儿竞。","笋柱秋千游女并。","芳洲拾翠暮忘归，秀野踏青来不定。","行云去后遥山暝。","已放笙歌池院静。","中庭月色正清明，无数杨花过无影。"]},{"id":"c57-976","title":"木兰花・玉楼春·轻牙低掌随声听","rhythmic":"木兰花・玉楼春","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["轻牙低掌随声听。","合调破空云自凝。","姝娘翠黛有人描，琼女分鬟待谁并。","弄妆俱学闲心性。","固向鸾台同照影。","双头莲子一时花，天碧秋池水如镜。"]},{"id":"c57-977","title":"倾杯・倾杯乐·横塘水静","rhythmic":"倾杯・倾杯乐","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["横塘水静，花窥影、孤城转。","浮玉无尘，五亭争景，画桥对起，垂虹不断。","爱溪上琼楼，凭雕栏、久□飞云远。","人在虚空，月生溟海，寒渔夜泛，游鳞可辨。","正是草长苹老，江南地暖。","汀洲日晚。","更茶山、已过清明，风雨暴千岩、啼鸟怨。","芳菲故苑。","深红尽、绿叶阴浓，青子枝头满。","史君莫放寻春缓。"]},{"id":"c57-978","title":"倾杯・倾杯乐·飞云过尽","rhythmic":"倾杯・倾杯乐","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["飞云过尽，明河浅、天无畔。","草色栖萤，霜华清暑，轻飔弄袂，澄澜拍岸。","宴玉麈谈宾，倚琼枝、秀挹雕觞满。","午夜中秋，十分圆月，香槽拨凤，朱弦轧雁。","正是欲醒还醉，临空怅远。","壶更叠换。","对东西、数里回塘，恨零落芙蓉、春不管。","笼灯待散。","谁知道、座有离人，目断双歌伴。","烟江艇子归来晚。"]},{"id":"c57-979","title":"离亭宴·捧黄封诏卷","rhythmic":"离亭宴","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["捧黄封诏卷。","随处是、离亭别宴。","红翠成轮歌未遍。","已恨野桥风便。","此去济南非久，惟有凤池鸾殿。","三月花飞几片。","又减却、芳菲过半。","千里恩深云海浅。","民爱比、春流不断。","更上玉楼西，归雁与、征帆共远。"]},{"id":"c57-980","title":"沁园春·心膂良臣","rhythmic":"沁园春","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["心膂良臣，帷幄元勋，左右万几。","暂武林分阃，东南外翰，锦衣乡社，未满瓜时。","易镇梧台，宣条期岁，又西指夷桥千骑移。","珠滩上，喜甘棠翠荫，依旧春晖。","须知。","系国安危。","料节召、还趋浴凤池。","且代工施化，持钧播泽，置盂天下，此外何思。","素卷书名，赤松游道，飙驭云軿仙可期。","湖山美，有啼猿唳鹤，相望东归。"]},{"id":"c57-981","title":"感皇恩·延寿芸香七世孙","rhythmic":"感皇恩","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["延寿芸香七世孙。","华轩承大对，见经纶。","溟鱼一息化天津。","袍如草，三百骑，从清尘。","玉树莹风神。","同时棠棣萼，一家春。","十年身是凤池人。","蓬莱阁，黄合主，迟谈宾。"]},{"id":"c57-982","title":"忆秦娥·参差竹","rhythmic":"忆秦娥","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["参差竹。","吹断相思曲。","情不足。","西北有楼穷远目。","忆苕溪、寒影透清玉。","秋雁南飞速。","菰草绿。","应下溪头沙上宿。"]},{"id":"c57-983","title":"系裙腰·惜霜蟾照夜云天","rhythmic":"系裙腰","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["惜霜蟾照夜云天。","朦胧影、画勾阑。","人情纵是长情月，算一年年。","又能得、几番圆。","欲寄西江题叶字，流不到、五亭前。","东池始有荷新绿，尚小如钱。","问何日藕、几时莲。"]},{"id":"c57-984","title":"清平乐·青袍如草","rhythmic":"清平乐","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["青袍如草。","得意还年少。","马跃绿螭金络脑。","寒食乍临新晓。","曲池斜度鸾桥。","西园一片笙箫。","自欲剩留春住，风花无奈飘飘。"]},{"id":"c57-985","title":"偷声木兰花·曾居别乘康吴俗","rhythmic":"偷声木兰花","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["曾居别乘康吴俗。","民到於今歌不足。","骊驭征鞭。","一去东风十二年。","重来却拥诸侯骑。","宝带垂鱼金照地。","和气融人。","清霅千家日日春。"]},{"id":"c57-986","title":"菩萨蛮·佳人学得平阳曲","rhythmic":"菩萨蛮","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["佳人学得平阳曲。","纤纤玉笋横孤竹。","一弄入云声。","海门江月清。","髻摇金钿落。","惜恐樱唇薄。","听罢已依依。","莫吹杨柳枝。"]},{"id":"c57-987","title":"菩萨蛮·藕丝衫翦猩红窄","rhythmic":"菩萨蛮","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["藕丝衫翦猩红窄。","衫轻不碍琼肤白。","缦鬓小横波。","花楼东是家。","上湖闲荡桨。","粉艳芙蓉样。","湖水亦多情。","照妆天底清。"]},{"id":"c57-988","title":"菩萨蛮·牛星织女年年别","rhythmic":"菩萨蛮","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["牛星织女年年别。","分明不及人间物。","匹鸟少孤飞。","断沙犹并栖。","洗车昏雨过。","缺月云中堕。","斜汉晓依依。","暗蛩还促机。"]},{"id":"c57-989","title":"菩萨蛮·双针竞引双丝缕","rhythmic":"菩萨蛮","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["双针竞引双丝缕。","家家尽道迎牛女。","不见渡河时。","空闻乌鹊飞。","西南低片月。","应恐云梳发。","寄语问星津。","谁为得巧人。"]},{"id":"c57-990","title":"庆春泽·飞阁危桥相倚","rhythmic":"庆春泽","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["飞阁危桥相倚。","人独立东风，满衣轻絮。","还记忆江南，如今天气。","正白苹花，绕堤涨流水。","寒梅落尽谁寄。","方春意无穷，青空千里。","愁草树依依，关城初闭。","对月黄昏，角声傍烟起。"]},{"id":"c57-991","title":"庆春泽·艳色不须妆样","rhythmic":"庆春泽","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["艳色不须妆样。","风韵好天真，画毫难上。","花影滟金尊，酒泉生浪。","镇欲留春，傍花为春唱。","银塘玉宇空旷。","冰齿映轻唇，蕊红新放。","声宛转，疑随烟香悠扬。","对暮林静，寥寥振清响。"]},{"id":"c57-992","title":"玉联环・解连环·南园已恨归来晚","rhythmic":"玉联环・解连环","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["南园已恨归来晚。","芳菲满眼。","春工偏上好花多，疑不向、空枝暖。","惜恐红云易散。","丛丛看遍。","当时犹有蕊如梅，问几日上、东风绽。"]},{"id":"c57-993","title":"玉树后庭花・后庭花·华灯火树红相斗","rhythmic":"玉树后庭花・后庭花","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["华灯火树红相斗。","往来如昼。","桥河水白天青，讶别生星斗。","落梅秾李还依旧。","宝钗沽酒。","晓蟾残漏心情，恨雕鞍归后。"]},{"id":"c57-994","title":"玉树后庭花・后庭花·宝床香重春眠觉","rhythmic":"玉树后庭花・后庭花","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["宝床香重春眠觉。","魫窗难晓。","新声丽色千人，歌后庭清妙。","青骢一骑来飞鸟。","靓妆难好。","至今落日寒蟾，照台城秋草。"]},{"id":"c57-995","title":"卜算子·梦断寒夜长","rhythmic":"卜算子","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["梦断寒夜长，坐待清霜晓。","临镜无人为整妆，但自学、孤鸾照。","楼台红树杪。","风月依前好。","江水东流郎在西，问尺素、何由到。"]},{"id":"c57-996","title":"双韵子·鸣鞘电过晓闱静","rhythmic":"双韵子","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["鸣鞘电过晓闱静。","敛龙旗风定。","凤楼远出霏烟，闻笑语、中天迥。","清光近。","欢声竟。","鸳鸯集、仙花斗影。","更闻度曲瑶山，升瑞日、春宫永。"]},{"id":"c57-997","title":"鹊桥仙·星桥火树","rhythmic":"鹊桥仙","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["星桥火树，长安一夜，开遍红莲万蕊。","绮罗能借月中春，风露细、天清似水。","重城闭月，青楼夸乐，人在银潢影里。","画屏期约近收灯，归步急、双鸳欲起。"]},{"id":"c57-998","title":"醉垂鞭·酒面滟金鱼","rhythmic":"醉垂鞭","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["酒面滟金鱼。","吴娃唱。","吴潮上。","玉殿白麻书。","待君归后除。","勾留风月好。","平湖晓。","翠峰孤。","此景出关无。","西州空画图。"]},{"id":"c57-999","title":"定西番·秀眼谩生千媚","rhythmic":"定西番","author":"张先","authorSlug":"张先","dynasty":"宋","kind":"ci","paragraphs":["秀眼谩生千媚，钗玉重，髻云低。","寂寂挹妆羞泪，怨分携。","鸳帐愿从今夜，梦长连晓鸡。","小逐画船风月，渡江西。"]}]