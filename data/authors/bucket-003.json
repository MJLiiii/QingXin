],"works":[{"id":"t54-209","title":"答楚儿","kind":"诗"}]},"陈克":{"slug":"陈克","name":"陈克","dynasty":"宋","style":"字子高 · 号赤城居士","life":"","origin":"天台（今属浙江）","seal":"陈","bio":["(1081－？) 字子高，自号赤城居士，天台 (今属浙江) 人。吕祉帅建康时，辟为参议。(见《花庵词选》卷八) 一云临海 (今属浙江) 人，侨居金陵。","绍兴中为敕令所删定官。(见《词林纪事》卷十) 词格艳丽，接近温、韦、晏、周。有《天台集》，不传。","今有辑本《赤城词》。"],"works":[{"id":"c63-156","title":"临江仙·枕帐依依残梦","kind":"词"},{"id":"c63-157","title":"临江仙·四海十年兵不解","kind":"词"},{"id":"c63-158","title":"渔家傲·宝瑟尘生郎去后","kind":"词"},{"id":"c63-159","title":"浣溪沙·浅画香膏拂紫绵","kind":"词"},{"id":"c63-160","title":"浣溪沙·香雾空濛堕彩蟾","kind":"词"},{"id":"c63-161","title":"浣溪沙·淡墨花枝掩薄罗","kind":"词"},{"id":"c63-162","title":"浣溪沙·短烛荧荧照碧窗","kind":"词"},{"id":"c63-163","title":"浣溪沙·小院春来百草青","kind":"词"},{"id":"c63-164","title":"浣溪沙·窗纸幽幽不肯明","kind":"词"},{"id":"c63-165","title":"摊破浣溪沙・山花子·□慢梳头浅画眉","kind":"词"},{"id":"c63-166","title":"谒金门·花满院","kind":"词"},{"id":"c63-167","title":"谒金门·柳丝碧","kind":"词"},{"id":"c63-168","title":"谒金门·深院静","kind":"词"},{"id":"c63-169","title":"谒金门·春漏促","kind":"词"},{"id":"c63-170","title":"谒金门·春草碧","kind":"词"},{"id":"c63-171","title":"谒金门·罗帐薄","kind":"词"},{"id":"c63-172","title":"谒金门·愁脉脉","kind":"词"},{"id":"c63-173","title":"谒金门·春寂寂","kind":"词"},{"id":"c63-174","title":"虞美人·踏车不用青裙女","kind":"词"},{"id":"c63-175","title":"虞美人·小山戢戢盆池浅","kind":"词"},{"id":"c63-176","title":"虞美人·绿阴满院帘垂地","kind":"词"},{"id":"c63-177","title":"菩萨蛮·柳条窣窣闲庭院","kind":"词"},{"id":"c63-178","title":"菩萨蛮·赤阑桥尽香街直","kind":"词"},{"id":"c63-179","title":"菩萨蛮·池塘淡淡浮鸂鶒","kind":"词"},{"id":"c63-180","title":"菩萨蛮·绿芜墙绕青苔院","kind":"词"},{"id":"c63-181","title":"菩萨蛮·柳条到地莺声滑","kind":"词"},{"id":"c63-182","title":"菩萨蛮·绿阴寂寂樱桃下","kind":"词"},{"id":"c63-183","title":"点绛唇·曲陌春风","kind":"词"},{"id":"c63-184","title":"好事近·寻遍石亭春","kind":"词"},{"id":"c63-185","title":"千秋岁·柏舟高躅","kind":"词"},{"id":"c63-186","title":"鹧鸪天·禁瘆馀寒酒半醒","kind":"词"},{"id":"c63-187","title":"鹧鸪天·芳树阴阴脱晚红","kind":"词"},{"id":"c63-188","title":"鹧鸪天·小市桥弯更向东","kind":"词"},{"id":"c63-189","title":"豆叶黄・忆王孙·粉墙丹柱柳丝中","kind":"词"},{"id":"c63