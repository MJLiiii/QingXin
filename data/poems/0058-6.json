[{"id":"c58-600","title":"西江月·欲了无生妙道","rhythmic":"西江月","author":"张伯端","authorSlug":"张伯端","dynasty":"宋","kind":"ci","paragraphs":["欲了无生妙道，莫如自见真心。","真心无相亦无音。","清净法身只恁。","此道非无外有，非中亦莫求寻。","二边俱遣弃中心。","见了名为上品。"]},{"id":"c58-601","title":"满庭芳·真铁牛儿","rhythmic":"满庭芳","author":"张伯端","authorSlug":"张伯端","dynasty":"宋","kind":"ci","paragraphs":["真铁牛儿，形容丑恶，性刚偏好争驰。","人人皆有，那角解牵骑。","种就黄芽满院，更须用、神水浇之。","宫里，若无此兽，安得似婴儿。","乾坤真动静，生成家活，总赖於伊。","饥餐虎髓，渴饮水银池。","夜半牵车进火，霞光迸、海底腾辉。","牧童笑，华池宴罢，乘个月明归。"]},{"id":"c58-602","title":"凤栖梧・蝶恋花·蜀道青天烟霭翳","rhythmic":"凤栖梧・蝶恋花","author":"卢氏","authorSlug":"卢氏","dynasty":"宋","kind":"ci","paragraphs":["蜀道青天烟霭翳。","帝里繁华、迢递何时至。","回望锦川挥粉泪。","凤钗斜亸乌云腻。","钿带双垂金缕细。","玉珮玎珰，露滴寒如水。","从此鸾妆添远意。","画眉学得遥山翠。"]},{"id":"c58-603","title":"家山好·挂冠归去旧烟萝","rhythmic":"家山好","author":"刘述","authorSlug":"刘述","dynasty":"宋","kind":"ci","paragraphs":["挂冠归去旧烟萝。","闲身健，养天和。","功名富贵非由我，莫贪他。","这歧路、足风波。","水晶宫里家山好，物外胜游多。","晴溪短棹，时时醉唱里棱罗。","天公奈我何。"]},{"id":"c58-604","title":"合宫歌·缵重明","rhythmic":"合宫歌","author":"赵祯","authorSlug":"赵祯","dynasty":"宋","kind":"ci","paragraphs":["缵重明。","端拱保凝命。","广大孝休德，永锡四海有庆。","觚坛寓礼正典名。","幔室雅奏，彩仗崇制定。","五位仿古甚盛。","蒿宫光符辰星。","高秋嘉时款芎灵。","交累圣。","上下来顾，寅畏歆纯诚。","三阶平。","金气肃，转和景。","翠葆御双观，巽风兑泽布令。","脂茶剗荡墨索清。","远迩向附，动植咸遂性。","表里穆悦，庶政醇醲，熙然胥庭。","唐舜华封祝，如南山寿永。","愿今广怀宁延，昌基扃。"]},{"id":"c58-605","title":"沁园春·华发青云","rhythmic":"沁园春","author":"王拱辰","authorSlug":"王拱辰","dynasty":"宋","kind":"ci","paragraphs":["华发青云。"]},{"id":"c58-606","title":"好事近·瑞雪满京都","rhythmic":"好事近","author":"蔡襄","authorSlug":"蔡襄","dynasty":"宋","kind":"ci","paragraphs":["瑞雪满京都，宫殿尽成银阙。","常对素光遥望，是江梅时节。","如今江上见寒梅，幽香自清绝。","重看落英残艳，想飘零如雪。"]},{"id":"c58-607","title":"踏莎行·嵩峤云高","rhythmic":"踏莎行","author":"韩绛","authorSlug":"韩绛","dynasty":"宋","kind":"ci","paragraphs":["嵩峤云高，洛川波暖。","举头乔木森无断。","□□□雨绝风尘，小桥频过春渠满。","□□离宫，□棱斗焕。","万家罗绮多游伴。","□□□□自风□，□□是处喧弦管。"]},{"id":"c58-608","title":"菩萨蛮·子规啼破城楼月","rhythmic":"菩萨蛮","author":"李师中","authorSlug":"李师中","dynasty":"宋","kind":"ci","paragraphs":["子规啼破城楼月。","画船晓载笙歌发。","两岸荔枝红。","万家烟雨中。","佳人相对泣。","泪下罗衣湿。","从此信音稀。","岭南无雁飞。"]},{"id":"c58-609","title":"喜迁莺·霜天清晓","rhythmic":"喜迁莺","author":"蔡挺","authorSlug":"蔡挺","dynasty":"宋","kind":"ci","paragraphs":["霜天清晓。","望紫塞古垒，寒云衰草。","汗马嘶风，边鸿翻月，垅上铁衣寒早。","剑歌骑曲悲壮，尽道君恩难报。","塞垣乐，尽双鞬锦带，山西年少。","谈笑。","刁斗静。","烽火一把，常送平安耗。","圣主忧边，威灵遐布，骄虏且宽天讨。","岁华向晚愁思，谁念玉关人老。","太平也，且欢娱，不惜金尊频倒。"]},{"id":"c58-610","title":"喜长新·秋云朔吹晓徘徊","rhythmic":"喜长新","author":"王益柔","authorSlug":"王益柔","dynasty":"宋","kind":"ci","paragraphs":["秋云朔吹晓徘徊。","雪照楼台。","梁王宴召有邹枚。","相如独逞雄才。","明烛薰炉香暖，深劝金杯。","庭前粉艳有寒梅。","一枝昨夜先开。"]},{"id":"c58-611","title":"西江月·早岁相期林下","rhythmic":"西江月","author":"韩维","authorSlug":"韩维","dynasty":"宋","kind":"ci","paragraphs":["早岁相期林下，高年同在尊前。","风花绣舞乍晴天。","绿蚁新浮酒面。","身外虚名电转，人间急景梭传。","当筵莫惜听朱弦。","一品归来强健。"]},{"id":"c58-612","title":"踏莎行·归雁低空","rhythmic":"踏莎行","author":"韩维","authorSlug":"韩维","dynasty":"宋","kind":"ci","paragraphs":["归雁低空，游蜂趁暖。","凭高目向西云断。","具茨山外夕阳多，展江亭下春波满。","双桂情深，千花明焕。","良辰谁是同游伴。","辛夷花谢早梅开。","应须次第调弦管。"]},{"id":"c58-613","title":"减字木兰花·和风动□","rhythmic":"减字木兰花","author":"韩维","authorSlug":"韩维","dynasty":"宋","kind":"ci","paragraphs":["和风动□。","□□新年□入手。","世事尘□。","□□□情近酒□。","水开湖□。","□□笙歌波面起。","相与排□。","□□□胜特地□。"]},{"id":"c58-614","title":"浪淘沙·饱食日□□","rhythmic":"浪淘沙","author":"韩维","authorSlug":"韩维","dynasty":"宋","kind":"ci","paragraphs":["饱食日□□。","□上危亭。","东风昨夜入□□。","□□雪晴云□□，□遍银屏。","回首叹劳生。","□鼎相承。","皇恩早晚□□□。","□□陂边垂钓手，不负幽情。"]},{"id":"c58-615","title":"胡捣练令・胡捣练·夜来风横雨飞狂","rhythmic":"胡捣练令・胡捣练","author":"韩维","authorSlug":"韩维","dynasty":"宋","kind":"ci","paragraphs":["夜来风横雨飞狂，满地闲花衰草。","燕子渐归春悄。","帘幕垂清晓。","天将佳景与闲人，美酒宁嫌华皓。","留取旧时欢笑。","莫共秋光老。"]},{"id":"c58-616","title":"失调名·轻云薄雾","rhythmic":"失调名","author":"韩维","authorSlug":"韩维","dynasty":"宋","kind":"ci","paragraphs":["轻云薄雾。","散作催花雨。"]},{"id":"c58-617","title":"失调名·兄弟对举杯","rhythmic":"失调名","author":"韩维","authorSlug":"韩维","dynasty":"宋","kind":"ci","paragraphs":["兄弟对举杯。"]},{"id":"c58-618","title":"赏南枝·暮冬天地闭","rhythmic":"赏南枝","author":"曾巩","authorSlug":"曾巩","dynasty":"宋","kind":"ci","paragraphs":["暮冬天地闭，正柔木冻折，瑞雪飘飞。","对景见南山，岭梅露、几点清雅容姿。","丹染萼、玉缀枝。","又岂是、一阳有私。","大抵是、化工独许，使占却先时。","霜威莫苦凌持。","此花根性，想群卉争知。","贵用在和羹，三春里、不管绿是红非。","攀赏处、宜酒卮。","醉拈嗅、幽香更奇。","倚阑干、仗何人去，嘱羌管休吹。"]},{"id":"c58-619","title":"阮郎归·渔舟容易入春山","rhythmic":"阮郎归","author":"司马光","authorSlug":"司马光","dynasty":"宋","kind":"ci","paragraphs":["渔舟容易入春山。","仙家日月闲。","绮窗纱幌映朱颜。","相逢醉梦间。","松露冷，海霞殷。","匆匆整棹还。","落花寂寂水潺潺。","重寻此路难。"]},{"id":"c58-620","title":"西江月·宝髻松松挽就","rhythmic":"西江月","author":"司马光","authorSlug":"司马光","dynasty":"宋","kind":"ci","paragraphs":["宝髻松松挽就，铅华淡淡妆成。","青烟翠雾罩轻盈。","飞絮游丝无定。","相见争如不见，有情何似无情。","笙歌散后酒初醒。","深院月斜人静。"]},{"id":"c58-621","title":"锦堂春・锦堂春慢·红日迟迟","rhythmic":"锦堂春・锦堂春慢","author":"司马光","authorSlug":"司马光","dynasty":"宋","kind":"ci","paragraphs":["红日迟迟，虚廊转影，槐阴迤逦西斜。","彩笔工夫，难状晚景烟霞。","蝶尚不知春去，漫绕幽砌寻花。","奈猛风过后，纵有残红，飞向谁家。","始知青鬓无价，叹飘零官路，荏苒年华。","今日笙歌丛里，特地咨嗟。","席上青衫湿透，算感旧、何止琵琶。","怎不教人易老，多少离愁，散在天涯。"]},{"id":"c58-622","title":"临江仙·一夜东风穿绣户","rhythmic":"临江仙","author":"苏氏","authorSlug":"苏氏","dynasty":"宋","kind":"ci","paragraphs":["一夜东风穿绣户，融融暖应佳时。","春来何处最先知。","平明堤上柳。","染遍郁金枝。","姊妹嬉游时节近，今朝应怨来迟。","凭谁说与到家期。","玉钗头上胜，留待远人归。"]},{"id":"c58-623","title":"更漏子·小阑干","rhythmic":"更漏子","author":"苏氏","authorSlug":"苏氏","dynasty":"宋","kind":"ci","paragraphs":["小阑干，深院宇。","依旧当时别处。","朱户锁，玉楼空。","一帘霜日红。","弄珠江，何处是，望断碧云无际。","凝泪眼，出重城。","隔溪羌笛声。"]},{"id":"c58-624","title":"鹊桥仙·星移斗转","rhythmic":"鹊桥仙","author":"苏氏","authorSlug":"苏氏","dynasty":"宋","kind":"ci","paragraphs":["星移斗转，玉蟾西下，渐觉东郊向晓。","马嘶人语隔霜林，望千里、长安古道。","珠宫姊妹，相逢方信，别后十分瘦了。","上林归去正花时，争奈向、花前又老。"]},{"id":"c58-625","title":"踏莎行·孤馆深沈","rhythmic":"踏莎行","author":"苏氏","authorSlug":"苏氏","dynasty":"宋","kind":"ci","paragraphs":["孤馆深沈，晓寒天气。","解鞍独自阑干倚。","暗香浮动月黄昏，落梅风送沾衣袂。","待写红笺，凭谁与寄。","先教觅取嬉游地。","到家正是早春时，小桃花下拼沈醉。"]},{"id":"c58-626","title":"清平乐·小山丛桂","rhythmic":"清平乐","author":"刘敞","authorSlug":"刘敞","dynasty":"宋","kind":"ci","paragraphs":["小山丛桂。","最有留人意。","拂叶攀花无限思。","雨湿浓香满袂。","别来过了秋光。","翠帘昨夜新霜。","多少月宫闲地，姮娥与借微芳。"]},{"id":"c58-627","title":"踏莎行·蜡炬高高","rhythmic":"踏莎行","author":"刘敞","authorSlug":"刘敞","dynasty":"宋","kind":"ci","paragraphs":["蜡炬高高，龙烟细细。","玉楼十二门初闭。","疏帘不卷水晶寒，小屏半掩琉璃翠。","桃叶新声，榴花美味。","南山宾客东山妓。","利名不肯放人闲，忙中偷取工夫醉。"]},{"id":"c58-628","title":"导引·忆玉清景","rhythmic":"导引","author":"王","authorSlug":"王","dynasty":"宋","kind":"ci","paragraphs":["忆玉清景，繁盛极当时。","千古事难追。","汉家别庙秋风起，空出奉宸衣。","三山浮海日晖晖。","羽盖共云飞。","灵宫旧是栖真处，还望玉舆归。"]},{"id":"c58-629","title":"发引·玉宸朝晚","rhythmic":"发引","author":"王","authorSlug":"王","dynasty":"宋","kind":"ci","paragraphs":["玉宸朝晚，忽掩赭黄衣。","愁雾锁金扉。","蓬莱待得仙丹至，人世已成非。","龙轩天仗转西畿。","旌旆入云飞。","望陵宫女垂红泪，不见翠舆归。"]},{"id":"c58-630","title":"发引·上林春晚","rhythmic":"发引","author":"王","authorSlug":"王","dynasty":"宋","kind":"ci","paragraphs":["上林春晚，曾是奉宸游。","水殿戏龙舟。","玉箫吹断催仙驭，一去隔千秋。","游人重到曲江头。","事往涕难收。","空馀御幄传觞处，依旧水东流。"]},{"id":"c58-631","title":"凤箫吟・芳草·锁离愁","rhythmic":"凤箫吟・芳草","author":"韩缜","authorSlug":"韩缜","dynasty":"宋","kind":"ci","paragraphs":["锁离愁，连绵无际，来时陌上初熏。","绣帏人念远，暗垂珠泪，泣送征轮。","长亭长在眼，更重重、远水孤云。","但望极楼高，尽日目断王孙。","消魂。","池塘别后，曾行处、绿妒轻裙。","恁时携素手，乱花飞絮里，缓步香裀。","朱颜空自改，向年年、芳意长新。","遍绿野，嬉游醉眠，莫负青春。"]},{"id":"c58-632","title":"蝶恋花·香作风光浓著露","rhythmic":"蝶恋花","author":"韩缜姬","authorSlug":"韩缜姬","dynasty":"宋","kind":"ci","paragraphs":["香作风光浓著露。","正恁双栖，又遣分飞去。","密诉东君应不许。","泪波一洒奴衷素。"]},{"id":"c58-633","title":"浪淘沙·雁塞说并门","rhythmic":"浪淘沙","author":"裴湘","authorSlug":"裴湘","dynasty":"宋","kind":"ci","paragraphs":["雁塞说并门。","郡枕西汾。","山形高下远相吞。","古寺楼台依碧嶂，烟景遥分。","晋庙锁溪云。","箫鼓仍存。","牛羊斜日自归村。","惟有故城禾黍地，前事消魂。"]},{"id":"c58-634","title":"浪淘沙·万国仰神京","rhythmic":"浪淘沙","author":"裴湘","authorSlug":"裴湘","dynasty":"宋","kind":"ci","paragraphs":["万国仰神京。","礼乐纵横。","葱葱佳气锁龙城。","日御明堂天子圣，朝会簪缨。","九陌六街平。","万国充盈。","青楼弦管酒如渑。","别有隋堤烟柳暮，千古含情。"]},{"id":"c58-635","title":"花心动·仙苑春浓","rhythmic":"花心动","author":"阮逸女","authorSlug":"阮逸女","dynasty":"宋","kind":"ci","paragraphs":["仙苑春浓，小桃开，枝枝已堪攀折。","乍雨乍晴，轻暖轻寒，渐近赏花时节。","柳摇台榭东风软，帘栊静、幽禽调舌。","断魂远、闲寻翠径，顿成愁结。","此恨无人共说。","还立尽黄昏，寸心空切。","强整绣衾，独掩朱扉，簟枕为谁铺设。","夜长更漏传声远，纱窗映、银缸明灭。","梦回处，梅梢半笼淡月。"]},{"id":"c58-636","title":"蝶恋花·叶底无风池面静","rhythmic":"蝶恋花","author":"滕甫","authorSlug":"滕甫","dynasty":"宋","kind":"ci","paragraphs":["叶底无风池面静。","掬水佳人，拍破青铜镜。","残月朦胧花弄影。","新梳斜插乌云鬓。","拍索闷怀添酒兴。","旋撷园蔬，随分成盘饤。","说与翠微休急性。","功名富贵皆前定。"]},{"id":"c58-637","title":"蝶恋花·昼永无人深院静","rhythmic":"蝶恋花","author":"滕甫","authorSlug":"滕甫","dynasty":"宋","kind":"ci","paragraphs":["昼永无人深院静。","一枕春醒，犹未忺临镜。","帘卷新蟾光射影。","速忙掠起蓬松鬓。","对景沈吟嗟没兴。","薄幸不来，空把杯盘饤。","休道妇人多水性。","今宵独自言无定。"]},{"id":"c58-638","title":"桂枝香·登临送目","rhythmic":"桂枝香","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["登临送目。","正故国晚秋，天气初肃。","千里澄江似练，翠峰如簇。","归帆去棹残阳里，背西风、酒旗斜矗。","彩舟云淡，星河鹭起，画图难足。","念往昔、繁华竞逐。","叹门外楼头，悲恨相续。","千古凭高，对此漫嗟荣辱。","六朝旧事随流水，但寒烟、芳草凝绿。","至今商女，时时犹唱，后庭遗曲。"]},{"id":"c58-639","title":"甘露歌·折得一枝香在手","rhythmic":"甘露歌","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["折得一枝香在手。","人间应未有。","疑是经春雪未消。","今日是何朝。"]},{"id":"c58-640","title":"甘露歌·尽日含毫难比兴","rhythmic":"甘露歌","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["尽日含毫难比兴。","都无色可并。","万里晴天何处来。","真是屑琼瑰。"]},{"id":"c58-641","title":"甘露歌·天寒日暮山谷里","rhythmic":"甘露歌","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["天寒日暮山谷里。","的砾愁成水。","池上渐多枝上稀。","唯有故人知。"]},{"id":"c58-642","title":"菩萨蛮·数家茅屋闲临水","rhythmic":"菩萨蛮","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["数家茅屋闲临水。","单衫短帽垂杨里。","今日是何朝。","看予度石桥。","梢梢新月偃。","午醉醒来晚。","何物最关情。","黄鹂三两声。"]},{"id":"c58-643","title":"渔家傲·灯火已收正月半","rhythmic":"渔家傲","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["灯火已收正月半。","山南山北花撩乱。","闻说洊亭新水漫。","骑款段。","穿云入坞寻游伴。","却拂僧床褰素幔。","千岩万壑春风暖。","一弄松声悲急管。","吹梦断。","西看窗日犹嫌短。"]},{"id":"c58-644","title":"渔家傲·平岸小桥千嶂抱","rhythmic":"渔家傲","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["平岸小桥千嶂抱。","柔蓝一水萦花草。","茅屋数间窗窈窕。","尘不到。","时时自有春风扫。","午枕觉来闻语鸟。","敧眠似听朝鸡早。","忽忆故人今总老。","贪梦好。","茫然忘了邯郸道。"]},{"id":"c58-645","title":"雨霖铃·孜孜矻矻","rhythmic":"雨霖铃","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["孜孜矻矻。","向无明里、强作窠窟。","浮名浮利何济，堪留恋处，轮回仓猝。","幸有明空妙觉，可弹指超出。","缘底事、抛了全潮，认一浮沤作瀛渤。","本源自性天真佛。","祗些些、妄想中埋没。","贪他眼花阳艳，谁信道、本来无物。","一旦茫然，终被阎罗老子相屈。","便纵有、千种机筹，怎免伊唐突。"]},{"id":"c58-646","title":"清平乐·云垂平野","rhythmic":"清平乐","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["云垂平野。","掩映竹篱茅舍。","阒寂幽居实潇洒。","是处绿娇红冶。","丈夫运用堂堂。","且莫五角六张。","若有一卮芳酒，逍遥自在无妨。"]},{"id":"c58-647","title":"浣溪沙·百亩中庭半是苔","rhythmic":"浣溪沙","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["百亩中庭半是苔。","门前白道水萦回。","爱闲能有几人来。","小院回廊春寂寂，山桃溪杏两三栽。","为谁零落为谁开。"]},{"id":"c58-648","title":"诉衷情·常时黄色见眉间","rhythmic":"诉衷情","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["常时黄色见眉间。","松桂我同攀。","每言天上辛苦，不肯饵金丹。","怜水静，爱云闲。","便忘还。","高歌一曲，岩谷迤逦，宛似商山。"]},{"id":"c58-649","title":"诉衷情·练巾藜杖白云间","rhythmic":"诉衷情","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["练巾藜杖白云间。","有兴即跻攀。","追思往昔如梦，华毂也曾丹。","尘自扰，性长闲。","更无还。","达如周召，穷似丘轲，祗个山山。"]},{"id":"c58-650","title":"诉衷情·茫然不肯住林间","rhythmic":"诉衷情","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["茫然不肯住林间。","有处即追攀。","将他死语图度，怎得离真丹。","浆水价，匹如闲。","也须还。","何如直截，踢倒军持，赢取沩山。"]},{"id":"c58-651","title":"诉衷情·营巢燕子逞翱翔","rhythmic":"诉衷情","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["营巢燕子逞翱翔。","微志在雕梁。","碧云举翮千里，其奈有鸾皇。","临济处，德山行。","果承当。","自时降住，一切天魔，扫地焚香。"]},{"id":"c58-652","title":"诉衷情·莫言普化祗颠狂","rhythmic":"诉衷情","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["莫言普化祗颠狂。","真解作津梁。","蓦然打个筋斗，直跳过羲皇。","临济处，德山行。","果承当。","将他建立，认作心诚，也是寻香。"]},{"id":"c58-653","title":"南乡子·嗟见世间人","rhythmic":"南乡子","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["嗟见世间人。","但有纤毫即是尘。","不住旧时无相貌，沈沦。","祗为从来认识神。","作麽有疏亲。","我自降魔转法轮。","不是摄心除妄想，求真。","幻化空身即法身。"]},{"id":"c58-654","title":"南乡子·自古帝王州","rhythmic":"南乡子","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["自古帝王州。","郁郁葱葱佳气浮。","四百年来成一梦，堪愁。","晋代衣冠成古丘。","绕水恣行游。","上尽层城更上楼。","往事悠悠君莫问，回头。","槛外长江空自流。"]},{"id":"c58-655","title":"浪淘沙令·伊吕两衰翁","rhythmic":"浪淘沙令","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["伊吕两衰翁。","历遍穷通。","一为钓叟一耕佣。","若使当时身不遇，老了英雄。","汤武偶相逢。","风虎云龙。","兴王祗在笑谈中。","直至如今千载后，谁与争功。"]},{"id":"c58-656","title":"望江南・忆江南·归依众","rhythmic":"望江南・忆江南","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["归依众，梵行四威仪。","愿我遍游诸佛土。","十方贤圣不相离。","永灭世间痴。"]},{"id":"c58-657","title":"望江南・忆江南·归依法","rhythmic":"望江南・忆江南","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["归依法，法法不思议。","愿我六根常寂静，心如宝月映琉璃。","了法更无疑。"]},{"id":"c58-658","title":"望江南・忆江南·归依佛","rhythmic":"望江南・忆江南","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["归依佛，弹指越三祗。","愿我速登无上觉，还如佛坐道场时。","能智又能悲。"]},{"id":"c58-659","title":"望江南・忆江南·三界里","rhythmic":"望江南・忆江南","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["三界里，有取总灾危。","普愿众生同我愿，能於空有善思惟。","三宝共住持。"]},{"id":"c58-660","title":"西江月·梅好惟嫌淡伫","rhythmic":"西江月","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["梅好惟嫌淡伫，天教薄与胭脂。","真妃初出华清池。","酒入琼姬半醉。","东阁诗情易动，高楼玉管休吹。","北人浑作杏花疑。","惟有青枝不似。"]},{"id":"c58-661","title":"渔家傲·隔岸桃花红未半","rhythmic":"渔家傲","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["隔岸桃花红未半。","枝头已有蜂儿乱。","惆怅武陵人不管。","清梦断。","亭亭伫立春宵短。"]},{"id":"c58-662","title":"清平乐·留春不住","rhythmic":"清平乐","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["留春不住。","费尽莺儿语。","满地残红宫锦污。","昨夜南园风雨。","小怜初上琵琶。","晓来思绕天涯。","不肯画堂朱户，春风自在杨花。"]},{"id":"c58-663","title":"生查子·雨打江南树","rhythmic":"生查子","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["雨打江南树。","一夜花开无数。","绿叶渐成阴，下有游人归路。","与君相逢处。","不道春将暮。","把酒祝东风，且莫恁、匆匆去。"]},{"id":"c58-664","title":"谒金门·春又老","rhythmic":"谒金门","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["春又老。","南陌酒香梅小。","遍地落花浑不扫。","梦回情意悄。","红笺寄与添烦恼。","细写相思多少。","醉后几行书字小。","泪痕都搵了。"]},{"id":"c58-665","title":"菩萨蛮·海棠乱发皆临水","rhythmic":"菩萨蛮","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["海棠乱发皆临水。","君知此处花何似。","凉月白纷纷。","香风隔岸闻。","啭枝黄鸟近。","隔岸声相应。","随意坐莓苔。","飘零酒一杯。"]},{"id":"c58-666","title":"千秋岁引·别馆寒砧","rhythmic":"千秋岁引","author":"王安石","authorSlug":"王安石","dynasty":"宋","kind":"ci","paragraphs":["别馆寒砧，孤城画角。","一派秋声入寥廓。","东归燕从海上去，南来雁向沙头落。","楚台风，庾楼月，宛如昨。","无奈被些名利缚。","无奈被他情担阁。","可惜风流总闲却。","当初漫留华表语，而今误我秦楼约。","梦阑时，酒醒后，思量著。"]},{"id":"c58-667","title":"定风波·待得明年重把酒","rhythmic":"定风波","author":"吴氏1","authorSlug":"吴氏1","dynasty":"宋","kind":"ci","paragraphs":["待得明年重把酒。","携手。","那知无雨又无风。"]},{"id":"c58-668","title":"蜡梅香·锦里阳和","rhythmic":"蜡梅香","author":"吴师孟","authorSlug":"吴师孟","dynasty":"宋","kind":"ci","paragraphs":["锦里阳和，看万木凋时，早梅独秀。","珍馆琼楼畔，正降跗初吐，秾华将茂。","国艳天葩，真澹伫、雪肌清瘦。","似广寒宫，铅华未御，自然妆就。","凝睇倚朱阑，喷清香暗度，易袭襟袖。","好与花为主，宜秉烛、频观泛湘酎。","莫待南枝，随乐府、新声吹后。","对赏心人，良辰好景，须信难偶。"]},{"id":"c58-669","title":"阮郎归·钓鱼船上谢三郎","rhythmic":"阮郎归","author":"俞紫芝","authorSlug":"俞紫芝","dynasty":"宋","kind":"ci","paragraphs":["钓鱼船上谢三郎。","双鬓已苍苍。","蓑衣未必清贵，不肯换金章。","汀草畔，浦花旁。","静鸣榔。","自来好个，渔父家风，一片潇湘。"]},{"id":"c58-670","title":"临江仙·弄水亭前千万景","rhythmic":"临江仙","author":"俞紫芝","authorSlug":"俞紫芝","dynasty":"宋","kind":"ci","paragraphs":["弄水亭前千万景，登临不忍空回。","水轻墨澹写蓬莱。","莫教世眼，容易洗尘埃。","收去雨昏都不见，展时还似云开。","先生高趣更多才。","人人尽道，小杜却重来。"]},{"id":"c58-671","title":"苏幕遮·地锺灵","rhythmic":"苏幕遮","author":"俞紫芝","authorSlug":"俞紫芝","dynasty":"宋","kind":"ci","paragraphs":["地锺灵，天应瑞。","簇簇香苞、团作真珠蕊。","玉宇瑶台分十二。","要伴姮娥，月里双双睡。","月如花，花似月。","花月生香，添此真奇异。","不许扬州夸间气。","昨夜春风，唤醒琼琼醉。"]},{"id":"c58-672","title":"失调名·玉环妾意无渝","rhythmic":"失调名","author":"郑獬","authorSlug":"郑獬","dynasty":"宋","kind":"ci","paragraphs":["玉环妾意无渝。","问君心、朝槿何如。"]},{"id":"c58-673","title":"好事近·江上探春回","rhythmic":"好事近","author":"郑獬","authorSlug":"郑獬","dynasty":"宋","kind":"ci","paragraphs":["江上探春回，正值早梅时节。","两行小槽双凤，按凉州初彻。","谢娘扶下绣鞍来，红靴踏残雪。","归去不须银烛，有山头明月。"]},{"id":"c58-674","title":"好事近·把酒对江梅","rhythmic":"好事近","author":"郑獬","authorSlug":"郑獬","dynasty":"宋","kind":"ci","paragraphs":["把酒对江梅，花小未禁风力。","何计不教零落，为青春留得。","故人莫问在天涯，尊前苦相忆。","好把素香收取，寄江南消息。"]},{"id":"c58-675","title":"渔家傲·雪月照梅溪畔路","rhythmic":"渔家傲","author":"强至","authorSlug":"强至","dynasty":"宋","kind":"ci","paragraphs":["雪月照梅溪畔路。","幽姿背立无言语。","冷浸瘦枝清浅处。","香暗度。","妆成处士横斜句。","浑似玉人常淡伫。","菱花相对盈清楚。","谁解小图先画取。","天欲曙。","恐随月色云间去。"]},{"id":"c58-676","title":"踏莎行·竹阁云深","rhythmic":"踏莎行","author":"沈注","authorSlug":"沈注","dynasty":"宋","kind":"ci","paragraphs":["竹阁云深，巢虚人阒。","几年湖上音尘寂。","风流今有使君家，月明夜夜闻双笛。"]},{"id":"c58-677","title":"望梅花·一阳初起","rhythmic":"望梅花","author":"蒲宗孟","authorSlug":"蒲宗孟","dynasty":"宋","kind":"ci","paragraphs":["一阳初起。","暖力未胜寒气。","堪赏素华长独秀，不并开红抽紫。","青帝只应怜洁白，不使雷同众卉。","淡然难比。","粉蝶岂知芳蕊。","半夜卷帘如乍失，只在银蟾影里。","残雪枝头君认取，自有清香旖旎。"]},{"id":"c58-678","title":"减字木兰花·纤纤素手","rhythmic":"减字木兰花","author":"陈汝羲","authorSlug":"陈汝羲","dynasty":"宋","kind":"ci","paragraphs":["纤纤素手。","盘里醉花新点就。","对叶双心。","别有东风意思深。","琼沾粉缀。","消得玉堂留客醉。","试嗅清芳。","别有红罗巧袖香。"]},{"id":"c58-679","title":"行香子·晚绿寒红","rhythmic":"行香子","author":"汪辅之","authorSlug":"汪辅之","dynasty":"宋","kind":"ci","paragraphs":["晚绿寒红。","芳意匆匆。","惜年华、今与谁同。","碧云零落，数字宾鸿。","看渚莲凋，宫扇旧，怨秋风。","流波坠叶，佳期何在，想天教、离恨无穷。","试将前事，闲倚梧桐。","有销魂处，明月夜，锦屏空。"]},{"id":"c58-680","title":"鹧鸪天·腊后春前暖律催","rhythmic":"鹧鸪天","author":"范纯仁","authorSlug":"范纯仁","dynasty":"宋","kind":"ci","paragraphs":["腊后春前暖律催。","日和风软欲开梅。","公方结客寻佳景，我亦忘形趁酒杯。","添歌管，续尊罍。","更阑烛短未能回。","清欢莫待相期约，乘兴来时便可来。"]},{"id":"c58-681","title":"雨中花・夜行船·万缕青青","rhythmic":"雨中花・夜行船","author":"张才翁","authorSlug":"张才翁","dynasty":"宋","kind":"ci","paragraphs":["万缕青青，初眠官柳，向人犹未成阴。","据雕鞍马上，拥鼻微吟。","远宦情怀谁问，空嗟壮志销沈。","正好花时节，山城留滞、忍负归心。","别离万里，飘蓬无定，谁念会合难凭。","相聚里，休辞金盏，酒浅还深。","欲把春愁抖擞，春愁转更难禁。","乱山高处，凭阑垂袖，聊寄登临。"]},{"id":"c58-682","title":"渔家傲·深愿弘慈无缝罅","rhythmic":"渔家傲","author":"寿涯禅师","authorSlug":"寿涯禅师","dynasty":"宋","kind":"ci","paragraphs":["深愿弘慈无缝罅。","乘时走入众生界。","窈窕丰姿都没赛。","提鱼卖。","堪笑马郎来纳败。","清冷露湿金襽坏。","茜裙不把珠缨盖。","特地掀来呈捏怪。","牵人爱。","还尽许多菩萨债。"]},{"id":"c58-683","title":"水龙吟·燕忙莺懒花残","rhythmic":"水龙吟","author":"章","authorSlug":"章","dynasty":"宋","kind":"ci","paragraphs":["燕忙莺懒花残，正堤上、柳花飘坠。","轻飞点画青林，谁道全无才思。","闲趁游丝，静临深院，日长门闭。","傍珠帘散漫，垂垂欲下，依前被，风扶起。","兰帐玉人睡觉，怪春衣、雪粘琼缀。","绣床旋满，香球无数，才圆却碎。","时见蜂儿，仰粘轻粉，鱼吹池水。","望章台路杳，金鞍游荡，有盈盈泪。"]},{"id":"c58-684","title":"声声令・胜胜令·帘移碎影","rhythmic":"声声令・胜胜令","author":"章","authorSlug":"章","dynasty":"宋","kind":"ci","paragraphs":["帘移碎影，香褪衣襟。","旧家庭院嫩苔侵。","东风过尽，暮云锁，绿窗深。","怕对人、闲枕剩衾。","楼底轻阴。","春信断，怯登临。","断肠魂梦两沈沈。","花飞水远，便从今。","莫追寻。","又怎禁、蓦地上心。"]},{"id":"c58-685","title":"渔父乐・渔歌子·水曲山隈四五家","rhythmic":"渔父乐・渔歌子","author":"徐积","authorSlug":"徐积","dynasty":"宋","kind":"ci","paragraphs":["水曲山隈四五家。","夕阳烟火隔芦花。","渔唱歇，醉眠斜。","纶竿蓑笠是生涯。"]},{"id":"c58-686","title":"渔父乐・渔歌子·见说红尘罩九衢","rhythmic":"渔父乐・渔歌子","author":"徐积","authorSlug":"徐积","dynasty":"宋","kind":"ci","paragraphs":["见说红尘罩九衢。","贪名逐利各区区。","论得失，问荣枯。","争似侬家占五湖。"]},{"id":"c58-687","title":"渔父乐・渔歌子·讨得渔竿买得船","rhythmic":"渔父乐・渔歌子","author":"徐积","authorSlug":"徐积","dynasty":"宋","kind":"ci","paragraphs":["讨得渔竿买得船。","归休何必待高年。","深浪里，乱云边。","只有逍遥是水仙。"]},{"id":"c58-688","title":"渔父乐・渔歌子·饱则高歌醉即眠","rhythmic":"渔父乐・渔歌子","author":"徐积","authorSlug":"徐积","dynasty":"宋","kind":"ci","paragraphs":["饱则高歌醉即眠。","只知头白不知年。","江绕屋，水随船。","买得风光不著钱。"]},{"id":"c58-689","title":"渔父乐・渔歌子·管得江湖占得山","rhythmic":"渔父乐・渔歌子","author":"徐积","authorSlug":"徐积","dynasty":"宋","kind":"ci","paragraphs":["管得江湖占得山。","白云同散学云闲。","清旦出，夕阳还。","不知身在画屏间。"]},{"id":"c58-690","title":"渔父乐・渔歌子·一酌村醪一曲歌","rhythmic":"渔父乐・渔歌子","author":"徐积","authorSlug":"徐积","dynasty":"宋","kind":"ci","paragraphs":["一酌村醪一曲歌。","回看尘世足风波。","忧患大，是非多。","纵得荣华有几何。"]},{"id":"c58-691","title":"开元乐・三台·鹳鹊楼头日暖","rhythmic":"开元乐・三台","author":"沈括","authorSlug":"沈括","dynasty":"宋","kind":"ci","paragraphs":["鹳鹊楼头日暖，蓬莱殿里花香。","草绿烟迷步辇，天高日近龙床。"]},{"id":"c58-692","title":"开元乐・三台·楼上正临宫外","rhythmic":"开元乐・三台","author":"沈括","authorSlug":"沈括","dynasty":"宋","kind":"ci","paragraphs":["楼上正临宫外，人间不见仙家。","寒食轻烟薄雾，满城明月梨花。"]},{"id":"c58-693","title":"开元乐・三台·按舞骊山影里","rhythmic":"开元乐・三台","author":"沈括","authorSlug":"沈括","dynasty":"宋","kind":"ci","paragraphs":["按舞骊山影里，回銮渭水光中。","玉笛一天明月，翠华满陌东风。"]},{"id":"c58-694","title":"开元乐・三台·殿后春旗簇仗","rhythmic":"开元乐・三台","author":"沈括","authorSlug":"沈括","dynasty":"宋","kind":"ci","paragraphs":["殿后春旗簇仗，楼前御队穿花。","一片红云闹处，外人遥认官家。"]},{"id":"c58-695","title":"失调名·谢娘栀子","rhythmic":"失调名","author":"范宽之","authorSlug":"范宽之","dynasty":"宋","kind":"ci","paragraphs":["谢娘栀子，贾妃萸佩。"]},{"id":"c58-696","title":"黄鹤引·生逢垂拱","rhythmic":"黄鹤引","author":"方资","authorSlug":"方资","dynasty":"宋","kind":"ci","paragraphs":["生逢垂拱。","不识干戈免田陇。","士林书圃终年，庸非天宠。","才初闒茸。","老去支离何用。","浩然归弄。","似黄鹤、秋风相送。","尘事塞翁心，浮世庄生梦。","漾舟遥指烟波，群山森动。","神闲意耸。","回首利鞿名鞚。","此情谁共。","问几斛、淋浪春瓮。"]},{"id":"c58-697","title":"点绛唇·秋气微凉","rhythmic":"点绛唇","author":"王安国","authorSlug":"王安国","dynasty":"宋","kind":"ci","paragraphs":["秋气微凉，梦回明月穿帘幕。","井梧萧索。","正绕南枝鹊。","宝瑟尘生，金雁空零落。","情无托。","鬓云慵掠。","不似君恩薄。"]},{"id":"c58-698","title":"清平乐·留春不住","rhythmic":"清平乐","author":"王安国","authorSlug":"王安国","dynasty":"宋","kind":"ci","paragraphs":["留春不住。","费尽莺儿语。","满地残红宫锦污。","昨夜南园风雨。","小怜初上琵琶。","晓来思绕天涯。","不肯画堂朱户，春风自在梨花。"]},{"id":"c58-699","title":"减字木兰花·画桥流水","rhythmic":"减字木兰花","author":"王安国","authorSlug":"王安国","dynasty":"宋","kind":"ci","paragraphs":["画桥流水。","雨湿落红飞不起。","月破黄昏。","帘里馀香马上闻。","徘徊不语。","今夜梦魂何处去。","不似垂杨。","犹解飞花入洞房。"]}]