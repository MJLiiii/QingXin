{"丁几仲":{"slug":"丁几仲","name":"丁几仲","dynasty":"宋","style":"","life":"","origin":"","seal":"丁","bio":[],"works":[{"id":"c76-547","title":"贺新郎·喜溢蟾宫梦","kind":"词"}]},"元万顷":{"slug":"元万顷","name":"元万顷","dynasty":"唐","style":"","life":"","origin":"","seal":"元","bio":["元万顷，洛阳人。后魏景穆皇帝之裔，起家通事舍人。干封中，从英国公李𪟝征高丽，令作檄文，万顷讥其不知守鸭绿之险，莫离支报曰：“谨闻命矣。","”遂移兵守鸭绿，兵不得入，坐流岭外，遇赦还，为北门学士。则天时，迁凤阁侍郎，坐与徐敬业兄弟友善，贬死。诗四首。"],"works":[{"id":"t2-886","title":"奉和太子纳妃太平公主出降","kind":"诗"},{"id":"t2-887","title":"奉和春日池台","kind":"诗"},{"id":"t2-888","title":"奉和春日二首 一","kind":"诗"},{"id":"t2-889","title":"奉和春日二首 二","kind":"诗"}]},"公乘亿":{"slug":"公乘亿","name":"公乘亿","dynasty":"唐","style":"字寿仙","life":"","origin":"","seal":"公","bio":["公乘亿，字寿仙，魏人。咸通末，登进士第，为魏博节度使乐彦祯从事，加授侍郎。诗一卷，今存四首。"],"works":[{"id":"t33-370","title":"赋得郎官上应列宿","kind":"诗"},{"id":"t33-371","title":"春风扇微和","kind":"诗"},{"id":"t33-372","title":"赋得秋菊有佳色","kind":"诗"},{"id":"t33-373","title":"赋得临江迟来客","kind":"诗"},{"id":"t33-374","title":"句","kind":"诗"}]},"大愚":{"slug":"大愚","name":"大愚","dynasty":"唐","style":"","life":"","origin":"","seal":"大","bio":["大愚，邺都青莲寺沙门。诗一首。"],"works":[{"id":"t45-538","title":"乞荆浩画","kind":"诗"}]},"徐俨夫":{"slug":"徐俨夫","name":"徐俨夫","dynasty":"宋","style":"","life":"","origin":"","seal":"徐","bio":[],"works":[{"id":"c73-963","title":"西江月·曲折迷春院宇","kind":"词"}]},"慧坚":{"slug":"慧坚","name":"慧坚","dynasty":"唐","style":"","life":"","origin":"","seal":"慧","bio":["慧坚，嗣归仁，住郢州大阳山。诗一首。（《全唐诗》无慧坚诗）"],"works":[{"id":"t56-64","title":"法身颂","kind":"诗"}]},"李仁悦":{"slug":"李仁悦","name":"李仁悦","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李仁，悦，后蜀广政二十年为简州清化军镇遏使。诗一首。（《全唐诗》无李仁悦诗）"],"works":[{"id":"t56-263","title":"偈","kind":"诗"}]},"李流谦":{"slug":"李流谦","name":"李流谦","dynasty":"宋","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"c66-959","title":"踏莎行·菊露晴黄","kind":"词"},{"id":"c66-960","title":"如梦令·老插黄花不称","kind":"词"},{"id":"c66-961","title":"醉蓬莱·正红疏绿密","kind":"词"},{"id":"c66-962","title":"小重山·轻暑单衣四月天","kind":"词"},{"id":"c66-963","title":"青玉案·