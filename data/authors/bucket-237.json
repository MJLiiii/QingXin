{"于经野":{"slug":"于经野","name":"于经野","dynasty":"唐","style":"","life":"","origin":"","seal":"于","bio":["于经野，中宗时为户部尚书。诗一首。"],"works":[{"id":"t5-306","title":"奉和九日幸临渭亭登高应制得樽字","kind":"诗"}]},"卢氏":{"slug":"卢氏","name":"卢氏","dynasty":"宋","style":"","life":"","origin":"","seal":"卢","bio":[],"works":[{"id":"c58-602","title":"凤栖梧・蝶恋花·蜀道青天烟霭翳","kind":"词"}]},"密陀僧":{"slug":"密陀僧","name":"密陀僧","dynasty":"唐","style":"","life":"","origin":"","seal":"密","bio":[],"works":[{"id":"t48-33","title":"湖城厅吟","kind":"诗"}]},"庄翱":{"slug":"庄翱","name":"庄翱","dynasty":"唐","style":"","life":"","origin":"","seal":"庄","bio":[],"works":[{"id":"t50-17","title":"寻幽居不遇","kind":"诗"},{"id":"t50-18","title":"句","kind":"诗"}]},"弓嗣初":{"slug":"弓嗣初","name":"弓嗣初","dynasty":"唐","style":"","life":"","origin":"","seal":"弓","bio":["弓嗣初，登咸亨二年进士第一人。诗二首。"],"works":[{"id":"t3-991","title":"晦日宴高氏林亭","kind":"诗"},{"id":"t3-992","title":"晦日重宴","kind":"诗"}]},"张复":{"slug":"张复","name":"张复","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张复，元和中人。诗一首。"],"works":[{"id":"t26-524","title":"山出云","kind":"诗"}]},"张白醪":{"slug":"张白醪","name":"张白醪","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["白醪，广明末衡阳人。诗一首。（《全唐诗》无张白醪诗）"],"works":[{"id":"t54-182","title":"歌","kind":"诗"}]},"李敻":{"slug":"李敻","name":"李敻","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t49-27","title":"恒岳晨望有怀","kind":"诗"}]},"李贞白":{"slug":"李贞白","name":"李贞白","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t48-318","title":"咏刺猬","kind":"诗"},{"id":"t48-319","title":"谒贵公子不礼书格子屏风","kind":"诗"},{"id":"t48-320","title":"咏月","kind":"诗"},{"id":"t48-321","title":"咏狗蚤","kind":"诗"},{"id":"t48-322","title":"咏罂粟子","kind":"诗"},{"id":"t48-323","title":"咏蟹","kind":"诗"}]},"武昌妓":{"slug":"武昌妓","name":"武昌妓","dynasty":"唐","style":"","life":"","origin":"","seal":"武","bio":[],"works":[{"id":"t44-103","title":"续韦蟾句","kind":"诗"}]},"毛明素":{"slug":"毛明素","name":"毛明素","dynasty":"唐","style":"","life":"","origin":"","seal":"毛","bio":["毛明素，贞观中人，诗一首。"],"works":[{"id":"t2-691","title":"与琳法师","kind":"诗"}]},"王丘":{"slug":"王丘","name":"王丘","dynasty":"唐","style":"字仲山","life":"","origin":"","seal":"王","bio":["王丘，字仲山，相州安阳人。举制科中第，自偃师主簿擢监察御史。开元初，迁紫微舍人，吏部侍郎，其奖用如孙逖、张晋明、王冷然，皆一时茂秀。","萧[嵩]暠引与当国，丘固辞，盛推韩休。休秉政，荐为御史大夫，终礼部尚书。诗三首。"],"works":[{"id":"t5-432","title":"咏史","kind":"诗"},{"id":"t5-433","title":"奉和圣制荅张说扈从南出鼠雀谷之作","kind":"诗"},{"id":"t5-434","title":"奉和圣制送张尚书巡边","kind":"诗"}]},"王岳灵":{"slug":"王岳灵","name":"王岳灵","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王岳灵，登开元进士第。天宝中，累官至监察御史。诗一首。"],"works":[{"id":"t6-992","title":"闻漏","kind":"诗"}]},"郑良士":{"slug":"郑良士","name":"郑良士","dynasty":"唐","style":"字君梦","life":"","origin":"","seal":"郑","bio":["郑良士，字君梦，闽人。昭宗时，献诗五百篇，授补阙。《白岩集》十卷。","今存三首。"],"works":[{"id":"t40-849","title":"题兴化高田院桥亭","kind":"诗"},{"id":"t40-850","title":"游九鲤湖","kind":"诗"},{"id":"t40-851","title":"寄富洋院禅者","kind":"诗"},{"id":"t54-287","title":"郑明府池亭","kind":"诗"},{"id":"t54-288","title":"送人罢尉归山","kind":"诗"},{"id":"t54-289","title":"题鸣峰岩 一","kind":"诗"},{"id":"t54-290","title":"题鸣峰岩 二","kind":"诗"}]},"陈坦之":{"slug":"陈坦之","name":"陈坦之","dynasty":"宋","style":"","life":"","origin":"","seal":"陈","bio":[],"works":[{"id":"c74-853","title":"塞翁吟·远碧秋痕瘦","kind":"词"},{"id":"c74-854","title":"沁园春·睡起闻莺","kind":"词"},{"id":"c74-855","title":"柳梢青·绿弱红臞","kind":"词"},{"id":"c74-856","title":"谒金门·归未卜","kind":"词"}]},"韩定辞":{"slug":"韩定辞","name":"韩定辞","dynasty":"唐","style":"","life":"","origin":"","seal":"韩","bio":["韩定辞，深州人，为镇州观察判官、捡校尚书祠部郎中、兼侍御史。诗一首。"],"works":[{"id":"t42-414","title":"答马彧","kind":"诗"}]},"颜真卿等":{"slug":"颜真卿等","name":"颜真卿等","dynasty":"唐","style":"字清臣","life":"","origin":"","seal":"颜","bio":["颜真卿字清臣，京兆长安人。开元二十二年进士及第，历任玄、肃、代诸朝，封鲁国公。李希烈陷汝州，卢杞奏遣真卿往谕，拘胁累岁，不屈而死。"],"works":[{"id":"t51-5","title":"竹山连句题潘氏书堂","kind":"诗"}]},"黄夷简":{"slug":"黄夷简","name":"黄夷简","dynasty":"唐","style":"字明举","life":"","origin":"","seal":"黄","bio":["夷简，字明举，福州人。仕吴越为明州判官，累迁检校秘书监、平江节度副使。开宝初使宋，太祖劝以归顺，归匿其言而退隐。","至吴越纳土，始复出，仕至平江军节度使。大中祥符四年卒，年七十七。（《全唐诗》无黄夷简诗，传据《宋史》卷四四一、《十国春秋》卷八七。","）"],"works":[{"id":"t55-713","title":"山居诗","kind":"诗"}]}}