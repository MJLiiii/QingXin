{"严蕊":{"slug":"严蕊","name":"严蕊","dynasty":"宋","style":"字幼芳","life":"","origin":"","seal":"严","bio":["--字幼芳，天台营妓。与朱熹、唐与正同时。事见周密《齐东野语》卷二十。","存词三首。"],"works":[{"id":"c67-882","title":"卜算子·不是爱风尘","kind":"词"},{"id":"c67-883","title":"如梦令·道是梨花不是","kind":"词"},{"id":"c67-884","title":"鹊桥仙·碧梧初出","kind":"词"}]},"冯熔":{"slug":"冯熔","name":"冯熔","dynasty":"宋","style":"","life":"","origin":"","seal":"冯","bio":[],"works":[{"id":"c71-616","title":"如梦令·素养浩然之气","kind":"词"}]},"叶法善":{"slug":"叶法善","name":"叶法善","dynasty":"唐","style":"字道元","life":"","origin":"","seal":"叶","bio":["叶法善，字道元，一字太素。家于松阳，遍历名山，得道术。高宗征之，驻景龙观。","明皇朝，试法多灵验。开元八年，年一百七岁，化去，留三诗于座侧。"],"works":[{"id":"t47-693","title":"留诗 一","kind":"诗"},{"id":"t47-694","title":"留诗 二","kind":"诗"},{"id":"t47-695","title":"留诗 三","kind":"诗"}]},"周渭":{"slug":"周渭","name":"周渭","dynasty":"唐","style":"字兆师","life":"","origin":"此为南汉宋初","seal":"周","bio":["周渭，大历十四年登第。诗二首。渭，字兆师，淮阴人。","大历十四年进士。历任汝州襄城尉、富平、长安尉、监察御史、殿中侍御史、膳部员外郎、祠部郎中，守秘书少监致仕，永贞元年卒，年六十六。补诗一首。","（《全唐诗》卷二八一收周渭诗，传甚简，今据《权载之文集》卷二三《唐故朝大夫守秘书少监致仕周君墓志铭》重录传） 渭，字得臣，昭州恭城人。大宝时苦于繁赋，逾岭北行，至汴京上书陈时务。后仕宋，历任漕使。","咸平二年卒，年七十七。诗二首。（《全唐诗》卷二八一收周渭，为大历间人。","此为南汉宋初人，兹据《宋史》卷三○四、《十国春秋》卷六五录传。）"],"works":[{"id":"t15-93","title":"赋得花发上林","kind":"诗"},{"id":"t15-94","title":"赠龙兴观主吴崇岳","kind":"诗"},{"id":"t53-155","title":"湘妃庙","kind":"诗"},{"id":"t56-36","title":"叠秀山","kind":"诗"},{"id":"t56-37","title":"游兼山","kind":"诗"}]},"孔颙":{"slug":"孔颙","name":"孔颙","dynasty":"唐","style":"","life":"","origin":"","seal":"孔","bio":[],"works":[{"id":"t48-254","title":"上浙东孟尚书","kind":"诗"}]},"孟安序":{"slug":"孟安序","name":"孟安序","dynasty":"唐","style":"","life":"","origin":"","seal":"孟","bio":[],"works":[{"id":"t56-325","title":"桃源（题拟）","kind":"诗"}]},"张守中":{"slug":"张守中","name":"张守中","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"t48-75","title":"句","kind":"诗"}]},"张迥":{"slug":"张迥","name":"张迥","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"t43-720","title":"句","kind":"诗"}]},"徐希仁":{"slug":"徐希仁","name":"徐希仁","dynasty":"唐","style":"","life":"","origin":"","seal":"徐","bio":["徐希仁，与卢仝同时。诗一首。"],"works":[{"id":"t25-163","title":"招玉川子咏新文","kind":"诗"}]},"曾布":{"slug":"曾布","name":"曾布","dynasty":"宋","style":"","life":"","origin":"","seal":"曾","bio":[],"works":[{"id":"c59-3","title":"江南好・忆江南·江南客","kind":"词"},{"id":"c59-4","title":"水调歌头·魏豪有冯燕","kind":"词"},{"id":"c59-5","title":"水调歌头·袖笼鞭敲镫","kind":"词"},{"id":"c59-6","title":"水调歌头·说良人滑将张婴","kind":"词"},{"id":"c59-7","title":"水调歌头·一夕还家醉","kind":"词"},{"id":"c59-8","title":"水调歌头·凤凰钗","kind":"词"},{"id":"c59-9","title":"水调歌头·向红尘里","kind":"词"},{"id":"c59-10","title":"水调歌头·义城元靖贤相国","kind":"词"}]},"李当":{"slug":"李当","name":"李当","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李当，晚唐懿宗、僖宗时人。历中书舍人、户部侍郎，出为河南尹，旋复除尚书左丞。时路严弄柄，摒斥异己，由是出牧道州。","诗一首。（《全唐诗》无李当诗）"],"works":[{"id":"t50-855","title":"题朝阳洞","kind":"诗"},{"id":"t54-135","title":"遇（疑为「过」）信美台诗","kind":"诗"}]},"毛熙圣":{"slug":"毛熙圣","name":"毛熙圣","dynasty":"唐","style":"","life":"","origin":"","seal":"毛","bio":[],"works":[{"id":"t56-298","title":"题孟岩","kind":"诗"}]},"玄觉":{"slug":"玄觉","name":"玄觉","dynasty":"唐","style":"字明道","life":"","origin":"","seal":"玄","bio":["玄觉，字明道，俗姓戴，永嘉人。总角出家，住龙兴寺。后诣韶州谒慧能，留一宿而悟佛法，世称一宿觉和尚。","先天二年卒，年四十九。诗一首。（《全唐诗》无玄觉诗，传录《宋高僧传》卷八）"],"works":[{"id":"t52-595","title":"永嘉证道歌","kind":"诗"}]},"王绰":{"slug":"王绰","name":"王绰","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王绰，登上元进士第。诗一首。"],"works":[{"id":"t13-604","title":"迎春东郊","kind":"诗"}]},"王翰":{"slug":"王翰","name":"王翰","dynasty":"唐","style":"字子羽","life":"","origin":"","seal":"王","bio":["王翰，字子羽，晋阳人。登进士第，举直言极谏，调昌乐尉，复举超拔群类。召为秘书正字，擢通事舍人，驾部员外。","出为汝州长史，改仙州别驾。日与才士豪侠饮乐游畋，坐贬道州司马卒。集十卷，今存诗一卷。","王翰，字子羽，晋阳人，登进士第，举直言极谏，调昌乐尉，复举超拔群类，召为秘书正字，擢通事舍人，驾部员外，出为汝州长史，改仙州别驾，日与才士豪侠饮乐游畋，坐贬道州司马卒。集十卷，今存诗一卷。"],"works":[{"id":"t1-246","title":"相和歌辞 饮马长城窟行","kind":"诗"},{"id":"t1-344","title":"相和歌辞 蛾眉怨","kind":"诗"},{"id":"t1-357","title":"相和歌辞 子夜春歌","kind":"诗"},{"id":"t7-619","title":"赠唐祖二子","kind":"诗"},{"id":"t7-620","title":"飞燕篇","kind":"诗"},{"id":"t7-621","title":"饮马长城窟行","kind":"诗"},{"id":"t7-622","title":"赋得明星玉女坛送廉察尉华阴","kind":"诗"},{"id":"t7-623","title":"春女行","kind":"诗"},{"id":"t7-624","title":"古娥眉怨","kind":"诗"},{"id":"t7-625","title":"子夜春歌","kind":"诗"},{"id":"t7-626","title":"奉和圣制同二相已下群官乐游园宴","kind":"诗"},{"id":"t7-627","title":"奉和圣制送张说上集贤院学士赐宴得筵字","kind":"诗"},{"id":"t7-628","title":"奉和圣制送张尚书巡边","kind":"诗"},{"id":"t7-629","title":"凉州词二首 一","kind":"诗"},{"id":"t7-630","title":"凉州词二首 二","kind":"诗"},{"id":"t7-631","title":"春日归思","kind":"诗"},{"id":"t7-632","title":"观蛮童为伎之作","kind":"诗"},{"id":"t48-802","title":"龙兴观金箓建醮","kind":"诗"},{"id":"t52-751","title":"答客问","kind":"诗"}]},"程杰":{"slug":"程杰","name":"程杰","dynasty":"唐","style":"","life":"","origin":"","seal":"程","bio":["程杰，无考。诗一首。（《全唐诗》无程杰诗）"],"works":[{"id":"t51-7","title":"无题","kind":"诗"},{"id":"t51-8","title":"芙蓉峰","kind":"诗"}]},"范周":{"slug":"范周","name":"范周","dynasty":"宋","style":"","life":"","origin":"","seal":"范","bio":[],"works":[{"id":"c59-684","title":"木兰花慢·美兰堂昼永","kind":"词"},{"id":"c59-685","title":"宝鼎现·夕阳西下","kind":"词"}]},"薛耀":{"slug":"薛耀","name":"薛耀","dynasty":"唐","style":"","life":"","origin":"","seal":"薛","bio":[],"works":[{"id":"t1-359","title":"相和歌辞 子夜冬歌","kind":"诗"}]},"裴丹":{"slug":"裴丹","name":"裴丹","dynasty":"唐","style":"","life":"","origin":"","seal":"裴","bio":["丹，开成三年为泾令。诗一首。（《全唐诗》无裴丹诗）"],"works":[{"id":"t53-711","title":"重建东峰亭（有序）","kind":"诗"}]},"魏朴":{"slug":"魏朴","name":"魏朴","dynasty":"唐","style":"字不琢","life":"","origin":"","seal":"魏","bio":["魏朴，字不琢，毘陵人。诗二首。"],"works":[{"id":"t34-765","title":"和皮日休悼鹤 一","kind":"诗"},{"id":"t34-766","title":"和皮日休悼鹤 二","kind":"诗"}]}}