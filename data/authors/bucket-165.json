":"","seal":"独","bio":["独孤良弼，贞元间进士，官左司郎中。诗一首。"],"works":[{"id":"t24-937","title":"上巳接清明游宴","kind":"诗"}]},"辨才":{"slug":"辨才","name":"辨才","dynasty":"唐","style":"","life":"","origin":"","seal":"辨","bio":["辨才，唐初人。姓袁氏，居越州永钦寺，智永弟子。诗一首。"],"works":[{"id":"t44-688","title":"设缸面酒欵萧翼探得来字","kind":"诗"},{"id":"t52-96","title":"赴召","kind":"诗"}]},"郑孺华":{"slug":"郑孺华","name":"郑孺华","dynasty":"唐","style":"","life":"","origin":"","seal":"郑","bio":["郑孺华，大历间人。诗一首。"],"works":[{"id":"t14-372","title":"赋得生刍一束","kind":"诗"}]},"郑文妻":{"slug":"郑文妻","name":"郑文妻","dynasty":"宋","style":"","life":"","origin":"","seal":"郑","bio":["--郑文，秀州人，太学生。妻，孙氏，存词一首。"],"works":[{"id":"c76-411","title":"忆秦娥·花深深","kind":"词"}]},"郭仲循":{"slug":"郭仲循","name":"郭仲循","dynasty":"宋","style":"","life":"","origin":"","seal":"郭","bio":[],"works":[{"id":"c64-502","title":"玉楼春·靓妆才学春无价","kind":"词"}]},"都下妓":{"slug":"都下妓","name":"都下妓","dynasty":"宋","style":"","life":"","origin":"","seal":"都","bio":[],"works":[{"id":"c64-776","title":"朝中措·屏山栏槛倚晴空","kind":"词"}]},"韦渠牟":{"slug":"韦渠牟","name":"韦渠牟","dynasty":"唐","style":"","life":"","origin":"","seal":"韦","bio":["韦渠牟，京兆万年人。少慧悟，涉览经史。初为道士，后为僧。","韩滉表试校书郎，德宗诞日，召之，同佛老师讲论大义，爱其辨博，因奏七十诣诗。旬日，再转右补阙、内供奉，迁谏议大夫。数召对奏事，终大常卿。","诗集十卷，今存二十一首。"],"works":[{"id":"t2-378","title":"杂歌谣辞 步虚词 一","kind":"诗"},{"id":"t2-379","title":"杂歌谣辞 步虚词 二","kind":"诗"},{"id":"t2-380","title":"杂歌谣辞 步虚词 三","kind":"诗"},{"id":"t2-381","title":"杂歌谣辞 步虚词 四","kind":"诗"},{"id":"t2-382","title":"杂歌谣辞 步虚词 五","kind":"诗"},{"id":"t2-383","title":"杂歌谣辞 步虚词 六","kind":"诗"},{"id":"t2-384","title":"杂歌谣辞 步虚词 七","kind":"诗"},{"id":"t2-385","title":"杂歌谣辞 步虚词 八","kind":"诗"},{"id":"t2-386","title":"杂歌谣辞 步虚词 九","kind":"诗"},{"id":"t2-387","title":"杂歌谣辞 步虚词 十","kind":"诗"},{"id":"t2-388","title":"杂歌谣辞 步虚词 十一","kind":"诗"},{"id":"t2-389","title":"杂歌谣辞 步虚词 十二","kind":"诗"},{"id":"t2-390","title":"杂歌谣辞 步虚词 十三","kind":"诗"},{"id":"t2-391","title":"杂歌谣辞 步虚词 十四","kind":"诗"},{"id":"t2-392","title":"杂歌谣辞 步虚词 十五","kind":"诗"},{"id":"t2-393","title":"杂歌谣辞 步虚词 十六","kind":