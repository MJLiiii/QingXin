n":"","seal":"崔","bio":["崔成甫，官校书郎，再尉关辅。贬湘阴，有《泽畔吟》，李白为之序。其为陕县尉时，韦坚为陕郡太守兼水陆转运使，凿潭望春楼下，成甫因变《得丁纥反体都董反歌》为《得宝歌》，坚命舟人歌之。","成甫又广为十阕，今不传。存诗一首。"],"works":[{"id":"t13-589","title":"赠李十二白","kind":"诗"}]},"崔玄真":{"slug":"崔玄真","name":"崔玄真","dynasty":"唐","style":"号岷山子","life":"","origin":"","seal":"崔","bio":["崔玄真，号岷山子。天宝间隐居岷山。著有《灵沙受气用药诀》一卷、《云母论》二卷，今皆逸。","存诗一首。（《全唐诗》无崔玄真诗，传据《新唐书·艺文志》，惟「玄」作「元」。）"],"works":[{"id":"t52-881","title":"大还丹口诀","kind":"诗"}]},"张良璞":{"slug":"张良璞","name":"张良璞","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张良璞，长安尉。诗一首。"],"works":[{"id":"t10-38","title":"览史","kind":"诗"}]},"徐叔至":{"slug":"徐叔至","name":"徐叔至","dynasty":"宋","style":"","life":"","origin":"","seal":"徐","bio":[],"works":[{"id":"c78-378","title":"促拍满路花·人间秋正好","kind":"词"},{"id":"c78-379","title":"鹧鸪天·两两台符映昴躔","kind":"词"}]},"德圆":{"slug":"德圆","name":"德圆","dynasty":"唐","style":"","life":"","origin":"","seal":"德","bio":[],"works":[{"id":"t51-839","title":"云门寺","kind":"诗"},{"id":"t56-596","title":"游云门寺之一","kind":"诗"}]},"德宗宫人":{"slug":"德宗宫人","name":"德宗宫人","dynasty":"唐","style":"","life":"","origin":"","seal":"德","bio":["德宗宫人，奉恩院王才人养女凤儿也。诗一首。"],"works":[{"id":"t43-752","title":"题花叶诗","kind":"诗"}]},"李羽":{"slug":"李羽","name":"李羽","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李羽，庐州人，登南唐进士第。诗一首。"],"works":[{"id":"t42-416","title":"献江淮郡守卢公","kind":"诗"}]},"杨希道":{"slug":"杨希道","name":"杨希道","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":[],"works":[{"id":"t42-939","title":"侍宴赋得起坐弹鸣琴二首 一","kind":"诗"},{"id":"t42-940","title":"侍宴赋得起坐弹鸣琴二首 二","kind":"诗"},{"id":"t42-941","title":"咏琴","kind":"诗"},{"id":"t42-942","title":"咏笙","kind":"诗"},{"id":"t42-943","title":"咏舞","kind":"诗"}]},"王坚":{"slug":"王坚","name":"王坚","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王坚，武后时人。诗二句（《全唐诗》无王坚诗）"],"works":[{"id":"t50-520","title":"句","kind":"诗"}]},"王审知":{"slug":"王审知","name":"王审知","dynasty":"唐","style":"字信通","life":"","origin":"","seal":"王","bio":["审知，字信通，光州固始人。唐季，从兄潮起兵，入据福建。潮卒，继任威武军节度使，奄有闽地。","开平三年，封闽王。同光三年卒，年六十四。（《全唐诗》无王审知诗，兹据《十因春秋》卷九十拟传）"],"works":[{"id":"t55-805","title":"无题","kind":"诗"},{"id":"t55-806","title":"与僧对句（题拟）","kind":"诗"}]},"王炎2":{"slug":"王炎2","name":"王炎2","dynasty":"宋","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"c60-840","title":"蝶恋花·纤手行杯红玉润","kind":"词"},{"id":"c60-841","title":"蝶恋花·柳暗西湖春欲暮","kind":"词"},{"id":"c60-842","title":"点绛唇·雨湿东风","kind":"词"},{"id":"c60-843","title":"水调歌头·江月冷如水","kind":"词"},{"id":"c60-844","title":"水调歌头·千里倦游客","kind":"词"},{"id":"c60-845","title":"念奴娇·小妆朱槛","kind":"词"},{"id":"c60-846","title":"鹧鸪天·淡淡疏疏不惹尘","kind":"词"},{"id":"c68-635","title":"阮郎归·落花时节近清明","kind":"词"},{"id":"c68-636","title":"青玉案·深红数点吹花絮","kind":"词"},{"id":"c68-637","title":"浪淘沙令·流水绕孤村","kind":"词"},{"id":"c68-638","title":"木兰花慢·缃桃花树下","kind":"词"},{"id":"c68-639","title":"清平乐·呢喃燕语","kind":"词"},{"id":"c68-640","title":"清平乐·儿曹耳语","kind":"词"},{"id":"c68-641","title":"浪淘沙·月色十分圆","kind":"词"},{"id":"c68-642","title":"卜算子·渡口唤扁舟","kind":"词"},{"id":"c68-643","title":"卜算子·散策问芳菲","kind":"词"},{"id":"c68-644","title":"江城子·清波渺渺日晖晖","kind":"词"},{"id":"c68-645","title":"虞美人·镜中失画双青鬓","kind":"词"},{"id":"c68-646","title":"南乡子·云淡日昽明","kind":"词"},{"id":"c68-647","title":"忆秦娥·胭脂点","kind":"词"},{"id":"c68-648","title":"临江仙·欲近上元人意好","kind":"词"},{"id":"c68-649","title":"好事近·时节近元宵","kind":"词"},{"id":"c68-650","title":"水调歌头·爱日护轻暖","kind":"词"},{"id":"c68-651","title":"念奴娇·晓来雨过","kind":"词"},{"id":"c68-652","title":"浪淘沙令·秋色满东篱","kind":"词"},{"id":"c68-653","title":"采桑子·一番飞次春风巧","kind":"词"},{"id":"c68-654","title":"好事近·玉颊映红绡","kind":"词"},{"id":"c68-655","title":"临江仙·雪片幻成肌骨","kind":"词"},{"id":"c68-656","title":"卜算子·腻玉染深红","kind":"词"},{"id":"c68-657","title":"木兰花慢·博山香雾冷","kind":"词"},{"id":"c68-658","title":"小重山·日脚才添一线长","kind":"词"},{"id":"c68-659","title":"阮郎归·几回幽梦绕家山","kind":"词"},{"id":"c68-660","title":"临江仙·试问休官林下去","kind":"词"},{"id":"c68-661","title":"临江仙·思忆故园花又发","kind":"词"},{"id":"c68-662","title":"水调歌头·新涨鸭头绿","kind":"词"},{"id":"c68-663","title":"南柯子・南歌子·天末家何许","kind":"词"},{"id":"c68-664","title":"好事近·闲日似年长","kind":"词"},{"id":"c68-665","title":"朝中措·杜鹃声断日曈昽","kind":"词"},{"id":"c68-666","title":"南柯子・南歌子·对镜鸾休舞","kind":"词"},{"id":"c68-667","title":"朝中措·蔷薇露染玉肌肤","kind":"词"},{"id":"c68-668","title":"西江月·蔌蔌落红都尽","kind":"词"},{"id":"c68-669","title":"柳梢青·葭管风微","kind":"词"},{"id":"c68-670","title":"踏莎行·木落天寒","kind":"词"},{"id":"c68-671","title":"清平乐·一杯椒醑","kind":"词"},{"id":"c68-672","title":"南柯子・南歌子·山冥云阴重","kind":"词"},{"id":"c68-673","title":"夜行船·淡饭粗衣随分过","kind":"词"},{"id":"c68-674","title":"临江仙·鶗鴂一声春事了","kind":"词"},{"id":"c68-675","title":"蓦山溪·莺啼花谢","kind":"词"},{"id":"c68-676","title":"忆秦娥·头如雪","kind":"词"},{"id":"c68-677","title":"满江红·宦海浮沉","kind":"词"}]},"眉娘":{"slug":"眉娘","name":"眉娘","dynasty":"唐","style":"号神姑","life":"","origin":"","seal":"眉","bio":["眉娘，南海人，卢姓，生而眉长，称眉娘。神针善绣，顺宗召入宫中，号神姑。宪宗度为女道士，称逍遥大师。","放归，后数年尸解。"],"works":[{"id":"t47-843","title":"和卓英英锦城春望","kind":"诗"},{"id":"t47-844","title":"和卓英英理笙","kind":"诗"},{"id":"t47-845","title":"太白山玄士画地吟","kind":"诗"}]},"贾躭":{"slug":"贾躭","name":"贾躭","dynasty":"唐","style":"字敦诗","life":"","origin":"","seal":"贾","bio":["贾躭，字敦诗，沧州南皮人。天宝中，举明经，授临清县尉。上疏论时政，改正平尉，从事河东检校膳部员外郎。","历邠州刺史，政绩茂异，入为鸿胪卿。自大历至贞元，三为节镇，徴拜右仆射，同中书门下平章事。在相位十三年，世称其淳德。","躭好地理学，外国使至，必讯其山川土俗，因譔《海内华夷图》及《古今郡国县道四夷述》四十卷，表献之。诗一首。"],"works":[{"id":"t13-493","title":"赋虞书歌","kind":"诗"}]},"赵良玉":{"slug":"赵良玉","name":"赵良玉","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"c78-538","title":"满庭芳·红杏香中","kind":"词"}]},"陈敷":{"slug":"陈敷","name":"陈敷","dynasty":"宋","style":"","life":"","origin":"","seal":"陈","bio":[],"works":[{"id":"c78-422","title":"水调歌头·明月双溪上","kind":"词"}]},"陈潜心":{"slug":"陈潜心","name":"陈潜心","dynasty":"宋","style":"","life":"","origin":"","seal":"陈","bio":[],"works":[{"id":"c76-566","title":"百字令・念奴娇·梅峰孕秀","kind":"词"}]},"随车娘子":{"slug":"随车娘子","name":"随车娘子","dynasty":"宋","style":"","life":"","origin":"","seal":"随","bio":[],"works":[{"id":"c61-113","title":"天仙子·别酒未斟心先醉","kind":"词"}]},"韦能谦":{"slug":"韦能谦","name":"韦能谦","dynasty":"宋","style":"","life":"","origin":"","seal":"韦","bio":[],"works":[{"id":"c67-307","title":"虞美人·风清日晚溪桥路","kind":"词"}]},"魏璞":{"slug":"魏璞","name":"魏璞","dynasty":"唐","style":"字不琢","life":"","origin":"","seal":"魏","bio":["魏璞字不琢，毘陵人。才高志旷，居舜定山下，杜门二十余年，饭蔬积学。工诗文，与皮日休、陆龟蒙友善，每秋风时，乘短舸载酒，相偕浮游烟水间，皮、陆各有赠诗。","（小传据顾季慈辑《江上诗钞》引《邑志·隐逸传》）今补诗三首。"],"works":[{"id":"t50-880","title":"无题","kind":"诗"},{"id":"t50-881","title":"寻鸟窠迹","kind":"诗"},{"id":"t50-882","title":"陪皮袭美陆鲁望重过鸟窠迹","kind":"诗"},{"id":"t50-883","title":"题舜山后牛迹石","kind":"诗"}]}}