{"丁仙芝":{"slug":"丁仙芝","name":"丁仙芝","dynasty":"唐","style":"","life":"","origin":"","seal":"丁","bio":["丁仙芝，曲阿人，登开元进士第，为余杭尉，诗十四首。丁仙芝，曲阿人。登开元进士第，为余杭尉。","诗十四首。"],"works":[{"id":"t1-34","title":"相和歌辞 江南曲","kind":"诗"},{"id":"t5-502","title":"和荐福寺英公新搆禅堂","kind":"诗"},{"id":"t5-503","title":"赠朱中书","kind":"诗"},{"id":"t5-504","title":"戏赠姚侍御","kind":"诗"},{"id":"t5-505","title":"余杭醉歌赠吴山人","kind":"诗"},{"id":"t5-506","title":"京中守岁","kind":"诗"},{"id":"t5-507","title":"渡扬子江","kind":"诗"},{"id":"t5-508","title":"长宁公主旧山池","kind":"诗"},{"id":"t5-509","title":"剡溪馆闻笛","kind":"诗"},{"id":"t5-510","title":"越裳贡白雉","kind":"诗"},{"id":"t5-511","title":"江南曲五首 一","kind":"诗"},{"id":"t5-512","title":"江南曲五首 二","kind":"诗"},{"id":"t5-513","title":"江南曲五首 三","kind":"诗"},{"id":"t5-514","title":"江南曲五首 四","kind":"诗"},{"id":"t5-515","title":"江南曲五首 五","kind":"诗"},{"id":"t5-516","title":"句","kind":"诗"},{"id":"t49-948","title":"句","kind":"诗"}]},"何坚":{"slug":"何坚","name":"何坚","dynasty":"唐","style":"","life":"","origin":"","seal":"何","bio":["坚，道州人。贞元间进士。为太学生，师韩愈。","归，愈作序送之。在道州从阳城游，世称其贤。后除国子监司籍。","诗二首。（《全唐诗》无何坚诗。事迹据《昌黎先生集》卷二十《送何坚序》、《道州志》卷九「乡贤」引《府志》）"],"works":[{"id":"t53-375","title":"次韵答阳刺史城","kind":"诗"},{"id":"t53-376","title":"除授太学国子监司籍之职因赋","kind":"诗"}]},"公孙杲":{"slug":"公孙杲","name":"公孙杲","dynasty":"唐","style":"","life":"","origin":"","seal":"公","bio":[],"works":[{"id":"t49-26","title":"五言赠诸法师","kind":"诗"}]},"吉皎":{"slug":"吉皎","name":"吉皎","dynasty":"唐","style":"","life":"","origin":"","seal":"吉","bio":["吉皎，冯翊人，卫尉卿致仕。诗一首。"],"works":[{"id":"t24-787","title":"七老会诗","kind":"诗"}]},"太白山玄士":{"slug":"太白山玄士","name":"太白山玄士","dynasty":"唐","style":"","life":"","origin":"","seal":"太","bio":[],"works":[{"id":"t47-813","title":"画地吟","kind":"诗"}]},"廖匡齐":{"slug":"廖匡齐","name":"廖匡齐","dynasty":"唐","style":"","life":"","origin":"","seal":"廖","bio":["匡齐，虔州虔化人。父爽，永州刺史。匡齐以功署决胜指挥使，与溪州蛮战死。","诗一首。（《全唐诗》无廖匡齐诗，传据《十国春秋》卷七三）"],"works":[{"id":"t55-951","title":"游零陵见父题壁感而成诗（题拟）","kind":"诗"}]},"曹松":{"slug":"曹松","name":"曹松","dynasty":"唐","style":"字梦徴 · 号五老牓","life":"","origin":"","seal":"曹","bio":["曹松，字梦徴，舒州人。学贾岛为诗，久困名场。至天复初，杜德祥主文，放松及王希羽、刘象、柯崇、郑希颜等及第，年皆七十余，时号五老牓。","授秘书省正字。集三卷，今编诗二卷。曹松，字梦徴，舒州人。","学贾岛为诗，久困名场。至天复初，杜德祥主文，放松及王希羽、刘象、柯崇、郑希颜等及第。年皆七十余，时号五老牓。","授秘书省正字。集三卷，今编诗二卷。曹松字梦征，舒州人。","为诗宗贾岛，深入幽境，然无枯淡之癖。初在建州依李频。眧宗光化四年，礼部侍郎杜德祥下与王希羽、刘象、柯崇、郑希颜皆七十余始及第，时号五老榜，为秘书曲校书郎。","补诗一首。"],"works":[{"id":"t40-360","title":"长安春日","kind":"诗"},{"id":"t40-361","title":"慈恩寺贻楚霄上人","kind":"诗"},{"id":"t40-362","title":"崇义里言怀","kind":"诗"},{"id":"t40-363","title":"僧院松","kind":"诗"},{"id":"t40-364","title":"贻世","kind":"诗"},{"id":"t40-365","title":"南游","kind":"诗"},{"id":"t40-366","title":"送胡中丞使日东","kind":"诗"},{"id":"t40-367","title":"哭陈陶处士","kind":"诗"},{"id":"t40-368","title":"言怀","kind":"诗"},{"id":"t40-369","title":"月","kind":"诗"},{"id":"t40-370","title":"答匡山僧赠榔栗杖","kind":"诗"},{"id":"t40-371","title":"商山夜闻泉","kind":"诗"},{"id":"t40-372","title":"书怀","kind":"诗"},{"id":"t40-373","title":"道中","kind":"诗"},{"id":"t40-374","title":"夏云","kind":"诗"},{"id":"t40-375","title":"塞上行","kind":"诗"},{"id":"t40-376","title":"晨起","kind":"诗"},{"id":"t40-377","title":"感世","kind":"诗"},{"id":"t40-378","title":"观华夷图","kind":"诗"},{"id":"t40-379","title":"山上寒夜呈进士许棠","kind":"诗"},{"id":"t40-380","title":"滕王阁春日晚眺","kind":"诗"},{"id":"t40-381","title":"钟陵野步","kind":"诗"},{"id":"t40-382","title":"哭胡处士","kind":"诗"},{"id":"t40-383","title":"青龙寺赠云颢法师","kind":"诗"},{"id":"t40-384","title":"荐福寺赠应制白公","kind":"诗"},{"id":"t40-385","title":"观山寺僧穿井","kind":"诗"},{"id":"t40-386","title":"送德光禅师","kind":"诗"},{"id":"t40-387","title":"赠南陵李主簿","kind":"诗"},{"id":"t40-388","title":"慈恩寺东楼","kind":"诗"},{"id":"t40-389","title":"古冢","kind":"诗"},{"id":"t40-390","title":"访山友","kind":"诗"},{"id":"t40-391","title":"林下书怀寄建州李频员外","kind":"诗"},{"id":"t40-392","title":"猿","kind":"诗"},{"id":"t40-393","title":"秋日送方干游上元","kind":"诗"},{"id":"t40-394","title":"哭李频员外","kind":"诗"},{"id":"t40-395","title":"山中言事","kind":"诗"},{"id":"t40-396","title":"送左协律京西从事","kind":"诗"},{"id":"t40-397","title":"望九华寄池阳太守","kind":"诗"},{"id"