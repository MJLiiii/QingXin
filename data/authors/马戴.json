{"slug":"马戴","name":"马戴","dynasty":"唐","style":"字虞臣","life":"","origin":"","seal":"马","bio":["马戴，字虞臣，会昌四年进士第。宣宗大中初，太原李司空辟掌书记，以正言被斥为龙阳尉。懿宗咸通末，佐大同军幕，终太学博士。","诗集一卷，今编二卷。"],"works":[{"id":"t0-935","title":"横吹曲辞 出塞","kind":"诗"},{"id":"t1-58","title":"相和歌辞 关山曲 一","kind":"诗"},{"id":"t1-59","title":"相和歌辞 关山曲 二","kind":"诗"},{"id":"t1-150","title":"相和歌辞 雀台怨","kind":"诗"},{"id":"t30-754","title":"校猎曲","kind":"诗"},{"id":"t30-755","title":"蛮家","kind":"诗"},{"id":"t30-756","title":"春思","kind":"诗"},{"id":"t30-757","title":"送从叔赴南海幕","kind":"诗"},{"id":"t30-758","title":"江行留别","kind":"诗"},{"id":"t30-759","title":"将别寄友人","kind":"诗"},{"id":"t30-760","title":"客行","kind":"诗"},{"id":"t30-761","title":"过野叟居","kind":"诗"},{"id":"t30-762","title":"答光州王使君","kind":"诗"},{"id":"t30-763","title":"下第再过崔邵池阳居","kind":"诗"},{"id":"t30-764","title":"夕次淮口","kind":"诗"},{"id":"t30-765","title":"落日怅望","kind":"诗"},{"id":"t30-766","title":"早发故山作","kind":"诗"},{"id":"t30-767","title":"下第别郜扶","kind":"诗"},{"id":"t30-768","title":"寄终南真空禅师","kind":"诗"},{"id":"t30-769","title":"长安寓居寄赠贾岛","kind":"诗"},{"id":"t30-770","title":"秋郊夕望","kind":"诗"},{"id":"t30-771","title":"赠越客","kind":"诗"},{"id":"t30-772","title":"送顾非熊下第归江南","kind":"诗"},{"id":"t30-773","title":"汧上劝旧友","kind":"诗"},{"id":"t30-774","title":"送狄参军赴杭州","kind":"诗"},{"id":"t30-775","title":"过故人所迁新居","kind":"诗"},{"id":"t30-776","title":"落照","kind":"诗"},{"id":"t30-777","title":"宿崔邵池阳别墅","kind":"诗"},{"id":"t30-778","title":"楚江怀古三首 一","kind":"诗"},{"id":"t30-779","title":"楚江怀古三首 二","kind":"诗"},{"id":"t30-780","title":"楚江怀古三首 三","kind":"诗"},{"id":"t30-781","title":"远水","kind":"诗"},{"id":"t30-782","title":"夕发邠宁寄从弟","kind":"诗"},{"id":"t30-783","title":"赠别北客","kind":"诗"},{"id":"t30-784","title":"夜下湘中","kind":"诗"},{"id":"t30-785","title":"送吕郎中牧东海郡","kind":"诗"},{"id":"t30-786","title":"山行偶作","kind":"诗"},{"id":"t30-787","title":"巴江夜猨","kind":"诗"},{"id":"t30-788","title":"送田使君牧蔡州","kind":"诗"},{"id":"t30-789","title":"雀台怨","kind":"诗"},{"id":"t30-790","title":"早发故园","kind":"诗"},{"