{"slug":"莫宣卿","name":"莫宣卿","dynasty":"唐","style":"字仲节","life":"","origin":"","seal":"莫","bio":["莫宣卿，字仲节，封州人。大中间举第一，官台州别驾，诗三首。"],"works":[{"id":"t31-406","title":"荅问读书居","kind":"诗"},{"id":"t31-407","title":"百官乘月早朝听残漏","kind":"诗"},{"id":"t31-408","title":"赋得水怀珠","kind":"诗"},{"id":"t31-409","title":"句","kind":"诗"}]}