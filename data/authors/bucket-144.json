":"t40-642","title":"吊侯圭常侍","kind":"诗"},{"id":"t40-643","title":"颜上人房","kind":"诗"},{"id":"t40-644","title":"题薛少府庄","kind":"诗"},{"id":"t40-645","title":"寄太白隐者","kind":"诗"}]},"独孤授":{"slug":"独孤授","name":"独孤授","dynasty":"唐","style":"","life":"","origin":"","seal":"独","bio":["独孤授，大历十四年登第。诗一首。"],"works":[{"id":"t15-91","title":"花发上林","kind":"诗"}]},"玄应":{"slug":"玄应","name":"玄应","dynasty":"唐","style":"","life":"","origin":"","seal":"玄","bio":["玄应，俗姓吴，泉州晋江人。嗣白龙道希，漳州报劬院。开宝八年卒，年六十六。","诗一首。（《全唐诗》无玄应诗）"],"works":[{"id":"t55-830","title":"无题","kind":"诗"},{"id":"t55-831","title":"临寂示漳州刺史陈文颢偈（题拟）","kind":"诗"}]},"胡夫人":{"slug":"胡夫人","name":"胡夫人","dynasty":"宋","style":"","life":"","origin":"","seal":"胡","bio":[],"works":[{"id":"c76-626","title":"采桑子·与君别后愁无限","kind":"词"}]},"苏癿":{"slug":"苏癿","name":"苏癿","dynasty":"唐","style":"","life":"","origin":"","seal":"苏","bio":[],"works":[{"id":"t56-422","title":"游苑","kind":"诗"},{"id":"t56-423","title":"清明日登张女郎神庙","kind":"诗"}]},"萧德言":{"slug":"萧德言","name":"萧德言","dynasty":"唐","style":"字文行","life":"","origin":"","seal":"萧","bio":["萧德言，字文行，雍州长安人。贞观中著作郎，兼弘文馆学士，博涉经史，晚尤笃志于学，自昼达夜，略无休倦。每开五经，必束带盥濯，危坐对之，为春宫侍读，拜秘书少监。","高宗以师傅恩，加银青光禄大夫。集三十卷，今存诗一首。"],"works":[{"id":"t2-664","title":"咏舞","kind":"诗"}]},"赵宗儒":{"slug":"赵宗儒","name":"赵宗儒","dynasty":"唐","style":"字秉文","life":"","origin":"","seal":"赵","bio":["赵宗儒，字秉文，邓州穰人。举进士，初授弘文馆校书郎，拜左拾遗，充翰林学士，与父晔秘书少监同日竝命，当时荣之。贞元十二年，以给事中同中书门下平章事。","罢相，为右庶子。端居守道，勤奉朝请，迁吏部侍郎，改尚书。前后三镇方任，八领选部，历宪、穆、敬、文四朝，以司空致仕。","诗一首。"],"works":[{"id":"t17-90","title":"和黄门武相公诏还题石门洞","kind":"诗"}]},"赵必��":{"slug":"赵必��","name":"赵必��","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"c75-808","title":"兰陵王·画阑直","kind":"词"},{"id":"c75-812","title":"华胥引·沧浪矶外","kind":"词"},{"id":"c75-821","title":"贺新郎·绣口琅玕腹","kind":"词"},{"id":"c75-825","title":"贺新郎·低唱芙蓉菊","kind":"词"}]},"郑雪岩":{"slug":"郑雪岩","name":"郑雪岩","dynasty":"宋","style":"","life":"","origin":"","seal":"郑","bio":[],"works":[{"id":"c74-776","title":"水调歌头·甫营亭子小","kind":"词"}]},"陈瓘":{"