[{"id":"c58-300","title":"玉楼春·阴阴树色笼晴昼","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["阴阴树色笼晴昼。","清淡园林春过后。","杏腮轻粉日催红，池面绿罗风卷皱。","佳人向晚新妆就。","圆腻歌喉珠欲溜。","当筵莫放酒杯迟，乐事良辰难入手。"]},{"id":"c58-301","title":"玉楼春·芙蓉斗晕燕支浅","rhythmic":"玉楼春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["芙蓉斗晕燕支浅。","留著晚花开小宴。","画船红日晚风清，柳色溪光晴照暖。","美人争劝梨花盏。","舞困玉腰裙缕慢。","莫交银烛促归期，已祝斜阳休更晚。"]},{"id":"c58-302","title":"渔家傲·正月斗杓初转势","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["正月斗杓初转势。","金刀剪彩功夫异。","称庆高堂欢幼稚。","看柳意。","偏从东面春风至。","十四新蟾圆尚未。","楼前乍看红灯试。","冰散绿池泉细细。","鱼欲戏。","园林已是花天气。"]},{"id":"c58-303","title":"渔家傲·二月春耕昌杏密","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["二月春耕昌杏密。","百花次第争先出。","惟有海棠梨第一。","深浅拂。","天生红粉真无匹。","画栋归来巢未失。","双双款语怜飞乙。","留客醉花迎晓日。","金盏溢。","却忧风雨飘零疾。"]},{"id":"c58-304","title":"渔家傲·三月清明天婉娩","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["三月清明天婉娩。","晴川祓禊归来晚。","况是踏青来处远。","犹不倦。","秋千别闭深庭院。","更值牡丹开欲遍。","酴醿压架清香散。","花底一尊谁解劝。","增眷恋。","东风回晚无情绊。"]},{"id":"c58-305","title":"渔家傲·四月园林春去后","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["四月园林春去后。","深深密幄阴初茂。","折得花枝犹在手。","香满袖。","叶间梅子青如豆。","风雨时时添气候。","成行新笋霜筠厚。","题就送春诗几首。","聊对酒。","樱桃色照银盘溜。"]},{"id":"c58-306","title":"渔家傲·五月榴花妖艳烘","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["五月榴花妖艳烘。","绿杨带雨垂垂重。","五色新丝缠角粽。","金盘送。","生绡画扇盘双凤。","正是浴兰时节动。","菖蒲酒美清尊共。","叶里黄骊时一弄。","犹瞢忪。","等闲惊破纱窗梦。"]},{"id":"c58-307","title":"渔家傲·六月炎天时霎雨","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["六月炎天时霎雨。","行云涌出奇峰露。","沼上嫩莲腰束素。","风兼露。","梁王宫阕无烦暑。","畏日亭亭残蕙炷。","傍帘乳燕双飞去。","碧碗敲冰倾玉处。","朝与暮。","故人风快凉轻度。"]},{"id":"c58-308","title":"渔家傲·七月新秋风露早","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["七月新秋风露早。","渚莲尚拆庭梧老。","是处瓜华时节好。","金尊倒。","人间采缕争祈巧。","万叶敲声凉乍到。","百虫啼晚烟如扫。","箭漏初长天杳杳。","人语悄。","那堪夜雨催清晓。"]},{"id":"c58-309","title":"渔家傲·八月秋高风历乱","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["八月秋高风历乱。","衰兰败芷红莲岸。","皓月十分光正满。","清光畔。","年年常愿琼筵看。","社近愁看归去燕。","江天空阔云容漫。","宋玉当时情不浅。","成幽怨。","乡关千里危肠断。"]},{"id":"c58-310","title":"渔家傲·九月霜秋秋已尽","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["九月霜秋秋已尽。","烘林败叶红相映。","惟有东篱黄菊盛。","遗金粉。","人家帘幕重阳近。","晓日阴阴晴未定。","授衣时节轻寒嫩。","新雁一声风又劲。","云欲凝。","雁来应有吾乡信。"]},{"id":"c58-311","title":"渔家傲·十月小春梅蕊绽","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["十月小春梅蕊绽。","红炉画阁新妆遍。","鸳帐美人贪睡暖。","梳洗懒。","玉壶一夜轻澌满。","楼上四垂帘不卷。","天寒山色偏宜远。","风急雁行吹字断。","红日晚。","江天雪意云撩乱。"]},{"id":"c58-312","title":"渔家傲·十一月新阳排寿","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["十一月新阳排寿宴。","黄锺应管添宫线。","猎猎寒威云不卷。","风头转。","时看雪霰吹人面。","南至迎长知漏箭。","书云纪候冰生妍。","腊近探春春尚远。","闲庭院。","梅花落尽千千片。"]},{"id":"c58-313","title":"渔家傲·十二月严凝天地","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["十二月严凝天地闭。","莫嫌台榭无花卉。","惟有酒能欺雪意。","增豪气。","直教耳热笙歌沸。","陇上雕鞍惟数骑。","猎围半合新霜里。","霜重鼓声寒不起。","千人指。","马前一雁寒空坠。"]},{"id":"c58-314","title":"渔家傲·正月新阳生翠琯","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["正月新阳生翠琯。","花苞柳线春犹浅。","帘幕千重方半卷。","池冰泮。","东风吹水琉璃软。","渐好凭阑醒醉眼。","陇梅暗落芳英断。","初日已知长一线。","清宵短。","梦魂怎奈珠宫远。"]},{"id":"c58-315","title":"渔家傲·二月春期看已半","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["二月春期看已半。","江边春色青犹短。","天气养花红日暖。","深深院。","真珠帘额初飞燕。","渐觉衔杯心绪懒。","酒侵花脸娇波慢。","一捻闲愁无处遣。","牵不断。","游丝百尺随风远。"]},{"id":"c58-316","title":"渔家傲·三月芳菲看欲暮","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["三月芳菲看欲暮。","胭脂泪洒梨花雨。","宝马绣轩南陌路。","笙歌举。","踏青斗草人无数。","强欲留春春不住。","东皇肯信韶容故。","安得此身如柳絮。","随风去。","穿帘透幕寻朱户。"]},{"id":"c58-317","title":"渔家傲·四月芳林何悄悄","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["四月芳林何悄悄。","绿阴满地青梅小。","南陌采桑何窈窕。","争语笑。","乱丝满腹吴蚕老。","宿酒半醒新睡觉。","雏莺相语匆匆晓。","惹得此情萦寸抱。","休临眺。","楼头一望皆芳草。"]},{"id":"c58-318","title":"渔家傲·五月薰风才一信","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["五月薰风才一信。","初荷出水清香嫩。","乳燕学飞帘额峻。","谁借问。","东邻期约尝佳酝。","漏短日长人乍困。","裙腰减尽柔肌损。","一撮眉尖千叠恨。","慵整顿。","黄梅雨细多闲闷。"]},{"id":"c58-319","title":"渔家傲·六月炎蒸何太盛","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["六月炎蒸何太盛。","海榴灼灼红相映。","天外奇峰千掌迥。","风影定。","汉宫圆扇初成咏。","珠箔初褰深院静。","绛绡衣窄冰肤莹。","睡起日高堆酒兴。","厌厌病。","宿酲和梦何时醒。"]},{"id":"c58-320","title":"渔家傲·七月芙蓉生翠水","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["七月芙蓉生翠水。","明霞拂脸新妆媚。","疑是楚宫歌舞妓。","争宠丽。","临风起舞夸腰细。","乌鹊桥边新雨霁。","长河清水冰无地。","此夕有人千里外。","经年岁。","犹嗟不及牵牛会。"]},{"id":"c58-321","title":"渔家傲·八月微凉生枕簟","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["八月微凉生枕簟。","金盘露洗秋光淡。","池上月华开宝鉴。","波潋滟。","故人千里应凭槛。","蝉树无情风苒苒。","燕归碧海珠帘揜。","沈臂冒霜潘鬓减。","愁黯黯。","年年此夕多悲感。"]},{"id":"c58-322","title":"渔家傲·九月重阳还又到","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["九月重阳还又到。","东篱菊放金钱小。","月下风前愁不少。","谁语笑。","吴娘捣练腰肢袅。","槁叶半轩慵更扫。","凭阑岂是闲临眺。","欲向南云新雁道。","休草草。","来时觅取伊消耗。"]},{"id":"c58-323","title":"渔家傲·十月轻寒生晚暮","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["十月轻寒生晚暮。","霜华暗卷楼南树。","十二阑干堪倚处。","聊一顾。","乱山衰草还家路。","悔别情怀多感慕。","胡笳不管离心苦。","犹喜清宵长数鼓。","双绣户。","梦魂尽远还须去。"]},{"id":"c58-324","title":"渔家傲·律应黄锺寒气苦","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["律应黄锺寒气苦。","冰生玉水云如絮。","千里乡关空倚慕。","无尺素。","双鱼不食南鸿渡。","把酒遣愁愁已去。","风吹酒力愁还聚。","却忆兽炉追旧处。","头懒举。","炉灰剔尽痕无数。"]},{"id":"c58-325","title":"渔家傲·腊月年光如激浪","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["腊月年光如激浪。","冻云欲折寒根向。","谢女雪诗真绝唱。","无比况。","长堤柳絮飞来往。","便好开尊夸酒量。","酒阑莫遣笙歌放。","此去青春都一饷。","休怅望。","瑶林即日堪寻访。"]},{"id":"c58-326","title":"南歌子·凤髻金泥带","rhythmic":"南歌子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["凤髻金泥带，龙纹玉掌梳。","走来窗下笑相扶。","爱道画眉深浅、入时无。","弄笔偎人久，描花试手初。","等闲妨了绣功夫。","笑问双鸳鸯字、怎生书。"]},{"id":"c58-327","title":"御街行·夭非华艳轻非雾","rhythmic":"御街行","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["夭非华艳轻非雾。","来夜半、天明去。","来如春梦不多时，去似朝云何处。","乳鸡酒燕，落星沈月，紞紞城头鼓。","参差渐辨西池树。","朱阁斜欹户。","绿苔深径少人行，苔上屐痕无数。","遗香馀粉，剩衾闲枕，天把多情赋。"]},{"id":"c58-328","title":"桃源忆故人·梅梢弄粉香犹嫩","rhythmic":"桃源忆故人","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["梅梢弄粉香犹嫩。","欲寄江南春信。","别后寸肠萦损。","说与伊争稳。","小炉独守寒灰尽。","忍泪低头画尽。","眉上万重新恨。","竟日无人问。"]},{"id":"c58-329","title":"桃源忆故人·莺愁燕苦春归去","rhythmic":"桃源忆故人","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["莺愁燕苦春归去。","寂寂花飘红雨。","碧草绿杨歧路。","况是长亭暮。","少年行客情难诉。","泣对东风无语。","目断两三烟树。","翠隔江淹浦。"]},{"id":"c58-330","title":"临江仙·柳外轻雷池上雨","rhythmic":"临江仙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["柳外轻雷池上雨，雨声滴碎荷声。","小楼西角断虹明。","阑干倚处，待得月华生。","燕子飞来窥画栋，玉钩垂下帘旌。","凉波不动簟纹平。","水精双枕，傍有堕钗横。"]},{"id":"c58-331","title":"临江仙·记得金銮同唱第","rhythmic":"临江仙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["记得金銮同唱第，春风上国繁华。","如今薄宦老天涯。","十年歧路，空负曲江花。","闻说阆山通阆苑，楼高不见君家。","孤城寒日等闲斜。","离愁难尽，红树远连霞。"]},{"id":"c58-332","title":"圣无忧・乌夜啼·世路风波险","rhythmic":"圣无忧・乌夜啼","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["世路风波险，十年一别须臾。","人生聚散长如此，相见且欢娱。","好酒能消光景，春风不染髭鬚。","为公一醉花前倒，红袖莫来扶。"]},{"id":"c58-333","title":"浪淘沙·把酒祝东风","rhythmic":"浪淘沙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["把酒祝东风。","且共从容。","垂杨紫陌洛城东。","总是当时携手处，游遍芳丛。","聚散苦匆匆。","此恨无穷。","今年花胜去年红。","可惜明年花更好，知与谁同。"]},{"id":"c58-334","title":"浪淘沙·花外倒金翘","rhythmic":"浪淘沙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["花外倒金翘。","饮散无憀。","柔桑蔽日柳迷条。","此地年时会一醉，还是春朝。","今日举轻桡。","帆影飘飘。","长亭回首短亭遥。","过尽长亭人更远，特地魂销。"]},{"id":"c58-335","title":"浪淘沙·五岭麦秋残","rhythmic":"浪淘沙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["五岭麦秋残。","荔子初丹。","绛纱囊里水晶丸。","可惜天教生处远，不近长安。","往事忆开元。","妃子偏怜。","一从魂散马嵬关。","只有红尘无驿使，满眼骊山。"]},{"id":"c58-336","title":"浪淘沙·万恨苦绵绵","rhythmic":"浪淘沙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["万恨苦绵绵。","旧约前欢。","桃花溪畔柳阴间。","几度日高春垂重，绣户深关。","楼外夕阳闲。","独自凭阑。","一重水隔一重山。","水阔山高人不见，有泪无言。"]},{"id":"c58-337","title":"浪淘沙·今日北池游","rhythmic":"浪淘沙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["今日北池游。","漾漾轻舟。","波光潋滟柳条柔。","如此春来春又去，白了人头。","好妓好歌喉。","不醉难休。","劝君满满酌金瓯。","纵使花时常病酒，也是风流。"]},{"id":"c58-338","title":"定风波·把酒花前欲问他","rhythmic":"定风波","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["把酒花前欲问他。","对花何吝醉颜酡。","春到几人能烂赏。","何况。","无情风雨等闲多。","艳树香丛都几许。","朝暮。","惜红愁粉奈情何。","好是金船浮玉浪。","相向。","十分深送一声歌。"]},{"id":"c58-339","title":"定风波·把酒花前欲问伊","rhythmic":"定风波","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["把酒花前欲问伊。","忍嫌金盏负春时。","红颜不能旬日看。","宜算。","须知开谢只相随。","蝶去蝶来犹解恋。","难见。","回头还是度年期。","莫候饮阑花已尽。","方信。","无人堪与补残枝。"]},{"id":"c58-340","title":"定风波·把酒花前欲问公","rhythmic":"定风波","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["把酒花前欲问公。","对花何事诉金锺。","为问去年春甚处。","虚度。","莺声撩乱一场空。","今岁春来须爱惜。","难得。","须知花面不长红。","待得酒醒君不见。","千片。","不随流水即随风。"]},{"id":"c58-341","title":"定风波·把酒花前欲问君","rhythmic":"定风波","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["把酒花前欲问君。","世间何计可留春。","纵使青春留得住。","虚语。","无情花对有情人。","任是好花须落去。","自古。","红颜能得几时新。","暗想浮生何时好。","唯有。","清歌一曲倒金尊。"]},{"id":"c58-342","title":"定风波·过尽韶华不可添","rhythmic":"定风波","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["过尽韶华不可添。","小楼红日下层檐。","春睡觉来情绪恶。","寂寞。","杨花缭乱拂珠帘。","早是闲愁依旧在。","无奈。","那堪更被宿酲兼。","把酒送春惆怅甚。","长恁。","年年三月病厌厌。"]},{"id":"c58-343","title":"定风波·对酒追欢莫负春","rhythmic":"定风波","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["对酒追欢莫负春。","春光归去可饶人。","昨日红芳今绿树。","已暮。","残花飞絮两纷纷。","粉面丽姝歌窈窕。","清妙。","尊前信任醉醺醺。","不是狂心贪燕乐。","自觉。","年来白发满头新。"]},{"id":"c58-344","title":"蓦山溪·新正初破","rhythmic":"蓦山溪","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["新正初破，三五银蟾满。","纤手染香罗，剪红莲、满城开遍。","楼台上下，歌管咽春风，驾香轮，停宝马，只待金乌晚。","帝城今夜，罗绮谁为伴。","应卜紫姑神，问归期、相思望断。","天涯情绪，对酒且开颜，春宵短。","春寒浅。","莫待金杯暖。"]},{"id":"c58-345","title":"浣溪沙·云曳香绵彩柱高","rhythmic":"浣溪沙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["云曳香绵彩柱高。","绛旗风飐出花梢。","一梭红带往来抛。","束素美人羞不打，却嫌裙慢褪纤腰。","日斜深院影空摇。"]},{"id":"c58-346","title":"浣溪沙·堤上游人逐画船","rhythmic":"浣溪沙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["堤上游人逐画船。","拍堤春水四垂天。","绿杨楼外出秋千。","白发戴花君莫笑，六么催拍盏频传。","人生何处似尊前。"]},{"id":"c58-347","title":"浣溪沙·湖上朱桥响画轮","rhythmic":"浣溪沙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["湖上朱桥响画轮。","溶溶春水浸春云。","碧琉璃滑净无尘。","当路游丝萦醉客，隔花啼鸟唤行人。","日斜归去奈何春。"]},{"id":"c58-348","title":"浣溪沙·叶底青青杏子垂","rhythmic":"浣溪沙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["叶底青青杏子垂。","枝头薄薄柳绵飞。","日高深院晚莺啼。","堪恨风流成薄幸，断无消息道归期。","托腮无语翠眉低。"]},{"id":"c58-349","title":"浣溪沙·青杏园林著酒香","rhythmic":"浣溪沙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["青杏园林著酒香。","佳人初著薄罗裳。","柳丝摇曳燕飞忙。","乍雨乍晴花自落，闲愁闲闷昼偏长。","为谁消瘦损容光。"]},{"id":"c58-350","title":"浣溪沙·红粉佳人白玉杯","rhythmic":"浣溪沙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["红粉佳人白玉杯。","木兰船稳棹歌催。","绿荷风里笑声来。","细雨轻烟笼草树，斜桥曲水绕楼台。","夕阳高处画屏开。"]},{"id":"c58-351","title":"浣溪沙·翠袖娇鬟舞石州","rhythmic":"浣溪沙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["翠袖娇鬟舞石州。","两行红粉一时羞。","新声难逐管弦愁。","白发主人年未老，清时贤相望偏优。","一尊风月为公留。"]},{"id":"c58-352","title":"浣溪沙·灯尽垂花月似霜","rhythmic":"浣溪沙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["灯尽垂花月似霜。","薄帘映月两交光。","酒醺红粉自生香。","双手舞馀拖翠袖，一声歌已釂金觞。","休回娇眼断人肠。"]},{"id":"c58-353","title":"浣溪沙·十载相逢酒一卮","rhythmic":"浣溪沙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["十载相逢酒一卮。","故人才见便开眉。","老来游旧更同谁。","浮世歌欢真易失，宦途离合信难期。","尊前莫惜醉如泥。"]},{"id":"c58-354","title":"御带花·青春何处风光好","rhythmic":"御带花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["青春何处风光好，帝里偏爱元夕。","万重绘彩，构一屏峰岭，半空金碧。","宝檠银釭，耀绛幕、龙虎腾掷。","沙堤远，雕轮绣毂，争走五王宅。","雍容熙熙昼，会乐府神姬，海洞仙客。","拽香摇翠，称执手行歌，锦街天陌。","月淡寒轻，渐向晓、漏声寂寂。","当年少，狂心未已，不醉怎归得。"]},{"id":"c58-355","title":"虞美人·炉香昼永龙烟白","rhythmic":"虞美人","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["炉香昼永龙烟白。","风动金鸾额。","画屏寒掩小山川。","睡容初起枕痕圆。","坠花钿。","楼高不及烟霄半。","望尽相思眼。","艳阳刚爱挫愁人。","故生芳草碧连云。","怨王孙。"]},{"id":"c58-356","title":"鹤冲天·梅谢粉","rhythmic":"鹤冲天","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["梅谢粉，柳拖金。","香满旧园林。","养花天气半晴阴。","花好却愁深。","花无数。","愁无数。","花好却愁春去。","戴花持酒祝东风。","千万莫匆匆。"]},{"id":"c58-357","title":"夜行船·忆昔西都欢纵","rhythmic":"夜行船","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["忆昔西都欢纵。","自别后、有谁能共。","伊川山水洛川花，细寻思、旧游如梦。","今日相逢情愈重。","愁闻唱、画楼锺动。","白发天涯逢此景，倒金尊、殢谁相送。"]},{"id":"c58-358","title":"夜行船·满眼东风飞絮","rhythmic":"夜行船","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["满眼东风飞絮。","催行色、短亭春暮。","落花流水草连云，看看是、断肠南浦。","檀板未终人去去。","扁舟在、绿杨深处。","手把金尊难为别，更那听、乱莺疏雨。"]},{"id":"c58-359","title":"洛阳春・一落萦·红纱未晓黄鹂语","rhythmic":"洛阳春・一落萦","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["红纱未晓黄鹂语。","蕙炉销兰炷。","锦屏罗幕护春寒，昨夜三更雨。","绣帘闲倚吹轻絮。","敛眉山无绪。","看花拭泪向归鸿，问来处、逢郎否。"]},{"id":"c58-360","title":"雨中花・夜行船·千古都门行路","rhythmic":"雨中花・夜行船","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["千古都门行路。","能使离歌声苦。","送尽行人，花残春晚，又到君东去。","醉藉落花吹暖絮。","多少曲堤芳树。","且携手留连，良辰美景，留作相思处。"]},{"id":"c58-361","title":"越溪春·三月十三寒食日","rhythmic":"越溪春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["三月十三寒食日，春色遍天涯。","越溪阆苑繁华地，傍禁垣、珠翠烟霞。","红粉墙头，秋千影里，临水人家。","归来晚驻香车。","银箭透窗纱。","有时三点两点雨霁，朱门柳细风斜。","沈麝不烧金鸭冷，笼月照梨花。"]},{"id":"c58-362","title":"贺圣朝影・添声杨柳枝·白雪梨花红粉桃","rhythmic":"贺圣朝影・添声杨柳枝","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["白雪梨花红粉桃。","露华高。","垂杨慢舞绿丝绦。","草如袍。","风过小池轻浪起，似江皋。","千金莫惜买香醪。","且陶陶。"]},{"id":"c58-363","title":"洞天春·莺啼绿树声早","rhythmic":"洞天春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["莺啼绿树声早。","槛外残红未扫。","露点真珠遍芳草。","正帘帏清晓。","秋千宅院悄悄。","又是清明过了。","燕蝶轻狂，柳丝撩乱，春心多少。"]},{"id":"c58-364","title":"忆汉月·红艳几枝轻袅","rhythmic":"忆汉月","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["红艳几枝轻袅。","新被东风开了。","倚烟啼露为谁娇，故惹蝶怜蜂恼。","多情游赏处，留恋向、绿丛千绕。","酒阑欢罢不成归，肠断月斜春老。"]},{"id":"c58-365","title":"清平乐·小庭春老","rhythmic":"清平乐","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["小庭春老。","碧砌红萱草。","长忆小阑闲共绕。","携手绿丛含笑。","别来音信全乖。","旧期前事堪猜。","门掩日斜人静，落花愁点青苔。"]},{"id":"c58-366","title":"凉州令・梁州令·翠树芳条飐","rhythmic":"凉州令・梁州令","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["翠树芳条飐。","的的裙腰初染。","佳人携手弄芳菲，绿阴红影，共展双纹簟。","插花照影窥鸾鉴。","只恐芳容减。","不堪零落春晚，青苔雨后深红点。","一去门闲掩。","重来却寻朱槛。","离离秋实弄轻霜，娇红脉脉，似见胭脂脸。","人非事往眉空敛。","谁把佳期赚。","芳心只愿长依旧，春风更放明年艳。"]},{"id":"c58-367","title":"南乡子·翠密红繁","rhythmic":"南乡子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["翠密红繁。","水国凉生未是寒。","雨打荷花珠不定，轻翻。","冷泼鸳鸯锦翅斑。","尽日凭阑。","弄蕊拈花仔细看。","偷得袅蹄新铸样，无端。","藏在红房艳粉间。"]},{"id":"c58-368","title":"南乡子·雨后斜阳","rhythmic":"南乡子","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["雨后斜阳。","细细风来细细香。","风定波平花映水，休藏。","照出轻盈半面妆。","路隔秋江。","莲子深深隐翠房。","意在莲心无问处，难忘。","泪裛红腮不记行。"]},{"id":"c58-369","title":"鹊桥仙·月波清霁","rhythmic":"鹊桥仙","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["月波清霁，烟容明淡，灵汉旧期还至。","鹊迎桥路接天津，映夹岸、星榆点缀。","云屏未卷，仙鸡催晓，肠断去年情味。","多应天意不教长，恁恐把、欢娱容易。"]},{"id":"c58-370","title":"圣无忧・乌夜啼·珠帘卷","rhythmic":"圣无忧・乌夜啼","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["珠帘卷，暮云愁。","垂杨暗锁青楼。","烟雨濛濛如画，轻风吹旋收。","香断锦屏新别，人闲玉簟初秋。","多少旧欢新恨，书杳杳、梦悠悠。"]},{"id":"c58-371","title":"摸鱼儿·卷绣帘","rhythmic":"摸鱼儿","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["卷绣帘、梧桐秋院落，一霎雨添新绿。","对小池闲立残妆浅，向晚水纹如縠。","凝远目。","恨人去寂寂，凤枕孤难宿。","倚阑不足。","看燕拂风檐，蝶翻露草，两两长相逐。","双眉促。","可惜年华婉娩，西风初弄庭菊。","况伊家年少，多情未已难拘束。","那堪更趁凉景，追寻甚处垂杨曲。","佳期过尽，但不说归来，多应忘了，云屏去时祝。"]},{"id":"c58-372","title":"少年游·去年秋晚此园中","rhythmic":"少年游","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["去年秋晚此园中。","携手玩芳丛。","拈花嗅蕊，恼烟撩雾，拼醉倚西风。","今年重对芳丛处，追往事、又成空。","敲遍阑干，向人无语，惆怅满枝红。"]},{"id":"c58-373","title":"少年游·肉红圆样浅心黄","rhythmic":"少年游","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["肉红圆样浅心黄。","枝上巧如装。","雨轻烟重，无憀天气，啼破晓来妆。","寒轻贴体风头冷，忍抛弃、向秋光。","不会深心，为谁惆怅，回面恨斜阳。"]},{"id":"c58-374","title":"少年游·玉壶冰莹兽炉灰","rhythmic":"少年游","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["玉壶冰莹兽炉灰。","人起绣帘开。","春从一夜，六花开尽，不待剪刀催。","洛阳城阙中天起，高下遍楼台。","絮乱风轻，拂鞍沾袖，归路似章街。"]},{"id":"c58-375","title":"鹧鸪天·学画宫眉细细长","rhythmic":"鹧鸪天","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["学画宫眉细细长。","芙蓉出水斗新妆。","只知一笑能倾国，不信相看有断肠。","双黄鹄，两鸳鸯。","迢迢云水恨难忘。","早知今日长相忆，不及从初莫作双。"]},{"id":"c58-376","title":"千秋岁·罗衫满袖","rhythmic":"千秋岁","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["罗衫满袖，尽是忆伊泪。","残妆粉，馀香被。","手把金尊酒，未饮先如醉。","但向道，厌厌成病皆因你。","离思迢迢远，一似长江水。","去不断，来无际。","红笺著意写，不尽相思意。","为个甚，相思只在心儿里。"]},{"id":"c58-377","title":"千秋岁·画堂人静","rhythmic":"千秋岁","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["画堂人静，翡翠帘前月。","鸾帷凤枕虚铺设。","风流难管束，一去音书歇。","到而今，高梧冷落西风切。","未语先垂泪，滴尽相思血。","魂欲断，情难绝。","都来些子事，更与何人说。","为个甚，心头见底多离别。"]},{"id":"c58-378","title":"醉蓬莱·见羞容敛翠","rhythmic":"醉蓬莱","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["见羞容敛翠，嫩脸匀红，素腰袅娜。","红药阑边，恼不教伊过。","半掩娇羞，语声低颤，问道有人知麽。","强整罗裙，偷回波眼，佯行佯坐。","更问假如，事还成后，乱了云鬟，被娘猜破。","我且归家，你而今休呵。","更为娘行，有些针线，诮未曾收囉。","却待更阑，庭花影下，重来则个。"]},{"id":"c58-379","title":"于飞乐·宝奁开","rhythmic":"于飞乐","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["宝奁开，美鉴静，一掬清蟾。","新妆脸，旋学花添。","蜀红衫，双绣蝶、裙缕鹣鹣。","寻思前事，小屏风、仍画江南。","怎空教、草解宜男。","柔桑密、又过春蚕。","正阴晴天气，更暝色相兼。","佳期消息，曲房西、碎月筛帘。"]},{"id":"c58-380","title":"鼓笛慢・水龙吟·缕金裙窣轻纱","rhythmic":"鼓笛慢・水龙吟","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["缕金裙窣轻纱，透红莹玉真堪爱。","多情更把，眼儿斜盼，眉儿敛黛。","舞态歌阑，困偎香脸，酒红微带。","便直饶、更有丹青妙手，应难写、天然态。","长恐有时不见，每饶伊、百般娇呆。","眼穿肠断，如今千种，思量无奈。","花谢春归，梦回云散，欲寻难再。","暗消魂，但觉鸳衾凤枕，有馀香在。"]},{"id":"c58-381","title":"看花回·晓色初透东窗","rhythmic":"看花回","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["晓色初透东窗，醉魂方觉。","恋恋绣衾半拥，动万感脉脉，春思无托。","追想少年，何处青楼贪欢乐。","当媚景，恨月愁花，算伊全妄凤帏约。","空泪滴、真珠暗落。","又被谁、连宵留著。","不晓高天甚意，既付与风流，却恁情薄。","细把身心自解，只与猛拼却。","又及至、见来了，怎生教人恶。"]},{"id":"c58-382","title":"蝶恋花·几度兰房听禁漏","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["几度兰房听禁漏。","臂上残妆，印得香盈袖。","酒力融融香汗透。","春娇入眼横波溜。","不见些时眉已皱。","水阔山遥，乍向分飞后。","大抵有情须感旧。","肌肤拼为伊销瘦。"]},{"id":"c58-383","title":"蝶恋花·宝琢珊瑚山样瘦","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["宝琢珊瑚山样瘦。","缓髻轻拢，一朵云生袖。","昨夜佳人初命偶。","论情旋旋移相就。","几叠鸳衾红浪皱。","暗觉金钗，磔磔声相扣。","一自楚台人梦后。","凄凉暮雨沾裀绣。"]},{"id":"c58-384","title":"蝶恋花·一掬天和金粉腻","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["一掬天和金粉腻。","莲子心中，自有深深意。","意密莲深秋正媚。","将花寄恨无人会。","桥上少年桥下水。","小棹归时，不语牵红袂。","浪溅荷心圆又碎。","无端欲伴相思泪。"]},{"id":"c58-385","title":"蝶恋花·百种相思千种恨","rhythmic":"蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["百种相思千种恨。","早是伤春，那更春醪困。","薄幸辜人终不愤。","何时枕畔分明问。","懊恼风流心一寸。","强醉偷眠，也即依前闷。","此意为君君不信。","泪珠滴尽愁难尽。"]},{"id":"c58-386","title":"武陵春·宝幄华灯相见夜","rhythmic":"武陵春","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["宝幄华灯相见夜，妆脸小桃红。","斗帐香檀翡翠笼。","携手恨匆匆。","金泥双结同心带，留与记情浓。","却望行云十二峰。","肠断月斜锺。"]},{"id":"c58-387","title":"梁州令·红杏墙头树","rhythmic":"梁州令","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["红杏墙头树。","紫萼香心初吐。","新年花发旧时枝，徘徊千绕，独共东风语。","阳台一梦如云雨。","为问今何处。","离情别恨多少，条条结向垂杨缕。","此事难分付。","初心本谁先许。","窃香解佩两沈沈，知他而今，记得当初否。","谁教薄幸轻相误。","不信道、相思苦。","如今却恁空追悔，元来也会忆人去。"]},{"id":"c58-388","title":"渔家傲·为爱莲房都一柄","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["为爱莲房都一柄。","双苞双蕊双红影。","雨势断来风色定。","秋水静。","仙郎彩女临鸾镜。","妾有容华君不省。","花无恩爱犹相并。","花却有情人薄幸。","心耿耿。","因花又染相思病。"]},{"id":"c58-389","title":"渔家傲·昨日采花花欲尽","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["昨日采花花欲尽。","隔花闻道潮来近。","风猎紫荷声又紧。","低难奔。","莲茎刺惹香腮损。","一缕艳痕红隐隐。","新霞点破秋蟾晕。","罗袖挹残心不稳。","羞人问。","归来剩把胭脂衬。"]},{"id":"c58-390","title":"渔家傲·一夜越溪秋水满","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["一夜越溪秋水满。","荷花开过溪南岸。","贪采嫩香星眼慢。","疏回眄。","郎船不觉来身畔。","罢采金英收玉腕。","回身急打船头转。","荷叶又浓波又浅。","无方便。","教人只得抬娇面。"]},{"id":"c58-391","title":"渔家傲·近日门前溪水涨","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["近日门前溪水涨。","郎船几度偷相访。","船小难开红斗帐。","无计向。","合欢影里空惆怅。","愿妾身为红菡萏。","年年生在秋江上。","重愿郎为花底浪。","无隔障。","随风逐雨长来往。"]},{"id":"c58-392","title":"渔家傲·妾解清歌并巧笑","rhythmic":"渔家傲","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["妾解清歌并巧笑。","郎多才俊兼年少。","何事抛儿行远道。","无音耗。","江头又绿王孙草。","昔日采花呈窈窕。","玉容长笑花枝老。","今日采花添懊恼。","伤怀抱。","玉容不及花枝好。"]},{"id":"c58-393","title":"一斛珠·今朝祖宴","rhythmic":"一斛珠","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["今朝祖宴。","可怜明夜孤灯馆。","酒醒明月空床满。","翠被重重，不似香肌暖。","愁肠恰似沈香篆。","千回万转萦还断。","梦中若得相寻见。","却愿春宵，一夜如年远。"]},{"id":"c58-394","title":"惜芳时・思归乐·因倚兰台翠云亸","rhythmic":"惜芳时・思归乐","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["因倚兰台翠云亸。","睡未足、双眉尚锁。","潜身走向伊行坐。","孜孜地、告他梳裹。","发妆酒冷重温过。","道要饮、除非伴我。","丁香嚼碎偎人睡，犹记恨、夜来些个。"]},{"id":"c58-395","title":"洞仙歌令・洞仙歌·楼前乱草","rhythmic":"洞仙歌令・洞仙歌","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["楼前乱草，是离人方寸。","倚遍阑干意无尽。","罗巾掩，宿粉残眉、香未减，人与天涯共远。","香闺知人否，长是厌厌，拟写相思寄归信。","未写了，泪成行、早满香笺。","相思字、一时滴损。","便直饶、伊家总无情，也拼了一生，为伊成病。"]},{"id":"c58-396","title":"洞仙歌令・洞仙歌·情知须病","rhythmic":"洞仙歌令・洞仙歌","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["情知须病，奈自家先肯。","天甚教伊恁端正。","忆年时、兰棹独倚春风，相怜处、月影花光相映。","别来凭谁诉，空寄香笺，拟问前欢甚时更。","后约与新期，易失难寻，空肠断、损风流心性。","除只把、芳尊强开颜，奈酒到愁肠，醉了还醒。"]},{"id":"c58-397","title":"鹊踏枝・蝶恋花·一曲尊前开画扇","rhythmic":"鹊踏枝・蝶恋花","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["一曲尊前开画扇。","暂近还遥，不语仍低面。","直至情多缘少见。","千金不直双回眄。","苦恨行云容易散。","过尽佳期，争向年芳晚。","百种寻思千万遍。","愁肠不似情难断。"]},{"id":"c58-398","title":"品令·渐素景","rhythmic":"品令","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["渐素景。","金风劲。","早是凄凉孤冷。","那堪闻、蛩吟穿金井。","唤愁绪难整。","懊恼人人薄幸。","负云期雨信。","终日望伊来，无凭准。","闷损我、也不定。"]},{"id":"c58-399","title":"燕归梁·风摆红藤卷绣帘","rhythmic":"燕归梁","author":"欧阳修","authorSlug":"欧阳修","dynasty":"宋","kind":"ci","paragraphs":["风摆红藤卷绣帘。","宝鉴慵拈。","日高梳洗几时忺。","金盆水、弄纤纤。","髻云谩亸残花淡，和娇媚、瘦岩岩。","离情更被宿酲兼。","空惹得、病厌厌。"]}]