[{"id":"c65-0","title":"渔家傲·昨夜山空流石乳","rhythmic":"渔家傲","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["昨夜山空流石乳。","道人妙手亲拈取。","未欲凌云归洞府。","清风举。","大千一叶同掀舞。","笑把须弥挝破鼓。","东山云作西山雨。","我欲住庵无拄斧。","君相许。","三更明月湖心午。"]},{"id":"c65-1","title":"渔家傲·潦倒瞿昙饶口悄","rhythmic":"渔家傲","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["潦倒瞿昙饶口悄。","拈花冤道头陀笑。","鸡足山中眠未觉。","谁知道。","至今功业犹分剖。","唇口周遮何日了。","禅床四面藤萝绕。","有个路头君试讨。","梅花老。","南园蝴蝶飞芳草。"]},{"id":"c65-2","title":"渔家傲·高绊袈裟挑纸帔","rhythmic":"渔家傲","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["高绊袈裟挑纸帔。","一杯茶罢成行计。","路入庐山风细细。","轻弹指。","百千三昧俱游戏。","法椅何曾烧两臂。","谁知纸上无穷意。","欲识普贤真实际。","齁齁地。","小炉雪夜和衣睡。"]},{"id":"c65-3","title":"渔家傲·顶上铁轮飞火焰","rhythmic":"渔家傲","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["顶上铁轮飞火焰。","防身细按威神剑。","体用双行谁敢觇。","光闪闪。","何须更把茶林撼。","衲子家风存古俭。","一条榔栗如天堑。","粥鼓未鸣灯火暗。","无恩念。","断崖古木横藤簟。"]},{"id":"c65-4","title":"渔家傲·落月杜鹃啼未了","rhythmic":"渔家傲","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["落月杜鹃啼未了。","粥鱼忽报千山晓。","笠子盖头衣钵少。","穿林表。","回头高刹空中小。","官路旧多林木绕。","露浓花蕊皆颠倒。","渡水登山排草草。","卢山好。","香炉峰下湖波渺。"]},{"id":"c65-5","title":"思佳客·江上何人一笛横","rhythmic":"思佳客","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["江上何人一笛横。","倚楼吹得月华生。","寒风堕指倾三弄，小市收灯欲二更。","持蟹股，破霜橙。","玉人水调品秦筝。","细看桃李春时面，共尽玻璃酒一觥。"]},{"id":"c65-6","title":"思佳客·微点胭脂晕泪痕","rhythmic":"思佳客","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["微点胭脂晕泪痕。","更衣整鬓立黄昏。","春风搅树花如雨，夕霭迷空燕趁门。","题往事，锦回纹。","春心无定似行云。","深屏绣幌空愁独，明月梨花殢一尊。"]},{"id":"c65-7","title":"好事近·别酒带愁酸","rhythmic":"好事近","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["别酒带愁酸，千里失群黄鹄。","行到小桥梯下，便飞云南北。","不妨垂手小徘徊，日影转阑曲。","从此贺囊佳制，有新奇题目。"]},{"id":"c65-8","title":"好事近·飞雪过江来","rhythmic":"好事近","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["飞雪过江来，船在赤栏桥侧。","惹报布帆无恙，著两行亲札。","从今日日在南楼，鬓自此时白。","一咏一觞谁共，负平生书册。"]},{"id":"c65-9","title":"好事近·年少万函书","rhythmic":"好事近","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["年少万函书，朱紫只应低拾。","更赖主人明眼，作青云梯级。","归来应是印累累，笳鼓闹乡邑。","若访老人生计，贩谢郎蓑笠。"]},{"id":"c65-10","title":"好事近·云影护梅枝","rhythmic":"好事近","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["云影护梅枝，短短未禁飞雪。","彩幅自题新句，作催妆佳阕。","西楼昨夜五更寒，恐一枝先发。","元是素娥无寐，驾半轮明月。"]},{"id":"c65-11","title":"好事近·小饮破清寒","rhythmic":"好事近","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["小饮破清寒，坐久困花颓玉。","两行艳衣明粉，听阿谁拘束。","丽华百媚坐来生，仙韵动群目。","一曲凤箫同去，倦人间丝竹。"]},{"id":"c65-12","title":"天仙子·楼下辘轳横露井","rhythmic":"天仙子","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["楼下辘轳横露井。","楼上婵娟开晓镜。","下楼难忘上楼时，风未定。","帆不正。","簌簌珍珠挥麈柄。","眉上新愁吹不醒。","别酒未斟歌未忍。","雪中梅下定重来，烟暝暝。","肠寸寸。","莫放笛声吹落尽。"]},{"id":"c65-13","title":"燕归梁·楼外东风杜宇声","rhythmic":"燕归梁","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["楼外东风杜宇声。","双枕细眉颦。","女郎番马小山屏。","金笼冷、梦魂惊。","起来重绾双罗髻，无个事、泪盈盈。","杨花蝴蝶乱分身。","飞不定、暮云晴。"]},{"id":"c65-14","title":"小重山·半夜灯残鼠上檠","rhythmic":"小重山","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["半夜灯残鼠上檠。","上窗风动竹，月微明。","梦魂偏记水西亭。","琅玕碧，花影弄晴蜓。","千里暮云平。","南楼催上烛，晚来晴。","酒阑人散斗西倾。","天如水，团扇扑流萤。"]},{"id":"c65-15","title":"河传·斜红照水","rhythmic":"河传","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["斜红照水。","似晴空万里。","明霞相倚。","逐伴笑歌，小立绿槐阴里。","诮没些，春气味。","纷纷觑著闲桃李。","浅浅深深，不满游人意。","幽艳一枝，向晚重帘深闭。","是青君、爱惜底。"]},{"id":"c65-16","title":"清平乐·水瓶石砚","rhythmic":"清平乐","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["水瓶石砚。","败壁蜗书篆。","窗下日舒缝衲线。","屋角晚风飞霰。","上元灯火佳时。","长廊语笑追随。","高卧一番纸帔，觉来月贯南枝。"]},{"id":"c65-17","title":"握金钗·风日困花枝","rhythmic":"握金钗","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["风日困花枝，晴蜂自相趁。","晚来红浅香尽。","整顿腰肢晕残粉。","弦上语，梦中人，天外信。","青杏已成双，新尊荐樱笋。","为谁一和销损。","数著佳期又不稳。","春去也，怎当他，清昼永。"]},{"id":"c65-18","title":"握金钗·向晚小妆匀","rhythmic":"握金钗","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["向晚小妆匀，明窗倦裁剪。","见花清泪遮眼。","开尽繁桃又春晚。","心下事，比年时，都较懒。","胡蝶入帘飞，郎声似莺啭。","见来无计拘管。","心似芭蕉乍舒展。","归去也，夕阳斜，红满院。"]},{"id":"c65-19","title":"南歌子·策杖穿荒圃","rhythmic":"南歌子","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["策杖穿荒圃，登临笑晚风。","无穷秋色蔽晴空。","遥见夕阳江上、卷飞蓬。","雁过菰蒲远，山遥梦寐通。","一林枫叶堕愁红。","归去暮烟深处、听疏锺。"]},{"id":"c65-20","title":"南歌子·远色连朱阁","rhythmic":"南歌子","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["远色连朱阁，寒鸦噪夕阳。","小炉温手酌鹅黄。","掩乱一枝清影、在寒窗。","念远歌声小，嗔归泪眼长。","纤腰今属冶游郎。","朝暮楚宫云雨、恨茫茫。"]},{"id":"c65-21","title":"蝶恋花·风洗游丝花皱影","rhythmic":"蝶恋花","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["风洗游丝花皱影。","碧草初齐，舞鹤闲相趁。","短梦乍回慵理鬓。","惊心忽数清明近。","逐伴强除眉上恨。","趁蝶西园，不觉鞋儿褪。","醉笑眼波横一寸。","微微酒色生红晕。"]},{"id":"c65-22","title":"蝶恋花·花色撩人红入眼","rhythmic":"蝶恋花","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["花色撩人红入眼。","可是东君，要得人肠断。","欲诉深情春不管。","风枝雨叶空撩乱。","谩插一枝飞一盏。","小赏幽期，破我平生愿。","珍约未成春又短。","但凭蝴蝶传深怨。"]},{"id":"c65-23","title":"品令·绣衣未整","rhythmic":"品令","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["绣衣未整。","傍窗格、临清镜。","新霜薄雾，这下几日，阴晴不定。","欲插黄花，心事又还记省。","去年香径。","共粉蝶、闲相趁。","宝香玉佩，暗解付与，多情荀令。","何日西楼，重见暮帆烟艇。"]},{"id":"c65-24","title":"祝英台・祝英台近·宝蟾明","rhythmic":"祝英台・祝英台近","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["宝蟾明，朱阁静，新燕近帘语。","还记元宵，灯火小桥路。","逢迎春笋柔微，凌波纤稳，诮不顾、斗斜三鼓。","甚无据。","谁信一霎是春，惊声留不住。","柳色苔痕，风雨暗花圃。","细看罗带银钩，绡巾香泪，算不枉、那时分付。"]},{"id":"c65-25","title":"水调歌头·扁舟思独往","rhythmic":"水调歌头","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["扁舟思独往，樯影划晴烟。","要伴人随明月，踏破水中天。","谁信骑鲸高逝，空对笔端风雨，如泛楚江船。","老子穷无赖，端欲把降竿。","白苹汀，归老计，似高闲。","平生爱我，一言相置二刘间。","准拟何山松桂，折足铛能安稳，芋火对阑残。","何必少林语，立雪问心安。"]},{"id":"c65-26","title":"水调歌头·江湖堪极目","rhythmic":"水调歌头","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["江湖堪极目，非雾亦非烟。","故人相见，纵横高义薄云天。","已具萸尊茗话，怅望云中江树，不见子猷船。","日色隐林表，十里认帆竿。","百年间，无个事，且安闲。","功名两字，茫然都坠有无间。","且尽身前一醉，休问古来今往，及取菊花残。","仙事占无据，竹帛笑刘安。"]},{"id":"c65-27","title":"水调歌头·秋斋多梦谒","rhythmic":"水调歌头","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["秋斋多梦谒，舌本欲生烟。","独步一庭明月，雁字已横天。","作个生涯不遂，松竹雨荒三径，却忆五湖船。","小阮贫尤甚，犊鼻挂长竿。","白鸥汀，风共水，一生闲。","横琴唳鹤，要携妻子老云间。","灯火荧荧深夜，高卧南窗折几，杯到不留残。","莫遣江湖手，遮日向长安。"]},{"id":"c65-28","title":"水调歌头·心肝皆锦绣","rhythmic":"水调歌头","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["心肝皆锦绣，落笔尽云烟。","诗狂酒兴，要骑赤鲤上青天。","织女回车相劳，指点虚无征路，翻动月明船。","举手谢同辈，岂复念渔竿。","我平生，心正似，白云闲。","衣冠污我，偶逢游戏到人间。","常念孤云高妙，若作辘轳俯仰，谁复食君残。","拜尘金谷辈，都是卧崇安。"]},{"id":"c65-29","title":"水调歌头·诗人翻水尽","rhythmic":"水调歌头","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["诗人翻水尽，寂寞五侯烟。","醉魂何在，应骑箕尾列青天。","记得平生谈笑，夹岸手栽杨柳，同泛夜深船。","溪水还依旧，深浅半青竿。","小神仙，殷七七，许闲闲。","黄粱未熟，经游都在梦魂间。","我厌嚣寺浊味，几欲凌云羽化，鸡犬不留残。","俗事丹砂冷，且抱一枝安。"]},{"id":"c65-30","title":"水调歌头·暮云遮远眼","rhythmic":"水调歌头","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["暮云遮远眼，叠叠入青烟。","十年不见，醯鸡同舞瓮中天。","闻道山阴回棹，相去都无百里，李郭可同船。","行止皆天意，端欲自操竿。","功名事，须早计，真安闲。","高才妙手，不当留意市廛间。","俄已山林长往，尘面时时拂镜，齿发甚衰残。","廊庙非吾事，茅屋且安安。"]},{"id":"c65-31","title":"水调歌头·抚床多感慨","rhythmic":"水调歌头","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["抚床多感慨，白发困风烟。","出门有碍，更堪寒暮雪飞天。","君弃一盂一衲，奔走五湖清海，杯度不乘船。","来访山中友，□□□□竿。","看人间，谁得似，谪仙闲。","生涯不问，留情多在酒杯间。","剪烛西风谈笑，零落一尊相对，不觉已更残。","回首功名事，笺记谢任安。"]},{"id":"c65-32","title":"水调歌头·十年禅榻畔","rhythmic":"水调歌头","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["十年禅榻畔，风雨扬茶烟。","跳丸日月，未甘白发困尧天。","江左风流才子，要伴江湖张翰，同泛洛阳船。","酌酒情无尽，海燕绕船竿。","逼人来，功业事，不教闲。","男儿三十，定当谈笑在堂间。","老子婆娑贫态，闭户长须赤脚，他日要分残。","禹浪桃花影，归棹正轻安。"]},{"id":"c65-33","title":"江城子·晓参垂户宿酲醒","rhythmic":"江城子","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["晓参垂户宿酲醒。","坐南亭。","对疏星。","点点萤光，偏向竹梢明。","望断长空何处是，云叶乱，彩霞横。","西楼依旧抱重城。","小银屏。","此时情。","鸦阵翻丛，枯柳两三声。","敧枕欲寻初夜梦，鸡唱远，晓蟾倾。"]},{"id":"c65-34","title":"江城子·闻君见影已堪怜","rhythmic":"江城子","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["闻君见影已堪怜。","短因缘。","偶同筵。","相见无言，分散倍依然。","做梦杨花随去也，妆阁畔，绣床前。","觉来离绪意绵绵。","写蛮笺。","倩谁传。","鱼雁悠悠，门外水如天。","欲上西楼还不忍，难著眼，望秋千。"]},{"id":"c65-35","title":"水龙吟·五湖春水茫茫","rhythmic":"水龙吟","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["五湖春水茫茫，梦魂夜逐杨花去。","汀花岸草，佳人微笑，眼波横注。","借问刘郎，心期则甚，一成无据。","自春来泪满，挼蓝袖口，没整顿，心情处。","闻道相如病渴，念文君、白头新句。","相思两地，无穷烟水，一庭花雾。","锦字藏头，织成机上，一时分付。","问他年，更有微云淡月，重来兮否。"]},{"id":"c65-36","title":"减字木兰花·雨帘高卷","rhythmic":"减字木兰花","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["雨帘高卷。","芳树阴阴连别馆。","凉气侵楼。","蕉叶荷枝各自秋。","前溪夜舞。","化作惊鸿留不住。","愁损腰肢。","一桁香销旧舞衣。"]},{"id":"c65-37","title":"减字木兰花·明眸巧笑","rhythmic":"减字木兰花","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["明眸巧笑。","坐久更宜灯烛照。","小醉辞归。","怀抱明明只自知。","琐窗重见。","桃李春风三月面。","怎不思量。","折柳孤吟断杀肠。"]},{"id":"c65-38","title":"江城子慢·新枝媚斜日","rhythmic":"江城子慢","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["新枝媚斜日。","花径霁、晚碧泛红滴。","近寒食。","蜂蝶乱、点检一城春色。","倦游客。","门外昏鸦啼梦破，春心似、游丝飞远碧。","燕子又语斜檐，行云自没消息。","当时乌丝夜语，约桃花时候，同醉瑶瑟。","甚端的。","看看是、榆角杨花飞掷。","怎忘得。","斜倚红楼回泪眼，天如水、沈沈连翠璧。","想伊不整啼妆影帘侧。"]},{"id":"c65-39","title":"如梦令·百和宝钗香佩","rhythmic":"如梦令","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["百和宝钗香佩。","短短同心霞带。","清镜照新妆，巧画一双眉黛。","多态。","多态。","偷观榴花窗外。"]},{"id":"c65-40","title":"极相思·拂墙花影飘红","rhythmic":"极相思","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["拂墙花影飘红。","微月辨帘栊。","香风满袖，金莲印步，狭径迎逢。","笑面乍开远敛翠，正花时、却恁西东。","别房初睡，斜门未锁，且更从容。"]},{"id":"c65-41","title":"极相思·西园斗草归迟","rhythmic":"极相思","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["西园斗草归迟。","隔叶啭黄鹂。","阑干醉倚，秋千背立，数遍佳期。","寒食清明都过了，趁如今、芍药蔷薇。","衩衣吟露，归舟缆月，方解开眉。"]},{"id":"c65-42","title":"贺新郎·斜日封残雪","rhythmic":"贺新郎","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["斜日封残雪。","记别时、檀槽按舞，霓裳初彻。","唱煞阳关留不住，桃花面皮似热。","渐点点、珍珠承睫。","门外潮平风席正，指佳期、共约花同折。","情未忍，带双结。","钗金未断肠先结。","下扁舟、更有暮山千叠。","别后武陵无好梦，春山子规更切。","但孤坐、一帘明月。","蚕共茧、花同蒂，甚人生要见，底多离别。","谁念我，泪如血。"]},{"id":"c65-43","title":"浪淘沙·倚枕数更筹","rhythmic":"浪淘沙","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["倚枕数更筹。","清夜悠悠。","竹风荷露小窗秋。","往事迷人浑不省，总是离愁。","无赖是横眸。","济楚风流。","一时搂揽著心头。","调数梦魂将我去，明月重楼。"]},{"id":"c65-44","title":"思佳客·深夜槐风析酲惺","rhythmic":"思佳客","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["深夜槐风析酲惺。","露荷凉气满西庭。","凭栏小语花梢月，缓步偷拈石上萤。","秋意早，暑衣轻。","殢人索酒复同倾。","大家沈醉还高枕，一任西楼报五更。"]},{"id":"c65-45","title":"二郎神·西池旧约","rhythmic":"二郎神","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["西池旧约。","燕语柳梢桃萼。","向紫陌、秋千影下，同绾双双凤索。","过了莺花休则问，风共月、一时闲却。","知谁去、唤得秋阴，满眼败垣红叶。","飘泊。","江湖载酒，十年行乐。","甚近日、伤高念远，不觉风前泪落。","橘熟橙黄堪一醉，断未负、晚凉池阁。","只愁被、撩拨春心，烦恼怎生安著。"]},{"id":"c65-46","title":"百宜娇・眉妩·隙月垂篦","rhythmic":"百宜娇・眉妩","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["隙月垂篦，乱蛩催织，秋晚嫩凉房户。","燕拂帘旌，鼠窥窗网，寂寂飞萤来去。","金铺镇掩，谩记得、花时南浦。","约重阳、萸糁菊英，小楼遥夜歌舞。","银烛暗、佳期细数。","帘幕渐西风，午窗秋雨。","叶底翻红，水面皱碧，灯火裁缝砧杵。","登高望极，正雾锁、官槐归路。","定须相将，宝马钿车，访吹箫侣。"]},{"id":"c65-47","title":"醉思仙·断人肠","rhythmic":"醉思仙","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["断人肠。","正西楼独上，愁倚斜阳。","称鸳鸯鸂鶒，两两池塘。","春又老，人何处，怎惯不思量。","到如今，瘦损我，又还无计禁当。","小院呼卢夜，当时醉倒残缸。","被天风吹散，凤翼难双。","南窗雨，西廊月，尚未散、拂天香。","听莺声，悄记得，那时舞板歌梁。"]},{"id":"c65-48","title":"眼儿媚·晓钗催鬓语南风","rhythmic":"眼儿媚","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["晓钗催鬓语南风。","碧涧小桥通。","榆阴短短，露光炯炯，满地花红。","天涯不见归帆影，蜂蝶尽西东。","宿酲渐解，残妆犹在，晓日帘栊。"]},{"id":"c65-49","title":"眼儿媚·循槛琅玕粉沾衣","rhythmic":"眼儿媚","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["循槛琅玕粉沾衣。","一片子规啼。","蓬壶梦短，蜀衾香远，愁损腰肢。","石城堂上双双燕，应傍莫愁飞。","春江艇子，雪中梅下，知与谁期。"]},{"id":"c65-50","title":"梦玉人引·上危梯尽","rhythmic":"梦玉人引","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["上危梯尽，尽画阁迥，昼帘垂。","曲水飘香，小园莺唤春归。","舞袖弓弯，正满城、烟草凄迷。","结伴踏青，趁蝴蝶双飞。","赏心欢计，从别后、无意到西池。","自检罗囊，要寻红叶留诗。","懒约无凭，莺花都不知。","怕人问，强开怀、细酌酴醿。"]},{"id":"c65-51","title":"倾杯令・杯倾乐·枫叶飘红","rhythmic":"倾杯令・杯倾乐","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["枫叶飘红，莲房肥露，枕席嫩凉先到。","帘外蟾华如扫。","枝上啼鸦催晓。","秋风又送潘郎老。","小窗明、疏萤浅照。","登高送远惆怅，白发至今未了。"]},{"id":"c65-52","title":"倾杯令・倾杯乐·隔座藏钩","rhythmic":"倾杯令・倾杯乐","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["隔座藏钩，分曹射覆，烛艳渐催三鼓。","筝按教坊新谱。","楼外月生春浦。","徘徊争忍忙归去。","怕明朝、无情风雨。","珍花美酒团坐，且作尊前笑侣。"]},{"id":"c65-53","title":"生查子·摊钱临小窗","rhythmic":"生查子","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["摊钱临小窗，扑蝶穿斜径。","醉戏晚风前，吹乱连枝影。","别来秋夜长，梦到金屏近。","肠断一声鸡，残月悬朝镜。"]},{"id":"c65-54","title":"生查子·裙长步渐迟","rhythmic":"生查子","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["裙长步渐迟，扇薄羞难掩。","鞋褪倚郎肩，问路眉先敛。","踏青南陌回，倚醉开娇靥。","今夜更同行，忍笑匀妆脸。"]},{"id":"c65-55","title":"生查子·双鬟绿发齐","rhythmic":"生查子","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["双鬟绿发齐，多笑蔫红落。","穿竹过西斋，问字时偷学。","娇慵不惯羞，同倚阑干角。","屈指数元宵，灯火堪行乐。"]},{"id":"c65-56","title":"扑蝴蝶近・扑蝴蝶·分钗绾髻","rhythmic":"扑蝴蝶近・扑蝴蝶","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["分钗绾髻，洞府难分手。","离觞短阕，啼痕冰舞袖。","马嘶霜滑，桥横路转，人依古柳。","晓色渐分星斗。","怎分剖。","心儿一似，倾入离愁万千斗。","垂鞭伫立，伤心还病酒。","十年梦里婵娟，二月花中豆蔻。","春风为谁依旧。"]},{"id":"c65-57","title":"扑蝴蝶近・扑蝴蝶·风荷露竹","rhythmic":"扑蝴蝶近・扑蝴蝶","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["风荷露竹，秋意侵疏鬓。","微灯曲几。","有帘通桂影。","乍凉衣著，轻明微醉，歌声听稳。","新愁殢人方寸。","怎不闷。","当初欲凭，燕翼西飞寄归信。","小窗睡起，梁间都去尽。","夜长旅枕先知，秋杪黄花渐近。","一成为伊销损。"]},{"id":"c65-58","title":"一落索·蝉带残声移别树","rhythmic":"一落索","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["蝉带残声移别树。","晚凉房户。","秋风有意染黄花，下几点、凄凉雨。","渺渺双鸿飞去。","乱云深处。","一山红叶为谁愁，供不尽、相思句。"]},{"id":"c65-59","title":"一落索·宫锦裁书寄远","rhythmic":"一落索","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["宫锦裁书寄远。","意长辞短。","香兰泣露雨催莲，暑气昏池馆。","向晚小园行遍。","石榴红满。","花花叶叶尽成双，浑似我、梁间燕。"]},{"id":"c65-60","title":"一落索·鸟散馀花飞舞","rhythmic":"一落索","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["鸟散馀花飞舞。","满地风雨。","长江滚滚接天流，夜送征帆去。","今夜行云何处。","断肠南浦。","残灯不剪五更寒，独自与、馀香语。"]},{"id":"c65-61","title":"谒金门·人已老","rhythmic":"谒金门","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["人已老。","春亦不留些少。","花尽叶长蚕又抱。","子规啼未了。","往事不论多少。","且向尊前一笑。","白发满头愁已到。","路长波渺渺。"]},{"id":"c65-62","title":"鼓笛慢・水龙吟·拍肩笑别洪崖","rhythmic":"鼓笛慢・水龙吟","author":"吕渭老","authorSlug":"吕渭老","dynasty":"宋","kind":"ci","paragraphs":["拍肩笑别洪崖，共看紫海还清浅。","蓬壶旧约，人间舒笑，桃红千遍。","去岁争春，今年逼腊，满空飘霰。","渐横枝照水，清绿弄日，都点缀、江南岸。","须吸百川为寿，卷恩波、已倾银汉。","戎袍拥戟，万钉围带，天孙新眷。","十里尘香，五更弦月，未收弦管。","正秦筝续谱，宫箫定拍，候来冬按。"]},{"id":"c65-63","title":"卜算子·拄颊看西湖","rhythmic":"卜算子","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["拄颊看西湖，屡对纶巾岸。","江上相从醉万山，六见年华换。","君唱我当酬，我醉君休管。","明日醒时小艇东，莫负传书雁。"]},{"id":"c65-64","title":"卜算子·堂下水浮天","rhythmic":"卜算子","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["堂下水浮天，人指山为岸。","水落寒沙只见山，暗被天偷换。","堂上老诗翁，客至劳相管。","风喘西头客自东，目送云中雁。"]},{"id":"c65-65","title":"卜算子·今日富川滨","rhythmic":"卜算子","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["今日富川滨，后夜湓江岸。","千里西湖指顾间，未怕新年换。","再见复何时，此意凭吟管。","应有新诗当尺书，日望南来雁。"]},{"id":"c65-66","title":"丑奴儿・采桑子·青腰似诧天公富","rhythmic":"丑奴儿・采桑子","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["青腰似诧天公富，奔走风云。","银界无痕。","委巷穷山草木春。","玉楼不怕歌茵湿，笑语纷纷。","须放他们。","醉里冰姿光照人。"]},{"id":"c65-67","title":"桃源忆故人·逢人借问春归处","rhythmic":"桃源忆故人","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["逢人借问春归处。","遥指芜城烟树。","收尽柳梢残雨。","月闯西南户。","游丝不解留伊住。","漫惹闲愁无数。","燕子为谁来去。","似说江头路。"]},{"id":"c65-68","title":"桃源忆故人·不知春色归何处","rhythmic":"桃源忆故人","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["不知春色归何处。","但见茂林芳树。","庭巷落花如雨。","斗乱穿窗户。","晚行溪上东风住。","荷点青钱无数。","蛱蝶飞来还去。","错认花间路。"]},{"id":"c65-69","title":"桃源忆故人·南园最是花多处","rhythmic":"桃源忆故人","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["南园最是花多处。","门掩绿杨千树。","别后几番风雨。","碧藓侵苔户。","侬家旧在郊西住。","门外远山无数。","谁道不如归去。","咫尺长安路。"]},{"id":"c65-70","title":"桃源忆故人·依依杨柳青青草","rhythmic":"桃源忆故人","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["依依杨柳青青草。","梦断画桥春晓。","风里落花如扫。","莫厌寻芳早。","酴醿芍药看来好。","恰似江湖遗老。","锦段荷□传到。","愧乏琼瑶报。"]},{"id":"c65-71","title":"桃源忆故人·望中风絮迷烟草","rhythmic":"桃源忆故人","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["望中风絮迷烟草。","愁结几番昏晓。","花径有时亲扫。","载酒应须早。","人情曷似春山好。","山色不随春老。","旧隐何当重到。","迎得平安报。"]},{"id":"c65-72","title":"沁园春·城郭萧条","rhythmic":"沁园春","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["城郭萧条，风雨霏微，酝造春愁。","况鸷群雕鹗，未谐荐祢，棘栖鸾凤，犹叹栖仇。","世路如棋，人情似纸，厚薄高低何日休。","逢殷浩，会披云对月，同赋南楼。","堪嗟日月如流。","甚首夏朅来今半秋。","纵荻花枫叶，强撩归思，有莼羹菰饭，归更何忧。","三板松舟，一篙秋水，百里淮山无暂留。","何须问，蘧蘧栩栩，孰是庄周。"]},{"id":"c65-73","title":"惜奴娇·不厮知名","rhythmic":"惜奴娇","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["不厮知名，怎奈向、前缘注定。","一封书、便成媒娉。","千里相从，恰似寻盟合姓。","泥泞。","尚隔个、轿儿难近。","薄薄纱厨，小驿夜凉人静。","红一点、暗通犀晕。","花月多情，摇碎半窗清影。","安稳。","悄不知、人痛损。"]},{"id":"c65-74","title":"惜奴娇·甚麽因缘","rhythmic":"惜奴娇","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["甚麽因缘，恰得一年相聚。","和闰月、更无剩数。","说著分飞，背面偷弹玉箸。","好去。","记取许时言语。","旧爱新人，后夜一时分付。","从前事、不堪回顾。","怎奈冤家，抵死牵肠惹肚。","愁苦。","梦断五更风雨。"]},{"id":"c65-75","title":"南乡子·遗爱满南州","rhythmic":"南乡子","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["遗爱满南州。","千骑曾为万里游。","琳馆归来，无责更无忧。","坐听笙歌醉玉舟。","香雾郁金虬。","春入梅花助献酬。","请祝遐年，长笑挹浮丘。","何止莘君一百筹。"]},{"id":"c65-76","title":"南乡子·天际彩虹垂","rhythmic":"南乡子","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["天际彩虹垂。","风起痴云快一吹。","原隰畇畇，春水更弥弥。","布谷期从野鸟知。","初霁卷帘时。","巷陌泥融燕子飞。","午醉醒来，红日欲平西。","一碗新茶乳面肥。"]},{"id":"c65-77","title":"南乡子·出户绣帘垂","rhythmic":"南乡子","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["出户绣帘垂。","拂面从他细细吹。","乘兴有谁招访戴，难为。","暖帐薰炉醉不知。","闲看逐风时。","欲著梅花又却飞。","雅兴佳人回舞袂，相宜。","试比冰肌可煞肥。"]},{"id":"c65-78","title":"南乡子·春霁柳花垂","rhythmic":"南乡子","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["春霁柳花垂。","娇软轻狂不待吹。","圆欲成球还复碎，谁为。","习习和风即旧知。","深院日长时。","乱扑珠帘入坐飞。","试问荻芽生也未，偏宜。","出网河豚美更肥。"]},{"id":"c65-79","title":"南乡子·风急断虹收","rhythmic":"南乡子","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["风急断虹收。","孤鹜摇摇下荻洲。","醉帽尽从吹落去，飕飕。","幸有黄花插满头。","君唱我当酬。","千里湖山照眼秋。","不见故人思故国，休休。","一阕清歌听解愁。"]},{"id":"c65-80","title":"南乡子·翠袖熨沈香","rhythmic":"南乡子","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["翠袖熨沈香。","黛拂修蛾淡淡妆。","消得多情锺傅粉，何郎。","风动珠帘月半床。","素手捧瑶觞。","谁念苏州已断肠。","夜雨不随歌扇歇，浪浪。","归去无心赋海棠。"]},{"id":"c65-81","title":"减字木兰花·彩幡金胜","rhythmic":"减字木兰花","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["彩幡金胜。","一笑酬春聊适性。","呆女痴儿。","半挽梅花半柳枝。","追欢何计。","幸对绿尊环皂髻。","欲舞还羞。","美盼娇回碧水秋。"]},{"id":"c65-82","title":"减字木兰花·诗成呵手","rhythmic":"减字木兰花","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["诗成呵手。","欲写已输君赋就。","寒粟生肤。","一盏浇肠可得无。","回风弄巧。","比似婆娑尤敏妙。","似个人人。","嗅认梅花孰是真。"]},{"id":"c65-83","title":"减字木兰花·尊前放手","rhythmic":"减字木兰花","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["尊前放手。","铜钵声穷诗已就。","姑射肌肤。","舞罢缠头怎得无。","青腰更巧。","搓粉团酥来斗妙。","不敢方人。","容色依稀似太真。"]},{"id":"c65-84","title":"减字木兰花·玉奴招手","rhythmic":"减字木兰花","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["玉奴招手。","来看前山琼琢就。","透骨侵肤。","似恁清寒更有无。","春工纵巧。","只许梅花称独妙。","花底逢人。","逐马银杯误认真。"]},{"id":"c65-85","title":"减字木兰花·鳖头龟手","rhythmic":"减字木兰花","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["鳖头龟手。","孤坐书生能意就。","暖体温肤。","绣被春寒想见无。","雪词工巧。","高压君房天下妙。","白发欺人。","甚矣吾衰懒是真。"]},{"id":"c65-86","title":"减字木兰花·修眉山远","rhythmic":"减字木兰花","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["修眉山远。","娇抹乌云秋水畔。","酒里花前。","坐拥斯人怎得寒。","醁醽浮满。","须索空缸仍覆盏。","正恐相妨。","归去如闻笑语香。"]},{"id":"c65-87","title":"减字木兰花·江梅清远","rhythmic":"减字木兰花","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["江梅清远。","潇洒一枝尊俎畔。","雪里风前。","照水窥檐巧耐寒。","多情美满。","共饮自应渠釂盏。","醉赏何妨。","倾国天教抵死香。"]},{"id":"c65-88","title":"减字木兰花·笑中声远","rhythmic":"减字木兰花","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["笑中声远。","走向曲房花树畔。","拥在尊前。","顿觉春温却夜寒。","愿酬心满。","只得教伊频劝盏。","缓唱何妨。","贴体衫儿扑扑香。"]},{"id":"c65-89","title":"减字木兰花·仙姿凝远","rhythmic":"减字木兰花","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["仙姿凝远。","半出新妆琼户畔。","缓步来前。","正值东风料峭寒。","钗头花满。","舞罢梅英飞入盏。","一釂何妨。","花与佳人巧斗香。"]},{"id":"c65-90","title":"减字木兰花·离筵暂住","rhythmic":"减字木兰花","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["离筵暂住。","君在龙舒曾是主。","今作行人。","卧辙何妨借寇恂。","清歌妙舞。","断送吟鞭乘醉去。","一釂休辞。","捧爵佳人玉箸垂。"]},{"id":"c65-91","title":"减字木兰花·金尊频倒","rhythmic":"减字木兰花","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["金尊频倒。","照坐梅花清更好。","春到长杨。","宠拜三公入郑庄。","月城两载。","千里生灵蒙惠爱。","舞彻歌词。","并立新妆绿带垂。"]},{"id":"c65-92","title":"减字木兰花·蛾眉螓首","rhythmic":"减字木兰花","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["蛾眉螓首。","舞雪娇回开冻候。","尽道今年。","千里风光萃绮筵。","坐来新月。","照我苍颜并白发。","酒到休辞。","自有黄芽介寿祺。"]},{"id":"c65-93","title":"阮郎归·玉绳低转斗阑干","rhythmic":"阮郎归","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["玉绳低转斗阑干。","欠温春酒寒。","夜长风劲怯衣单。","有人哦二山。","蟾欲满，雁初还。","桃花微破颜。","枕痕犹带断红残。","无言心自闲。"]},{"id":"c65-94","title":"阮郎归·长杨风软弄腰肢","rhythmic":"阮郎归","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["长杨风软弄腰肢。","日长胡蝶飞。","雨馀新绿细通池。","玉钩悬妓衣。","鸿雁远，子规啼。","此情谁得知。","一尊聊与故人持。","醉来悲别离。"]},{"id":"c65-95","title":"长相思·雨濛濛","rhythmic":"长相思","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["雨濛濛。","日昽昽。","洗出远山三四重。","分明眉黛浓。","野桥西，官路东。","小驿夜凉风入松。","梦魂谁与同。"]},{"id":"c65-96","title":"长相思·花一枝","rhythmic":"长相思","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["花一枝。","酒一卮。","举酒对花君莫辞。","人生多别离。","行相随。","坐相随。","更有何人得似伊。","春融胡蝶飞。"]},{"id":"c65-97","title":"长相思·天四垂","rhythmic":"长相思","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["天四垂。","山四围。","山色天容入坐帷。","清风吹我衣。","湖水东，江水西。","东去西来无尽期。","不如君共伊。"]},{"id":"c65-98","title":"长相思·吴江枫","rhythmic":"长相思","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["吴江枫。","吴江风。","索索秋声飞乱红。","晚来归兴浓。","淮山西，淮山东。","明月今宵何处同。","相寻魂梦中。"]},{"id":"c65-99","title":"长相思·风凄凄","rhythmic":"长相思","author":"王之道","authorSlug":"王之道","dynasty":"宋","kind":"ci","paragraphs":["风凄凄。","雨霏霏。","风雨夜寒人别离。","梦回还自疑。","蛩声悲。","漏声迟。","一点青灯明更微。","照人双泪垂。"]}]