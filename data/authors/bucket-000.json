tyle":"号冲虚居士","life":"","origin":"","seal":"孙","bio":["--号冲虚居士，黄铢之母。今有赵万里辑本《冲虚居士词》。"],"works":[{"id":"c65-595","title":"滴滴金·月光飞入林前屋","kind":"词"},{"id":"c65-596","title":"醉蓬莱·看鸥翻波溅","kind":"词"},{"id":"c65-597","title":"菩萨蛮·栏干六曲天围碧","kind":"词"},{"id":"c65-598","title":"少年游·雨晴云敛","kind":"词"},{"id":"c65-599","title":"忆秦娥·秋寂寞","kind":"词"},{"id":"c65-600","title":"醉思仙·晚霞红","kind":"词"},{"id":"c65-601","title":"如梦令·翠柏红蕉影乱","kind":"词"},{"id":"c65-602","title":"清平乐·悠悠扬扬","kind":"词"}]},"尤袤":{"slug":"尤袤","name":"尤袤","dynasty":"宋","style":"","life":"","origin":"","seal":"尤","bio":[],"works":[{"id":"c59-895","title":"瑞鹧鸪·梁溪西畔小桥东","kind":"词"},{"id":"c59-896","title":"瑞鹧鸪·两行芳蕊傍溪阴","kind":"词"}]},"尹洙":{"slug":"尹洙","name":"尹洙","dynasty":"宋","style":"","life":"","origin":"","seal":"尹","bio":[],"works":[{"id":"c58-197","title":"水调歌头·万倾太湖上","kind":"词"}]},"崔沔":{"slug":"崔沔","name":"崔沔","dynasty":"唐","style":"字善冲","life":"","origin":"","seal":"崔","bio":["崔沔，字善冲，京兆长安人。事亲至孝，应制举，高第，俄被黜落者所援。则天令所司重试，沔对策又工于前，为天下第一。","岑羲器之曰：“今之郄诜也。”特荐为左补阙。开元中，拜中书侍郎，出为魏州刺史。","征还，分掌十铨，以清直历秘书监，太子宾客。沔深明礼经，详定宗庙笾豆之数及六亲服纪，多所建议。诗一首。"],"works":[{"id":"t5-388","title":"奉和圣制同二相已下群官乐游园宴","kind":"诗"}]},"徐源":{"slug":"徐源","name":"徐源","dynasty":"唐","style":"","life":"","origin":"","seal":"徐","bio":[],"works":[{"id":"t50-610","title":"无题","kind":"诗"},{"id":"t50-611","title":"题灵泉寺","kind":"诗"}]},"敬括":{"slug":"敬括","name":"敬括","dynasty":"唐","style":"字叔弓","life":"","origin":"","seal":"敬","bio":["敬括，字叔弓，河东人。少以文词称乡，举进士，又应制登科。累官右拾遗、内供奉、殿中侍御史。","天宝末，以不附杨国忠，出为刺史。迁给事中、兵部侍郎、大理卿。大历初，诏选循良为近辅，以括为同州刺史，入为御史大夫，卒。","诗一首。"],"works":[{"id":"t10-574","title":"省试七月流火","kind":"诗"}]},"昭宗皇帝":{"slug":"昭宗皇帝","name":"昭宗皇帝","dynasty":"唐","style":"","life":"","origin":"","seal":"昭","bio":["帝讳晔，懿宗第七子，初名杰，封寿王。文德元年，立为皇太弟。在位十四年。","帝攻书好文，而承广明寇乱之后，唐祚日衰，遗诗只韵，皆其播迁所制也。帝讳晔，懿宗第七子，初名杰，封寿王。文德元年，立为皇太弟。","在位十四年。帝攻书好文，而承广明寇乱之后，唐祚日衰。遗诗只韵，皆其播迁所制也。"],"works":[{"id":"t0-214","title":"咏雷句","kind":"诗"},{"id":"t49-72","title":"巫山一段云 一","kind":"诗"},{"id":"t49-73","title":"巫山一段云 二","kind":"诗"},{"id":"t49-74","title":"菩萨蛮 一","kind":"诗"},{"id":"t49-75","title":"菩萨蛮 二","kind":"诗"}]},"朱休":{"slug":"朱休","name":"朱休","dynasty":"唐","style":"","life":"","origin":"","seal":"朱","bio":[],"works":[{"id":"t43-275","title":"春水绿波","kind":"诗"}]},"欧阳彬":{"slug":"欧阳彬","name":"欧阳彬","dynasty":"唐","style":"","life":"","origin":"","seal":"欧","bio":[],"works":[{"id":"t43-716","title":"句","kind":"诗"},{"id":"t49-681","title":"生查子","kind":"诗"},{"id":"t56-258","title":"复为翰林作（题拟）","kind":"诗"}]},"沈邈":{"slug":"沈邈","name":"沈邈","dynasty":"宋","style":"","life":"","origin":"","seal":"沈","bio":[],"works":[{"id":"c57-653","title":"剔银灯·一夜隋河风劲","kind":"词"},{"id":"c57-654","title":"剔银灯·江上秋高霜早","kind":"词"}]},"王韫秀":{"slug":"王韫秀","name":"王韫秀","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王韫秀，河西节度使忠嗣女，宰相元载妻也。诗三首。"],"works":[{"id":"t43-928","title":"同夫游秦","kind":"诗"},{"id":"t43-929","title":"夫入相寄姨妹","kind":"诗"},{"id":"t43-930","title":"喻夫阻客","kind":"诗"}]},"缪岛云":{"slug":"缪岛云","name":"缪岛云","dynasty":"唐","style":"","life":"","origin":"","seal":"缪","bio":["缪岛云，少从浮图，武宗时返俗。补诗十首。"],"works":[{"id":"t43-669","title":"句","kind":"诗"},{"id":"t50-827","title":"白龙潭","kind":"诗"},{"id":"t50-828","title":"游黄山怀古","kind":"诗"},{"id":"t50-829","title":"登天都峰","kind":"诗"},{"id":"t50-830","title":"马迹石","kind":"诗"},{"id":"t50-831","title":"望黄山诸峰","kind":"诗"},{"id":"t50-832","title":"汤泉","kind":"诗"},{"id":"t50-833","title":"朱砂石","kind":"诗"},{"id":"t50-834","title":"石人峰","kind":"诗"},{"id":"t50-835","title":"僊僧洞","kind":"诗"},{"id":"t50-836","title":"僊桥","kind":"诗"},{"id":"t53-841","title":"过盱江麻姑山题绝句","kind":"诗"}]},"胡证":{"slug":"胡证","name":"胡证","dynasty":"唐","style":"字启中","life":"","origin":"","seal":"胡","bio":["胡证字启中，河东的。官至检校兵部尚书、广州刺史、充岭南节度使。大和二年卒于任，年七十一。","补诗一首。"],"works":[{"id":"t50-639","title":"汝州北楼晚望少室诗","kind":"诗"}]},"苏拯":{"slug":"苏拯","name":"苏拯","dynasty":"唐","style":"","life":"","origin":"","seal":"苏","bio":["苏拯，光化中人，诗一卷。"],"works":[{"id":"t40-501","title":"颂鲁","kind":"诗"},{"id":"t40-502","t