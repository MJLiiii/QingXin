{"冯伉":{"slug":"冯伉","name":"冯伉","dynasty":"唐","style":"","life":"","origin":"","seal":"冯","bio":["冯伉，魏州元城人。大历初，举五经，又举宏词，三迁膳部员外郎。使泽潞，不受币，德宗以其清可用，授醴泉令，为著谕蒙书以劝俗。","韦渠牟荐为给事中，再领国子祭酒。卒，赠礼部尚书。诗三首。"],"works":[{"id":"t0-750","title":"郊庙歌辞 享文敬太子庙乐章 迎俎酌献","kind":"诗"},{"id":"t17-551","title":"和权载之离合诗","kind":"诗"},{"id":"t17-552","title":"享文恭太子庙乐章二首 一","kind":"诗"},{"id":"t17-553","title":"享文恭太子庙乐章二首 二","kind":"诗"}]},"冯延鲁":{"slug":"冯延鲁","name":"冯延鲁","dynasty":"唐","style":"字叔文","life":"","origin":"","seal":"冯","bio":["延鲁，字叔文，一名谧，新安人，延巳异母弟。中主立，累迁至中书舍人。攻福州败，流舒州。","赦归，改工部侍郎。周据扬州，被俘仕北为刑部侍郎。放还为户部尚书，改常州观察使，卒。","有集，不传。诗一首又二句。（《全唐诗》无冯延鲁诗，传据马氏《南唐书》卷二十一、《宋史》卷四七八）"],"works":[{"id":"t55-410","title":"归国南辕之日答揆相赠诗（题拟）","kind":"诗"},{"id":"t55-411","title":"赠李学士","kind":"诗"}]},"刘处约":{"slug":"刘处约","name":"刘处约","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":["处约，宣州人。曾任吏部员外郎、考功郎中。孙长卿，以诗名世。","诗一首。（《全唐诗》无刘处约诗。兹据《元和姓纂》卷五、劳格《郎官石柱题名考》卷四、卷九录其事迹）"],"works":[{"id":"t52-590","title":"下山逢故人","kind":"诗"}]},"华清淑":{"slug":"华清淑","name":"华清淑","dynasty":"宋","style":"","life":"","origin":"","seal":"华","bio":[],"works":[{"id":"c75-657","title":"望江南・忆江南·燕塞雪","kind":"词"}]},"吉王从谦":{"slug":"吉王从谦","name":"吉王从谦","dynasty":"唐","style":"","life":"","origin":"","seal":"吉","bio":["从谦，元完第九子，后主母弟也。风采峭整，动有规诲，喜为律诗。宋改封鄂国公。","诗一首。"],"works":[{"id":"t0-340","title":"观棋","kind":"诗"}]},"吴仁璧":{"slug":"吴仁璧","name":"吴仁璧","dynasty":"唐","style":"字廷宝","life":"","origin":"","seal":"吴","bio":["吴仁璧，字廷宝，吴人或云关右人。大顺二年，登进士第。钱镠据浙，累辟不就，镠怒，沈之江。","诗一卷，今存十一首。"],"works":[{"id":"t38-697","title":"投谢钱武肃","kind":"诗"},{"id":"t38-698","title":"客路","kind":"诗"},{"id":"t38-699","title":"南徐题友人郊居","kind":"诗"},{"id":"t38-700","title":"读度人经寄郑仁表","kind":"诗"},{"id":"t38-701","title":"秋日听僧弹琴","kind":"诗"},{"id":"t38-702","title":"贾谊","kind":"诗"},{"id":"t38-703","title":"春雪","kind":"诗"},{"id":"t38-704","title":"衰柳","kind":"诗"},{"id":"t38-705","title":"凤仙花","kind":"诗"},{"id":"t38-706","title":"金钱花","kind":"诗"},{"id":"t38-707","title":"钱塘鹤","kind":"诗"},{"id":"t38-708","title":"句","kind":"诗"}]},"周紫芝":{"slug":"周紫芝","name":"周紫芝","dynasty":"宋","style":"字少隐 · 号竹坡居士","life":"","origin":"宣城（今属安徽）","seal":"周","bio":["--(1082－？) 字少隐，号竹坡居士。宣城 (今属安徽) 人。从李之仪、吕本中游。","绍兴进士，曾任枢密院编修。出知建康府、兴国军。晚年屡以诗文谀颁秦桧、秦父子。","著有《太仓米集》及《竹坡诗话》。词学晏几道，晚年除其丽，自成一格。有《竹坡词》传世。"],"works":[{"id":"c63-456","title":"水龙吟·黄金双阙横空","kind":"词"},{"id":"c63-457","title":"水龙吟·楚山千叠浮空","kind":"词"},{"id":"c63-458","title":"水龙吟·楚山木落风高","kind":"词"},{"id":"c63-459","title":"浣溪沙·近腊风光一半休","kind":"词"},{"id":"c63-460","title":"浣溪沙·欲醉江梅兴未休","kind":"词"},{"id":"c63-461","title":"浣溪沙·无限春情不肯休","kind":"词"},{"id":"c63-462","title":"浣溪沙·水上鸣榔不系船","kind":"词"},{"id":"c63-463","title":"浣溪沙·多病嫌秋怕上楼","kind":"词"},{"id":"c63-464","title":"浣溪沙·醽醁新翻碧玉壶","kind":"词"},{"id":"c63-465","title":"浣溪沙·学画双蛾苦未成","kind":"词"},{"id":"c63-466","title":"卜算子·江北上归舟","kind":"词"},{"id":"c63-467","title":"卜算子·霜叶下孤篷","kind":"词"},{"id":"c63-468","title":"卜算子·絮尽柳成空","kind":"词"},{"id":"c63-469","title":"木兰花・玉楼春·嫦娥天上人谁识","kind":"词"},{"id":"c63-470","title":"木兰花・玉楼春·江头雨后山如髻","kind":"词"},{"id":"c63-471","title":"减字木兰花·春闲昼永","kind":"词"},{"id":"c63-472","title":"减字木兰花·蓬莱三岛","kind":"词"},{"id":"c63-473","title":"减字木兰花·西山岩桂","kind":"词"},{"id":"c63-474","title":"减字木兰花·当年文伯","kind":"词"},{"id":"c63-475","title":"摊破浣溪沙・山花子·苍璧新敲小凤团","kind":"词"},{"id":"c63-476","title":"减字木兰花·门外青骢月下嘶","kind":"词"},{"id":"c63-477","title":"水调歌头·白发三千丈","kind":"词"},{"id":"c63-478","title":"水调歌头·濯锦桥边月","kind":"词"},{"id":"c63-479","title":"水调歌头·岁晚念行役","kind":"词"},{"id":"c63-480","title":"水调歌头·落日在烟树","kind":"词"},{"id":"c63-481","title":"沙塞子·秋云微淡月微羞","kind":"词"},{"id":"c63-482","title":"沙塞子·玉溪秋月浸寒波","kind":"词"},{"id":"c63-483","title":"鹧鸪天·荷气吹凉到枕边","kind":"词"},{"id":"c63-484","title":"鹧鸪天·乌鹊桥边河汉流","kind":"词"},{"id":"c63-485","title":"鹧鸪天·尊酒年年乐事多","kind":"词"},{"id":"c63-486","title":"鹧鸪天·名在休文季孟间","kind":"词"},{"id":"c63-487","title":"鹧鸪天·袅袅云梳晓髻堆","kind":"词"},{"id":"c63-488","title":"鹧鸪天·晴日烘帘暖似春","kind":"词"},{"id":"c63-489","title":"鹧鸪天·一点残红欲尽时","kind":"词"},{"id