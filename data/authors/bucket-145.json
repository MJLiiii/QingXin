实","name":"庭实","dynasty":"唐","style":"","life":"","origin":"","seal":"庭","bio":[],"works":[{"id":"t47-240","title":"逸句","kind":"诗"}]},"普愿":{"slug":"普愿","name":"普愿","dynasty":"唐","style":"","life":"","origin":"","seal":"普","bio":["普愿，姓王，郑州新郑人。至德二年依大隗山大慧禅师，后师马祖道一。贞元十一年后，住池州南泉山，世称南泉和尚。","大和八年卒，年八十七。诗一首。（《全唐诗》无普愿诗）"],"works":[{"id":"t53-619","title":"久住投机偈","kind":"诗"}]},"李彦𬀩":{"slug":"李彦𬀩","name":"李彦𬀩","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t1-75","title":"相和歌辞 采桑","kind":"诗"}]},"李生":{"slug":"李生","name":"李生","dynasty":"宋","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"c64-755","title":"渔家傲·庭院黄昏人悄悄","kind":"词"}]},"李真":{"slug":"李真","name":"李真","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李真，唐末仙人。"],"works":[{"id":"t47-728","title":"丈人山诗","kind":"诗"}]},"李缟":{"slug":"李缟","name":"李缟","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李缟，唐末人。诗一首。"],"works":[{"id":"t40-841","title":"和三乡诗","kind":"诗"}]},"王从叔":{"slug":"王从叔","name":"王从叔","dynasty":"宋","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"c76-465","title":"昭君怨·门外春风几度","kind":"词"},{"id":"c76-466","title":"阮郎归·风中柳絮水中萍","kind":"词"},{"id":"c76-467","title":"南柯子・南歌子·碧树留云湿","kind":"词"},{"id":"c76-468","title":"浣溪沙·水月精神玉雪胎","kind":"词"},{"id":"c76-469","title":"秋蕊香·薄薄罗衣乍暖","kind":"词"}]},"萧允之":{"slug":"萧允之","name":"萧允之","dynasty":"宋","style":"","life":"","origin":"","seal":"萧","bio":[],"works":[{"id":"c76-486","title":"渡江云·蔷薇开欲谢","kind":"词"},{"id":"c76-487","title":"满江红·冷逼疏帘","kind":"词"},{"id":"c76-488","title":"琐窗寒·细雨收尘","kind":"词"},{"id":"c76-489","title":"蝶恋花·十幅归帆风力满","kind":"词"},{"id":"c76-490","title":"虞美人·朱楼曾记回娇盼","kind":"词"},{"id":"c76-491","title":"点绛唇·花径相逢","kind":"词"}]},"裴夷直":{"slug":"裴夷直","name":"裴夷直","dynasty":"唐","style":"字礼卿","life":"","origin":"","seal":"裴","bio":["裴夷直，字礼卿，河东人，擢进士第。文宗时，历右拾遗、礼部员外郎，进中书舍人。武宗即位，出刺杭州，斥驩州司户参军。","宣宗初，复拜江、华等州刺史，终散骑常侍。诗一卷。"],"works":[{"id":"t27-802","title":"献岁书情","ki