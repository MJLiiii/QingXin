{"于尹躬":{"slug":"于尹躬","name":"于尹躬","dynasty":"唐","style":"","life":"","origin":"","seal":"于","bio":["于尹躬，大历进士。元和间为中书舍人，左迁洋州刺史。诗一首。"],"works":[{"id":"t16-580","title":"南至日太史登台书云物","kind":"诗"}]},"何仲举":{"slug":"何仲举","name":"何仲举","dynasty":"唐","style":"","life":"","origin":"","seal":"何","bio":["何仲举，营道人。后唐天成中登进士第，仕楚，署天策府学士、全、衡二州刺史。诗一首。"],"works":[{"id":"t42-567","title":"李臯试诗","kind":"诗"},{"id":"t42-568","title":"句","kind":"诗"},{"id":"t55-950","title":"谢秦王","kind":"诗"}]},"吴奕":{"slug":"吴奕","name":"吴奕","dynasty":"宋","style":"","life":"","origin":"","seal":"吴","bio":[],"works":[{"id":"c76-632","title":"升平乐·水阁层台","kind":"词"}]},"吴舜选":{"slug":"吴舜选","name":"吴舜选","dynasty":"宋","style":"","life":"","origin":"","seal":"吴","bio":[],"works":[{"id":"c63-818","title":"蓦山溪·园林何有","kind":"词"}]},"张希复":{"slug":"张希复","name":"张希复","dynasty":"唐","style":"字善继","life":"","origin":"","seal":"张","bio":["张希复，字善继，常山人，历官集贤校理学士。诗一首。张希复，字善继，常山人。","历官集贤校理学士。诗一首。"],"works":[{"id":"t30-166","title":"咏宣律和尚袈裟","kind":"诗"},{"id":"t49-197","title":"闲中好","kind":"诗"}]},"方为":{"slug":"方为","name":"方为","dynasty":"唐","style":"","life":"","origin":"","seal":"方","bio":["方为，处士，约为五代时人。（《全唐诗》无方为诗）"],"works":[{"id":"t55-333","title":"献砚诗","kind":"诗"}]},"曹希蕴":{"slug":"曹希蕴","name":"曹希蕴","dynasty":"宋","style":"","life":"","origin":"","seal":"曹","bio":[],"works":[{"id":"c62-555","title":"西江月·零落不因春雨","kind":"词"},{"id":"c62-556","title":"踏莎行·解遣愁人","kind":"词"}]},"曾崇范妻":{"slug":"曾崇范妻","name":"曾崇范妻","dynasty":"唐","style":"","life":"","origin":"","seal":"曾","bio":[],"works":[{"id":"t48-197","title":"梦中语","kind":"诗"}]},"温宪":{"slug":"温宪","name":"温宪","dynasty":"唐","style":"","life":"","origin":"","seal":"温","bio":["温宪，庭筠之子，登进士第。光启中，为山南从事。诗四首。"],"works":[{"id":"t37-184","title":"郊居","kind":"诗"},{"id":"t37-185","title":"杏花","kind":"诗"},{"id":"t37-186","title":"春鸠","kind":"诗"},{"id":"t37-187","title":"题崇[庆]寺壁","kind":"诗"},{"id":"t51-530","title":"梨花","kind":"诗"}]},"王威德":{"slug":"王威德","name":"王威德","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["威德，唐初人。（《全唐诗》无王威德诗）"],"works":[{"id":"t52-98","title":"戏贾元逊","kind":"诗"}]},"田游岩":{"slug":"田游岩","name":"田游岩","dynasty":"唐","style":"号许由东邻","life":"","origin":"","seal":"田","bio":["田游岩，京兆三原人。初补太学生，罢归。遍游山水，后入箕山，筑室许由庙东，自号许由东邻。","调露中，高宗游嵩山，亲至其门，游岩山衣田冠出拜。帝令左右扶止之，谓曰：“先生养道山中，比得佳否？”对曰：“臣泉石膏盲，烟霞痼疾，既逢圣代，幸得逍遥。”敕乘传赴都，授崇文馆学士，进太子洗马。","垂拱中，坐与裴炎善，放还山。蚕衣耕食，不交当世，惟与韩法昭、宋之问为方外友。诗一首。"],"works":[{"id":"t3-877","title":"弘农清岩曲有磐石可坐宋十一每拂拭待余寄诗赠之","kind":"诗"}]},"聂冠卿":{"slug":"聂冠卿","name":"聂冠卿","dynasty":"宋","style":"","life":"","origin":"","seal":"聂","bio":[],"works":[{"id":"c57-645","title":"多丽·想人生","kind":"词"}]},"薛少殷":{"slug":"薛少殷","name":"薛少殷","dynasty":"唐","style":"","life":"","origin":"","seal":"薛","bio":[],"works":[{"id":"t43-336","title":"临川羡鱼","kind":"诗"}]},"薛曜":{"slug":"薛曜","name":"薛曜","dynasty":"唐","style":"","life":"","origin":"","seal":"薛","bio":["薛曜，元超子，以文学知名。尚城阳公主，子绍尚太平公主，绍兄凯惧太盛，以问从兄克。克曰：“帝甥尚主，由来故事，但以恭慎行之，何惧也。","”圣历中，与修《三教珠英》，官正谏大夫。集二十卷，今存诗五首。"],"works":[{"id":"t4-305","title":"奉和圣制夏日游石淙山","kind":"诗"},{"id":"t4-306","title":"子夜冬歌","kind":"诗"},{"id":"t4-307","title":"舞马篇","kind":"诗"},{"id":"t4-308","title":"正夜侍宴应诏","kind":"诗"},{"id":"t4-309","title":"送道士入天台","kind":"诗"},{"id":"t48-790","title":"登绵州富乐山别李道士䇿","kind":"诗"},{"id":"t48-791","title":"九城寻山水","kind":"诗"},{"id":"t48-792","title":"邙山古意","kind":"诗"}]},"赵佶":{"slug":"赵佶","name":"赵佶","dynasty":"宋","style":"","life":"1100 — 1125","origin":"","seal":"赵","bio":["(1082－1135) 即宋徽宗。公元 1100-1125 年在位。靖康二年 (1127)，为金人所俘，死于五国城 (今黑龙江依兰)。","书、画、词皆善。有曹元忠辑本《宋徽宗词》。"],"works":[{"id":"c64-136","title":"声声慢·宫梅粉淡","kind":"词"},{"id":"c64-137","title":"声声慢·欺寒冲暖","kind":"词"},{"id":"c64-138","title":"念奴娇·雅怀素态","kind":"词"},{"id":"c64-139","title":"醉落魄・一斛珠·无言哽噎","kind":"词"},{"id":"c64-140","title":"探春令·帘旌微动","kind":"词"},{"id":"c64-141","title":"聒龙谣·紫阙苕峣","kind":"词"},{"id":"c64-142","title":"临江仙·过水穿山前去也","kind":"词"},{"id":"c64-143","title":"月上海棠·孟婆且与我","kind":"词"},{"id":"c64-144","title":"满庭芳·寰宇清夷","kind":"词"},{"id":"c64-145","title":"眼儿媚·玉京曾忆惜繁华","kind":"词"},{"id":"c64-146","title":"燕山亭·裁翦冰绡","kind":"词"},{"id":"c64-147","title":"失调名·卷起珠帘","kind":"词"},{"id":"c64-148","title":"金莲绕凤楼·绛烛朱笼相随映","kind":"词"},{"id":"c64-149","title":"小重山·罗绮生香娇上春","kind":"词"}]},"赵崇嶓":{"slug":"赵崇嶓","name":"赵崇嶓","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"c73-294","title":"如梦令·日日酒围花阵","kind":"词"},{"id":"c73-295","title":"如梦令·窗外燕娇莺妒","kind":"词"},{"id":"c73-296","title":"更漏子·玉搔头","kind":"词"},{"id":"c73-297","title":"谒金门·春尚浅","kind":"词"},{"id":"c73-298","title":"谒金门·春意泄","kind":"词"},{"id":"c73-299","title":"谒金门·晴意早","kind":"词"},{"id":"c73-300","title":"谒金门·春意薄","kind":"词"},{"id":"c73-301","title":"清平乐·莺歌蝶舞","kind":"词"},{"id":"c73-302","title":"清平乐·妒红欺绿","kind":"词"},{"id":"c73-303","title":"南柯子・南歌子·丝发风轻掠","kind":"词"},{"id":"c73-304","title":"南柯子・南歌子·掩笑轻抬袖","kind":"词"},{"id":"c73-305","title":"望海潮·轻云过雨","kind":"词"},{"id":"c73-306","title":"沁园春·紫陌芳尘","kind":"词"},{"id":"c73-307","title":"摸鱼儿·卷珠帘","kind":"词"},{"id":"c73-308","title":"过秦楼·隐枕轻潮","kind":"词"},{"id":"c73-309","title":"归朝欢·翠羽低飞帘半揭","kind":"词"},{"id":"c73-310","title":"恋绣衾·江烟如雾水满汀","kind":"词"},{"id":"c73-311","title":"蝶恋花·一翦微寒禁翠袂","kind":"词"},{"id":"c73-312","title":"菩萨蛮·桃花相向东风笑","kind":"词"},{"id":"c73-313","title":"金明池·桂海云蒸","kind":"词"}]},"阎朝隐":{"slug":"阎朝隐","name":"阎朝隐","dynasty":"唐","style":"字友倩","life":"","origin":"","seal":"阎","bio":["阎朝隐，字友倩，赵州栾城人，连中进士、孝弟廉让科。性滑稽，属辞奇诡，为武后所赏，累迁给事中，预修《三教珠英》。圣历中，转麟台少监，坐附张易之徙岭外。","景龙时，还为著作郎。先天中，除秘书少监，后贬通州别驾。诗十三首。"],"works":[{"id":"t1-458","title":"相和歌辞 采莲女","kind":"诗"},{"id":"t1-598","title":"琴曲歌辞 明月歌","kind":"诗"},{"id":"t3-910","title":"侍从途中口号应制","kind":"诗"},{"id":"t3-911","title":"奉和圣制夏日游石淙山","kind":"诗"},{"id":"t3-912","title":"鹦鹉猫儿篇","kind":"诗"},{"id":"t3-913","title":"三日曲水侍宴应制","kind":"诗"},{"id":"t3-914","title":"奉和九日幸临渭亭登高应制得筵字","kind":"诗"},{"id":"t3-915","title":"奉和送金城公主适西蕃应制","kind":"诗"},{"id":"t3-916","title":"奉和立春游苑迎春应制","kind":"诗"},{"id":"t3-917","title":"奉和圣制春日幸望春宫应制","kind":"诗"},{"id":"t3-918","title":"夜宴安乐公主新宅","kind":"诗"},{"id":"t3-919","title":"饯唐永昌","kind":"诗"},{"id":"t3-920","title":"明月歌","kind":"诗"},{"id":"t3-921","title":"采莲女","kind":"诗"},{"id":"t3-922","title":"奉和登骊山应制","kind":"诗"},{"id":"t50-145","title":"度岭（二首。斯五五五） 一","kind":"诗"},{"id":"t50-146","title":"度岭（二首。斯五五五） 二","kind":"诗"}]},"陈致雍":{"slug":"陈致雍","name":"陈致雍","dynasty":"唐","style":"","life":"","origin":"","seal":"陈","bio":["陈致雍，莆田人。初仕闽为太常卿。复入南唐，以通礼及第，除秘书监。","未几，致仕归，陈洪进辟为掌书记。撰《曲台奏议》二十卷等。（《十国春秋》卷九七本传）"],"works":[{"id":"t55-843","title":"补迎神奏永和之舞九变第二奏","kind":"诗"}]},"陈诩":{"slug":"陈诩","name":"陈诩","dynasty":"唐","style":"","life":"","origin":"","seal":"陈","bio":[],"works":[{"id":"t53-156","title":"无题","kind":"诗"},{"id":"t53-157","title":"新雷","kind":"诗"}]},"黄童":{"slug":"黄童","name":"黄童","dynasty":"宋","style":"","life":"","origin":"","seal":"黄","bio":[],"works":[{"id":"c66-56","title":"卜算子·不忍更回头","kind":"词"}]},"齐己":{"slug":"齐己","name":"齐己","dynasty":"唐","style":"号衡岳沙门","life":"","origin":"","seal":"齐","bio":["齐己，名得生，姓胡氏，潭之益阳人。出家大沩山同庆寺，复栖衡岳东林。后欲入蜀，经江陵，高从诲留为僧正，居之龙兴寺，自号衡岳沙门。","《白莲集》十卷，外编一卷，今编诗十卷。齐己，名得生，姓胡氏，潭之益阳人。出家大沩山同庆寺，复栖衡岳东林。","后欲入蜀，经江陵，高从诲留为僧正，居之龙兴寺，自号衡岳沙门。白莲集十卷，外编一卷，今编诗十卷。"],"works":[{"id":"t46-274","title":"夏日草堂作","kind":"诗"},{"id":"t46-275","title":"寄镜湖方干处士","kind":"诗"},{"id":"t46-276","title":"送人归吴","kind":"诗"},{"id":"t46-277","title":"赠仰上人","kind":"诗"},{"id":"t46-278","title":"夜坐","kind":"诗"},{"id":"t46-279","title":"新栽松","kind":"诗"},{"id":"t46-280","title":"期友人","kind":"诗"},{"id":"t46-281","title":"和郑谷郎中看棋","kind":"诗"},{"id":"t46-282","title":"寄钱塘罗给事","kind":"诗"},{"id":"t46-283","title":"戊辰岁湘中寄郑谷郎中","kind":"诗"},{"id":"t46-284","title":"寓言","kind":"诗"},{"id":"t46-285","title":"寄王振拾遗","kind":"诗"},{"id":"t46-286","title":"经贾岛旧居","kind":"诗"},{"id":"t46-287","title":"送人游塞","kind":"诗"},{"id":"t46-288","title":"桃花","kind":"诗"},{"id":"t46-289","title":"闻鴈","kind":"诗"},{"id":"t46-290","title":"送人游南","kind":"诗"},{"id":"t46-291","title":"送益公归旧居","kind":"诗"},{"id":"t46-292","title":"不睡","k