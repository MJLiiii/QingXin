{"云台峰五女仙":{"slug":"云台峰五女仙","name":"云台峰五女仙","dynasty":"唐","style":"","life":"","origin":"","seal":"云","bio":[],"works":[{"id":"t47-850","title":"会真诗 一","kind":"诗"},{"id":"t47-851","title":"会真诗 二","kind":"诗"},{"id":"t47-852","title":"会真诗 三","kind":"诗"},{"id":"t47-853","title":"会真诗 四","kind":"诗"},{"id":"t47-854","title":"会真诗 五","kind":"诗"}]},"卞震":{"slug":"卞震","name":"卞震","dynasty":"唐","style":"","life":"","origin":"","seal":"卞","bio":["卞震，成都人。蜀进士，为渝州判。蜀平，入宋，仍旧职。","补句二。"],"works":[{"id":"t43-730","title":"句","kind":"诗"},{"id":"t50-991","title":"句（《吟窗杂录》卷三一《历代吟谱》引此二句，题作《秋夕诗》。）","kind":"诗"},{"id":"t56-285","title":"忆鹳诗","kind":"诗"},{"id":"t56-286","title":"途中诗","kind":"诗"},{"id":"t56-287","title":"寄陈抟诗","kind":"诗"},{"id":"t56-288","title":"东郊诗","kind":"诗"}]},"厉元范":{"slug":"厉元范","name":"厉元范","dynasty":"宋","style":"","life":"","origin":"","seal":"厉","bio":[],"works":[{"id":"c70-860","title":"失调名·叶叶柳眉齐抹翠","kind":"词"}]},"史远道":{"slug":"史远道","name":"史远道","dynasty":"宋","style":"","life":"","origin":"","seal":"史","bio":[],"works":[{"id":"c64-501","title":"独脚令・忆王孙·墙头梅蕊一枝新","kind":"词"}]},"崔常侍":{"slug":"崔常侍","name":"崔常侍","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":[],"works":[{"id":"t47-995","title":"官坡馆联句","kind":"诗"}]},"张崇杰":{"slug":"张崇杰","name":"张崇杰","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["崇杰，贞元间青州临淄县令。（《全唐诗》无张崇杰诗）"],"works":[{"id":"t53-150","title":"龙池（题拟）","kind":"诗"}]},"归登":{"slug":"归登","name":"归登","dynasty":"唐","style":"字冲之","life":"","origin":"","seal":"归","bio":["归登，字冲之，吴县人，崇敬之子。贞元初，策贤良，为右拾遗，转右补阙、起居舍人。顺宗为皇太子，登父子侍读，及即位，以东宫恩，拜给事中，迁工部侍郎。","复为皇太子诸王侍读，累进工部尚书。卒，谥曰宪。诗一首。"],"works":[{"id":"t0-754","title":"郊庙歌辞 享惠昭太子庙乐章 请神","kind":"诗"},{"id":"t16-856","title":"享惠昭太子庙乐章","kind":"诗"}]},"李正辞":{"slug":"李正辞","name":"李正辞","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李正辞，贞元八年进士第。宪宗时，自拾遗转补阙。诗一首。"],"works":[{"id":"t17-147","title":"赋得白云起封中","kind":"诗"}]},"杨发":{"slug":"杨发","name":"杨发","dynasty":"唐","style":"字至之","life":"","origin":"","seal":"杨","bio":["杨发，字至之，冯翊人。以父遗直客苏州，因家焉。登太和四年进士第，历太常少卿，出为苏州刺史，即其乡里也。","后为岭南节度使，以严为治，军乱，贬婺州刺史。诗十三首。"],"works":[{"id":"t28-61","title":"南溪书院","kind":"诗"},{"id":"t28-62","title":"春园醉醒闲卧小斋","kind":"诗"},{"id":"t28-63","title":"小园秋兴","kind":"诗"},{"id":"t28-64","title":"与诸公池上待月","kind":"诗"},{"id":"t28-65","title":"簷雀","kind":"诗"},{"id":"t28-66","title":"残花","kind":"诗"},{"id":"t28-67","title":"山泉","kind":"诗"},{"id":"t28-68","title":"秋晚日少陵原游山泉之什","kind":"诗"},{"id":"t28-69","title":"秋晴独立南亭","kind":"诗"},{"id":"t28-70","title":"宿黄花馆","kind":"诗"},{"id":"t28-71","title":"南野逢田客","kind":"诗"},{"id":"t28-72","title":"东斋夜宴酬绍之起居见赠","kind":"诗"},{"id":"t28-73","title":"玩残花","kind":"诗"},{"id":"t51-414","title":"和李卫公漳浦驿留题","kind":"诗"}]},"王位之":{"slug":"王位之","name":"王位之","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["位之，开元二十八年任滑州匡城县主簿。诗一首。（《全唐诗》无王位之诗）"],"works":[{"id":"t52-767","title":"无题","kind":"诗"},{"id":"t52-768","title":"五言晚泛灵溪之作","kind":"诗"}]},"王景中":{"slug":"王景中","name":"王景中","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"t43-263","title":"风草不留霜","kind":"诗"}]},"胡幼黄":{"slug":"胡幼黄","name":"胡幼黄","dynasty":"宋","style":"","life":"","origin":"","seal":"胡","bio":[],"works":[{"id":"c76-0","title":"水调歌头·有喜君初度","kind":"词"}]},"蔡隐丘":{"slug":"蔡隐丘","name":"蔡隐丘","dynasty":"唐","style":"","life":"","origin":"","seal":"蔡","bio":["蔡隐丘，曲阿人。缑氏主簿，善书。诗一首。"],"works":[{"id":"t5-517","title":"石桥琪树","kind":"诗"},{"id":"t5-518","title":"句","kind":"诗"},{"id":"t52-781","title":"句","kind":"诗"}]},"袁郊":{"slug":"袁郊","name":"袁郊","dynasty":"唐","style":"字之仪","life":"","origin":"","seal":"袁","bio":["袁郊，字之仪，朗山人，滋之子也。咸通时，为祠部郎中，昭宗朝，为翰林学士。诗四首。"],"works":[{"id":"t33-223","title":"月","kind":"诗"},{"id":"t33-224","title":"霜","kind":"诗"},{"id":"t33-225","title":"露","kind":"诗"},{"id":"t33-226","title":"云","kind":"诗"}]},"郑愚":{"slug":"郑愚","name":"郑愚","dynasty":"唐","style":"","life":"","origin":"","seal":"郑","bio":["郑愚，番禺人。咸通中，观察桂管，入为礼部侍郎。黄巢平后，出镇南海，终尚书左仆射。","诗二首。郑愚，番禺人，咸通中，观察桂管，入为礼部侍郎，黄巢平后，出镇南海，终尚书左仆射。诗二首。"],"works":[{"id":"t33-210","title":"幼作","kind":"诗"},{"id":"t33-211","title":"茶诗","kind":"诗"},{"id":"t48-276","title":"醉题广州使院","kind":"诗"},{"id":"t48-277","title":"拟权龙褒体赠鄠县李令及寄朝右","kind":"诗"},{"id":"t51-461","title":"泛石岐海","kind":"诗"}]},"陈若晦":{"slug":"陈若晦","name":"陈若晦","dynasty":"宋","style":"","life":"","origin":"","seal":"陈","bio":[],"works":[{"id":"c76-407","title":"满庭芳·五洞深沈","kind":"词"}]},"韦元旦":{"slug":"韦元旦","name":"韦元旦","dynasty":"唐","style":"字烜","life":"","origin":"","seal":"韦","bio":["韦元旦，京兆万年人。擢进士第，补东阿尉，迁左台监察御史。与张易之为姻属，易之败，贬感义尉。","后复进用，终中书舍人。诗十首。韦元旦字烜，京洮万年人。","垂拱中为美原县尉，官终中书舍人。补诗一首。"],"works":[{"id":"t3-923","title":"奉和九日幸临渭亭登高应制得月字","kind":"诗"},{"id":"t3-924","title":"奉和送金城公主适西蕃应制","kind":"诗"},{"id":"t3-925","title":"饯唐州高使君赴任","kind":"诗"},{"id":"t3-926","title":"早朝","kind":"诗"},{"id":"t3-927","title":"奉和立春游苑迎春应制","kind":"诗"},{"id":"t3-928","title":"奉和圣制春日幸望春宫应制","kind":"诗"},{"id":"t3-929","title":"奉和人日宴大明宫恩赐彩缕人胜应制","kind":"诗"},{"id":"t3-930","title":"奉和幸安乐公主山庄应制","kind":"诗"},{"id":"t3-931","title":"兴庆池侍宴应制","kind":"诗"},{"id":"t3-932","title":"夜宴安乐公主宅","kind":"诗"},{"id":"t50-509","title":"五言夏日游神泉诗（并序）","kind":"诗"},{"id":"t52-516","title":"五言奉和姚元崇相公过楼岩寺诗（题拟）","kind":"诗"}]},"齐光乂":{"slug":"齐光乂","name":"齐光乂","dynasty":"唐","style":"","life":"","origin":"","seal":"齐","bio":["齐。预定《礼记月令》，时为集贤直学士。天宝五载刻《删定月令表》，署为宣州司马。","十四载为宣州长史，终于秘书少监。诗一首。（《全唐诗》无齐光乂诗，传据《全唐文》卷三五四、《元和姓纂四校记》卷六、《新唐书·艺文志》一、《李太白全集》卷二八《赵公西侯新亭颂》。","）"],"works":[{"id":"t52-845","title":"无题","kind":"诗"},{"id":"t52-846","title":"送贺秘监归会稽诗","kind":"诗"}]}}