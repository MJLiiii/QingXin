{"叶元良":{"slug":"叶元良","name":"叶元良","dynasty":"唐","style":"","life":"","origin":"","seal":"叶","bio":[],"works":[{"id":"t43-305","title":"御制段太尉碑","kind":"诗"}]},"大义":{"slug":"大义","name":"大义","dynasty":"唐","style":"","life":"","origin":"","seal":"大","bio":["大义，俗姓徐，衢州须江县人。嗣马祖，在信州，时称鹅湖和尚。元和十三年卒，年七十四。","诗二首。（《全唐诗》无大义诗）"],"works":[{"id":"t53-430","title":"坐禅铭","kind":"诗"},{"id":"t53-431","title":"颂","kind":"诗"}]},"姜晞":{"slug":"姜晞","name":"姜晞","dynasty":"唐","style":"","life":"","origin":"","seal":"姜","bio":["姜晞，上邽人。登永隆元年进士第，官工部侍郎、散骑常侍，封金城郡公。诗一首。"],"works":[{"id":"t4-113","title":"龙池篇","kind":"诗"}]},"富嘉谟":{"slug":"富嘉谟","name":"富嘉谟","dynasty":"唐","style":"号为富吴体","life":"","origin":"","seal":"富","bio":["富嘉谟，雍州武功人，举进士。长安中，累官晋阳尉，预修《三教珠英》。中兴初，历左台御史，与吴少微友善，属词并以经典为本，文体一变，号为富吴体。","张说称其文如孤峰绝岸，壁立万仞，浓云郁兴，震雷俱发，诚可畏也。若施于廊庙，则骇矣。集十卷，今存诗一首。"],"works":[{"id":"t4-963","title":"明冰篇","kind":"诗"},{"id":"t52-511","title":"丽色赋附歌","kind":"诗"}]},"崔文邕":{"slug":"崔文邕","name":"崔文邕","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":["崔文邕，博陵人。开元中为梓州铜山县尉。诗一首。","（《全唐诗》无崔文邕诗）"],"works":[{"id":"t50-592","title":"千秋亭咏（并序）","kind":"诗"}]},"徐昌图":{"slug":"徐昌图","name":"徐昌图","dynasty":"唐","style":"","life":"","origin":"","seal":"徐","bio":["--莆田人。初仕闽、南唐，后归宋，任国子博士，官至殿中丞。词存三首，风格隽美。"],"works":[{"id":"t49-877","title":"木兰花","kind":"诗"},{"id":"t49-878","title":"临江仙","kind":"诗"},{"id":"t49-879","title":"河传","kind":"诗"}]},"晏几道":{"slug":"晏几道","name":"晏几道","dynasty":"宋","style":"字叔原 · 号小山","life":"","origin":"抚州临川（今江西抚州）","seal":"晏","bio":["(约 1040－约 1112) 字叔原，号小山，抚州临川 (今江西抚州) 人。晏殊第七子。曾监颍昌府许田镇。","一生仕途不利，家道中落，然个性耿介，不肯依傍权贵，文章亦自立规模。工令词，多追怀往昔欢娱之作，情调感伤，风格婉丽。有《小山词》传世。"],"works":[{"id":"c58-719","title":"临江仙·斗草阶前初见","kind":"词"},{"id":"c58-720","title":"临江仙·身外闲愁空满","kind":"词"},{"id":"c58-721","title":"临江仙·淡水三年欢意","kind":"词"},{"id":"c58-722","title":"临江仙·浅浅馀寒春半","kind":"词"},{"id":"c58-723","title":"临江仙·长爱碧阑干影","kind":"词"},{"id":"c58-724","title":"临江仙·旖旎仙花解语","kind":"词"},{"id":"c58-725","title":"临江仙·梦后楼台高锁","kind":"词"},{"id"