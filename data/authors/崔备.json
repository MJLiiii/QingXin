{"slug":"崔备","name":"崔备","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":["崔备，建中进士第，为西川节度使判官，终工部郎中。诗六首。"],"works":[{"id":"t17-96","title":"和武相公中秋锦楼玩月 一","kind":"诗"},{"id":"t17-97","title":"和武相公中秋锦楼玩月 二","kind":"诗"},{"id":"t17-98","title":"奉陪武相公西亭夜宴陆郎中","kind":"诗"},{"id":"t17-99","title":"清溪路中寄诸公","kind":"诗"},{"id":"t17-100","title":"奉酬中书相公至日圜丘行事合于中书宿直移止于集贤院叙情见寄之什","kind":"诗"},{"id":"t17-101","title":"使院忆山中道侣兼怀李约","kind":"诗"},{"id":"t53-454","title":"无题","kind":"诗"},{"id":"t53-455","title":"寄羊士谔永宁里居（题拟）","kind":"诗"}]}