{"slug":"李縠","name":"李縠","dynasty":"唐","style":"字德师","life":"","origin":"","seal":"李","bio":["李縠，字德师，咸通进士，唐末为浙东观察推官，兼殿中侍御史。诗四首。"],"works":[{"id":"t34-759","title":"浙东罢府西归酬别张广文皮先辈陆秀才","kind":"诗"},{"id":"t34-760","title":"和皮日休悼鸖 一","kind":"诗"},{"id":"t34-761","title":"和皮日休悼鸖 二","kind":"诗"},{"id":"t34-762","title":"醉中袭美先月中归","kind":"诗"}]}