[{"id":"c62-400","title":"武陵春·银浦流云初度月","rhythmic":"武陵春","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["银浦流云初度月，空碧挂团团。","照夜珠胎贝阙寒。","光彩满长安。","春风为拂新沙路，珂马款天关。","篆印金窠红屈盘。","嵬ㄝ押千官。"]},{"id":"c62-401","title":"玉楼春·今朝何以为公寿","rhythmic":"玉楼春","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["今朝何以为公寿。","极贵长年公素有。","庭阶不乏长芝兰，少翁又是廷臣右。","三能粲粲依魁秀。","八柱魏魏蟠地厚。","皇家卜册万斯年，年光长转洪钧手。"]},{"id":"c62-402","title":"玉楼春·我公两器兼文武","rhythmic":"玉楼春","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["我公两器兼文武。","谈笑岩廊无治古。","红颜绿发已官高，赤舄绣裳今仲父。","我欲形容无妙语。","颂穆清风须吉甫。","望公聊比泰山云，岁岁年年天下雨。"]},{"id":"c62-403","title":"玉楼春·压玉为浆麟作朒","rhythmic":"玉楼春","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["压玉为浆麟作朒。","珠树琼葩长不谢。","翠帘绣暖燕归来，宝鸭花香蜂上下。","沙堤佩马催公驾。","月白风清天不夜。","重来赫赫照岩廊，不动堂堂凝太华。"]},{"id":"c62-404","title":"秦楼月・忆秦娥·蔷薇折","rhythmic":"秦楼月・忆秦娥","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["蔷薇折。","一怀秀影花和月。","花和月。","著人浓似，粉香酥色。","绿阴垂幕帘波叠。","微风过竹凉吹发。","凉吹发。","无人分付，这些时节。"]},{"id":"c62-405","title":"遍地花·白玉阑边自凝伫","rhythmic":"遍地花","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["白玉阑边自凝伫。","满枝头、彩云雕雾。","甚芳菲、绣得成团，砌合出、韶华好处。","暖风前、一笑盈盈，吐檀心、向谁分付。","莫与他、西子精神，不枉了、东君雨露。"]},{"id":"c62-406","title":"夜游宫·长记劳君送远","rhythmic":"夜游宫","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["长记劳君送远。","柳烟重、桃花波暖。","花外溪城望不见。","古槐边，故人稀，秋鬓晚。","我有凌霄伴。","在何处、山寒云乱。","何不随君弄清浅。","见伊时，话阳春，山数点。"]},{"id":"c62-407","title":"诉衷情·花阴柳影映帘栊","rhythmic":"诉衷情","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["花阴柳影映帘栊。","罗幕绣重重。","行云自随语燕，回雪趁惊鸿。","银字歇，玉杯空。","蕙烟中。","桃花髻暖，杏叶眉弯，一片春风。"]},{"id":"c62-408","title":"诉衷情·短疏萦缘象床低","rhythmic":"诉衷情","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["短疏萦缘象床低。","玉鸭度香迟。","微云淡著河汉，凉过碧梧枝。","秋韵起，月阴移。","下帘时。","人间天上，一样风光，我与君知。"]},{"id":"c62-409","title":"醉花阴·檀板一声莺起速","rhythmic":"醉花阴","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["檀板一声莺起速。","山影穿疏木。","人在翠阴中，欲觅残春，春在屏风曲。","劝君对客杯须覆。","灯照瀛洲绿。","西去玉堂深，魄冷魂清，独引金莲烛。"]},{"id":"c62-410","title":"醉花阴·金叶犹温香未歇","rhythmic":"醉花阴","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["金叶犹温香未歇。","尘定歌初彻。","暖透薄罗衣，一霎清风，人映团团月。","持杯试听留春阕。","此个情肠别。","分付与莺莺，劝取东君，停待芳菲节。"]},{"id":"c62-411","title":"减字木兰花·暖风吹雪","rhythmic":"减字木兰花","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["暖风吹雪。","洗尽碧阶今夜月。","试觅云英。","更就蓝桥借月明。","从教不借。","自有使君家不夜。","谁道由天。","光景随人特地妍。"]},{"id":"c62-412","title":"减字木兰花·曾教风月","rhythmic":"减字木兰花","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["曾教风月。","催促花边烟棹发。","不管花开。","月白风清始肯来。","既来且住。","风月闲寻秋好处。","收取凄清。","暖日阑干助梦吟。"]},{"id":"c62-413","title":"减字木兰花·小桥秀绝","rhythmic":"减字木兰花","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["小桥秀绝。","露湿芙蕖花上月。","月下人人。","花样精神月样清。","谁言见惯。","到了司空情不慢。","丞相瞋无。","若不瞋时醉倩扶。"]},{"id":"c62-414","title":"上林春令・一落索·蝴蝶初翻帘绣","rhythmic":"上林春令・一落索","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["蝴蝶初翻帘绣。","万玉女、齐回舞袖。","落花飞絮濛濛，长忆著、灞桥别后。","浓香斗帐自永漏。","任满地、月深云厚。","夜寒不近流苏，祗怜他、后庭梅瘦。"]},{"id":"c62-415","title":"人娇·雪做屏风","rhythmic":"人娇","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["雪做屏风，花为行帐。","屏帐里、见春模样。","小晴未了，轻阴一饷。","酒到处、恰如把春拈上。","官柳黄轻，河堤绿涨。","花多处、少停兰桨。","雪边花际，平芜叠幛。","这一段、凄凉为谁怅望。"]},{"id":"c62-416","title":"人娇·短棹犹停","rhythmic":"人娇","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["短棹犹停，寸心先往。","说归期、唤做的当。","夕阳下地，重城远样。","风露冷、高楼误伊等望。","今夜孤村，月明怎向。","依还是、梦回绣幌。","远山想像。","秋波荡漾。","明夜里、与伊画著眉上。"]},{"id":"c62-417","title":"惜分飞·山转沙回江声小","rhythmic":"惜分飞","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["山转沙回江声小。","望尽冷烟衰草。","梦断瑶台晓。","楚云何处英英好。","古寺黄昏人悄悄。","帘卷寒堂月到。","不会思量了。","素光看尽桐阴少。"]},{"id":"c62-418","title":"惜分飞·泪湿阑干花著露","rhythmic":"惜分飞","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["泪湿阑干花著露。","愁到眉峰碧聚。","此恨平分取。","更无言语。","空相觑。","短雨残云无意绪。","寂寞朝朝暮暮。","今夜山深处。","断魂分付。","潮回去。"]},{"id":"c62-419","title":"惜分飞·花影低徊帘幕卷","rhythmic":"惜分飞","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["花影低徊帘幕卷。","惯了双来燕燕。","惊散雕阑晚。","雨昏烟重垂杨院。","云断月斜红烛短。","望断真个望断。","情寄梅花点。","趁风飞过楼南畔。"]},{"id":"c62-420","title":"惜分飞·恰则心头托托地","rhythmic":"惜分飞","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["恰则心头托托地。","放下了日多萦系。","别恨还容易。","袖痕犹有年时泪。","满满频斟乞求醉。","且要时闲忘记。","明日刘郎起。","马蹄去便三千里。"]},{"id":"c62-421","title":"蝶恋花·闻说君家传窈窕","rhythmic":"蝶恋花","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["闻说君家传窈窕。","秀色天真，更夺丹青妙。","细意端相都总好。","春愁春媚生颦笑。","琼玉胸前金凤小。","那得殷勤，细托琵琶道。","十二峰云遮醉倒。","华灯翠帐花相照。"]},{"id":"c62-422","title":"蝶恋花·江接寒溪家已近","rhythmic":"蝶恋花","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["江接寒溪家已近。","想见秋来，松菊荒三径。","目送吴山秋色尽。","星星却入双蓬鬓。","凫短鹤长真个定。","勋业来迟，不用频看镜。","懒出问人人不问。","绿尊倒尽横书枕。"]},{"id":"c62-423","title":"蝶恋花·相见江南情不少","rhythmic":"蝶恋花","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["相见江南情不少。","尔许多时，怪得无消耗。","淡日暖云句引到。","阑干寂寞怜春小。","宫面可忺匀画了。","粉瘦酥寒，一段天真好。","唤起玉儿娇睡觉。","半山残月南枝晓。"]},{"id":"c62-424","title":"蝶恋花·红杏梢头寒食雨","rhythmic":"蝶恋花","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["红杏梢头寒食雨。","燕子泥新，不住飞来去。","行傍柳阴闻好语。","莺儿穿过黄金缕。","桑落酒寒杯懒举。","总被多情，做得无情绪。","春过二分能几许。","银台新火重帘暮。"]},{"id":"c62-425","title":"蝶恋花·三叠阑干铺碧甃","rhythmic":"蝶恋花","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["三叠阑干铺碧甃。","小雨新晴，才过清明后。","初见花王披衮绣。","娇云瑞日明春昼。","彩女朝真天质秀。","宝髻微偏，风卷霞衣皱。","莫道东君情最厚。","韶光半在东堂手。"]},{"id":"c62-426","title":"蝶恋花·红影斑斑吹锦片","rhythmic":"蝶恋花","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["红影斑斑吹锦片。","露叶烟梢，寒月娟娟满。","更起绕庭行百遍。","无人祗有栖莺见。","觅个薄情心对换。","愁绪偏长，不信春宵短。","正是碧云音信断。","半衾犹赖香熏暖。"]},{"id":"c62-427","title":"蝶恋花·城上春云低阁雨","rhythmic":"蝶恋花","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["城上春云低阁雨。","渐觉春随，一片花飞去。","素颈圆吭莺燕语。","不妨缓缓歌金缕。","堕纪颓纲公已举。","但见清风，萧瑟随谈绪。","借寇假饶天不许。","未须忙遣韶华暮。"]},{"id":"c62-428","title":"蝶恋花·花里传觞飞羽过","rhythmic":"蝶恋花","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["花里传觞飞羽过。","渐觉金槽，月缺圆龙破。","素手转罗酥作颗。","鹅溪雪绢云腴堕。","七盏能醒千日卧。","扶起瑶山，嫌怕香尘涴。","醉色轻松留不可。","清风停待些时过。"]},{"id":"c62-429","title":"蝶恋花·不雨不晴秋气味","rhythmic":"蝶恋花","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["不雨不晴秋气味。","酒病秋怀，不做醒松地。","初换夹衣围翠被。","蔷薇水润衙香腻。","旋折秋英餐露蕊。","金缕虬团，更试康王水。","幽梦不来寻小睡。","无言划尽屏山翠。"]},{"id":"c62-430","title":"更漏子·玉狻猊","rhythmic":"更漏子","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["玉狻猊，金叶暖。","馥馥香云不断。","长下著，绣帘重。","怕随花信风。","傍蔷薇，摇露点。","衣润得香长远。","双枕凤，一衾鸾。","柳烟花雾间。"]},{"id":"c62-431","title":"更漏子·绿窗寒","rhythmic":"更漏子","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["绿窗寒，清漏短。","帐底沈香火暖。","残烛暗，小屏弯。","云峰遮梦还。","那些愁，推不去。","分付一檐寒雨。","檐外竹，试秋声。","空庭鹤唤人。"]},{"id":"c62-432","title":"更漏子·柳藏烟","rhythmic":"更漏子","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["柳藏烟，云漏日。","寒满雕盘玉食。","风卷旆，水摇天。","鱼龙挟彩船。","水边人，波面乐。","太守与民同乐。","春好处，总随轩。","花中谁状元。"]},{"id":"c62-433","title":"西江月·花下春藏五马","rhythmic":"西江月","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["花下春藏五马，松间风落双凫。","兵厨玉帐卷酃湖。","人醉碧云欲暮。","归去聊登文石，翱翔便是天衢。","雅歌谁解继投壶。","桃李无言满路。"]},{"id":"c62-434","title":"西江月·烟雨半藏杨柳","rhythmic":"西江月","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["烟雨半藏杨柳，风光初到桃花。","玉人细细酌流霞。","醉里将春留下。","柳畔鸳鸯作伴，花边蝴蝶为家。","醉翁醉里也随他。","月在柳桥花榭。"]},{"id":"c62-435","title":"西江月·雨后夹衣初冷","rhythmic":"西江月","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["雨后夹衣初冷，霜前细菊浑斑。","觚棱清月绣团环。","万里长安秋晚。","槽下内家玉滴，盘中江国金丸。","春容著面作微殷。","烛影红摇醉眼。"]},{"id":"c62-436","title":"西江月·席上芙蓉待暖","rhythmic":"西江月","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["席上芙蓉待暖，花间騕袅还嘶。","劝君不醉且无归。","归去因谁惜醉。","汤点瓶心未老，乳堆盏面初肥。","留连能得几多时。","两腋清风唤起。"]},{"id":"c62-437","title":"青玉案·芙蕖花上濛濛雨","rhythmic":"青玉案","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["芙蕖花上濛濛雨。","又冷落、池塘暮。","何处风来摇碧户。","卷帘凝望，淡烟疏柳，翡翠穿花去。","玉京人去无由驻。","恁独坐、凭阑处。","试问绿窗秋到否。","可人今夜，新凉一枕，无计相分付。"]},{"id":"c62-438","title":"青玉案·玉婴初有排云分","rhythmic":"青玉案","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["玉婴初有排云分。","向晚色、娟娟静。","秋入风枝清不尽。","月和粉露，徘徊孤映，独夜扶疏影。","子猷风调全相称。","是彼此、无凡韵。","玉勒前头花柳近。","水边石上，冷依烟雨，时有幽人问。"]},{"id":"c62-439","title":"青玉案·玉人为我殷勤醉","rhythmic":"青玉案","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["玉人为我殷勤醉。","向醉里、添姿媚。","偏著冠儿钗欲坠。","桃花气暖，露浓烟重，不自禁春意。","绿榆阴下东行水。","渐渐近、凄凉地。","明月侵床愁不睡。","眉儿吃皱，为谁无语，阁住阳关泪。"]},{"id":"c62-440","title":"青玉案·今宵月好来同看","rhythmic":"青玉案","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["今宵月好来同看。","月未落、人还散。","把手留连帘儿畔。","含羞和恨转娇盼。","恁花映春风面。","相思不用宽金钏。","也不用、多情似玉燕。","问取婵娟学长远。","不必清光夜夜见。","但莫负、团圆愿。"]},{"id":"c62-441","title":"河满子·急雨初收珠点","rhythmic":"河满子","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["急雨初收珠点。","云峰巉绝天半。","辘轳金井卷甘冽，帘外翠阴遮遍。","波翻水精重帘，秋在琉璃双簟。","漏永流花缓缓。","未放崦嵫晼晚。","红荷绿芰暮天好，小宴水亭风馆。","云乱香喷宝鸭，月冷钗横玉燕。"]},{"id":"c62-442","title":"谒金门·灯雾里","rhythmic":"谒金门","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["灯雾里。","老去昔游不记。","月似旧时人不似。","小楼何处是。","归卧晚香翠被。","玉酒著人小醉。","欲睡先来都不睡。","此情那恁地。"]},{"id":"c62-443","title":"七娘子·山屏雾帐玲珑碧","rhythmic":"七娘子","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["山屏雾帐玲珑碧。","更绮窗、临水新凉入。","雨短烟长，柳桥萧瑟。","这番一日凉一日。","离多绿鬓多时白。","这离情、不似而今惜。","云外长安，斜晖脉脉。","西风吹梦来无迹。"]},{"id":"c62-444","title":"七娘子·月光波影寒相向","rhythmic":"七娘子","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["月光波影寒相向。","借团团、与做长壕样。","此老南楼，风流可想。","殷勤冰彩随人上。","欲同次道倾家酿。","有兵厨、玉盎金波涨。","云外归鸿，烟中飞桨。","五湖秋兴心先往。"]},{"id":"c62-445","title":"雨中花・夜行船·寒浸东倾不定","rhythmic":"雨中花・夜行船","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["寒浸东倾不定。","更奈橹声催紧。","堤树胧明孤月上，暗淡移船影。","旧事十年愁未醒。","渐老可禁离恨。","今夜谁知风露里，目断云空尽。"]},{"id":"c62-446","title":"雨中花・夜行船·池上山寒欲雾","rhythmic":"雨中花・夜行船","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["池上山寒欲雾。","竹暗小窗低户。","数点秋声侵短梦，檐下芭蕉雨。","白酒浮蛆鸡啄黍。","问陶令、几时归去。","溪月岭云红蓼岸，总是思量处。"]},{"id":"c62-447","title":"夜行船·寒满一衾谁共","rhythmic":"夜行船","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["寒满一衾谁共。","夜沈沈、醉魂朦鬆。","雨呼烟唤付凄凉，又不成、那些好梦。","明日烟江□暝曚。","扁舟系、一行螮蝀。","季鹰生事水弥漫，过鲈船、再三目送。"]},{"id":"c62-448","title":"夜行船·弄水馀英溪畔","rhythmic":"夜行船","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["弄水馀英溪畔。","绮罗香、日迟风慢。","桃花春浸一篙深，画桥东、柳低烟远。","涨绿流红空满眼。","倚兰桡、旧愁无限。","莫把鸳鸯惊飞去，要歌时、少低檀板。"]},{"id":"c62-449","title":"鹊桥仙·红摧绿锉","rhythmic":"鹊桥仙","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["红摧绿锉，莺愁蝶怨，满院落花风紧。","醉乡好梦恰瞢腾，又冷落、一成吹醒。","柔红不耐，暗香犹好，觑著翻成不忍。","春心减尽眼长闲，更肯被、游丝牵引。"]},{"id":"c62-450","title":"鹊桥仙·水精帘外","rhythmic":"鹊桥仙","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["水精帘外，沈香阑畔，新下红油画幕。","百花何处避芳尘，便独自、将春占却。","月华淡淡，夜寒森森，犹把红灯照著。","醉时从醉不归家，贤守定、不教冷落。"]},{"id":"c62-451","title":"烛影摇红·一亩清阴","rhythmic":"烛影摇红","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["一亩清阴，半天潇洒松窗午。","床头秋色小屏山，碧帐垂烟缕。","枕畔风摇绿户。","唤人醒、不教梦去。","可怜恰到，瘦石寒泉，冷云幽处。"]},{"id":"c62-452","title":"烛影摇红·老景萧条","rhythmic":"烛影摇红","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["老景萧条，送君归去添凄断。","赠君明月满前溪，直到西湖畔。","门掩绿苔应遍。","为黄花、频开醉眼。","橘奴无恙，蝶子相迎，寒窗日短。"]},{"id":"c62-453","title":"烛影摇红·鬓绿飘萧","rhythmic":"烛影摇红","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["鬓绿飘萧，漫郎已是青云晚。","古槐阴外小阑干，不负看山眼。","此意悠悠无限。","有云山、知人醉懒。","他年寻我，水边月底，一蓑烟短。"]},{"id":"c62-454","title":"忆秦娥·醉醉","rhythmic":"忆秦娥","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["醉醉。","醉击珊瑚碎。","花花。","先借春光与酒家。","夜寒我醉谁扶我。","应抱瑶琴卧。","清清。","揽月吟风不用人。"]},{"id":"c62-455","title":"忆秦娥·夜夜","rhythmic":"忆秦娥","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["夜夜。","夜了花朝也。","连忙。","指点银瓶索酒尝。","明朝花落知多少。","莫把残红扫。","愁人。","一片花飞减却春。"]},{"id":"c62-456","title":"武陵春·城上落梅风料峭","rhythmic":"武陵春","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["城上落梅风料峭，寒馥逼清尊。","爽兴天教属使君。","雪意压歌云。","插帽殷罗金缕细，燕燕早随人。","留取笙歌直到明。","莲漏已催春。"]},{"id":"c62-457","title":"武陵春·风过冰檐环佩响","rhythmic":"武陵春","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["风过冰檐环佩响，宿雾在华茵。","剩落瑶花衬月明。","嫌怕有纤尘。","凤口衔灯金炫转，人醉觉寒轻。","但得清光解照人。","不负五更春。"]},{"id":"c62-458","title":"武陵春·春在前村梅雪里","rhythmic":"武陵春","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["春在前村梅雪里，一夜到千门。","玉佩琼琚下冷云。","银界见东君。","桃花髻暖双飞燕，金字巧宜春。","寂寞溪桥柳弄晴。","老也探花人。"]},{"id":"c62-459","title":"点绛唇·高柳横斜","rhythmic":"点绛唇","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["高柳横斜，冷光凌乱摇疏翠。","露荷珠缀。","但见鸳鸯睡。","□□□□，□□□□□。","□□□。","□□□□。","□□□□□。"]},{"id":"c62-460","title":"点绛唇·柏叶春醅","rhythmic":"点绛唇","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["柏叶春醅，为君亲酌玻璃盏。","玉箫牙管。","人意如春暖。","鬓绿长留，不使韶华晚。","春无限。","碧桃花畔。","笑看蓬莱浅。"]},{"id":"c62-461","title":"点绛唇·手抚归鸿","rhythmic":"点绛唇","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["手抚归鸿，坐临烟雨帘旌润。","气清天近。","云日温阑楯。","压玉浮金，一醉留青鬓。","风光胜。","淡妆人靓。","眉黛生秋晕。"]},{"id":"c62-462","title":"点绛唇·何处君家","rhythmic":"点绛唇","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["何处君家，蟠桃花下瑶池畔。","日迟烟暖。","占得春长远。","几见花开，一任年光换。","今年见。","明年重见。","春色如人面。"]},{"id":"c62-463","title":"点绛唇·秀岭寒青","rhythmic":"点绛唇","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["秀岭寒青，冷泉凌乱催秋意。","佩环声里。","无限真珠碎。","叹我平生，识尽闲滋味。","来闲地。","为君一醉。","万事浮云外。"]},{"id":"c62-464","title":"点绛唇·小院重帘","rhythmic":"点绛唇","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["小院重帘，那回来处花相向。","迟迟一饷。","记得春模样。","昨夜月明，应照芙蓉帐。","空凝望。","蜂劳蝶攘。","谁在花枝上。"]},{"id":"c62-465","title":"点绛唇·绣岭横秋","rhythmic":"点绛唇","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["绣岭横秋，玉螭吹暑迎凉气。","碧崖流水。","流入春葱指。","半倚朱弦，微亸连环珥。","通深意。","月明风细。","分付知音耳。"]},{"id":"c62-466","title":"如梦令·深苑重调弦管","rhythmic":"如梦令","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["深苑重调弦管。","不觉银台烛短。","相对有金波，天畔杯中都满。","人远。","人远。","醉倚阑干玉冷。"]},{"id":"c62-467","title":"玉楼春·当日岭头相见处","rhythmic":"玉楼春","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["当日岭头相见处。","玉骨冰肌元淡伫。","近来因甚要浓妆，不管满城桃杏妒。","酒晕脸霞春暗度。","认是东皇偏管顾。","生罗衣褪为谁羞，香冷熏炉都不觑。"]},{"id":"c62-468","title":"生查子·鲈蟹正肥时","rhythmic":"生查子","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["鲈蟹正肥时，烟雨新凉日。","露蕊郁金黄，云液蒲萄碧。","此日古为佳，此醉君宁惜。","高挂水精帘，尽放秋光入。"]},{"id":"c62-469","title":"生查子·日照小窗纱","rhythmic":"生查子","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["日照小窗纱，风动重帘绣。","宝炷暮云迷，曲沼晴漪皱。","烟暖柳醒松，雪尽梅清瘦。","恰是可怜时，好似花秾后。"]},{"id":"c62-470","title":"生查子·钗上燕犹寒","rhythmic":"生查子","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["钗上燕犹寒，胜里红偏小。","恰有尔多春，不许群花笑。","酒面粉酥融，香袖金泥罩。","芳意已潜通，残雪犹相照。"]},{"id":"c62-471","title":"生查子·春晚出山城","rhythmic":"生查子","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["春晚出山城，落日行江岸。","人不共潮来，香亦临风散。","花谢小妆残，莺困清歌断。","行雨梦魂消，飞絮心情乱。"]},{"id":"c62-472","title":"生查子·花地锦斑残","rhythmic":"生查子","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["花地锦斑残，月箔波凌乱。","斗鸭玉阑旁，扑兽金炉畔。","小醉奈春何，轻梦催云散。","却步蕙兰中，应被鸳鸯见。"]},{"id":"c62-473","title":"浪淘沙·深院绣帘垂","rhythmic":"浪淘沙","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["深院绣帘垂。","前日春归。","画桥杨柳弄烟霏。","池面东风先解冻，龟上涟漪。","酒潋玉东西。","香暖狻猊。","远山郁秀入双眉。","待看碧桃花烂漫，春日迟迟。"]},{"id":"c62-474","title":"菩萨蛮·玉卮细酌流霞湿","rhythmic":"菩萨蛮","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["玉卮细酌流霞湿。","金钗翠袖勤留客。","行色小梅残。","官桥杨柳寒。","赐环宣室夜。","看落金莲灺。","人记海听康。","流风秀水旁。"]},{"id":"c62-475","title":"菩萨蛮·端端正正人如月","rhythmic":"菩萨蛮","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["端端正正人如月。","孜孜媚媚花如颊。","花月不如人。","眉眉眼眼春。","沈香添小炷。","共挹熏炉语。","香解著人衣。","君心蝴蝶飞。"]},{"id":"c62-476","title":"菩萨蛮·含章檐下眉如月","rhythmic":"菩萨蛮","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["含章檐下眉如月。","融酥和粉描疏雪。","桃杏莫争春。","凌风台畔人。","如今千万树。","零乱孤村雨。","和雨滴瑶觞。","归来肌骨香。"]},{"id":"c62-477","title":"菩萨蛮·淡烟疏雨东篱晓","rhythmic":"菩萨蛮","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["淡烟疏雨东篱晓。","菊团凄露真珠小。","青蕊抱寒枝。","因谁特故迟。","曾是骚人盼。","羞做茱萸伴。","揉破郁金黄。","与君些子香。"]},{"id":"c62-478","title":"菩萨蛮·溪山不尽知多少","rhythmic":"菩萨蛮","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["溪山不尽知多少。","遥峰秀叠寒波渺。","携酒上高台。","与君开壮怀。","枉做悲秋赋。","醉后悲何处。","白发几黄花。","官裘付酒家。"]},{"id":"c62-479","title":"菩萨蛮·春潮曾送离魂去","rhythmic":"菩萨蛮","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["春潮曾送离魂去。","春山曾见伤离处。","老去不堪愁。","凭阑看水流。","东风留不住。","一夜檐前雨。","明日觅春痕。","红疏桃杏村。"]},{"id":"c62-480","title":"菩萨蛮·云山沁绿残眉浅","rhythmic":"菩萨蛮","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["云山沁绿残眉浅。","垂杨睡起腰肢软。","不见玉妆台。","飞花将梦来。","行云何事恶。","雨透罗衣薄。","不忍湿残春。","黄莺啼向人。"]},{"id":"c62-481","title":"菩萨蛮·当时学舞钧天部","rhythmic":"菩萨蛮","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["当时学舞钧天部。","惊鸿吹下江湖去。","家住百花桥。","何郎偏与娇。","杏梁尘拂面。","牙板闻莺燕。","劝客玉梨花。","月侵钗燕斜。"]},{"id":"c62-482","title":"渔家傲·年少莫寻潜玉老","rhythmic":"渔家傲","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["年少莫寻潜玉老。","无才无艺烦君笑。","暖过茅檐霜日晓。","休起早。","竹间尽日无人到。","别径小峰孤碧峭。","曲沟浅浸寒清绕。","此老相看情不少。","浑忘了。","浑教忘了长安道。"]},{"id":"c62-483","title":"渔家傲·恰则小庵贪睡著","rhythmic":"渔家傲","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["恰则小庵贪睡著。","不知风撼梅花落。","一点儿春吹去却。","香约略。","黄蜂犹抱红酥萼。","绕遍寒枝添索寞。","却穿竹径随孤鹤。","守定微官真个错。","从今莫。","从今莫负云山约。"]},{"id":"c62-484","title":"渔家傲·鬓底青春留不住","rhythmic":"渔家傲","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["鬓底青春留不住。","功名薄似风前絮。","何似瓮头春没数。","都占取。","只消一纸长门赋。","寒日半窗桑柘暮。","倚阑目送繁云去。","却欲载书寻旧路。","烟深处。","杏花菖叶耕春雨。"]},{"id":"c62-485","title":"于飞乐·水边山","rhythmic":"于飞乐","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["水边山，云畔水，新出烟林。","送秋来、双桧寒阴。","桧堂寒，香雾碧，帘箔清深。","放衙隐几，谁知共、云水无心。","望西园，飞盖夜，月到清尊。","为诗翁、露冷风清。","退红裙，云碧袖，花草争春。","劝翁强饮，莫孤负、风月留人。"]},{"id":"c62-486","title":"于飞乐·记瞢腾","rhythmic":"于飞乐","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["记瞢腾，浓睡里，一片行云。","未多时、梦破云惊。","听辘轳，声断也，井底银瓶。","不知罗带，等闲便、结得同心。","系画船，杨柳岸，晓月亭亭。","记阳关、断韵残声。","被西风，吹玉枕，酒魄还清。","有些言语，独自个、说与谁应。"]},{"id":"c62-487","title":"于飞乐·并梅兄","rhythmic":"于飞乐","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["并梅兄，双蝶子，烟缕衫轻。","凤凰钗、缭绕香云。","淡梳妆，□得恁，雪腻酥匀。","揉春捻就，更是他、花与精神。","黛尖低、桃萼破，微笑轻颦。","早做成、役梦劳魂。","好风前，佳月下，莫忘行人。","扁舟去也，没个事、多样离情。"]},{"id":"c62-488","title":"阮郎归·映阶芳草净无尘","rhythmic":"阮郎归","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["映阶芳草净无尘。","新晴隔柳阴。","绿丝步障碧茸茵。","遮藏欲尽春。","寒未了，酒须深。","残花无处寻。","年来陪尽惜春心。","闲愁渐不禁。"]},{"id":"c62-489","title":"阮郎归·雨馀烟草弄春柔","rhythmic":"阮郎归","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["雨馀烟草弄春柔。","芳郊翠欲流。","暖风时转柳花球。","晴光烂不收。","红尽处，绿新稠。","秾华只暂留。","却应留下等闲愁。","令人双鬓秋。"]},{"id":"c62-490","title":"虞美人·游人莫笑东园小","rhythmic":"虞美人","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["游人莫笑东园小。","莫问花多少。","一枝半朵恼人肠。","无限姿姿媚媚、倚斜阳。","二分春去知何处。","赖是无风雨。","更将绣幕密遮花。","任是东风急性、不由他。"]},{"id":"c62-491","title":"虞美人·百花赶定东君去","rhythmic":"虞美人","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["百花赶定东君去。","知与花何处。","阳春但更买花栽。","留住蜂儿蝶子、等君来。","翠轻绿嫩庭阴好。","醉便眠芳草。","春波如酒不曾空。","谁见东堂日日、自春风。"]},{"id":"c62-492","title":"虞美人·柳枝却学腰肢袅","rhythmic":"虞美人","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["柳枝却学腰肢袅。","好似江东小。","春风吹绿上眉峰。","秀色欲流不断、眼波融。","檐前月上灯花堕。","风递馀香过。","小欢云散已难收。","到处冷烟寒雨、为君愁。"]},{"id":"c62-493","title":"一落索·月下风前花畔","rhythmic":"一落索","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["月下风前花畔。","此情不浅。","欲留风月守花枝，却不道、而今远。","樯外鹭飞沙晚。","烟斜雨短。","青山祗管一重重，向东下、遮人眼。"]},{"id":"c62-494","title":"散馀霞·墙头花□寒犹噤","rhythmic":"散馀霞","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["墙头花□寒犹噤。","放绣帘昼静。","帘外时有蜂儿，趁杨花不定。","阑干又还独凭。","念翠低眉晕。","春梦枉恼人肠，更厌厌酒病。"]},{"id":"c62-495","title":"最高楼·微雨过","rhythmic":"最高楼","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["微雨过，深院芰荷中。","香冉冉，绣重重。","玉人共倚阑干角，月华犹在小池东。","入人怀，吹鬓影，可怜风。","分散去、轻如云与梦，剩下了、许多风与月，侵枕簟，冷帘栊。","副能小睡还惊觉，略成轻醉早醒松。","仗行云，将此恨，到眉峰。"]},{"id":"c62-496","title":"最高楼·新睡起","rhythmic":"最高楼","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["新睡起，熏过绣罗衣。","梳洗了，百般宜。","东风淡荡垂杨院，一春心事有谁知。","苦留人，娇不尽，曲眉低。","漫良夜、月圆空好意，恐落花、流水终寄恨，悲欢往往相随。","凤台痴望双双羽，高唐愁著梦回时。","又争如，遵大路，合逢伊。"]},{"id":"c62-497","title":"少年游·遥山雪气入疏帘","rhythmic":"少年游","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["遥山雪气入疏帘。","罗幕晓寒添。","爱日腾波，朝霞入户，一线过冰檐。","绿尊香嫩蒲萄暖，满酌破冬严。","庭下早梅，已含芳意，春近瘦枝南。"]},{"id":"c62-498","title":"粉蝶儿·雪遍梅花","rhythmic":"粉蝶儿","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["雪遍梅花，素光都共奇绝。","到窗前、认君时节。","下重帏，香篆冷，兰膏明灭。","梦悠扬，空绕断云残月。","沈郎带宽，同心放开重结。","褪罗衣、楚腰一捻。","正春风，新著摸，花花叶叶。","粉蝶儿，这回共花同活。"]},{"id":"c62-499","title":"调笑・调笑令·城月","rhythmic":"调笑・调笑令","author":"毛滂","authorSlug":"毛滂","dynasty":"宋","kind":"ci","paragraphs":["城月。","冷罗袜。","郎睡不知鸾帐揭。","香凄翠被灯明灭。","花困钗横时节。","河桥杨柳催行色。","愁黛有人描得。"]}]