":"拟寒山 六","kind":"诗"},{"id":"t55-450","title":"拟寒山 七","kind":"诗"},{"id":"t55-451","title":"拟寒山 八","kind":"诗"},{"id":"t55-452","title":"拟寒山 九","kind":"诗"},{"id":"t55-453","title":"拟寒山 十","kind":"诗"}]},"玉真":{"slug":"玉真","name":"玉真","dynasty":"宋","style":"","life":"","origin":"","seal":"玉","bio":[],"works":[{"id":"c61-115","title":"杨柳枝·已谢芳华更不留","kind":"词"}]},"王叡":{"slug":"王叡","name":"王叡","dynasty":"唐","style":"号炙毂子","life":"","origin":"","seal":"王","bio":["王叡，元和后诗人，自号炙毂子。集五卷，今存诗九首。"],"works":[{"id":"t1-31","title":"相和歌辞 公无渡河","kind":"诗"},{"id":"t1-402","title":"相和歌辞 祠神歌 迎神","kind":"诗"},{"id":"t1-403","title":"相和歌辞 祠神歌 送神","kind":"诗"},{"id":"t27-193","title":"公无渡河","kind":"诗"},{"id":"t27-194","title":"松","kind":"诗"},{"id":"t27-195","title":"竹","kind":"诗"},{"id":"t27-196","title":"解昭君怨","kind":"诗"},{"id":"t27-197","title":"祠渔山神女歌二首 一","kind":"诗"},{"id":"t27-198","title":"祠渔山神女歌二首 二","kind":"诗"},{"id":"t27-199","title":"牡丹","kind":"诗"},{"id":"t27-200","title":"秋","kind":"诗"},{"id":"t27-201","title":"燕","kind":"诗"}]},"袁朗":{"slug":"袁朗","name":"袁朗","dynasty":"唐","style":"字诗","life":"","origin":"","seal":"袁","bio":["袁朗，雍州长安人，勤学，好属文，在陈释褐秘书郎，甚为江总所重。尝制千字诗，当时以为盛作。后主召入禁中，使为《月赋》，染翰立成，迁太子洗马。","仕隋，为仪曹郎。入唐，授齐王文学，转给事中。贞观初卒，太宗称其谨厚，悼惜之。","集十四卷，今存诗四首。"],"works":[{"id":"t1-245","title":"相和歌辞 饮马长城窟行","kind":"诗"},{"id":"t2-412","title":"赋饮马长城窟","kind":"诗"},{"id":"t2-413","title":"和洗掾登城南坂望京邑","kind":"诗"},{"id":"t2-414","title":"秋日应诏","kind":"诗"},{"id":"t2-415","title":"秋夜独坐","kind":"诗"}]},"裴航":{"slug":"裴航","name":"裴航","dynasty":"唐","style":"","life":"","origin":"","seal":"裴","bio":["裴航，长庆中进士。"],"works":[{"id":"t47-712","title":"赠樊夫人诗","kind":"诗"},{"id":"t47-713","title":"樊夫人荅裴航","kind":"诗"}]},"赵子发":{"slug":"赵子发","name":"赵子发","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"c62-688","title":"鹧鸪天·约略应飞白玉盘","kind":"词"},{"id":"c62-689","title":"洞仙歌·荒山明月","kind":"词"},{"id":"c62-690","title":"桃源忆故人·芳菲已有东风露","kind":"词"},{"id":"c62-691","title":"浣溪沙·疏荫摇摇趁岸移","kind":"词"},{"id":"c62-692","title":"南歌子·天末疑无路","kind":"词"},{"id":"c62-693","title":"南歌子·人有纫兰佩","kind":"词"},{"id":"c62-694","title":"点绛唇·野岸孤舟","kind":"词"},{"id":"c62-695","title":"虞美人·飞云流水来无信","kind":"词"},{"id":"c62-696","title":"惜分飞·数点雨声惊残暑","kind":"词"},{"id":"c62-697","title":"阮郎归·马蹄踏月响空山","kind":"词"},{"id":"c62-698","title":"忆王孙·日长高柳一蝉声","kind":"词"},{"id":"c62-699","title":"杨柳枝·淅淅西风生暮寒","kind":"词"},{"id":"c62-700","title":"望江南・忆江南·新梦断","kind":"词"},{"id":"c62-701","title":"菩萨蛮·闲庭草色侵阶绿","kind":"词"},{"id":"c62-702","title":"少年游·晓山日薄半春阴","kind":"词"},{"id":"c62-703","title":"采桑子·春蚕昨夜眠方起","kind":"词"},{"id":"c62-704","title":"浪淘沙·约素小腰身","kind":"词"}]},"连妙淑":{"slug":"连妙淑","name":"连妙淑","dynasty":"宋","style":"","life":"","origin":"","seal":"连","bio":[],"works":[{"id":"c75-652","title":"望江南・忆江南·寒料峭","kind":"词"}]},"韦夏卿":{"slug":"韦夏卿","name":"韦夏卿","dynasty":"唐","style":"字云客","life":"","origin":"","seal":"韦","bio":["韦夏卿，字云客，京兆万年人。大历中，与弟正卿同举贤良方正高等，授高陵主簿，累迁刑部员外郎，擢给事中，出为常、苏二州刺史。徐州节度使张建封辟为徐泗行军司马，俄召为吏部侍郎，进检校工部尚书、东都留守，改太子少保。","诗三首。"],"works":[{"id":"t14-365","title":"别张贾","kind":"诗"},{"id":"t14-366","title":"送顾况归茅山","kind":"诗"},{"id":"t14-367","title":"和丘员外题湛长史旧居","kind":"诗"}]},"韩屿":{"slug":"韩屿","name":"韩屿","dynasty":"唐","style":"","life":"","origin":"","seal":"韩","bio":["韩屿，祠部郎中。诗一首。"],"works":[{"id":"t42-905","title":"赠进士李守微","kind":"诗"}]}}