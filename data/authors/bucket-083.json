"c63-655","title":"感皇恩·花院小回廊","kind":"词"},{"id":"c63-656","title":"感皇恩·密竹翦轻绡","kind":"词"},{"id":"c63-657","title":"小重山·鞭凤骖鸾自斗杓","kind":"词"},{"id":"c63-658","title":"小重山·星斗心胸锦绣肠","kind":"词"},{"id":"c63-659","title":"花心动·红日当楼","kind":"词"},{"id":"c63-660","title":"渔家傲·海角秋高风力骤","kind":"词"}]},"栖岩":{"slug":"栖岩","name":"栖岩","dynasty":"唐","style":"","life":"","origin":"","seal":"栖","bio":[],"works":[{"id":"t51-812","title":"题祝融峰（句）","kind":"诗"}]},"毕干泰":{"slug":"毕干泰","name":"毕干泰","dynasty":"唐","style":"","life":"","origin":"","seal":"毕","bio":["毕干泰，景龙时人。诗一首。"],"works":[{"id":"t5-311","title":"奉和九月九日登慈恩寺浮图应制","kind":"诗"}]},"江直木":{"slug":"江直木","name":"江直木","dynasty":"唐","style":"字子建","life":"","origin":"","seal":"江","bio":["江直木，字子建，寻阳人。江梦孙之姪。七觪以神童擢第，后家居二十五年。","仕南唐为太常寺奉礼郎，转江都县主簿，历任江夏、黄梅令，累迁至水部员外郎。开宝三年随使留宋，历任泰宁节度判官、司门员外郎、兵部员外郎。太平兴国五年卒，年六十四。","有集二十卷，不存。存诗二句。（《全唐诗》无江直木诗）"],"works":[{"id":"t55-489","title":"丙寅岁与徐铉同赋（题拟）","kind":"诗"}]},"王湾":{"slug":"王湾","name":"王湾","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王湾，洛阳人，登先天进士第。开元初，为荥阳主簿。马怀素请校正群籍，召学涉之士，分部譔次，湾在选，中秘书罢譔。","又与陆绍伯等同校丽正院书，终洛阳尉。湾词翰早著，其“海日生残夜，江春入旧年”之句，当时称最。张说手题于政事堂，每示能文，令为楷式。","诗十首。"],"works":[{"id":"t5-563","title":"奉使登终南山","kind":"诗"},{"id":"t5-564","title":"晚夏马嵬卿叔池亭即事寄京都一二知己","kind":"诗"},{"id":"t5-565","title":"丽正殿赐宴同勒天前烟年四韵应制","kind":"诗"},{"id":"t5-566","title":"奉和贺监林月清酌","kind":"诗"},{"id":"t5-567","title":"次北固山下","kind":"诗"},{"id":"t5-568","title":"观搊筝","kind":"诗"},{"id":"t5-569","title":"晚春诣苏州敬赠武员外","kind":"诗"},{"id":"t5-570","title":"秋夜寓直即事怀赠萧令公裴侍郎兼通简南省诸友人","kind":"诗"},{"id":"t5-571","title":"哭补阙亡友綦毋学士","kind":"诗"},{"id":"t5-572","title":"闰月七日织女","kind":"诗"},{"id":"t5-573","title":"句","kind":"诗"}]},"王驾":{"slug":"王驾","name":"王驾","dynasty":"唐","style":"字大用 · 号守素先生","life":"","origin":"","seal":"王","bio":["王驾，字大用，河中人。大顺元年登进士第，仕至礼部员外郎，自号守素先生。集六卷，今存诗六首。","王驾，字大用，河中人。大顺元年登进士第，仕至礼部员外郎。自号守素先生。","集六卷，今存诗六首。"],"works":[{"id":"t38-674","title":"夏雨","kind":"诗"},{"id":"t38-675","title":"古意","kind":"诗"},{"id":"t38-676","title":"社日","kind":"诗"},{"id":"t38-677","title":"雨晴","kind":"诗"},{"id":"t38-678","title":"乱后曲江","kind":"诗"},{"id":"t38-679","title":"过故友居","kind":"诗"},{"id":"t48-941","title":"次韵和卢先辈避难寺居看牡丹","kind":"诗"},{"id":"t51-535","title":"永和县上巳","kind":"诗"}]},"畅诸":{"slug":"畅诸","name":"畅诸","dynasty":"唐","style":"","life":"","origin":"","seal":"畅","bio":[],"works":[{"id":"t15-537","title":"早春","kind":"诗"},{"id":"t50-203","title":"登观鹊楼（伯三六一九）","kind":"诗"}]},"解叔禄":{"slug":"解叔禄","name":"解叔禄","dynasty":"唐","style":"","life":"","origin":"","seal":"解","bio":[],"works":[{"id":"t50-41","title":"句","kind":"诗"}]},"轩辕伟":{"slug":"轩辕伟","name":"轩辕伟","dynasty":"唐","style":"","life":"","origin":"","seal":"轩","bio":["轩辕伟，建中贞元间人，与吉逾同时。诗一首。（《全唐诗》无轩辕伟诗）"],"works":[{"id":"t50-636","title":"无题","kind":"诗"},{"id":"t50-637","title":"题云居上寺","kind":"诗"}]},"韩缜":{"slug":"韩缜","name":"韩缜","dynasty":"宋","style":"字玉汝","life":"","origin":"其先真定灵寿（今属河北）","seal":"韩","bio":["--(1019－1097) 字玉汝。其先真定灵寿 (今属河北) 人，雍丘 (今河南县)。庆历二年 (1042) 进士。","累官知枢密院事、尚书右仆射、兼中书侍郎，出知颍昌府。以太子太保致仕。卒谥庄敏。","存词一首。"],"works":[{"id":"c58-631","title":"凤箫吟・芳草·锁离愁","kind":"词"}]},"高观国":{"slug":"高观国","name":"高观国","dynasty":"宋","style":"字宾王","life":"","origin":"山阴（今浙江绍兴）","seal":"高","bio":["--字宾王，山阴 (今浙江绍兴) 人。与史达祖同时，常相唱和。张炎将他和姜夔、吴文英、史达祖并称。","《古今词话》称其词“工而入逸，婉而多风”。有《竹屋痴语》传世。"],"works":[{"id":"c63-977","title":"浣溪沙·魂是湘云骨是兰","kind":"词"},{"id":"c63-978","title":"浣溪沙·偷得韩香惜未烧","kind":"词"},{"id":"c63-979","title":"浣溪沙·云外峰峦翠欲埋","kind":"词"},{"id":"c63-980","title":"浣溪沙·一色烟云澹不消","kind":"词"},{"id":"c63-981","title":"兰陵王·凤箫咽","kind":"词"},{"id":"c63-982","title":"兰陵王·洒虚阁","kind":"词"},{"id":"c63-983","title":"水龙吟·旧家心绪如云","kind":"词"},{"id":"c63-984","title":"水龙吟·道山玉府真仙","kind":"词"},{"id":"c63-985","title":"水龙吟·夜来曾跨青虬","kind":"词"},{"id":"c63-986","title":"声声慢·壶天不夜","kind":"词"},{"id":"c63-987","title":"隔浦莲・隔浦莲近拍·银湾初霁暮雨","kind":"词"},{"id":"c63-988","title":"思佳客·入手西风意已羞","kind":"词"},{"id":"c63-989","title":"思佳客·写出梨花雨后晴","kind":"词"},{"id":"c63-990","title":"思佳客·有约湖山却解