{"于瓌":{"slug":"于瓌","name":"于瓌","dynasty":"唐","style":"字正德","life":"","origin":"","seal":"于","bio":["于瓌，字正德，敖之子，大中七年进士第一人。诗二首。"],"works":[{"id":"t31-370","title":"和绵州于中丞登越王楼作二首 一","kind":"诗"},{"id":"t31-371","title":"和绵州于中丞登越王楼作二首 二","kind":"诗"}]},"何千里":{"slug":"何千里","name":"何千里","dynasty":"唐","style":"","life":"","origin":"","seal":"何","bio":["千里，开元十二年以奉天尉充宇文融劝农判官，又历任监察御史、殿中侍御史并内供奉。诗一首。（《全唐诗》无何千里诗，传据《唐会要》卷八五、《御史台精舍题名考》卷二）"],"works":[{"id":"t52-820","title":"送贺秘监归会稽诗","kind":"诗"}]},"刘清之":{"slug":"刘清之","name":"刘清之","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c61-120","title":"青玉案·江南十月春风早","kind":"词"},{"id":"c76-435","title":"鹧鸪天·柳色青青罩翠烟","kind":"词"}]},"卢照隣":{"slug":"卢照隣","name":"卢照隣","dynasty":"唐","style":"字升之","life":"","origin":"","seal":"卢","bio":["卢照邻，字升之，范阳人。十岁，从曹宪、王义方授苍雅，调邓王府典签，王有书十二车，照邻总披览，略能记忆，王爱重，比之相如，调新都尉。染风疾，去官，居太白山，以服饵为事，又客东龙门山，疾甚，足挛，一手又废，乃去阳翟具茨山下，买园数十亩，疎颍水周舍，复卧其中。","后不堪其苦，与亲属诀，自投颍水死，年四十。尝著五悲文以自明，有集二十卷，又幽忧子三卷，今编诗二卷。"],"works":[{"id":"t48-785","title":"凌晨","kind":"诗"}]},"周弘亮":{"slug":"周弘亮","name":"周弘亮","dynasty":"唐","style":"","life":"","origin":"","seal":"周","bio":["周弘亮，登贞元进士第。诗三首。"],"works":[{"id":"t24-921","title":"除夜书情","kind":"诗"},{"id":"t24-922","title":"曲江亭望慈恩寺杏园花发","kind":"诗"},{"id":"t24-923","title":"故乡除夜","kind":"诗"}]},"张盈润":{"slug":"张盈润","name":"张盈润","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张盈润，后汉干祐二年任节度押衙。诗一首。（《全唐诗》无张盈润诗）"],"works":[{"id":"t55-247","title":"题敦煌千龛窟（题拟）","kind":"诗"}]},"彭泰翁":{"slug":"彭泰翁","name":"彭泰翁","dynasty":"宋","style":"","life":"","origin":"","seal":"彭","bio":[],"works":[{"id":"c76-516","title":"念奴娇·九华惊觉","kind":"词"},{"id":"c76-517","title":"忆旧游·玉环扶浅醉","kind":"词"},{"id":"c76-518","title":"拜星月慢·雾罥觚棱","kind":"词"}]},"慕容垂":{"slug":"慕容垂","name":"慕容垂","dynasty":"唐","style":"","life":"","origin":"","seal":"慕","bio":[],"works":[{"id":"t47-946","title":"冢上荅太宗","kind":"诗"}]},"慧超":{"slug":"慧超","name":"慧超","dynasty":"唐","style":"","life":"","origin":"","seal":"慧","bio":["慧超，新罗国僧人。开元中，曾远赴五天竺国，经我国唐提安西等地。诗二首。"],"works":[{"id":"t51-128","title":"逢汉使入蕃略题四韵","kind":"诗"},{"id":"t51-129","title":"冬日在吐火罗逢雪述怀","kind":"诗"},{"id":"t52-643","title":"摩诃罗国娑般檀寺述志（题拟）","kind":"诗"},{"id":"t52-644","title":"南天路言怀（题拟）","kind":"诗"},{"id":"t52-645","title":"哀求法汉僧（并序○题拟）","kind":"诗"}]},"文及翁":{"slug":"文及翁","name":"文及翁","dynasty":"宋","style":"字时学 · 号本心","life":"","origin":"绵州（今四川绵阳）","seal":"文","bio":["--字时学，一作时举，号本心，绵州 (今四川绵阳) 人，移居吴兴。宝元年 (1153) 进士。景定间，言公田事，有名朝野。","官至试尚书礼部侍郎除签书枢密院事。宋亡，累征不起。有集，不传。","存词一首。"],"works":[{"id":"c74-666","title":"贺新郎·一勺西湖水","kind":"词"},{"id":"c74-667","title":"失调名·朗吟飞过","kind":"词"}]},"智常":{"slug":"智常","name":"智常","dynasty":"唐","style":"号赤眼归宗和尚","life":"","origin":"","seal":"智","bio":["智常，信州贵溪人。嗣慧能。诗一首。","（《全唐诗》无智常诗） 智常，嗣马祖，在江州归宗寺，时号赤眼归宗和尚。白居易在江州，尝与游。又曾与江州刺史李渤讨论佛理。","诗二首。（《全唐诗》无智常诗，传据《祖堂集》卷十五、《景德传灯录》卷七）"],"works":[{"id":"t52-618","title":"偈","kind":"诗"},{"id":"t53-637","title":"万卷赞","kind":"诗"},{"id":"t53-638","title":"偈 一","kind":"诗"},{"id":"t53-639","title":"偈 二","kind":"诗"}]},"曹文姬":{"slug":"曹文姬","name":"曹文姬","dynasty":"唐","style":"","life":"","origin":"","seal":"曹","bio":[],"works":[{"id":"t44-90","title":"句","kind":"诗"}]},"曾":{"slug":"曾","name":"曾","dynasty":"宋","style":"","life":"","origin":"","seal":"曾","bio":[],"works":[{"id":"c64-243","title":"浣溪沙·别样清芬扑鼻来","kind":"词"},{"id":"c64-244","title":"调笑令·佳友","kind":"词"},{"id":"c64-245","title":"调笑・调笑令·清友","kind":"词"},{"id":"c64-246","title":"调笑・调笑令·净友","kind":"词"},{"id":"c64-247","title":"调笑・调笑令·玉友","kind":"词"},{"id":"c64-248","title":"调笑・调笑令·花好","kind":"词"},{"id":"c64-249","title":"调笑・调笑令·酒美","kind":"词"},{"id":"c64-250","title":"临江仙·子后寅前东向坐","kind":"词"},{"id":"c65-263","title":"朝中措·幽芳独秀在山林","kind":"词"},{"id":"c65-264","title":"朝中措·绿华居处渺云深","kind":"词"},{"id":"c65-265","title":"念奴娇·绣衣直指","kind":"词"},{"id":"c65-267","title":"浣溪沙·无数春山展画屏","kind":"词"},{"id":"c65-268","title":"点绛唇·九月传杯","kind":"词"},{"id":"c78-334","title":"水龙吟·去年看月诗成","kind":"词"}]},"曾弼":{"slug":"曾弼","name":"曾弼","dynasty":"唐","style":"","life":"","origin":"","seal":"曾","bio":["弼，长沙人，依逸人王元为诗友。"],"works":[{"id":"t51-787","title":"宿玉泉寺（句）","kind":"诗"},{"id":"t51-788","title":"君山（句）","kind":"诗"}]},"李斌":{"slug":"李斌","name":"李斌","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t56-308","title":"大桐军行","kind":"诗"},{"id":"t56-309","title":"剑歌 一","kind":"诗"},{"id":"t56-310","title":"剑歌 二","kind":"诗"},{"id":"t56-311","title":"日南王","kind":"诗"},{"id":"t56-312","title":"秋渡颍水","kind":"诗"}]},"梁陟":{"slug":"梁陟","name":"梁陟","dynasty":"唐","style":"","life":"","origin":"","seal":"梁","bio":[],"works":[{"id":"t43-238","title":"送孙舍人归湘州","kind":"诗"}]},"楚娘":{"slug":"楚娘","name":"楚娘","dynasty":"宋","style":"","life":"","origin":"","seal":"楚","bio":[],"works":[{"id":"c61-64","title":"生查子·去年梅雪天","kind":"词"}]},"法琳":{"slug":"法琳","name":"法琳","dynasty":"唐","style":"","life":"","origin":"","seal":"法","bio":["法琳，姓陈，颍川人，寓居襄阳。少出家，住荆州青溪山玉泉寺。游猎儒释，博通内外词旨。","隋季入关，舍僧服归俗。武德初复为僧，住京师济法寺。贞观初移住龙田寺。","十三年冬，因谤讪罪下狱，陈书自诉，诏不加罪，勅移于益郡僧舍。次年六月，行至百牢关因疾而卒，年六十九。著作甚多，传世有《破邪论》、《辨正论》等。","诗五首。（《全唐诗》无法琳诗。事迹据《续高僧传》卷二四本传、《开元释教录》卷八本传及《法琳别传》。","）"],"works":[{"id":"t51-990","title":"别毛明素","kind":"诗"},{"id":"t51-991","title":"勅放迁益部临行赋诗（题拟）","kind":"诗"},{"id":"t51-992","title":"辞诀友人诗（题拟）","kind":"诗"},{"id":"t51-993","title":"言志","kind":"诗"},{"id":"t51-994","title":"青溪野老诗（题从《续古文苑》卷四）","kind":"诗"}]},"潘良贵":{"slug":"潘良贵","name":"潘良贵","dynasty":"宋","style":"","life":"","origin":"","seal":"潘","bio":[],"works":[{"id":"c65-235","title":"满庭芳·夹水松篁","kind":"词"}]},"熊上达":{"slug":"熊上达","name":"熊上达","dynasty":"宋","style":"","life":"","origin":"","seal":"熊","bio":[],"works":[{"id":"c69-741","title":"万年欢·春管方中","kind":"词"}]},"独孤绶":{"slug":"独孤绶","name":"独孤绶","dynasty":"唐","style":"","life":"","origin":"","seal":"独","bio":["仲子陵，峨眉人，大历中登第，历官常侍。诗一首。"],"works":[{"id":"t15-75","title":"投珠于泉","kind":"诗"},{"id":"t15-76","title":"秦镜","kind":"诗"}]},"王謩":{"slug":"王謩","name":"王謩","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王謩，大中时人，