seal":"释","bio":["释玄宗（清刻本作元宗），俗姓吴氏，永嘉人。唐开耀二年生。少时出家于本部永定山宝寿院。","得戒后诸方游学，谒江陵朗禅师。复至寿州紫金山留行禅观。大历二年卒，年八十六。","诗二首。（《全唐诗》无玄宗诗，传据《宋高僧传》卷二十）"],"works":[{"id":"t52-937","title":"题石门","kind":"诗"},{"id":"t52-938","title":"题石门洞","kind":"诗"}]},"陈文弼":{"slug":"陈文弼","name":"陈文弼","dynasty":"唐","style":"字处仁","life":"","origin":"","seal":"陈","bio":["文弼，字处仁，有诗三百篇行于世，今存一首。（《全唐诗》无陈文弼诗）"],"works":[{"id":"t56-385","title":"咏海潮诗","kind":"诗"}]},"韬光":{"slug":"韬光","name":"韬光","dynasty":"唐","style":"","life":"","origin":"","seal":"韬","bio":["韬光，蜀人。卓锡灵隐之巢沟坞，白居易守郡时，题其堂曰法安。诗一首。"],"works":[{"id":"t45-439","title":"谢白乐天招","kind":"诗"}]},"颜曹":{"slug":"颜曹","name":"颜曹","dynasty":"唐","style":"","life":"","origin":"","seal":"颜","bio":["颜曹，初唐人。诗一首。（详附按）"],"works":[{"id":"t52-491","title":"古意","kind":"诗"}]},"魏承班":{"slug":"魏承班","name":"魏承班","dynasty":"唐","style":"","life":"","origin":"","seal":"魏","bio":["--(约公元 930 年前后在世) 前蜀王建养子魏宏夫之子。宏夫赐姓王，易名宗弼，封齐王。承班为驸马都尉，官至太尉，《花间集》称魏太尉。","今有王国维辑《魏太尉词》一卷。"],"works":[{"id":"t49-512","title":"诉衷情 一","kind":"诗"},{"id":"t49-513","title":"诉衷情 二","kind":"诗"},{"id":"t49-514","title":"诉衷情 三","kind":"诗"},{"id":"t49-515","title":"诉衷情 四","kind":"诗"},{"id":"t49-516","title":"诉衷情 五","kind":"诗"},{"id":"t49-517","title":"生查子 一","kind":"诗"},{"id":"t49-518","title":"生查子 二","kind":"诗"},{"id":"t49-519","title":"生查子 三","kind":"诗"},{"id":"t49-520","title":"菩萨蛮 一","kind":"诗"},{"id":"t49-521","title":"菩萨蛮 二","kind":"诗"},{"id":"t49-522","title":"菩萨蛮 三","kind":"诗"},{"id":"t49-523","title":"渔歌子","kind":"诗"},{"id":"t49-524","title":"满宫花 一","kind":"诗"},{"id":"t49-525","title":"满宫花 二","kind":"诗"},{"id":"t49-526","title":"谒金门 一","kind":"诗"},{"id":"t49-527","title":"谒金门 二","kind":"诗"},{"id":"t49-528","title":"谒金门 三","kind":"诗"},{"id":"t49-529","title":"木兰花","kind":"诗"},{"id":"t49-530","title":"玉楼春 一","kind":"诗"},{"id":"t49-531","title":"玉楼春 二","kind":"诗"},{"id":"t49-532","title":"黄钟乐","kind":"诗"}]},"黄陵美人":{"slug":"黄陵美人","name":"黄陵美人","dynasty":"唐","style":"","life":"","origin":"","seal":"黄","bio":[],"wor