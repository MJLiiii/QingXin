{"元季川":{"slug":"元季川","name":"元季川","dynasty":"唐","style":"","life":"","origin":"","seal":"元","bio":["元季川，大历、贞元间诗人也，一云名融，元结弟。诗四首。"],"works":[{"id":"t13-540","title":"泉上雨后作","kind":"诗"},{"id":"t13-541","title":"登云中","kind":"诗"},{"id":"t13-542","title":"山中晓兴","kind":"诗"},{"id":"t13-543","title":"古远行","kind":"诗"}]},"元础":{"slug":"元础","name":"元础","dynasty":"唐","style":"","life":"","origin":"","seal":"元","bio":[],"works":[{"id":"t47-236","title":"逸句","kind":"诗"}]},"刘景翔":{"slug":"刘景翔","name":"刘景翔","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c76-503","title":"念奴娇·甚情幻化","kind":"词"},{"id":"c76-504","title":"小重山·山翠晴岚曲曲偎","kind":"词"},{"id":"c76-505","title":"玉楼春·可怜又误江南景","kind":"词"},{"id":"c76-506","title":"如梦令·独立荷汀烟渚","kind":"词"}]},"庾光先":{"slug":"庾光先","name":"庾光先","dynasty":"唐","style":"","life":"","origin":"","seal":"庾","bio":["庾光先，新野人，官至吏部侍郎。尝陷安禄山，不受伪署。诗一首。"],"works":[{"id":"t7-662","title":"奉和刘采访缙云南岭作","kind":"诗"}]},"张白":{"slug":"张白","name":"张白","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张白，衡州人。少应举不第，入道，常挑一铁葫芦，得钱便饮酒，自称白云子。忽一日死，葬武陵城西。","经半载，有鼎州官扬州勾当公事，遇于酒肆，同酌数日。众闻之，开验其棺，一空，有《武陵春色》诗三百首，今存其一。"],"works":[{"id":"t47-758","title":"武陵春色","kind":"诗"},{"id":"t47-759","title":"赠酒店崔氏","kind":"诗"},{"id":"t47-760","title":"哭陆先生","kind":"诗"}]},"昙靖":{"slug":"昙靖","name":"昙靖","dynasty":"唐","style":"","life":"","origin":"","seal":"昙","bio":["昙靖，元和初沙门。诗一首。（《全唐诗》无昙靖诗）"],"works":[{"id":"t53-390","title":"奉送日本国使空海上人橘秀才朝献后却还","kind":"诗"}]},"朱敦儒":{"slug":"朱敦儒","name":"朱敦儒","dynasty":"宋","style":"字希真 · 号岩壑","life":"","origin":"洛阳（今属河南）","seal":"朱","bio":["--(1081－1159) 字希真，号岩壑，洛阳 (今属河南) 人。早年隐居不仕。绍兴三年 (1133)，补右迪功郎。","五年 (1135)，赐同进士出身，为秘书省正字、擢兵部郎中，迁两浙东堤点刑狱。秦桧当国时，除鸿胪少卿。桧死，亦废。","晚居嘉禾。有《岩壑老人诗文》一卷，不传。又有词集《樵歌》三卷。","词风豪放旷达，语言清畅，多写隐逸生活。南渡后，间有感喟国事之作。"],"works":[{"id":"c63-208","title":"聒龙谣·肩拍洪崖","kind":"词"},{"id":"c63-209","title":"聒龙谣·凭月携箫","kind":"词"},{"id":"c63-210","title":"雨中花・夜行船·故国当年得意","kind":"词"},{"id":"c63-211","title":"水调歌头·当年五陵下","kind":