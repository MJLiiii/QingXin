{"slug":"崔峒","name":"崔峒","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":["崔峒，博陵人。登进士第，为拾遗，集贤学士，终于州刺史。《艺文传》云：“终右补阙，大历十才子之一也。","”诗一卷。"],"works":[{"id":"t15-809","title":"扬州选蒙相公赏判雪后呈上","kind":"诗"},{"id":"t15-810","title":"客舍书情寄赵中丞","kind":"诗"},{"id":"t15-811","title":"客舍有怀因呈诸在事","kind":"诗"},{"id":"t15-812","title":"书怀寄杨郭李王判官","kind":"诗"},{"id":"t15-813","title":"奉和给事寓直","kind":"诗"},{"id":"t15-814","title":"初入集贤院赠李献仁","kind":"诗"},{"id":"t15-815","title":"酬李补阙雨中寄赠","kind":"诗"},{"id":"t15-816","title":"初除拾遗酬丘二十二见寄","kind":"诗"},{"id":"t15-817","title":"刘展下判官相招以诗答之","kind":"诗"},{"id":"t15-818","title":"送侯山人赴会稽","kind":"诗"},{"id":"t15-819","title":"宿禅智寺上方演大师院","kind":"诗"},{"id":"t15-820","title":"题空山人石室","kind":"诗"},{"id":"t15-821","title":"登蒋山开善寺","kind":"诗"},{"id":"t15-822","title":"题崇福寺禅院","kind":"诗"},{"id":"t15-823","title":"秋晚送丹徒许明府赴上国因寄江南故人","kind":"诗"},{"id":"t15-824","title":"送薛仲方归扬州","kind":"诗"},{"id":"t15-825","title":"送韦员外还京","kind":"诗"},{"id":"t15-826","title":"润州送友人","kind":"诗"},{"id":"t15-827","title":"送张芬东归","kind":"诗"},{"id":"t15-828","title":"送苏修游上饶","kind":"诗"},{"id":"t15-829","title":"送陆明府之盱眙","kind":"诗"},{"id":"t15-830","title":"江南回逢赵曜因送任十一赴交城主簿","kind":"诗"},{"id":"t15-831","title":"送薛良史往越州谒从叔","kind":"诗"},{"id":"t15-832","title":"送丘二十二之苏州","kind":"诗"},{"id":"t15-833","title":"登润州芙蓉楼","kind":"诗"},{"id":"t15-834","title":"江上书怀","kind":"诗"},{"id":"t15-835","title":"春日忆姚氏外甥","kind":"诗"},{"id":"t15-836","title":"送真上人还兰若","kind":"诗"},{"id":"t15-837","title":"润州送师弟自江夏往台州","kind":"诗"},{"id":"t15-838","title":"送李道士归山","kind":"诗"},{"id":"t15-839","title":"宿江西窦主簿厅","kind":"诗"},{"id":"t15-840","title":"喜逢妻弟郑损因送入京","kind":"诗"},{"id":"t15-841","title":"咏门下画小松上元王杜三相公","kind":"诗"},{"id":"t15-842","title":"寄上礼部李侍郎","kind":"诗"},{"id":"t15-843","title":"书情寄上苏州韦使君兼呈吴县李明府","kind":"诗"},{"id":"t15-844","title":"题桐庐李明府官舍","kind":"诗"},{"id":"t15-845","title":"赠窦十九","kind":"诗"},{"id":"t15-846","title":"虔州见郑表新诗因以寄赠","kind":"诗"},{"id":"t15-847","title":"赠元秘书","kind