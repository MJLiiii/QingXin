{"于敖":{"slug":"于敖","name":"于敖","dynasty":"唐","style":"字蹈中","life":"","origin":"","seal":"于","bio":["于敖，字蹈中，江南人。登进士第，长庆中给事中。寻转工部侍郎，出为宣歙观察使，兼御史中丞。","诗一首。"],"works":[{"id":"t17-108","title":"闻莺","kind":"诗"}]},"冯著":{"slug":"冯著","name":"冯著","dynasty":"唐","style":"","life":"","origin":"","seal":"冯","bio":["冯著，韦应物同时人。尝受李广州署为录事，应物有诗以送其行。诗四首。"],"works":[{"id":"t10-568","title":"短歌行","kind":"诗"},{"id":"t10-569","title":"洛阳道","kind":"诗"},{"id":"t10-570","title":"行路难","kind":"诗"},{"id":"t10-571","title":"燕衔泥","kind":"诗"}]},"刘涧谷":{"slug":"刘涧谷","name":"刘涧谷","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c76-549","title":"西江月·淑质生当良月","kind":"词"}]},"周元范":{"slug":"周元范","name":"周元范","dynasty":"唐","style":"","life":"","origin":"","seal":"周","bio":["周元范，句曲人。诗一首。"],"works":[{"id":"t24-794","title":"和白太守拣贡橘","kind":"诗"},{"id":"t24-795","title":"句","kind":"诗"},{"id":"t49-975","title":"奉和白舍人游镜湖夜归","kind":"诗"},{"id":"t49-976","title":"句","kind":"诗"}]},"崔锜":{"slug":"崔锜","name":"崔锜","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":[],"works":[{"id":"t51-551","title":"岳阳悼贾岛（《全唐诗》七六八作安锜《题贾岛墓》，末一字「忡」，《鉴诫录》作「㤏」）（崔锜评事倅岳阳日，为诗悼贾岛。岳是，普州地名。今因创墓在岳阳山上，山下有岳阳池。○《鉴诫录》八《贾忤旨》）","kind":"诗"}]},"张文伏":{"slug":"张文伏","name":"张文伏","dynasty":"唐","style":"字德昭","life":"","origin":"","seal":"张","bio":["张文伏，原列「无世次」作者。清戚学标《三台诗录》卷一有其传云：「字德昭，仙居人。天成元年进士。","授淮东安抚司，移刺太原，称循吏第一，晋大中大夫，锡二品服。未几，归隐盂川。周显德间及宋初屡诏皆不起，年八十余卒。","」今移此。文伏，字德昭，仙居人。天成元年进士，授淮东安抚司，移刺太原，称循吏，晋大中大夫锡二品服。","未几归隐盂川。周显德及宋初屡诏皆不起，年八十余卒。补诗一首。","（《全唐诗续补遗》卷十九收文伏诗一首，无事迹）"],"works":[{"id":"t51-595","title":"无题","kind":"诗"},{"id":"t51-596","title":"苍岭","kind":"诗"},{"id":"t55-287","title":"柬范丞相质","kind":"诗"}]},"智寂":{"slug":"智寂","name":"智寂","dynasty":"唐","style":"","life":"","origin":"","seal":"智","bio":["智寂，嗣云门文偃。住韶州披云寺。诗一首。","（《全唐诗》无智寂诗）"],"works":[{"id":"t56-38","title":"偈","kind":"诗"}]},"曾揆":{"slug":"曾揆","name":"曾揆","dynasty":"宋","style":"","life":"","origin":"","seal":"曾","bio":[],"works":[{"id":"c71-647","title":"西江月·檐雨轻敲