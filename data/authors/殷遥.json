{"slug":"殷遥","name":"殷遥","dynasty":"唐","style":"","life":"","origin":"","seal":"殷","bio":["殷遥，句容人。天宝间，忠王府曹参军。诗五首。"],"works":[{"id":"t5-538","title":"塞上","kind":"诗"},{"id":"t5-539","title":"送友人下第归省","kind":"诗"},{"id":"t5-540","title":"送杜士瞻楚州觐省","kind":"诗"},{"id":"t5-541","title":"友人山亭","kind":"诗"},{"id":"t5-542","title":"春晚山行","kind":"诗"},{"id":"t49-949","title":"句","kind":"诗"}]}