{"严休复":{"slug":"严休复","name":"严休复","dynasty":"唐","style":"","life":"","origin":"","seal":"严","bio":["严休复，官散骑常侍，平卢节度使。诗二首。"],"works":[{"id":"t24-797","title":"唐昌观玉蘂花折有仙人游怅然成二绝 一","kind":"诗"},{"id":"t24-798","title":"唐昌观玉蘂花折有仙人游怅然成二绝 二","kind":"诗"},{"id":"t53-613","title":"与于驸马","kind":"诗"}]},"刘德秀":{"slug":"刘德秀","name":"刘德秀","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c68-628","title":"贺新郎·雨沐秋荣薄","kind":"词"}]},"卢景亮":{"slug":"卢景亮","name":"卢景亮","dynasty":"唐","style":"字长晦","life":"","origin":"","seal":"卢","bio":["卢景亮，字长晦，范阳人。少孤，力学，善属文。德宗时，历右补阙，鲠毅无所回，贬斥二十年，至元和初，召还，再迁中书舍人。","诗一首。"],"works":[{"id":"t25-256","title":"寒夜闻霜钟","kind":"诗"}]},"孟简":{"slug":"孟简","name":"孟简","dynasty":"唐","style":"字几道","life":"","origin":"","seal":"孟","bio":["孟简，字几道，德州人，举进士、宏词，皆及第。元和中，累官至户部侍郎，坐事因贬吉州司马。诗七首。"],"works":[{"id":"t0-757","title":"郊庙歌辞 享惠昭太子庙乐章 送文舞出迎武舞入","kind":"诗"},{"id":"t25-262","title":"享惠昭太子庙乐章","kind":"诗"},{"id":"t25-263","title":"拟古","kind":"诗"},{"id":"t25-264","title":"咏欧阳行周事","kind":"诗"},{"id":"t25-265","title":"惜分阴","kind":"诗"},{"id":"t25-266","title":"嘉禾合颖","kind":"诗"},{"id":"t25-267","title":"赋得亚父碎玉斗","kind":"诗"},{"id":"t25-268","title":"酬施先辈","kind":"诗"},{"id":"t53-472","title":"白乌呈瑞赋附歌","kind":"诗"},{"id":"t53-473","title":"谒禹庙","kind":"诗"}]},"守安":{"slug":"守安","name":"守安","dynasty":"唐","style":"","life":"","origin":"","seal":"守","bio":["守安，嗣漳州桂琛禅师。初住江州悟空院，后住衡岳南台。诗一首。","（《全唐诗》无守安诗）"],"works":[{"id":"t55-944","title":"颂","kind":"诗"}]},"张循之":{"slug":"张循之","name":"张循之","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张循之，洛阳人，与弟仲之并以学业著名。则天时，上书忤旨，被诛。诗六首。"],"works":[{"id":"t0-865","title":"鼓吹曲辞 巫山高","kind":"诗"},{"id":"t5-179","title":"巫山高","kind":"诗"},{"id":"t5-180","title":"送泉州李使君之任","kind":"诗"},{"id":"t5-181","title":"长门怨","kind":"诗"},{"id":"t5-182","title":"巫山","kind":"诗"},{"id":"t5-183","title":"送王汶宰江阴","kind":"诗"},{"id":"t5-184","title":"婺州留别邓使君","kind":"诗"}]},"张锡":{"slug":"张锡","name":"张锡","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张锡，武城人，文琮子。则天时为凤阁侍郎同平章事，请还庐陵王，坐流循州。韦后临朝，复相。","旬日，出刺绛州。诗二首。"],"works":[{"id":"t5-319","title":"奉和九月九日登慈恩寺浮图应制","kind":"诗"},{"id":"t5-320","title":"晦日宴高文学林亭","kind":"诗"}]},"张𫖮":{"slug":"张𫖮","name":"张𫖮","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"t43-725","title":"句","kind":"诗"}]},"彭城":{"slug":"彭城","name":"彭城","dynasty":"唐","style":"","life":"","origin":"","seal":"彭","bio":["城，大和初为内供奉侍御。（《全唐诗》无彭城诗）"],"works":[{"id":"t53-500","title":"同观察使张公仲方大和元年夏祷雨归至圣泉寺作","kind":"诗"}]},"朱褒":{"slug":"朱褒","name":"朱褒","dynasty":"唐","style":"","life":"","origin":"","seal":"朱","bio":["朱褒，永嘉人，善属诗文。值寇乱，据州，以同姓结援梁太祖，奏授温州刺史，充静海军使。诗一首。"],"works":[{"id":"t41-208","title":"悼杨氏妓琴弦","kind":"诗"}]},"李善夷":{"slug":"李善夷","name":"李善夷","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李善夷，与李群玉同时，谪宦沣阳，《江南集》十卷。今存诗二首。"],"works":[{"id":"t31-349","title":"责汉水辞","kind":"诗"},{"id":"t31-350","title":"大隄曲","kind":"诗"}]},"李序":{"slug":"李序","name":"李序","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"t47-903","title":"笑巫诗","kind":"诗"}]},"牛凤及":{"slug":"牛凤及","name":"牛凤及","dynasty":"唐","style":"","life":"","origin":"","seal":"牛","bio":["牛凤及，长寿中撰《唐书》，刘轲与马植论史官书，尝称之。诗一首。"],"works":[{"id":"t5-209","title":"奉和受图温洛应制","kind":"诗"}]},"王延彬":{"slug":"王延彬","name":"王延彬","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王延彬，闽王审知弟审邽之子，官节度使。时中原人士杨承休、郑璘、韩偓、归传懿、杨赞图、郑戬等皆避乱入闽，依审邽，审邽振赋以财，遣延彬作招贤馆礼焉。诗二首。"],"works":[{"id":"t42-634","title":"春日寓感","kind":"诗"},{"id":"t42-635","title":"哭徐夤","kind":"诗"},{"id":"t55-791","title":"赠泉州宏则和尚（题拟）","kind":"诗"},{"id":"t55-792","title":"上长庆和尚偈（题拟）","kind":"诗"}]},"萧东父":{"slug":"萧东父","name":"萧东父","dynasty":"宋","style":"","life":"","origin":"","seal":"萧","bio":[],"works":[{"id":"c76-464","title":"齐天乐·扇鸾收影惊秋晚","kind":"词"}]},"薛琼":{"slug":"薛琼","name":"薛琼","dynasty":"唐","style":"","life":"","origin":"","seal":"薛","bio":[],"works":[{"id":"t44-73","title":"赋荆门","kind":"诗"}]},"费时举":{