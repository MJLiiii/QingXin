{"孔纾":{"slug":"孔纾","name":"孔纾","dynasty":"唐","style":"字持卿","life":"","origin":"","seal":"孔","bio":["孔纾，字持卿，孔子四十代孙。咸通九年进士，官至左拾遗。咸通十五年卒，年三十三。","诗一首。（《全唐诗》无孔纾诗）"],"works":[{"id":"t54-94","title":"临终前月余作隐语（题拟）","kind":"诗"}]},"孙欣":{"slug":"孙欣","name":"孙欣","dynasty":"唐","style":"","life":"","origin":"","seal":"孙","bio":["孙欣，开宝间人。诗一首。"],"works":[{"id":"t10-39","title":"奉试冷井诗","kind":"诗"}]},"孙舣":{"slug":"孙舣","name":"孙舣","dynasty":"宋","style":"","life":"","origin":"","seal":"孙","bio":[],"works":[{"id":"c64-737","title":"菩萨蛮·一声羌管吹呜咽","kind":"词"}]},"孟彦深":{"slug":"孟彦深","name":"孟彦深","dynasty":"唐","style":"字士源","life":"","origin":"","seal":"孟","bio":["孟彦深，字士源，登天宝二年进士第，为武昌令。元结居樊上，[尝]常作《退谷铭》曰：“干进之客，不得游之。”又作《杯湖铭》曰：“为人厌者，勿泛杯湖。","”孟士源尝黜官，无情干进。在武昌，不为人厌，可游退谷，可泛杯湖矣。诗一首。"],"works":[{"id":"t9-510","title":"元次山居武昌之樊山新春大雪以诗问之","kind":"诗"}]},"廖莹中":{"slug":"廖莹中","name":"廖莹中","dynasty":"宋","style":"","life":"","origin":"","seal":"廖","bio":[],"works":[{"id":"c75-525","title":"木兰花慢·请诸君著眼","kind":"词"},{"id":"c75-526","title":"个侬·恨个侬无赖","kind":"词"}]},"朱藻":{"slug":"朱藻","name":"朱藻","dynasty":"宋","style":"","life":"","origin":"","seal":"朱","bio":[],"works":[{"id":"c71-759","title":"采桑子·障泥油壁人归后","kind":"词"}]},"李居仁":{"slug":"李居仁","name":"李居仁","dynasty":"宋","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"c76-46","title":"天香·瀛峤浮烟","kind":"词"},{"id":"c76-47","title":"水龙吟·蕊仙群拥宸游","kind":"词"}]},"江油令":{"slug":"江油令","name":"江油令","dynasty":"唐","style":"","life":"","origin":"","seal":"江","bio":["江油令，姓名不详，约为开元前期人。诗一首又二句。（《全唐诗》无江油令诗）"],"works":[{"id":"t52-633","title":"咏江上溺死女子（题拟）","kind":"诗"},{"id":"t52-634","title":"赋山火诗","kind":"诗"}]},"江满昌":{"slug":"江满昌","name":"江满昌","dynasty":"唐","style":"","life":"","origin":"","seal":"江","bio":["江满昌，曾任特进行门下侍郎兼镇西员外都督。诗一首。（《全唐诗》无江满昌诗）"],"works":[{"id":"t52-175","title":"大唐大慈恩寺大师画赞","kind":"诗"}]},"王贞白":{"slug":"王贞白","name":"王贞白","dynasty":"唐","style":"字有道","life":"","origin":"","seal":"王","bio":["王贞白，字有道，永丰人。干宁二年张贻宪榜进士。后七年，始授校书郎。","尝与罗隐、方干、贯休同倡和。有《灵溪集》七卷，今编诗一卷。王贞白，字有道，永丰人。","干宁二年张贻宪榜进士。后七年，始授校书郎。尝与罗隐、方干、贯休同倡和。","有灵溪集七卷，今编诗一卷。王贞白字有道，永丰人。干宁二年张贻宪榜进士。","补诗十二首。"],"works":[{"id":"t1-643","title":"杂曲歌辞 妾薄命","kind":"诗"},{"id":"t39-407","title":"拟塞外征行","kind":"诗"},{"id":"t39-408","title":"芦苇","kind":"诗"},{"id":"t39-409","title":"田舍曲","kind":"诗"},{"id":"t39-410","title":"妾薄命","kind":"诗"},{"id":"t39-411","title":"湘妃怨","kind":"诗"},{"id":"t39-412","title":"长门怨二首 一","kind":"诗"},{"id":"t39-413","title":"长门怨二首 二","kind":"诗"},{"id":"t39-414","title":"有所思","kind":"诗"},{"id":"t39-415","title":"短歌","kind":"诗"},{"id":"t39-416","title":"御沟水","kind":"诗"},{"id":"t39-417","title":"少年行二首 一","kind":"诗"},{"id":"t39-418","title":"少年行二首 二","kind":"诗"},{"id":"t39-419","title":"塞上曲","kind":"诗"},{"id":"t39-420","title":"长安道","kind":"诗"},{"id":"t39-421","title":"洛阳道","kind":"诗"},{"id":"t39-422","title":"度关山","kind":"诗"},{"id":"t39-423","title":"出自蓟北门行","kind":"诗"},{"id":"t39-424","title":"从军行","kind":"诗"},{"id":"t39-425","title":"古悔从军行","kind":"诗"},{"id":"t39-426","title":"胡笳曲","kind":"诗"},{"id":"t39-427","title":"入塞","kind":"诗"},{"id":"t39-428","title":"游僊","kind":"诗"},{"id":"t39-429","title":"歌","kind":"诗"},{"id":"t39-430","title":"经故洛城","kind":"诗"},{"id":"t39-431","title":"金陵","kind":"诗"},{"id":"t39-432","title":"金陵怀古","kind":"诗"},{"id":"t39-433","title":"商山","kind":"诗"},{"id":"t39-434","title":"庐山","kind":"诗"},{"id":"t39-435","title":"终南山","kind":"诗"},{"id":"t39-436","title":"寄郑谷","kind":"诗"},{"id":"t39-437","title":"题严陵钓台","kind":"诗"},{"id":"t39-438","title":"晓泊汉阳渡","kind":"诗"},{"id":"t39-439","title":"随计","kind":"诗"},{"id":"t39-440","title":"白牡丹","kind":"诗"},{"id":"t39-441","title":"述松","kind":"诗"},{"id":"t39-442","title":"宫池产瑞莲","kind":"诗"},{"id":"t39-443","title":"送友人南归","kind":"诗"},{"id":"t39-444","title":"送马明府归山","kind":"诗"},{"id":"t39-445","title":"送韩从事归本道","kind":"诗"},{"id":"t39-446","title":"秋日旅怀寄右省郑拾遗","kind":"诗"},{"id":"t39-447","title":"赠刘凝评事","kind":"诗"},{"id":"t39-448","title":"忆张处士","kind":"诗"},{"id":"t39-449","title":"云居长老","kind":"诗"},{"id":"t39-450","title":"洗竹","kind":"诗"},{"id":"t39-451","title":"庾楼晓望","kind":"诗"},{"id":"t39-452","title":"送芮尊师","kind":"诗"},{"id":"t39-453","title":"折杨柳三首 一","kind":"诗"},{"id":"t39-454","title":"折杨柳三首 二","kind":"诗"},{"id":"t39-455","title":"折杨柳三首 三","kind":"诗"}]},"肃宗皇帝":{"slug":"肃宗皇帝","name":"肃宗皇帝","dynasty":"唐","style":"","life":"","origin":"","seal":"肃","bio":["帝讳亨，明皇第三子，初名嗣升，封陕王。开元十五年，更名浚，徙封忠王。二十三年，又更名玙。","明年，立为皇太子。二十八年，又更名绍。天宝三载，乃更名亨。","明皇幸蜀，即位于灵武。聪明彊记，属词典丽。在位七年，谥曰宣。","诗四首。"],"works":[{"id":"t0-181","title":"延英殿玉灵芝诗三章章八句 一","kind":"诗"},{"id":"t0-182","title":"延英殿玉灵芝诗三章章八句 二","kind":"诗"},{"id":"t0-183","title":"延英殿玉灵芝诗三章章八句 三","kind":"诗"},{"id":"t0-184","title":"赐棃李泌与诸王联句","kind":"诗"}]},"裴杞":{"slug":"裴杞","name":"裴杞","dynasty":"唐","style":"","life":"","origin":"","seal":"裴","bio":[],"works":[{"id":"t43-257","title":"风光草际浮","kind":"诗"}]},"赵仁奖":{"slug":"赵仁奖","name":"赵仁奖","dynasty":"唐","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"t43-650","title":"句","kind":"诗"}]},"郑元弼":{"slug":"郑元弼","name":"郑元弼","dynasty":"唐","style":"","life":"","origin":"","seal":"郑","bio":["元弼，仙游人，良士子。事王继鹏为礼部员外郎。通文时，尝使晋。","王延义立，改官谏议大夫，迁礼部尚书、判三司。天德二年为朱文进所杀。诗二首。","（《全唐诗》无郑元弼诗，传据《仙游志》卷四、《十国春秋》卷九六）"],"works":[{"id":"t55-833","title":"汀州定光南安岩诗二首（题拟） 一","kind":"诗"},{"id":"t55-834","title":"汀州定光南安岩诗二首（题拟） 二","kind":"诗"}]},"顾非熊":{"slug":"顾非熊","name":"顾非熊","dynasty":"唐","style":"","life":"","origin":"","seal":"顾","bio":["顾非熊，况之子，性滑稽，好凌轹，困举场三十年。穆宗长庆中，登进士第，累佐使府。大中间，为盱眙尉。","慕父风，弃官隐茅山。诗一卷。"],"works":[{"id":"t27-363","title":"秋日陕州道中作","kind":"诗"},{"id":"t27-364","title":"经杭州","kind":"诗"},{"id":"t27-365","title":"经河中","kind":"诗"},{"id":"t27-366","title":"送僧归洞庭","kind":"诗"},{"id":"t27-367","title":"题觉真上人院","kind":"诗"},{"id":"t27-368","title":"寄太白无能禅师","kind":"诗"},{"id":"t27-369","title":"舒州酬别侍御","kind":"诗"},{"id":"t27-370","title":"姚岩寺路怀友","kind":"诗"},{"id":"t27-371","title":"天河阁到啼猿阁即事","kind":"诗"},{"id":"t27-372","title":"夏日会修行段将军宅","kind":"诗"},{"id":"t27-373","title":"送杭州姚员外","k