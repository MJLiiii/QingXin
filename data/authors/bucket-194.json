,"life":"","origin":"","seal":"汤","bio":["汤悦，陈州西华人，本姓殷，文圭之子。仕南唐，官学士，历枢密使、右仆射。元宗时，淮上用兵，书檄教诰皆出其手。","诗五首。"],"works":[{"id":"t42-436","title":"奉和圣制送邓王牧宣城","kind":"诗"},{"id":"t42-437","title":"早春寄华下同志","kind":"诗"},{"id":"t42-438","title":"鼎臣学士侍郎以东馆庭梅昔翰苑之毫末今复半枯向时同僚零落都尽素𩬇垂领兹唯二人感旧伤怀发于吟咏惠然好我不能无言輙次来韵攀和","kind":"诗"},{"id":"t42-439","title":"再次前韵代梅荅","kind":"诗"},{"id":"t42-440","title":"鼎臣学士侍郎楚金舍人学士以再伤庭梅诗同垂宠和清绝感叹情致俱深因成四十字陈谢","kind":"诗"},{"id":"t51-637","title":"送季大夫牧舒州","kind":"诗"}]},"薛令之":{"slug":"薛令之","name":"薛令之","dynasty":"唐","style":"","life":"","origin":"","seal":"薛","bio":["薛令之，闽之长溪人。肃宗为太子时，令之以右补阙兼侍读。积岁不迁，乃弃官，徒步归乡里。","及肃宗即位，以旧恩召，而令之已前卒。诗二首。"],"works":[{"id":"t10-564","title":"自悼","kind":"诗"},{"id":"t10-565","title":"灵岩寺","kind":"诗"},{"id":"t51-307","title":"太姥山","kind":"诗"},{"id":"t52-757","title":"草堂吟","kind":"诗"}]},"薛巽":{"slug":"薛巽","name":"薛巽","dynasty":"唐","style":"","life":"","origin":"","seal":"薛","bio":["薛巽，河东人。元和初为河北行营粮料使于臯谟判官；六年五月，坐于赃事贬连州，量移朗州员外司马。诗一首。","（据《柳河东集》卷十三《朗州员外司户薛君妻崔氏墓志铭》、卷二三《送薛判官量移序》、《旧唐书》卷一六三《崔元略传》）"],"works":[{"id":"t53-396","title":"善卷祠","kind":"诗"}]},"薛昭蕴":{"slug":"薛昭蕴","name":"薛昭蕴","dynasty":"唐","style":"","life":"","origin":"","seal":"薛","bio":["--《花间集》称薛侍郎。或疑即薛昭纬。新、旧《唐书》有《薛昭纬传》，言纬于乾宁中为礼部侍郎。","孙光宪《北梦琐言》卷四云：“薛澄州昭纬，即保逊之子也。恃才傲物，亦有父风。每入朝省，弄笏而行，旁若无人，好唱《浣溪沙》词。","”存词十九首。王国维辑有《薛侍郎词》一卷。"],"works":[{"id":"t49-432","title":"相见欢","kind":"诗"},{"id":"t49-433","title":"醉公子","kind":"诗"},{"id":"t49-434","title":"女冠子 一","kind":"诗"},{"id":"t49-435","title":"女冠子 二","kind":"诗"},{"id":"t49-436","title":"浣溪沙 一","kind":"诗"},{"id":"t49-437","title":"浣溪沙 二","kind":"诗"},{"id":"t49-438","title":"浣溪沙 三","kind":"诗"},{"id":"t49-439","title":"浣溪沙 四","kind":"诗"},{"id":"t49-440","title":"浣溪沙 五","kind":"诗"},{"id":"t49-441","title":"浣溪沙 六","kind":"诗"},{"id":"t49-442","title":"浣溪沙 七","kind":"诗"},{"id":"t49-443","title":"浣溪沙 八","kind":"诗"},{"id":"t49-444","title":"谒金门","kind":"诗"},{"id":"t49-445","title":"喜迁莺 一","kind":"诗"},{"id":"t49-446","title":"喜迁莺 二","kind":"诗"},{"id":"t49-447","title":"喜迁莺 三","kind":"诗"},{"id":"t49-448","title":"小重山 一","kind":"诗"},{"id":"t49-449","title":"小重山 二","kind":"诗"},{"id":"t49-450","title":"离别难","kind":"诗"}]},"薛能":{"slug":"薛能","name":"薛能","dynasty":"唐","style":"字太拙","life":"","origin":"","seal":"薛","bio":["薛能，字太拙，汾州人。登会昌六年进士第。大中末，书判中选，补盩厔尉，李福镇滑，表署观察判官，历御史、都官刑部员外郎。","福徙西蜀，奏以自副。咸通中，摄嘉州刺史，迁主客、度支、刑部郎中，权知京兆尹事，授工部尚书，节度徐州，徙忠武。广明元年，徐军戍溵水，经许，能以旧军，馆之城中，军惧见袭。","大将周岌乘众疑逐能，自称留后，因屠其家。能僻于诗，日赋一章，有集十卷，今编诗四卷。薛能，字太拙，汾州人。","登会昌六年进士第。大中末，书判中选，补盩厔尉，李福镇滑，表署观察判官，历御史、都官刑部员外郎。福徙西蜀，奏以自副。","咸通中，摄嘉州刺史，迁主客、度支、刑部郎中，权知京兆尹事，授工部尚书，节度徐州，徙忠武。广明元年，徐军戍溵水，经许。能以旧军，馆之城中，军惧见袭。","大将周岌乘众疑逐能，自称留后，因屠其家。能僻于诗，日赋一章，有集十卷，今编诗四卷。"],"works":[{"id":"t1-7","title":"横吹曲辞 长安道","kind":"诗"},{"id":"t1-134","title":"相和歌辞 铜雀台","kind":"诗"},{"id":"t1-509","title":"舞曲歌辞 柘枝词 一","kind":"诗"},{"id":"t1-510","title":"舞曲歌辞 柘枝词 二","kind":"诗"},{"id":"t1-511","title":"舞曲歌辞 柘枝词 三","kind":"诗"},{"id":"t1-804","title":"杂曲歌辞 行路难","kind":"诗"},{"id":"t2-161","title":"杂曲歌辞 杨柳枝 一","kind":"诗"},{"id":"t2-162","title":"杂曲歌辞 杨柳枝 二","kind":"诗"},{"id":"t2-163","title":"杂曲歌辞 杨柳枝 三","kind":"诗"},{"id":"t2-164","title":"杂曲歌辞 杨柳枝 四","kind":"诗"},{"id":"t2-165","title":"杂曲歌辞 杨柳枝 五","kind":"诗"},{"id":"t2-166","title":"杂曲歌辞 杨柳枝 六","kind":"诗"},{"id":"t2-167","title":"杂曲歌辞 杨柳枝 七","kind":"诗"},{"id":"t2-168","title":"杂曲歌辞 杨柳枝 八","kind":"诗"},{"id":"t2-169","title":"杂曲歌辞 杨柳枝 九","kind":"诗"},{"id":"t2-170","title":"杂曲歌辞 杨柳枝 十","kind":"诗"},{"id":"t2-171","title":"杂曲歌辞 杨柳枝 一","kind":"诗"},{"id":"t2-172","title":"杂曲歌辞 杨柳枝 二","kind":"诗"},{"id":"t2-173","title":"杂曲歌辞 杨柳枝 三","kind":"诗"},{"id":"t2-174","title":"杂曲歌辞 杨柳枝 四","kind":"诗"},{"id":"t2-175","title":"杂曲歌辞 杨柳枝 五","kind":"诗"},{"id":"t2-176","title":"杂曲歌辞 杨柳枝 六","kind":"诗"},{"id":"t2-177","title":"杂曲歌辞 杨柳枝 七","kind":"诗"},{"id":"t2-178","title":"杂曲歌辞 杨柳枝 八","kind":"诗"},{"id":"t2-179","title":"杂曲歌辞 杨柳枝 九","kind":"诗"},{"id":"t2-219","title":"杂曲歌辞 升平乐 一","kind":"诗"},{"id":"t2-220","title":"杂曲歌辞 升平乐 二","kind":"诗"},{"id":"t2-221","title":"杂曲歌辞 升平乐 三","kind":"诗"},{"id":"t2-222","title":"杂曲歌辞 升平乐 四","kind":"诗"},{"id":"t2-223","title":"杂曲歌辞 升平乐 五","kind":"诗"},{"id":"t2-224","title":"杂曲歌辞 升平乐 六","kind":"诗"},{"id":"t2-225","title":"杂曲歌辞 升平乐 七","kind":"诗"},{"id":"t2-226","title":"杂曲歌辞 升平乐 八","kind":"诗"},{"id":"t2-227","title":"杂曲歌辞 升平乐 九","kind":"诗"},{"id":"t2-228","title":"杂曲歌辞 升平乐 十","kind":"诗"},{"id":"t30-973","title":"新雪八韵","kind":"诗"},{"id":"t30-974","title":"国学试风化下","kind":"诗"},{"id":"t30-975","title":"升平词十首 一","kind":"诗"},{"id":"t30-976","title":"升平词十首 二","kind":"诗"},{"id":"t30-977","title":"升平词十首 三","kind":"诗"},{"id":"t30-978","title":"升平词十首 四","kind":"诗"},{"id":"t30-979","title":"升平词十首 五","kind":"诗"},{"id":"t30-980","title":"升平词十首 六","kind":"诗"},{"id":"t30-981","title":"升平词十首 七","kind":"诗"},{"id":"t30-982","title":"升平词十首 八","kind":"诗"},{"id":"t30-983","title":"升平词十首 九","kind":"诗"},{"id":"t30-984","title":"升平词十首 十","kind":"诗"},{"id":"t30-985","title":"送冯温往河外","kind":"诗"},{"id":"t30-986","title":"送从兄之太原副使","kind":"诗"},{"id":"t30-987","title":"送马戴书记之太原","kind":"诗"}]},"贞素":{"slug":"贞素","name":"贞素","dynasty":"唐","style":"","life":"","origin":"","seal":"贞","bio":["贞素，晚唐时渤海僧。长庆间，曾为日本国入唐求法僧灵仙东渡答谢。大和二年回，诣灵境寺复命，时灵仙已先卒。","贞素哭之以诗云。（《全唐诗》无贞素诗）"],"works":[{"id":"t51-21","title":"哭日本国内供奉大德灵仙和尚诗（并序）","kind":"诗"}]},"贯休":{"slug":"贯休","name":"贯休","dynasty":"唐","style":"字德隐 · 号禅月大师","life":"","origin":"","seal":"贯","bio":["贯休，字德隐，俗姓姜氏，兰溪人。七岁出家，日读经书千字，过目不忘，既精奥义，诗亦奇险，兼工书画。初为吴越钱镠所重，后谒成汭荆南。","汭欲授书法，休曰：“须登坛乃授。”汭怒，遰放之黔。天复中，入益州，王建礼遇之，署号禅月大师，或呼为得得来和尚，终于蜀，年八十一。","初有《西岳集》，吴融为序，极称之，后弟子昙域更名《宝月集》，其全集三十卷，已亡。胡震亨谓“宋睦州刻本多载他人诗，不足信”，其说亦不知何据，胡存诗仅三卷，今编十二卷。贯休，字德隐，俗姓姜氏，兰溪人。","七岁出家，日读经书千字，过目不忘，既精奥义，诗亦奇险，兼工书画。初为吴越钱镠所重，后谒成汭荆南。汭欲授书法，休曰：须登坛乃授。","汭怒，递放之黔。天复中，入益州，王建礼遇之，署号禅月大师，或呼为得得来和尚，终于蜀，年八十一。初有西岳集，吴融为序，极称之，后弟子昙域更名宝月集，其全集三十卷，已亡。","胡震亨谓宋睦州刻本多载他人诗，不足信，其说亦不知何据，胡存诗仅三卷，今编十二卷。贯休，俗姓姜氏，字德隐，兰溪人。补诗二首。"],"works":[{"id":"t45-553","title":"善哉行","kind":"诗"},{"id":"t45-554","title":"读离骚经","kind":"诗"},{"id":"t45-555","title":"阳春曲","kind":"诗"},{"id":"t45-556","title":"白雪曲","kind":"诗"},{"id":"t45-557","title":"上留田","kind":"诗"},{"id":"t45-558","title":"胡无人","kind":"诗"},{"id":"t45-559","title":"苦寒行","kind":"诗"},{"id":"t45-560","title":"蒿里","kind":"诗"},{"id":"t45-561","title":"临高台","kind":"诗"},{"id":"t45-562","title":"杞梁妻","kind":"诗"},{"id":"t45-563","title":"古离别","kind":"诗"},{"id":"t45-564","title":"战城南二首 一","kind":"诗"},{"id":"t45-565","title":"战城南二首 二","kind":"诗"},{"id":"t45-566","title":"少年行 一","kind":"诗"},{"id":"t45-567","title":"少年行 二","kind":"诗"},{"id":"t45-568","title":"少年行 三","kind":"诗"},{"id":"t45-569","title":"梦游仙四首 一","kind":"诗"},{"id":"t45-570","title":"梦游仙四首 二","kind":"诗"},{"id":"t45-571","title":"梦游仙四首 三","kind":"诗"},{"id":"t45-572","title":"梦游仙四首 四","kind":"诗"},{"id":"t45-573","title":"轻薄篇二首 一","kind":"诗"},{"id":"t45-574","title":"轻薄篇二首 二","kind":"诗"},{"id":"t45-575","title":"长安道","kind":"诗"},{"id":"t45-576","title":"洛阳尘","kind":"诗"},{"id":"t45-577","title":"富贵曲二首 一","kind":"诗"},{"id":"t45-578","title":"富贵曲二首 二","kind":"诗"},{"id":"t45-579","title":"野田黄雀行","kind":"诗"},{"id":"t45-580","title":"古意九首 一","kind":"诗"},{"id":"t45-581","title":"古意九首 二","kind":"诗"},{"id":"t45-582","title":"古意九首 三","kind":"诗"},{"id":"t45-583","title":"古意九首 四","kind":"诗"},{"id":"t45-584","title":"古意九首 五","kind":"诗"},{"id":"t45-585","title":"古意九首 六","kind":"诗"},{"id":"t45-586","title":"古意九首 七","kind":"诗"},{"id":"t45-587","title":"古意九首 八","kind":"诗"},{"id":"t45-588","title":"古意九首 九","kind":"诗"},{"id":"t45-589","title":"酷吏词","kind":"诗"},{"id":"t45-590","title":"还举人歌行卷","kind":"诗"},{"id":"t45-591","title":"陈宫词","kind":"诗"},{"id":"t45-592","title":"拟齐梁酬所知见赠二首 一","kind":"诗"},{"id":"t45-593","title":"拟齐梁酬所知见赠二首 二","kind":"诗"},{"id":"t45-594","title":"经古战场","kind":"诗"},{"id":"t45-595","title":"村行遇猎","kind":"诗"},{"id":"t45-596","title":"渔家","kind":"诗"},{"id":"t45-597","title":"田家作","kind":"诗"},{"id":"t45-598","title":"江边祠","kind":"诗"},{"id":"t45-599","title":"苦热寄赤松道者","kind":"诗"},{"id":"t45-600","title":"偶作二首 一","kind":"诗"},{"id":"t45-601","title":"偶作二首 二","kind":"诗"},{"id":"t45-602","title":"夜夜曲","kind":"诗"}]},"赵林":{"slug":"赵林","name":"赵林","dynasty":"唐","style":"","life":"","origin":"","seal":"赵","bio":["林，进士及弟，陞朝赐绯而卒。（《全唐诗》无赵林诗）"],"works":[{"id":"t56-409","title":"朝霞诗","kind":"诗"}]},"郭利贞":{"slug":"郭利贞","name":"郭利贞","dynasty":"唐","style":"","life":"","origin":"","seal":"郭","bio":["郭利贞，神龙中为吏部员外，赋《上元》诗，与苏味道、崔液并为绝唱。诗一首。"],"works":[{"id":"t5-230","title":"上元","kind":"诗"}]},"陈谊":{"slug":"陈谊","name":"陈谊","dynasty":"唐","style":"","life":"","origin":"","seal":"陈","bio":["谊，吉州人。"],"works":[{"id":"t51-803","title":"题螺江庙","kind":"诗"}]}}