{"刘谷":{"slug":"刘谷","name":"刘谷","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":["刘谷，与李郢同时。诗一首。"],"works":[{"id":"t40-835","title":"和三乡诗","kind":"诗"}]},"季广琛":{"slug":"季广琛","name":"季广琛","dynasty":"唐","style":"","life":"","origin":"","seal":"季","bio":[],"works":[{"id":"t43-660","title":"句","kind":"诗"}]},"常楚老":{"slug":"常楚老","name":"常楚老","dynasty":"唐","style":"","life":"","origin":"","seal":"常","bio":["常楚老，长庆进士，官拾遗。诗二首。"],"works":[{"id":"t27-354","title":"祖龙行","kind":"诗"},{"id":"t27-355","title":"江上蚊子","kind":"诗"},{"id":"t27-356","title":"句","kind":"诗"}]},"张鸿":{"slug":"张鸿","name":"张鸿","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["鸿，连州桂阳人。天祐二年进士。时唐祚式微，鸿知势不可为，遂隐居不仕。","诗清纯，著述甚富，有集十二卷，今不存。（《全唐诗》卷七七四收鸿诗一首，列为世次爵里俱无考作者。今据《粤诗搜逸》卷一引《连州志》本传补其事迹）"],"works":[{"id":"t43-123","title":"赠乔尊师","kind":"诗"},{"id":"t54-390","title":"贞女石（相传秦时有数女游，卒遇风雨，一女化为石。）","kind":"诗"}]},"德韶":{"slug":"德韶","name":"德韶","dynasty":"唐","style":"","life":"","origin":"","seal":"德","bio":["德韶，姓陈，处州龙泉人。嗣清凉文益。吴越忠懿王延请住天台山，为国师。","开宝五年卒，年八十二。诗一首。（《全唐诗》无德韶诗）"],"works":[{"id":"t55-589","title":"颂","kind":"诗"}]},"李播":{"slug":"李播","name":"李播","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李播，登元和进士第，以郎中典蕲州。诗一首。"],"works":[{"id":"t26-161","title":"见志","kind":"诗"},{"id":"t43-94","title":"见美人闻琴不听","kind":"诗"},{"id":"t53-758","title":"悼故妓","kind":"诗"}]},"杨宇":{"slug":"杨宇","name":"杨宇","dynasty":"唐","style":"字子庥","life":"","origin":"","seal":"杨","bio":["宇，字子庥，弘农华阴人。茂卿子。大和八年登进士第，历官左金吾卫兵曹参军、国子助教。","大中五年卒，年四十五。（据《千唐志斋藏志》大中五年杨牢撰《唐故文林郎国子助教杨君墓志铭》）"],"works":[{"id":"t53-899","title":"赠舍弟","kind":"诗"}]},"某教授":{"slug":"某教授","name":"某教授","dynasty":"宋","style":"","life":"","origin":"","seal":"某","bio":[],"works":[{"id":"c67-832","title":"眼儿媚·鬓边一点似飞鸦","kind":"词"}]},"田敏":{"slug":"田敏","name":"田敏","dynasty":"唐","style":"","life":"","origin":"","seal":"田","bio":["敏，淄州邹平人。梁贞明中登科，留为国子四门博士。后唐天成初，改为尚书博士，又为国子博士，转屯田员外郎，兼太常博士。","改户部员外郎。清泰初，迁国子司业。晋天福四年授祭酒、检校工部尚书，兼户部侍郎。","开运初，迁兵部侍郎、充弘文馆学士，改授检校右仆射，复为祭酒。汉干祐中，拜尚书右丞、判国子监。周广顺初，改左丞，遣使契丹。","世宗即位，拜太常卿、检校左仆射，加司空。显德五年，上章请老，迁工部尚书，改太子少保致仕，归淄州别墅。齿数帝即位，加少传。","开宝四年卒，年九十二。"],"works":[{"id":"t51-583","title":"无题","kind":"诗"},{"id":"t51-584","title":"明德舞（后周宗庙乐舞辞。太祖庙堂）","kind":"诗"}]},"皮光业":{"slug":"皮光业","name":"皮光业","dynasty":"唐","style":"","life":"","origin":"","seal":"皮","bio":[],"works":[{"id":"t43-710","title":"句","kind":"诗"},{"id":"t55-579","title":"索茗题巨觥（题拟）","kind":"诗"}]},"罗颖":{"slug":"罗颖","name":"罗颖","dynasty":"唐","style":"","life":"","origin":"","seal":"罗","bio":[],"works":[{"id":"t48-348","title":"题汉祖庙","kind":"诗"}]},"魏炎":{"slug":"魏炎","name":"魏炎","dynasty":"唐","style":"","life":"","origin":"","seal":"魏","bio":[],"works":[{"id":"t51-309","title":"历山","kind":"诗"},{"id":"t51-310","title":"又曰","kind":"诗"},{"id":"t51-311","title":"又曰","kind":"诗"}]}}