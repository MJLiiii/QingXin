{"刘崇鲁":{"slug":"刘崇鲁","name":"刘崇鲁","dynasty":"唐","style":"字郊文","life":"","origin":"","seal":"刘","bio":["刘崇鲁，字郊文，崇龟弟也。擢进士第，景福中，官水部郎中、知制诰。坐崔昭纬党，贬崖州司户。","诗一首。"],"works":[{"id":"t40-353","title":"席上吟","kind":"诗"}]},"利登":{"slug":"利登","name":"利登","dynasty":"宋","style":"","life":"","origin":"","seal":"利","bio":[],"works":[{"id":"c73-947","title":"绿头鸭・多丽·晚春天","kind":"词"},{"id":"c73-948","title":"菩萨蛮·玉阑干外重帘晚","kind":"词"},{"id":"c73-949","title":"玉楼春·夹帘不卷重堂暮","kind":"词"},{"id":"c73-950","title":"水调歌头·日月换飞涧","kind":"词"},{"id":"c73-951","title":"洞仙歌·弄香吹粉","kind":"词"},{"id":"c73-952","title":"过秦楼·眉黛山分","kind":"词"},{"id":"c73-953","title":"齐天乐·淡云荒草秋汀暮","kind":"词"},{"id":"c73-954","title":"鹧鸪天·凤尾鬟香再叠梳","kind":"词"},{"id":"c73-955","title":"风流子·梨园花柳地","kind":"词"},{"id":"c73-956","title":"风入松·断芜幽树际烟平","kind":"词"},{"id":"c73-957","title":"水调歌头·相聚不知好","kind":"词"},{"id":"c73-958","title":"失调名·花外潮回","kind":"词"},{"id":"c73-959","title":"虞美人·当时养士知何许","kind":"词"}]},"吴文若":{"slug":"吴文若","name":"吴文若","dynasty":"宋","style":"","life":"","origin":"","seal":"吴","bio":[],"works":[{"id":"c78-650","title":"蝶恋花·玉宇生凉秋恰半","kind":"词"}]},"失撰人名":{"slug":"失撰人名","name":"失撰人名","dynasty":"唐","style":"","life":"","origin":"","seal":"失","bio":[],"works":[{"id":"t1-508","title":"舞曲歌辞 柘枝词","kind":"诗"}]},"文丙":{"slug":"文丙","name":"文丙","dynasty":"唐","style":"","life":"","origin":"","seal":"文","bio":[],"works":[{"id":"t49-35","title":"罗浮山","kind":"诗"},{"id":"t49-36","title":"牡丹","kind":"诗"},{"id":"t49-37","title":"藓花","kind":"诗"},{"id":"t49-38","title":"新栽松","kind":"诗"},{"id":"t49-39","title":"柳","kind":"诗"}]},"王彭年":{"slug":"王彭年","name":"王彭年","dynasty":"宋","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"c68-80","title":"朝中措·人才七泽盛三湘","kind":"词"}]},"若讷":{"slug":"若讷","name":"若讷","dynasty":"唐","style":"","life":"","origin":"","seal":"若","bio":[],"works":[{"id":"t56-585","title":"大还丹口诀","kind":"诗"},{"id":"t56-586","title":"歌","kind":"诗"}]},"贺公":{"slug":"贺公","name":"贺公","dynasty":"唐","style":"","life":"","origin":"","seal":"贺","bio":[],"works":[{"id":"t43-739","title":"句","kind":"诗"}]},"郑惟忠":{"slug":"郑惟忠","name":"郑惟忠","dynasty":"唐","style":"","life":"","origin":"","seal":"郑","bio":["郑惟忠，宋州人。仪凤中，举进士，则天召见，称旨，授胄曹参军，再迁凤阁舍人。中宗即位，拜黄门侍郎，守大理卿，推断大狱，多所全活。","开元初，为礼部尚书，太子宾客。诗一首。"],"works":[{"id":"t2-922","title":"送苏尚书赴益州","kind":"诗"},{"id":"t52-629","title":"古石之歌","kind":"诗"}]}}