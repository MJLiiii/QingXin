]},"王易简":{"slug":"王易简","name":"王易简","dynasty":"唐","style":"字理得 · 号可竹","life":"","origin":"山阴（今浙江绍兴）","seal":"王","bio":["--字理得，号可竹，山阴 (今浙江绍兴) 人。登进士，除瑞安簿，不赴。隐居城南，有《山中观史吟》，存词见《乐府补题》。"],"works":[{"id":"t41-207","title":"官左拾遗归隐作","kind":"诗"},{"id":"c76-31","title":"齐天乐·宫烟晓散春如雾","kind":"词"},{"id":"c76-32","title":"酹江月・念奴娇·暗帘吹雨","kind":"词"},{"id":"c76-33","title":"庆宫春・高阳台·庭草春迟","kind":"词"},{"id":"c76-34","title":"天香·烟峤收痕","kind":"词"},{"id":"c76-35","title":"水龙吟·翠裳微护冰肌","kind":"词"},{"id":"c76-36","title":"摸鱼儿·怪鲛宫","kind":"词"},{"id":"c76-37","title":"齐天乐·翠云深锁齐姬恨","kind":"词"}]},"留晚香":{"slug":"留晚香","name":"留晚香","dynasty":"宋","style":"","life":"","origin":"","seal":"留","bio":[],"works":[{"id":"c76-584","title":"最高楼·西江水","kind":"词"}]},"聂夷中":{"slug":"聂夷中","name":"聂夷中","dynasty":"唐","style":"字坦之","life":"","origin":"","seal":"聂","bio":["聂夷中，字坦之，河东人。咸通十二年登第，官华阴尉。诗一卷。"],"works":[{"id":"t1-4","title":"横吹曲辞 长安道","kind":"诗"},{"id":"t1-115","title":"相和歌辞 短歌行","kind":"诗"},{"id":"t1-268","title":"相和歌辞 胡无人行","kind":"诗"},{"id":"t1-351","title":"相和歌辞 杂怨三首 一","kind":"诗"},{"id":"t1-352","title":"相和歌辞 杂怨三首 二","kind":"诗"},{"id":"t1-353","title":"相和歌辞 杂怨三首 三","kind":"诗"},{"id":"t1-409","title":"相和歌辞 乌夜啼","kind":"诗"},{"id":"t1-750","title":"杂曲歌辞 空城雀","kind":"诗"},{"id":"t1-790","title":"杂曲歌辞 行路难","kind":"诗"},{"id":"t1-817","title":"杂曲歌辞 古别离","kind":"诗"},{"id":"t1-870","title":"杂曲歌辞 饮酒乐","kind":"诗"},{"id":"t1-891","title":"杂曲歌辞 起夜半","kind":"诗"},{"id":"t1-899","title":"杂曲歌辞 大垂手","kind":"诗"},{"id":"t35-193","title":"杂兴","kind":"诗"},{"id":"t35-194","title":"杂怨 一","kind":"诗"},{"id":"t35-195","title":"杂怨 二","kind":"诗"},{"id":"t35-196","title":"行路难","kind":"诗"},{"id":"t35-197","title":"大垂手","kind":"诗"},{"id":"t35-198","title":"空城雀","kind":"诗"},{"id":"t35-199","title":"胡无人行","kind":"诗"},{"id":"t35-200","title":"咏田家","kind":"诗"},{"id":"t35-201","title":"燕台二首 一","kind":"诗"},{"id":"t35-202","title":"燕台二首 二","kind":"诗"},{"id":"t35-203","title":"古兴","kind":"诗"},{"id":"t35-204","title":"劝酒二首 一","kind":"诗"},{"id"