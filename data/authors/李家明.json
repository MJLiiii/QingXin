{"slug":"李家明","name":"李家明","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李家明，庐州西昌人。元宗时，为乐部头，谈谐敏给，善为讽辞。诗四首。"],"works":[{"id":"t42-432","title":"元宗钓鱼无获进诗","kind":"诗"},{"id":"t42-433","title":"咏卧牛","kind":"诗"},{"id":"t42-434","title":"题纸鸢止宋齐丘哭子","kind":"诗"},{"id":"t42-435","title":"咏皖公山","kind":"诗"}]}