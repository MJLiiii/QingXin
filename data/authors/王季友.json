{"slug":"王季友","name":"王季友","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王季友，河南人。家贫卖履，博极群书。豫章太守李勉引为宾客，甚敬之，杜甫诗所谓丰城客子王季友也。","诗十一首。"],"works":[{"id":"t13-520","title":"别李季友","kind":"诗"},{"id":"t13-521","title":"寄韦子春","kind":"诗"},{"id":"t13-522","title":"杂诗","kind":"诗"},{"id":"t13-523","title":"滑中赠崔高士瑾","kind":"诗"},{"id":"t13-524","title":"还山留别长安知己","kind":"诗"},{"id":"t13-525","title":"代贺若令誉赠沈千运","kind":"诗"},{"id":"t13-526","title":"酬李十六岐","kind":"诗"},{"id":"t13-527","title":"宿东溪李十五山亭","kind":"诗"},{"id":"t13-528","title":"观于舍人壁画山水","kind":"诗"},{"id":"t13-529","title":"玉壶冰","kind":"诗"},{"id":"t13-530","title":"古塞曲","kind":"诗"},{"id":"t43-284","title":"玉壶冰","kind":"诗"},{"id":"t48-821","title":"青出蓝","kind":"诗"},{"id":"t48-822","title":"皇帝移晦日为中和节","kind":"诗"}]}