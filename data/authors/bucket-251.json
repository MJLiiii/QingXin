nd":"诗"}]},"韩雄":{"slug":"韩雄","name":"韩雄","dynasty":"唐","style":"","life":"","origin":"","seal":"韩","bio":[],"works":[{"id":"t42-990","title":"敕和元相公家园即事寄王相公","kind":"诗"}]}}