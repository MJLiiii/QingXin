{"介胄鬼":{"slug":"介胄鬼","name":"介胄鬼","dynasty":"唐","style":"","life":"","origin":"","seal":"介","bio":[],"works":[{"id":"t47-950","title":"掷裴武公诗","kind":"诗"}]},"刘望":{"slug":"刘望","name":"刘望","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":["望，袁州万载人。唐末进士及第，与钟传同时。补诗一首。","（《全唐诗》卷七七五收刘望诗一首，列为世次爵里俱无考作者。今据徐松《登科记考》卷二七引《永乐大典》引《宜春志》及下补诗叙其事迹。钟传卒于天祐三年。","）"],"works":[{"id":"t43-133","title":"九嶷山","kind":"诗"},{"id":"t54-388","title":"献江西钟令公","kind":"诗"}]},"刘猛":{"slug":"刘猛","name":"刘猛","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":["刘猛，梁州进士，与元稹同时。诗三首。"],"works":[{"id":"t24-803","title":"月生","kind":"诗"},{"id":"t24-804","title":"苦雨","kind":"诗"},{"id":"t24-805","title":"晓","kind":"诗"}]},"卢渥":{"slug":"卢渥","name":"卢渥","dynasty":"唐","style":"字子章","life":"","origin":"","seal":"卢","bio":["卢渥，字子章，范阳人。大中进士第，历中书舍人、陕府观察使，终检校司徒。诗二首。"],"works":[{"id":"t31-425","title":"赋得寿星见","kind":"诗"},{"id":"t31-426","title":"题嘉祥驿","kind":"诗"}]},"去非":{"slug":"去非","name":"去非","dynasty":"宋","style":"","life":"","origin":"","seal":"去","bio":[],"works":[{"id":"c78-651","title":"满庭芳·龙角辉春","kind":"词"}]},"史思明":{"slug":"史思明","name":"史思明","dynasty":"唐","style":"","life":"","origin":"","seal":"史","bio":["思明，本名窣干，宁夷州突厥杂种胡人。天宝初，以军功至将军知平卢军事，迁北平太守。十一载，除平卢兵马使。","安禄山反，代贾循为范阳留后。乾元二年，杀安庆绪，僭称大圣燕王。上元二年，为子朝义缢杀。","诗二首。（《全唐诗》卷八六九收思明诗一首，缺传，今据《旧唐书》卷二○○本传补传。）"],"works":[{"id":"t48-250","title":"樱桃子诗","kind":"诗"},{"id":"t52-890","title":"石榴诗","kind":"诗"},{"id":"t52-891","title":"以樱桃赐子朝义及周贽（题拟）","kind":"诗"}]},"吴康":{"slug":"吴康","name":"吴康","dynasty":"宋","style":"","life":"","origin":"","seal":"吴","bio":[],"works":[{"id":"c70-798","title":"失调名·试问海棠健否","kind":"词"},{"id":"c70-799","title":"失调名·凌空蜂翼递香来","kind":"词"}]},"吴武陵":{"slug":"吴武陵","name":"吴武陵","dynasty":"唐","style":"","life":"","origin":"","seal":"吴","bio":["吴武陵，信州人。元和初，擢进士第，窦易直判度支，表武陵主盐北边，入为太学博士。太和中，出刺韶州，寻贬潘州司户参军。","诗一卷，今存二首。"],"works":[{"id":"t25-708","title":"贡院楼北新栽小松","kind":"诗"},{"id":"t25-709","title":"题路左佛堂","kind":"诗"},{"id":"t51-381","title":"龙虎