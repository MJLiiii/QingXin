{"东冈":{"slug":"东冈","name":"东冈","dynasty":"宋","style":"","life":"","origin":"","seal":"东","bio":[],"works":[{"id":"c75-786","title":"百字令・念奴娇·排云拓月","kind":"词"}]},"于邺":{"slug":"于邺","name":"于邺","dynasty":"唐","style":"","life":"","origin":"","seal":"于","bio":["于邺，唐末进士，诗一卷。"],"works":[{"id":"t40-800","title":"书怀","kind":"诗"},{"id":"t40-801","title":"书情","kind":"诗"},{"id":"t40-802","title":"涂中作","kind":"诗"},{"id":"t40-803","title":"春过函谷关","kind":"诗"},{"id":"t40-804","title":"褒中即事","kind":"诗"},{"id":"t40-805","title":"岁暮还家","kind":"诗"},{"id":"t40-806","title":"还家","kind":"诗"},{"id":"t40-807","title":"题华山麻处士所居","kind":"诗"},{"id":"t40-808","title":"天南怀故人","kind":"诗"},{"id":"t40-809","title":"路傍草","kind":"诗"},{"id":"t40-810","title":"秋夕闻雁","kind":"诗"},{"id":"t40-811","title":"洛中有怀","kind":"诗"},{"id":"t40-812","title":"送魏山韦处士","kind":"诗"},{"id":"t40-813","title":"白樱桃","kind":"诗"},{"id":"t40-814","title":"白樱树","kind":"诗"},{"id":"t40-815","title":"下第不胜其忿题路左佛庙","kind":"诗"},{"id":"t40-816","title":"感怀","kind":"诗"},{"id":"t40-817","title":"游中梁山","kind":"诗"},{"id":"t40-818","title":"寻山","kind":"诗"},{"id":"t40-819","title":"宿江口","kind":"诗"},{"id":"t40-820","title":"秋夜达萧关","kind":"诗"},{"id":"t40-821","title":"斜谷道","kind":"诗"},{"id":"t40-822","title":"过百牢关贻舟中者","kind":"诗"},{"id":"t40-823","title":"客中览镜","kind":"诗"},{"id":"t40-824","title":"长安逢隐者","kind":"诗"},{"id":"t40-825","title":"与僧话旧","kind":"诗"},{"id":"t40-826","title":"赠王道士","kind":"诗"},{"id":"t40-827","title":"匣中琴","kind":"诗"},{"id":"t40-828","title":"友人亭松","kind":"诗"},{"id":"t40-829","title":"过洛阳城","kind":"诗"},{"id":"t40-830","title":"客中月","kind":"诗"},{"id":"t40-831","title":"王将军宅夜听歌","kind":"诗"},{"id":"t40-832","title":"长信宫","kind":"诗"},{"id":"t40-833","title":"高楼","kind":"诗"}]},"令狐峘":{"slug":"令狐峘","name":"令狐峘","dynasty":"唐","style":"","life":"","origin":"","seal":"令","bio":["令狐峘，德棻五世孙，登进士第。禄山之乱，隐居南山豹林谷。司徒杨绾未仕时，亦避地谷中，尝止峘舍，赏其博学，及绾为礼部侍郎，引入史馆。","建中初，为礼部侍郎，典贡举，执政杨炎有所请托，峘得其私书奏之。德宗恶其讦，贬衡州别驾。诗二首。"],"works":[{"id":"t13-421","title":"硖州旅舍奉怀苏州韦郎中","kind":"诗"},{"id":"t13-422","title":"释奠日国学观礼闻雅颂","kind":"诗"}]},"任宇":{"slug":"任宇","name":"任宇","dynasty":"唐","style":"","life":"","origin":"","seal":"任","bio":["任宇，生平无考。诗一首。（任宇，《元和姓䉤》卷五云为渭州人，任迪简之次子。","两《唐书》有《任迪简传》，作京兆万年人。张忱石《〈全唐诗〉无世次作者事迹考索》云渭州当作渭南，任氏自汉任敖之后徙居渭南，唐初任雅相迁至万年。当以后者更为准确。","《新安志》卷九云任宇于咸通七年任歙州刺史，此诗即作于其时。《郎官石柱题名》户部员外郎有任宇，名列裴虔余后，薛调前，亦咸通间任。原列「无考」作者，今移此。","）（《全唐诗》无任宇诗）"],"works":[{"id":"t50-844","title":"新安郡北百余里即黄山西北有山峰高出颇类大华因目为小华山前郡守才客题咏至多偶登斯楼因成一绝","kind":"诗"}]},"可旻":{"slug":"可旻","name":"可旻","dynasty":"宋","style":"","life":"","origin":"","seal":"可","bio":[],"works":[{"id":"c71-456","title":"渔家傲·曾讲弥陀经十遍","kind":"词"},{"id":"c71-457","title":"渔家傲·我佛莲华随步踏","kind":"词"},{"id":"c71-458","title":"渔家傲·彼土因何名极乐","kind":"词"},{"id":"c71-459","title":"渔家傲·佛赞西方经现在","kind":"词"},{"id":"c71-460","title":"渔家傲·鹦鹉频伽知几只","kind":"词"},{"id":"c71-461","title":"渔家傲·清净乐邦吾本郡","kind":"词"},{"id":"c71-462","title":"渔家傲·理性本来长自在","kind":"词"},{"id":"c71-463","title":"渔家傲·为厌娑婆求净土","kind":"词"},{"id":"c71-464","title":"渔家傲·四相相催生病老","kind":"词"},{"id":"c71-465","title":"渔家傲·人世罪冤知底数","kind":"词"},{"id":"c71-466","title":"渔家傲·万事到头无益已","kind":"词"},{"id":"c71-467","title":"渔家傲·西望乐邦云杳隔","kind":"词"},{"id":"c71-468","title":"渔家傲·富贵经中谈净域","kind":"词"},{"id":"c71-469","title":"渔家傲·文墨尖新无处用","kind":"词"},{"id":"c71-470","title":"渔家傲·休纵心猿驰意马","kind":"词"},{"id":"c71-471","title":"渔家傲·三十六般包一袋","kind":"词"},{"id":"c71-472","title":"渔家傲·一点神魂初托魄","kind":"词"},{"id":"c71-473","title":"渔家傲·净土故乡嗟乍别","kind":"词"},{"id":"c71-474","title":"渔家傲·善导可嗟今已往","kind":"词"},{"id":"c71-475","title":"渔家傲·西土纹成东土壤","kind":"词"}]},"叶隆礼":{"slug":"叶隆礼","name":"叶隆礼","dynasty":"宋","style":"","life":"","origin":"","seal":"叶","bio":[],"works":[{"id":"c74-161","title":"兰陵王·大堤直","kind":"词"}]},"开成时儒":{"slug":"开成时儒","name":"开成时儒","dynasty":"唐","style":"","life":"","origin":"","seal":"开","bio":[],"works":[{"id":"t53-714","title":"送义存出家（题拟）","kind":"诗"},{"id":"t53-715","title":"送义存出家（题拟） 一","kind":"诗"},{"id":"t53-716","title":"送义存出家（题拟） 二","kind":"诗"},{"id":"t53-717","title":"送义存出家（题拟） 三","kind":"诗"}]},"怀濬":{"slug":"怀濬","name":"怀濬","dynasty":"唐","style":"","life":"","origin":"","seal":"怀","bio":["怀濬，秭归郡僧。诗二首。"],"works":[{"id":"t45-539","title":"上归州刺史代通状二首 一","kind":"诗"},{"id":"t45-540","title":"上归州刺史代通状二首 二","kind":"诗"},{"id":"t56-61","title":"寄南平王","kind":"诗"}]},"无际道人":{"slug":"无际道人","name":"无际道人","dynasty":"宋","style":"","life":"","origin":"","seal":"无","bio":[],"works":[{"id":"c78-211","title":"渔家傲·七坐道场三奉诏","kind":"词"}]},"朱泽":{"slug":"朱泽","name":"朱泽","dynasty":"唐","style":"","life":"","origin":"","seal":"朱","bio":[],"works":[{"id":"t48-274","title":"嘲郭凝素","kind":"诗"}]},"欧阳":{"slug":"欧阳","name":"欧阳","dynasty":"宋","style":"","life":"","origin":"","seal":"欧","bio":[],"works":[{"id":"c62-978","title":"踏莎行·雁字成行","kind":"词"}]},"潘熊飞":{"slug":"潘熊飞","name":"潘熊飞","dynasty":"宋","style":"","life":"","origin":"","seal":"潘","bio":[],"works":[{"id":"c78-652","title":"南乡子·十日后重阳","kind":"词"}]},"玄泰":{"slug":"玄泰","name":"玄泰","dynasty":"唐","style":"","life":"","origin":"","seal":"玄","bio":["玄泰，不知何许人。嗣石霜。住南岳七宝台寺，与贯休、齐己为友。","誓不立门徒，逍遥自适，时谓泰布衲。尝为曹山本寂禅师作碑。卒年六十五。","所著塔铭歌颂等，好事者编聚成集。诗三首。（《全唐诗》无玄泰诗，传据《祖堂集》卷九、《宋高僧传》卷十七）"],"works":[{"id":"t54-380","title":"畬山谣","kind":"诗"},{"id":"t54-381","title":"临化偈 一","kind":"诗"},{"id":"t54-382","title":"临化偈 二","kind":"诗"}]},"王霞卿":{"slug":"王霞卿","name":"王霞卿","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王霞卿，蓝田人，会稽宰韩嵩之妾。嵩死，霞卿流落会稽，尝题诗唐安寺。进士郑殷彝和诗求谒，霞卿荅诗拒之。","诗二首。"],"works":[{"id":"t43-960","title":"题唐安寺阁壁","kind":"诗"},{"id":"t43-961","title":"荅郑殷彝","kind":"诗"}]},"赵惠宗":{"slug":"赵惠宗","name":"赵惠宗","dynasty":"唐","style":"","life":"","origin":"","seal":"赵","bio":["赵惠宗，硖州人，通晓法箓。天宝末，忽积薪自焚，坐火中，诵度人经。火既烬，其下草犹绿，得遗简。","有诗二首。"],"works":[{"id":"t47-704","title":"遗简诗 一","kind":"诗"},{"id":"t47-705","title":"遗简诗 二","kind":"诗"}]},"赵迁":{"slug":"赵迁","name":"赵迁","dynasty":"唐","style":"","life":"","origin":"","seal":"赵","bio":["迁，大历间为左领军卫兵参军、翰林待诏，不空俗弟子。撰《不空行状》。诗二首。","（《全唐诗》无赵迁诗）"],"works":[{"id":"t52-980","title":"故功德使凉国公李将军挽歌词二首 一","kind":"诗"},{"id":"t52-981","title":"故功德使凉国公李将军挽歌词二首 二","kind":"诗"}]},"陈复休":{"slug":"陈复休","name":"陈复休","dynasty":"唐","style":"号七子","life":"","origin":"","seal":"陈","bio":["陈复休，号七子。贞元中，来举褒城，多变化之术。尝狂醉市中，褒帅怒而系于狱，不食而死，寻即臭烂，而复见于家。","中和间，大驾还京，复休亦至阙下。田晋公问京国几年安宁，曰二十，果自问后二十日，再幸陈仓。后寄诗晋公，未详其意，及驾至梁洋，邠帅朱玫立襄王监国，寒梅两枝验矣。"],"works":[{"id":"t47-829","title":"句","kind":"诗"}]},"陈朴":{"slug":"陈朴","name":"陈朴","dynasty":"宋","style":"","life":"","origin":"","seal":"陈","bio":[],"works":[{"id":"c58-567","title":"望江南・忆江南·中黄宝","kind":"词"},{"id":"c58-568","title":"望江南・忆江南·玄珠降","kind":"词"},{"id":"c58-569","title":"望江南・忆江南·毛发落","kind":"词"},{"id":"c58-570","title":"望江南・忆江南·丹往右","kind":"词"},{"id":"c58-571","title":"望江南・忆江南·珠自右","kind":"词"},{"id":"c58-572","title":"望江南・忆江南·日精满","kind":"词"},{"id":"c58-573","title":"望江南・忆江南·形透日","kind":"词"},{"id":"c58-574","title":"望江南・忆江南·内外遍","kind":"词"},{"id":"c58-575","title":"望江南・忆江南·丹九转","kind":"词"}]},"鲍氏君[徽]微":{"slug":"鲍氏君[徽]微","name":"鲍氏君[徽]微","dynasty":"唐","style":"","life":"","origin":"","seal":"鲍","bio":[],"works":[{"id":"t0-997","title":"横吹曲辞 关山月","kind":"诗"}]}}