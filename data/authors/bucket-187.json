,"title":"媿谢诗","kind":"诗"}]},"洪惠英":{"slug":"洪惠英","name":"洪惠英","dynasty":"宋","style":"","life":"","origin":"","seal":"洪","bio":[],"works":[{"id":"c66-993","title":"减字木兰花·梅花似雪","kind":"词"}]},"璘禅师":{"slug":"璘禅师","name":"璘禅师","dynasty":"唐","style":"","life":"","origin":"","seal":"璘","bio":["璘禅师，嗣文偃，住鼎州沧溪。诗一首。（《全唐诗》无璘禅师诗）"],"works":[{"id":"t55-985","title":"颂","kind":"诗"}]},"秀登":{"slug":"秀登","name":"秀登","dynasty":"唐","style":"","life":"","origin":"","seal":"秀","bio":["秀登，齐己、贯微、小白同时人，五代时在世。诗三首。（《全唐诗》无秀登诗）"],"works":[{"id":"t55-228","title":"送小白上人归华顶（一作云守恭作）","kind":"诗"},{"id":"t55-229","title":"朝海峰","kind":"诗"},{"id":"t55-230","title":"送贯微归天台","kind":"诗"}]},"程太虚":{"slug":"程太虚","name":"程太虚","dynasty":"唐","style":"号道济大师","life":"","origin":"","seal":"程","bio":["隋程太虚，西充人。自幼学道，精修勤苦。隐居南岷山，绝粒，有二虎侍左右。","九井十三峰，皆其修炼处也。一夕，大风雨，砌下得碧玉印。每乞符祈年，印以授之，辄获丰稔。","唐元和中解体，后迁神于元宫，容貌不变。宣宗命人求之，过商山，宿逆旅，蹑险有居第如公馆。青童引见，一道士自称程太虚，祖居西充。","且嘱曰：「明岁君自蜀至南岷，无忘我。」及至蜀，视画像，与前见者无异。宋赐号道济大师。","（《古今图书集成·职方典·顺庆府部》引《总志》）"],"works":[{"id":"t51-927","title":"磨剑泉","kind":"诗"},{"id":"t51-928","title":"清心泉","kind":"诗"},{"id":"t51-929","title":"漱玉泉","kind":"诗"},{"id":"t51-930","title":"洞阳峰","kind":"诗"},{"id":"t51-931","title":"醮坛峰","kind":"诗"}]},"程武":{"slug":"程武","name":"程武","dynasty":"宋","style":"","life":"","origin":"","seal":"程","bio":[],"works":[{"id":"c74-817","title":"念奴娇·蜀江城远","kind":"词"},{"id":"c74-818","title":"清平乐·曳云摇玉","kind":"词"},{"id":"c74-819","title":"小重山·香减鲛绡添泪痕","kind":"词"}]},"莫将":{"slug":"莫将","name":"莫将","dynasty":"宋","style":"","life":"","origin":"","seal":"莫","bio":[],"works":[{"id":"c64-122","title":"木兰花・玉楼春·一枝和露珍珠贯","kind":"词"},{"id":"c64-123","title":"木兰花・玉楼春·梅边晓景清无比","kind":"词"},{"id":"c64-124","title":"木兰花・玉楼春·清姿自是生寒瘦","kind":"词"},{"id":"c64-125","title":"木兰花・玉楼春·寒梢雨里愁无那","kind":"词"},{"id":"c64-126","title":"木兰花・玉楼春·寻梅莫背东风路","kind":"词"},{"id":"c64-127","title":"木兰花・玉楼春·暗香浮动黄昏后","kind":"词"},{"id":"c64-128","title":"木兰花・玉楼春·花时人道多风雨","kind":"词"},{"id":"c64-129","title":"木兰花・玉楼春·眼前欲尽情何限","kind":"词"},{"id":"c64-130","title":"木兰花・玉楼春·前村雪里虽然早","kind":"词"},{"id":"c64-131","title":"木兰花・玉楼春·少陵长被花为恼","kind":"词"},{"id":"c64-132","title":"独脚令・忆王孙·绛唇初点粉红新","kind":"词"},{"id":"c64-133","title":"浣溪沙·宝钏香裙上玉梯","kind":"词"},{"id":"c64-134","title":"浣溪沙·归梦悠扬见未真","kind":"词"}]},"蒋思恭":{"slug":"蒋思恭","name":"蒋思恭","dynasty":"宋","style":"","life":"","origin":"","seal":"蒋","bio":[],"works":[{"id":"c78-582","title":"水调歌头·紫府掣金钥","kind":"词"},{"id":"c78-583","title":"水调歌头·风流九霞客","kind":"词"}]},"辨正":{"slug":"辨正","name":"辨正","dynasty":"唐","style":"","life":"","origin":"","seal":"辨","bio":["辨正，俗姓秦，日本人。少年出家。长安间入唐，学三论宗。","曾以善棋入临淄三李隆基藩邸。客死于唐。诗二首。","（《全唐诗》无辨正诗）"],"works":[{"id":"t52-636","title":"在唐忆本乡","kind":"诗"},{"id":"t52-637","title":"与朝主人","kind":"诗"}]},"邵某":{"slug":"邵某","name":"邵某","dynasty":"宋","style":"","life":"","origin":"","seal":"邵","bio":[],"works":[{"id":"c66-164","title":"清平乐·阿郎去日","kind":"词"}]},"郑獬":{"slug":"郑獬","name":"郑獬","dynasty":"宋","style":"","life":"","origin":"","seal":"郑","bio":[],"works":[{"id":"c58-672","title":"失调名·玉环妾意无渝","kind":"词"},{"id":"c58-673","title":"好事近·江上探春回","kind":"词"},{"id":"c58-674","title":"好事近·把酒对江梅","kind":"词"}]},"阎选":{"slug":"阎选","name":"阎选","dynasty":"唐","style":"字里不详","life":"","origin":"","seal":"阎","bio":["--生卒和字里不详。后蜀时布衣，善小词，与欧阳炯、鹿虔、毛文锡、韩琮被时人称为“五鬼”。《花间集》称阎处士。","今有王国维辑《阎处士词》一卷。"],"works":[{"id":"t49-682","title":"虞美人 一","kind":"诗"},{"id":"t49-683","title":"虞美人 二","kind":"诗"},{"id":"t49-684","title":"临江仙 一","kind":"诗"},{"id":"t49-685","title":"临江仙 二","kind":"诗"},{"id":"t49-686","title":"浣溪沙","kind":"诗"},{"id":"t49-687","title":"八拍蛮 一","kind":"诗"},{"id":"t49-688","title":"八拍蛮 二","kind":"诗"},{"id":"t49-689","title":"河传","kind":"诗"},{"id":"t49-690","title":"谒金门","kind":"诗"},{"id":"t49-691","title":"定风波","kind":"诗"}]},"韦应物":{"slug":"韦应物","name":"韦应物","dynasty":"唐","style":"","life":"","origin":"","seal":"韦","bio":["韦应物，京兆长安人。少以三卫郎事明皇，晚更折节读书。永泰中，授京兆功曹，迁洛阳丞。","大历十四年，自鄠令制除栎阳令，以疾辞不就。建中三年，拜比部员外郎，出为滁州刺史。久之，调江州，追赴阙，改左司郎中，复出为苏州刺史。","应物性高洁，所在焚香埽地而坐，唯顾况、刘长卿、丘丹、秦系、皎然之俦，得厕宾客，与之酬倡。其诗闲澹简远，人比之陶潜，称陶韦云。集十卷，今编诗十卷。","韦应物，京兆长安人。少以三卫郎事明皇，晚更折节读书。永泰中，授京兆功曹，迁洛阳丞。","大历十四年，自鄠令制除栎阳令，以疾辞不就。建中三年，拜比部员外郎，出为滁州刺史。久之，调江州，追赴阙，改左司郎中，复出为苏州刺史。","应物性高洁，所在焚香扫地而坐，唯顾况、刘长卿、丘丹、秦系、皎然之俦，得厕宾客，与之酬倡。其诗闲澹简远，人比之陶潜，称陶韦云。集十卷，今编诗十卷。","韦应物，京兆长安人。生开元二十五年。少以三卫郎事明皇。","乾元间为太学生，始折节读书。永泰中为洛阳丞。大历间历仕京兆府功曹参军。","十四年，自鄠县令制除栎阳令，公疾辞不就。建中中拜尚书比部员外郎，出为滁州刺史。调江州。","追赴阙，改左司郎中。复出为苏州刺史。约卒于贞元九年。","其诗闲澹简远，人比之陶潜，称陶韦云。补诗一首。"],"works":[{"id":"t0-881","title":"鼓吹曲辞 芳树","kind":"诗"},{"id":"t0-888","title":"鼓吹曲辞 有所思","kind":"诗"},{"id":"t1-5","title":"横吹曲辞 长安道","kind":"诗"},{"id":"t1-228","title":"相和歌辞 相逢行","kind":"诗"},{"id":"t1-791","title":"杂曲歌辞 行路难","kind":"诗"},{"id":"t1-875","title":"杂曲歌辞 三台二首 一","kind":"诗"},{"id":"t1-876","title":"杂曲歌辞 三台二首 二","kind":"诗"},{"id":"t1-877","title":"杂曲歌辞 上皇三台","kind":"诗"},{"id":"t1-878","title":"杂曲歌辞 突厥三台","kind":"诗"},{"id":"t2-243","title":"杂曲歌辞 宫中调笑 一","kind":"诗"},{"id":"t2-244","title":"杂曲歌辞 宫中调笑 二","kind":"诗"},{"id":"t8-945","title":"拟古诗十二首 一","kind":"诗"},{"id":"t8-946","title":"拟古诗十二首 二","kind":"诗"},{"id":"t8-947","title":"拟古诗十二首 三","kind":"诗"},{"id":"t8-948","title":"拟古诗十二首 四","kind":"诗"},{"id":"t8-949","title":"拟古诗十二首 五","kind":"诗"},{"id":"t8-950","title":"拟古诗十二首 六","kind":"诗"},{"id":"t8-951","title":"拟古诗十二首 七","kind":"诗"},{"id":"t8-952","title":"拟古诗十二首 八","kind":"诗"},{"id":"t8-953","title":"拟古诗十二首 九","kind":"诗"},{"id":"t8-954","title":"拟古诗十二首 十","kind":"诗"},{"id":"t8-955","title":"拟古诗十二首 十一","kind":"诗"},{"id":"t8-956","title":"拟古诗十二首 十二","kind":"诗"},{"id":"t8-957","title":"杂体五首 一","kind":"诗"},{"id":"t8-958","title":"杂体五首 二","kind":"诗"},{"id":"t8-959","title":"杂体五首 三","kind":"诗"},{"id":"t8-960","title":"杂体五首 四","kind":"诗"},{"id":"t8-961","title":"杂体五首 五","kind":"诗"},{"id":"t8-962","title":"与友生野饮效陶体","kind":"诗"},{"id":"t8-963","title":"效何水部二首 一","kind":"诗"},{"id":"t8-964","title":"效何水部二首 二","kind":"诗"},{"id":"t8-965","title":"效陶彭泽","kind":"诗"},{"id":"t8-966","title":"大梁亭会李四栖梧作","kind":"诗"},{"id":"t8-967","title":"燕李录事","kind":"诗"},{"id":"t8-968","title":"淮上喜会梁川故