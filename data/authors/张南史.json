{"slug":"张南史","name":"张南史","dynasty":"唐","style":"字季直","life":"","origin":"","seal":"张","bio":["张南史，字季直，幽州人。好弈棋，其后折节读书，遂入诗境，以试参军。避乱，居扬州，再召，未赴而卒。","诗一卷。"],"works":[{"id":"t15-876","title":"富阳南楼望浙江风起","kind":"诗"},{"id":"t15-877","title":"奉酬李舍人秋日寓直见寄","kind":"诗"},{"id":"t15-878","title":"同韩侍郎秋朝使院","kind":"诗"},{"id":"t15-879","title":"送朱大游塞","kind":"诗"},{"id":"t15-880","title":"送郑录事赴太原","kind":"诗"},{"id":"t15-881","title":"送余赞善使还赴薛尚书幕","kind":"诗"},{"id":"t15-882","title":"送李侍御入茅山采药","kind":"诗"},{"id":"t15-883","title":"寄中书李舍人","kind":"诗"},{"id":"t15-884","title":"和崔中丞中秋月","kind":"诗"},{"id":"t15-885","title":"西陵怀灵一上人兼寄朱放","kind":"诗"},{"id":"t15-886","title":"寄静虚上人云门","kind":"诗"},{"id":"t15-887","title":"送司空十四北游宋州","kind":"诗"},{"id":"t15-888","title":"殷卿宅夜宴","kind":"诗"},{"id":"t15-889","title":"宣城雪后还望郡中寄孟侍御","kind":"诗"},{"id":"t15-890","title":"独孤常州北亭","kind":"诗"},{"id":"t15-891","title":"早春书事奉寄中书李舍人","kind":"诗"},{"id":"t15-892","title":"陆胜宅秋暮雨中探韵同作","kind":"诗"},{"id":"t15-893","title":"春日道中寄孟侍御","kind":"诗"},{"id":"t15-894","title":"江北春望赠皇甫补阙","kind":"诗"},{"id":"t15-895","title":"酬张二仓曹杨子闲居见寄兼呈韩郎中左补阙皇甫冉","kind":"诗"},{"id":"t15-896","title":"秋夜闻鴈寄南十五兼呈空和尚","kind":"诗"},{"id":"t15-897","title":"雪","kind":"诗"},{"id":"t15-898","title":"月","kind":"诗"},{"id":"t15-899","title":"泉","kind":"诗"},{"id":"t15-900","title":"竹","kind":"诗"},{"id":"t15-901","title":"花","kind":"诗"},{"id":"t15-902","title":"草","kind":"诗"},{"id":"t51-325","title":"竹〖1〗","kind":"诗"},{"id":"t53-55","title":"送李使君贬郴州","kind":"诗"}]}