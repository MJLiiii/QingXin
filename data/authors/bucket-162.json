{"乐史":{"slug":"乐史","name":"乐史","dynasty":"唐","style":"字子正","life":"","origin":"","seal":"乐","bio":["史，字子正，抚州宜黄人。仕南唐为秘书郎。入宋，复登进士，历水部员外郎，使两浙巡抚，判西京留司御史台，卒。","著有《太平寰宇记》、《广卓异记》、《洞仙集》等。诗一首。（《全唐诗》无乐史诗）"],"works":[{"id":"t55-500","title":"钟山寺","kind":"诗"}]},"刘邺":{"slug":"刘邺","name":"刘邺","dynasty":"唐","style":"字汉藩","life":"","origin":"","seal":"刘","bio":["刘邺，字汉藩，三复之子。咸通中，从藩幕召入内庭，特赐及第，历相位。僖宗朝，再迁尚书左仆射，死黄巢之难。","《甘棠集》三卷，今存诗二首。"],"works":[{"id":"t33-699","title":"翰林作","kind":"诗"},{"id":"t33-700","title":"待漏院吟","kind":"诗"}]},"勿翁":{"slug":"勿翁","name":"勿翁","dynasty":"宋","style":"","life":"","origin":"","seal":"勿","bio":[],"works":[{"id":"c76-598","title":"贺新郎·庭外潇潇雨","kind":"词"}]},"吴淑姬1":{"slug":"吴淑姬1","name":"吴淑姬1","dynasty":"宋","style":"","life":"","origin":"","seal":"吴","bio":[],"works":[{"id":"c64-749","title":"小重山·谢了荼䕷春事休","kind":"词"},{"id":"c64-750","title":"惜分飞·岸柳依依拖金缕","kind":"词"},{"id":"c64-751","title":"祝英台近·粉痕销","kind":"词"},{"id":"c64-752","title":"失调名·尘满妆台","kind":"词"}]},"吴淑真":{"slug":"吴淑真","name":"吴淑真","dynasty":"宋","style":"","life":"","origin":"","seal":"吴","bio":[],"works":[{"id":"c75-661","title":"霜天晓角·塞门桂月","kind":"词"}]},"天目僧":{"slug":"天目僧","name":"天目僧","dynasty":"唐","style":"","life":"","origin":"","seal":"天","bio":["天目僧，失其名。诗一首。"],"works":[{"id":"t51-35","title":"答赞宁","kind":"诗"}]},"宋先生":{"slug":"宋先生","name":"宋先生","dynasty":"宋","style":"","life":"","origin":"","seal":"宋","bio":[],"works":[{"id":"c63-904","title":"浪淘沙·师指炼金丹","kind":"词"},{"id":"c63-905","title":"浪淘沙·铅汞要加添","kind":"词"},{"id":"c63-906","title":"糖多令・唐多令·搬载渡黄河","kind":"词"},{"id":"c63-907","title":"桃源忆故人·自从师指天机道","kind":"词"},{"id":"c63-908","title":"惜黄花·天机大道","kind":"词"},{"id":"c63-909","title":"阮郎归·一轮明月照三峰","kind":"词"},{"id":"c63-910","title":"武陵春·七返阳全阴去尽","kind":"词"},{"id":"c70-67","title":"苏幕遮·气随神","kind":"词"},{"id":"c70-68","title":"丑奴儿・采桑子·真人本是凡人做","kind":"词"},{"id":"c70-69","title":"沁园春·速速修行","kind":"词"},{"id":"c70-70","title":"武陵春·七返还丹人怎晓","kind":"词"},{"id":"c70-71","title":"武陵春·虎绕龙蟠功最妙","kind":"词"},{"id":"c70-72","title":"丑奴儿・采桑子·河车怎敢停留住","kind":"词"},{"id":"c70-73","title":"丑奴儿・采桑子·因师传说朝元理","kind":"词"},{"id":"c70-74","title":"丑奴儿・采桑子·夜来子后披衣坐","kind":"词"},{"id":"c70-75","title":"太常引·金丹只在自身中","kind":"词"},{"id":"c70-76","title":"点绛唇·二气工夫","kind":"词"},{"id":"c70-77","title":"点绛唇·这个工夫","kind":"词"},{"id":"c70-78","title":"捣练子·真水火","kind":"词"},{"id":"c70-79","title":"临江仙·说甚坎离龙共虎","kind":"词"},{"id":"c70-80","title":"丑奴儿・采桑子·金公本是乾家子","kind":"词"},{"id":"c70-81","title":"浪淘沙·我有一张琴","kind":"词"}]},"宋雍":{"slug":"宋雍","name":"宋雍","dynasty":"唐","style":"","life":"","origin":"","seal":"宋","bio":[],"works":[{"id":"t43-23","title":"春日","kind":"诗"},{"id":"t43-24","title":"失题","kind":"诗"}]},"常非月":{"slug":"常非月","name":"常非月","dynasty":"唐","style":"","life":"","origin":"","seal":"常","bio":["常非月，西河尉。诗一首。"],"works":[{"id":"t10-37","title":"咏谈容娘","kind":"诗"}]},"张观":{"slug":"张观","name":"张观","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张观，楚马殷时人。诗一首。"],"works":[{"id":"t42-599","title":"过衡山赠廖处士","kind":"诗"}]},"惟审":{"slug":"惟审","name":"惟审","dynasty":"唐","style":"","life":"","origin":"","seal":"惟","bio":[],"works":[{"id":"t47-205","title":"别友人","kind":"诗"},{"id":"t47-206","title":"赋得闻晓莺啼","kind":"诗"},{"id":"t47-207","title":"春日旅怀呈知己","kind":"诗"}]},"智远":{"slug":"智远","name":"智远","dynasty":"唐","style":"","life":"","origin":"","seal":"智","bio":[],"works":[{"id":"t47-196","title":"律僧","kind":"诗"}]},"李昭象":{"slug":"李昭象","name":"李昭象","dynasty":"唐","style":"字化文","life":"","origin":"","seal":"李","bio":["李昭象，字化文，父方玄为池州刺史，因家焉。懿宗末年，以文干相国路岩。岩问其年，曰十有七矣，岩年尚少，尤器重之，荐于朝，将召试，会岩贬，遂还秋浦，移居九华，与张乔、顾云辈为方外友。","诗八首。"],"works":[{"id":"t38-665","title":"喜杜荀鹤及第","kind":"诗"},{"id":"t38-666","title":"赴举出山留寄山居郑参军","kind":"诗"},{"id":"t38-667","title":"题顾正字溪居","kind":"诗"},{"id":"t38-668","title":"寄献山中顾公员外","kind":"诗"},{"id":"t38-669","title":"山中寄崔谏议","kind":"诗"},{"id":"t38-670","title":"学仙词寄顾云","kind":"诗"},{"id":"t38-671","title":"寄尉迟侍御","kind":"诗"},{"id":"t38-672","title":"招西洞道者","kind":"诗"},{"id":"t38-673","title":"句","kind":"诗"}]},"杨齐悊":{"slug":"杨齐悊","name":"杨齐悊","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":["《全唐诗》把杨齐悊编入「无世次爵里可考」卷中，仅据《唐诗记事》载《过函谷关》一首。《珠英集》载齐悊诗二首，第二首《晓过古延各关》，即《唐诗纪事》的《过函谷关》。《珠英集》题：「洛阳县尉弘农杨齐悊」。","又《唐会要》卷三十六「修撰」条记预修《三教珠英》的二十六人姓名中，也有杨齐悊。修《全唐诗》者竟不稍加考索，置之「无世次爵里可攷」卷内，未免疏忽。兹依《珠英集》把杨齐悊排在胡皓前。"],"works":[{"id":"t50-162","title":"秋夜䜩徐四山亭（伯三七七一）","kind":"诗"}]},"欧阳朝阳":{"slug":"欧阳朝阳","name":"欧阳朝阳","dynasty":"宋","style":"","life":"","origin":"","seal":"欧","bio":[],"works":[{"id":"c76-555","title":"摸鱼儿·正当绂麟时候","kind":"词"}]},"沧浩":{"slug":"沧浩","name":"沧浩","dynasty":"唐","style":"","life":"","origin":"","seal":"沧","bio":[],"works":[{"id":"t47-219","title":"怀旧山","kind":"诗"}]},"河中鬼":{"slug":"河中鬼","name":"河中鬼","dynasty":"唐","style":"","life":"","origin":"","seal":"河","bio":[],"works":[{"id":"t47-964","title":"踏歌","kind":"诗"}]},"王感化":{"slug":"王感化","name":"王感化","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王感化，建州人，后入金陵教坊。少聪敏，未尝执卷，而多识。善为词，滑稽无穷。","元宗嗣位，宴乐击鞠不辍，尝乘醉命感化奏水调词，感化唯歌“南朝天子爱风流”一句，如是者数四。元宗悟，复杯叹曰：“使孙陈二主得此一句，不当有衔璧之辱也。”由是有宠。","诗二首。"],"works":[{"id":"t42-429","title":"建州节帅更代筵上献诗","kind":"诗"},{"id":"t42-430","title":"奉元宗命咏苑中白野鹊","kind":"诗"},{"id":"t42-431","title":"句","kind":"诗"},{"id":"t55-387","title":"咏马（题拟）","kind":"诗"}]},"王操":{"slug":"王操","name":"王操","dynasty":"唐","style":"字正美","life":"","origin":"","seal":"王","bio":["操，字正美，江左人。在南唐事迹待考。太平兴国中上《南郊赋》，授太子洗马，奉使陇右。","（《全唐诗》无王操诗，传据《增修诗话总龟前集》卷十一引《雅言系述》）"],"works":[{"id":"t55-503","title":"缺题 一","kind":"诗"},{"id":"t55-504","title":"缺题 二","kind":"诗"},{"id":"t55-505","title":"哭左偃（题拟）","kind":"诗"}]},"王绍":{"slug":"王绍","name":"王绍","dynasty":"宋","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"c76-436","title":"菩萨蛮·天正朔旦开新历","kind":"词"}]},"王苍":{"slug":"王苍","name":"王苍","dynasty":"宋","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"c74-844","title":"诉衷情·补成团扇绣残工","kind":"词"}]},"王重":{"slug":"王重","name":"王重","dynasty":"宋","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"c62-536","title":"蝶恋花·去岁花前曾记有","kind":"词"},{"id":"c62-537","title":"烛影摇红·烟雨江城","kind":"词"}]},"程师孟":{"slug":"程师孟","name":"程师孟","dynasty":"宋","style":"","life":"","origin":"","seal":"程","bio":[],"works":[{"id":"c58-566","title":"渔家傲·折柳赠君君且住","kind":"词"}]},"聂胜琼":{"slug":"聂胜琼","name":"聂胜琼","dynasty":"宋","style":"","life":"","origin":"","seal":"聂","bio":["--原为汴京歌妓，后归李之问。存词一首，断句一。"],"works":[{"id":"c64-772","title":"失调名·无计留君住","kind":"词"},{"id":"c64-773","title":"鹧鸪天·玉惨花愁出凤城","kind":"词"}]},"许坚":{"slug":"许坚","name":"许坚","dynasty":"唐","style":"字介石","life":"","origin":"","seal":"许","bio":["许坚，有异术，尝往来庐阜茅山间。李璟时，以异人召，不至，后不知所终。诗五首。","许坚，字介石，庐江人。许坚，南唐李璟时人。补诗一首。"],"works":[{"id":"t42-424","title":"登游齐山","kind":"诗"},{"id":"t42-425","title":"游溧阳下山寺","kind":"诗"},{"id":"t42-426","title":"题幽栖观","kind":"诗"},{"id":"t42-427","title":"上舍人徐铉","kind":"诗"},{"id":"t42-428","title":"题茅山观","kind":"诗"},{"id":"t47-750","title":"游溧阳霞泉寺限白字","kind":"诗"},{"id":"t47-751","title":"幽栖观","kind":"诗"},{"id":"t47-752","title":"题茅山观","kind":"诗"},{"id":"t47-753","title":"题扇","kind":"诗"},{"id":"t47-754","title":"上徐舍人铉","kind":"诗"},{"id":"t47-755","title":"句","kind":"诗"},{"id":"t51-4","title":"题失","kind":"诗"},{"id":"t51-645","title":"小桃源（一题《入黟吟》。《舆地纪胜》二十作李白诗）（未详其所自来，客游于黟，乐之，作诗云云，遂家焉。今桃源洞有许氏，盖其后裔云。或曰：坚即宣平，坚其名，宣平其字，未知是否。〖1〗）","kind":"诗"},{"id":"t51-646","title":"戢兵山（旧名石鼓山，在黟县北十五里，高百仞，周十里，有石鼓、石人、石驴。相传石鼓鸣即驴鸣，人哭而长官不利。后凿其鼓破之，遂不复鸣。唐天宝六年改今名。）","kind":"诗"},{"id":"t55-492","title":"题胡氏华林书院（题拟）","kind":"诗"}]},"赵起":{"slug":"赵起","name":"赵起","dynasty":"唐","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"t43-50","title":"奉和登会昌山应制","kind":"诗"}]},"陆质":{"slug":"陆质","name":"陆质","dynasty":"唐","style":"","life":"","origin":"","seal":"陆","bio":["质，本名淳，吴郡人。深于《春秋》。历官左拾遗、太常博士、左司郎中、信、台州刺史、给事中、皇太子侍读，贞元二十一年病卒。","诗一首。（《全唐诗》无陆质诗，传据《旧唐书·儒学传》本传）"],"works":[{"id":"t53-162","title":"送最澄阇梨还日本诗","kind":"诗"}]}}