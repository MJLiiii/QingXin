],"works":[{"id":"c60-591","title":"汉宫春·潇洒江梅","kind":"词"},{"id":"c60-592","title":"洞仙歌·一团娇软","kind":"词"},{"id":"c60-593","title":"玉蝴蝶·壮岁分符方面","kind":"词"},{"id":"c60-594","title":"念奴娇·素光练净","kind":"词"},{"id":"c60-595","title":"小冲山・小重山·谁劝东风腊里来","kind":"词"},{"id":"c60-596","title":"木兰花・玉楼春·沈吟不语晴窗畔","kind":"词"},{"id":"c60-597","title":"清平乐·露花烟柳","kind":"词"},{"id":"c60-598","title":"满庭芳·又喜椒觞到手","kind":"词"},{"id":"c60-599","title":"玉楼春·一年适尽莲花漏","kind":"词"},{"id":"c60-600","title":"满庭芳·凉风吹帽","kind":"词"},{"id":"c60-601","title":"女冠子·帝城三五","kind":"词"},{"id":"c60-602","title":"调笑令·双绿","kind":"词"}]},"杨员外":{"slug":"杨员外","name":"杨员外","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":["杨员外，名不详，与钱起同时，任考功员外郎。诗二句。（详附按）"],"works":[{"id":"t53-7","title":"赠钱起（题拟）","kind":"诗"}]},"杨炎":{"slug":"杨炎","name":"杨炎","dynasty":"唐","style":"字公南","life":"","origin":"","seal":"杨","bio":["杨炎，字公南，凤翔人。初为河西节度掌书记，拜起居舍人，历礼部郎中，迁中书舍人。与常衮并掌纶诰，衮长于除书，炎善于德音，时称常杨。","进吏部侍郎，坐附元载，贬道州司马。德宗即位，崔祐甫荐其文学器用，上亦自闻其名，拜门下侍郎同平章事，再贬崖州司马。炎初奏请内府租赋仍归左藏库，及定两税法，颇有嘉声。","专政后，惟务报讐搆害，意为爱憎，卒至赐死。集十卷，今存诗二首。"],"works":[{"id":"t5-746","title":"流崖州至鬼门关作","kind":"诗"},{"id":"t5-747","title":"赠元载歌妓","kind":"诗"}]},"林珝":{"slug":"林珝","name":"林珝","dynasty":"唐","style":"","life":"","origin":"","seal":"林","bio":[],"works":[{"id":"t43-212","title":"送安养阎主簿还竹寺","kind":"诗"}]},"武曌":{"slug":"武曌","name":"武曌","dynasty":"唐","style":"","life":"","origin":"","seal":"武","bio":[],"works":[{"id":"t51-134","title":"游石淙诗（并序）","kind":"诗"}]},"潘汾":{"slug":"潘汾","name":"潘汾","dynasty":"宋","style":"","life":"","origin":"","seal":"潘","bio":[],"works":[{"id":"c64-738","title":"倦寻芳·兽环半掩","kind":"词"},{"id":"c64-739","title":"贺新郎·篆缕销香鼎","kind":"词"},{"id":"c64-740","title":"孟家蝉·向卖花担上","kind":"词"},{"id":"c64-741","title":"花心动·啼鸟惊心","kind":"词"},{"id":"c64-742","title":"玉蝴蝶·睡起日高莺啭","kind":"词"},{"id":"c64-743","title":"丑奴儿慢・采桑子慢·愁春未醒","kind":"词"}]},"王彦威":{"slug":"王彦威","name":"王彦威","dynasty":"唐","style":"","life":"","origin":"","seal":"王","bio":["王彦威，太原人。孤贫力学，淹识古今典礼，举明经甲科，撰元和新体上之，拜博士。累擢司封郎中、弘文馆学士。","开成时，历忠宣武节度使。诗一首。"],"works":[{"id":"t28-36","title":"宣武军镇作","kind":"诗"}]},"长孙无忌":{"slug":"长孙无忌","name":"长孙无忌","dynasty":"唐","style":"字机辅","life":"","origin":"","seal":"长","bio":["长孙无忌，字机辅，河南洛阳人，文德皇后之兄。好学，有筹略，佐太宗定天下，以功第一，封齐国公，历尚书仆射、司空，诫惧盈满，固辞不许，复拜司徒。贞观十七年，图功臣二十四人于凌烟阁，无忌为之冠。","高宗即位，进册太尉，知门下省。后为许敬宗诬搆，贬死黔州。诗三首。"],"works":[{"id":"t2-417","title":"新曲二首 一","kind":"诗"},{"id":"t2-418","title":"新曲二首 二","kind":"诗"},{"id":"t2-419","title":"灞桥待李将军","kind":"诗"},{"id":"t48-202","title":"与欧阳询互嘲 一","kind":"诗"},{"id":"t48-203","title":"与欧阳询互嘲 二","kind":"诗"},{"id":"t52-106","title":"五言[仪鸾殿]早秋侍宴应诏","kind":"诗"},{"id":"t52-107","title":"五言春日侍宴望海应诏","kind":"诗"},{"id":"t52-108","title":"五言奉和行经破薛举战地应诏","kind":"诗"},{"id":"t52-109","title":"五言侍宴延庆殿同赋别题得寒桂丛应诏","kind":"诗"}]},"陈秉文":{"slug":"陈秉文","name":"陈秉文","dynasty":"宋","style":"","life":"","origin":"","seal":"陈","bio":[],"works":[{"id":"c78-495","title":"满庭芳·山涌银涛","kind":"词"}]},"韩嘉彦":{"slug":"韩嘉彦","name":"韩嘉彦","dynasty":"宋","style":"","life":"","origin":"","seal":"韩","bio":[],"works":[{"id":"c62-565","title":"玉漏迟·杏香消散尽","kind":"词"}]},"高蟾":{"slug":"高蟾","name":"高蟾","dynasty":"唐","style":"","life":"","origin":"","seal":"高","bio":["高蟾，河朔人。干符三年，登进士第。干宁间，为御史中丞。","诗一卷。"],"works":[{"id":"t1-318","title":"相和歌辞 长门怨 一","kind":"诗"},{"id":"t1-319","title":"相和歌辞 长门怨 二","kind":"诗"},{"id":"t37-189","title":"途中除夜","kind":"诗"},{"id":"t37-190","title":"长门怨","kind":"诗"},{"id":"t37-191","title":"秋日寄华阳山人","kind":"诗"},{"id":"t37-192","title":"感事","kind":"诗"},{"id":"t37-193","title":"楚思","kind":"诗"},{"id":"t37-194","title":"雪中","kind":"诗"},{"id":"t37-195","title":"道中有感","kind":"诗"},{"id":"t37-196","title":"宋汴道中","kind":"诗"},{"id":"t37-197","title":"秋思","kind":"诗"},{"id":"t37-198","title":"即事","kind":"诗"},{"id":"t37-199","title":"渔家","kind":"诗"},{"id":"t37-200","title":"关中","kind":"诗"},{"id":"t37-201","title":"归思","kind":"诗"},{"id":"t37-202","title":"下第出春明门","kind":"诗"},{"id":"t37-203","title":"华清宫","kind":"诗"},{"id":"t37-204","title":"秋