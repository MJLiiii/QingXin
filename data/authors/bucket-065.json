{"刘乙":{"slug":"刘乙","name":"刘乙","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"t49-11","title":"晓望","kind":"诗"},{"id":"t49-12","title":"山中早起","kind":"诗"}]},"姚岩杰":{"slug":"姚岩杰","name":"姚岩杰","dynasty":"唐","style":"","life":"","origin":"","seal":"姚","bio":["姚岩杰，梁公崇裔孙，以诗酒放游江左。《象溪子》二十卷，今存诗一首。"],"works":[{"id":"t37-188","title":"报颜标","kind":"诗"}]},"孙佺":{"slug":"孙佺","name":"孙佺","dynasty":"唐","style":"字麟德","life":"","origin":"","seal":"孙","bio":["孙佺，字麟德，汝州人，宰相处约子。中宗时为幽州都督。诗一首。"],"works":[{"id":"t5-314","title":"奉和九月九日登慈恩寺浮图应制","kind":"诗"}]},"岑羲":{"slug":"岑羲","name":"岑羲","dynasty":"唐","style":"字伯华","life":"","origin":"","seal":"岑","bio":["岑羲，字伯华，文本之孙，第进士。则天时，为天官员外郎。中宗朝，同中书门下三品。","景云初，进侍中，封南阳郡公，坐豫太平公主谋，伏诛。诗六首。"],"works":[{"id":"t4-931","title":"九月九日幸临渭亭登高应制得涘字","kind":"诗"},{"id":"t4-932","title":"奉和九月九日登慈恩寺浮屠应制","kind":"诗"},{"id":"t4-933","title":"饯唐州高使君","kind":"诗"},{"id":"t4-934","title":"奉和春日幸望春宫应制","kind":"诗"},{"id":"t4-935","title":"奉和幸安乐公主山庄应制","kind":"诗"},{"id":"t4-936","title":"夜宴安乐公主新宅","kind":"诗"}]},"归晓":{"slug":"归晓","name":"归晓","dynasty":"唐","style":"号惠广大师","life":"","origin":"","seal":"归","bio":["于襄州凤山延庆禅院。入宋，屡承礼敬。开宝二年，赐紫绶。","太平兴国三年赐号惠广大师。端拱元年卒，年六十六。诗一首。","（《全唐诗》无归晓诗）"],"works":[{"id":"t55-335","title":"无题","kind":"诗"},{"id":"t55-336","title":"至安陆竺乾盛会","kind":"诗"}]},"朱彦时":{"slug":"朱彦时","name":"朱彦时","dynasty":"唐","style":"","life":"","origin":"","seal":"朱","bio":[],"works":[{"id":"t57-235","title":"黑儿赋","kind":"诗"}]},"李义府":{"slug":"李义府","name":"李义府","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李义府，瀛州饶阳人。对策擢第，补门下省典仪，寻除监察御史、太子舍人，与司议郎来济俱以文翰见知，时称“来李”。尝献《承华箴》，预撰《晋书》。","高宗嗣位，迁中书舍人，以赞立武昭仪，擢中书侍郎，晋中书令，怙宠稔恶，长流巂州。存诗八首。"],"works":[{"id":"t1-980","title":"杂曲歌辞 堂堂 一","kind":"诗"},{"id":"t1-981","title":"杂曲歌辞 堂堂 二","kind":"诗"},{"id":"t2-567","title":"和边城秋气早","kind":"诗"},{"id":"t2-568","title":"招谕有怀赠同行人","kind":"诗"},{"id":"t2-569","title":"宣正殿芝草","kind":"诗"},{"id":"t2-570","title":"咏鹦鹉","kind":"诗"},{"id":"t2-571","title":"在巂州遥