[{"id":"c77-0","title":"南歌子·玉殿分时果","rhythmic":"南歌子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["玉殿分时果，金盘弄赐冰。","晚来阶下按歌声。","恰好一方明月、可中庭。","露下天如水，风来夜又清。","偏他不肯大家行。","漾下扇儿拍手、引流萤。"]},{"id":"c77-1","title":"失调名·千里伤行客","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["千里伤行客。"]},{"id":"c77-2","title":"失调名·黄叶无风自落","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["黄叶无风自落，彩云不雨空归。"]},{"id":"c77-3","title":"玉珑璁·城南路","rhythmic":"玉珑璁","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["城南路。","桥南路。","玉钩帘卷香横雾。","新相识。","旧相识。","浅颦低拍，嫩红轻碧。","惜惜惜。","刘郎去。","阮郎住。","为云为雨朝还暮。","心相忆。","空相忆。","露荷心性，柳花踪迹。","得得得。"]},{"id":"c77-4","title":"浣溪沙·碎剪香罗浥泪痕","rhythmic":"浣溪沙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["碎剪香罗浥泪痕。","鹧鸪声断不堪闻。","马嘶人去近黄昏。","整整斜斜扬柳陌，疏疏密密杏花村。","一番风月更销魂。"]},{"id":"c77-5","title":"点绛唇·燕子依依","rhythmic":"点绛唇","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["燕子依依，晓来总为谁归去。","淡云生处。","已觉宾鸿度。","浅笑深颦，便面机中素。","乘鸾女。","琐窗琼宇。","会有明年暑。"]},{"id":"c77-6","title":"踏青游·识个人人","rhythmic":"踏青游","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["识个人人，恰正二年欢会。","似赌赛、六只浑四。","向巫山、重重去，如鱼水。","两情美。","同倚画楼十二。","倚了又还重倚。","两日不来，时时在人心里。","拟问卜、常占归计。","拚三八清齐，望永同鸳被。","到梦里。","蓦然被人惊觉，梦也有头无尾。"]},{"id":"c77-7","title":"玉楼春·东风杨柳门前路","rhythmic":"玉楼春","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["东风杨柳门前路。","毕竟雕鞍留不住。","柔情胜似岭头云，别泪多如花上雨。","青楼画幕无重数。","听得楼边车马去。","若将眉黛染情深，且到丹青难画处。"]},{"id":"c77-8","title":"浣溪沙·云锁柴门半掩关","rhythmic":"浣溪沙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["云锁柴门半掩关。","垂纶犹自在前湾。","独乘孤棹夜方还。","任使有荣居紫禁，争如无事隐青山。","浮名浮利总输闲。"]},{"id":"c77-9","title":"浣溪沙·一副纶竿一只船","rhythmic":"浣溪沙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["一副纶竿一只船。","蓑衣竹笠是生缘。","五湖来往不知年。","青嶂更无荣辱到，白头终没利名牵。","芦花深处伴鸥眠。"]},{"id":"c77-10","title":"浣溪沙·钓罢高歌酒一杯","rhythmic":"浣溪沙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["钓罢高歌酒一杯。","醉醒曾笑楚臣来。","夕阳维缆碧江隈。","蓑笠每因山雨戴，船窗多为水花开。","安居流景任相催。"]},{"id":"c77-11","title":"浣溪沙·雨气兼香泛芰荷","rhythmic":"浣溪沙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["雨气兼香泛芰荷。","回舟冒雨懒披蓑。","夜阑风静水无波。","白酒追欢常恨少，青山入望岂嫌多。","人间荣辱尽从他。"]},{"id":"c77-12","title":"定风波·雨雾云收望远山","rhythmic":"定风波","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["雨雾云收望远山。","钓竿林下恣清闲。","蝉噪日斜林影转。","溪岸。","绿深红浅画屏间。","对酒狂歌时鼓枻。","更邀同志醉前湾。","待月却寻维缆处，归来，烟萝一迳接柴关。"]},{"id":"c77-13","title":"雨中花・夜行船·我有五重深深愿","rhythmic":"雨中花・夜行船","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["我有五重深深愿。","第一愿、且图久远。","二愿恰如雕梁双燕。","岁岁后、长相见。","三愿薄情相顾恋。","第四愿、永不分散。","五愿奴留收园结果，做个人宅院。"]},{"id":"c77-14","title":"望海潮·彩筒角黍","rhythmic":"望海潮","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["彩筒角黍，兰桡画舫，佳时竟吊沅湘。","古意未收，新愁又起，断魂流水茫茫。","堪笑又堪伤。","有临皋仙子，连璧檀郎。","暗约同归，远烟深处弄沧浪。","倚楼魂已飞扬。","共偷挥玉箸，痛饮霞觞。","烟水无情，揉花碎玉，空馀怨抑凄凉。","杨谢旧遗芳。","算世间纵有，不恁非常。","但看芙蓉并蒂，他日一双双。"]},{"id":"c77-15","title":"失调名·喜则喜","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["喜则喜、得入手。","愁则愁、不长久。","忻则忻、我两个斯守。","怕则怕、人来破斗。"]},{"id":"c77-16","title":"扑蝴蝶·烟条雨叶","rhythmic":"扑蝴蝶","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["烟条雨叶，绿遍江南岸。","思归倦客，寻芳来较晚。","岫边红日初斜，陌上飞花正满。","凄凉数声羌管。","怨春短。","玉人应在，明月楼中画眉懒。","蛮笺锦字，多时鱼雁断。","恨随去水东流，事与行云共远。","罗衾旧香犹暖。"]},{"id":"c77-17","title":"侍香金童·喜叶之地","rhythmic":"侍香金童","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["喜叶之地，手把怀儿摸。","甚恰恨、出题斯撞著。","内臣过得不住脚。","忙里只是，看得斑驳。","骇这一身冷汗，都如云雾薄。","比似年时头势恶。","待检又还猛想度。","只恐根底，有人寻着。"]},{"id":"c77-18","title":"啄木儿·洗出养花天气","rhythmic":"啄木儿","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["洗出养花天气。"]},{"id":"c77-19","title":"柳梢青·晓星明灭","rhythmic":"柳梢青","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["晓星明灭。","白露点、秋风落叶。","故址颓垣，荒烟衰草，溪前宫阙。","长安道上行客，念依旧、名深利切。","改变容颜，销磨古今，垅头残月。"]},{"id":"c77-20","title":"眉峰碧・卜算子·蹙破眉峰碧","rhythmic":"眉峰碧・卜算子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["蹙破眉峰碧。","纤手还重执。","镇日相看未足时，忍便使、鸳鸯只。","薄暮投村驿。","风雨愁通夕。","窗外芭蕉窗里人，分明叶上心头滴。"]},{"id":"c77-21","title":"失调名·送千里蟾宫客","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["送千里蟾宫客。"]},{"id":"c77-22","title":"失调名·来春高步过南宫","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["来春高步过南宫，更答取龙头策。"]},{"id":"c77-23","title":"失调名·恐伊不信是龙头","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["恐伊不信是龙头，和书寄与三题草。"]},{"id":"c77-24","title":"失调名·问醉吟今夜","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["问醉吟今夜，何处凤楼偏好。"]},{"id":"c77-25","title":"失调名·光生里閈","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["光生里閈，荣破天荒。"]},{"id":"c77-26","title":"行香子·清要无因","rhythmic":"行香子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["清要无因，举选艰辛。","系书钱、须要十分。","浮名浮利，虚苦劳神。","叹旅中愁，心中闷，部中身。","虽抱文章，苦苦推寻。","更休说、谁假谁真。","不如归去，作个齐民。","免一回来，一回讨，一回论。"]},{"id":"c77-27","title":"失调名·君是园中杨柳","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["君是园中杨柳，能得几时青。","趁金明、春光尚好，尊酒赏闲情。","他年归去，强山阴处，一枕晓霞清。"]},{"id":"c77-28","title":"失调名·华宫瑶馆游毕","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["华宫瑶馆游毕。","却返绛节、回鸾翼。","荷殷勤、三斝香醪，供养我、上真仙客。","赤霭浮空，祥云远布，是我来时节。","且频修，同泛舸、上云秋碧。"]},{"id":"c77-29","title":"湘灵瑟·霜风摧兰","rhythmic":"湘灵瑟","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["霜风摧兰。","银屏生晓寒。","淡扫眉山。","脸红殷。","潇湘浦，芙蓉湾。","相思数声哀叹。","画楼尊酒闲。"]},{"id":"c77-30","title":"失调名·平地一声雷","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["平地一声雷。"]},{"id":"c77-31","title":"失调名·休休得也□","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["休休得也□，云深处、高卧斜阳。"]},{"id":"c77-32","title":"失调名·单于若问君家世","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["单于若问君家世，说与教知。","便是红窗迥底儿。"]},{"id":"c77-33","title":"失调名·说与教知","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["说与教知。","便是中朝一汉儿。"]},{"id":"c77-34","title":"失调名·便是监商孟客儿","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["便是监商孟客儿。"]},{"id":"c77-35","title":"减字木兰花·家门希差","rhythmic":"减字木兰花","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["家门希差。","养得一枚依样画。","百事无能。","只去篱边缠倒藤。","几回水上。","轧捺不翻真个强。","无处容他。","只好炎天晒作巴。"]},{"id":"c77-36","title":"满庭芳·光芒","rhythmic":"满庭芳","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["光芒。","长万丈，司空见惯，应谓寻常。","……仍传□、儋崖父老，只候蔡元长。"]},{"id":"c77-37","title":"失调名·妙手庖人","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["妙手庖人，搓得细如麻线。","面儿白、心下黑，身长行短。","蓦地下来后，吓出一身冷汗。","这一场欢会，早危如累卵。","便做羊肉燥子，勃推饤碗。","终不似、引盘美满。","舞万遍。","无心看。","愁听弦管。","收盘盏。","寸肠暗断。"]},{"id":"c77-38","title":"浪淘沙·水饭恶冤家","rhythmic":"浪淘沙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["水饭恶冤家。","些小姜瓜。","尊前正欲饮流霞。","却被伊来刚打住，好闷人那。","不免着匙爬。","一似吞沙。","主人若也要人夸。","莫惜更搀三五盏，锦上添花。"]},{"id":"c77-39","title":"夜游宫·因被吾皇手诏","rhythmic":"夜游宫","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["因被吾皇手诏。","把天下、寺来改了。","大觉金仙也不小。","德士道。","却我甚头脑。","道袍须索要。","冠儿戴、恁且休笑。","最是一种祥瑞好。","古来少。","葫芦上面生芝草。"]},{"id":"c77-40","title":"西江月·早岁轻衫短帽","rhythmic":"西江月","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["早岁轻衫短帽。","中间圆顶方袍。","忽然天赐降宸毫。","接引私心入道。","可谓一身三教。","如今且得逍遥。","擎拳稽首拜云霄。","有分长生不老。"]},{"id":"c77-41","title":"青玉案·钉鞋踏破祥符路","rhythmic":"青玉案","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["钉鞋踏破祥符路。","似白鹭、纷纷去。","试盝幞头谁与度。","八厢儿事，两员直殿，怀挟无藏处。","时辰报尽天将暮。","把笔胡填备员句。","试问闲愁知几许。","两条脂烛，半盂馊饭，一阵黄昏雨。"]},{"id":"c77-42","title":"失调名·瘦得脸儿两指大","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["瘦得脸儿两指大。"]},{"id":"c77-43","title":"失调名·柳丝只解风前舞","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["柳丝只解风前舞。","诮系惹、那人不住。"]},{"id":"c77-44","title":"滴滴金·当初亲下求言诏","rhythmic":"滴滴金","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["当初亲下求言诏。","引得都来胡道。","人人招是骆宝王，并洛阳年少。","自讼监宫并岳庙。","都一时闲了。","误人多是误人多，误了人多少。"]},{"id":"c77-45","title":"水调歌头·平生太湖上","rhythmic":"水调歌头","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["平生太湖上，短棹几经过。","如今重到，何事愁与水云多。","拟把匣中长剑，换取扁舟一叶，归去老渔蓑。","银艾非吾事，丘壑已蹉跎。","脍新鲈，斟美酒，起悲歌。","太平生长，岂谓今日识兵戈。","欲泻三江雪浪，净洗胡尘千里，不用挽天河。","回首望霄汉，双泪堕清波。"]},{"id":"c77-46","title":"失调名·做园子","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["做园子，得数载。","栽培得、那花木，就中堪爱。","特将一个、保义酬劳，反做了、今日殃害。","诏书下来索金带。","这官告、看看毁坏。","放牙笏、便担屎担，却依旧种菜。"]},{"id":"c77-47","title":"失调名·叠假山","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["叠假山、得保义。","幞头上、带著百般村气。","做模样、偏得人憎，又识甚条例。","今日伏惟安置。","官诰又来索气。","不如更叠个盆山，卖八文十二。"]},{"id":"c77-48","title":"结带巾·头巾带","rhythmic":"结带巾","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["头巾带。","谁理会。","三千贯赏钱，新行条例。","不得向后长垂，与胡服相类。","法甚严，人尽畏。","便缝阔大带，向前面系。","和我太学先辈，被人呼保义。"]},{"id":"c77-49","title":"失调名·欲折花枝斜插鬓","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["欲折花枝斜插鬓。"]},{"id":"c77-50","title":"失调名·薰风时送芰荷香","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["薰风时送芰荷香。"]},{"id":"c77-51","title":"失调名·花有重开月再圆","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["花有重开月再圆。"]},{"id":"c77-52","title":"鹊桥仙·柳家一句最著题","rhythmic":"鹊桥仙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["柳家一句最著题，道暮雨、芳尘轻洒。"]},{"id":"c77-53","title":"失调名·你自平生行短","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["你自平生行短，不公正、欺物瞒心。","交年夜、将烧毁，犹自昧神明。","若还替得，你可知好里，争奈无凭。","我虽然无口，肚里清醒。","除非阎家大伯，一时间、批判昏沈。","休痴呵，临时恐怕，各自要安身。"]},{"id":"c77-54","title":"失调名·别有暗愁深意","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["别有暗愁深意。"]},{"id":"c77-55","title":"失调名·晓风吹人","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["晓风吹人，酒醒时候。"]},{"id":"c77-56","title":"失调名·海棠花谢清明后","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["海棠花谢清明后。"]},{"id":"c77-57","title":"鹧鸪天·春晓千门放钥匙","rhythmic":"鹧鸪天","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["春晓千门放钥匙。","万官班从出祥曦。","九重彩浪浮龙盖，一点红云护赭衣。","车马过，打球归。","芳尘洒定不教飞。","钧天品动回銮曲，十里珠帘待日西。"]},{"id":"c77-58","title":"鹧鸪天·日暮迎祥对御回","rhythmic":"鹧鸪天","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["日暮迎祥对御回。","宫花载路锦成堆。","天津桥畔鞭声过，宣德楼前扇影开。","奏舜乐，进尧杯。","传宣车马上天街。","君王喜与民同乐，八面三呼震地来。"]},{"id":"c77-59","title":"鹧鸪天·紫禁烟光一万重","rhythmic":"鹧鸪天","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["紫禁烟光一万重。","五门金碧射晴空。","梨园羯鼓三千面，陆海鳌山十二峰。","香雾重，月华浓。","露台仙仗彩云中。","朱栏画栋金泥幕，卷尽红莲十里风。"]},{"id":"c77-60","title":"鹧鸪天·香雾氤氲结彩山","rhythmic":"鹧鸪天","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["香雾氤氲结彩山。","蓬莱顶上驾头还。","绣鞯狨坐三千骑，玉带金鱼四十班。","风细细，佩珊珊。","一天和气转春寒。","千门万户笙萧里，十二楼台月上栏。"]},{"id":"c77-61","title":"青玉案·人生南北如歧路","rhythmic":"青玉案","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["人生南北如歧路。","世事悠悠等风絮。","造化小儿无定据。","翻来覆去，倒横直竖，眼见都如许。","伊周功业何须慕。","不学渊明便归去。","坎止流行随所寓。","玉堂金马，竹篱茅舍，总是无心处。"]},{"id":"c77-62","title":"绛都春·寒阴渐晓","rhythmic":"绛都春","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["寒阴渐晓。","报驿使探春，南枝开早。","粉蕊弄香，芳脸凝酥琼枝小。","雪天分外精神好。","向白玉堂前应到。","化工不管，朱门闭也，暗传音耗。","轻渺。","盈盈笑靥，称娇面、爱学宫妆新巧。","几度醉吟，独倚栏干黄昏后。","月笼疏影横斜照。","更莫待、单于吹老。","便须折取归来，胆瓶顿了。"]},{"id":"c77-63","title":"孤鸾·天然标格","rhythmic":"孤鸾","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["天然标格。","是小萼堆红，芳姿凝白。","淡伫新妆，浅点寿阳宫额。","东君相留厚意，倩年年、与传消息。","昨夜前村雪里，有一枝先折。","念故人、何处水云隔。","纵驿使相逢，难寄春色。","试问丹青手，是怎生描得。","晓来一番雨过，更那堪、数声羌笛。","归去和羹未晚，劝行人休摘。"]},{"id":"c77-64","title":"金菊对芙蓉·花则一名","rhythmic":"金菊对芙蓉","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["花则一名，种分三色，嫩红妖白娇黄。","正清秋佳景，雨霁风凉。","郊墟十里飘兰麝，潇洒处、旖旎非常。","自然风韵，开时不惹，蝶乱蜂狂。","携酒独揖蟾光。","问花神何属，离兑中央。","引骚人乘兴，广赋诗章。","几多才子争攀折，嫦娥道，三种深香，状元红是，黄为榜眼，白探花郎。"]},{"id":"c77-65","title":"失调名·郎马频嘶竟不来","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["郎马频嘶竟不来。"]},{"id":"c77-66","title":"失调名·轻暖轻寒","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["轻暖轻寒，正是赏花天气。"]},{"id":"c77-67","title":"失调名·盻盻秋波","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["盻盻秋波。"]},{"id":"c77-68","title":"失调名·春色恼人眠不得","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["春色恼人眠不得。"]},{"id":"c77-69","title":"失调名·千丝万绪惹春风","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["千丝万绪惹春风。"]},{"id":"c77-70","title":"失调名·燕子引雏飞","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["燕子引雏飞。"]},{"id":"c77-71","title":"失调名·莫怪沈腰易瘦","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["莫怪沈腰易瘦。"]},{"id":"c77-72","title":"失调名·双双飞燕柳边轻","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["双双飞燕柳边轻。"]},{"id":"c77-73","title":"失调名·帘卷画堂人寂静","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["帘卷画堂人寂静。"]},{"id":"c77-74","title":"失调名·一番雨过","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["一番雨过，池塘十里芰荷香。"]},{"id":"c77-75","title":"失调名·湘簟展清波","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["湘簟展清波。"]},{"id":"c77-76","title":"失调名·醉乡天广大","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["醉乡天广大。"]},{"id":"c77-77","title":"失调名·云情雨意商量雪","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["云情雨意商量雪。"]},{"id":"c77-78","title":"失调名·凤楼帘卷鳌山对","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["凤楼帘卷鳌山对。"]},{"id":"c77-79","title":"失调名·箫鼓向晚","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["箫鼓向晚。"]},{"id":"c77-80","title":"失调名·倚风三喷横竹","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["倚风三喷横竹。"]},{"id":"c77-81","title":"失调名·卷上珠帘光","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["卷上珠帘光。"]},{"id":"c77-82","title":"失调名·轻暖轻寒","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["轻暖轻寒，正是困人天气。"]},{"id":"c77-83","title":"失调名·一种相思两地愁","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["一种相思两地愁。"]},{"id":"c77-84","title":"失调名·饮尽莫留残","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["饮尽莫留残。"]},{"id":"c77-85","title":"秋霁·壬戌之秋","rhythmic":"秋霁","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["壬戌之秋，是苏子与客，泛舟赤壁。","举酒属客，月明风细，水光与天相接。","扣舷唱月。","桂棹兰桨堪游逸。","又有客。","能吹洞箫，和声鸣烟。","追想孟德、困於周郎，到今空有，当时踪迹。","算惟有、清风朗月，取之无禁用不竭。","客喜洗盏还再酌。","既已同醉，相与枕藉舟中，始知东方，晃然既白。"]},{"id":"c77-86","title":"贺新郎·步自雪堂去","rhythmic":"贺新郎","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["步自雪堂去。","望临皋、将归二客，从余遵路。","木叶萧萧霜露降，仰见天高月吐。","共对影、行歌频顾。","月白风清如此夜，叹无肴、有酒成虚度。","闻薄暮，网罾举。","归而斗酒谋诸妇。","便携鳞载酒，相从旧追游处。","断岸横江寻赤壁，不复江山如故，但放舟、中流容与。","客去冥然方就睡，梦蹁跹、羽衣揖余语。","相顾笑，遂惊寤。"]},{"id":"c77-87","title":"如梦令·韵似江梅标致","rhythmic":"如梦令","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["韵似江梅标致。","美似江梅多丽。","清似腊梅香，白似雪梅香腻，非是。","非是。","我道梅花似你。"]},{"id":"c77-88","title":"忆秦娥·暮云碧","rhythmic":"忆秦娥","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["暮云碧。","佳人不见愁如织。","愁如织。","两行征雁，数声羌笛。","锦书难寄西飞翼。","无言只是空相忆。","空相忆。","纱窗人梦，梦双人只。"]},{"id":"c77-89","title":"忆秦娥·娇滴滴","rhythmic":"忆秦娥","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["娇滴滴。","双眉敛破春山色。","春山色。","为君含笑，为君愁蹙。","多情别后无消息。","此时更有谁知得。","谁知得。","夜深无寐，度江横笛。"]},{"id":"c77-90","title":"忆秦娥·秋寂寂","rhythmic":"忆秦娥","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["秋寂寂。","碧纱窗外人横笛。","人横笛。","天津桥上，旧曾听得。","宫妆玉指无人识。","龙吟水底声初息。","声初息。","月明江上，数峰凝碧。"]},{"id":"c77-91","title":"浪淘沙·帘外五更风","rhythmic":"浪淘沙","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["帘外五更风。","吹梦无踪。","画楼重上与谁同。","记得玉钗斜拨火，宝篆成空。","回首紫金峰。","雨润烟浓。","一江春浪醉醒中。","留得罗襟前日泪，弹与征鸿。"]},{"id":"c77-92","title":"满庭芳·碧落横秋","rhythmic":"满庭芳","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["碧落横秋，浮云崩浪，夜凉先到梧桐。","荷花十丈，人在赤城中。","凤髻尚梳雾湿，眉峰翠、的烁双瞳。","多应是，金丹一粒，点就蕊仙宫。","相逢。","蓬岛客，酒翻银海，一饮如虹。","弄横玉招月，吹上层空。","青鸾传书满座，蟠桃树、已结轻红。","拚沉醉，人间拍手，一笑有东风。"]},{"id":"c77-93","title":"失调名·和尚性好耍","rhythmic":"失调名","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["和尚性好耍。","贪恋一枝花。","见说醉归明月夜。","滋味难禁价。","金帛宁论价。","毒手遭他下。","料想从今难更也。","空惹傍人话。"]},{"id":"c77-94","title":"望江南・忆江南·江南竹","rhythmic":"望江南・忆江南","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["江南竹，巧匠织成笼。","赠与吾师藏法体，碧潭深处伴蛟龙。","色即是成空。"]},{"id":"c77-95","title":"西江月·早晚以成行色","rhythmic":"西江月","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["早晚以成行色，主人莫与留延。","正当春月艳阳天。","去赛从前心愿。","执状去呈仙尉，殷勤早与周旋。","不辞客路往来难，暂辍舞裙歌扇。"]},{"id":"c77-96","title":"燕山亭·风雨无情","rhythmic":"燕山亭","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["风雨无情，红药吐时，下得恹恹摧挫。","云艳卷凉，旋汲银屏，收拾二三千朵。","长日留伊，要把酒、不教放过。","无那。","越放纵香心，越盘来大。","特地点检笙歌，先要吹个、六么曲破。","总是少年，负却才名，佳客共伊围坐。","粉薄香浓，为笑多、不肯梳裹。","知麽。","须醉倒、今宵伴我。"]},{"id":"c77-97","title":"鹧鸪天·山色晴岚景物佳","rhythmic":"鹧鸪天","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["山色晴岚景物佳。","暖烘回雁起平沙。","东郊渐觉花供眼，南陌依稀草吐芽。","堤上柳，未藏鸦。","寻芳趁步到山家。","陇头几树红梅落，红杏枝头未著花。"]},{"id":"c77-98","title":"眼儿媚·深闺小院日初长","rhythmic":"眼儿媚","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["深闺小院日初长。","娇女绮罗裳。","不做东君造化，金针刺绣群芳样。","斜枝嫩叶包开蕊。","唯只欠馨香。","曾向园林深处，引教蝶乱蜂狂。"]},{"id":"c77-99","title":"南乡子·帘卷水西楼","rhythmic":"南乡子","author":"无名氏","authorSlug":"无名氏","dynasty":"宋","kind":"ci","paragraphs":["帘卷水西楼。","一曲新腔唱打油。","宿雨眠云年少梦，休讴。","且尽生前酒一瓯。","明日又登舟。","却指今宵是旧游。","同是他乡沦落客，休愁。","月子弯弯照几州。"]}]