{"slug":"乔知之","name":"乔知之","dynasty":"唐","style":"","life":"","origin":"","seal":"乔","bio":["乔知之，同州冯翊人，与弟侃、备竝以文词知名，知之尤称俊才。则天时，累除右补阙，迁左司郎中，为武承嗣所害。诗一卷。"],"works":[{"id":"t0-970","title":"横吹曲辞 折杨柳","kind":"诗"},{"id":"t1-140","title":"相和歌辞 铜雀妓","kind":"诗"},{"id":"t1-169","title":"相和歌辞 从军行","kind":"诗"},{"id":"t1-912","title":"杂曲歌辞 定情篇","kind":"诗"},{"id":"t4-318","title":"长信宫中树","kind":"诗"},{"id":"t4-319","title":"下山逢故夫","kind":"诗"},{"id":"t4-320","title":"巫山高","kind":"诗"},{"id":"t4-321","title":"弃妾篇","kind":"诗"},{"id":"t4-322","title":"苦寒行","kind":"诗"},{"id":"t4-323","title":"从军行","kind":"诗"},{"id":"t4-324","title":"拟古赠陈子昂","kind":"诗"},{"id":"t4-325","title":"定情篇","kind":"诗"},{"id":"t4-326","title":"绿珠篇","kind":"诗"},{"id":"t4-327","title":"和李侍郎古意","kind":"诗"},{"id":"t4-328","title":"倡女行","kind":"诗"},{"id":"t4-329","title":"羸骏篇","kind":"诗"},{"id":"t4-330","title":"铜雀妓","kind":"诗"},{"id":"t4-331","title":"侍宴应制得分字","kind":"诗"},{"id":"t4-332","title":"梨园亭子侍宴","kind":"诗"},{"id":"t4-333","title":"和苏员外寓直","kind":"诗"},{"id":"t4-334","title":"哭故人","kind":"诗"},{"id":"t4-335","title":"折杨柳","kind":"诗"}]}