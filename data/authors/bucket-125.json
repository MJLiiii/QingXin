{"了元":{"slug":"了元","name":"了元","dynasty":"宋","style":"","life":"","origin":"","seal":"了","bio":[],"works":[{"id":"c59-595","title":"满庭芳·鳞甲何多","kind":"词"}]},"仁贞":{"slug":"仁贞","name":"仁贞","dynasty":"唐","style":"","life":"","origin":"","seal":"仁","bio":["仁贞，唐末渤海僧，曾东渡日本国。（《日本古典文学大系》本《文华秀丽集》日本学者注载仁贞文史事迹云：弘仁五年〖公元八一四年〗来朝〖指日本〗，为渤海国使录事。六年，授从五位下。","同年五月归国，船破，王孝廉卒，仁贞携其稿入日本，后卒。）诗一首。（《全唐诗》无仁贞诗）"],"works":[{"id":"t51-20","title":"七日禁中陪宴","kind":"诗"}]},"何蠲":{"slug":"何蠲","name":"何蠲","dynasty":"唐","style":"","life":"","origin":"","seal":"何","bio":["何蠲，前进士。诗二首。（《全唐诗》无何蠲诗）"],"works":[{"id":"t56-321","title":"渔父歌沧浪赋附歌 一","kind":"诗"},{"id":"t56-322","title":"渔父歌沧浪赋附歌 二","kind":"诗"}]},"刘幽求":{"slug":"刘幽求","name":"刘幽求","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":["刘幽求，冀州武强人。圣历中，举制科，中第。临淄王入诛韦庶人，幽求预参大策，是夜所下制敕百余道，皆出其手，以功授中书舍人。","睿宗即位，行尚书右丞，迁吏部尚书，拜侍中。开元初，改尚书左右仆射为左右丞相，乃以幽求为左丞相。后坐怨望，贬卒。","诗一首。"],"works":[{"id":"t5-192","title":"书怀","kind":"诗"}]},"刘庄物":{"slug":"刘庄物","name":"刘庄物","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":["刘庄物，开成中人，诗一首。"],"works":[{"id":"t30-169","title":"莺出谷","kind":"诗"}]},"庄南杰":{"slug":"庄南杰","name":"庄南杰","dynasty":"唐","style":"","life":"","origin":"","seal":"庄","bio":["庄南杰，进士，与贾岛同时，杂歌行一卷，今存诗五首。庄南杰，进士，与贾岛同时，杂歌行一卷，今存诗五首。"],"works":[{"id":"t0-894","title":"鼓吹曲辞 黄雀行","kind":"诗"},{"id":"t1-259","title":"相和歌辞 雁门太守行","kind":"诗"},{"id":"t1-467","title":"相和歌辞 阳春曲","kind":"诗"},{"id":"t1-624","title":"杂曲歌辞 伤歌行","kind":"诗"},{"id":"t25-152","title":"湘弦曲","kind":"诗"},{"id":"t25-153","title":"黄雀行","kind":"诗"},{"id":"t25-154","title":"雁门太守行","kind":"诗"},{"id":"t25-155","title":"阳春曲","kind":"诗"},{"id":"t25-156","title":"伤歌行","kind":"诗"},{"id":"t48-868","title":"红蔷薇","kind":"诗"},{"id":"t48-869","title":"晓歌","kind":"诗"},{"id":"t48-870","title":"春草歌","kind":"诗"},{"id":"t48-871","title":"古松歌","kind":"诗"},{"id":"t51-443","title":"寄郑碏叠石砚歌","kind":"诗"}]},"李朋":{"slug":"李朋","name":"李朋","dynasty":"唐","style":"","life":"","origin":"","seal":"李","bio":["李朋，刑部员外郎，诗一首。"],"works":[{"id":"t31-361","title":"奉酬绵州中丞以江山小图远垂赐及兼寄诗","kind":"诗"}]},"李程":{"slug":"李程","name":"李程","dynasty":"唐","style":"字表臣 · 号八塼学士","life":"","origin":"","seal":"李","bio":["李程，字表臣，陇西人。贞元十二年，登进士第。累辟使府，为监察御史，充翰林学士。","元和中，知制诰，拜礼部侍郎。敬宗即位，以吏部侍郎同平章事，后罢为河东节度使。程在翰苑，日过八塼乃至，时号八塼学士。","诗五首。"],"works":[{"id":"t19-599","title":"春台晴望","kind":"诗"},{"id":"t19-600","title":"玉壶冰","kind":"诗"},{"id":"t19-601","title":"赋得竹箭有筠","kind":"诗"},{"id":"t19-602","title":"观庆云图","kind":"诗"},{"id":"t19-603","title":"赠毛仙翁","kind":"诗"}]},"殷文圭":{"slug":"殷文圭","name":"殷文圭","dynasty":"唐","style":"","life":"","origin":"","seal":"殷","bio":["殷文圭，池州人。居九华，苦学，所用墨池，底为之穴。唐末，词场请托公行，文圭与游恭独步场屋。","干宁中及第，为裴枢宣谕判官。后事杨行密，终左千牛卫将军。诗一卷。"],"works":[{"id":"t39-816","title":"八月十五夜","kind":"诗"},{"id":"t39-817","title":"省试夜投献座主","kind":"诗"},{"id":"t39-818","title":"观贺皇太子册命","kind":"诗"},{"id":"t39-819","title":"行朝早春侍师门宴西溪席上作","kind":"诗"},{"id":"t39-820","title":"贺同年第三人刘先辈咸辟命","kind":"诗"},{"id":"t39-821","title":"寄广南刘仆射","kind":"诗"},{"id":"t39-822","title":"题吴中陆龟蒙山斋","kind":"诗"},{"id":"t39-823","title":"经李翰林墓","kind":"诗"},{"id":"t39-824","title":"鹦鹉","kind":"诗"},{"id":"t39-825","title":"边将别","kind":"诗"},{"id":"t39-826","title":"江南秋日","kind":"诗"},{"id":"t39-827","title":"题友人庭竹","kind":"诗"},{"id":"t39-828","title":"览陆龟蒙旧集","kind":"诗"},{"id":"t39-829","title":"玉仙道中","kind":"诗"},{"id":"t39-830","title":"赵侍郎看红白牡丹因寄杨状头赞图","kind":"诗"},{"id":"t39-831","title":"题胡州太学丘光庭博士幽居","kind":"诗"},{"id":"t39-832","title":"初秋留别越中幕客","kind":"诗"},{"id":"t39-833","title":"送道者朝见后归山","kind":"诗"},{"id":"t39-834","title":"赠战将","kind":"诗"},{"id":"t39-835","title":"九华贺雨吟","kind":"诗"},{"id":"t39-836","title":"赠池州张太守","kind":"诗"},{"id":"t39-837","title":"中秋自宛陵寄池阳太守","kind":"诗"},{"id":"t39-838","title":"次韵九华杜先辈重阳寄投宛陵丞相","kind":"诗"},{"id":"t39-839","title":"寄贺杜荀鹤及第","kind":"诗"},{"id":"t39-840","title":"春草碧色","kind":"诗"},{"id":"t39-841","title":"和友人送衡尚书赴池阳副车","kind":"诗"},{"id":"t39-842","title":"贻李南平","kind":"诗"},{"id":"t39-843","title":"句","kind":"诗"},{"id"