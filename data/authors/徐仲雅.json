{"slug":"徐仲雅","name":"徐仲雅","dynasty":"唐","style":"","life":"","origin":"","seal":"徐","bio":["徐仲雅，其先秦中人，徙居长沙，事马氏，为观察判官、天册府学士。所业百余卷行世，今存诗六首。"],"works":[{"id":"t42-569","title":"畊夫谣","kind":"诗"},{"id":"t42-570","title":"赠齐己","kind":"诗"},{"id":"t42-571","title":"赠江处士","kind":"诗"},{"id":"t42-572","title":"东华观偃松","kind":"诗"},{"id":"t42-573","title":"咏椶树","kind":"诗"},{"id":"t42-574","title":"宫词","kind":"诗"},{"id":"t42-575","title":"句","kind":"诗"},{"id":"t51-785","title":"潭州（讽楚王之侈）","kind":"诗"},{"id":"t55-960","title":"桃源（题拟）","kind":"诗"},{"id":"t55-961","title":"东华观偃松（补序）","kind":"诗"}]}