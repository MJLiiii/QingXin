{"何":{"slug":"何","name":"何","dynasty":"宋","style":"","life":"","origin":"","seal":"何","bio":[],"works":[{"id":"c64-702","title":"采桑子·百花丛里花君子","kind":"词"},{"id":"c64-703","title":"虞美人·分香帕子揉蓝腻","kind":"词"},{"id":"c64-704","title":"失调名·便饶你","kind":"词"},{"id":"c64-705","title":"失调名·细雨共斜风","kind":"词"}]},"卢延让":{"slug":"卢延让","name":"卢延让","dynasty":"唐","style":"字子善","life":"","origin":"","seal":"卢","bio":["卢延让，字子善，范阳人。光化九年进士第，朗陵雷满辟从事。满败，归王建，授水部员外郎，累迁给事中，终刑郎侍郎。","诗一卷，今存十首。卢延让，字子善，范阳人，光化九年进士第。朗陵雷满辟从事，满败，归王建，授水部员外郎。","累迁给事中，终刑郎侍郎。诗一卷，今存十首。"],"works":[{"id":"t40-318","title":"苦吟","kind":"诗"},{"id":"t40-319","title":"雪","kind":"诗"},{"id":"t40-320","title":"松寺","kind":"诗"},{"id":"t40-321","title":"赠僧","kind":"诗"},{"id":"t40-322","title":"逢友人赴阙","kind":"诗"},{"id":"t40-323","title":"哭李郢端公","kind":"诗"},{"id":"t40-324","title":"谢杨尚书惠樱桃","kind":"诗"},{"id":"t40-325","title":"寒食日戏赠李侍御","kind":"诗"},{"id":"t40-326","title":"樊川寒食二首 一","kind":"诗"},{"id":"t40-327","title":"樊川寒食二首 二","kind":"诗"},{"id":"t40-328","title":"句","kind":"诗"},{"id":"t48-309","title":"哭亡将诗","kind":"诗"},{"id":"t48-957","title":"八月十六夜月","kind":"诗"},{"id":"t48-958","title":"冬除夜书情","kind":"诗"},{"id":"t48-959","title":"观新岁朝贺","kind":"诗"},{"id":"t51-701","title":"吊孟浩然（后二句）","kind":"诗"},{"id":"t51-702","title":"怀江上（句）（卢延逊五举方登第。〖2〗尝作诗云。「狐冲」二句，租庸张相濬每诵之。又「饿猫」二句，成中令汭激赏之。又「栗爆」二句，王中懿建爱之。卢尝谓人曰：「平生投谒公卿，不意得猫儿狗子之力也。」） 一","kind":"诗"},{"id":"t51-703","title":"怀江上（句）（卢延逊五举方登第。〖2〗尝作诗云。「狐冲」二句，租庸张相濬每诵之。又「饿猫」二句，成中令汭激赏之。又「栗爆」二句，王中懿建爱之。卢尝谓人曰：「平生投谒公卿，不意得猫儿狗子之力也。」） 二","kind":"诗"},{"id":"t51-704","title":"怀江上（句）（卢延逊五举方登第。〖2〗尝作诗云。「狐冲」二句，租庸张相濬每诵之。又「饿猫」二句，成中令汭激赏之。又「栗爆」二句，王中懿建爱之。卢尝谓人曰：「平生投谒公卿，不意得猫儿狗子之力也。」） 三","kind":"诗"},{"id":"t56-239","title":"冬夜宴柳驸马陟宅得更字","kind":"诗"}]},"司马光":{"slug":"司马光","name":"司马光","dynasty":"宋","style":"字君实","life":"","origin":"涑水乡","seal":"司","bio":["--(1019－1086) 字君实，陕州夏县 (今属山西) 涑水乡人，世称涑水先生。宝元元年 (1038) 进士。仁宗末年任天章阁待制兼侍讲，知谏院。","神宗时反对王安石变法，出知永兴军。哲宗元初，拜尚书左仆射兼门下侍郎。为相八月，病卒。","著有《司马文正公集》、《稽古录》，并主修《资冶通鉴》。存词三首。"],"works":[{"id":"c58-619","title":"阮郎归·渔舟容易入春山","kind":"词"},{"id":"c58-620","title":"西江月·宝髻松松挽就","kind":"词"},{"id":"c58-621","title":"锦堂春・锦堂春慢·红日迟迟","kind":"词"}]},"吉逾":{"slug":"吉逾","name":"吉逾","dynasty":"唐","style":"","life":"","origin":"","seal":"吉","bio":["吉逾，建中贞元间人，官范阳县丞。诗一首。（《全唐诗》无吉逾诗）"],"works":[{"id":"t50-632","title":"题云居上寺（并序）","kind":"诗"}]},"孟翔":{"slug":"孟翔","name":"孟翔","dynasty":"唐","style":"","life":"","origin":"","seal":"孟","bio":[],"works":[{"id":"t49-43","title":"奉和郎中游仙山四瀑布兼寄李吏部包秘监判官","kind":"诗"}]},"宜春头陀":{"slug":"宜春头陀","name":"宜春头陀","dynasty":"唐","style":"","life":"","origin":"","seal":"宜","bio":["宜春头陀，姓名不详，会昌间结庵宜春之钟村，自称年已一百四五十，村氓彭叟与其善，传其歌辞。诗一首。（《全唐诗》无宜春头陀诗）"],"works":[{"id":"t53-740","title":"歌","kind":"诗"}]},"崔绩":{"slug":"崔绩","name":"崔绩","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":["崔绩，大历进士第。诗一首。"],"works":[{"id":"t15-552","title":"小苑春望宫池柳色","kind":"诗"}]},"崔藩":{"slug":"崔藩","name":"崔藩","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":[],"works":[{"id":"t43-295","title":"暗投明珠","kind":"诗"}]},"应物":{"slug":"应物","name":"应物","dynasty":"唐","style":"","life":"","origin":"","seal":"应","bio":["应物，大中时江南诗僧也，尝与罗邺唱酬，作《九华山记》。诗二首。"],"works":[{"id":"t45-461","title":"龙潭","kind":"诗"},{"id":"t45-462","title":"题化城寺","kind":"诗"}]},"张嘉贞":{"slug":"张嘉贞","name":"张嘉贞","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["张嘉贞，蒲州猗氏人。以五经举，补平乡尉。则天召见，与语大悦，擢监察御史，累迁中书舍人。","开元中，拜中书令，后出为定州刺史，知北平军事。将行，上自赋诗，诏百僚出饯于上东门外。嘉贞至州，于恒岳庙中立颂，自为文书石，累封河东侯。","诗三首。"],"works":[{"id":"t5-438","title":"恩敕尚书省僚宴昆明池应制","kind":"诗"},{"id":"t5-439","title":"奉和早登太行山中言志应制","kind":"诗"},{"id":"t5-440","title":"奉和圣制送张说巡边","kind":"诗"},{"id":"t5-441","title":"句","kind":"诗"}]},"张琼英":{"slug":"张琼英","name":"张琼英","dynasty":"宋","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"c75-662","title":"满江红·太液芙蓉","kind":"词"}]},"张陵":{"slug":"张陵","name":"张陵","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"t43-72","title":"虏患","kind":"诗"}]},"朱晦":{"slug":"朱