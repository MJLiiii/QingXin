"kind":"词"},{"id":"c64-281","title":"清平乐·红莲照晚","kind":"词"},{"id":"c64-282","title":"人月圆·封人祝望尧云了","kind":"词"},{"id":"c64-283","title":"西江月·易老方惊岁晚","kind":"词"},{"id":"c64-284","title":"惜分飞·年少春心花里转","kind":"词"},{"id":"c64-285","title":"减字木兰花·思堂醇酎","kind":"词"}]},"戚逍遥":{"slug":"戚逍遥","name":"戚逍遥","dynasty":"唐","style":"","life":"","origin":"","seal":"戚","bio":["戚逍遥，冀州南宫人。幼好道，父以女诫授逍遥，逍遥曰：“此常人之事耳。”遂取老子仙经诵之。","年二十余，适同邑蒯浔，不为尘俗事，惟独居一室，绝食静想，作歌云云，人悉以为妖。一夜，闻室内有人语声。又三日，忽闻屋裂声如雷，仰视天半，逍遥与仙众俱在云中，历历闻分别语，观望无不惊叹。"],"works":[{"id":"t47-838","title":"歌","kind":"诗"}]},"朱涣":{"slug":"朱涣","name":"朱涣","dynasty":"宋","style":"","life":"","origin":"","seal":"朱","bio":[],"works":[{"id":"c73-75","title":"百岁令·瑞芳楼下","kind":"词"},{"id":"c78-213","title":"齐天乐·白云封断仙岩路","kind":"词"}]},"李慧之":{"slug":"李慧之","name":"李慧之","dynasty":"宋","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"c76-583","title":"沁园春·八九十翁","kind":"词"}]},"李縠":{"slug":"李縠","name":"李縠","dynasty":"唐","style":"字德师","life":"","origin":"","seal":"李","bio":["李縠，字德师，咸通进士，唐末为浙东观察推官，兼殿中侍御史。诗四首。"],"works":[{"id":"t34-759","title":"浙东罢府西归酬别张广文皮先辈陆秀才","kind":"诗"},{"id":"t34-760","title":"和皮日休悼鸖 一","kind":"诗"},{"id":"t34-761","title":"和皮日休悼鸖 二","kind":"诗"},{"id":"t34-762","title":"醉中袭美先月中归","kind":"诗"}]},"楼枎":{"slug":"楼枎","name":"楼枎","dynasty":"宋","style":"","life":"","origin":"","seal":"楼","bio":[],"works":[{"id":"c73-855","title":"水龙吟·素蛾洗尽繁妆","kind":"词"},{"id":"c73-856","title":"菩萨蛮·丝丝杨柳莺声近","kind":"词"},{"id":"c73-857","title":"沁园春·开辟以来","kind":"词"}]},"沈蔚":{"slug":"沈蔚","name":"沈蔚","dynasty":"宋","style":"","life":"","origin":"","seal":"沈","bio":[],"works":[{"id":"c62-583","title":"满庭芳·柳与堤回","kind":"词"},{"id":"c62-584","title":"满庭芳·雪底寻梅","kind":"词"},{"id":"c62-585","title":"满庭芳·疏木藏钟","kind":"词"},{"id":"c62-586","title":"临江仙·过尽清明三月雨","kind":"词"},{"id":"c62-587","title":"梦玉人引·旧追游处","kind":"词"},{"id":"c62-588","title":"蓦山溪·想伊不住","kind":"词"},{"id":"c62-589","title":"汉宫春·别酒初醒","kind":"词"},{"id":"c62-590","title":"寻梅·今年早觉花信蹉","kind":"词"},{"i