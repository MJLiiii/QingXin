{"冷朝阳":{"slug":"冷朝阳","name":"冷朝阳","dynasty":"唐","style":"","life":"","origin":"","seal":"冷","bio":["冷朝阳，金陵人。登大历进士第，为薛嵩从事。诗十一首。"],"works":[{"id":"t16-569","title":"同张深秀才游华严寺","kind":"诗"},{"id":"t16-570","title":"中秋与空上人同宿华严寺","kind":"诗"},{"id":"t16-571","title":"宿柏岩寺","kind":"诗"},{"id":"t16-572","title":"登灵善寺塔","kind":"诗"},{"id":"t16-573","title":"瀑布泉","kind":"诗"},{"id":"t16-574","title":"冬日逢冯法曹话怀","kind":"诗"},{"id":"t16-575","title":"送唐六赴举","kind":"诗"},{"id":"t16-576","title":"送远上人归京","kind":"诗"},{"id":"t16-577","title":"别郎上人","kind":"诗"},{"id":"t16-578","title":"立春","kind":"诗"},{"id":"t16-579","title":"送红线","kind":"诗"},{"id":"t51-326","title":"晚次渭上","kind":"诗"}]},"刘仁父":{"slug":"刘仁父","name":"刘仁父","dynasty":"宋","style":"","life":"","origin":"","seal":"刘","bio":[],"works":[{"id":"c76-596","title":"踏莎行·不假牵丝","kind":"词"}]},"司马□":{"slug":"司马□","name":"司马□","dynasty":"唐","style":"","life":"","origin":"","seal":"司","bio":[],"works":[{"id":"t56-300","title":"题伏波庙","kind":"诗"}]},"孟云卿":{"slug":"孟云卿","name":"孟云卿","dynasty":"唐","style":"","life":"","origin":"","seal":"孟","bio":["孟云卿，河南人，一曰武昌人。第进士，为校书郎，与杜甫、元结友善。诗一卷。"],"works":[{"id":"t1-65","title":"相和歌辞 挽歌","kind":"诗"},{"id":"t1-626","title":"杂曲歌辞 悲哉行","kind":"诗"},{"id":"t1-809","title":"杂曲歌辞 古别离","kind":"诗"},{"id":"t1-831","title":"杂曲歌辞 生别离","kind":"诗"},{"id":"t7-633","title":"古别离","kind":"诗"},{"id":"t7-634","title":"今别离","kind":"诗"},{"id":"t7-635","title":"悲哉行","kind":"诗"},{"id":"t7-636","title":"行行且游猎篇","kind":"诗"},{"id":"t7-637","title":"古挽歌","kind":"诗"},{"id":"t7-638","title":"放歌行","kind":"诗"},{"id":"t7-639","title":"伤怀赠故人","kind":"诗"},{"id":"t7-640","title":"邺城怀古","kind":"诗"},{"id":"t7-641","title":"伤情","kind":"诗"},{"id":"t7-642","title":"伤时二首 一","kind":"诗"},{"id":"t7-643","title":"伤时二首 二","kind":"诗"},{"id":"t7-644","title":"田园观雨兼晴后作","kind":"诗"},{"id":"t7-645","title":"汴河阻风","kind":"诗"},{"id":"t7-646","title":"行路难","kind":"诗"},{"id":"t7-647","title":"途中寄友人","kind":"诗"},{"id":"t7-648","title":"寒食","kind":"诗"},{"id":"t7-649","title":"新安江上寄处士","kind":"诗"},{"id":"t7-650","title":"句","kind":"诗"}]},"宇文融":{"slug":"宇文融","name":"宇文融","dynasty":"唐","style":"","life":"","origin":"","seal":"宇","bio":["宇文融，京兆万年人。明辨，有吏干。开元初，拜监察御史，充使搜括户口，奏置劝农判官十人，分行天下，颇扰人不便。","进御史中丞，出为魏州刺史，请复九河旧道，开稻田以利人，回易陆运。入为鸿胪卿，兼户部侍郎，转黄门侍郎，同中书门下平章事，荐宋璟为右丞相，裴耀卿、许景先为侍郎，甚允朝廷之望。未几罢相，坐事贬严州卒。","诗一首。"],"works":[{"id":"t5-387","title":"奉和圣制左丞相说右丞相璟太子少傅乾曜同日上官命宴都堂赐诗","kind":"诗"}]},"宣宗皇帝李忱":{"slug":"宣宗皇帝李忱","name":"宣宗皇帝李忱","dynasty":"唐","style":"","life":"","origin":"","seal":"宣","bio":["宣宗皇帝李忱，宪宗第十三子。元和五年生，母曰孝明皇后郑氏。武宗会昌六年即帝位，其明年改元大中，在位十三年而卒。","补诗一首。"],"works":[{"id":"t50-375","title":"南安夕阳山真寂寺题诗","kind":"诗"},{"id":"t53-914","title":"浮云宫","kind":"诗"},{"id":"t53-915","title":"悼盐官和尚（题拟《祖庭事苑》拟。《海昌胜迹志》题作《悟空塔》）","kind":"诗"},{"id":"t53-916","title":"送崔铉赴淮南","kind":"诗"},{"id":"t53-917","title":"题天乙山寺","kind":"诗"}]},"崔公辅":{"slug":"崔公辅","name":"崔公辅","dynasty":"唐","style":"","life":"","origin":"","seal":"崔","bio":["公辅，清河人。行十三。进士及第，与杜甫同时，曾任评事，官至雅州刺史。","（《全唐诗》无崔公辅诗。据《新唐书》卷七二《宰相世系表》及《舆地纪胜》录其事迹。）"],"works":[{"id":"t53-16","title":"同李使君渭游等慈寺（题拟）","kind":"诗"}]},"张绍":{"slug":"张绍","name":"张绍","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"t49-23","title":"冲佑观","kind":"诗"}]},"归耕子":{"slug":"归耕子","name":"归耕子","dynasty":"唐","style":"","life":"","origin":"","seal":"归","bio":["归耕子，自称为士之不遇者，幼习文武之艺，好奇异之状，天复二年撰《神仙炼丹点铸三元宝照法》。诗一首。（《全唐诗》无归耕子诗）"],"works":[{"id":"t54-352","title":"𬬻养丹歌","kind":"诗"}]},"徐一初":{"slug":"徐一初","name":"徐一初","dynasty":"宋","style":"","life":"","origin":"","seal":"徐","bio":["--生平待考。存词一首，见于《吴礼部诗话》。"],"works":[{"id":"c76-408","title":"摸鱼儿·对茱萸","kind":"词"}]},"懒堂女子":{"slug":"懒堂女子","name":"懒堂女子","dynasty":"宋","style":"","life":"","origin":"","seal":"懒","bio":[],"works":[{"id":"c61-99","title":"烛影摇红·绿净湖光","kind":"词"}]},"李久善":{"slug":"李久善","name":"李久善","dynasty":"宋","style":"","life":"","origin":"","seal":"李","bio":[],"works":[{"id":"c64-462","title":"念奴娇·东君试手","kind":"词"},{"id":"c64-463","title":"蝶恋花·莺掷垂杨","kind":"词"}