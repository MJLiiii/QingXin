{"元□□":{"slug":"元□□","name":"元□□","dynasty":"唐","style":"","life":"","origin":"","seal":"元","bio":[],"works":[{"id":"t56-297","title":"石门精室诗","kind":"诗"}]},"刘瞻":{"slug":"刘瞻","name":"刘瞻","dynasty":"唐","style":"","life":"","origin":"","seal":"刘","bio":["等职。出为河东节度使，入为京兆尹。十年，同平章事，次年因同昌公主事贬外，入朝以太子宾客分司。","（《全唐诗》无刘瞻诗，传录《旧唐书》卷一七七本传）"],"works":[{"id":"t54-87","title":"无题","kind":"诗"},{"id":"t54-88","title":"竹枝词（送李庚）","kind":"诗"}]},"吴淑姬2":{"slug":"吴淑姬2","name":"吴淑姬2","dynasty":"宋","style":"","life":"","origin":"","seal":"吴","bio":[],"works":[{"id":"c66-187","title":"长相思令・长相思·烟霏霏","kind":"词"}]},"太学诸生":{"slug":"太学诸生","name":"太学诸生","dynasty":"宋","style":"","life":"","origin":"","seal":"太","bio":[],"works":[{"id":"c66-997","title":"南乡子·洪迈被拘留","kind":"词"}]},"彦光":{"slug":"彦光","name":"彦光","dynasty":"唐","style":"","life":"","origin":"","seal":"彦","bio":["彦光，五代吴时扬州惠照寺俗讲僧。诗一首。（《全唐诗》无彦光诗）"],"works":[{"id":"t55-350","title":"答谢建偈（题拟）","kind":"诗"}]},"徐仲雅":{"slug":"徐仲雅","name":"徐仲雅","dynasty":"唐","style":"","life":"","origin":"","seal":"徐","bio":["徐仲雅，其先秦中人，徙居长沙，事马氏，为观察判官、天册府学士。所业百余卷行世，今存诗六首。"],"works":[{"id":"t42-569","title":"畊夫谣","kind":"诗"},{"id":"t42-570","title":"赠齐己","kind":"诗"},{"id":"t42-571","title":"赠江处士","kind":"诗"},{"id":"t42-572","title":"东华观偃松","kind":"诗"},{"id":"t42-573","title":"咏椶树","kind":"诗"},{"id":"t42-574","title":"宫词","kind":"诗"},{"id":"t42-575","title":"句","kind":"诗"},{"id":"t51-785","title":"潭州（讽楚王之侈）","kind":"诗"},{"id":"t55-960","title":"桃源（题拟）","kind":"诗"},{"id":"t55-961","title":"东华观偃松（补序）","kind":"诗"}]},"志定":{"slug":"志定","name":"志定","dynasty":"唐","style":"","life":"","origin":"","seal":"志","bio":[],"works":[{"id":"t47-244","title":"逸句","kind":"诗"}]},"沈韬文":{"slug":"沈韬文","name":"沈韬文","dynasty":"唐","style":"","life":"","origin":"","seal":"沈","bio":["沈韬文，湖州人。事钱镠为元帅府典谒，累官左卫上将军，改湖州刺史。诗一首。"],"works":[{"id":"t42-625","title":"游西湖","kind":"诗"}]},"游次公":{"slug":"游次公","name":"游次公","dynasty":"宋","style":"字子明 · 号西池","life":"","origin":"建安（今属福建）","seal":"游","bio":["--字子明，号西池，建安 (今属福建) 人。范成大帅桂林，以文章见知，参内幕。淳熙十四年 (1187) 通判汀州。","存词五首。"],"works":[{"id":"c59-872","title":"贺新郎·暖霭浮晴篽","kind":"词"},{"id":"c59-873","title":"卜算子·风雨送人来","kind":"词"},{"id":"c59-874","title":"满江红·云接苍梧","kind":"词"},{"id":"c59-875","title":"贺新郎·斗柄回秋律","kind":"词"},{"id":"c59-876","title":"满江红·一舸归来","kind":"词"}]},"王娇姿":{"slug":"王娇姿","name":"王娇姿","dynasty":"宋","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"c76-628","title":"失调名·兀自未归来","kind":"词"}]},"王野":{"slug":"王野","name":"王野","dynasty":"宋","style":"","life":"","origin":"","seal":"王","bio":[],"works":[{"id":"c72-745","title":"西河·天下事","kind":"词"},{"id":"c72-746","title":"六州歌头·龙蟠虎踞","kind":"词"},{"id":"c72-747","title":"沁园春·月地云阶","kind":"词"}]},"王铎":{"slug":"王铎","name":"王铎","dynasty":"唐","style":"字昭范","life":"","origin":"","seal":"王","bio":["王铎，字昭范，宰相播之从子。会昌初，擢进士第，咸通时拜相。黄巢之乱，命为行营都统，封晋公。","后落职，节度沧景，为魏博节度乐从训所害。诗三首。"],"works":[{"id":"t30-947","title":"和于兴宗登越王楼诗","kind":"诗"},{"id":"t30-948","title":"谒梓潼张恶子庙","kind":"诗"},{"id":"t30-949","title":"罢都统守镇滑州作","kind":"诗"},{"id":"t30-950","title":"句","kind":"诗"},{"id":"t54-189","title":"[拟]送贺秘监归会稽诗","kind":"诗"}]},"省澄":{"slug":"省澄","name":"省澄","dynasty":"唐","style":"号净禅师","life":"","origin":"","seal":"省","bio":["省澄，俗姓阮，泉州仙游县人。嗣保福，在泉州，世称福先招庆和尚。闽王钦重，赐号净禅师。","诗七首。（《全唐诗》无省澄诗，传据《祖堂集》卷十三、《景德传灯录》卷二十二。《五灯会元》卷八作「省僜」。","）"],"works":[{"id":"t55-808","title":"示执坐禅者颂","kind":"诗"},{"id":"t55-809","title":"示坐禅方便颂","kind":"诗"},{"id":"t55-810","title":"颂三首 一","kind":"诗"},{"id":"t55-811","title":"颂三首 二","kind":"诗"},{"id":"t55-812","title":"颂三首 三","kind":"诗"},{"id":"t55-813","title":"答国师","kind":"诗"},{"id":"t55-814","title":"长庆和尚赞","kind":"诗"}]},"花仲胤":{"slug":"花仲胤","name":"花仲胤","dynasty":"宋","style":"","life":"","origin":"","seal":"花","bio":[],"works":[{"id":"c64-759","title":"南乡子·顿首起情人","kind":"词"}]},"蜀中酒阁道人":{"slug":"蜀中酒阁道人","name":"蜀中酒阁道人","dynasty":"唐","style":"","life":"","origin":"","seal":"蜀","bio":[],"works":[{"id":"t47-797","title":"歌","kind":"诗"}]},"蜀太后徐氏":{"slug":"蜀太后徐氏","name":"蜀太后徐氏","dynasty":"唐","style":"","life":"","origin":"","seal":"蜀","bio":["成都徐耕，生二女，皆有国色，能为诗，蜀王建纳之，姊为贤妃，娣为淑妃。王衍即位，册贤妃为顺圣太后，淑妃为翊圣太妃。咸康元年，衍奉太后太妃同祷青城山，凡游历之处，各赋诗刻于石，共十六首。"],"works":[{"id":"t0-355","title":"丈人观","kind":"诗"},{"id":"t0-356","title":"玄都观","kind":"诗"},{"id":"t0-357","title":"丈人观谒先帝御容","kind":"诗"},{"id":"t0-358","title":"题金华宫","kind":"诗"},{"id":"t0-359","title":"丹景山至德寺","kind":"诗"},{"id":"t0-360","title":"题彭州阳平化","kind":"诗"},{"id":"t0-361","title":"三学山夜看圣灯","kind":"诗"},{"id":"t0-362","title":"题天回驿","kind":"诗"}]},"褚载":{"slug":"褚载","name":"褚载","dynasty":"唐","style":"字厚之","life":"","origin":"","seal":"褚","bio":["褚载，字厚之。干宁二年，登进士第。诗一卷，今存诗十四首。"],"works":[{"id":"t39-64","title":"投节度邢公","kind":"诗"},{"id":"t39-65","title":"贺赵观文重试及第","kind":"诗"},{"id":"t39-66","title":"赠道士","kind":"诗"},{"id":"t39-67","title":"晓发","kind":"诗"},{"id":"t39-68","title":"晓感","kind":"诗"},{"id":"t39-69","title":"南徐晚望","kind":"诗"},{"id":"t39-70","title":"移石","kind":"诗"},{"id":"t39-71","title":"瀑布","kind":"诗"},{"id":"t39-72","title":"定鼎门","kind":"诗"},{"id":"t39-73","title":"陈仓驿","kind":"诗"},{"id":"t39-74","title":"长城","kind":"诗"},{"id":"t39-75","title":"吊秦叟","kind":"诗"},{"id":"t39-76","title":"云","kind":"诗"},{"id":"t39-77","title":"鹤","kind":"诗"},{"id":"t39-78","title":"句","kind":"诗"}]},"谭意哥":{"slug":"谭意哥","name":"谭意哥","dynasty":"宋","style":"","life":"","origin":"","seal":"谭","bio":[],"works":[{"id":"c64-756","title":"极相思令・极相思·湘东最是得春先","kind":"词"},{"id":"c64-757","title":"长相思令・长相思·旧燕初归","kind":"词"}]},"贾彦璋":{"slug":"贾彦璋","name":"贾彦璋","dynasty":"唐","style":"","life":"","origin":"","seal":"贾","bio":[],"works":[{"id":"t43-169","title":"晚霁登汝南大云阁","kind":"诗"},{"id":"t43-170","title":"宿香山阁","kind":"诗"},{"id":"t43-171","title":"苏著作山池","kind":"诗"},{"id":"t43-172","title":"王龙骧墓","kind":"诗"}]},"郑虔":{"slug":"郑虔","name":"郑虔","dynasty":"唐","style":"","life":"","origin":"","seal":"郑","bio":["郑虔，荥阳人。天宝初，为协律郎，坐事谪官。明皇爱其才，特置广文馆，授为博士，迁著作郎。","以陷安禄山，贬台州司户参军。最善杜甫，又与秘书监郑审篇翰齐价。虔工画山水，好书，常苦无纸，乃于慈恩寺贮柿叶数屋，日往取叶肄书，岁久殆尽。","尝