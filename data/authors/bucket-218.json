":"c62-276","title":"渔家傲·浦口潮来沙尾涨","kind":"词"},{"id":"c62-277","title":"传言玉女·一夜东风","kind":"词"},{"id":"c62-278","title":"如梦令·帘外新来双燕","kind":"词"},{"id":"c62-279","title":"如梦令·墙外辘轳金并","kind":"词"},{"id":"c62-280","title":"如梦令·门在垂杨阴里","kind":"词"},{"id":"c62-281","title":"上林春慢·帽落宫花","kind":"词"},{"id":"c62-282","title":"汉宫春·潇洒江梅","kind":"词"},{"id":"c62-283","title":"小重山·碧水浮瓜纹簟前","kind":"词"}]},"杨廷玉":{"slug":"杨廷玉","name":"杨廷玉","dynasty":"唐","style":"","life":"","origin":"","seal":"杨","bio":[],"works":[{"id":"t48-224","title":"回波词","kind":"诗"}]},"段文昌":{"slug":"段文昌","name":"段文昌","dynasty":"唐","style":"字墨卿","life":"","origin":"","seal":"段","bio":["段文昌，字墨卿，一字景初。贞元初，授校书郎，累擢翰林学士、中书舍人。穆宗即位，拜中书侍郎同中书门下平章事，未逾年，出为劒南、西川节度使。","文宗立，拜御史大夫，节度淮南，徙荆南，终西川节度。集三十卷，今存诗四首。"],"works":[{"id":"t0-673","title":"郊庙歌辞 享太庙乐章 象德舞","kind":"诗"},{"id":"t17-559","title":"享太庙乐章","kind":"诗"},{"id":"t17-560","title":"题武担寺西台","kind":"诗"},{"id":"t17-561","title":"晚夏登张仪楼呈院中诸公","kind":"诗"},{"id":"t17-562","title":"还别业寻龙华山寺广宣上人","kind":"诗"}]},"胡嘉鄢":{"slug":"胡嘉鄢","name":"胡嘉鄢","dynasty":"唐","style":"","life":"","origin":"","seal":"胡","bio":["嘉鄢，天宝初人。诗一首。（《全唐诗》无胡嘉鄢诗）"],"works":[{"id":"t52-789","title":"送贺秘监归会稽诗","kind":"诗"}]},"苗发":{"slug":"苗发","name":"苗发","dynasty":"唐","style":"","life":"","origin":"","seal":"苗","bio":["苗发，宰相晋卿之子。终都官员外郎，大历十才子之一也。诗二首。"],"works":[{"id":"t15-857","title":"送司空曙之苏州","kind":"诗"},{"id":"t15-858","title":"送孙德谕罢官往黔州","kind":"诗"},{"id":"t52-993","title":"酬李端得山中道友书见寄之作（题拟）","kind":"诗"}]},"蒲宗孟":{"slug":"蒲宗孟","name":"蒲宗孟","dynasty":"宋","style":"","life":"","origin":"","seal":"蒲","bio":[],"works":[{"id":"c58-677","title":"望梅花·一阳初起","kind":"词"}]},"郑颋":{"slug":"郑颋","name":"郑颋","dynasty":"唐","style":"","life":"","origin":"","seal":"郑","bio":["郑颋，荥阳人，为王世充御史大夫。太宗围城时，乞为浮屠，世充恶而杀之。诗一首。"],"works":[{"id":"t41-185","title":"临刑诗","kind":"诗"}]}}