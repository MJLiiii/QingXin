{"伍彬":{"slug":"伍彬","name":"伍彬","dynasty":"唐","style":"","life":"","origin":"","seal":"伍","bio":["伍彬，邳阳人，初仕楚，后入宋。诗一首。"],"works":[{"id":"t42-576","title":"分水岭","kind":"诗"},{"id":"t42-577","title":"句","kind":"诗"}]},"国邵南":{"slug":"国邵南","name":"国邵南","dynasty":"唐","style":"","life":"","origin":"","seal":"国","bio":[],"works":[{"id":"t48-173","title":"梦崔嘏妻诗","kind":"诗"}]},"师备":{"slug":"师备","name":"师备","dynasty":"唐","style":"","life":"","origin":"","seal":"师","bio":["师备，姓谢，福州闽县人。嗣雪峰。住福州玄沙院，世称玄沙和尚。","开平二年卒，年七十四。诗八首。（《全唐诗》无师备诗，传据《祖堂集》卷十、《宋高僧传》卷十三、《景德传灯录》卷十八。","）"],"works":[{"id":"t55-718","title":"送灵云和尚颂（题拟）","kind":"诗"},{"id":"t55-719","title":"偈 一","kind":"诗"},{"id":"t55-720","title":"偈 二","kind":"诗"},{"id":"t55-721","title":"偈 三","kind":"诗"},{"id":"t55-722","title":"颂 一","kind":"诗"},{"id":"t55-723","title":"颂 二","kind":"诗"},{"id":"t55-724","title":"颂 三","kind":"诗"},{"id":"t55-725","title":"颂 四","kind":"诗"}]},"庄布":{"slug":"庄布","name":"庄布","dynasty":"唐","style":"","life":"","origin":"","seal":"庄","bio":[],"works":[{"id":"t51-445","title":"石榴歌","kind":"诗"}]},"张成可":{"slug":"张成可","name":"张成可","dynasty":"宋","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"c78-584","title":"洞仙歌·薰风池阁","kind":"词"}]},"张明中":{"slug":"张明中","name":"张明中","dynasty":"宋","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"c78-540","title":"贺新郎·卓茕欧阳子","kind":"词"}]},"张柬之":{"slug":"张柬之","name":"张柬之","dynasty":"唐","style":"字孟将","life":"","origin":"","seal":"张","bio":["张柬之，字孟将，襄阳人。涉猎经史，尤好三礼。举进士，贤良对策第一，授监察御史。","圣历中，为凤阁舍人，弘文馆学士。长安中，令举宰相材，以姚崇荐，迁凤阁侍郎，知政事。及诛二张兄弟，柬之首谋也。","中宗即位，以功擢天官尚书，封汉阳王，迁中书令，为武三思所搆，贬死。集十卷，今存诗五首。"],"works":[{"id":"t1-431","title":"相和歌辞 大堤曲","kind":"诗"},{"id":"t1-741","title":"杂曲歌辞 东飞伯劳歌","kind":"诗"},{"id":"t5-186","title":"大堤曲","kind":"诗"},{"id":"t5-187","title":"东飞伯劳歌","kind":"诗"},{"id":"t5-188","title":"出塞","kind":"诗"},{"id":"t5-189","title":"与国贤良夜歌二首 一","kind":"诗"},{"id":"t5-190","title":"与国贤良夜歌二首 二","kind":"诗"}]},"张生":{"slug":"张生","name":"张生","dynasty":"唐","st