{"何师心":{"slug":"何师心","name":"何师心","dynasty":"宋","style":"","life":"","origin":"","seal":"何","bio":[],"works":[{"id":"c69-762","title":"满江红·一水飞空","kind":"词"}]},"全济时":{"slug":"全济时","name":"全济时","dynasty":"唐","style":"","life":"","origin":"","seal":"全","bio":["全济时，贞元间广文馆进士。诗一首。（《全唐诗》无全济时诗）"],"works":[{"id":"t53-168","title":"送最澄上人还日本国","kind":"诗"}]},"周匡物":{"slug":"周匡物","name":"周匡物","dynasty":"唐","style":"字几本 · 号各部委已经先生","life":"","origin":"","seal":"周","bio":["周匡物，字几本，漳州人。元和十一年进士及第，仕至高州刺史。诗五首。","周匡物字几本，龙溪人。元和十一年进士及第，御试《学殖赋》、《莺出谷诗》，为世传诵。读书天城山，敕改其山为名第山，因号各部委已经先生。","仕至高州刺史。补诗一首。"],"works":[{"id":"t26-136","title":"古镜歌","kind":"诗"},{"id":"t26-137","title":"及第谣","kind":"诗"},{"id":"t26-138","title":"及第后谢座主","kind":"诗"},{"id":"t26-139","title":"自题读书堂","kind":"诗"},{"id":"t26-140","title":"应举题钱塘公馆","kind":"诗"},{"id":"t50-646","title":"无题","kind":"诗"},{"id":"t50-647","title":"三桥隐居歌","kind":"诗"}]},"夏宝松":{"slug":"夏宝松","name":"夏宝松","dynasty":"唐","style":"","life":"","origin":"","seal":"夏","bio":[],"works":[{"id":"t43-694","title":"句","kind":"诗"}]},"张伯寿":{"slug":"张伯寿","name":"张伯寿","dynasty":"宋","style":"","life":"","origin":"","seal":"张","bio":[],"works":[{"id":"c78-294","title":"水调歌头·天地有英气","kind":"词"},{"id":"c78-295","title":"临江仙·天上姮娥元不老","kind":"词"},{"id":"c78-296","title":"临江仙·吴越家声传铁券","kind":"词"},{"id":"c78-297","title":"临江仙·家住清湘云外窟","kind":"词"},{"id":"c78-298","title":"临江仙·龙首凤池家鼎贵","kind":"词"},{"id":"c78-299","title":"临江仙·瑞气薰城春色早","kind":"词"},{"id":"c78-300","title":"临江仙·爆竹声残天未晓","kind":"词"}]},"张绰":{"slug":"张绰","name":"张绰","dynasty":"唐","style":"","life":"","origin":"","seal":"张","bio":["绰，天宝初人。诗一首。（《全唐诗》无张绰诗）"],"works":[{"id":"t52-793","title":"送贺秘监归会稽诗","kind":"诗"}]},"房琯":{"slug":"房琯","name":"房琯","dynasty":"唐","style":"字次律","life":"","origin":"","seal":"房","bio":["房琯，字次律，河南人，则天时平章事融之子，以门荫补弘文生。开元中，明皇将封岱岳，琯撰封禅书以献。张说奇其才，授秘书省校书郎，又应堪任县令举，为卢氏令，寻拜监察御史。","天宝初，迁主客员外，累宪部侍郎。明皇幸蜀，琯独驰赴行在，上大悦，即日拜文部尚书，同平章事。与左相韦见素等奉册灵武，因陈时事，言词慷慨，肃宗为之改容，诏持节充招讨节度等使。","后为贺兰进明所搆，罢相，寻贬邠州刺史。诗一首。"],"works":[{"id":