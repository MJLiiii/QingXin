{"slug":"林滋","name":"林滋","dynasty":"唐","style":"字后象","life":"","origin":"","seal":"林","bio":["林滋，字后象，闽人。会昌三年进士第，与同年詹雄、郑𫍯齐名，时称雄诗、𫍯文、滋赋为闽中三绝。官终金部郎中。","诗六首。"],"works":[{"id":"t30-592","title":"望九华山","kind":"诗"},{"id":"t30-593","title":"春望","kind":"诗"},{"id":"t30-594","title":"蠡泽旅怀","kind":"诗"},{"id":"t30-595","title":"宴韦侍御新亭","kind":"诗"},{"id":"t30-596","title":"人日","kind":"诗"},{"id":"t30-597","title":"和主司王起","kind":"诗"}]}