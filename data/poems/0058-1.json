[{"id":"c58-100","title":"诉衷情·东风杨柳欲青青","rhythmic":"诉衷情","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["东风杨柳欲青青。","烟淡雨初晴。","恼他香阁浓睡，撩乱有啼莺。","眉叶细，舞腰轻。","宿妆成。","一春芳意，三月和风，牵系人情。"]},{"id":"c58-101","title":"诉衷情·芙蓉金菊斗馨香","rhythmic":"诉衷情","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["芙蓉金菊斗馨香。","天气欲重阳。","远村秋色如画，红树间疏黄。","流水淡，碧天长。","路茫茫。","凭高目断，鸿雁来时，无限思量。"]},{"id":"c58-102","title":"诉衷情·数枝金菊对芙蓉","rhythmic":"诉衷情","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["数枝金菊对芙蓉。","摇落意重重。","不知多少幽怨，和露泣西风。","人散后，月明中。","夜寒浓。","谢娘愁卧，潘令闲眠，心事无穷。"]},{"id":"c58-103","title":"诉衷情·露莲双脸远山眉","rhythmic":"诉衷情","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["露莲双脸远山眉。","偏与淡妆宜。","小庭帘幕春晚，闲共柳丝垂。","人别后，月圆时。","信迟迟。","心心念念，说尽无凭，只是相思。"]},{"id":"c58-104","title":"诉衷情·秋风吹绽北池莲","rhythmic":"诉衷情","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["秋风吹绽北池莲。","曙云楼阁鲜。","画堂今日嘉会，齐拜玉炉烟。","斟美酒，祝芳筵。","奉觥船。","宜春耐夏，多福庄严，富贵长年。"]},{"id":"c58-105","title":"诉衷情·世间荣贵月中人","rhythmic":"诉衷情","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["世间荣贵月中人。","嘉庆在今辰。","兰堂帘幕高卷，清唱遏行云。","持玉盏，敛红巾。","祝千春。","榴花寿酒，金鸭炉香，岁岁长新。"]},{"id":"c58-106","title":"诉衷情·海棠珠缀一重重","rhythmic":"诉衷情","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["海棠珠缀一重重。","清晓近帘栊。","胭脂谁与匀淡，偏向脸边浓。","看叶嫩，惜花红。","意无穷。","如花似叶，岁岁年年，共占春风。"]},{"id":"c58-107","title":"胡捣练·小桃花与早梅花","rhythmic":"胡捣练","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["小桃花与早梅花，尽是芳妍品格。","未上东风先拆。","分付春消息。","佳人钗上玉尊前，朵朵秾香堪惜。","谁把彩豪描得。","免恁轻抛掷。"]},{"id":"c58-108","title":"人娇·二月春风","rhythmic":"人娇","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["二月春风，正是杨花满路。","那堪更、别离情绪。","罗巾掩泪，任粉痕沾污。","争奈向、千留万留不住。","玉酒频倾，宿眉愁聚。","空肠断、宝筝弦柱。","人间后会，又不知何处。","魂梦里、也须时时飞去。"]},{"id":"c58-109","title":"人娇·玉树微凉","rhythmic":"人娇","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["玉树微凉，渐觉银河影转。","林叶静、疏红欲遍。","朱帘细雨，尚迟留归燕。","嘉庆日、多少世人良愿。","楚竹惊鸾，秦筝起雁。","萦舞袖、急翻罗荐。","云回一曲，更轻栊檀板。","香炷远、同祝寿期无限。"]},{"id":"c58-110","title":"人娇·一叶秋高","rhythmic":"人娇","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["一叶秋高，向夕红兰露坠。","风月好、乍凉天气。","长生此日，见人中嘉瑞。","斟寿酒、重唱妙声珠缀。","凤莞移宫，钿衫回袂。","帘影动、鹊炉香细。","南真宝箓，赐玉京千岁。","良会永、莫惜流霞同醉。"]},{"id":"c58-111","title":"踏莎行·细草愁烟","rhythmic":"踏莎行","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["细草愁烟，幽花怯露。","凭阑总是销魂处。","日高深院静无人，时时海燕双飞去。","带缓罗衣，香残蕙炷。","天长不禁迢迢路。","垂杨只解惹春风，何曾系得行人住。"]},{"id":"c58-112","title":"踏莎行·祖席离歌","rhythmic":"踏莎行","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["祖席离歌，长亭别宴。","香尘已隔犹回面。","居人匹马映林嘶，行人去棹依波转。","画阁魂消，高楼目断。","斜阳只送平波远。","无穷无尽是离愁，天涯地角寻思遍。"]},{"id":"c58-113","title":"踏莎行·碧海无波","rhythmic":"踏莎行","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["碧海无波，瑶台有路。","思量便合双飞去。","当时轻别意中人，山长水远知何处。","绮席凝尘，香闺掩雾。","红笺小字凭谁附。","高楼目尽欲黄昏，梧桐叶上萧萧雨。"]},{"id":"c58-114","title":"踏莎行·绿树归莺","rhythmic":"踏莎行","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["绿树归莺，雕梁别燕。","春光一去如流电。","当歌对酒莫沈吟，人生有限情无限。","弱袂萦春，修蛾写怨。","秦筝宝柱频移雁。","尊中绿醑意中人，花朝月夜长相见。"]},{"id":"c58-115","title":"踏莎行·小径红稀","rhythmic":"踏莎行","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["小径红稀，芳郊绿遍。","高台树色阴阴见。","春风不解禁杨花，濛濛乱扑行人面。","翠叶藏莺，朱帘隔燕。","炉香静逐游丝转。","一场愁梦酒醒时，斜阳却照深深院。"]},{"id":"c58-116","title":"渔家傲·画鼓声中昏又晓","rhythmic":"渔家傲","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["画鼓声中昏又晓。","时光只解催人老。","求得浅欢风日好。","齐揭调。","神仙一曲渔家傲。","绿水悠悠天杳杳。","浮生岂得长年少。","莫惜醉来开口笑。","须信道。","人间万事何时了。"]},{"id":"c58-117","title":"渔家傲·荷叶荷花相间斗","rhythmic":"渔家傲","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["荷叶荷花相间斗。","红娇绿嫩新妆就。","昨日小池疏雨后。","铺锦绣。","行人过去频回首。","倚遍朱阑凝望久。","鸳鸯浴处波文皱。","谁唤谢娘斟美酒。","萦舞袖。","当筵劝我千长寿。"]},{"id":"c58-118","title":"渔家傲·荷叶初开犹半卷","rhythmic":"渔家傲","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["荷叶初开犹半卷。","荷花欲拆犹微绽。","此叶此花真可羡。","秋水畔。","青凉伞映红妆面。","美酒一杯留客宴。","拈花摘叶情无限。","争奈世人多聚散。","频祝愿。","如花似叶长相见。"]},{"id":"c58-119","title":"渔家傲·杨柳风前香百步","rhythmic":"渔家傲","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["杨柳风前香百步。","盘心碎点真珠露。","疑是水仙开洞府。","妆景趣。","红幢绿盖朝天路。","小鸭飞来稠闹处。","三三两两能言语。","饮散短亭人欲去。","留不住。","黄昏更下萧萧雨。"]},{"id":"c58-120","title":"渔家傲·粉笔丹青描未得","rhythmic":"渔家傲","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["粉笔丹青描未得。","金针彩线功难敌。","谁傍暗香轻采摘。","风淅淅。","船头触散双鸂鶒。","夜雨染成天水碧。","朝阳借出胭脂色。","欲落又开人共惜。","秋气逼。","盘中已见新莲菂。"]},{"id":"c58-121","title":"渔家傲·叶下鵁鶄眠未稳","rhythmic":"渔家傲","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["叶下鵁鶄眠未稳。","风翻露飐香成阵。","仙女出游知远近。","羞借问。","饶将绿扇遮红粉。","一掬蕊黄沾雨润。","天人乞与金英嫩。","试折乱条醒酒困。","应有恨。","芳心拗尽丝无尽。"]},{"id":"c58-122","title":"渔家傲·罨画溪边停彩舫","rhythmic":"渔家傲","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["罨画溪边停彩舫。","仙娥绣被呈新样。","飒飒风声来一饷。","愁四望。","残红片片随波浪。","琼脸丽人青步障。","风牵一袖低相向。","应有锦鳞闲倚傍。","秋水上。","时时绿柄轻摇扬。"]},{"id":"c58-123","title":"渔家傲·宿蕊斗攒金粉闹","rhythmic":"渔家傲","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["宿蕊斗攒金粉闹。","青房暗结蜂儿小。","敛面似啼开似笑。","天与貌。","人间不是铅华少。","叶软香清无限好。","风头日脚乾催老。","待得玉京仙子到。","凭向道。","红颜只合长年少。"]},{"id":"c58-124","title":"渔家傲·脸傅朝霞衣剪翠","rhythmic":"渔家傲","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["脸傅朝霞衣剪翠。","重重占断秋江水。","一曲采莲风细细。","人未醉。","鸳鸯不合惊飞起。","欲摘嫩条嫌绿刺。","闲敲画扇偷金蕊。","半夜月明珠露坠。","多少意。","红腮点点相思泪。"]},{"id":"c58-125","title":"渔家傲·越女采莲江北岸","rhythmic":"渔家傲","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["越女采莲江北岸。","轻桡短棹随风便。","人貌与花相斗艳。","流水慢。","时时照影看妆面。","莲叶层层张绿伞。","莲房个个垂金盏。","一把藕丝牵不断。","红日晚。","回头欲去心撩乱。"]},{"id":"c58-126","title":"渔家傲·粉面啼红腰束素","rhythmic":"渔家傲","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["粉面啼红腰束素。","当年拾翠曾相遇。","密意深情谁与诉。","空怨慕。","西池夜夜风兼露。","池上夕阳笼碧树。","池中短棹惊微雨。","水泛落英何处去。","人不语。","东流到了无停住。"]},{"id":"c58-127","title":"渔家傲·幽鹭慢来窥品格","rhythmic":"渔家傲","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["幽鹭慢来窥品格。","双鱼岂解传消息。","绿柄嫩香频采摘。","心似织。","条条不断谁牵役。","粉泪暗和清露滴。","罗衣染尽秋江色。","对面不言情脉脉。","烟水隔。","无人说似长相忆。"]},{"id":"c58-128","title":"渔家傲·楚国细腰元自瘦","rhythmic":"渔家傲","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["楚国细腰元自瘦。","文君腻脸谁描就。","日夜声声催箭漏。","昏复昼。","红颜岂得长如旧。","醉折嫩房和蕊嗅。","天丝不断清香透。","却傍小阑凝坐久。","风满袖。","西池月上人归后。"]},{"id":"c58-129","title":"渔家傲·嫩绿堪裁红欲绽","rhythmic":"渔家傲","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["嫩绿堪裁红欲绽。","蜻蜓点水鱼游畔。","一霎雨声香四散。","风飐乱。","高低掩映千千万。","总是凋零终有恨。","能无眼下生留恋。","何似折来妆粉面。","勤看玩。","胜如落尽秋江岸。"]},{"id":"c58-130","title":"雨中花・夜行船·剪翠妆红欲就","rhythmic":"雨中花・夜行船","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["剪翠妆红欲就。","折得清香满袖。","一对鸳鸯眠未足，叶下长相守。","莫傍细条寻嫩藕。","怕绿刺、罥衣伤手。","可惜许、月明风露好，恰在人归后。"]},{"id":"c58-131","title":"瑞鹧鸪·越娥红泪泣朝云","rhythmic":"瑞鹧鸪","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["越娥红泪泣朝云。","越梅从此学妖嚬。","腊月初头、庾岭繁开后，特染妍华赠世人。","前溪昨夜深深雪，朱颜不掩天真。","何时驿使西归，寄与相思客，一枝新。","报道江南别样春。"]},{"id":"c58-132","title":"瑞鹧鸪·江南残腊欲归时","rhythmic":"瑞鹧鸪","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["江南残腊欲归时。","有梅红亚雪中枝。","一夜前村、间破瑶英拆，端的千花冷未知。","丹青改样匀朱粉，雕梁欲画犹疑。","何妨与向冬深，密种秦人路，夹仙溪。","不待妖桃客自迷。"]},{"id":"c58-133","title":"望仙门·紫薇枝上露华浓","rhythmic":"望仙门","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["紫薇枝上露华浓。","起秋风。","管弦声细出帘栊。","象筵中。","仙酒斟云液，仙歌转绕梁虹。","此时佳会庆相逢。","庆相逢。","欢醉且从容。"]},{"id":"c58-134","title":"望仙门·玉壶清漏起微凉","rhythmic":"望仙门","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["玉壶清漏起微凉。","好秋光。","金杯重叠满琼浆。","会仙乡。","新曲调丝管，新声更飐霓裳。","博山炉暖泛浓香。","泛浓香。","为寿百千长。"]},{"id":"c58-135","title":"望仙门·玉池波浪碧如鳞","rhythmic":"望仙门","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["玉池波浪碧如鳞。","露莲新。","清歌一曲翠眉嚬。","舞华茵。","满酌兰英酒，须知献寿千春。","太平无事荷君恩。","荷君恩。","齐唱《望仙门》。"]},{"id":"c58-136","title":"长生乐·玉露金风月正圆","rhythmic":"长生乐","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["玉露金风月正圆。","台榭早凉天。","画堂嘉会，组绣列芳筵。","洞府星辰龟鹤，来添福寿。","欢声喜色，同入金炉泛浓烟。","清歌妙舞，急管繁弦。","榴花满酌觥船。","人尽祝、富贵又长年。","莫教红日西晚，留著醉神仙。"]},{"id":"c58-137","title":"长生乐·阆苑神仙平地见","rhythmic":"长生乐","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["阆苑神仙平地见。","碧海架蓬瀛。","洞门相向，倚金铺微明。","处处天花撩乱，飘散歌声。","装真筵寿，赐与流霞满瑶觥。","红鸾翠节，紫凤银笙。","玉女双来近彩云。","随步朝夕拜三清。","为传王母金箓，祝千岁长生。"]},{"id":"c58-138","title":"蝶恋花·一霎秋风惊画扇","rhythmic":"蝶恋花","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["一霎秋风惊画扇。","艳粉娇红，尚拆荷花面。","草际露垂虫响遍。","珠帘不下留归燕。","扫掠亭台开小院。","四坐清欢，莫放金杯浅。","龟鹤命长松寿远。","阳春一曲情千万。"]},{"id":"c58-139","title":"蝶恋花·紫菊初生朱槿坠","rhythmic":"蝶恋花","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["紫菊初生朱槿坠。","月好风清，渐有中秋意。","更漏乍长天似水。","银屏展尽遥山翠。","绣幕卷波香引穗。","急管繁弦，共庆人间瑞。","满酌玉杯萦舞袂。","南春祝寿千千岁。"]},{"id":"c58-140","title":"蝶恋花·帘幕风轻双语燕","rhythmic":"蝶恋花","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["帘幕风轻双语燕。","午醉醒来，柳絮飞撩乱。","心事一春犹未见。","馀花落尽青苔院。","百尺朱楼闲倚遍。","薄雨浓云，抵死遮人面。","消息未知归早晚。","斜阳只送平波远。"]},{"id":"c58-141","title":"蝶恋花·玉碗冰寒消暑气","rhythmic":"蝶恋花","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["玉碗冰寒消暑气。","碧簟纱厨，向午朦胧睡。","莺舌惺松如会意。","无端画扇惊飞起。","雨后初凉生水际。","人面荷花，的的遥相似。","眼看红芳犹抱蕊。","丛中已结新莲子。"]},{"id":"c58-142","title":"蝶恋花·梨叶疏红蝉韵歇","rhythmic":"蝶恋花","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["梨叶疏红蝉韵歇。","银汉风高，玉管声凄切。","枕簟乍凉铜漏咽。","谁教社燕轻离别。","草际蛩吟珠露结。","宿酒醒来，不记归时节。","多少衷肠犹未说。","朱帘一夜朦胧月。"]},{"id":"c58-143","title":"蝶恋花·南雁依稀回侧阵","rhythmic":"蝶恋花","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["南雁依稀回侧阵。","雪霁墙阴，偏觉兰芽嫩。","中夜梦馀消酒困。","炉香卷穗灯生晕。","急景流年都一瞬。","往事前欢，未免萦方寸。","腊后花期知渐近。","寒梅已作东风信。"]},{"id":"c58-144","title":"拂霓裳·庆生辰","rhythmic":"拂霓裳","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["庆生辰。","庆生辰是百千春。","开雅宴，画堂高会有诸亲。","钿函封大国，玉色受丝纶。","感皇恩。","望九重、天上拜尧云。","今朝祝寿，祝寿数，比松椿。","斟美酒，至心如对月中人。","一声檀板动，一炷蕙香焚。","祷仙真。","愿年年今日、喜长新。"]},{"id":"c58-145","title":"拂霓裳·喜秋成","rhythmic":"拂霓裳","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["喜秋成。","见千门万户乐升平。","金风细，玉池波浪縠文生。","宿露沾罗幕，微凉入画屏。","张绮宴，傍熏炉蕙炷、和新声。","神仙雅会，会此日，象蓬瀛。","管弦清，旋翻红袖学飞琼。","光阴无暂住，欢醉有闲情。","祝辰星。","愿百千为寿、献瑶觥。"]},{"id":"c58-146","title":"拂霓裳·乐秋天","rhythmic":"拂霓裳","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["乐秋天。","晚荷花缀露珠圆。","风日好，数行新雁贴寒烟。","银簧调脆管，琼柱拨清弦。","捧觥船。","一声声、齐唱太平年。","人生百岁，离别易，会逢难。","无事日，剩呼宾友启芳筵。","星霜催绿鬓，风露损朱颜。","惜清欢。","又何妨、沈醉玉尊前。"]},{"id":"c58-147","title":"菩萨蛮·芳莲九蕊开新艳","rhythmic":"菩萨蛮","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["芳莲九蕊开新艳。","轻红淡白匀双脸。","一朵近华堂。","学人宫样妆。","看时斟美酒。","共祝千年寿。","销得曲中夸。","世间无此花。"]},{"id":"c58-148","title":"菩萨蛮·秋花最是黄葵好","rhythmic":"菩萨蛮","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["秋花最是黄葵好。","天然嫩态迎秋早。","染得道家衣。","淡妆梳洗时。","晓来清露滴。","一一金杯侧。","插向绿云鬓。","便随王母仙。"]},{"id":"c58-149","title":"菩萨蛮·人人尽道黄葵淡","rhythmic":"菩萨蛮","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["人人尽道黄葵淡。","侬家解说黄葵艳。","可喜万般宜。","不劳朱粉施。","摘承金盏酒。","劝我千长寿。","擎作女真冠。","试伊娇面看。"]},{"id":"c58-150","title":"菩萨蛮·高梧叶下秋光晚","rhythmic":"菩萨蛮","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["高梧叶下秋光晚。","珍丛化出黄金盏。","还似去年时。","傍阑三两枝。","人情须耐久。","花面长依旧。","莫学蜜蜂儿。","等闲悠扬飞。"]},{"id":"c58-151","title":"秋蕊香·梅蕊雪残香瘦","rhythmic":"秋蕊香","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["梅蕊雪残香瘦。","罗幕轻寒微透。","多情只是春杨柳。","占断可怜时候。","萧娘劝我杯中酒。","翻红袖。","金乌玉兔长飞走。","争得朱颜依旧。"]},{"id":"c58-152","title":"秋蕊香·向晓雪花呈瑞","rhythmic":"秋蕊香","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["向晓雪花呈瑞。","飞遍玉城瑶砌。","何人剪碎天边桂。","散作瑶田琼蕊。","萧娘敛尽双蛾翠。","回香袂。","今朝有酒今朝醉。","遮莫更长无睡。"]},{"id":"c58-153","title":"相思儿令·昨日探春消息","rhythmic":"相思儿令","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["昨日探春消息，湖上绿波平。","无奈绕堤芳草，还向旧痕生。","有酒且醉瑶觥。","更何妨、檀板新声。","谁教杨柳千丝，就中牵系人情。"]},{"id":"c58-154","title":"相思儿令·春色渐芳菲也","rhythmic":"相思儿令","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["春色渐芳菲也，迟日满烟波。","正好艳阳时节，争奈落花何。","醉来拟恣狂歌。","断肠中、赢得愁多。","不如归傍纱窗，有人重画双蛾。"]},{"id":"c58-155","title":"滴滴金·梅花漏泄春消息","rhythmic":"滴滴金","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["梅花漏泄春消息。","柳丝长，草芽碧。","不觉星霜鬓边白。","念时光堪惜。","兰堂把酒留嘉客。","对离筵，驻行色。","千里音尘便疏隔。","合有人相忆。"]},{"id":"c58-156","title":"山亭柳·家住西秦","rhythmic":"山亭柳","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["家住西秦。","赌博艺随身。","花柳上、斗尖新。","偶学念奴声调，有时高遏行云。","蜀锦缠头无数，不负辛勤。","数年来往咸京道，残杯冷炙谩消魂。","衷肠事、托何人。","若有知音见采，不辞遍唱《阳春》。","一曲当筵落泪，重掩罗巾。"]},{"id":"c58-157","title":"睿恩新·芙蓉一朵霜秋色","rhythmic":"睿恩新","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["芙蓉一朵霜秋色。","迎晓露、依依先拆。","似佳人、独立倾城，傍朱槛、暗传消息。","静对西风脉脉。","金蕊绽、粉红如滴。","向兰堂、莫厌重深，免清夜、微寒渐逼。"]},{"id":"c58-158","title":"睿恩新·红丝一曲傍阶砌","rhythmic":"睿恩新","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["红丝一曲傍阶砌。","珠露下、独呈纤丽。","剪鲛绡、碎作香英，分彩线、簇成娇蕊。","向晚群花欲悴。","放朵朵、似延秋意。","待佳人、插向钗头，更袅袅、低临凤髻。"]},{"id":"c58-159","title":"玉堂春·帝城春暖","rhythmic":"玉堂春","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["帝城春暖。","御柳暗遮空苑。","海燕双双，拂扬帘栊。","女伴相携、共绕林间路，折得樱桃插髻红。","昨夜临明微雨，新英遍旧丛。","宝马香车、欲傍西池看，触处杨花满袖风。"]},{"id":"c58-160","title":"玉堂春·后园春早","rhythmic":"玉堂春","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["后园春早。","残雪尚濛烟草。","数树寒梅，欲绽香英。","小妹无端、折尽钗头朵，满把金尊细细倾。","忆得往年同伴，沈吟无限情。","恼乱东风、莫便吹零落，惜取芳菲眼下明。"]},{"id":"c58-161","title":"玉堂春·斗城池馆","rhythmic":"玉堂春","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["斗城池馆。","二月风和烟暖。","绣户珠帘，日影初长。","玉辔金鞍、缭绕沙堤路，几处行人映绿杨。","小槛朱阑回倚，千花浓露香。","脆管清弦、欲奏新翻曲，依约林间坐夕阳。"]},{"id":"c58-162","title":"临江仙·资善堂中三十载","rhythmic":"临江仙","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["资善堂中三十载，旧人多是凋零。","与君相见最伤情。","一尊如旧，聊且话平生。","此别要知须强饮，雪残风细长亭。","待君归觐九重城。","帝宸思旧，朝夕奉皇明。"]},{"id":"c58-163","title":"燕归梁·双燕归飞绕画堂","rhythmic":"燕归梁","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["双燕归飞绕画堂。","似留恋虹梁。","清风明月好时光。","更何况、绮筵张。","云衫侍女，频倾寿酒，加意动笙簧。","人人心在玉炉香。","庆佳会、祝延长。"]},{"id":"c58-164","title":"燕归梁·金鸭香炉起瑞烟","rhythmic":"燕归梁","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["金鸭香炉起瑞烟。","呈妙舞开筵。","阳春一曲动朱弦。","斟美酒、泛觥船。","中秋五日，风清露爽，犹是早凉天。","蟠桃花发一千年。","祝长寿、比神仙。"]},{"id":"c58-165","title":"望汉月・忆汉月·千缕万条堪结","rhythmic":"望汉月・忆汉月","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["千缕万条堪结。","占断好风良月。","谢娘春晚先多愁，更撩乱、絮飞如雪。","短亭相送处，长忆得、醉中攀折。","年年岁岁好时节。","怎奈尚、有人离别。"]},{"id":"c58-166","title":"连理枝·玉字秋风至","rhythmic":"连理枝","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["玉字秋风至。","帘幕生凉气。","朱槿犹开，红莲尚拆，芙蓉含蕊。","送旧巢归燕拂高檐，见梧桐叶坠。","嘉宴凌晨启。","金鸭飘香细。","凤竹鸾丝，清歌妙舞，尽呈游艺。","愿百千遐寿比神仙，有年年岁岁。"]},{"id":"c58-167","title":"连理枝·绿树莺声老","rhythmic":"连理枝","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["绿树莺声老。","金井生秋早。","不寒不暖，裁衣按曲，天时正好。","况兰堂逢著寿筵开，见炉香缥缈。","组绣呈纤巧。","歌舞夸妍妙。","玉酒频倾，朱弦翠管，移宫易调。","献金杯重叠祝长生，永消遥奉道。"]},{"id":"c58-168","title":"破阵子·燕子来时新社","rhythmic":"破阵子","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["燕子来时新社，梨花落后清明。","池上碧苔三四点，叶底黄鹂一两声。","日长飞絮轻。","巧笑东邻女伴，采桑径里逢迎。","疑怪昨宵春梦好，元是今朝斗草赢。","笑从双脸生。"]},{"id":"c58-169","title":"玉楼春·绿杨芳草长亭路","rhythmic":"玉楼春","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["绿杨芳草长亭路。","年少抛人容易去。","楼头残梦五更钟，花底离情三月雨。","无情不似多情苦。","一寸还成千万缕。","天涯地角有穷时，只有相思无尽处。"]},{"id":"c58-170","title":"失调名·芳草连天碧","rhythmic":"失调名","author":"晏殊","authorSlug":"晏殊","dynasty":"宋","kind":"ci","paragraphs":["芳草连天碧。"]},{"id":"c58-171","title":"临江仙·湖水连天天连水","rhythmic":"临江仙","author":"滕宗谅","authorSlug":"滕宗谅","dynasty":"宋","kind":"ci","paragraphs":["湖水连天天连水，秋来分外澄清。","君山自是小蓬瀛。","气蒸云梦泽，波撼岳阳城。","帝子有灵能鼓瑟，凄然依旧伤情。","微闻兰芝动芳馨。","曲终人不见，江上数峰青。"]},{"id":"c58-172","title":"满江红·无利无名","rhythmic":"满江红","author":"张","authorSlug":"张","dynasty":"宋","kind":"ci","paragraphs":["无利无名，无荣无辱，无烦无恼。","夜灯前、独歌独酌，独吟独笑。","况值群山初雪满，又兼明月交光好。","便假饶百岁拟如何，从他老。","知富贵，谁能保。","知功业，何时了。","算箪瓢金玉，所争多少。","一瞬光阴何足道，但思行乐常不早。","待春来携酒殢东风，眠芳草。"]},{"id":"c58-173","title":"离亭燕・离亭宴·一带江山如画","rhythmic":"离亭燕・离亭宴","author":"张","authorSlug":"张","dynasty":"宋","kind":"ci","paragraphs":["一带江山如画。","风物向秋潇洒。","水浸碧天何处断，翠色冷光相射。","蓼岸荻花中，隐映竹篱茅舍。","天际客帆高挂。","门外酒旗低迓。","多少六朝兴废事，尽入渔樵闲话。","怅望倚危栏，红日无言西下。"]},{"id":"c58-174","title":"诉衷情·烧残绛蜡泪成痕","rhythmic":"诉衷情","author":"王益","authorSlug":"王益","dynasty":"宋","kind":"ci","paragraphs":["烧残绛蜡泪成痕。","街鼓报黄昏。","碧云又阻来信，廊上月侵门。","愁永夜，拂香裀。","待谁温。","梦兰憔悴，掷果凄凉，两处销魂。"]},{"id":"c58-175","title":"鹊桥仙·一分素景","rhythmic":"鹊桥仙","author":"石延年","authorSlug":"石延年","dynasty":"宋","kind":"ci","paragraphs":["一分素景，千家新月，凉露楼台遍洗。","宝奁深夜结蛛丝，紝五孔、金针不寐。"]},{"id":"c58-176","title":"燕归梁·芳草年年惹恨幽","rhythmic":"燕归梁","author":"石延年","authorSlug":"石延年","dynasty":"宋","kind":"ci","paragraphs":["芳草年年惹恨幽。","想前事悠悠。","伤春伤别几时休。","算从古、为风流。","春山总把，深匀翠黛，千叠在眉头。","不知供得几多愁。","更斜日、凭危楼。"]},{"id":"c58-177","title":"迷仙引·春阴霁","rhythmic":"迷仙引","author":"关咏","authorSlug":"关咏","dynasty":"宋","kind":"ci","paragraphs":["春阴霁。","岸柳参差，袅袅金丝细。","画阁昼眠莺唤起。","烟光媚。","燕燕双高，引愁人如醉。","慵缓步，眉敛金铺倚。","嘉景易失，懊恼韶光改。","花空委。","忍厌厌地。","施朱粉，临鸾鉴，腻香销减摧桃李。","独自个凝睇。","暮云暗、遥山翠。","天色无情，四远低垂淡如水。","离恨托、征鸿寄。","旋娇波、暗落相思泪。","妆如洗。","向高楼、日日春风里。","悔凭阑、芳草人千里。"]},{"id":"c58-178","title":"水调歌头·六郡酒泉","rhythmic":"水调歌头","author":"刘潜","authorSlug":"刘潜","dynasty":"宋","kind":"ci","paragraphs":["六郡酒泉。"]},{"id":"c58-179","title":"六州歌头·秦亡草昧","rhythmic":"六州歌头","author":"刘潜","authorSlug":"刘潜","dynasty":"宋","kind":"ci","paragraphs":["秦亡草昧，刘项起吞并。","驱龙虎。","鞭寰宇。","斩长鲸。","扫欃枪。","血染彭门战。","视馀耳，皆鹰犬。","平祸乱。","归炎汉。","势奔倾。","兵散月明。","风急旌旗乱，刁斗三更。","命虞姬相对，泣听楚歌声。","玉帐魂惊。","泪盈盈。","恨花无主。","凝愁绪。","挥雪刃，掩泉扃。","时不利。","骓不逝。","困阴陵。","叱追兵。","喑呜摧天地，望归路，忍偷生。","功盖世。","成闲纪。","建遗灵。","江静水寒烟冷，波纹细、古木凋零。","遣行人到此，追念痛伤情。","胜负难凭。"]},{"id":"c58-180","title":"水调歌头·落日塞垣路","rhythmic":"水调歌头","author":"刘潜","authorSlug":"刘潜","dynasty":"宋","kind":"ci","paragraphs":["落日塞垣路，风劲戛貂裘。","翩翩数骑闲猎，深入黑山头。","极目平沙千里，惟见雕弓白羽，铁面骇骅骝。","隐隐望青冢，特地起闲愁。","汉天子，方鼎盛，四百州。","玉颜皓齿，深锁三十六宫秋。","堂有经纶贤相，边有纵横谋将，不作翠蛾羞。","戎虏和乐也，圣主永无忧。"]},{"id":"c58-181","title":"蝶恋花·遥夜亭皋闲信步","rhythmic":"蝶恋花","author":"李冠","authorSlug":"李冠","dynasty":"宋","kind":"ci","paragraphs":["遥夜亭皋闲信步。","才过清明，渐觉伤春暮。","数点雨声风约住。","朦胧淡月云来去。","桃杏依稀香暗渡。","谁在秋千，笑里轻轻语。","一寸相思千万绪。","人间没个安排处。"]},{"id":"c58-182","title":"六州歌头·凄凉绣岭","rhythmic":"六州歌头","author":"李冠","authorSlug":"李冠","dynasty":"宋","kind":"ci","paragraphs":["凄凉绣岭，宫殿倚山阿。","明皇帝。","曾游地。","锁烟萝。","郁嵯峨。","忆惜真妃子。","艳倾国，方姝丽。","朝复暮。","嫔嫱妒。","宠偏颇。","三尺玉泉新浴，莲羞吐、红浸秋波。","听花奴，敲羯鼓，酣奏鸣鼍。","体不胜罗。","舞婆娑。","正霓裳曳。","惊烽燧。","千万骑。","拥雕戈。","情宛转。","魂空乱。","蹙双蛾。","奈兵何。","痛惜三春暮，委妖丽，马嵬坡。","平寇乱。","回宸辇。","忍重过。","香瘗紫囊犹有，鸿都客、钿合应讹。","使行人到此，千古只伤歌。","事往愁多。"]},{"id":"c58-183","title":"六州歌头·秦亡草昧","rhythmic":"六州歌头","author":"李冠","authorSlug":"李冠","dynasty":"宋","kind":"ci","paragraphs":["秦亡草昧，刘项起吞并。","鞭寰宇。","驱龙虎。","扫欃枪。","斩长鲸。","雪染中原战。","视馀耳，皆鹰犬。","平祸乱。","归炎汉。","势奔倾。","兵散月明。","风急旌旗乱，刁斗三更。","共虞姬相对，泣听楚歌声。","玉帐魂惊。","泪盈盈。","念花无主。","凝愁苦。","挥雪刃，掩泉扃。","时不利。","骓不逝。","困阴陵。","叱追兵。","呜喑摧天地，望归路，忍偷生。","功盖世，何处见遗灵。","江静水寒烟冷，波纹钿、古木凋零。","遣行人到此，追念益伤情。","胜负难凭。"]},{"id":"c58-184","title":"蝶恋花·贴鬓香云双绾绿","rhythmic":"蝶恋花","author":"李冠","authorSlug":"李冠","dynasty":"宋","kind":"ci","paragraphs":["贴鬓香云双绾绿。","柳弱花娇，一点春心足。","不肯玉箫闲度曲。","恼人特把青蛾蹙。","静夜溪桥霜薄屋。","独影行歌，惊起双鸾宿。","愁破酒阑闺梦熟。","月斜窗外风敲竹。"]},{"id":"c58-185","title":"千秋万岁・千秋岁引·杏花好","rhythmic":"千秋万岁・千秋岁引","author":"李冠","authorSlug":"李冠","dynasty":"宋","kind":"ci","paragraphs":["杏花好、子细君须辨。","比早梅深、夭桃浅。","把鲛绡、淡拂鲜红面。","蜡融紫萼重重现。","烟外悄，风中笑，香满院。","欲绽全开俱可羡。","粹美妖娆无处选。","除卿卿似寻常见。","倚天真、艳冶轻朱粉，分明洗出胭脂面。","追往事，绕芳榭，千千遍。"]},{"id":"c58-186","title":"菩萨蛮·娟娟侵鬓妆痕浅","rhythmic":"菩萨蛮","author":"谢绛","authorSlug":"谢绛","dynasty":"宋","kind":"ci","paragraphs":["娟娟侵鬓妆痕浅。","双眸相媚弯如翦。","一瞬百般宜。","无论笑与啼。","酒阑思翠被。","特故瞢腾地。","生怕促归轮。","微波先注人。"]},{"id":"c58-187","title":"夜行船·昨夜佳期初共","rhythmic":"夜行船","author":"谢绛","authorSlug":"谢绛","dynasty":"宋","kind":"ci","paragraphs":["昨夜佳期初共。","鬓云低、翠翘金凤。","尊前和笑不成歌，意偷转、眼波微送。","草草不容成楚梦。","渐寒深、翠帘霜重。","相看送到断肠时，月西斜、画楼钟动。"]},{"id":"c58-188","title":"诉衷情·银缸夜永影长孤","rhythmic":"诉衷情","author":"谢绛","authorSlug":"谢绛","dynasty":"宋","kind":"ci","paragraphs":["银缸夜永影长孤。","香草续残炉。","倚屏脉脉无语，粉泪不成珠。","双粲枕，百娇壶。","忆当初。","君恩莫似，秋叶无情，欲向人疏。"]},{"id":"c58-189","title":"失调名·因为衔泥污锦衣","rhythmic":"失调名","author":"宋祁","authorSlug":"宋祁","dynasty":"宋","kind":"ci","paragraphs":["因为衔泥污锦衣。","垂下珠帘不敢归。"]},{"id":"c58-190","title":"浪淘沙近・浪淘沙·少年不管","rhythmic":"浪淘沙近・浪淘沙","author":"宋祁","authorSlug":"宋祁","dynasty":"宋","kind":"ci","paragraphs":["少年不管。","流光如箭。","因循不觉韶光换。","至如今，始惜月满、花满、酒满。","扁舟欲解垂杨岸。","尚同欢宴。","日斜歌阕将分散。","倚兰桡，望水远、天远、人远。"]},{"id":"c58-191","title":"蝶恋花·雨过蒲萄新涨绿","rhythmic":"蝶恋花","author":"宋祁","authorSlug":"宋祁","dynasty":"宋","kind":"ci","paragraphs":["雨过蒲萄新涨绿。","苍玉盘倾，堕碎珠千斛。","姬监拥前红簇簇。","温泉初试真妃浴。","驿使南来丹荔熟。","故翦轻绡，一色颁时服。","娇汗易晞凝醉玉。","青凉不用香绵扑。"]},{"id":"c58-192","title":"玉楼春·东城渐觉风光好","rhythmic":"玉楼春","author":"宋祁","authorSlug":"宋祁","dynasty":"宋","kind":"ci","paragraphs":["东城渐觉风光好。","縠皱波纹迎客棹。","绿杨烟外晓寒轻，红杏枝头春意闹。","浮生长恨欢娱少。","肯爱千金轻一笑。","为君持酒劝斜阳，且向花间留晚照。"]},{"id":"c58-193","title":"蝶恋花·绣幕茫茫罗帐卷","rhythmic":"蝶恋花","author":"宋祁","authorSlug":"宋祁","dynasty":"宋","kind":"ci","paragraphs":["绣幕茫茫罗帐卷。","春睡腾腾，困入娇波慢。","隐隐枕痕留玉脸。","腻云斜溜钗头燕。","远梦无端欢又散。","泪落胭脂，界破蜂黄浅。","整了翠鬟匀了面。","芳心一寸情何限。"]},{"id":"c58-194","title":"鹧鸪天·画毂雕鞍狭路逢","rhythmic":"鹧鸪天","author":"宋祁","authorSlug":"宋祁","dynasty":"宋","kind":"ci","paragraphs":["画毂雕鞍狭路逢。","一声肠断绣帘中。","身无彩凤双飞翼，心有灵犀一点通。","金作屋，玉为笼。","车如流水马游龙。","刘郎已恨蓬山远，更隔蓬山几万重。"]},{"id":"c58-195","title":"好事近·睡起玉屏风","rhythmic":"好事近","author":"宋祁","authorSlug":"宋祁","dynasty":"宋","kind":"ci","paragraphs":["睡起玉屏风，吹去乱红犹落。","天气骤生轻暖，衬沈香帷箔。","珠帘约住海棠风，愁拖两眉角。","昨夜一庭明月，冷秋千红索。"]},{"id":"c58-196","title":"木兰花令·都城水绿嬉游处","rhythmic":"木兰花令","author":"贾昌朝","authorSlug":"贾昌朝","dynasty":"宋","kind":"ci","paragraphs":["都城水绿嬉游处。","仙棹往来人笑语。","红随远浪泛桃花，雪散平堤飞柳絮。","东君欲共春归去。","一阵狂风和骤雨。","碧油红旆锦障泥，斜日画桥芳草路。"]},{"id":"c58-197","title":"水调歌头·万倾太湖上","rhythmic":"水调歌头","author":"尹洙","authorSlug":"尹洙","dynasty":"宋","kind":"ci","paragraphs":["万倾太湖上，朝暮浸寒光。","吴王去后，台榭千古锁悲凉。","谁信蓬山仙子，天与经纶才器，等闲厌名缰。","敛翼下霄汉，雅意在沧浪。","晚秋里，烟寂静，雨微凉。","危亭好景，佳树修竹绕回塘。","不用移舟酌酒，自有青山渌水，掩映似潇湘。","莫问平生意，别有好思量。"]},{"id":"c58-198","title":"苏幕遮·露堤平","rhythmic":"苏幕遮","author":"梅尧臣","authorSlug":"梅尧臣","dynasty":"宋","kind":"ci","paragraphs":["露堤平，烟墅杳。","乱碧萋萋，雨后江天晓。","独有庾郎年最少。","窣地春袍，嫩色宜相照。","接长亭，迷远道。","堪怨王孙，不记归期早。","落尽梨花春又了。","满地残阳，翠色和烟老。"]},{"id":"c58-199","title":"玉楼春·天然不比花含粉","rhythmic":"玉楼春","author":"梅尧臣","authorSlug":"梅尧臣","dynasty":"宋","kind":"ci","paragraphs":["天然不比花含粉。","约月眉黄春色嫩。","小桥低映欲迷人，闲倚东风无奈困。","烟姿最与章台近。","冉冉千丝谁结恨。","狂莺来往恋芳阴，不道风流真能尽。"]}]