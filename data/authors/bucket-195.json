翰","dynasty":"唐","style":"","life":"","origin":"","seal":"哥","bio":["翰，突骑施哥舒之裔，世居安西。初为安西节度使王忠嗣衙将，擢为大斗军副使。拒吐蕃有功，迁陇右节度副使，后代忠嗣知节度事。","天宝末，加河西节度使，封西平郡王。禄山乱，率军守潼关，兵败被执，遂降，后被杀。诗一首。","（《全唐诗》无哥舒翰诗，事迹录《旧唐书》卷一○四本传）"],"works":[{"id":"t52-864","title":"破阵乐","kind":"诗"},{"id":"t52-865","title":"题凤凰山","kind":"诗"}]},"孟不疑":{"slug":"孟不疑","name":"孟不疑","dynasty":"唐","style":"","life":"","origin":"","seal":"孟","bio":[],"works":[{"id":"t43-732","title":"句","kind":"诗"}]},"宣宗宫人":{"slug":"宣宗宫人","name":"宣宗宫人","dynasty":"唐","style":"","life":"","origin":"","seal":"宣","bio":["宣宗宫人，姓韩氏。诗一首。"],"works":[{"id":"t43-753","title":"题红叶","kind":"诗"}]},"张永进":{"slug":"张永进","name":"张永进","dynasty":"唐","style":"号三楚渔人","life":"","origin":"","seal":"张","bio":["永进，自号三楚渔人。金山国老臣。天祐二年在世。","诗二首。（《全唐诗》无张永进诗）"],"works":[{"id":"t54-452","title":"白雀歌（并进表）","kind":"诗"},{"id":"t54-453","title":"颂曰","kind":"诗"}]},"林钟宫":{"slug":"林钟宫","name":"林钟宫","dynasty":"唐","style":"","life":"","origin":"","seal":"林","bio":[],"works":[{"id":"t0-534","title":"郊庙歌辞 祭汾阴乐章 顺和","kind":"诗"}]},"王昌龄":{"slug":"王昌龄","name":"王昌龄","dynasty":"唐","style":"字少伯","life":"","origin":"","seal":"王","bio":["王昌龄，字少伯，京兆人。登开元十五年进士第，补秘书郎。二十二年，中宏词科，调汜水尉，迁江宁丞。","晚节不护细行，贬龙标尉卒。昌龄诗绪密而思清，与高适、王[之涣]涣之齐名，时谓王江宁。集六卷，今编诗四卷。"],"works":[{"id":"t0-933","title":"横吹曲辞 出塞 一","kind":"诗"},{"id":"t0-934","title":"横吹曲辞 出塞 二","kind":"诗"},{"id":"t1-114","title":"相和歌辞 长歌行","kind":"诗"},{"id":"t1-179","title":"相和歌辞 从军行","kind":"诗"},{"id":"t1-180","title":"相和歌辞 从军行 二","kind":"诗"},{"id":"t1-181","title":"相和歌辞 从军行 三","kind":"诗"},{"id":"t1-182","title":"相和歌辞 从军行 四","kind":"诗"},{"id":"t1-252","title":"相和歌辞 放歌行","kind":"诗"},{"id":"t1-341","title":"相和歌辞 长信怨 一","kind":"诗"},{"id":"t1-342","title":"相和歌辞 长信怨 二","kind":"诗"},{"id":"t1-446","title":"相和歌辞 采莲曲三首 一","kind":"诗"},{"id":"t1-447","title":"相和歌辞 采莲曲三首 二","kind":"诗"},{"id":"t1-448","title":"相和歌辞 采莲曲三首 三","kind":"诗"},{"id":"t1-679","title":"杂曲歌辞 少年行二首 一","kind":"诗"},{"id":"t1-680","title":"杂曲歌辞 少年行二首 二","kind":"诗"},{"id":"t1-807","title":"杂曲歌