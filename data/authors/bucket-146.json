9","title":"南溪别业","kind":"诗"},{"id":"t13-500","title":"古意","kind":"诗"},{"id":"t13-501","title":"台中书怀","kind":"诗"},{"id":"t13-502","title":"经埋轮地","kind":"诗"},{"id":"t13-503","title":"山行见鹊巢","kind":"诗"},{"id":"t13-504","title":"巫山之阳香溪之阴明妃神女旧迹存焉","kind":"诗"},{"id":"t13-505","title":"夜飞鹊","kind":"诗"},{"id":"t52-842","title":"古意","kind":"诗"}]},"赵汝愚":{"slug":"赵汝愚","name":"赵汝愚","dynasty":"宋","style":"","life":"","origin":"","seal":"赵","bio":[],"works":[{"id":"c68-718","title":"柳梢青·水月光中","kind":"词"}]},"赵牧":{"slug":"赵牧","name":"赵牧","dynasty":"唐","style":"","life":"","origin":"","seal":"赵","bio":["赵牧，大中、咸通间人，诗一首。"],"works":[{"id":"t31-353","title":"对酒","kind":"诗"}]},"韩思彦":{"slug":"韩思彦","name":"韩思彦","dynasty":"唐","style":"","life":"","origin":"","seal":"韩","bio":["韩思彦，与贺遂亮同官御史。高宗时，待诏弘文馆，上元中卒。诗一首。"],"works":[{"id":"t2-911","title":"酬贺遂亮","kind":"诗"}]}}